mode test

// Test for #47: cross-namespace method calls work correctly.
// Original bug: redeclaring I64 as ext_struct silently overwrote core definition.
// Fix: struct/enum redeclaration now produces an error.

// Cross-namespace calls: calling methods from one type inside another type's namespace
Helper := struct {
    val : I64 = 0
namespace:
    make := func(n: I64) returns Helper {
        return Helper(val = n)
    }
}

Wrapper := struct {
    data : Helper = Helper()
namespace:
    from_int := func(n: I64) returns Wrapper {
        // Cross-namespace call: Helper.make called from Wrapper's namespace
        h := Helper.make(n)
        return Wrapper(data = h)
    }
}

test_cross_namespace := test() {
    w := Wrapper.from_int(42)
    assert_eq(__LOC__, w.data.val, 42)
}

test_cross_namespace_str := test() {
    // Cross-namespace call involving Str methods
    s := Str.with_capacity(10)
    assert_eq(__LOC__, s, "")
}
