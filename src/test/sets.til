mode test

test_i64_set := test() {
    // TODO(#15): dummy references so scavenger keeps cmp/clone/delete methods
    assert_eq(__LOC__, I64.cmp(1, 2), -1)
    assert_eq(__LOC__, 1.clone(), 1)

    s := Set.new("I64", I64.size())
    s.add(own 3)
    s.add(own 1)
    s.add(own 2)
    assert_eq(__LOC__, s.len().to_i64(), 3)
    assert(__LOC__, s.has(1))
    assert(__LOC__, s.has(2))
    assert(__LOC__, s.has(3))
    assert(__LOC__, s.has(4).not())

    // Duplicates ignored
    s.add(own 2)
    assert_eq(__LOC__, s.len().to_i64(), 3)
}

test_str_set := test() {
    // TODO(#15): dummy references so scavenger keeps cmp/clone/delete methods
    assert_eq(__LOC__, Str.cmp("a", "b"), -1)
    assert_eq_str(__LOC__, "hi".clone(), "hi")

    ss := Set.new("Str", Str.size())
    ss.add(own "banana")
    ss.add(own "apple")
    ss.add(own "cherry")
    assert_eq(__LOC__, ss.len().to_i64(), 3)
    assert(__LOC__, ss.has("apple"))
    assert(__LOC__, ss.has("banana"))
    assert(__LOC__, ss.has("cherry"))
    assert(__LOC__, ss.has("date").not())
    ss.add(own "apple")
    assert_eq(__LOC__, ss.len().to_i64(), 3)
}

// --- Set literal tests ---

test_set_literal_i64 := test() {
    // TODO(#15): dummy references so scavenger keeps cmp/clone/delete methods
    assert_eq(__LOC__, I64.cmp(1, 2), -1)
    assert_eq(__LOC__, 1.clone(), 1)

    s := {3, 1, 2}
    assert_eq(__LOC__, s.len().to_i64(), 3)
    assert(__LOC__, s.has(1))
    assert(__LOC__, s.has(2))
    assert(__LOC__, s.has(3))
    assert(__LOC__, s.has(4).not())
}

test_set_literal_str := test() {
    // TODO(#15): dummy references so scavenger keeps cmp/clone/delete methods
    assert_eq(__LOC__, Str.cmp("a", "b"), -1)
    assert_eq_str(__LOC__, "hi".clone(), "hi")

    s := {"apple", "banana", "cherry"}
    assert_eq(__LOC__, s.len().to_i64(), 3)
    assert(__LOC__, s.has("apple"))
    assert(__LOC__, s.has("banana"))
    assert(__LOC__, s.has("cherry"))
    assert(__LOC__, s.has("date").not())
}
