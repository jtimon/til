mode test

test_i64 := test() {
    assert(__LOC__, 1.lt(2))
    assert(__LOC__, 2.gt(1))
    assert(__LOC__, 1.lte(1))
    assert(__LOC__, 1.lte(2))
    assert(__LOC__, 2.gte(2))
    assert(__LOC__, 2.gte(1))
    assert(__LOC__, 1.neq(2))
    assert(__LOC__, 1.eq(1))
}

test_u8 := test() {
    u1 : U8 = 10
    u2 : U8 = 20
    assert(__LOC__, u1.lt(u2))
    assert(__LOC__, u2.gt(u1))
    assert(__LOC__, u1.lte(u1))
    assert(__LOC__, u2.gte(u1))
    assert(__LOC__, u1.neq(u2))
}

test_str := test() {
    assert(__LOC__, "apple".lt("banana"))
    assert(__LOC__, "banana".gt("apple"))
    assert(__LOC__, "hello".lte("hello"))
    assert(__LOC__, "hello".gte("hello"))
    assert(__LOC__, "a".lte("b"))
    assert(__LOC__, "b".gte("a"))
    assert(__LOC__, "hello".eq("hello"))
    assert(__LOC__, "hello".neq("world"))
}

test_bool := test() {
    assert(__LOC__, true.eq(true))
    assert(__LOC__, false.eq(false))
    assert(__LOC__, true.neq(false))
    assert(__LOC__, true.gt(false))
    assert(__LOC__, false.lt(true))
}

Point := struct {
    mut x := 0
    mut y := 0
}

Line := struct {
    mut start := Point()
    mut end := Point()
    namespace:
    length_sq := func(self: Line) returns I64 {
        dx := self.end.x.sub(self.start.x)
        dy := self.end.y.sub(self.start.y)
        return dx.mul(dx).add(dy.mul(dy))
    }
    cmp := func(a: Line, b: Line) returns I64 {
        return a.length_sq().cmp(b.length_sq())
    }
}

test_line := test() {
    s := Line(end=Point(x=3, y=4))    // length_sq = 25
    l := Line(end=Point(x=6, y=8))   // length_sq = 100
    same := Line(end=Point(x=4, y=3))  // length_sq = 25

    assert(__LOC__, s.lt(l))
    assert(__LOC__, l.gt(s))
    assert(__LOC__, s.eq(same))
    assert(__LOC__, s.lte(same))
    assert(__LOC__, s.gte(same))
    assert(__LOC__, s.lte(l))
    assert(__LOC__, l.gte(s))
    assert(__LOC__, s.neq(l))
}
