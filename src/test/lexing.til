mode script

import("../self/lexer.til")

check_tok := proc(tokens: Vec, i: I64, expected_type: TokenType, expected_text: Str) {
    ref t : Token = tokens.get(i.to_u64())
    tt := t.type
    test_expect(__LOC__, tt.eq(expected_type),
        "token ", i.to_str(), " type: expected ", expected_type.to_str(),
        " got ", tt.to_str())
    assert_eq_str(__LOC__, t.text, expected_text)
}

test_empty := proc() {
    tokens := tokenize("", "test")
    assert_eq(__LOC__, tokens.len().to_i64(), 1)
    check_tok(tokens, 0, TokenType.Eof, "")
}

test_singles := proc() {
    tokens := tokenize("( ) { } [ ] , : . ? ! + - * /", "test")
    check_tok(tokens, 0, TokenType.LParen, "(")
    check_tok(tokens, 1, TokenType.RParen, ")")
    check_tok(tokens, 2, TokenType.LBrace, "{")
    check_tok(tokens, 3, TokenType.RBrace, "}")
    check_tok(tokens, 4, TokenType.LBracket, "[")
    check_tok(tokens, 5, TokenType.RBracket, "]")
    check_tok(tokens, 6, TokenType.Comma, ",")
    check_tok(tokens, 7, TokenType.Colon, ":")
    check_tok(tokens, 8, TokenType.Dot, ".")
    check_tok(tokens, 9, TokenType.Question, "?")
    check_tok(tokens, 10, TokenType.Bang, "!")
    check_tok(tokens, 11, TokenType.Plus, "+")
    check_tok(tokens, 12, TokenType.Minus, "-")
    check_tok(tokens, 13, TokenType.Star, "*")
    check_tok(tokens, 14, TokenType.Slash, "/")
    check_tok(tokens, 15, TokenType.Eof, "")
}

test_two_char := proc() {
    tokens := tokenize(":= == != <= >= ..", "test")
    check_tok(tokens, 0, TokenType.ColonEq, ":=")
    check_tok(tokens, 1, TokenType.EqEq, "==")
    check_tok(tokens, 2, TokenType.Neq, "!=")
    check_tok(tokens, 3, TokenType.LtEq, "<=")
    check_tok(tokens, 4, TokenType.GtEq, ">=")
    check_tok(tokens, 5, TokenType.DotDot, "..")
    check_tok(tokens, 6, TokenType.Eof, "")
}

test_keywords := proc() {
    tokens := tokenize("if else while return func proc struct enum test", "test")
    check_tok(tokens, 0, TokenType.KwIf, "if")
    check_tok(tokens, 1, TokenType.KwElse, "else")
    check_tok(tokens, 2, TokenType.KwWhile, "while")
    check_tok(tokens, 3, TokenType.KwReturn, "return")
    check_tok(tokens, 4, TokenType.KwFunc, "func")
    check_tok(tokens, 5, TokenType.KwProc, "proc")
    check_tok(tokens, 6, TokenType.KwStruct, "struct")
    check_tok(tokens, 7, TokenType.KwEnum, "enum")
    check_tok(tokens, 8, TokenType.KwTest, "test")
}

test_more_keywords := proc() {
    tokens := tokenize("mode mut own ref shallow returns throws for in break continue defer null", "test")
    check_tok(tokens, 0, TokenType.KwMode, "mode")
    check_tok(tokens, 1, TokenType.KwMut, "mut")
    check_tok(tokens, 2, TokenType.KwOwn, "own")
    check_tok(tokens, 3, TokenType.KwRef, "ref")
    check_tok(tokens, 4, TokenType.KwShallow, "shallow")
    check_tok(tokens, 5, TokenType.KwReturns, "returns")
    check_tok(tokens, 6, TokenType.KwThrows, "throws")
    check_tok(tokens, 7, TokenType.KwFor, "for")
    check_tok(tokens, 8, TokenType.KwIn, "in")
    check_tok(tokens, 9, TokenType.KwBreak, "break")
    check_tok(tokens, 10, TokenType.KwContinue, "continue")
    check_tok(tokens, 11, TokenType.KwDefer, "defer")
    check_tok(tokens, 12, TokenType.KwNull, "null")
}

test_statement := proc() {
    tokens := tokenize("x := 42", "test")
    check_tok(tokens, 0, TokenType.Ident, "x")
    check_tok(tokens, 1, TokenType.ColonEq, ":=")
    check_tok(tokens, 2, TokenType.Number, "42")
    check_tok(tokens, 3, TokenType.Eof, "")
}

test_numbers := proc() {
    tokens := tokenize("0 123 3.14", "test")
    check_tok(tokens, 0, TokenType.Number, "0")
    check_tok(tokens, 1, TokenType.Number, "123")
    check_tok(tokens, 2, TokenType.Number, "3.14")
    check_tok(tokens, 3, TokenType.Eof, "")
}

test_line_comment := proc() {
    tokens := tokenize("x // ignored", "test")
    check_tok(tokens, 0, TokenType.Ident, "x")
    check_tok(tokens, 1, TokenType.Eof, "")
}

test_hash_comment := proc() {
    tokens := tokenize("x # ignored", "test")
    check_tok(tokens, 0, TokenType.Ident, "x")
    check_tok(tokens, 1, TokenType.Eof, "")
}

test_tok_name := proc() {
    assert_eq_str(__LOC__, tok_name(TokenType.LParen), "(")
    assert_eq_str(__LOC__, tok_name(TokenType.Ident), "identifier")
    assert_eq_str(__LOC__, tok_name(TokenType.StringTok), "string")
    assert_eq_str(__LOC__, tok_name(TokenType.KwIf), "if")
    assert_eq_str(__LOC__, tok_name(TokenType.KwTest), "test")
    assert_eq_str(__LOC__, tok_name(TokenType.KwShallow), "shallow")
    assert_eq_str(__LOC__, tok_name(TokenType.KwNull), "null")
    assert_eq_str(__LOC__, tok_name(TokenType.Eof), "eof")
}

test_empty()
test_singles()
test_two_char()
test_keywords()
test_more_keywords()
test_statement()
test_numbers()
test_line_comment()
test_hash_comment()
test_tok_name()

println("lexing: ok")
