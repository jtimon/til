mode test

# basic macro with I64 args
macro_add := macro(a: I64, b: I64) returns I64 {
    return a.add(b)
}

test_basic_macro := test() {
    assert_eq(__LOC__, macro_add(3, 4), 7)
}

test_macro_const_arg := test() {
    N := 10
    assert_eq(__LOC__, macro_add(N, 5), 15)
}

# macro returning Str
macro_greet := macro(name: Str) returns Str {
    return "hello ".concat(name)
}

test_macro_str := test() {
    assert_eq_str(__LOC__, macro_greet("world"), "hello world")
}

# macro body can call procs (runs at compile time)
macro_double := macro(x: I64) returns I64 {
    println("precomp: doubling ", x.to_str())
    return x.mul(2)
}

test_macro_proc_call := test() {
    assert_eq(__LOC__, macro_double(21), 42)
}

# macro called from inside a func (with literal arg)
macro_square := macro(x: I64) returns I64 {
    return x.mul(x)
}
square_plus_one := func(dummy: I64) returns I64 {
    s := macro_square(7)
    return s.add(1)
}

test_macro_in_func := test() {
    assert_eq(__LOC__, square_plus_one(0), 50)
}

# macro returning Bool
macro_is_big := macro(x: I64) returns Bool {
    return x.gt(100)
}

test_macro_bool := test() {
    expect(__LOC__, macro_is_big(200), "200 is big")
    expect(__LOC__, macro_is_big(50).not(), "50 is not big")
}

# --- constant folding for pure funcs ---

double := func(x: I64) returns I64 {
    return x.mul(2)
}

test_func_folding := test() {
    assert_eq(__LOC__, double(5), 10)
    assert_eq(__LOC__, double(double(3)), 12)
}

test_func_const_arg := test() {
    K := 7
    assert_eq(__LOC__, double(K), 14)
}

greet := func(name: Str) returns Str {
    return "hi ".concat(name)
}

test_func_str := test() {
    assert_eq_str(__LOC__, greet("til"), "hi til")
}
