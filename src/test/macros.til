mode script

# basic macro with I64 args
macro_add := macro(a: I64, b: I64) returns I64 {
    return a.add(b)
}
assert_eq(loc(), macro_add(3, 4), 7)

# macro with constant (non-mut) arg
N := 10
assert_eq(loc(), macro_add(N, 5), 15)

# macro returning Str
macro_greet := macro(name: Str) returns Str {
    return "hello ".concat(name)
}
assert_eq_str(loc(), macro_greet("world"), "hello world")

# macro body can call procs (runs at compile time)
macro_double := macro(x: I64) returns I64 {
    println("precomp: doubling ", x.to_str())
    return x.mul(2)
}
assert_eq(loc(), macro_double(21), 42)

# macro called from inside a func (with literal arg)
macro_square := macro(x: I64) returns I64 {
    return x.mul(x)
}
square_plus_one := func(dummy: I64) returns I64 {
    s := macro_square(7)
    return s.add(1)
}
assert_eq(loc(), square_plus_one(0), 50)

# macro returning Bool
macro_is_big := macro(x: I64) returns Bool {
    return x.gt(100)
}
test(loc(), macro_is_big(200), "200 is big")
test(loc(), macro_is_big(50).not(), "50 is not big")

# --- constant folding for pure funcs ---

# basic func folding
double := func(x: I64) returns I64 {
    return x.mul(2)
}
assert_eq(loc(), double(5), 10)

# nested folding: double(double(3)) → 12
assert_eq(loc(), double(double(3)), 12)

# func with constant arg
K := 7
assert_eq(loc(), double(K), 14)

# func returning Str
greet := func(name: Str) returns Str {
    return "hi ".concat(name)
}
assert_eq_str(loc(), greet("til"), "hi til")
