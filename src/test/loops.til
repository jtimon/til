mode test

test_for_in_str := test() {
    // Str.get returns ref U8 — type inferred
    mut result := Str.with_capacity(10)
    for c in "hello" {
        result.push_str(Str.from_byte(c))
    }
    assert_eq_str(__LOC__, result, "hello")
}

test_for_in_str_explicit := test() {
    // Explicit type annotation also works
    mut result := Str.with_capacity(10)
    for c : U8 in "world" {
        result.push_str(Str.from_byte(c))
    }
    assert_eq_str(__LOC__, result, "world")
}

test_for_in_vec := test() {
    v := vec("I64", 10, 20, 30)
    mut sum := 0
    for x : I64 in v {
        sum = sum.add(x)
    }
    assert_eq(__LOC__, sum, 60)
}

test_for_in_array := test() {
    a := array("I64", 1, 2, 3, 4, 5)
    mut sum := 0
    for x : I64 in a {
        sum = sum.add(x)
    }
    assert_eq(__LOC__, sum, 15)
}

test_for_in_break := test() {
    mut count := 0
    for c in "abcdef" {
        if count.eq(3) { break }
        count = count.add(1)
    }
    assert_eq(__LOC__, count, 3)
}

test_for_in_continue := test() {
    // Skip 'b' characters
    mut result := Str.with_capacity(10)
    for c in "abcbd" {
        if c.eq('b') { continue }
        result.push_str(Str.from_byte(c))
    }
    assert_eq_str(__LOC__, result, "acd")
}

test_for_in_nested := test() {
    mut count := 0
    for c1 in "ab" {
        for c2 in "xy" {
            count = count.add(1)
        }
    }
    assert_eq(__LOC__, count, 4)
}

test_for_in_empty := test() {
    mut count := 0
    for c in "" {
        count = count.add(1)
    }
    assert_eq(__LOC__, count, 0)

    v := vec("I64")
    mut sum := 0
    for x : I64 in v {
        sum = sum.add(x)
    }
    assert_eq(__LOC__, sum, 0)
}

test_for_in_scope := test() {
    // Loop variable should not leak to outer scope
    // (desugars to anonymous block)
    x := 42
    for c in "abc" {
        // c is scoped inside the block
    }
    assert_eq(__LOC__, x, 42)
}

test_range_ascending := test() {
    mut sum := 0
    for i in 0..5 {
        sum = sum.add(i.to_i64())
    }
    assert_eq(__LOC__, sum, 10)
}

test_range_descending := test() {
    mut sum := 0
    for i in 5..0 {
        sum = sum.add(i.to_i64())
    }
    assert_eq(__LOC__, sum, 15)
}

test_range_empty := test() {
    mut count := 0
    for i in 3..3 {
        count = count.add(1)
    }
    assert_eq(__LOC__, count, 0)
}

test_range_single := test() {
    mut sum := 0
    for i in 0..1 {
        sum = sum.add(i.to_i64())
    }
    assert_eq(__LOC__, sum, 0)
}

test_range_break := test() {
    mut last := 0
    for i in 0..100 {
        if i.eq(5) { break }
        last = i.to_i64()
    }
    assert_eq(__LOC__, last, 4)
}

test_range_continue := test() {
    // Sum only even numbers 0..10
    mut sum := 0
    for i in 0..10 {
        if i.mod(2).neq(0) { continue }
        sum = sum.add(i.to_i64())
    }
    assert_eq(__LOC__, sum, 20)
}

test_range_nested := test() {
    mut sum := 0
    for i in 0..3 {
        for j in 0..4 {
            sum = sum.add(1)
        }
    }
    assert_eq(__LOC__, sum, 12)
}

test_while_basic := test() {
    mut i := 0
    while i.lt(5) {
        i = i.add(1)
    }
    assert_eq(__LOC__, i, 5)
}

test_while_false := test() {
    while false {
        panic(__LOC__, "unreachable")
    }
}

test_while_break := test() {
    mut i := 0
    while true {
        if i.eq(3) { break }
        i = i.add(1)
    }
    assert_eq(__LOC__, i, 3)
}

test_while_continue := test() {
    mut k := 0
    mut total := 0
    while k.lt(5) {
        k = k.add(1)
        if k.eq(3) { continue }
        total = total.add(k)
    }
    assert_eq(__LOC__, total, 12)
}
