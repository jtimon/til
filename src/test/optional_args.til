mode test

minus := func(a: I64, b: I64) returns I64 { return a.sub(b) }

test_named_args := test() {
    assert_eq(loc(), minus(10, 3), 7)
    assert_eq(loc(), minus(a=10, b=3), 7)
    assert_eq(loc(), minus(b=3, a=10), 7)
    assert_eq(loc(), minus(10, b=3), 7)
}

opt_greet := func(name: Str, greeting: Str = "Hello") returns Str {
    return format(greeting, ", ", name, "!")
}

test_optional_args := test() {
    assert_eq_str(loc(), opt_greet("World"), "Hello, World!")
    assert_eq_str(loc(), opt_greet("World", "Hi"), "Hi, World!")
    assert_eq_str(loc(), opt_greet("World", greeting="Hey"), "Hey, World!")
}

opt_make_point := func(x: I64 = 0, y: I64 = 0) returns I64 {
    return x.add(y)
}

test_all_optional := test() {
    assert_eq(loc(), opt_make_point(), 0)
    assert_eq(loc(), opt_make_point(5), 5)
    assert_eq(loc(), opt_make_point(y=7), 7)
    assert_eq(loc(), opt_make_point(5, 10), 15)
    assert_eq(loc(), opt_make_point(y=10, x=5), 15)
}

opt_compute := func(a: I64, b: I64, c: I64 = 10) returns I64 {
    return a.add(b).add(c)
}

test_mixed_required_optional := test() {
    assert_eq(loc(), opt_compute(1, 2), 13)
    assert_eq(loc(), opt_compute(1, 2, 3), 6)
    assert_eq(loc(), opt_compute(1, 2, c=20), 23)
}
