mode test

// Test universal UFCS: a.f(b) resolves to top-level f(a, b)

double := func(x: I64) returns I64 { return x.mul(2) }

test_basic := test() {
    assert(loc(), 5.double().eq(10))
    assert(loc(), 0.double().eq(0))
}

test_println := test() {
    "hello from ufcs".println()
}

test_format := test() {
    s := "result: ".format(42.to_str())
    assert(loc(), s.eq("result: 42"))
}

greet := func(name: Str) returns Str {
    return "hello, ".format(name)
}

test_user_func := test() {
    s := "world".greet()
    assert(loc(), s.eq("hello, world"))
}
