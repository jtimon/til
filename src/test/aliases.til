mode test

# === Variable aliases (auto-ref) ===

test_i64_alias := test() {
    x := 42
    y := x
    assert_eq(__LOC__, y, 42)
}

test_str_alias := test() {
    s := "hello"
    t := s
    assert_eq_str(__LOC__, t, "hello")
}

test_bool_alias := test() {
    a := true
    b := a
    assert(__LOC__, b)
}

Point := struct {
    x := 0
    y := 0
}

test_struct_alias := test() {
    p := Point(x = 10, y = 20)
    q := p
    assert_eq(__LOC__, q.x, 10)
    assert_eq(__LOC__, q.y, 20)
}

test_mut_source_clones := test() {
    mut x := 42
    y := x
    x = 99
    assert_eq(__LOC__, y, 42)
}

test_mut_dest_clones := test() {
    x := 42
    mut y := x
    y = 99
    assert_eq(__LOC__, x, 42)
}

test_multiple_aliases := test() {
    x := "shared"
    a := x
    b := x
    assert_eq_str(__LOC__, a, "shared")
    assert_eq_str(__LOC__, b, "shared")
}

test_alias_in_if := test() {
    x := 42
    if true {
        y := x
        assert_eq(__LOC__, y, 42)
    }
}

test_alias_in_loop := test() {
    x := "loop"
    for i in 0..3 {
        y := x
        assert_eq_str(__LOC__, y, "loop")
    }
}

test_alias_lifetime := test() {
    x := "first"
    y := x
    assert_eq_str(__LOC__, y, "first")
}

test_alias_chain := test() {
    x := 100
    y := x
    z := y
    assert_eq(__LOC__, z, 100)
}

get_val := func() returns I64 {
    x := 42
    y := x
    return y
}

test_alias_return_clones := test() {
    assert_eq(__LOC__, get_val(), 42)
}

check_param_clones := func(val: I64) returns I64 {
    copy := val
    return copy
}

test_param_clones := test() {
    assert_eq(__LOC__, check_param_clones(77), 77)
}

test_struct_field_clones := test() {
    p := Point(x = 5, y = 10)
    mut v := p.x
    v = 99
    assert_eq(__LOC__, p.x, 5)
}

# === Type aliases: structs ===

Point2 := Point

test_struct_type_alias := test() {
    p := Point2(x=10, y=20)
    assert_eq(__LOC__, p.x, 10)
    assert_eq(__LOC__, p.y, 20)

    q : Point2 = Point2(x=5)
    assert_eq(__LOC__, q.x, 5)

    // Alias and original are interchangeable
    r : Point = Point2(x=1, y=2)
    assert_eq(__LOC__, r.x, 1)
    s : Point2 = Point(x=3, y=4)
    assert_eq(__LOC__, s.x, 3)

    // Clone via alias
    p2 := p.clone()
    assert_eq(__LOC__, p2.x, 10)
}

Line := struct {
    own mut start := Point(x=0, y=0)
    own mut end := Point(x=0, y=0)
}

Line2 := Line

test_nested_struct_alias := test() {
    l := Line2(start=Point(x=1, y=2), end=Point2(x=3, y=4))
    assert_eq(__LOC__, l.start.x, 1)
    assert_eq(__LOC__, l.end.x, 3)
}

# === Type aliases: enums ===

Color := enum { Red, Green, Blue }

Color2 := Color

test_enum_type_alias := test() {
    c := Color2.Red
    expect(__LOC__, c.eq(Color.Red), "alias Red eq original Red")
    expect(__LOC__, c.eq(Color2.Green).not(), "alias Red neq alias Green")
    assert_eq_str(__LOC__, Color2.Blue.to_str(), "Blue")
}

# === Type aliases: primitives ===

USize := U64

add_usize := func(a: USize, b: USize) returns USize {
    return a.add(b)
}

make_vec_usize := func(n: USize) returns Vec {
    return Vec.new("U64", n)
}

test_primitive_type_alias := test() {
    x : USize = 42
    assert_eq(__LOC__, x.to_i64(), 42)
    y : USize = 100
    assert_eq(__LOC__, x.add(y).to_i64(), 142)
}

test_primitive_alias_in_func := test() {
    assert_eq(__LOC__, add_usize(3, 7).to_i64(), 10)
}

test_primitive_alias_with_container := test() {
    mut v := make_vec_usize(I64.size())
    v.push(own 42)
    assert_eq(__LOC__, v.len().to_i64(), 1)
}

# === Type aliases: function signatures ===

BinaryOp := func(I64, I64) returns I64

fn_add := func(a: I64, b: I64) returns I64 { return a.add(b) }

Callback := BinaryOp

apply_callback := func(cb: Callback, a: I64, b: I64) returns I64 {
    return cb(a, b)
}

test_funcsig_alias := test() {
    assert_eq(__LOC__, apply_callback(fn_add, 3, 5), 8)
    f : Callback = fn_add
    assert_eq(__LOC__, f(10, 20), 30)
}

# === Tests needed for #80 (USize in container definitions) ===

// These verify that a primitive alias works in ALL contexts
// that containers use: struct fields, function params/returns,
// method calls, Vec.new elem_size, etc.

get_usize := func(x: USize) returns USize { return x }

test_alias_passthrough := test() {
    // Alias value passed through function and back
    n : USize = 64
    result := get_usize(n)
    assert_eq(__LOC__, result.to_i64(), 64)
}

test_alias_arithmetic := test() {
    // Alias values support the same methods as the target type
    a : USize = 10
    b : USize = 3
    assert_eq(__LOC__, a.add(b).to_i64(), 13)
    assert_eq(__LOC__, a.sub(b).to_i64(), 7)
    assert_eq(__LOC__, a.mul(b).to_i64(), 30)
}

test_alias_comparison := test() {
    a : USize = 5
    b : USize = 10
    assert(__LOC__, a.lt(b))
    assert(__LOC__, b.gt(a))
    assert(__LOC__, a.eq(a))
}

Sized := struct { mut n : USize = 0 }

test_alias_in_struct_field := test() {
    s := Sized(n = 42)
    assert_eq(__LOC__, s.n.to_i64(), 42)
}

# === Alias in struct with methods (simulates #80 container use case) ===

MySize := U64

MyVec := struct {
    mut count : MySize = 0
    namespace:
    len := func(self: MyVec) returns MySize { return self.count }
    inc := proc(mut self: MyVec) { self.count = self.count.add(1) }
}

test_alias_in_struct_methods := test() {
    mut v := MyVec()
    v.inc()
    v.inc()
    assert_eq(__LOC__, v.len().to_i64(), 2)
}
