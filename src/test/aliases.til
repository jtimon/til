mode test

# Auto-alias: immutable `y := x` becomes implicit ref (no clone)

test_i64_alias := test() {
    x := 42
    y := x
    assert_eq(__LOC__, y, 42)
}

test_str_alias := test() {
    s := "hello"
    t := s
    assert_eq_str(__LOC__, t, "hello")
}

test_bool_alias := test() {
    a := true
    b := a
    assert(__LOC__, b)
}

# Struct alias: field access through alias
Point := struct {
    x := 0
    y := 0
}

test_struct_alias := test() {
    p := Point(x = 10, y = 20)
    q := p
    assert_eq(__LOC__, q.x, 10)
    assert_eq(__LOC__, q.y, 20)
}

# Mut source → clone (not alias): mutating source doesn't affect dest
test_mut_source_clones := test() {
    mut x := 42
    y := x
    x = 99
    assert_eq(__LOC__, y, 42)
}

# Mut dest → clone (not alias): mutating dest doesn't affect source
test_mut_dest_clones := test() {
    x := 42
    mut y := x
    y = 99
    assert_eq(__LOC__, x, 42)
}

# Multiple aliases to the same source
test_multiple_aliases := test() {
    x := "shared"
    a := x
    b := x
    assert_eq_str(__LOC__, a, "shared")
    assert_eq_str(__LOC__, b, "shared")
}

# Alias inside if body
test_alias_in_if := test() {
    x := 42
    if true {
        y := x
        assert_eq(__LOC__, y, 42)
    }
}

# Alias inside while body
test_alias_in_while := test() {
    x := "loop"
    mut i := 0
    while i.lt(3) {
        y := x
        assert_eq_str(__LOC__, y, "loop")
        i = i.add(1)
    }
}

# Alias lifetime: alias used after source's last direct mention
test_alias_lifetime := test() {
    x := "first"
    y := x
    # x is not directly used again, but y (alias of x) is
    assert_eq_str(__LOC__, y, "first")
}

# Alias chaining: y aliases x, z aliases y
test_alias_chain := test() {
    x := 100
    y := x
    z := y
    assert_eq(__LOC__, z, 100)
}

test_alias_chain_str := test() {
    a := "chain"
    b := a
    c := b
    assert_eq_str(__LOC__, c, "chain")
}

# Deep alias chain: x → y (alias) → z (alias) → w (alias)
test_deep_chain := test() {
    x := "deep"
    y := x
    z := y
    w := z
    assert_eq_str(__LOC__, w, "deep")
}

# Returning an alias auto-clones (safe — alias doesn't outlive source)
get_val := func() returns I64 {
    x := 42
    y := x
    return y
}

test_alias_return_clones := test() {
    assert_eq(__LOC__, get_val(), 42)
}

get_str := func() returns Str {
    s := "returned"
    t := s
    return t
}

test_alias_return_str := test() {
    assert_eq_str(__LOC__, get_str(), "returned")
}

# Copying from param produces a clone (not an alias — params excluded)
check_param_clones := func(val: I64) returns I64 {
    copy := val
    return copy
}

test_param_clones := test() {
    assert_eq(__LOC__, check_param_clones(77), 77)
}

# Alias from struct field access still clones (not alias — field access is not NODE_IDENT)
test_struct_field_clones := test() {
    p := Point(x = 5, y = 10)
    mut v := p.x
    v = 99
    assert_eq(__LOC__, p.x, 5)
}
