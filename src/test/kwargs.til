mode test

// #32: Keyword arguments (kwargs) capture

has_key := func(key: Str, opts: ...) returns Bool {
    return opts.has(key)
}

test_basic_kwargs := test() {
    assert(__LOC__, has_key("x", x = 42))
    assert(__LOC__, has_key("color", color = "red").not().not())
}

test_kwargs_missing := test() {
    assert(__LOC__, has_key("missing").not())
}

test_kwargs_multiple := test() {
    assert(__LOC__, has_key("x", x = 10, y = 20))
    assert(__LOC__, has_key("y", x = 10, y = 20))
    assert(__LOC__, has_key("z", x = 10, y = 20).not())
}

greet := func(name: Str, opts: ...) returns Str {
    if opts.has("prefix") {
        ref p : Str = opts.get("prefix")
        return p.clone().format(" ", name)
    }
    return name
}

test_kwargs_str := test() {
    assert_eq_str(__LOC__, greet("World"), "World")
    assert_eq_str(__LOC__, greet("World", prefix = "Hello"), "Hello World")
}

// #188: a kwargs fcall nested inside another kwargs fcall (e.g.
// greet("W", prefix = make_str(greeting = "Hi"))) used to leave the
// inner make_str(greeting = "Hi") raw inside the outer DynMap.set
// value arg, because the typer's process_call_desugars only desugared
// the first kwargs fcall returned by find_kwargs_fcall per stmt --
// the outer one. The builder then emitted the raw kwargs call and
// gcc rejected the args. Twin of #186 on the kwargs path. Fix:
// recurse process_call_desugars on each emitted DynMap.set setter so
// nested kwargs fcalls inside its value arg get their own DynMap.new
// + DynMap.set wrap and rewrite.

bug188_kwargs_nested_in_kwargs := test() {
    assert_eq_str(__LOC__, greet("World", prefix = greet("Hi")), "Hi World")
}

// Mixed-shape coverage: the recursion in process_call_desugars passes
// both has_variadic and has_kwargs through, so a variadic fcall
// inside a kwargs setter (and vice versa) should desugar correctly.
// Lock that in. Same root fix as #186 / #188.
bug188_join := func(parts: ..Str) returns Str {
    mut result := ""
    for i in 0..parts.len() {
        ref p : Str = parts.get(i)
        result = result.concat(p)
    }
    return result
}

bug188_kwargs_variadic_mixed := test() {
    // variadic fcall as a kwargs value arg: outer kwargs setter holds
    // bug188_join(...) whose own variadic args need their own
    // Array.new + Array.set wrap.
    assert_eq_str(__LOC__, greet("World", prefix = bug188_join("a", "b")), "ab World")
    // kwargs fcall as a variadic arg: outer variadic setter holds
    // greet(..., prefix = ...) whose kwargs need their own DynMap.new
    // + DynMap.set wrap.
    assert_eq_str(__LOC__, bug188_join("hi ", greet("Y", prefix = "Mr")), "hi Mr Y")
}

// Sibling-position variant of #186 / #188 on the kwargs path: a stmt
// with multiple SIBLING kwargs fcalls (peers in the same arg list,
// not nested) used to get only the first one desugared because
// find_kwargs_fcall returns the first match. Fix: after rewriting
// a kwargs fcall, recurse process_call_desugars on stmt.
bug189_pair := func(a: Str, b: Str) returns Str {
    return a.clone().format("|", b)
}

bug189_sibling_kwargs := test() {
    // bug189_pair is regular but takes two greet-with-kwargs results --
    // two SIBLINGS in the same arg list.
    assert_eq_str(__LOC__, bug189_pair(greet("X", prefix = "Mr"), greet("Y", prefix = "Ms")), "Mr X|Ms Y")
}

// Mixed-shape siblings: one sibling is a variadic fcall, the other
// is a kwargs fcall. The desugar runs the variadic loop first, then
// the kwargs loop, so each sibling lands in its own pass. Locks in
// that the two while-loops compose correctly when both shapes
// appear at sibling position in the same stmt.
bug189_sibling_mixed_variadic_kwargs := test() {
    assert_eq_str(__LOC__,
        bug189_pair(bug188_join("a", "b"), greet("X", prefix = "Mr")),
        "ab|Mr X")
    // Reverse arg order so the kwargs sibling appears before the
    // variadic one in DFS order.
    assert_eq_str(__LOC__,
        bug189_pair(greet("X", prefix = "Mr"), bug188_join("a", "b")),
        "Mr X|ab")
}

// Combined variadic + kwargs in the SAME function signature
// (Python's `def f(*args, **kwargs)` shape). The parser used to
// reject this outright; the desugar's rewrite_variadic_fcall_args
// now shifts kwargs_index by (1 - variadic_count) when the
// variadic range collapses, so the kwargs handler still finds
// the named args block.
combo_sum := func(_label: Str, items: ..I64, opts: ...) returns I64 {
    mut total := 0
    for i in 0..items.len() {
        ref n : I64 = items.get(i)
        total = total.add(n)
    }
    if opts.has("bias") {
        ref b : I64 = opts.get("bias")
        total = total.add(b)
    }
    return total
}

test_combo_variadic_and_kwargs := test() {
    // Neither variadic nor kwargs args supplied (both ranges empty).
    assert_eq(__LOC__, combo_sum("x"), 0)
    // Variadic only.
    assert_eq(__LOC__, combo_sum("x", 10, 20), 30)
    // Kwargs only.
    assert_eq(__LOC__, combo_sum("x", bias = 50), 50)
    // Both supplied -- the case the parser used to reject.
    assert_eq(__LOC__, combo_sum("x", 1, 2, 3, bias = 100), 106)
    // Multiple kwargs (only "bias" is read, the rest are ignored).
    assert_eq(__LOC__, combo_sum("x", 1, 2, 3, bias = 100, extra = 999), 106)
}
