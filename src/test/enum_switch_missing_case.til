mode test

Color := enum { Red, Green, Blue }
Token := enum { Num: I64, Name: Str, Eof }

# Inner enum for nested-exhaustiveness checks (#200)
Inside := enum { A: I64, B: Str, C }
Outside := enum { Wrap: Inside, Leaf: I64 }

test_missing_simple_case := test() {
    mut result := ""
    switch Color.Green {
    case Color.Red: result = "red"
    case Color.Green: result = "green"
    }
    println(result)
}

test_missing_payload_case := test() {
    mut result := ""
    switch Token.Num(42) {
    case Token.Num(n): result = "num"
    case Token.Eof: result = "eof"
    }
    println(result)
}

# #200: nested patterns must cover every sub-variant or use a binding/default.
test_missing_nested_inner := test() {
    val := Outside.Wrap(Inside.A(1))
    mut r := 0
    switch val {
    case Outside.Wrap(Inside.A(v)): r = v
    case Outside.Leaf(i):           r = i
    }
    println(r)
}

# #199: a guarded case does not cover its variant -- the guard can fail at
# runtime, so the variant remains a "missing case" without a default arm.
test_missing_guarded_case := test() {
    flag := true
    c := Color.Red
    mut r := ""
    switch c {
    case Color.Red if flag: r = "red-guarded"
    case Color.Green:       r = "green"
    case Color.Blue:        r = "blue"
    }
    println(r)
}
