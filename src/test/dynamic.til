mode test

test_dyn_map_i64 := test() {
    dm := DynMap.new()
    dm.set(own "answer", "I64", I64.size(), own 42)
    dm.set(own "count", "I64", I64.size(), own 7)

    assert_eq(__LOC__, dm.len().to_i64(), 2)
    assert(__LOC__, dm.has("answer"))
    assert(__LOC__, dm.has("count"))
    assert(__LOC__, dm.has("missing").not())

    ref v0 : I64 = dm.get("answer")
    ref v1 : I64 = dm.get("count")
    assert_eq(__LOC__, v0, 42)
    assert_eq(__LOC__, v1, 7)

    ref t0 : Str = dm.type_at("answer")
    ref s0 : USize = dm.size_at("answer")
    assert_eq_str(__LOC__, t0, "I64")
    assert_eq(__LOC__, s0.to_i64(), 8)
}

test_dyn_map_mixed := test() {
    dm := DynMap.new()
    dm.set(own "name", "Str", Str.size(), own "til")
    dm.set(own "enabled", "Bool", Bool.size(), own true)
    dm.set(own "size", "I64", I64.size(), own 64)

    ref name : Str = dm.get("name")
    ref enabled : Bool = dm.get("enabled")
    ref size : I64 = dm.get("size")

    assert_eq_str(__LOC__, name, "til")
    assert(__LOC__, enabled)
    assert_eq(__LOC__, size, 64)

    ref tn : Str = dm.type_at("name")
    ref tb : Str = dm.type_at("enabled")
    ref ts : Str = dm.type_at("size")
    assert_eq_str(__LOC__, tn, "Str")
    assert_eq_str(__LOC__, tb, "Bool")
    assert_eq_str(__LOC__, ts, "I64")
}

test_dyn_map_overwrite := test() {
    dm := DynMap.new()
    dm.set(own "v", "I64", I64.size(), own 1)
    dm.set(own "v", "Str", Str.size(), own "two")

    assert_eq(__LOC__, dm.len().to_i64(), 1)
    ref v : Str = dm.get("v")
    ref t : Str = dm.type_at("v")
    ref s : USize = dm.size_at("v")
    assert_eq_str(__LOC__, v, "two")
    assert_eq_str(__LOC__, t, "Str")
    assert_eq(__LOC__, s.to_i64(), 16)
}

Foo := struct {
    x := 0
    namespace:
    bar := func(self: Foo) returns I64 { return self.x }
}

test_dyn_has_method := test() {
    // TODO(#15): dummy references so scavenger keeps clone
    assert_eq(__LOC__, 1.clone(), 1)
    assert_eq_str(__LOC__, "hi".clone(), "hi")

    expect(__LOC__, dyn_has_method("I64", "delete"), "I64 has delete")
    expect(__LOC__, dyn_has_method("I64", "clone"), "I64 has clone")
    expect(__LOC__, dyn_has_method("I64", "nonexistent").not(), "I64 no nonexistent")
    expect(__LOC__, dyn_has_method("Str", "delete"), "Str has delete")
    expect(__LOC__, dyn_has_method("Str", "nonexistent").not(), "Str no nonexistent")
    expect(__LOC__, dyn_has_method("Bool", "eq"), "Bool has eq")
    expect(__LOC__, dyn_has_method("Bool", "not").not(), "Bool no not (moved to top-level)")
    f := Foo(x=0)
    assert_eq(__LOC__, f.bar(), 0)
    expect(__LOC__, dyn_has_method("Foo", "bar"), "Foo has bar")
    expect(__LOC__, dyn_has_method("Foo", "baz").not(), "Foo no baz")
}

// Dynamic arg narrowing (#20): pass Dynamic where concrete type expected
test_dynamic_narrowing := test() {
    my_vec := vec("I64", 10, 20, 30)
    ref x2 : I64 = my_vec.get(0)
    assert_eq(__LOC__, x2, 10)
    // Dynamic value as typed argument
    assert_eq(__LOC__, 34.add(my_vec.get(0)), 44)
    // Chaining with typed start: 0.add(Dynamic) returns I64, chain continues
    assert_eq(__LOC__, 0.add(my_vec.get(0)).add(my_vec.get(1)).add(my_vec.get(2)), 60)
    // Top-level UFCS on Dynamic receiver: and/or/not are unique top-level functions
    my_bvec := vec("Bool", true, false)
    assert(__LOC__, my_bvec.get(0).and(my_bvec.get(0)))
    assert(__LOC__, my_bvec.get(1).or(my_bvec.get(0)))
    // TODO(#166): my_bvec.get(1).not() -- Bool values in Vec don't round-trip via chained UFCS (false->true)
}

test_dynamic_local := test() {
    buf : Dynamic = malloc(4)
    assert(__LOC__, is_null(buf).not())
}
