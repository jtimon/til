mode test

Point := struct {
    mut x := 0
    mut y := 0
}

Person := struct {
    mut name := "unknown"
    mut age := 0
}

Flags := struct {
    mut active := false
    mut visible := true
}

Entity := struct {
    id := 0
    mut name := "unnamed"
}

test_basic_struct := test() {
    p := Point()
    assert_eq(__LOC__, p.x, 0)
    assert_eq(__LOC__, p.y, 0)
    p.x = 5
    p.y = 10
    assert_eq(__LOC__, p.x, 5)
    assert_eq(__LOC__, p.y, 10)
}

test_mixed_types := test() {
    bob := Person()
    assert_eq_str(__LOC__, bob.name, "unknown")
    assert_eq(__LOC__, bob.age, 0)
    bob.name = "Bob"
    bob.age = 30
    assert_eq_str(__LOC__, bob.name, "Bob")
    assert_eq(__LOC__, bob.age, 30)
}

test_bool_fields := test() {
    f := Flags()
    assert(__LOC__, f.active.not())
    assert(__LOC__, f.visible)
    f.active = true
    assert(__LOC__, f.active)
}

test_named_args := test() {
    p2 := Point(x=5)
    assert_eq(__LOC__, p2.x, 5)
    assert_eq(__LOC__, p2.y, 0)
    p3 := Point(y=10)
    assert_eq(__LOC__, p3.x, 0)
    assert_eq(__LOC__, p3.y, 10)
    p4 := Point(x=3, y=7)
    assert_eq(__LOC__, p4.x, 3)
    assert_eq(__LOC__, p4.y, 7)
    alice := Person(name="Alice", age=25)
    assert_eq_str(__LOC__, alice.name, "Alice")
    assert_eq(__LOC__, alice.age, 25)
}

test_explicit_annotation := test() {
    p5 : Point = Point()
    assert_eq(__LOC__, p5.x, 0)
    p6 : Point = Point(x=42, y=99)
    assert_eq(__LOC__, p6.x, 42)
    assert_eq(__LOC__, p6.y, 99)
}

test_immutable_fields := test() {
    e1 := Entity(id=1, name="hero")
    assert_eq(__LOC__, e1.id, 1)
    assert_eq_str(__LOC__, e1.name, "hero")
    e1.name = "villain"
    assert_eq_str(__LOC__, e1.name, "villain")
    assert_eq(__LOC__, e1.id, 1)
    e2 := Entity()
    assert_eq(__LOC__, e2.id, 0)
    assert_eq_str(__LOC__, e2.name, "unnamed")
    e3 := Entity(id=99)
    assert_eq(__LOC__, e3.id, 99)
}

test_independence := test() {
    a := Point()
    b := Point()
    a.x = 1
    assert_eq(__LOC__, a.x, 1)
    assert_eq(__LOC__, b.x, 0)
}

Line := struct {
    mut start := Point()
    mut end := Point()
}

test_nested_structs := test() {
    l1 := Line()
    assert_eq(__LOC__, l1.start.x, 0)
    assert_eq(__LOC__, l1.start.y, 0)
    assert_eq(__LOC__, l1.end.x, 0)
    assert_eq(__LOC__, l1.end.y, 0)
    l2 := Line(start=Point(x=1, y=2), end=Point(x=3, y=4))
    assert_eq(__LOC__, l2.start.x, 1)
    assert_eq(__LOC__, l2.start.y, 2)
    assert_eq(__LOC__, l2.end.x, 3)
    assert_eq(__LOC__, l2.end.y, 4)
    l3 := Line(end=Point(x=10))
    assert_eq(__LOC__, l3.start.x, 0)
    assert_eq(__LOC__, l3.end.x, 10)
    l1.start.x = 42
    assert_eq(__LOC__, l1.start.x, 42)
    l1.end.y = 99
    assert_eq(__LOC__, l1.end.y, 99)
    l4 := Line()
    assert_eq(__LOC__, l4.start.x, 0)
}

Counter := struct {
    mut value := 0
    namespace:
    mut instance_count := 0
    default_name := "Counter"
}

test_namespace := test() {
    assert_eq(__LOC__, Counter.instance_count, 0)
    assert_eq_str(__LOC__, Counter.default_name, "Counter")
    Counter.instance_count = 42
    assert_eq(__LOC__, Counter.instance_count, 42)
    c1 := Counter()
    assert_eq(__LOC__, c1.instance_count, 42)
    assert_eq_str(__LOC__, c1.default_name, "Counter")
    Counter.instance_count = 100
    c2 := Counter()
    assert_eq(__LOC__, c2.instance_count, 100)
    assert_eq(__LOC__, c1.instance_count, 100)
    c1.value = 5
    c2.value = 10
    assert_eq(__LOC__, c1.value, 5)
    assert_eq(__LOC__, c2.value, 10)
    assert_eq_str(__LOC__, I64.to_str(42), "42")
    assert_eq_str(__LOC__, Bool.to_str(true), "true")
}

Greeter := struct {
    namespace:
    greet := func(name: Str) returns Str {
        return format("hello, ", name)
    }
}

Describable := struct {
    mut val := 0
    namespace:
    describe := func(d: Describable) returns Str {
        return format("val=", d.val.to_str())
    }
}

test_ufcs := test() {
    x := 42
    assert_eq_str(__LOC__, x.to_str(), "42")
    assert_eq_str(__LOC__, 0.to_str(), "0")
    y := true
    assert_eq_str(__LOC__, y.to_str(), "true")
    assert_eq_str(__LOC__, false.to_str(), "false")
    assert_eq_str(__LOC__, Greeter.greet("world"), "hello, world")
    d := Describable(val=42)
    assert_eq_str(__LOC__, d.describe(), "val=42")
    assert_eq_str(__LOC__, Describable.describe(d), "val=42")
}

test_clone := test() {
    // Clone a simple struct
    p := Point(x=3, y=7)
    p2 := p.clone()
    assert_eq(__LOC__, p2.x, 3)
    assert_eq(__LOC__, p2.y, 7)
    // Mutating original doesn't affect clone
    p.x = 99
    assert_eq(__LOC__, p2.x, 3)
    assert_eq(__LOC__, p.x, 99)

    // Clone a nested struct (Line has Point fields)
    l := Line(start=Point(x=1, y=2), end=Point(x=3, y=4))
    l2 := l.clone()
    assert_eq(__LOC__, l2.start.x, 1)
    assert_eq(__LOC__, l2.end.y, 4)
    l.start.x = 99
    assert_eq(__LOC__, l2.start.x, 1)

    // Clone builtins
    assert_eq(__LOC__, 42.clone(), 42)
    assert_eq_str(__LOC__, "hello".clone(), "hello")
    assert(__LOC__, true.clone())
}

test_delete := test() {
    p := Point(x=3, y=7)
    own p.delete()

    l := Line(start=Point(x=1, y=2), end=Point(x=3, y=4))
    Line.delete(own l)

    x := 42
    own x.delete()
    s := "hello"
    own s.delete()
    b := true
    own b.delete()
}

// Custom clone: adds 1 to val, proving auto-generated clone was skipped
CloneCustom := struct {
    mut val := 0
    namespace:
    clone := func(self: CloneCustom) returns CloneCustom {
        return CloneCustom(val=self.val.add(1))
    }
}

// Custom delete: increments namespace counter, proving auto-generated delete was skipped
DeleteCustom := struct {
    mut id := 0
    namespace:
    mut delete_count := 0
    delete := proc(own self: DeleteCustom, call_free: Bool = true) {
        DeleteCustom.delete_count = DeleteCustom.delete_count.add(1)
        if call_free { free(own self) }
    }
}

test_custom_clone := test() {
    c := CloneCustom(val=5)
    d := c.clone()
    assert_eq(__LOC__, d.val, 6)
    e := d.clone()
    assert_eq(__LOC__, e.val, 7)
}

test_custom_delete := test() {
    assert_eq(__LOC__, DeleteCustom.delete_count, 0)
    t := DeleteCustom(id=1)
    own t.delete()
    assert_eq(__LOC__, DeleteCustom.delete_count, 1)
    t2 := DeleteCustom(id=2)
    own t2.delete()
    assert_eq(__LOC__, DeleteCustom.delete_count, 2)
}

Container := struct {
    mut items := Vec.new("I64", I64.size())
}

test_vec_in_struct := test() {
    c := Container()
    c.items.push(own 10)
    c.items.push(own 20)
    c.items.push(own 30)
    assert_eq(__LOC__, c.items.len(), 3)
    assert_eq(__LOC__, c.items.get(0), 10)
    assert_eq(__LOC__, c.items.get(1), 20)
    assert_eq(__LOC__, c.items.get(2), 30)
}

test_nested_struct_field_mutation := test() {
    l := Line()
    l.start.x = 42
    l.start.y = 99
    assert_eq(__LOC__, l.start.x, 42)
    assert_eq(__LOC__, l.start.y, 99)
    assert_eq(__LOC__, l.end.x, 0)
    assert_eq(__LOC__, l.end.y, 0)
}

test_field_access_copy := test() {
    c := Container()
    c.items.push(own 1)
    c.items.push(own 2)
    copy := c.items
    c.items.push(own 3)
    assert_eq(__LOC__, c.items.len(), 3)
    assert_eq(__LOC__, copy.len(), 2)
}

test_field_reassign := test() {
    bob := Person()
    assert_eq_str(__LOC__, bob.name, "unknown")
    bob.name = "Alice"
    assert_eq_str(__LOC__, bob.name, "Alice")
    bob.name = "Charlie"
    assert_eq_str(__LOC__, bob.name, "Charlie")
}
