mode script

Point := struct {
    mut x := 0
    mut y := 0
}

Person := struct {
    mut name := "unknown"
    mut age := 0
}

Flags := struct {
    mut active := false
    mut visible := true
}

Entity := struct {
    id := 0
    mut name := "unnamed"
}

test_basic_struct := proc() {
    p := Point()
    assert_eq(loc(), p.x, 0)
    assert_eq(loc(), p.y, 0)
    p.x = 5
    p.y = 10
    assert_eq(loc(), p.x, 5)
    assert_eq(loc(), p.y, 10)
}

test_mixed_types := proc() {
    bob := Person()
    assert_eq_str(loc(), bob.name, "unknown")
    assert_eq(loc(), bob.age, 0)
    bob.name = "Bob"
    bob.age = 30
    assert_eq_str(loc(), bob.name, "Bob")
    assert_eq(loc(), bob.age, 30)
}

test_bool_fields := proc() {
    f := Flags()
    assert(loc(), f.active.not())
    assert(loc(), f.visible)
    f.active = true
    assert(loc(), f.active)
}

test_named_args := proc() {
    p2 := Point(x=5)
    assert_eq(loc(), p2.x, 5)
    assert_eq(loc(), p2.y, 0)
    p3 := Point(y=10)
    assert_eq(loc(), p3.x, 0)
    assert_eq(loc(), p3.y, 10)
    p4 := Point(x=3, y=7)
    assert_eq(loc(), p4.x, 3)
    assert_eq(loc(), p4.y, 7)
    alice := Person(name="Alice", age=25)
    assert_eq_str(loc(), alice.name, "Alice")
    assert_eq(loc(), alice.age, 25)
}

test_explicit_annotation := proc() {
    p5 : Point = Point()
    assert_eq(loc(), p5.x, 0)
    p6 : Point = Point(x=42, y=99)
    assert_eq(loc(), p6.x, 42)
    assert_eq(loc(), p6.y, 99)
}

test_immutable_fields := proc() {
    e1 := Entity(id=1, name="hero")
    assert_eq(loc(), e1.id, 1)
    assert_eq_str(loc(), e1.name, "hero")
    e1.name = "villain"
    assert_eq_str(loc(), e1.name, "villain")
    assert_eq(loc(), e1.id, 1)
    e2 := Entity()
    assert_eq(loc(), e2.id, 0)
    assert_eq_str(loc(), e2.name, "unnamed")
    e3 := Entity(id=99)
    assert_eq(loc(), e3.id, 99)
}

test_independence := proc() {
    a := Point()
    b := Point()
    a.x = 1
    assert_eq(loc(), a.x, 1)
    assert_eq(loc(), b.x, 0)
}

Line := struct {
    mut start := Point()
    mut end := Point()
}

test_nested_structs := proc() {
    l1 := Line()
    assert_eq(loc(), l1.start.x, 0)
    assert_eq(loc(), l1.start.y, 0)
    assert_eq(loc(), l1.end.x, 0)
    assert_eq(loc(), l1.end.y, 0)
    l2 := Line(start=Point(x=1, y=2), end=Point(x=3, y=4))
    assert_eq(loc(), l2.start.x, 1)
    assert_eq(loc(), l2.start.y, 2)
    assert_eq(loc(), l2.end.x, 3)
    assert_eq(loc(), l2.end.y, 4)
    l3 := Line(end=Point(x=10))
    assert_eq(loc(), l3.start.x, 0)
    assert_eq(loc(), l3.end.x, 10)
    l1.start.x = 42
    assert_eq(loc(), l1.start.x, 42)
    l1.end.y = 99
    assert_eq(loc(), l1.end.y, 99)
    l4 := Line()
    assert_eq(loc(), l4.start.x, 0)
}

Counter := struct {
    mut value := 0
    namespace:
    mut instance_count := 0
    default_name := "Counter"
}

test_namespace := proc() {
    assert_eq(loc(), Counter.instance_count, 0)
    assert_eq_str(loc(), Counter.default_name, "Counter")
    Counter.instance_count = 42
    assert_eq(loc(), Counter.instance_count, 42)
    c1 := Counter()
    assert_eq(loc(), c1.instance_count, 42)
    assert_eq_str(loc(), c1.default_name, "Counter")
    Counter.instance_count = 100
    c2 := Counter()
    assert_eq(loc(), c2.instance_count, 100)
    assert_eq(loc(), c1.instance_count, 100)
    c1.value = 5
    c2.value = 10
    assert_eq(loc(), c1.value, 5)
    assert_eq(loc(), c2.value, 10)
    assert_eq_str(loc(), I64.to_str(42), "42")
    assert_eq_str(loc(), Bool.to_str(true), "true")
}

Greeter := struct {
    namespace:
    greet := func(name: Str) returns Str {
        return format("hello, ", name)
    }
}

Describable := struct {
    mut val := 0
    namespace:
    describe := func(d: Describable) returns Str {
        return format("val=", d.val.to_str())
    }
}

test_ufcs := proc() {
    x := 42
    assert_eq_str(loc(), x.to_str(), "42")
    assert_eq_str(loc(), 0.to_str(), "0")
    y := true
    assert_eq_str(loc(), y.to_str(), "true")
    assert_eq_str(loc(), false.to_str(), "false")
    assert_eq_str(loc(), Greeter.greet("world"), "hello, world")
    d := Describable(val=42)
    assert_eq_str(loc(), d.describe(), "val=42")
    assert_eq_str(loc(), Describable.describe(d), "val=42")
}

test_clone := proc() {
    // Clone a simple struct
    p := Point(x=3, y=7)
    p2 := p.clone()
    assert_eq(loc(), p2.x, 3)
    assert_eq(loc(), p2.y, 7)
    // Mutating original doesn't affect clone
    p.x = 99
    assert_eq(loc(), p2.x, 3)
    assert_eq(loc(), p.x, 99)

    // Clone a nested struct (Line has Point fields)
    l := Line(start=Point(x=1, y=2), end=Point(x=3, y=4))
    l2 := l.clone()
    assert_eq(loc(), l2.start.x, 1)
    assert_eq(loc(), l2.end.y, 4)
    l.start.x = 99
    assert_eq(loc(), l2.start.x, 1)

    // Clone builtins
    assert_eq(loc(), 42.clone(), 42)
    assert_eq_str(loc(), "hello".clone(), "hello")
    assert(loc(), true.clone())
}

test_delete := proc() {
    p := Point(x=3, y=7)
    p.delete()

    l := Line(start=Point(x=1, y=2), end=Point(x=3, y=4))
    l.delete()

    x := 42
    x.delete()
    s := "hello"
    s.delete()
    b := true
    b.delete()
}

test_basic_struct()
test_mixed_types()
test_bool_fields()
test_named_args()
test_explicit_annotation()
test_immutable_fields()
test_independence()
test_nested_structs()
test_namespace()
test_ufcs()
test_clone()
test_delete()
