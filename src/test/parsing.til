mode script

// ============================================================
// Section 1: Lexer (from lexing.til, without tests)
// ============================================================

TokenType := enum {
    Eof,
    LParen, RParen, LBrace, RBrace, LBracket, RBracket,
    Comma, Colon, Question, Bang,
    Minus, Plus, Star, Slash,
    Dot, DotDot,
    Eq, EqEq, Neq,
    Lt, LtEq, Gt, GtEq,
    ColonEq,
    Ident, StringTok, Number,
    KwMode, KwMut, KwOwn, KwRef,
    KwStruct, KwExtStruct, KwEnum, KwNamespace,
    KwFunc, KwProc, KwMacro, KwExtFunc, KwExtProc,
    KwReturns, KwThrows,
    KwIf, KwElse,
    KwWhile, KwFor, KwIn,
    KwSwitch, KwMatch, KwCase, KwDefault,
    KwReturn, KwThrow, KwCatch,
    KwBreak, KwContinue, KwDefer,
    KwTrue, KwFalse,
    Error,
}

Token := struct {
    type := TokenType.Eof
    text := ""
    line := 0
    col := 0
}

CH_NL     := U8.from_i64(10)
CH_CR     := U8.from_i64(13)
CH_TAB    := U8.from_i64(9)
CH_SPACE  := U8.from_i64(32)
CH_SEMI   := U8.from_i64(59)
CH_HASH   := U8.from_i64(35)
CH_SLASH  := U8.from_i64(47)
CH_STAR   := U8.from_i64(42)
CH_QUOTE  := U8.from_i64(34)
CH_BSLASH := U8.from_i64(92)
CH_DOT    := U8.from_i64(46)
CH_BANG   := U8.from_i64(33)
CH_EQ     := U8.from_i64(61)
CH_LT     := U8.from_i64(60)
CH_GT     := U8.from_i64(62)
CH_COLON  := U8.from_i64(58)
CH_LPAREN := U8.from_i64(40)
CH_RPAREN := U8.from_i64(41)
CH_LBRACE := U8.from_i64(123)
CH_RBRACE := U8.from_i64(125)
CH_LBRACK := U8.from_i64(91)
CH_RBRACK := U8.from_i64(93)
CH_COMMA  := U8.from_i64(44)
CH_QMARK  := U8.from_i64(63)
CH_PLUS   := U8.from_i64(43)
CH_MINUS  := U8.from_i64(45)
CH_UNDER  := U8.from_i64(95)
CH_0      := U8.from_i64(48)
CH_9      := U8.from_i64(57)
CH_A      := U8.from_i64(65)
CH_Z      := U8.from_i64(90)
CH_a      := U8.from_i64(97)
CH_z      := U8.from_i64(122)

is_digit := func(c: U8) returns Bool {
    return c.gte(CH_0).and(c.lte(CH_9))
}

is_alpha := func(c: U8) returns Bool {
    return c.gte(CH_a).and(c.lte(CH_z))
        .or(c.gte(CH_A).and(c.lte(CH_Z)))
        .or(c.eq(CH_UNDER))
}

is_alnum := func(c: U8) returns Bool {
    return is_alpha(c).or(is_digit(c))
}

lookup_keyword := func(word: Str) returns TokenType {
    if word.eq("mode") { return TokenType.KwMode }
    if word.eq("mut") { return TokenType.KwMut }
    if word.eq("own") { return TokenType.KwOwn }
    if word.eq("ref") { return TokenType.KwRef }
    if word.eq("struct") { return TokenType.KwStruct }
    if word.eq("ext_struct") { return TokenType.KwExtStruct }
    if word.eq("enum") { return TokenType.KwEnum }
    if word.eq("namespace") { return TokenType.KwNamespace }
    if word.eq("func") { return TokenType.KwFunc }
    if word.eq("proc") { return TokenType.KwProc }
    if word.eq("macro") { return TokenType.KwMacro }
    if word.eq("ext_func") { return TokenType.KwExtFunc }
    if word.eq("ext_proc") { return TokenType.KwExtProc }
    if word.eq("returns") { return TokenType.KwReturns }
    if word.eq("throws") { return TokenType.KwThrows }
    if word.eq("if") { return TokenType.KwIf }
    if word.eq("else") { return TokenType.KwElse }
    if word.eq("while") { return TokenType.KwWhile }
    if word.eq("for") { return TokenType.KwFor }
    if word.eq("in") { return TokenType.KwIn }
    if word.eq("switch") { return TokenType.KwSwitch }
    if word.eq("match") { return TokenType.KwMatch }
    if word.eq("case") { return TokenType.KwCase }
    if word.eq("default") { return TokenType.KwDefault }
    if word.eq("return") { return TokenType.KwReturn }
    if word.eq("throw") { return TokenType.KwThrow }
    if word.eq("catch") { return TokenType.KwCatch }
    if word.eq("break") { return TokenType.KwBreak }
    if word.eq("continue") { return TokenType.KwContinue }
    if word.eq("defer") { return TokenType.KwDefer }
    if word.eq("true") { return TokenType.KwTrue }
    if word.eq("false") { return TokenType.KwFalse }
    return TokenType.Ident
}

tokenize := proc(source: Str, path: Str) returns Vec {
    mut tokens := Vec.new("Token", Token.size())
    mut pos := 0
    mut line_num := 1
    mut line_start := 0
    src_len := source.len()

    while pos.lt(src_len) {
        ref c : U8 = source.char_at(pos)

        if c.eq(CH_SPACE).or(c.eq(CH_TAB)).or(c.eq(CH_CR)).or(c.eq(CH_SEMI)) {
            pos = pos.add(1)
            continue
        }
        if c.eq(CH_NL) {
            pos = pos.add(1)
            line_num = line_num.add(1)
            line_start = pos
            continue
        }

        col := pos.sub(line_start).add(1)
        start := pos

        if c.eq(CH_HASH) {
            while pos.lt(src_len) {
                if source.char_at(pos).eq(CH_NL) { break }
                pos = pos.add(1)
            }
            continue
        }
        if c.eq(CH_SLASH).and(pos.add(1).lt(src_len)) {
            ref c2 : U8 = source.char_at(pos.add(1))
            if c2.eq(CH_SLASH) {
                while pos.lt(src_len) {
                    if source.char_at(pos).eq(CH_NL) { break }
                    pos = pos.add(1)
                }
                continue
            }
            if c2.eq(CH_STAR) {
                pos = pos.add(2)
                mut depth := 1
                while pos.lt(src_len) {
                    if depth.lte(0) { break }
                    if pos.add(1).lt(src_len) {
                        ref b1 : U8 = source.char_at(pos)
                        ref b2 : U8 = source.char_at(pos.add(1))
                        if b1.eq(CH_SLASH).and(b2.eq(CH_STAR)) {
                            depth = depth.add(1)
                            pos = pos.add(2)
                            continue
                        }
                        if b1.eq(CH_STAR).and(b2.eq(CH_SLASH)) {
                            depth = depth.sub(1)
                            pos = pos.add(2)
                            continue
                        }
                    }
                    if source.char_at(pos).eq(CH_NL) {
                        line_num = line_num.add(1)
                        line_start = pos.add(1)
                    }
                    pos = pos.add(1)
                }
                continue
            }
        }

        if is_digit(c) {
            while pos.lt(src_len) {
                if is_digit(source.char_at(pos)).not() { break }
                pos = pos.add(1)
            }
            if pos.add(1).lt(src_len) {
                if source.char_at(pos).eq(CH_DOT).and(is_digit(source.char_at(pos.add(1)))) {
                    pos = pos.add(1)
                    while pos.lt(src_len) {
                        if is_digit(source.char_at(pos)).not() { break }
                        pos = pos.add(1)
                    }
                }
            }
            tokens.push(own Token(type = TokenType.Number,
                text = source.substr(start, pos.sub(start)),
                line = line_num, col = col))
            continue
        }

        if is_alpha(c) {
            while pos.lt(src_len) {
                if is_alnum(source.char_at(pos)).not() { break }
                pos = pos.add(1)
            }
            word := source.substr(start, pos.sub(start))
            tt := lookup_keyword(word)
            tokens.push(own Token(type = tt, text = word, line = line_num, col = col))
            continue
        }

        if c.eq(CH_QUOTE) {
            pos = pos.add(1)
            while pos.lt(src_len) {
                if source.char_at(pos).eq(CH_QUOTE) { break }
                if source.char_at(pos).eq(CH_BSLASH).and(pos.add(1).lt(src_len)) {
                    pos = pos.add(1)
                }
                if source.char_at(pos).eq(CH_NL) {
                    line_num = line_num.add(1)
                    line_start = pos.add(1)
                }
                pos = pos.add(1)
            }
            if pos.lt(src_len).and(source.char_at(pos).eq(CH_QUOTE)) {
                pos = pos.add(1)
                tokens.push(own Token(type = TokenType.StringTok,
                    text = source.substr(start.add(1), pos.sub(start).sub(2)),
                    line = line_num, col = col))
            } else {
                tokens.push(own Token(type = TokenType.Error,
                    text = source.substr(start, pos.sub(start)),
                    line = line_num, col = col))
            }
            continue
        }

        if pos.add(1).lt(src_len) {
            ref c2 : U8 = source.char_at(pos.add(1))
            mut two := TokenType.Eof
            if c.eq(CH_COLON).and(c2.eq(CH_EQ)) { two = TokenType.ColonEq }
            if c.eq(CH_EQ).and(c2.eq(CH_EQ)) { two = TokenType.EqEq }
            if c.eq(CH_BANG).and(c2.eq(CH_EQ)) { two = TokenType.Neq }
            if c.eq(CH_LT).and(c2.eq(CH_EQ)) { two = TokenType.LtEq }
            if c.eq(CH_GT).and(c2.eq(CH_EQ)) { two = TokenType.GtEq }
            if c.eq(CH_DOT).and(c2.eq(CH_DOT)) { two = TokenType.DotDot }
            if two.eq(TokenType.Eof).not() {
                tokens.push(own Token(type = two,
                    text = source.substr(start, 2),
                    line = line_num, col = col))
                pos = pos.add(2)
                continue
            }
        }

        mut single := TokenType.Eof
        if c.eq(CH_LPAREN) { single = TokenType.LParen }
        if c.eq(CH_RPAREN) { single = TokenType.RParen }
        if c.eq(CH_LBRACE) { single = TokenType.LBrace }
        if c.eq(CH_RBRACE) { single = TokenType.RBrace }
        if c.eq(CH_LBRACK) { single = TokenType.LBracket }
        if c.eq(CH_RBRACK) { single = TokenType.RBracket }
        if c.eq(CH_COMMA) { single = TokenType.Comma }
        if c.eq(CH_COLON) { single = TokenType.Colon }
        if c.eq(CH_DOT) { single = TokenType.Dot }
        if c.eq(CH_QMARK) { single = TokenType.Question }
        if c.eq(CH_BANG) { single = TokenType.Bang }
        if c.eq(CH_PLUS) { single = TokenType.Plus }
        if c.eq(CH_MINUS) { single = TokenType.Minus }
        if c.eq(CH_STAR) { single = TokenType.Star }
        if c.eq(CH_SLASH) { single = TokenType.Slash }
        if c.eq(CH_EQ) { single = TokenType.Eq }
        if c.eq(CH_LT) { single = TokenType.Lt }
        if c.eq(CH_GT) { single = TokenType.Gt }

        if single.eq(TokenType.Eof).not() {
            tokens.push(own Token(type = single,
                text = source.substr(start, 1),
                line = line_num, col = col))
            pos = pos.add(1)
            continue
        }

        tokens.push(own Token(type = TokenType.Error,
            text = source.substr(start, 1),
            line = line_num, col = col))
        pos = pos.add(1)
    }

    col := pos.sub(line_start).add(1)
    tokens.push(own Token(type = TokenType.Eof, text = "", line = line_num, col = col))
    return tokens
}

// ============================================================
// Section 2: Parser data structures
// ============================================================

NodeType := enum {
    Body, LiteralStr, LiteralNum, LiteralBool, Ident,
    Decl, Assign, FCall, FuncDef, StructDef, EnumDef,
    FieldAccess, FieldAssign, Return, If, While, ForIn,
    NamedArg, Break, Continue,
}

FuncType := enum { Func, Proc, Macro, ExtFunc, ExtProc }

NONE := 0.sub(1)

Node := struct {
    type := NodeType.Body
    mut str_val := ""
    mut child_start := 0
    mut child_count := 0
    mut decl_name := ""
    mut decl_type := ""
    mut is_mut := false
    mut is_ref := false
    mut is_own := false
    mut is_ns := false
    mut is_own_arg := false
    mut is_ext := false
    mut func_type := FuncType.Func
    mut param_start := 0
    mut param_count := 0
    mut return_type := ""
    mut return_is_ref := false
    mut variadic_index := 0.sub(1)
    line := 0
    col := 0
}

ParamInfo := struct {
    name := ""
    type_name := ""
    is_mut := false
    is_own := false
    default_node := 0.sub(1)
}

// ============================================================
// Section 3: Pools, helpers, parser primitives
// ============================================================

mut nodes := Vec.new("Node", Node.size())
mut child_pool := Vec.new("I64", 8)
mut param_pool := Vec.new("ParamInfo", ParamInfo.size())

mut p_tokens := Vec.new("Token", Token.size())
mut p_pos := 0
mut p_count := 0
mut p_path := ""

// --- Node pool helpers ---

make_node := proc(nt: NodeType, l: I64, c: I64) returns I64 {
    idx := nodes.len()
    nodes.push(own Node(type = nt, line = l, col = c))
    return idx
}

set_children := proc(ni: I64, children: Vec) {
    ref n : Node = nodes.get(ni)
    n.child_start = child_pool.len()
    n.child_count = children.len()
    mut i := 0
    while i.lt(children.len()) {
        ref cv : I64 = children.get(i)
        val := cv.add(0)
        child_pool.push(own val)
        i = i.add(1)
    }
}

set_child1 := proc(ni: I64, c0: I64) {
    ref n : Node = nodes.get(ni)
    n.child_start = child_pool.len()
    n.child_count = 1
    v0 := c0.add(0)
    child_pool.push(own v0)
}

set_child2 := proc(ni: I64, c0: I64, c1: I64) {
    ref n : Node = nodes.get(ni)
    n.child_start = child_pool.len()
    n.child_count = 2
    v0 := c0.add(0)
    v1 := c1.add(0)
    child_pool.push(own v0)
    child_pool.push(own v1)
}

set_child3 := proc(ni: I64, c0: I64, c1: I64, c2: I64) {
    ref n : Node = nodes.get(ni)
    n.child_start = child_pool.len()
    n.child_count = 3
    v0 := c0.add(0)
    v1 := c1.add(0)
    v2 := c2.add(0)
    child_pool.push(own v0)
    child_pool.push(own v1)
    child_pool.push(own v2)
}

// --- Node accessors ---

node_type := proc(idx: I64) returns NodeType {
    ref n : Node = nodes.get(idx)
    return n.type
}

node_str := proc(idx: I64) returns Str {
    ref n : Node = nodes.get(idx)
    return n.str_val
}

node_child_count := proc(idx: I64) returns I64 {
    ref n : Node = nodes.get(idx)
    return n.child_count
}

node_child := proc(idx: I64, ci: I64) returns I64 {
    ref n : Node = nodes.get(idx)
    ref cv : I64 = child_pool.get(n.child_start.add(ci))
    return cv.add(0)
}

// --- Parser primitives ---

parser_check := proc(tt: TokenType) returns Bool {
    ref t : Token = p_tokens.get(p_pos)
    return t.type.eq(tt)
}

parser_advance := proc() {
    ref t : Token = p_tokens.get(p_pos)
    if t.type.eq(TokenType.Eof).not() {
        p_pos = p_pos.add(1)
    }
}

parser_expect := proc(tt: TokenType) {
    ref t : Token = p_tokens.get(p_pos)
    if t.type.eq(tt).not() {
        msg := "parse error: expected ".concat(tt.to_str()).concat(" found '").concat(t.text).concat("'")
        panic(loc(), msg)
    }
    parser_advance()
}

parse_error := proc(msg: Str) {
    ref t : Token = p_tokens.get(p_pos)
    panic(loc(), msg.concat(" at ").concat(p_path).concat(":").concat(t.line.to_str()).concat(":").concat(t.col.to_str()))
}

// ============================================================
// Section 4: Parser functions
// ============================================================

// Forward-referenced: parse_statement, parse_expression
// In til, forward references just work (typer resolves them)

// --- parse_block ---
// Expects '{' already consumed. Reads statements until '}'

parse_block := proc() returns I64 {
    ref pt : Token = p_tokens.get(p_pos)
    body := make_node(NodeType.Body, pt.line, pt.col)
    mut children := Vec.new("I64", 8)
    while true {
        if parser_check(TokenType.RBrace) { break }
        if parser_check(TokenType.Eof) { break }
        stmt := parse_statement()
        children.push(own stmt)
    }
    parser_expect(TokenType.RBrace)
    set_children(body, children)
    return body
}

// --- parse_func_def ---

parse_func_def := proc() returns I64 {
    ref kw : Token = p_tokens.get(p_pos)
    kw_line := kw.line
    kw_col := kw.col
    kw_type := kw.type
    parser_advance()

    mut ft := FuncType.Func
    if kw_type.eq(TokenType.KwProc) { ft = FuncType.Proc }
    if kw_type.eq(TokenType.KwMacro) { ft = FuncType.Macro }
    if kw_type.eq(TokenType.KwExtFunc) { ft = FuncType.ExtFunc }
    if kw_type.eq(TokenType.KwExtProc) { ft = FuncType.ExtProc }

    parser_expect(TokenType.LParen)

    mut plist := Vec.new("ParamInfo", ParamInfo.size())
    mut variadic_index := NONE
    while true {
        if parser_check(TokenType.RParen) { break }
        if parser_check(TokenType.Eof) { break }

        mut p_is_own := false
        if parser_check(TokenType.KwOwn) {
            parser_advance()
            p_is_own = true
        }
        mut p_is_mut := false
        if parser_check(TokenType.KwMut) {
            parser_advance()
            p_is_mut = true
        }

        ref pname_tok : Token = p_tokens.get(p_pos)
        pname := pname_tok.text
        pname_line := pname_tok.line
        pname_col := pname_tok.col
        parser_expect(TokenType.Ident)
        parser_expect(TokenType.Colon)

        mut is_this_variadic := false
        if parser_check(TokenType.DotDot) {
            parser_advance()
            if p_is_own {
                panic(loc(), "parse error: variadic param cannot be own")
            }
            if p_is_mut {
                panic(loc(), "parse error: variadic param cannot be mut")
            }
            if variadic_index.neq(NONE) {
                panic(loc(), "parse error: only one variadic param allowed")
            }
            variadic_index = plist.len()
            is_this_variadic = true
        }

        ref ptype_tok : Token = p_tokens.get(p_pos)
        ptype := ptype_tok.text
        parser_expect(TokenType.Ident)

        mut def_node := NONE
        if parser_check(TokenType.Eq) {
            parser_advance()
            def_node = parse_expression()
        }

        if variadic_index.neq(NONE) {
            if is_this_variadic.not() {
                if def_node.eq(NONE) {
                    panic(loc(), "parse error: positional param not allowed after variadic")
                }
            }
        }

        plist.push(own ParamInfo(name = pname, type_name = ptype,
            is_mut = p_is_mut, is_own = p_is_own, default_node = def_node))

        if parser_check(TokenType.Comma) { parser_advance() }
    }
    parser_expect(TokenType.RParen)

    mut ret_type := ""
    mut ret_is_ref := false
    if parser_check(TokenType.KwReturns) {
        parser_advance()
        if parser_check(TokenType.KwRef) {
            parser_advance()
            ret_is_ref = true
        }
        ref rt_tok : Token = p_tokens.get(p_pos)
        ret_type = rt_tok.text
        parser_expect(TokenType.Ident)
    }

    def_idx := make_node(NodeType.FuncDef, kw_line, kw_col)
    ref def_n : Node = nodes.get(def_idx)
    def_n.func_type = ft
    def_n.return_type = ret_type
    def_n.return_is_ref = ret_is_ref
    def_n.variadic_index = variadic_index
    def_n.param_start = param_pool.len()
    def_n.param_count = plist.len()

    // Commit params to param_pool
    mut pi := 0
    while pi.lt(plist.len()) {
        ref p : ParamInfo = plist.get(pi)
        param_pool.push(own ParamInfo(name = p.name, type_name = p.type_name,
            is_mut = p.is_mut, is_own = p.is_own, default_node = p.default_node))
        pi = pi.add(1)
    }

    parser_expect(TokenType.LBrace)
    body_idx := parse_block()
    set_child1(def_idx, body_idx)

    return def_idx
}

// --- parse_struct_def ---

parse_struct_def := proc() returns I64 {
    ref kw : Token = p_tokens.get(p_pos)
    kw_line := kw.line
    kw_col := kw.col
    is_ext := kw.type.eq(TokenType.KwExtStruct)
    parser_advance()

    def_idx := make_node(NodeType.StructDef, kw_line, kw_col)
    ref def_n : Node = nodes.get(def_idx)
    def_n.is_ext = is_ext

    parser_expect(TokenType.LBrace)

    ref bt : Token = p_tokens.get(p_pos)
    body_idx := make_node(NodeType.Body, bt.line, bt.col)
    mut children := Vec.new("I64", 8)
    mut in_namespace := false

    while true {
        if parser_check(TokenType.RBrace) { break }
        if parser_check(TokenType.Eof) { break }

        if parser_check(TokenType.KwNamespace) {
            parser_advance()
            parser_expect(TokenType.Colon)
            in_namespace = true
            continue
        }

        stmt := parse_statement()
        if in_namespace {
            if node_type(stmt).eq(NodeType.Decl) {
                ref sn : Node = nodes.get(stmt)
                sn.is_ns = true
            }
        }
        children.push(own stmt)
    }
    parser_expect(TokenType.RBrace)
    set_children(body_idx, children)
    set_child1(def_idx, body_idx)

    return def_idx
}

// --- parse_enum_def ---

parse_enum_def := proc() returns I64 {
    ref kw : Token = p_tokens.get(p_pos)
    kw_line := kw.line
    kw_col := kw.col
    parser_advance()

    def_idx := make_node(NodeType.EnumDef, kw_line, kw_col)

    parser_expect(TokenType.LBrace)

    ref bt : Token = p_tokens.get(p_pos)
    body_idx := make_node(NodeType.Body, bt.line, bt.col)
    mut children := Vec.new("I64", 8)
    mut in_namespace := false

    while true {
        if parser_check(TokenType.RBrace) { break }
        if parser_check(TokenType.Eof) { break }

        if parser_check(TokenType.KwNamespace) {
            parser_advance()
            parser_expect(TokenType.Colon)
            in_namespace = true
            continue
        }

        if in_namespace {
            stmt := parse_statement()
            if node_type(stmt).eq(NodeType.Decl) {
                ref sn : Node = nodes.get(stmt)
                sn.is_ns = true
            }
            children.push(own stmt)
        } else {
            ref vt : Token = p_tokens.get(p_pos)
            v_line := vt.line
            v_col := vt.col
            v_name := vt.text
            parser_expect(TokenType.Ident)

            variant := make_node(NodeType.Decl, v_line, v_col)
            ref vn : Node = nodes.get(variant)
            vn.decl_name = v_name

            if parser_check(TokenType.Colon) {
                parser_advance()
                ref pt : Token = p_tokens.get(p_pos)
                vn.decl_type = pt.text
                parser_expect(TokenType.Ident)
            }

            children.push(own variant)
            if parser_check(TokenType.Comma) { parser_advance() }
        }
    }
    parser_expect(TokenType.RBrace)
    set_children(body_idx, children)
    set_child1(def_idx, body_idx)

    return def_idx
}

// --- parse_call ---
// Name already consumed, current token is '('

parse_call := proc(name: Str, call_line: I64, call_col: I64) returns I64 {
    parser_advance() // consume '('

    // loc() special case
    if name.eq("loc") {
        parser_expect(TokenType.RParen)
        loc_str := format(p_path, ":", call_line.to_str(), ":", call_col.to_str())
        loc_idx := make_node(NodeType.LiteralStr, call_line, call_col)
        ref loc_n : Node = nodes.get(loc_idx)
        loc_n.str_val = loc_str
        return loc_idx
    }

    call_idx := make_node(NodeType.FCall, call_line, call_col)
    mut children := Vec.new("I64", 8)

    // First child: callee identifier
    callee := make_node(NodeType.Ident, call_line, call_col)
    ref cn : Node = nodes.get(callee)
    cn.str_val = name
    children.push(own callee)

    // Parse arguments
    while true {
        if parser_check(TokenType.RParen) { break }
        if parser_check(TokenType.Eof) { break }

        // Named arg: IDENT '=' expr (lookahead)
        mut is_named := false
        if parser_check(TokenType.Ident) {
            if p_pos.add(1).lt(p_count) {
                ref next_tok : Token = p_tokens.get(p_pos.add(1))
                if next_tok.type.eq(TokenType.Eq) {
                    is_named = true
                }
            }
        }

        if is_named {
            ref aname_tok : Token = p_tokens.get(p_pos)
            aname := aname_tok.text
            aname_line := aname_tok.line
            aname_col := aname_tok.col
            parser_advance() // consume ident
            parser_advance() // consume '='
            na_idx := make_node(NodeType.NamedArg, aname_line, aname_col)
            ref na_n : Node = nodes.get(na_idx)
            na_n.str_val = aname
            val_idx := parse_expression()
            set_child1(na_idx, val_idx)
            children.push(own na_idx)
        } else {
            mut arg_is_own := false
            if parser_check(TokenType.KwOwn) {
                parser_advance()
                arg_is_own = true
            }
            arg_idx := parse_expression()
            if arg_is_own {
                ref an : Node = nodes.get(arg_idx)
                an.is_own_arg = true
            }
            children.push(own arg_idx)
        }
        if parser_check(TokenType.Comma) { parser_advance() }
    }
    parser_expect(TokenType.RParen)
    set_children(call_idx, children)

    return call_idx
}

// --- parse_method_args ---
// Shared logic: parse method call args after '(' already consumed

parse_method_args := proc(call_idx: I64, callee_idx: I64) {
    mut children := Vec.new("I64", 8)
    children.push(own callee_idx)

    while true {
        if parser_check(TokenType.RParen) { break }
        if parser_check(TokenType.Eof) { break }

        mut is_named := false
        if parser_check(TokenType.Ident) {
            if p_pos.add(1).lt(p_count) {
                ref next_tok : Token = p_tokens.get(p_pos.add(1))
                if next_tok.type.eq(TokenType.Eq) {
                    is_named = true
                }
            }
        }

        if is_named {
            ref aname_tok : Token = p_tokens.get(p_pos)
            aname := aname_tok.text
            aname_line := aname_tok.line
            aname_col := aname_tok.col
            parser_advance()
            parser_advance()
            na_idx := make_node(NodeType.NamedArg, aname_line, aname_col)
            ref na_n : Node = nodes.get(na_idx)
            na_n.str_val = aname
            val_idx := parse_expression()
            set_child1(na_idx, val_idx)
            children.push(own na_idx)
        } else {
            mut arg_is_own := false
            if parser_check(TokenType.KwOwn) {
                parser_advance()
                arg_is_own = true
            }
            arg_idx := parse_expression()
            if arg_is_own {
                ref an : Node = nodes.get(arg_idx)
                an.is_own_arg = true
            }
            children.push(own arg_idx)
        }
        if parser_check(TokenType.Comma) { parser_advance() }
    }
    parser_expect(TokenType.RParen)
    set_children(call_idx, children)
}

// --- parse_expression ---

parse_expression := proc() returns I64 {
    ref t : Token = p_tokens.get(p_pos)
    t_type := t.type
    t_text := t.text
    t_line := t.line
    t_col := t.col

    mut e := NONE

    if t_type.eq(TokenType.StringTok) {
        parser_advance()
        e = make_node(NodeType.LiteralStr, t_line, t_col)
        ref en : Node = nodes.get(e)
        en.str_val = t_text
    }
    if e.eq(NONE) {
        if t_type.eq(TokenType.Number) {
            parser_advance()
            e = make_node(NodeType.LiteralNum, t_line, t_col)
            ref en : Node = nodes.get(e)
            en.str_val = t_text
        }
    }
    if e.eq(NONE) {
        if t_type.eq(TokenType.KwTrue).or(t_type.eq(TokenType.KwFalse)) {
            parser_advance()
            e = make_node(NodeType.LiteralBool, t_line, t_col)
            ref en : Node = nodes.get(e)
            en.str_val = t_text
        }
    }
    if e.eq(NONE) {
        if t_type.eq(TokenType.Ident) {
            parser_advance()
            if parser_check(TokenType.LParen) {
                e = parse_call(t_text, t_line, t_col)
            } else {
                e = make_node(NodeType.Ident, t_line, t_col)
                ref en : Node = nodes.get(e)
                en.str_val = t_text
            }
        }
    }
    if e.eq(NONE) {
        if t_type.eq(TokenType.KwFunc).or(t_type.eq(TokenType.KwProc))
            .or(t_type.eq(TokenType.KwMacro))
            .or(t_type.eq(TokenType.KwExtFunc)).or(t_type.eq(TokenType.KwExtProc)) {
            return parse_func_def()
        }
    }
    if e.eq(NONE) {
        if t_type.eq(TokenType.KwStruct).or(t_type.eq(TokenType.KwExtStruct)) {
            return parse_struct_def()
        }
    }
    if e.eq(NONE) {
        if t_type.eq(TokenType.KwEnum) {
            return parse_enum_def()
        }
    }
    if e.eq(NONE) {
        parse_error("unexpected token '".concat(t_text).concat("'"))
    }

    // Field access chain: expr.field or expr.method(args)
    while parser_check(TokenType.Dot) {
        parser_advance() // consume '.'
        ref ft : Token = p_tokens.get(p_pos)
        f_text := ft.text
        f_line := ft.line
        f_col := ft.col
        parser_expect(TokenType.Ident)

        if parser_check(TokenType.LParen) {
            // Method call: expr.method(args)
            parser_advance() // consume '('
            callee := make_node(NodeType.FieldAccess, f_line, f_col)
            ref cln : Node = nodes.get(callee)
            cln.str_val = f_text
            set_child1(callee, e)

            call_idx := make_node(NodeType.FCall, f_line, f_col)
            parse_method_args(call_idx, callee)
            e = call_idx
        } else {
            // Field access: expr.field
            access := make_node(NodeType.FieldAccess, f_line, f_col)
            ref an : Node = nodes.get(access)
            an.str_val = f_text
            set_child1(access, e)
            e = access
        }
    }

    return e
}

// --- parse_statement_ident ---

parse_statement_ident := proc(is_mut: Bool, is_own: Bool) returns I64 {
    ref t : Token = p_tokens.get(p_pos)
    t_text := t.text
    t_line := t.line
    t_col := t.col
    parser_advance()

    // Declaration: name := value
    if parser_check(TokenType.ColonEq) {
        parser_advance()
        decl := make_node(NodeType.Decl, t_line, t_col)
        ref dn : Node = nodes.get(decl)
        dn.decl_name = t_text
        dn.is_mut = is_mut
        dn.is_own = is_own
        val := parse_expression()
        set_child1(decl, val)
        return decl
    }

    // Declaration with explicit type: name : Type = value
    if parser_check(TokenType.Colon) {
        parser_advance()
        ref type_tok : Token = p_tokens.get(p_pos)
        type_name := type_tok.text
        parser_advance()
        parser_expect(TokenType.Eq)
        decl := make_node(NodeType.Decl, t_line, t_col)
        ref dn : Node = nodes.get(decl)
        dn.decl_name = t_text
        dn.decl_type = type_name
        dn.is_mut = is_mut
        dn.is_own = is_own
        val := parse_expression()
        set_child1(decl, val)
        return decl
    }

    // Field access/assign or method call: name.field...
    if parser_check(TokenType.Dot) {
        mut obj := make_node(NodeType.Ident, t_line, t_col)
        ref on : Node = nodes.get(obj)
        on.str_val = t_text

        mut last_field_text := ""
        mut last_field_line := 0
        mut last_field_col := 0

        while parser_check(TokenType.Dot) {
            parser_advance() // consume '.'
            ref ft : Token = p_tokens.get(p_pos)
            last_field_text = ft.text
            last_field_line = ft.line
            last_field_col = ft.col
            parser_expect(TokenType.Ident)

            if parser_check(TokenType.Dot) {
                // More dots — intermediate field access
                access := make_node(NodeType.FieldAccess, last_field_line, last_field_col)
                ref an : Node = nodes.get(access)
                an.str_val = last_field_text
                set_child1(access, obj)
                obj = access
            }
        }

        // Method call: name.method(args)
        if parser_check(TokenType.LParen) {
            parser_advance() // consume '('
            callee := make_node(NodeType.FieldAccess, last_field_line, last_field_col)
            ref cln : Node = nodes.get(callee)
            cln.str_val = last_field_text
            set_child1(callee, obj)

            call_idx := make_node(NodeType.FCall, last_field_line, last_field_col)
            parse_method_args(call_idx, callee)
            return call_idx
        }

        // Field assignment: name.field = value
        parser_expect(TokenType.Eq)
        fa := make_node(NodeType.FieldAssign, t_line, t_col)
        ref fan : Node = nodes.get(fa)
        fan.str_val = last_field_text
        val := parse_expression()
        set_child2(fa, obj, val)
        return fa
    }

    // Assignment: name = value
    if parser_check(TokenType.Eq) {
        parser_advance()
        assign := make_node(NodeType.Assign, t_line, t_col)
        ref an : Node = nodes.get(assign)
        an.str_val = t_text
        val := parse_expression()
        set_child1(assign, val)
        return assign
    }

    // Function call: name(...)
    if parser_check(TokenType.LParen) {
        return parse_call(t_text, t_line, t_col)
    }

    parse_error("expected ':=', ':', '=' or '(' after '".concat(t_text).concat("'"))
    return NONE
}

// --- parse_statement ---

parse_statement := proc() returns I64 {
    ref t : Token = p_tokens.get(p_pos)
    t_type := t.type
    t_line := t.line
    t_col := t.col

    if t_type.eq(TokenType.Ident) {
        return parse_statement_ident(false, false)
    }

    if t_type.eq(TokenType.KwRef) {
        parser_advance()
        ref id_tok : Token = p_tokens.get(p_pos)
        id_name := id_tok.text
        id_line := id_tok.line
        id_col := id_tok.col
        parser_expect(TokenType.Ident)

        decl := make_node(NodeType.Decl, id_line, id_col)
        ref dn : Node = nodes.get(decl)
        dn.decl_name = id_name
        dn.is_ref = true

        if parser_check(TokenType.Colon) {
            // ref name : Type = expr
            parser_advance()
            ref type_tok : Token = p_tokens.get(p_pos)
            dn.decl_type = type_tok.text
            parser_advance()
            parser_expect(TokenType.Eq)
        } else {
            // ref name := expr
            parser_expect(TokenType.ColonEq)
        }
        val := parse_expression()
        set_child1(decl, val)
        return decl
    }

    if t_type.eq(TokenType.KwMut) {
        parser_advance()
        return parse_statement_ident(true, false)
    }

    if t_type.eq(TokenType.KwReturn) {
        parser_advance()
        ret := make_node(NodeType.Return, t_line, t_col)
        // If next token looks like a value, parse it
        if parser_check(TokenType.RBrace).not() {
            if parser_check(TokenType.Eof).not() {
                val := parse_expression()
                set_child1(ret, val)
            }
        }
        return ret
    }

    if t_type.eq(TokenType.KwIf) {
        parser_advance()
        node := make_node(NodeType.If, t_line, t_col)
        cond := parse_expression()
        parser_expect(TokenType.LBrace)
        then_body := parse_block()

        if parser_check(TokenType.KwElse) {
            parser_advance()
            if parser_check(TokenType.KwIf) {
                // else if -> else { if ... }
                ref ebt : Token = p_tokens.get(p_pos)
                else_body := make_node(NodeType.Body, ebt.line, ebt.col)
                nested_if := parse_statement()
                set_child1(else_body, nested_if)
                set_child3(node, cond, then_body, else_body)
            } else {
                parser_expect(TokenType.LBrace)
                else_body := parse_block()
                set_child3(node, cond, then_body, else_body)
            }
        } else {
            set_child2(node, cond, then_body)
        }
        return node
    }

    if t_type.eq(TokenType.KwWhile) {
        parser_advance()
        node := make_node(NodeType.While, t_line, t_col)
        cond := parse_expression()
        parser_expect(TokenType.LBrace)
        body := parse_block()
        set_child2(node, cond, body)
        return node
    }

    if t_type.eq(TokenType.LBrace) {
        parser_advance()
        return parse_block()
    }

    if t_type.eq(TokenType.KwOwn) {
        parser_advance()
        // own field declaration: own name := ... or own mut name := ...
        mut own_mut := false
        if parser_check(TokenType.KwMut) {
            own_mut = true
        }

        mut is_decl := false
        if parser_check(TokenType.Ident).or(parser_check(TokenType.KwMut)) {
            if own_mut { parser_advance() }
            if parser_check(TokenType.Ident) {
                if p_pos.add(1).lt(p_count) {
                    ref next_tok : Token = p_tokens.get(p_pos.add(1))
                    if next_tok.type.eq(TokenType.ColonEq).or(next_tok.type.eq(TokenType.Colon)) {
                        is_decl = true
                    }
                }
            }
        }

        if is_decl {
            return parse_statement_ident(own_mut, true)
        }

        if own_mut {
            parse_error("expected identifier after 'own mut'")
        }

        // own expression (call-site ownership marker)
        expr := parse_expression()
        // Walk down to primary and mark is_own_arg
        mut primary := expr
        while true {
            ref pn : Node = nodes.get(primary)
            if pn.child_count.eq(0) { break }
            if pn.type.eq(NodeType.FCall).or(pn.type.eq(NodeType.FieldAccess)) {
                primary = node_child(primary, 0)
            } else {
                break
            }
        }
        ref pn : Node = nodes.get(primary)
        pn.is_own_arg = true
        return expr
    }

    if t_type.eq(TokenType.StringTok).or(t_type.eq(TokenType.Number))
        .or(t_type.eq(TokenType.KwTrue)).or(t_type.eq(TokenType.KwFalse)) {
        return parse_expression()
    }

    if t_type.eq(TokenType.KwBreak) {
        parser_advance()
        return make_node(NodeType.Break, t_line, t_col)
    }

    if t_type.eq(TokenType.KwContinue) {
        parser_advance()
        return make_node(NodeType.Continue, t_line, t_col)
    }

    parse_error("expected statement, found '".concat(t.text).concat("'"))
    return NONE
}

// --- parse (entry point) ---

parse := proc(source: Str, path: Str) returns I64 {
    // Reset pools
    nodes = Vec.new("Node", Node.size())
    child_pool = Vec.new("I64", 8)
    param_pool = Vec.new("ParamInfo", ParamInfo.size())

    // Tokenize
    p_tokens = tokenize(source, path)
    p_pos = 0
    p_count = p_tokens.len()
    p_path = path

    // Skip optional mode declaration
    if parser_check(TokenType.KwMode) {
        parser_advance()
        parser_expect(TokenType.Ident)
    }

    // Parse top-level body
    root := make_node(NodeType.Body, 1, 1)
    mut children := Vec.new("I64", 8)
    while parser_check(TokenType.Eof).not() {
        stmt := parse_statement()
        children.push(own stmt)
    }
    set_children(root, children)
    return root
}

// ============================================================
// Section 5: Tests
// ============================================================

assert_node_type := proc(idx: I64, expected: NodeType) {
    actual := node_type(idx)
    expect(loc(), actual.eq(expected),
        format("node type: expected ", expected.to_str(), " got ", actual.to_str()))
}

assert_node_str := proc(idx: I64, expected: Str) {
    actual := node_str(idx)
    assert_eq_str(loc(), actual, expected)
}

assert_nchildren := proc(idx: I64, expected: I64) {
    actual := node_child_count(idx)
    assert_eq(loc(), actual, expected)
}

// Test: literal number
test_literal_num := proc() {
    root := parse("42", "test")
    assert_nchildren(root, 1)
    stmt := node_child(root, 0)
    assert_node_type(stmt, NodeType.LiteralNum)
    assert_node_str(stmt, "42")
}

// Test: literal string
test_literal_str := proc() {
    QQ := Str.from_byte(CH_QUOTE)
    root := parse(QQ.concat("hello").concat(QQ), "test")
    assert_nchildren(root, 1)
    stmt := node_child(root, 0)
    assert_node_type(stmt, NodeType.LiteralStr)
    assert_node_str(stmt, "hello")
}

// Test: literal bool
test_literal_bool := proc() {
    root := parse("true", "test")
    stmt := node_child(root, 0)
    assert_node_type(stmt, NodeType.LiteralBool)
    assert_node_str(stmt, "true")
}

// Test: declaration
test_decl := proc() {
    root := parse("x := 42", "test")
    assert_nchildren(root, 1)
    decl := node_child(root, 0)
    assert_node_type(decl, NodeType.Decl)
    ref dn : Node = nodes.get(decl)
    assert_eq_str(loc(), dn.decl_name, "x")
    assert_nchildren(decl, 1)
    val := node_child(decl, 0)
    assert_node_type(val, NodeType.LiteralNum)
    assert_node_str(val, "42")
}

// Test: declaration with explicit type
test_decl_typed := proc() {
    root := parse("x : I64 = 42", "test")
    decl := node_child(root, 0)
    assert_node_type(decl, NodeType.Decl)
    ref dn : Node = nodes.get(decl)
    assert_eq_str(loc(), dn.decl_name, "x")
    assert_eq_str(loc(), dn.decl_type, "I64")
}

// Test: assignment
test_assign := proc() {
    root := parse("x := 0; x = 42", "test")
    assert_nchildren(root, 2)
    assign := node_child(root, 1)
    assert_node_type(assign, NodeType.Assign)
    assert_node_str(assign, "x")
    assert_nchildren(assign, 1)
}

// Test: function call
test_fcall := proc() {
    root := parse("foo(1, 2)", "test")
    call := node_child(root, 0)
    assert_node_type(call, NodeType.FCall)
    assert_nchildren(call, 3) // callee + 2 args
    callee := node_child(call, 0)
    assert_node_type(callee, NodeType.Ident)
    assert_node_str(callee, "foo")
    arg1 := node_child(call, 1)
    assert_node_type(arg1, NodeType.LiteralNum)
    assert_node_str(arg1, "1")
    arg2 := node_child(call, 2)
    assert_node_str(arg2, "2")
}

// Test: named args
test_named_args := proc() {
    root := parse("foo(x = 1)", "test")
    call := node_child(root, 0)
    assert_nchildren(call, 2) // callee + 1 named arg
    na := node_child(call, 1)
    assert_node_type(na, NodeType.NamedArg)
    assert_node_str(na, "x")
    assert_nchildren(na, 1)
}

// Test: field access
test_field_access := proc() {
    root2 := parse("x := a.b", "test")
    decl := node_child(root2, 0)
    val := node_child(decl, 0)
    assert_node_type(val, NodeType.FieldAccess)
    assert_node_str(val, "b")
    inner := node_child(val, 0)
    assert_node_type(inner, NodeType.Ident)
    assert_node_str(inner, "a")
}

// Test: method call
test_method_call := proc() {
    root := parse("x.foo(1)", "test")
    call := node_child(root, 0)
    assert_node_type(call, NodeType.FCall)
    callee := node_child(call, 0)
    assert_node_type(callee, NodeType.FieldAccess)
    assert_node_str(callee, "foo")
    inner := node_child(callee, 0)
    assert_node_type(inner, NodeType.Ident)
    assert_node_str(inner, "x")
}

// Test: if statement
test_if := proc() {
    root := parse("if true { x := 1 }", "test")
    if_node := node_child(root, 0)
    assert_node_type(if_node, NodeType.If)
    assert_nchildren(if_node, 2) // cond + then
    cond := node_child(if_node, 0)
    assert_node_type(cond, NodeType.LiteralBool)
}

// Test: if/else
test_if_else := proc() {
    root := parse("if true { x := 1 } else { y := 2 }", "test")
    if_node := node_child(root, 0)
    assert_node_type(if_node, NodeType.If)
    assert_nchildren(if_node, 3) // cond + then + else
}

// Test: while
test_while := proc() {
    root := parse("while true { break }", "test")
    w := node_child(root, 0)
    assert_node_type(w, NodeType.While)
    assert_nchildren(w, 2) // cond + body
    body := node_child(w, 1)
    assert_node_type(body, NodeType.Body)
    brk := node_child(body, 0)
    assert_node_type(brk, NodeType.Break)
}

// Test: func def
test_func_def := proc() {
    root := parse("f := func(a: I64) returns I64 { return a }", "test")
    decl := node_child(root, 0)
    assert_node_type(decl, NodeType.Decl)
    fdef := node_child(decl, 0)
    assert_node_type(fdef, NodeType.FuncDef)
    ref fn : Node = nodes.get(fdef)
    assert_eq(loc(), fn.param_count, 1)
    assert_eq_str(loc(), fn.return_type, "I64")
    // Check body has a return statement
    body := node_child(fdef, 0)
    assert_node_type(body, NodeType.Body)
    ret := node_child(body, 0)
    assert_node_type(ret, NodeType.Return)
}

// Test: struct def
test_struct_def := proc() {
    root := parse("Pt := struct { x := 0; y := 0 }", "test")
    decl := node_child(root, 0)
    sdef := node_child(decl, 0)
    assert_node_type(sdef, NodeType.StructDef)
    body := node_child(sdef, 0)
    assert_node_type(body, NodeType.Body)
    assert_nchildren(body, 2)
}

// Test: enum def
test_enum_def := proc() {
    root := parse("Color := enum { Red, Green, Blue }", "test")
    decl := node_child(root, 0)
    edef := node_child(decl, 0)
    assert_node_type(edef, NodeType.EnumDef)
    body := node_child(edef, 0)
    assert_nchildren(body, 3)
}

// Test: return
test_return := proc() {
    root := parse("f := func() returns I64 { return 42 }", "test")
    decl := node_child(root, 0)
    fdef := node_child(decl, 0)
    body := node_child(fdef, 0)
    ret := node_child(body, 0)
    assert_node_type(ret, NodeType.Return)
    assert_nchildren(ret, 1)
    val := node_child(ret, 0)
    assert_node_type(val, NodeType.LiteralNum)
    assert_node_str(val, "42")
}

// Test: break and continue
test_break_continue := proc() {
    root := parse("while true { break; continue }", "test")
    w := node_child(root, 0)
    body := node_child(w, 1)
    assert_nchildren(body, 2)
    assert_node_type(node_child(body, 0), NodeType.Break)
    assert_node_type(node_child(body, 1), NodeType.Continue)
}

// Test: ref decl
test_ref_decl := proc() {
    root := parse("ref x : I64 = foo()", "test")
    decl := node_child(root, 0)
    assert_node_type(decl, NodeType.Decl)
    ref dn : Node = nodes.get(decl)
    assert_eq_str(loc(), dn.decl_name, "x")
    assert_eq_str(loc(), dn.decl_type, "I64")
    expect(loc(), dn.is_ref, "is_ref")
}

// Test: mut decl
test_mut_decl := proc() {
    root := parse("mut x := 0", "test")
    decl := node_child(root, 0)
    ref dn : Node = nodes.get(decl)
    assert_eq_str(loc(), dn.decl_name, "x")
    expect(loc(), dn.is_mut, "is_mut")
}

// Test: field assignment
test_field_assign := proc() {
    root := parse("a.x = 42", "test")
    fa := node_child(root, 0)
    assert_node_type(fa, NodeType.FieldAssign)
    assert_node_str(fa, "x")
    assert_nchildren(fa, 2) // obj + value
}

// Test: nested expression
test_nested := proc() {
    root := parse("x := a.add(1).sub(2)", "test")
    decl := node_child(root, 0)
    val := node_child(decl, 0)
    // a.add(1).sub(2) is FCall(FieldAccess("sub", FCall(FieldAccess("add", Ident("a")), 1)), 2)
    assert_node_type(val, NodeType.FCall) // .sub(2)
    callee := node_child(val, 0)
    assert_node_type(callee, NodeType.FieldAccess)
    assert_node_str(callee, "sub")
}

// Test: own expression
test_own_expr := proc() {
    root := parse("v.push(own x)", "test")
    call := node_child(root, 0)
    assert_node_type(call, NodeType.FCall)
    // arg should have is_own_arg
    arg := node_child(call, 1)
    ref an : Node = nodes.get(arg)
    expect(loc(), an.is_own_arg, "own arg")
}

// Test: mode declaration
test_mode := proc() {
    root := parse("mode script; x := 1", "test")
    assert_nchildren(root, 1)
    decl := node_child(root, 0)
    assert_node_type(decl, NodeType.Decl)
}

// Run all tests
test_literal_num()
test_literal_str()
test_literal_bool()
test_decl()
test_decl_typed()
test_assign()
test_fcall()
test_named_args()
test_field_access()
test_method_call()
test_if()
test_if_else()
test_while()
test_func_def()
test_struct_def()
test_enum_def()
test_return()
test_break_continue()
test_ref_decl()
test_mut_decl()
test_field_assign()
test_nested()
test_own_expr()
test_mode()

println("parsing: ok")
