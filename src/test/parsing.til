mode script

import("../self/lexer.til")
import("../self/ast.til")
import("../self/parser.til")

// Helper: tokenize + parse
parse_src := proc(src: Str) returns Expr {
    tokens := tokenize(src, "test")
    mut mode_str := ""
    return parse(tokens, "test", mode_str)
}

test_empty := proc() {
    root := parse_src("")
    assert(__LOC__, root.type.eq(NodeType.Body))
    assert_eq(__LOC__, root.children.len(), 0)
}

test_declaration := proc() {
    root := parse_src("x := 42")
    assert_eq(__LOC__, root.children.len(), 1)
    ref decl : Expr =root.children.get(0)
    assert_eq_str(__LOC__, node_type_name(decl.type), "decl")
    // Check decl data
    assert(__LOC__, decl.data.is_Decl())
    dd := decl.data.get_Decl()
    assert_eq_str(__LOC__, dd.name, "x")
    assert_eq_str(__LOC__, dd.explicit_type, "")
    // Check value child
    assert_eq(__LOC__, decl.children.len(), 1)
    ref val : Expr =decl.children.get(0)
    assert_eq_str(__LOC__, node_type_name(val.type), "num")
}

test_typed_decl := proc() {
    root := parse_src("x : I64 = 0")
    ref decl : Expr =root.children.get(0)
    assert(__LOC__, decl.data.is_Decl())
    dd := decl.data.get_Decl()
    assert_eq_str(__LOC__, dd.name, "x")
    assert_eq_str(__LOC__, dd.explicit_type, "I64")
}

test_assignment := proc() {
    root := parse_src("x = 1")
    ref assign : Expr =root.children.get(0)
    assert_eq_str(__LOC__, node_type_name(assign.type), "assign")
    assert(__LOC__, assign.data.is_StrVal())
    assert_eq_str(__LOC__, assign.data.get_StrVal(), "x")
    assert_eq(__LOC__, assign.children.len(), 1)
}

test_call := proc() {
    root := parse_src("foo(1, 2)")
    ref call : Expr =root.children.get(0)
    assert_eq_str(__LOC__, node_type_name(call.type), "fcall")
    // children: [callee_ident, arg1, arg2]
    assert_eq(__LOC__, call.children.len(), 3)
    ref callee : Expr =call.children.get(0)
    assert_eq_str(__LOC__, node_type_name(callee.type), "ident")
    assert_eq_str(__LOC__, callee.data.get_StrVal(), "foo")
}

test_method_call := proc() {
    root := parse_src("x.foo(1)")
    ref call : Expr =root.children.get(0)
    assert_eq_str(__LOC__, node_type_name(call.type), "fcall")
    // children: [callee=FieldAccess, arg]
    assert_eq(__LOC__, call.children.len(), 2)
    ref callee : Expr =call.children.get(0)
    assert_eq_str(__LOC__, node_type_name(callee.type), "field_access")
    assert_eq_str(__LOC__, callee.data.get_StrVal(), "foo")
}

test_if_else := proc() {
    root := parse_src("if true { x = 1 } else { x = 2 }")
    ref node : Expr = root.children.get(0)
    assert_eq_str(__LOC__, node_type_name(node.type), "if")
    assert_eq(__LOC__, node.children.len(), 3)
}

test_while := proc() {
    root := parse_src("while true { x = 1 }")
    ref node : Expr = root.children.get(0)
    assert_eq_str(__LOC__, node_type_name(node.type), "while")
    assert_eq(__LOC__, node.children.len(), 2)
}

test_func_def := proc() {
    root := parse_src("f := func(x: I64) returns I64 { return x }")
    ref decl : Expr =root.children.get(0)
    assert_eq_str(__LOC__, node_type_name(decl.type), "decl")
    assert_eq(__LOC__, decl.children.len(), 1)
    ref fdef : Expr = decl.children.get(0)
    assert_eq_str(__LOC__, node_type_name(fdef.type), "func_def")
    assert(__LOC__, fdef.data.is_FuncDef())
    fd := fdef.data.get_FuncDef()
    assert_eq_str(__LOC__, func_type_name(fd.func_type), "func")
    assert_eq_str(__LOC__, fd.return_type, "I64")
    assert_eq(__LOC__, fd.param_names.len(), 1)
}

test_struct_def := proc() {
    root := parse_src("P := struct { mut x := 0 }")
    ref decl : Expr =root.children.get(0)
    assert_eq_str(__LOC__, node_type_name(decl.type), "decl")
    ref sdef : Expr = decl.children.get(0)
    assert_eq_str(__LOC__, node_type_name(sdef.type), "struct_def")
    // Body has one field decl
    ref body : Expr = sdef.children.get(0)
    assert_eq(__LOC__, body.children.len(), 1)
}

test_switch := proc() {
    root := parse_src("switch x { case 1: y = 1 case 2: y = 2 case: y = 0 }")
    ref node : Expr = root.children.get(0)
    assert_eq_str(__LOC__, node_type_name(node.type), "switch")
    // children: [switch_expr, case1, case2, default_case]
    assert_eq(__LOC__, node.children.len(), 4)
    // First case has match expr + body = 2 children
    ref c1 : Expr = node.children.get(1)
    assert_eq(__LOC__, c1.children.len(), 2)
    // Default case has body only = 1 child
    ref cd : Expr = node.children.get(3)
    assert_eq(__LOC__, cd.children.len(), 1)
}

test_for_in := proc() {
    root := parse_src("for i in 0..10 { x = i }")
    ref node : Expr = root.children.get(0)
    assert_eq_str(__LOC__, node_type_name(node.type), "for_in")
    assert_eq_str(__LOC__, node.data.get_StrVal(), "i")
    assert_eq(__LOC__, node.children.len(), 2)
}

test_empty()
test_declaration()
test_typed_decl()
test_assignment()
test_call()
test_method_call()
test_if_else()
test_while()
test_func_def()
test_struct_def()
test_switch()
test_for_in()

println("parsing: ok")
