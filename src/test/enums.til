mode test

# basic enum
Color := enum { Red, Green, Blue }

test_basic_enum := test() {
    c := Color.Red
    expect(__LOC__, c.eq(Color.Red), "Red eq Red")
    expect(__LOC__, c.eq(Color.Green).not(), "Red neq Green")
}

test_to_str := test() {
    assert_eq_str(__LOC__, Color.Red.to_str(), "Red")
    assert_eq_str(__LOC__, Color.Blue.to_str(), "Blue")
}

test_clone := test() {
    c2 := Color.Green
    assert_eq_str(__LOC__, c2.to_str(), "Green")
}

# enum in func params
is_red := func(c: Color) returns Bool {
    return c.eq(Color.Red)
}

test_func_params := test() {
    expect(__LOC__, is_red(Color.Red), "func: is_red(Red)")
    expect(__LOC__, is_red(Color.Blue).not(), "func: is_red(Blue)")
}

# enum with namespace section
Direction := enum {
    Up, Down, Left, Right
    namespace:
    is_vertical := func(self: Direction) returns Bool {
        if self.eq(Direction.Up) { return true }
        if self.eq(Direction.Down) { return true }
        return false
    }
}

test_namespace := test() {
    expect(__LOC__, Direction.Up.is_vertical(), "Up is vertical")
    expect(__LOC__, Direction.Left.is_vertical().not(), "Left not vertical")
}

# --- payload enums ---

Token := enum { Num: I64, Name: Str, Eof }

test_payload_construction := test() {
    t := Token.Num(42)
    t2 := Token.Eof
    t3 := Token.Name("hello")

    expect(__LOC__, t.is_Num(), "Num is_Num")
    expect(__LOC__, t.is_Eof().not(), "Num not is_Eof")
    expect(__LOC__, t2.is_Eof(), "Eof is_Eof")
    expect(__LOC__, t3.is_Name(), "Name is_Name")
}

test_payload_get := test() {
    t := Token.Num(42)
    t3 := Token.Name("hello")
    assert_eq(__LOC__, t.get_Num(), 42)
    assert_eq_str(__LOC__, t3.get_Name(), "hello")
}

test_payload_to_str := test() {
    assert_eq_str(__LOC__, Token.Num(42).to_str(), "Num(42)")
    assert_eq_str(__LOC__, Token.Eof.to_str(), "Eof")
    assert_eq_str(__LOC__, Token.Name("hello").to_str(), "Name(hello)")
}

test_payload_eq := test() {
    t := Token.Num(42)
    expect(__LOC__, t.eq(Token.Num(42)), "Num(42) eq Num(42)")
    expect(__LOC__, t.eq(Token.Num(99)).not(), "Num(42) neq Num(99)")
    expect(__LOC__, t.eq(Token.Eof).not(), "Num neq Eof")
    expect(__LOC__, Token.Eof.eq(Token.Eof), "Eof eq Eof")
}

test_payload_clone := test() {
    t4 := Token.Num(7)
    assert_eq(__LOC__, t4.get_Num(), 7)
}

# --- enum as struct field ---

# Simple enum field
Painted := struct {
    color := Color.Red
    mut label := ""
}

test_simple_enum_field := test() {
    p := Painted(color = Color.Blue, label = "sky")
    expect(__LOC__, p.color.eq(Color.Blue), "simple enum field read")
    assert_eq_str(__LOC__, p.label, "sky")
}

test_simple_enum_field_default := test() {
    p := Painted()
    expect(__LOC__, p.color.eq(Color.Red), "simple enum field default")
}

get_tag_name := func(tok: Token) returns Str {
    if tok.is_Num() { return "num" }
    if tok.is_Name() { return "name" }
    return "eof"
}

test_payload_func_params := test() {
    assert_eq_str(__LOC__, get_tag_name(Token.Num(1)), "num")
    assert_eq_str(__LOC__, get_tag_name(Token.Eof), "eof")
}
