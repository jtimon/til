mode test

# basic enum
Color := enum { Red, Green, Blue }

test_basic_enum := test() {
    c := Color.Red
    expect(__LOC__, c.eq(Color.Red), "Red eq Red")
    expect(__LOC__, c.eq(Color.Green).not(), "Red neq Green")
}

test_to_str := test() {
    assert_eq_str(__LOC__, Color.Red.to_str(), "Red")
    assert_eq_str(__LOC__, Color.Blue.to_str(), "Blue")
}

test_clone := test() {
    c2 := Color.Green
    assert_eq_str(__LOC__, c2.to_str(), "Green")
}

# enum in func params
is_red := func(c: Color) returns Bool {
    return c.eq(Color.Red)
}

test_func_params := test() {
    expect(__LOC__, is_red(Color.Red), "func: is_red(Red)")
    expect(__LOC__, is_red(Color.Blue).not(), "func: is_red(Blue)")
}

# enum with namespace section
Direction := enum {
    Up, Down, Left, Right
    namespace:
    is_vertical := func(self: Direction) returns Bool {
        if self.eq(Direction.Up) { return true }
        if self.eq(Direction.Down) { return true }
        return false
    }
}

test_namespace := test() {
    expect(__LOC__, Direction.Up.is_vertical(), "Up is vertical")
    expect(__LOC__, Direction.Left.is_vertical().not(), "Left not vertical")
}

# --- type aliases ---

Color2 := Color

test_enum_type_alias := test() {
    c := Color2.Red
    expect(__LOC__, c.eq(Color.Red), "alias Red eq original Red")
    expect(__LOC__, c.eq(Color2.Green).not(), "alias Red neq alias Green")
    assert_eq_str(__LOC__, Color2.Blue.to_str(), "Blue")
}

Direction2 := Direction

test_enum_alias_namespace := test() {
    expect(__LOC__, Direction2.Up.is_vertical(), "alias Up is vertical")
    expect(__LOC__, Direction2.Left.is_vertical().not(), "alias Left not vertical")
}

# --- payload enums ---

Token := enum { Num: I64, Name: Str, Eof }

test_payload_construction := test() {
    t := Token.Num(42)
    t2 := Token.Eof
    t3 := Token.Name("hello")

    expect(__LOC__, t.is(Token.Num), "Num is_Num")
    expect(__LOC__, t.is(Token.Eof).not(), "Num not is_Eof")
    expect(__LOC__, t2.is(Token.Eof), "Eof is_Eof")
    expect(__LOC__, t3.is(Token.Name), "Name is_Name")
}

test_payload_to_str := test() {
    assert_eq_str(__LOC__, Token.Num(42).to_str(), "Num(42)")
    assert_eq_str(__LOC__, Token.Eof.to_str(), "Eof")
    assert_eq_str(__LOC__, Token.Name("hello").to_str(), "Name(hello)")
}

test_payload_eq := test() {
    t := Token.Num(42)
    expect(__LOC__, t.eq(Token.Num(42)), "Num(42) eq Num(42)")
    expect(__LOC__, t.eq(Token.Num(99)).not(), "Num(42) neq Num(99)")
    expect(__LOC__, t.eq(Token.Eof).not(), "Num neq Eof")
    expect(__LOC__, Token.Eof.eq(Token.Eof), "Eof eq Eof")
}

test_payload_clone := test() {
    t4 := Token.Num(7)
    switch t4 {
    case Token.Num(_tn4):
        assert_eq(__LOC__, _tn4, 7)
    case:
        UNREACHABLE(__LOC__)
    }
}

# --- enum as struct field ---

# Simple enum field
Painted := struct {
    color := Color.Red
    mut label := ""
}

test_simple_enum_field := test() {
    p := Painted(color = Color.Blue, label = "sky")
    expect(__LOC__, p.color.eq(Color.Blue), "simple enum field read")
    assert_eq_str(__LOC__, p.label, "sky")
}

test_simple_enum_field_default := test() {
    p := Painted()
    expect(__LOC__, p.color.eq(Color.Red), "simple enum field default")
}

get_tag_name := func(tok: Token) returns Str {
    if tok.is(Token.Num) { return "num" }
    if tok.is(Token.Name) { return "name" }
    return "eof"
}

test_payload_func_params := test() {
    assert_eq_str(__LOC__, get_tag_name(Token.Num(1)), "num")
    assert_eq_str(__LOC__, get_tag_name(Token.Eof), "eof")
}

# --- struct payload in tagged enum ---

Point := struct {
    mut x := 0
    mut y := 0
    namespace:
    eq := func(a: Point, b: Point) returns Bool { return a.x.eq(b.x).and(a.y.eq(b.y)) }
    to_str := func(self: Point) returns Str { return format(self.x.to_str(), ",", self.y.to_str()) }
}

Shape := enum { Dot: Point, Line: Str, Empty }

test_struct_payload := test() {
    s := Shape.Dot(Point(x = 3, y = 4))
    switch s {
    case Shape.Dot(p):
        assert_eq(__LOC__, p.x, 3)
        assert_eq(__LOC__, p.y, 4)
    case:
        UNREACHABLE(__LOC__)
    }
}

test_struct_payload_eq := test() {
    s1 := Shape.Dot(Point(x = 1, y = 2))
    s2 := Shape.Dot(Point(x = 1, y = 2))
    s3 := Shape.Dot(Point(x = 9, y = 9))
    expect(__LOC__, s1.eq(s2), "same Dot eq")
    expect(__LOC__, s1.eq(s3).not(), "diff Dot neq")
    expect(__LOC__, s1.eq(Shape.Empty).not(), "Dot neq Empty")
}

test_struct_payload_clone := test() {
    s := Shape.Dot(Point(x = 5, y = 6))
    s2 := s.clone()
    switch s2 {
    case Shape.Dot(p):
        assert_eq(__LOC__, p.x, 5)
        assert_eq(__LOC__, p.y, 6)
    case:
        UNREACHABLE(__LOC__)
    }
}

test_struct_payload_to_str := test() {
    assert_eq_str(__LOC__, Shape.Empty.to_str(), "Empty")
    assert_eq_str(__LOC__, Shape.Line("hi").to_str(), "Line(hi)")
}

// payload enum as struct field (#53)

Data := struct {
    mut x := 0
    mut y := 0
    namespace:
    eq := func(a: Data, b: Data) returns Bool { return a.x.eq(b.x).and(a.y.eq(b.y)) }
    to_str := func(self: Data) returns Str { return format(self.x.to_str(), ",", self.y.to_str()) }
}
Kind := enum { A: Data, B: I64, C }
Container := struct { mut name := ""; mut kind := Kind.C }

test_payload_enum_field := test() {
    c := Container(name = "test", kind = Kind.A(Data(x = 3, y = 4)))
    assert_eq_str(__LOC__, c.kind.to_str(), "A(3,4)")
    switch c.kind {
    case Kind.A(d):
        assert_eq(__LOC__, d.x, 3)
        assert_eq(__LOC__, d.y, 4)
        assert_eq_str(__LOC__, d.to_str(), "3,4")
    case:
        UNREACHABLE(__LOC__)
    }
}

test_payload_enum_field_b := test() {
    c := Container(name = "test", kind = Kind.B(42))
    switch c.kind {
    case Kind.B(_kb):
        assert_eq(__LOC__, _kb, 42)
    case:
        UNREACHABLE(__LOC__)
    }
}

test_payload_enum_field_default := test() {
    c := Container()
    expect(__LOC__, c.kind.is(Kind.C), "default kind.is_C()")
}

test_payload_enum_field_mut := test() {
    mut c := Container(name = "test", kind = Kind.C)
    expect(__LOC__, c.kind.is(Kind.C), "initially C")
    c.kind = Kind.A(Data(x = 7, y = 8))
    switch c.kind {
    case Kind.A(d):
        assert_eq(__LOC__, d.x, 7)
        assert_eq(__LOC__, d.y, 8)
    case:
        UNREACHABLE(__LOC__)
    }
}

# --- switch on enums ---

test_switch_enum := test() {
    mut result := ""
    switch Color.Green {
    case Color.Red: result = "red"
    case Color.Green: result = "green"
    case Color.Blue: result = "blue"
    }
    assert_eq_str(__LOC__, result, "green")
}

test_switch_payload := test() {
    mut result := 0
    switch Token.Num(42) {
    case Token.Num(value): result = value
    case Token.Name(_s): result = -1
    case Token.Eof: result = -2
    }
    assert_eq(__LOC__, result, 42)
}

test_switch_payload_multi := test() {
    mut num_val := 0
    mut str_val := ""
    mut is_eof := false

    switch Token.Name("hello") {
    case Token.Num(n):
        num_val = n
    case Token.Name(s):
        str_val = s
    case Token.Eof:
        is_eof = true
    }
    assert_eq(__LOC__, num_val, 0)
    assert_eq_str(__LOC__, str_val, "hello")
    assert(__LOC__, is_eof.not())
}

test_switch_payload_with_default := test() {
    mut result := ""
    switch Token.Eof {
    case Token.Num(_n): result = "num"
    case Token.Name(_s): result = "name"
    case: result = "other"
    }
    assert_eq_str(__LOC__, result, "other")
}

# --- switch on enum without payload extraction ---

test_switch_payload_tag_only := test() {
    // switch on payload enum matching variant without extracting payload
    mut result := ""
    switch Token.Num(42) {
    case Token.Num: result = "num"
    case Token.Name: result = "name"
    case Token.Eof: result = "eof"
    }
    assert_eq_str(__LOC__, result, "num")
}

# --- enum variant as function argument ---

check_variant := func(t: Token, expected_tag: Str) returns Bool {
    return t.to_str().starts_with(expected_tag)
}

test_variant_func_arg := test() {
    expect(__LOC__, check_variant(Token.Num(1), "Num"), "Num starts with Num")
    expect(__LOC__, check_variant(Token.Eof, "Eof"), "Eof starts with Eof")
}

# --- is (generic tag comparison) ---

test_is_simple := test() {
    c := Color.Green
    expect(__LOC__, c.is(Color.Green), "Green is Green")
    expect(__LOC__, c.is(Color.Red).not(), "Green not Red")
}

test_is_payload := test() {
    t := Token.Num(42)
    expect(__LOC__, t.is(Token.Num(0)), "Num is Num")
    expect(__LOC__, t.is(Token.Eof).not(), "Num not Eof")
    expect(__LOC__, t.is(Token.Name("")).not(), "Num not Name")
}

test_is_bare_payload := test() {
    s := Shape.Dot(Point(x = 3, y = 4))
    expect(__LOC__, s.is(Shape.Dot), "Dot is Shape.Dot")
    expect(__LOC__, s.is(Shape.Empty).not(), "Dot not Shape.Empty")
    expect(__LOC__, s.is(Shape.Line).not(), "Dot not Shape.Line")
    // Also test with Token enum bare payload variants
    t := Token.Num(42)
    expect(__LOC__, t.is(Token.Num), "Num is Token.Num")
    expect(__LOC__, t.is(Token.Name).not(), "Num not Token.Name")
    expect(__LOC__, t.is(Token.Eof).not(), "Num not Token.Eof")
}

test_is_payload_eof := test() {
    t := Token.Eof
    expect(__LOC__, t.is(Token.Eof), "Eof is Eof")
    expect(__LOC__, t.is(Token.Num(0)).not(), "Eof not Num")
}

# --- exhaustive switch (#113): default catches everything the other cases don't ---

test_switch_default_only := test() {
    mut result := ""
    switch Color.Blue {
    case: result = "other"
    }
    assert_eq_str(__LOC__, result, "other")
}

test_switch_default_covers_missing := test() {
    # only Red is explicit; default absorbs Green and Blue
    mut result := ""
    switch Color.Green {
    case Color.Red: result = "red"
    case: result = "other"
    }
    assert_eq_str(__LOC__, result, "other")
}

# --- nested pattern matching (#36) ---

InnerE := enum { ValueA: I64, ValueB: Str, ValueC }
OuterE := enum { WrapperA: InnerE, WrapperB: I64 }

test_nested_payload_a := test() {
    outer := OuterE.WrapperA(InnerE.ValueA(42))
    mut result := 0
    switch outer {
    case OuterE.WrapperA(InnerE.ValueA(val)): result = val
    case OuterE.WrapperA(InnerE.ValueB(_s)): result = -1
    case OuterE.WrapperA(InnerE.ValueC):     result = -2
    case OuterE.WrapperB(i):                 result = i
    }
    assert_eq(__LOC__, result, 42)
}

test_nested_payload_b := test() {
    outer := OuterE.WrapperA(InnerE.ValueB("hello"))
    mut result := ""
    switch outer {
    case OuterE.WrapperA(InnerE.ValueA(_n)): result = "got-a"
    case OuterE.WrapperA(InnerE.ValueB(s)):  result = s
    case OuterE.WrapperA(InnerE.ValueC):     result = "got-c"
    case OuterE.WrapperB(_i):                result = "outer-b"
    }
    assert_eq_str(__LOC__, result, "hello")
}

test_nested_bare_inner := test() {
    outer := OuterE.WrapperA(InnerE.ValueC)
    mut hit := false
    switch outer {
    case OuterE.WrapperA(InnerE.ValueA(_n)): hit = false
    case OuterE.WrapperA(InnerE.ValueB(_s)): hit = false
    case OuterE.WrapperA(InnerE.ValueC):     hit = true
    case OuterE.WrapperB(_i):                hit = false
    }
    assert(__LOC__, hit)
}

test_nested_outer_b := test() {
    outer := OuterE.WrapperB(99)
    mut result := 0
    switch outer {
    case OuterE.WrapperA(InnerE.ValueA(_n)): result = 1
    case OuterE.WrapperA(InnerE.ValueB(_s)): result = 2
    case OuterE.WrapperA(InnerE.ValueC):     result = 3
    case OuterE.WrapperB(i):                 result = i
    }
    assert_eq(__LOC__, result, 99)
}

# Three levels of nesting.

InnerInnerE := enum { X: I64, Y }
MidE := enum { M: InnerInnerE, N: I64 }
DeepE := enum { O: MidE, P }

test_nested_triple := test() {
    v := DeepE.O(MidE.M(InnerInnerE.X(7)))
    mut result := 0
    switch v {
    case DeepE.O(MidE.M(InnerInnerE.X(n))): result = n
    case DeepE.O(MidE.M(InnerInnerE.Y)):    result = -1
    case DeepE.O(MidE.N(i)):                result = i
    case DeepE.P:                           result = -99
    }
    assert_eq(__LOC__, result, 7)
}

test_nested_triple_fallthrough := test() {
    v := DeepE.O(MidE.N(42))
    mut result := 0
    switch v {
    case DeepE.O(MidE.M(InnerInnerE.X(n))): result = n
    case DeepE.O(MidE.M(InnerInnerE.Y)):    result = -1
    case DeepE.O(MidE.N(i)):                result = i
    case DeepE.P:                           result = -99
    }
    assert_eq(__LOC__, result, 42)
}

# --- struct field matching in switch cases (#36) ---

PointPat := struct {
    mut x := 0
    mut y := 0
    namespace:
    eq := func(a: PointPat, b: PointPat) returns Bool { return a.x.eq(b.x).and(a.y.eq(b.y)) }
    to_str := func(self: PointPat) returns Str { return format(self.x.to_str(), ",", self.y.to_str()) }
}

test_struct_field_literal := test() {
    p := PointPat(x = 0, y = 5)
    mut r := ""
    switch p {
    case PointPat(x = 0, y = 0): r = "origin"
    case PointPat(x = 0, y = ny): r = format("y-", ny.to_str())
    case PointPat(x = nx, y = 0): r = format("x-", nx.to_str())
    case PointPat(x = _nx, y = _ny): r = "other"
    }
    assert_eq_str(__LOC__, r, "y-5")
}

test_struct_field_origin := test() {
    p := PointPat(x = 0, y = 0)
    mut r := ""
    switch p {
    case PointPat(x = 0, y = 0): r = "origin"
    case PointPat(x = _nx, y = _ny): r = "other"
    }
    assert_eq_str(__LOC__, r, "origin")
}

test_struct_field_bind_only := test() {
    p := PointPat(x = 7, y = 9)
    mut sum := 0
    switch p {
    case PointPat(x = nx, y = ny): sum = nx.add(ny)
    }
    assert_eq(__LOC__, sum, 16)
}

ShapePat := enum { Dot: PointPat, Line: I64 }

test_enum_payload_then_struct_pattern := test() {
    s := ShapePat.Dot(PointPat(x = 0, y = 7))
    mut hit := ""
    switch s {
    case ShapePat.Dot(p):
        switch p {
        case PointPat(x = 0, y = ny): hit = format("y-axis-", ny.to_str())
        case PointPat(x = _nx, y = _ny): hit = "other"
        }
    case ShapePat.Line(_l): hit = "line"
    }
    assert_eq_str(__LOC__, hit, "y-axis-7")
}

# Struct pattern *directly* inside an enum variant payload.
test_enum_with_struct_pattern := test() {
    s := ShapePat.Dot(PointPat(x = 0, y = 7))
    mut hit := ""
    switch s {
    case ShapePat.Dot(PointPat(x = 0, y = ny)): hit = format("y-axis-", ny.to_str())
    case ShapePat.Dot(p): hit = format("dot-", p.x.to_str(), ",", p.y.to_str())
    case ShapePat.Line(_l): hit = "line"
    }
    assert_eq_str(__LOC__, hit, "y-axis-7")
}

test_enum_with_struct_pattern_fallthrough := test() {
    s := ShapePat.Dot(PointPat(x = 3, y = 4))
    mut hit := ""
    switch s {
    case ShapePat.Dot(PointPat(x = 0, y = _ny)): hit = "y-axis"
    case ShapePat.Dot(p): hit = format("dot-", p.x.to_str(), ",", p.y.to_str())
    case ShapePat.Line(_l): hit = "line"
    }
    assert_eq_str(__LOC__, hit, "dot-3,4")
}

# --- guard clauses (#199) ---

ColorG := enum { Unknown, Number: I64, Name: Str }

test_guard_positive := test() {
    c := ColorG.Number(42)
    mut r := ""
    switch c {
    case ColorG.Unknown: r = "unknown"
    case ColorG.Number(code) if code.gt(0): r = "positive"
    case ColorG.Number(code): r = format("non-pos-", code.to_str())
    case ColorG.Name(name): r = format("named-", name)
    }
    assert_eq_str(__LOC__, r, "positive")
}

test_guard_falls_through := test() {
    c := ColorG.Number(-5)
    mut r := ""
    switch c {
    case ColorG.Unknown: r = "unknown"
    case ColorG.Number(code) if code.gt(0): r = "positive"
    case ColorG.Number(code): r = format("non-pos-", code.to_str())
    case ColorG.Name(_name): r = "named"
    }
    assert_eq_str(__LOC__, r, "non-pos--5")
}

test_guard_uses_binding := test() {
    c := ColorG.Number(7)
    mut hit := 0
    switch c {
    case ColorG.Number(v) if v.eq(7): hit = v
    case ColorG.Number(_v): hit = -1
    case ColorG.Unknown: hit = -2
    case ColorG.Name(_n): hit = -3
    }
    assert_eq(__LOC__, hit, 7)
}

test_guard_bare_variant := test() {
    flag := true
    c := ColorG.Unknown
    mut r := ""
    switch c {
    case ColorG.Unknown if flag: r = "yes"
    case ColorG.Unknown: r = "no"
    case ColorG.Number(_n): r = "num"
    case ColorG.Name(_n): r = "name"
    }
    assert_eq_str(__LOC__, r, "yes")
}

test_guard_bare_variant_false := test() {
    flag := false
    c := ColorG.Unknown
    mut r := ""
    switch c {
    case ColorG.Unknown if flag: r = "yes"
    case ColorG.Unknown: r = "no"
    case ColorG.Number(_n): r = "num"
    case ColorG.Name(_n): r = "name"
    }
    assert_eq_str(__LOC__, r, "no")
}
