mode test

# basic enum
Color := enum { Red, Green, Blue }

test_basic_enum := test() {
    c := Color.Red
    test_expect(__LOC__, c.eq(Color.Red), "Red eq Red")
    test_expect(__LOC__, c.eq(Color.Green).not(), "Red neq Green")
}

test_to_str := test() {
    assert_eq_str(__LOC__, Color.Red.to_str(), "Red")
    assert_eq_str(__LOC__, Color.Blue.to_str(), "Blue")
}

test_clone := test() {
    c2 := Color.Green
    assert_eq_str(__LOC__, c2.to_str(), "Green")
}

# enum in func params
is_red := func(c: Color) returns Bool {
    return c.eq(Color.Red)
}

test_func_params := test() {
    test_expect(__LOC__, is_red(Color.Red), "func: is_red(Red)")
    test_expect(__LOC__, is_red(Color.Blue).not(), "func: is_red(Blue)")
}

# enum with namespace section
Direction := enum {
    Up, Down, Left, Right
    namespace:
    is_vertical := func(self: Direction) returns Bool {
        if self.eq(Direction.Up) { return true }
        if self.eq(Direction.Down) { return true }
        return false
    }
}

test_namespace := test() {
    test_expect(__LOC__, Direction.Up.is_vertical(), "Up is vertical")
    test_expect(__LOC__, Direction.Left.is_vertical().not(), "Left not vertical")
}

# --- payload enums ---

Token := enum { Num: I64, Name: Str, Eof }

test_payload_construction := test() {
    t := Token.Num(42)
    t2 := Token.Eof
    t3 := Token.Name("hello")

    test_expect(__LOC__, t.is_Num(), "Num is_Num")
    test_expect(__LOC__, t.is_Eof().not(), "Num not is_Eof")
    test_expect(__LOC__, t2.is_Eof(), "Eof is_Eof")
    test_expect(__LOC__, t3.is_Name(), "Name is_Name")
}

test_payload_get := test() {
    t := Token.Num(42)
    t3 := Token.Name("hello")
    assert_eq(__LOC__, t.get_Num(), 42)
    assert_eq_str(__LOC__, t3.get_Name(), "hello")
}

test_payload_to_str := test() {
    assert_eq_str(__LOC__, Token.Num(42).to_str(), "Num(42)")
    assert_eq_str(__LOC__, Token.Eof.to_str(), "Eof")
    assert_eq_str(__LOC__, Token.Name("hello").to_str(), "Name(hello)")
}

test_payload_eq := test() {
    t := Token.Num(42)
    test_expect(__LOC__, t.eq(Token.Num(42)), "Num(42) eq Num(42)")
    test_expect(__LOC__, t.eq(Token.Num(99)).not(), "Num(42) neq Num(99)")
    test_expect(__LOC__, t.eq(Token.Eof).not(), "Num neq Eof")
    test_expect(__LOC__, Token.Eof.eq(Token.Eof), "Eof eq Eof")
}

test_payload_clone := test() {
    t4 := Token.Num(7)
    assert_eq(__LOC__, t4.get_Num(), 7)
}

# --- enum as struct field ---

# Simple enum field
Painted := struct {
    color := Color.Red
    mut label := ""
}

test_simple_enum_field := test() {
    p := Painted(color = Color.Blue, label = "sky")
    test_expect(__LOC__, p.color.eq(Color.Blue), "simple enum field read")
    assert_eq_str(__LOC__, p.label, "sky")
}

test_simple_enum_field_default := test() {
    p := Painted()
    test_expect(__LOC__, p.color.eq(Color.Red), "simple enum field default")
}

get_tag_name := func(tok: Token) returns Str {
    if tok.is_Num() { return "num" }
    if tok.is_Name() { return "name" }
    return "eof"
}

test_payload_func_params := test() {
    assert_eq_str(__LOC__, get_tag_name(Token.Num(1)), "num")
    assert_eq_str(__LOC__, get_tag_name(Token.Eof), "eof")
}

# --- struct payload in tagged enum ---

Point := struct {
    mut x := 0
    mut y := 0
    namespace:
    eq := func(a: Point, b: Point) returns Bool { return a.x.eq(b.x).and(a.y.eq(b.y)) }
    to_str := func(self: Point) returns Str { return format(self.x.to_str(), ",", self.y.to_str()) }
}

Shape := enum { Dot: Point, Line: Str, Empty }

test_struct_payload := test() {
    s := Shape.Dot(Point(x = 3, y = 4))
    test_expect(__LOC__, s.is_Dot(), "Dot is_Dot")
    test_expect(__LOC__, s.is_Empty().not(), "Dot not is_Empty")
    p := s.get_Dot()
    assert_eq(__LOC__, p.x, 3)
    assert_eq(__LOC__, p.y, 4)
}

test_struct_payload_eq := test() {
    s1 := Shape.Dot(Point(x = 1, y = 2))
    s2 := Shape.Dot(Point(x = 1, y = 2))
    s3 := Shape.Dot(Point(x = 9, y = 9))
    test_expect(__LOC__, s1.eq(s2), "same Dot eq")
    test_expect(__LOC__, s1.eq(s3).not(), "diff Dot neq")
    test_expect(__LOC__, s1.eq(Shape.Empty).not(), "Dot neq Empty")
}

test_struct_payload_clone := test() {
    s := Shape.Dot(Point(x = 5, y = 6))
    s2 := s.clone()
    p := s2.get_Dot()
    assert_eq(__LOC__, p.x, 5)
    assert_eq(__LOC__, p.y, 6)
}

test_struct_payload_to_str := test() {
    assert_eq_str(__LOC__, Shape.Empty.to_str(), "Empty")
    assert_eq_str(__LOC__, Shape.Line("hi").to_str(), "Line(hi)")
}

// payload enum as struct field: codegen bug (#53) — interpreter works, compiled produces wrong values
