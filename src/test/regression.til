mode test

// Regression tests. Add new entries as bugs are fixed; one test per
// bug, named `bug<N>`. Top-level decls (structs, enums, maps) live in
// this file too -- prefix them with `Bug<N>` to avoid future
// collisions as more entries accumulate.

// --- #47: cross-namespace method calls -------------------------------
//
// Original bug: redeclaring I64 as ext_struct silently overwrote the
// core definition. Fix: struct/enum redeclaration now produces an
// error. This regression covers cross-namespace calls (calling methods
// from one type's namespace inside another type's namespace).

Bug47Helper := struct {
    val : I64 = 0
namespace:
    make := func(n: I64) returns Bug47Helper {
        return Bug47Helper(val = n)
    }
}

Bug47Wrapper := struct {
    data : Bug47Helper = Bug47Helper()
namespace:
    from_int := func(n: I64) returns Bug47Wrapper {
        // Cross-namespace call: Bug47Helper.make from Bug47Wrapper's namespace
        h := Bug47Helper.make(n)
        return Bug47Wrapper(data = h)
    }
}

bug47 := test() {
    // Cross-namespace call between user-defined structs
    w := Bug47Wrapper.from_int(42)
    assert_eq(__LOC__, w.data.val, 42)
    // Cross-namespace call into a core type's namespace
    s := Str.with_capacity(10)
    assert_eq_str(__LOC__, s, "")
}

// --- #150 / #153: module-level enum-valued Map literal ---------------
//
// #150: scavenger dropped top-level init statements in test mode (so
// Map.set got pruned) and emit_as_ptr passed a stack compound literal
// to Map.set's own val param (so the internal free() hit a non-heap
// pointer and the binary aborted during teardown).
// #153: reinterpret_ptr_value hardcoded enum tag to 0, so
// `ref va : E = m.get("a")` always read back tag 0 in the interpreter.

Bug150E := enum { A, B, C }

Bug150M := {
    "a": Bug150E.A,
    "b": Bug150E.B
}

bug150 := test() {
    ref va : Bug150E = Bug150M.get("a")
    assert(__LOC__, va.eq(Bug150E.A))
    ref vb : Bug150E = Bug150M.get("b")
    assert(__LOC__, vb.eq(Bug150E.B))
}

// --- #185: ref-Dynamic local narrowed by narrow_dynamic emits bad C --
//
// Bug: a `ref X : Dynamic = ...` local, when fed directly into a
// typed-primitive call site (e.g. not(x), y.add(x)), used to compile
// to DEREF(x) on a void * -- invalid C. The typer's narrow_dynamic
// retypes the Ident to the param's primitive type (Bool/U8/etc.), so
// emit_deref no longer saw a Dynamic and fell into the generic
// ref-local branch which emits *x; but x's declared C type is
// void *, so gcc rejected the deref. Worked fine in interpret mode.
// Fix: track ref-Dynamic locals in Context.ref_dyn_locals so
// emit_deref can emit DEREF((PrimT *)x) -- a typed cast through the
// narrowed primitive type.

bug185 := test() {
    // Bool via UFCS receiver (Dynamic-typed receiver).
    bv := vec("Bool", true, false)
    ref bx : Dynamic = bv.get(1)
    ref by : Dynamic = bv.get(0)
    assert(__LOC__, bx.not())
    assert(__LOC__, by.not().not())
    // Bool via positional Dynamic arg into a top-level helper.
    assert(__LOC__, and(by, by))
    assert(__LOC__, or(bx, by))
    assert(__LOC__, and(bx, by).not())
    // U8: mixed typed/Dynamic args into a typed-primitive method.
    uv := vec("U8", 1.to_u8(), 2.to_u8(), 3.to_u8())
    ref ux : Dynamic = uv.get(1)
    uy : U8 = 10.to_u8()
    assert_eq(__LOC__, uy.add(ux).to_i64(), 12)
}

// --- #186: nested variadic fcall not desugared into Array wrap -------
//
// Bug: a user-defined variadic call nested inside another variadic
// call (e.g. println(say(true, false, true))) was left with raw args
// because the typer's process_call_desugars only desugared the first
// variadic fcall returned by find_variadic_fcall per stmt -- the
// outer one. The inner say(...) survived inside one of the outer
// Array.set value args, so the builder emitted say(_t_Bool_A,
// &_t_Bool_B, &_t_Bool_C) and gcc rejected the call ("too many
// arguments to function 'say'"). Standalone variadic calls and
// variadic calls from inside test() bodies escaped the bug because
// they weren't nested. Fix: recurse process_call_desugars on each
// emitted Array.set setter so nested variadic fcalls inside its
// value arg get their own Array.new + Array.set wrap and rewrite.

bug186_say := func(bools: ..Bool) returns Str {
    mut out := ""
    for b : Bool in bools { if b { out = out.concat("T") } else { out = out.concat("F") } }
    return out
}

bug186_concat := func(parts: ..Str) returns Str {
    mut result := ""
    for i in 0..parts.len() {
        ref p : Str = parts.get(i)
        result = result.concat(p)
    }
    return result
}

bug186 := test() {
    // Nested user-defined variadic inside a variadic Str.concat-style
    // call: pass the result of one variadic into another variadic.
    assert_eq_str(__LOC__, bug186_concat(bug186_say(true, false), bug186_say(true)), "TFT")
    // The CLI repro shape: variadic returning Str fed into println --
    // exercised here by composing through another variadic so the
    // nested-variadic-in-variadic codepath is hit inside test() too.
    assert_eq_str(__LOC__, bug186_concat(bug186_say(true, false, true)), "TFT")
}
