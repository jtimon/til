mode test

test_file_write_and_read := test() {
    path := "tmp/_test_file_io.txt"
    f := File.new(path, true)
    f.write("hello ")
    f.write("world")
    f.close()

    f2 := File.new(path, false)
    content := f2.read_all()
    f2.close()

    assert_eq_str(__LOC__, content, "hello world")
}

test_file_read_all := test() {
    path := "tmp/_test_file_read.txt"
    File.writefile(path, "abc123")

    f := File.new(path, false)
    content := f.read_all()
    f.close()

    assert_eq_str(__LOC__, content, "abc123")
}

test_file_multiple_writes := test() {
    path := "tmp/_test_file_multi.txt"
    f := File.new(path, true)
    for i in 0..5 {
        f.write(i.to_str())
        f.write(" ")
    }
    f.close()

    content := File.readfile(path)
    assert_eq_str(__LOC__, content, "0 1 2 3 4 ")
}
