mode test

fn_double := func(n: I64) returns I64 {
    return n.mul(2)
}

fn_add := func(a: I64, b: I64) returns I64 {
    return a.add(b)
}

fn_negate := func(n: I64) returns I64 {
    return 0.sub(n)
}

greet := proc(mut x: I64) {
    x = x.add(100)
}

apply := func(f: Fn(I64) returns I64, x: I64) returns I64 {
    return f(x)
}

apply2 := func(f: Fn(I64, I64) returns I64, a: I64, b: I64) returns I64 {
    return f(a, b)
}

mutate := proc(f: Fn(mut I64), mut x: I64) {
    f(x)
}

test_basic_fn_ptr := test() {
    f := fn_double
    assert_eq(__LOC__, f(5), 10)
    assert_eq(__LOC__, f(0), 0)
    assert_eq(__LOC__, f(3), 6)
}

test_pass_fn_as_arg := test() {
    assert_eq(__LOC__, apply(fn_double, 5), 10)
    assert_eq(__LOC__, apply(fn_double, 3), 6)
    assert_eq(__LOC__, apply(fn_negate, 7), 0.sub(7))
}

test_pass_fn_two_args := test() {
    assert_eq(__LOC__, apply2(fn_add, 3, 4), 7)
    assert_eq(__LOC__, apply2(fn_add, 10, 20), 30)
}

test_fn_ptr_mut_param := test() {
    mut val := 42
    mutate(greet, val)
    assert_eq(__LOC__, val, 142)
}

// --- FuncSig type definitions ---

BinaryOp := func(I64, I64) returns I64

fn_mul := func(a: I64, b: I64) returns I64 {
    return a.mul(b)
}

apply_binop := func(op: BinaryOp, a: I64, b: I64) returns I64 {
    return op(a, b)
}

test_funcsig_named_param := test() {
    assert_eq(__LOC__, apply_binop(fn_add, 3, 5), 8)
    assert_eq(__LOC__, apply_binop(fn_mul, 3, 5), 15)
}

test_funcsig_decl_type := test() {
    f : BinaryOp = fn_add
    assert_eq(__LOC__, f(10, 20), 30)

    g : BinaryOp = fn_mul
    assert_eq(__LOC__, g(4, 5), 20)
}

test_funcsig_reassign := test() {
    mut f : BinaryOp = fn_add
    assert_eq(__LOC__, f(2, 3), 5)
    f = fn_mul
    assert_eq(__LOC__, f(2, 3), 6)
}

UnaryOp := func(I64) returns I64

apply_unary := func(op: UnaryOp, x: I64) returns I64 {
    return op(x)
}

test_funcsig_unary := test() {
    assert_eq(__LOC__, apply_unary(fn_double, 7), 14)
    assert_eq(__LOC__, apply_unary(fn_negate, 5), 0.sub(5))
}

Mutator := proc(mut I64)

apply_mutator := proc(f: Mutator, mut x: I64) {
    f(x)
}

test_funcsig_proc := test() {
    mut val := 10
    apply_mutator(greet, val)
    assert_eq(__LOC__, val, 110)
}

// --- FuncSig form declarations ---

sum_sig : func(I64, I64) returns I64 = (a, b) {
    return a.add(b)
}

negate_sig : func(I64) returns I64 = (x) {
    return 0.sub(x)
}

greet_sig : proc(mut I64) = (x) {
    x = x.add(100)
}

test_funcsig_form_basic := test() {
    assert_eq(__LOC__, sum_sig(3, 5), 8)
    assert_eq(__LOC__, negate_sig(7), 0.sub(7))
}

test_funcsig_form_proc := test() {
    mut val := 10
    greet_sig(val)
    assert_eq(__LOC__, val, 110)
}

test_funcsig_form_as_value := test() {
    f : BinaryOp = sum_sig
    assert_eq(__LOC__, f(10, 20), 30)
    assert_eq(__LOC__, apply_binop(sum_sig, 4, 6), 10)
}

// --- Named FuncSig form ---

sum_named : BinaryOp = (a, b) {
    return a.add(b)
}

negate_named : UnaryOp = (x) {
    return 0.sub(x)
}

greet_named : Mutator = (x) {
    x = x.add(100)
}

test_named_funcsig_form := test() {
    assert_eq(__LOC__, sum_named(3, 5), 8)
    assert_eq(__LOC__, negate_named(7), 0.sub(7))
    assert_eq(__LOC__, apply_binop(sum_named, 4, 6), 10)
}

test_named_funcsig_form_proc := test() {
    mut val := 10
    greet_named(val)
    assert_eq(__LOC__, val, 110)
}

test_named_funcsig_form_as_value := test() {
    f : BinaryOp = sum_named
    assert_eq(__LOC__, f(10, 20), 30)
}

// --- Returning FuncSig-typed values ---

get_binop := func(which: Str) returns BinaryOp {
    if which.eq("add") {
        return fn_add
    }
    return fn_mul
}

test_return_funcsig := test() {
    op := get_binop("add")
    assert_eq(__LOC__, op(3, 5), 8)
    op2 := get_binop("mul")
    assert_eq(__LOC__, op2(3, 5), 15)
}

test_return_funcsig_pass := test() {
    op := get_binop("add")
    assert_eq(__LOC__, apply_binop(op, 10, 20), 30)
}

// --- Struct fields with FuncSig type ---

Handler := struct {
    mut on_click : BinaryOp = fn_add
}

test_struct_field_funcsig := test() {
    h := Handler(on_click = fn_add)
    assert_eq(__LOC__, h.on_click(3, 5), 8)
}

test_struct_field_reassign := test() {
    mut h := Handler(on_click = fn_add)
    assert_eq(__LOC__, h.on_click(3, 5), 8)
    h.on_click = fn_mul
    assert_eq(__LOC__, h.on_click(3, 5), 15)
}

test_struct_field_default := test() {
    h := Handler()
    assert_eq(__LOC__, h.on_click(3, 5), 8)
}

// --- Enum payloads with FuncSig type ---

Action := enum { Click: BinaryOp, Idle }

test_enum_funcsig_payload := test() {
    a := Action.Click(fn_add)
    test_expect(__LOC__, a.is_Click(), "Click is_Click")
    op := a.get_Click()
    assert_eq(__LOC__, op(3, 5), 8)
}

test_enum_funcsig_payload_mul := test() {
    a := Action.Click(fn_mul)
    test_expect(__LOC__, a.is_Click(), "Click is_Click")
    op := a.get_Click()
    assert_eq(__LOC__, op(4, 5), 20)
}

test_enum_funcsig_idle := test() {
    a : Action = Action.Idle
    test_expect(__LOC__, a.is_Idle(), "Idle is_Idle")
    test_expect(__LOC__, a.is_Click().not(), "Idle not Click")
}
