mode test
import("../self/ast.til")

test_node_name := test() {
    assert_eq_str(__LOC__, node_name(ExprData.Body), "body")
    assert_eq_str(__LOC__, node_name(ExprData.FCall), "fcall")
    assert_eq_str(__LOC__, node_name(ExprData.LiteralNull), "null")
    assert_eq_str(__LOC__, node_name(ExprData.Return), "return")
    assert_eq_str(__LOC__, node_name(ExprData.Break), "break")
}

test_func_type := test() {
    assert_eq_str(__LOC__, func_type_name(FuncType.Func), "func")
    assert_eq_str(__LOC__, func_type_name(FuncType.Proc), "proc")
    assert_eq_str(__LOC__, func_type_name(FuncType.ExtProc), "ext_proc")
}

test_til_type := test() {
    assert_eq_str(__LOC__, til_type_name_c(TilType.Unknown), "unknown")
    assert_eq_str(__LOC__, til_type_name_c(TilType.I64), "I64")
    assert_eq_str(__LOC__, til_type_name_c(TilType.FuncPtr), "Fn")
    assert_eq_str(__LOC__, til_type_name_c(TilType.U64), "U64")
    assert_eq_str(__LOC__, til_type_name_c(TilType.F32), "F32")
}

test_expr_new := test() {
    mut e := Expr.new(ExprData.Body, 1, 5, "test.til")
    assert_eq(__LOC__, e.line.to_i64(), 1)
    assert_eq(__LOC__, e.col.to_i64(), 5)
    assert_eq_str(__LOC__, e.path, "test.til")
}

test_expr_children := test() {
    mut parent := Expr.new(ExprData.Body, 1, 1, "test.til")
    child1 := Expr.new(ExprData.Body, 2, 1, "test.til")
    child2 := Expr.new(ExprData.Body, 3, 1, "test.til")
    Expr.add_child(parent, own child1)
    Expr.add_child(parent, own child2)
    assert_eq(__LOC__, Expr.child_count(parent), 2)
}
