mode test

// Regression test for #150: module-level enum-valued Map literal.
// The scavenger used to drop top-level init statements in test mode
// (so Map.set got pruned) and emit_as_ptr passed a stack compound
// literal to Map.set's own val param (so the internal free() hit a
// non-heap pointer and the binary aborted during teardown). Also
// covers #153 (reinterpret_ptr_value hardcoded enum tag to 0, so
// ref va : E = m.get("a") always read back tag 0 in the interpreter).

E := enum { A, B, C }

M := {
    "a": E.A,
    "b": E.B
}

test_enum_map_literal_lookup := test() {
    ref va : E = M.get("a")
    assert(__LOC__, va.eq(E.A))
    ref vb : E = M.get("b")
    assert(__LOC__, vb.eq(E.B))
}
