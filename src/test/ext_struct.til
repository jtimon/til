mode script

Pair := ext_struct {
    mut a := 0
    mut b := 0
    namespace:
    sum := ext_func(self: Pair) returns I64 {}
    swap := ext_func(self: Pair) returns Pair {}
    clone := ext_func(self: Pair) returns Pair {}
    delete := ext_proc(own self: Pair, call_free: Bool = true) {}

    // Regular funcs calling ext_funcs in same namespace
    double_sum := func(self: Pair) returns I64 {
        return self.sum().mul(2)
    }
    is_equal := func(self: Pair) returns Bool {
        return self.a.eq(self.b)
    }
    diff := func(self: Pair) returns I64 {
        return self.a.sub(self.b)
    }
    swapped_sum := func(self: Pair) returns I64 {
        return self.swap().sum()
    }
    with_offset := func(self: Pair, n: I64) returns Pair {
        return Pair(a=self.a.add(n), b=self.b.add(n))
    }
}

test_instantiation := proc() {
    p := Pair()
    assert_eq(loc(), p.a, 0)
    assert_eq(loc(), p.b, 0)
    p2 := Pair(a=3, b=7)
    assert_eq(loc(), p2.a, 3)
    assert_eq(loc(), p2.b, 7)
}

test_field_mutation := proc() {
    p := Pair(a=1, b=2)
    p.a = 10
    assert_eq(loc(), p.a, 10)
    assert_eq(loc(), p.b, 2)
}

test_ext_methods := proc() {
    p := Pair(a=3, b=7)
    assert_eq(loc(), p.sum(), 10)
    q := p.swap()
    assert_eq(loc(), q.a, 7)
    assert_eq(loc(), q.b, 3)
}

test_mixed_methods := proc() {
    p := Pair(a=3, b=7)
    assert_eq(loc(), p.double_sum(), 20)
    assert(loc(), p.is_equal().not())
    assert_eq(loc(), p.diff(), 0.sub(4))
    assert_eq(loc(), p.swapped_sum(), 10)

    q := Pair(a=5, b=5)
    assert(loc(), q.is_equal())
    assert_eq(loc(), q.diff(), 0)

    r := p.with_offset(10)
    assert_eq(loc(), r.a, 13)
    assert_eq(loc(), r.b, 17)
    assert_eq(loc(), r.sum(), 30)
}

test_clone := proc() {
    p := Pair(a=3, b=7)
    q := p.clone()
    assert_eq(loc(), q.a, 3)
    assert_eq(loc(), q.b, 7)
    q.a = 99
    assert_eq(loc(), p.a, 3)
    assert_eq(loc(), q.a, 99)
}

test_delete := proc() {
    p := Pair(a=1, b=2)
    own p.delete()
}

test_instantiation()
test_field_mutation()
test_ext_methods()
test_mixed_methods()
test_clone()
test_delete()
