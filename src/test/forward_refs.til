mode test

// forward reference: call a function defined later
test_forward_func := test() {
    assert_eq(__LOC__, fwd_double(5), 10)
}

fwd_double := func(n: I64) returns I64 {
    return n.mul(2)
}

fwd_factorial := func(n: I64) returns I64 {
    if n.lte(1) { return 1 }
    return n.mul(fwd_factorial(n.sub(1)))
}

test_recursion := test() {
    assert_eq(__LOC__, fwd_factorial(5), 120)
    assert_eq(__LOC__, fwd_factorial(1), 1)
    assert_eq(__LOC__, fwd_factorial(0), 1)
}

fwd_is_even := func(n: I64) returns Bool {
    if n.eq(0) { return true }
    return fwd_is_odd(n.sub(1))
}

fwd_is_odd := func(n: I64) returns Bool {
    if n.eq(0) { return false }
    return fwd_is_even(n.sub(1))
}

test_mutual_recursion := test() {
    assert(__LOC__, fwd_is_even(0))
    assert(__LOC__, fwd_is_odd(0).not())
    assert(__LOC__, fwd_is_odd(1))
    assert(__LOC__, fwd_is_even(4))
    assert(__LOC__, fwd_is_odd(7))
}

fwd_make_point := func(x: I64, y: I64) returns FwdPoint {
    return FwdPoint(x=x, y=y)
}

FwdPoint := struct {
    mut x := 0
    mut y := 0
}

test_forward_struct := test() {
    p := fwd_make_point(3, 7)
    assert_eq(__LOC__, p.x, 3)
    assert_eq(__LOC__, p.y, 7)
}
