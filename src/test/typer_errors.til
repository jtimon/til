mode script

// undefined symbol
println(missing_x)

// undefined function
foo(1)

// undefined type in explicit declaration
y : Blah = 35

// type mismatch: declared Str but value is I64
z : Str = 35

// if condition must be Bool
if 69 {
    println("FAIL")
}

if "hello" {
    println("FAIL")
}

// while condition must be Bool
while 1 {
    println("FAIL")
}

// variable not visible outside block scope
{
    inner := "scoped"
}
println(inner)

// func cannot call proc
bad_func := func(x: I64) returns I64 {
    println("side effect!")
    return x
}


// cannot assign to immutable variable
immut := 42
immut = 43

// cannot assign to function parameter
assign_param := proc(a: I64) {
    a = 99
}

// assignment type mismatch
mut m := 42
m = "oops"

// cannot assign to immutable struct field
ImmutStruct := struct {
    id := 0
    mut name := "x"
}
immut_struct := ImmutStruct()
immut_struct.id = 5

// struct instantiation: unknown field
bad1 := ImmutStruct(bogus=1)

// struct instantiation: positional arg not allowed
bad2 := ImmutStruct(42)

// wrong explicit type on func def
bad_fn : Str = func(n: I64) returns I64 { return n }

// wrong explicit type on struct def
bad_st : I64 = struct { mut x := 0 }

// cannot assign to immutable namespace field
NsStruct := struct {
    mut x := 0
    namespace:
    mut count := 0
    label := "fixed"
}
NsStruct.label = "oops"

// struct instantiation should not accept namespace field as named arg
bad_ns := NsStruct(count=5)

// ufcs: no such method on type
x := 42
x.nonexistent()

// ufcs: method call on type with no namespace
s := "hello"
s.nonexistent()

// ufcs: method call on literal
"hello".nonexistent()

// cannot assign to non-mut parameter (mut keyword exists)
assign_nonmut := proc(mut a: I64, b: I64) {
    a = 1
    b = 2
}

// own: missing 'own' at call site
take := proc(own x: I64) {
    println(x.to_str())
}
take(42)

// own: 'own' at call site but param is not own
regular := proc(x: I64) {
    println(x.to_str())
}
ov := 1
regular(own ov)

// own: use after ownership transfer
eat := proc(own v: I64) {
    println(v.to_str())
}
doomed := 99
eat(own doomed)
println(doomed.to_str())

// own: missing 'own' on UFCS call to own-taking method
OwnTest := struct {
    mut val := 0
}
ot1 := OwnTest(val=1)
ot1.delete()

// own: missing 'own' on direct namespace call to own-taking method
ot2 := OwnTest(val=2)
OwnTest.delete(ot2)

// struct literal: non-ref fields consume variables
CtorOwn := struct {
    mut name := "default"
}
ctor_name := "hello"
co := CtorOwn(name=ctor_name)
println(ctor_name)

// break outside loop
break

// continue outside loop
continue

// ref: declaration requires ref-returning function or ref/param variable
ref bad_ref := 42

// ref: function must return a parameter or ref variable
bad_ref_fn := func(a: I64) returns ref I64 {
    mut b := a
    return b
}

// cannot return ref variable from non-ref function; use .clone() or 'returns ref'
TERR_ARR := array("I64", 1, 2, 3)
bad_ret_ref := func(i: I64) returns I64 {
    ref v : I64 = TERR_ARR.get(i)
    return v
}

// cannot own result of ref-returning function; use 'ref' or Type.clone()
good_ref_fn := func(a: I64) returns ref I64 { return a }
bad_own := good_ref_fn(42)

// cannot own result of ref-returning function (Vec.get returns ref Dynamic)
ref_vec := vec("I64", 10, 20)
bad_vec_own : I64 = ref_vec.get(0)

// no need for explicit own on typed local
own bad_own_local : U8 = malloc(2)

// no need for explicit own on typed mutable local
own mut bad_own_mut_local : U8 = malloc(2)

// no need for explicit own on Dynamic local
own bad_dyn : Dynamic = malloc(2)

// cannot store Dynamic: inferred from malloc
bad_dyn2 := malloc(32)

// dyn_call: method must be a string literal
method_var := "clone"
dyn_call_ret("I64", method_var, 1, 42)

// argument type mismatch: I64 method with Bool arg
32.add(true)

// argument type mismatch: Bool top-level func with I64 arg
and(true, 42)

// argument type mismatch: user-defined function
type_test := func(a: I64, _b: Bool) returns I64 { return a }
type_test(1, 2)

// #157 argument type mismatch: variadic ..Str called with a type that
// has no to_str method (auto-coerce only fires when to_str exists)
NoToStr := struct { x : I64 = 0 }
println(NoToStr())
str_va := proc(_parts: ..Str) { print_flush() }
str_va(NoToStr())

// cannot call method on Dynamic value (namespace UFCS ambiguous)
dyn_vec := vec("I64", 10, 20)
dyn_bad := dyn_vec.get(0).add(35)

// map literal: key type must implement cmp
NoCmp := struct { x := 0 }
bad_map := {NoCmp(x=1): "one"}

// set literal: element type must implement cmp
bad_set := {NoCmp(x=1), NoCmp(x=2)}

// for-in: Dynamic collection without explicit type
forin_vec := vec("I64", 1, 2, 3)
for x in forin_vec { }

// for-in: type has no get method
NoGet := struct {
    namespace:
    len := func(_self: NoGet) returns I64 { return 0 }
}
for x in NoGet() { }

// for-in: type has no len method
NoLen := struct {
    namespace:
    get := func(_self: NoLen, i: I64) returns ref I64 { return i }
}
for x in NoLen() { }

// NULL: cannot assign to non-ref declaration
nonnull_local : I64 = NULL

// NULL: cannot pass to 'own' parameter
take_own := proc(own _x: I64) {}
take_own(own NULL)

// NULL: cannot pass to 'shallow' parameter
take_shallow := proc(shallow _x: I64) {}
take_shallow(NULL)

// #99: struct with new() -- literal outside namespace is an error
HasNew := struct {
    mut x := 0
namespace:
    new := func(x: I64) returns HasNew { return HasNew(x = x) }
}
hn := HasNew(x = 1)

// #86: unused function parameter (prefix with _ to suppress)
unused_param := func(a: I64, b: I64) returns I64 { return a }
unused_param(1, 2)

// #86: unused local variable (prefix with _ to suppress)
unused_local := func() returns I64 {
    unused := 99
    return 0
}
unused_local()

// #161: 'ref mut' cannot launder mutability from an immutable ref local
TerrLaunder := struct { mut field := 0 }
terr_launder_local := TerrLaunder(field=1)
ref terr_launder_r : TerrLaunder = terr_launder_local
ref mut terr_launder_rm : TerrLaunder = terr_launder_r

// #161: 'ref mut' cannot launder mutability from an immutable param
terr_launder_fn := proc(p: TerrLaunder) {
    ref mut leaked : TerrLaunder = p
    leaked.field = 99
}
terr_launder_fn(terr_launder_local)

// #113: non-exhaustive switch on enum (simple, no payload)
TerrColor := enum { Red, Green, Blue }
terr_color := TerrColor.Green
switch terr_color {
case TerrColor.Red: println("red")
case TerrColor.Green: println("green")
}

// #113: non-exhaustive switch on enum (payload variants)
TerrTok := enum { Num: I64, Name: Str, Eof }
terr_tok := TerrTok.Eof
switch terr_tok {
case TerrTok.Num: println("num")
case TerrTok.Eof: println("eof")
}

// #148: unqualified namespace member access from sibling method
NsUnqualified := namespace {
    mut urmom := 69
    get := func() returns I64 { return urmom }
}

// proc without any proc/ext_proc calls should be a func
useless_proc := proc(_x: I64) {
    return
}
useless_proc(1)

// #168 step 1: ref binding cannot be initialized from .clone()
TerrCloneRefSrc := struct { mut field := 0 }
terr_clone_ref_src := TerrCloneRefSrc(field=1)
ref terr_clone_ref : TerrCloneRefSrc = terr_clone_ref_src.clone()
ref mut terr_clone_ref_mut : TerrCloneRefSrc = terr_clone_ref_src.clone()

// #168 step 2: predicate generalised from literal `.clone()` to any
// FCall whose callee returns OwnType.Own. Catches struct constructors,
// factory funcs, and any user func declared `returns own ...`.
ref terr_step2_ctor : TerrCloneRefSrc = TerrCloneRefSrc(field=2)
terr_make_owned_str := func() returns Str { return "owned" }
ref terr_step2_func : Str = terr_make_owned_str()

// #168 step 5: ref-typed function cannot return an owned value.
terr_step5_bad_ret := func(f: TerrCloneRefSrc) returns ref TerrCloneRefSrc {
    return f.clone()
}

// #168 step 3: ref struct field default cannot be an owned value.
// NULL stays allowed (forced exception for ref fields).
TerrStep3 := struct {
    ref mut bad_field : TerrCloneRefSrc = TerrCloneRefSrc(field=3)
    ref mut ok_field : TerrCloneRefSrc = NULL
}

// #168 step 2 follow-up: enum variant constructors are caught too,
// because the initer registers each variant as a namespace decl with
// a FuncDef whose default return_own_type is Own.
TerrStep2Enum := enum { TerrPayload: I64, TerrEmpty }
ref terr_step2_enum : TerrStep2Enum = TerrStep2Enum.TerrPayload(5)

// #168 step 4: assignment to a ref-typed lvalue cannot accept an owned
// RHS. Catches both plain Assign and FieldAssign shapes.
TerrStep4Field := struct {
    ref mut data : Str = NULL
namespace:
    set_clone := func(mut self: TerrStep4Field, src: Str) returns I64 {
        self.data = src.clone()
        return 0
    }
}
terr_step4_assign := func() returns I64 {
    ref mut x : Str = "borrow"
    x = "fresh".clone()
    return 0
}
terr_step4_assign()

// #168 step 1b / #177: ref bindings cannot be initialized to NULL.
// Field defaults remain allowed (the parent type doesn't yet have an
// instance to point at). Func/proc/test/macro bodies AND module scope
// are now uniformly rejected.
terr_null_ref_local_fn := func() returns I64 {
    ref leaked_null : I64 = NULL
    ref mut leaked_null_mut : I64 = NULL
    if is_null(leaked_null) { return 0 }
    if is_null(leaked_null_mut) { return 0 }
    return 1
}
terr_null_ref_local_fn()

// #177: same rule applies at module scope (was the conservative
// carve-out before the cached_*_def migration).
ref terr_module_null : I64 = NULL
ref mut terr_module_null_mut : I64 = NULL

// #191: macro argument must be known at compile time
macro_test := macro(x: I64) returns I64 { return x }
runtime_val := func() returns I64 { return 42 }
_ = macro_test(runtime_val())
