mode script

// undefined symbol
println(to_str(x))

// undefined function
foo(1)

// undefined type in explicit declaration
y : Blah = 35

// type mismatch: declared Str but value is I64
z : Str = 35

// if condition must be Bool
if 69 {
    println("FAIL")
}

if "hello" {
    println("FAIL")
}

// while condition must be Bool
while 1 {
    println("FAIL")
}

// variable not visible outside block scope
{
    inner := "scoped"
}
println(inner)

// func cannot call proc
bad_func := func(x: I64) returns I64 {
    println("side effect!")
    return x
}

// func must declare a return type
no_ret := func(x: I64) {
    return x
}
