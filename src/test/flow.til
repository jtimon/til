mode script

// break exits while loop
mut i := 0
while true {
    if i.eq(3) { break }
    i = i.add(1)
}
println(i.to_str())

// break with code after loop
mut sum := 0
mut j := 0
while true {
    if j.eq(5) { break }
    sum = sum.add(j)
    j = j.add(1)
}
println(sum.to_str())

// return inside if frees locals
early_ret := func(x: Bool) returns I64 {
    a := 10
    b := 20
    if x { return a }
    return b
}
println(early_ret(true).to_str())
println(early_ret(false).to_str())
