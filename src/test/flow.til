mode script

// break exits while loop
mut i := 0
while true {
    if i.eq(3) { break }
    i = i.add(1)
}
println(i.to_str())

// break with code after loop
mut sum := 0
mut j := 0
while true {
    if j.eq(5) { break }
    sum = sum.add(j)
    j = j.add(1)
}
println(sum.to_str())

// return inside if frees locals
early_ret := func(x: Bool) returns I64 {
    a := 10
    b := 20
    if x { return a }
    return b
}
println(early_ret(true).to_str())
println(early_ret(false).to_str())

// continue skips iteration
mut k := 0
mut total := 0
while k.lt(5) {
    k = k.add(1)
    if k.eq(3) { continue }
    total = total.add(k)
}
println(total.to_str())

// else if chains
check := func(n: I64) returns I64 {
    if n.eq(1) { return 10 }
    else if n.eq(2) { return 20 }
    else if n.eq(3) { return 30 }
    else { return 0 }
}
println(check(1).to_str())
println(check(2).to_str())
println(check(3).to_str())
println(check(99).to_str())
