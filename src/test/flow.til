mode test

test_if_else := test() {
    if true {
        assert(__LOC__, true)
    }
    if false {
        panic(__LOC__, "unreachable")
    } else {
        assert(__LOC__, true)
    }
    if true.and(true) {
        assert(__LOC__, true)
    }
    if true.and(false) {
        panic(__LOC__, "unreachable")
    } else {
        assert(__LOC__, true)
    }
}

test_while_loop := test() {
    while false {
        panic(__LOC__, "unreachable")
    }
    mut i := 0
    while i.lt(5) {
        i = i.add(1)
    }
    assert_eq(__LOC__, i, 5)
}

test_break := test() {
    mut i := 0
    while true {
        if i.eq(3) { break }
        i = i.add(1)
    }
    assert_eq(__LOC__, i, 3)
    mut sum := 0
    mut j := 0
    while true {
        if j.eq(5) { break }
        sum = sum.add(j)
        j = j.add(1)
    }
    assert_eq(__LOC__, sum, 10)
}

test_continue := test() {
    mut k := 0
    mut total := 0
    while k.lt(5) {
        k = k.add(1)
        if k.eq(3) { continue }
        total = total.add(k)
    }
    assert_eq(__LOC__, total, 12)
}

flow_early_ret := func(x: Bool) returns I64 {
    a := 10
    b := 20
    if x { return a }
    return b
}

test_early_return := test() {
    assert_eq(__LOC__, flow_early_ret(true), 10)
    assert_eq(__LOC__, flow_early_ret(false), 20)
}

flow_check := func(n: I64) returns I64 {
    if n.eq(1) { return 10 }
    else if n.eq(2) { return 20 }
    else if n.eq(3) { return 30 }
    else { return 0 }
}

test_else_if := test() {
    assert_eq(__LOC__, flow_check(1), 10)
    assert_eq(__LOC__, flow_check(2), 20)
    assert_eq(__LOC__, flow_check(3), 30)
    assert_eq(__LOC__, flow_check(99), 0)
}

# ASAP edge cases: return from inside while must free parent-scope locals

asap_return_from_while := func(n: I64) returns Str {
    s := "allocated"
    mut i := 0
    while i.lt(n) {
        if i.eq(2) { return "early" }
        i = i.add(1)
    }
    return s
}

test_asap_while := test() {
    # Early return path: s must be freed before returning "early"
    assert_eq_str(__LOC__, asap_return_from_while(5), "early")
    # Normal path: s returned normally
    assert_eq_str(__LOC__, asap_return_from_while(1), "allocated")
}

asap_return_nested := func(n: I64) returns Str {
    s1 := "first"
    s2 := "second"
    mut i := 0
    while i.lt(n) {
        if i.eq(1) {
            if true {
                return s1
            }
        }
        i = i.add(1)
    }
    return s2
}

test_asap_nested := test() {
    # Return from if-inside-if-inside-while: s2 must be freed, s1 returned
    assert_eq_str(__LOC__, asap_return_nested(3), "first")
    # Normal path: s1 freed by ASAP, s2 returned
    assert_eq_str(__LOC__, asap_return_nested(0), "second")
}

asap_break_no_leak := func() returns Str {
    s := "alive"
    mut i := 0
    while i.lt(10) {
        if i.eq(2) { break }
        i = i.add(1)
    }
    # s must still be alive after break (not freed by break)
    return s
}

test_asap_break := test() {
    assert_eq_str(__LOC__, asap_break_no_leak(), "alive")
}

# ASAP edge case: variable used in both branches of if/else
asap_if_both_branches := func(x: I64) returns Str {
    s := "both"
    if x.eq(1) {
        _ := format(s)
    } else {
        _ := format(s)
    }
    # s freed after if/else, not leaked
    return "done"
}

# ASAP edge case: variable used only in one branch
asap_if_one_branch := func(x: I64) returns Str {
    s := "one"
    if x.eq(1) {
        _ := format(s)
    } else {
        _ := format("other")
    }
    # s freed after if/else even though only used in then
    return "done"
}

# ASAP edge case: return from one branch, other locals freed
asap_if_return_branch := func(x: I64) returns Str {
    s := "kept"
    t := "freed"
    if x.eq(1) {
        return s
    }
    return t
}

test_asap_if_else := test() {
    assert_eq_str(__LOC__, asap_if_both_branches(1), "done")
    assert_eq_str(__LOC__, asap_if_both_branches(0), "done")
    assert_eq_str(__LOC__, asap_if_one_branch(1), "done")
    assert_eq_str(__LOC__, asap_if_one_branch(0), "done")
    # return from if: s returned, t freed before return
    assert_eq_str(__LOC__, asap_if_return_branch(1), "kept")
    # fall through: t returned, s freed by ASAP
    assert_eq_str(__LOC__, asap_if_return_branch(0), "freed")
}

# ASAP edge case: mut variable reassignment must free old value
test_reassign_str := test() {
    mut s := "hello"
    s = "world"
    assert_eq_str(__LOC__, s, "world")
}

reassign_clone_helper := proc(x: Str) {
    mut s := "hello"
    s = x
    assert_eq_str(__LOC__, s, "from_arg")
}

test_reassign_clone := test() {
    reassign_clone_helper("from_arg")
}

test_reassign_multi := test() {
    mut s := "a"
    s = "b"
    s = "c"
    s = "d"
    assert_eq_str(__LOC__, s, "d")
}
