mode script

test_if_else := proc() {
    if true {
        assert(loc(), true)
    }
    if false {
        panic(loc(), "unreachable")
    } else {
        assert(loc(), true)
    }
    if true.and(true) {
        assert(loc(), true)
    }
    if true.and(false) {
        panic(loc(), "unreachable")
    } else {
        assert(loc(), true)
    }
}

test_while_loop := proc() {
    while false {
        panic(loc(), "unreachable")
    }
    mut i := 0
    while i.lt(5) {
        i = i.add(1)
    }
    assert_eq(loc(), i, 5)
}

test_break := proc() {
    mut i := 0
    while true {
        if i.eq(3) { break }
        i = i.add(1)
    }
    assert_eq(loc(), i, 3)
    mut sum := 0
    mut j := 0
    while true {
        if j.eq(5) { break }
        sum = sum.add(j)
        j = j.add(1)
    }
    assert_eq(loc(), sum, 10)
}

test_continue := proc() {
    mut k := 0
    mut total := 0
    while k.lt(5) {
        k = k.add(1)
        if k.eq(3) { continue }
        total = total.add(k)
    }
    assert_eq(loc(), total, 12)
}

flow_early_ret := func(x: Bool) returns I64 {
    a := 10
    b := 20
    if x { return a }
    return b
}

test_early_return := proc() {
    assert_eq(loc(), flow_early_ret(true), 10)
    assert_eq(loc(), flow_early_ret(false), 20)
}

flow_check := func(n: I64) returns I64 {
    if n.eq(1) { return 10 }
    else if n.eq(2) { return 20 }
    else if n.eq(3) { return 30 }
    else { return 0 }
}

test_else_if := proc() {
    assert_eq(loc(), flow_check(1), 10)
    assert_eq(loc(), flow_check(2), 20)
    assert_eq(loc(), flow_check(3), 30)
    assert_eq(loc(), flow_check(99), 0)
}

# ASAP edge cases: return from inside while must free parent-scope locals

asap_return_from_while := func(n: I64) returns Str {
    s := "allocated"
    mut i := 0
    while i.lt(n) {
        if i.eq(2) { return "early" }
        i = i.add(1)
    }
    return s
}

test_asap_while := proc() {
    # Early return path: s must be freed before returning "early"
    assert_eq_str(loc(), asap_return_from_while(5), "early")
    # Normal path: s returned normally
    assert_eq_str(loc(), asap_return_from_while(1), "allocated")
}

asap_return_nested := func(n: I64) returns Str {
    s1 := "first"
    s2 := "second"
    mut i := 0
    while i.lt(n) {
        if i.eq(1) {
            if true {
                return s1
            }
        }
        i = i.add(1)
    }
    return s2
}

test_asap_nested := proc() {
    # Return from if-inside-if-inside-while: s2 must be freed, s1 returned
    assert_eq_str(loc(), asap_return_nested(3), "first")
    # Normal path: s1 freed by ASAP, s2 returned
    assert_eq_str(loc(), asap_return_nested(0), "second")
}

asap_break_no_leak := func() returns Str {
    s := "alive"
    mut i := 0
    while i.lt(10) {
        if i.eq(2) { break }
        i = i.add(1)
    }
    # s must still be alive after break (not freed by break)
    return s
}

test_asap_break := proc() {
    assert_eq_str(loc(), asap_break_no_leak(), "alive")
}

# ASAP edge case: variable used in both branches of if/else
asap_if_both_branches := func(x: I64) returns Str {
    s := "both"
    if x.eq(1) {
        _ := format(s)
    } else {
        _ := format(s)
    }
    # s freed after if/else, not leaked
    return "done"
}

# ASAP edge case: variable used only in one branch
asap_if_one_branch := func(x: I64) returns Str {
    s := "one"
    if x.eq(1) {
        _ := format(s)
    } else {
        _ := format("other")
    }
    # s freed after if/else even though only used in then
    return "done"
}

# ASAP edge case: return from one branch, other locals freed
asap_if_return_branch := func(x: I64) returns Str {
    s := "kept"
    t := "freed"
    if x.eq(1) {
        return s
    }
    return t
}

test_asap_if_else := proc() {
    assert_eq_str(loc(), asap_if_both_branches(1), "done")
    assert_eq_str(loc(), asap_if_both_branches(0), "done")
    assert_eq_str(loc(), asap_if_one_branch(1), "done")
    assert_eq_str(loc(), asap_if_one_branch(0), "done")
    # return from if: s returned, t freed before return
    assert_eq_str(loc(), asap_if_return_branch(1), "kept")
    # fall through: t returned, s freed by ASAP
    assert_eq_str(loc(), asap_if_return_branch(0), "freed")
}

# ASAP edge case: mut variable reassignment must free old value
test_reassign_str := proc() {
    mut s := "hello"
    s = "world"
    assert_eq_str(loc(), s, "world")
}

test_reassign_clone := proc(x: Str) {
    mut s := "hello"
    s = x
    assert_eq_str(loc(), s, "from_arg")
}

test_reassign_multi := proc() {
    mut s := "a"
    s = "b"
    s = "c"
    s = "d"
    assert_eq_str(loc(), s, "d")
}

test_if_else()
test_while_loop()
test_break()
test_continue()
test_early_return()
test_else_if()
test_asap_while()
test_asap_nested()
test_asap_break()
test_asap_if_else()
test_reassign_str()
test_reassign_clone("from_arg")
test_reassign_multi()
