mode script

// Test: global variables accessible from functions and procs,
// including forward refs to globals declared later
// See issue #17

// func accessing global
f := func() returns I64 {
    return x
}

// proc accessing global
g := proc() {
    println(x.to_str())
}

// proc accessing global via declaration
h := proc() {
    y := x
    println(y.to_str())
}

x := 42

assert(__LOC__, f().eq(42))
g()
h()

inc := proc() {
    counter = counter.add(1)
}

get_counter := func() returns I64 {
    return counter
}

// mut global modified by proc
mut counter := 0

inc()
inc()
inc()
assert(__LOC__, get_counter().eq(3))
assert(__LOC__, counter.eq(3))
counter = 100
assert(__LOC__, counter.eq(100))

DeleteOnOverwrite := struct {
    mut id := 0
    namespace:
    mut delete_count := 0
    delete := proc(own self: DeleteOnOverwrite, call_free: Bool = true) {
        DeleteOnOverwrite.delete_count = DeleteOnOverwrite.delete_count.add(1)
        if call_free { free(own self) }
    }
}

mut tracked := DeleteOnOverwrite(id=1)
assert(__LOC__, DeleteOnOverwrite.delete_count.eq(0))
tracked = DeleteOnOverwrite(id=2)
assert(__LOC__, DeleteOnOverwrite.delete_count.eq(1))
tracked = DeleteOnOverwrite(id=3)
assert(__LOC__, DeleteOnOverwrite.delete_count.eq(2))

println("globals: ok")
