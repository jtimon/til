mode script

// Test: global variables accessible from functions and procs,
// including forward refs to globals declared later
// See issue #17

// func accessing global
f := func() returns I64 {
    return x
}

// proc accessing global
g := proc() {
    println(x.to_str())
}

// proc accessing global via declaration
h := proc() {
    y := x
    println(y.to_str())
}

x := 42

assert(__LOC__, f().eq(42))
g()
h()

inc := proc() {
    counter = counter.add(1)
}

get_counter := func() returns I64 {
    return counter
}

// mut global modified by proc
mut counter := 0

inc()
inc()
inc()
assert(__LOC__, get_counter().eq(3))
assert(__LOC__, counter.eq(3))
counter = 100
assert(__LOC__, counter.eq(100))

println("globals: ok")
