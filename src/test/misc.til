mode script

a := 34
b := 35
println(a.add(b).to_str())

s := "Hello"
println(s)

x : I64 = 35
println(x.to_str())

greeting : Str = "Hi there"
println(greeting)

t := true
f := false
println(t.to_str())
println(f.to_str())
println(true.and(true).to_str())
println(true.and(false).to_str())
println(false.or(false).to_str())
println(false.or(true).to_str())

if true {
    println("if true works")
}

if false {
    println("FAIL")
} else {
    println("else works")
}

if true.and(true) {
    println("and(true, true) is truthy")
}

if true.and(false) {
    println("FAIL")
} else {
    println("and(true, false) is falsy")
}

while false {
    println("FAIL")
}
println("while false skipped")

println(1.eq(1).to_str())
println(1.lt(2).to_str())
println(2.gt(1).to_str())

{
    inner := "scoped"
    println(inner)
}
println("after block")

println(1.lte(2).to_str())
println(2.lte(2).to_str())
println(3.lte(2).to_str())
println(3.gte(2).to_str())
println(2.gte(2).to_str())
println(1.gte(2).to_str())
println(1.neq(2).to_str())
println(2.neq(2).to_str())
println(10.mod(3).to_str())
println(10.mod(5).to_str())
println(42.neg().to_str())

mut counter := 0
counter = 1
counter = counter.add(1)
println(counter.to_str())

mut msg : Str = "hello"
msg = "world"
println(msg)

mut i := 0
while i.lt(5) {
    print(i.to_str(), " ")
    i = i.add(1)
}
println("")

// explicit FunctionDef type annotation
double : FunctionDef = func(n: I64) returns I64 {
    return n.mul(2)
}
assert_eq(loc(), double(5), 10)

greet_person : FunctionDef = proc(name: Str) {
    println("hello, ", name)
}
greet_person("world")

Point : StructDef = struct {
    mut x := 0
    mut y := 0
}
p := Point()
println(p.x.to_str())
println(p.y.to_str())
p.x = 5
p.y = 10
println(p.x.to_str())
println(p.y.to_str())
println(loc())
assert(loc(), true)
assert(loc(), 1.eq(1))
println("hello".concat(" world"))
println(format("a", "b", "c"))
test(loc(), 2.eq(2), "2 should equal 2")
assert_eq(loc(), 1.add(1), 2)
assert_eq_str(loc(), "a".concat("b"), "ab")

// bitwise I64 operations
assert_eq(loc(), 6.and(3), 2)
assert_eq(loc(), 6.or(3), 7)
assert_eq(loc(), 6.xor(3), 5)

// U8 tests
a_u8 : U8 = 200
b_u8 : U8 = 55
assert_eq_str(loc(), a_u8.add(b_u8).to_str(), "255")
assert_eq_str(loc(), a_u8.add(b_u8).add(b_u8).to_str(), "54")
assert_eq_str(loc(), a_u8.sub(b_u8).to_str(), "145")
assert_eq_str(loc(), a_u8.to_i64().to_str(), "200")
assert(loc(), a_u8.gt(b_u8))
assert(loc(), a_u8.eq(a_u8))
c_u8 : U8 = U8.from_i64(42)
assert_eq_str(loc(), c_u8.to_str(), "42")

// mut param tests
inc := proc(mut x: I64) {
    x = I64.add(x, 1)
}
mut_val := 42
inc(mut_val)
assert_eq(loc(), mut_val, 43)

swap := proc(mut a: I64, mut b: I64) {
    tmp := a
    a = b
    b = tmp
}
mut_a := 10
mut_b := 20
swap(mut_a, mut_b)
assert_eq(loc(), mut_a, 20)
assert_eq(loc(), mut_b, 10)

// own param tests
consume := proc(own x: I64) {
    println(x.to_str())
}
owned_val := 42
consume(own owned_val)

// own param returned (ownership passes through)
identity := func(own x: I64) returns I64 {
    return x
}
assert_eq(loc(), identity(own 100), 100)
