mode script

// dyn_has_method — check method existence on builtin types
// TODO(#15): methods checked must also be referenced directly so the scavenger
// keeps them. Remove these dummy calls once scavenger understands dyn_has_method.
assert_eq(loc(), 1.clone(), 1)
assert_eq_str(loc(), "hi".clone(), "hi")

test(loc(), dyn_has_method("I64", "delete"), "I64 has delete")
test(loc(), dyn_has_method("I64", "clone"), "I64 has clone")
test(loc(), dyn_has_method("I64", "nonexistent").not(), "I64 no nonexistent")
test(loc(), dyn_has_method("Str", "delete"), "Str has delete")
test(loc(), dyn_has_method("Str", "nonexistent").not(), "Str no nonexistent")
test(loc(), dyn_has_method("Bool", "eq"), "Bool has eq")
test(loc(), dyn_has_method("Bool", "not").not(), "Bool no not (moved to top-level)")

// Test with a user-defined struct
Foo := struct {
    x := 0
    namespace:
    bar := func(self: Foo) returns I64 { return self.x }
}
f := Foo(x=0)
assert_eq(loc(), f.bar(), 0)
test(loc(), dyn_has_method("Foo", "bar"), "Foo has bar")
test(loc(), dyn_has_method("Foo", "baz").not(), "Foo no baz")

println("dyn_has_method: all passed")

// cmp
assert_eq(loc(), I64.cmp(1, 2), 0.sub(1))
assert_eq(loc(), I64.cmp(5, 5), 0)
assert_eq(loc(), I64.cmp(3, 1), 1)
assert_eq(loc(), U8.cmp(U8.from_i64(1), U8.from_i64(2)), 0.sub(1))
assert_eq(loc(), U8.cmp(U8.from_i64(5), U8.from_i64(5)), 0)
assert_eq(loc(), U8.cmp(U8.from_i64(3), U8.from_i64(1)), 1)
assert_eq(loc(), Bool.cmp(false, false), 0)
assert_eq(loc(), Bool.cmp(true, true), 0)
assert_eq(loc(), Bool.cmp(false, true), 0.sub(1))
assert_eq(loc(), Bool.cmp(true, false), 1)
assert_eq(loc(), Str.cmp("abc", "abd"), 0.sub(1))
assert_eq(loc(), Str.cmp("hello", "hello"), 0)
assert_eq(loc(), Str.cmp("b", "a"), 1)
assert_eq(loc(), Str.cmp("ab", "a"), 1)
assert_eq(loc(), Str.cmp("a", "ab"), 0.sub(1))
println("cmp: all passed")

// variadic args
variadic_sum := func(nums: ..I64) returns I64 {
    mut i := 0
    mut total := 0
    while i.lt(nums.len()) {
        ref n: I64 = nums.get(i)
        total = total.add(n)
        i = i.add(1)
    }
    return total
}
assert_eq(loc(), variadic_sum(1, 2, 3), 6)
assert_eq(loc(), variadic_sum(10), 10)
assert_eq(loc(), variadic_sum(), 0)

// proc-based variadic test (not constant-foldable)
variadic_print := proc(nums: ..I64) {
    mut i := 0
    while i.lt(nums.len()) {
        ref n: I64 = nums.get(i)
        print(n.to_str())
        if i.lt(nums.len().sub(1)) { print(",") }
        i = i.add(1)
    }
    println("")
}
variadic_print(10, 20, 30)

println("variadic: all passed")
