mode script

a := 34
b := 35
println(i64_to_str(add(a, b)))

s := "Hello"
println(s)

x : I64 = 35
println(i64_to_str(x))

greeting : Str = "Hi there"
println(greeting)

t := true
f := false
println(bool_to_str(t))
println(bool_to_str(f))
println(bool_to_str(and(true, true)))
println(bool_to_str(and(true, false)))
println(bool_to_str(or(false, false)))
println(bool_to_str(or(false, true)))

if true {
    println("if true works")
}

if false {
    println("FAIL")
} else {
    println("else works")
}

if and(true, true) {
    println("and(true, true) is truthy")
}

if and(true, false) {
    println("FAIL")
} else {
    println("and(true, false) is falsy")
}

while false {
    println("FAIL")
}
println("while false skipped")

println(bool_to_str(eq(1, 1)))
println(bool_to_str(lt(1, 2)))
println(bool_to_str(gt(2, 1)))

{
    inner := "scoped"
    println(inner)
}
println("after block")

println(bool_to_str(lte(1, 2)))
println(bool_to_str(lte(2, 2)))
println(bool_to_str(lte(3, 2)))
println(bool_to_str(gte(3, 2)))
println(bool_to_str(gte(2, 2)))
println(bool_to_str(gte(1, 2)))
println(bool_to_str(neq(1, 2)))
println(bool_to_str(neq(2, 2)))
println(i64_to_str(mod(10, 3)))
println(i64_to_str(mod(10, 5)))
println(i64_to_str(neg(42)))

mut counter := 0
counter = 1
counter = add(counter, 1)
println(i64_to_str(counter))

mut msg : Str = "hello"
msg = "world"
println(msg)

mut i := 0
while lt(i, 5) {
    print(i64_to_str(i), " ")
    i = add(i, 1)
}
println("")

// explicit FunctionDef type annotation
double : FunctionDef = func(n: I64) returns I64 {
    return mul(n, 2)
}
assert_eq(loc(), double(5), 10)

greet_person : FunctionDef = proc(name: Str) {
    println("hello, ", name)
}
greet_person("world")

Point : StructDef = struct {
    mut x := 0
    mut y := 0
}
p := Point()
println(i64_to_str(p.x))
println(i64_to_str(p.y))
p.x = 5
p.y = 10
println(i64_to_str(p.x))
println(i64_to_str(p.y))
println(loc())
assert(loc(), true)
assert(loc(), eq(1, 1))
println(concat("hello", " world"))
println(format("a", "b", "c"))
test(loc(), eq(2, 2), "2 should equal 2")
assert_eq(loc(), add(1, 1), 2)
assert_eq_str(loc(), concat("a", "b"), "ab")
