mode test

test_loc_directives := test() {
    // __LOC__ returns "file:line:col" string
    loc := __LOC__
    test_expect(__LOC__, loc.find("misc.til").neq(0.sub(1)), "__LOC__ contains filename")

    // __FILE__ returns file path string
    test_expect(__LOC__, __FILE__.find("misc.til").neq(0.sub(1)), "__FILE__ contains filename")

    // __LINE__ returns I64
    line := __LINE__
    assert_eq(__LOC__, line, 12)

    // __COL__ returns I64
    col := __COL__
    assert_eq(__LOC__, col, 12)
}

Foo := struct {
    x := 0
    namespace:
    bar := func(self: Foo) returns I64 { return self.x }
}

test_dyn_has_method := test() {
    // TODO(#15): dummy references so scavenger keeps clone
    assert_eq(__LOC__, 1.clone(), 1)
    assert_eq_str(__LOC__, "hi".clone(), "hi")

    test_expect(__LOC__, dyn_has_method("I64", "delete"), "I64 has delete")
    test_expect(__LOC__, dyn_has_method("I64", "clone"), "I64 has clone")
    test_expect(__LOC__, dyn_has_method("I64", "nonexistent").not(), "I64 no nonexistent")
    test_expect(__LOC__, dyn_has_method("Str", "delete"), "Str has delete")
    test_expect(__LOC__, dyn_has_method("Str", "nonexistent").not(), "Str no nonexistent")
    test_expect(__LOC__, dyn_has_method("Bool", "eq"), "Bool has eq")
    test_expect(__LOC__, dyn_has_method("Bool", "not").not(), "Bool no not (moved to top-level)")
    f := Foo(x=0)
    assert_eq(__LOC__, f.bar(), 0)
    test_expect(__LOC__, dyn_has_method("Foo", "bar"), "Foo has bar")
    test_expect(__LOC__, dyn_has_method("Foo", "baz").not(), "Foo no baz")
}

test_cmp := test() {
    assert_eq(__LOC__, I64.cmp(1, 2), 0.sub(1))
    assert_eq(__LOC__, I64.cmp(5, 5), 0)
    assert_eq(__LOC__, I64.cmp(3, 1), 1)
    assert_eq(__LOC__, U8.cmp(1, 2), 0.sub(1))
    assert_eq(__LOC__, U8.cmp(5, 5), 0)
    assert_eq(__LOC__, U8.cmp(3, 1), 1)
    assert_eq(__LOC__, Bool.cmp(false, false), 0)
    assert_eq(__LOC__, Bool.cmp(true, true), 0)
    assert_eq(__LOC__, Bool.cmp(false, true), 0.sub(1))
    assert_eq(__LOC__, Bool.cmp(true, false), 1)
    assert_eq(__LOC__, Str.cmp("abc", "abd"), 0.sub(1))
    assert_eq(__LOC__, Str.cmp("hello", "hello"), 0)
    assert_eq(__LOC__, Str.cmp("b", "a"), 1)
    assert_eq(__LOC__, Str.cmp("ab", "a"), 1)
    assert_eq(__LOC__, Str.cmp("a", "ab"), 0.sub(1))
}

// variadic args
variadic_sum := func(nums: ..I64) returns I64 {
    mut total := 0
    for n : I64 in nums {
        total = total.add(n)
    }
    return total
}

test_variadic := test() {
    assert_eq(__LOC__, variadic_sum(1, 2, 3), 6)
    assert_eq(__LOC__, variadic_sum(10), 10)
    assert_eq(__LOC__, variadic_sum(), 0)
}

// proc-based variadic test (not constant-foldable)
variadic_print := proc(nums: ..I64) {
    for i in 0..nums.len() {
        ref n: I64 = nums.get(i)
        print(n.to_str())
        if i.lt(nums.len().sub(1)) { print(",") }
    }
    println("")
}

test_variadic_proc := test() {
    variadic_print(10, 20, 30)
}

// Dynamic arg narrowing (#20): pass Dynamic where concrete type expected
test_dynamic_narrowing := test() {
    my_vec := vec("I64", 10, 20, 30)
    ref x2 : I64 = my_vec.get(0)
    assert_eq(__LOC__, x2, 10)
    // Dynamic value as typed argument
    assert_eq(__LOC__, 34.add(my_vec.get(0)), 44)
    // Chaining with typed start: 0.add(Dynamic) returns I64, chain continues
    assert_eq(__LOC__, 0.add(my_vec.get(0)).add(my_vec.get(1)).add(my_vec.get(2)), 60)
    // Top-level UFCS on Dynamic receiver: and/or/not are unique top-level functions
    my_bvec := vec("Bool", true, false)
    assert(__LOC__, my_bvec.get(0).and(my_bvec.get(0)))
    assert(__LOC__, my_bvec.get(1).or(my_bvec.get(0)))
    // TODO: my_bvec.get(1).not() — Bool values in Vec don't round-trip correctly (false→true)
}

test_i16 := test() {
    // Arithmetic
    a : I16 = 100
    b : I16 = 42
    assert_eq(__LOC__, a.add(b).to_i64(), 142)
    assert_eq(__LOC__, a.sub(b).to_i64(), 58)
    assert_eq(__LOC__, a.mul(b).to_i64(), 4200)
    assert_eq(__LOC__, a.div(b).to_i64(), 2)
    assert_eq(__LOC__, a.mod(b).to_i64(), 16)

    // Negative values
    c : I16 = 100.neg().to_i16()
    assert_eq(__LOC__, c.to_i64(), 100.neg())
    assert_eq(__LOC__, c.neg().to_i64(), 100)
    assert_eq(__LOC__, c.add(a).to_i64(), 0)

    // Comparisons
    assert(__LOC__, a.gt(b))
    assert(__LOC__, b.lt(a))
    assert(__LOC__, a.gte(a))
    assert(__LOC__, a.lte(a))
    assert(__LOC__, a.neq(b))
    assert(__LOC__, a.eq(a))
    assert(__LOC__, c.lt(a))

    // to_str
    assert_eq_str(__LOC__, 12345.to_i16().to_str(), "12345")
    assert_eq_str(__LOC__, 100.neg().to_i16().to_str(), "-100")

    // size
    assert_eq(__LOC__, I16.size().to_i64(), 2)
}

test_i32 := test() {
    a : I32 = 100
    b : I32 = 42
    assert_eq(__LOC__, a.add(b).to_i64(), 142)
    assert_eq(__LOC__, a.sub(b).to_i64(), 58)
    assert_eq(__LOC__, a.mul(b).to_i64(), 4200)
    assert_eq(__LOC__, a.div(b).to_i64(), 2)
    assert_eq(__LOC__, a.mod(b).to_i64(), 16)

    // Negative
    c : I32 = 100.neg().to_i32()
    assert_eq(__LOC__, c.to_i64(), 100.neg())
    assert_eq(__LOC__, c.neg().to_i64(), 100)

    // Comparisons
    assert(__LOC__, a.gt(b))
    assert(__LOC__, b.lt(a))
    assert(__LOC__, a.eq(a))
    assert(__LOC__, a.neq(b))
    assert(__LOC__, c.lt(a))

    // to_str
    assert_eq_str(__LOC__, 12345.to_i32().to_str(), "12345")
    assert_eq_str(__LOC__, 100.neg().to_i32().to_str(), "-100")

    // size
    assert_eq(__LOC__, I32.size().to_i64(), 4)
}

test_u32 := test() {
    // Arithmetic
    a : U32 = 100
    b : U32 = 42
    assert_eq(__LOC__, a.add(b).to_i64(), 142)
    assert_eq(__LOC__, a.sub(b).to_i64(), 58)
    assert_eq(__LOC__, a.mul(b).to_i64(), 4200)
    assert_eq(__LOC__, a.div(b).to_i64(), 2)
    assert_eq(__LOC__, a.mod(b).to_i64(), 16)

    // Comparisons (auto-generated from cmp)
    assert(__LOC__, a.gt(b))
    assert(__LOC__, b.lt(a))
    assert(__LOC__, a.gte(a))
    assert(__LOC__, a.lte(a))
    assert(__LOC__, a.neq(b))
    assert(__LOC__, a.eq(a))

    // Bitwise (0xFF00=65280, 0x0FF0=4080, AND=3840, OR=65520, XOR=61680)
    x : U32 = 65280
    y : U32 = 4080
    assert_eq(__LOC__, x.and(y).to_i64(), 3840)
    assert_eq(__LOC__, x.or(y).to_i64(), 65520)
    assert_eq(__LOC__, x.xor(y).to_i64(), 61680)

    // to_str
    assert_eq_str(__LOC__, 12345.to_u32().to_str(), "12345")

    // size
    assert_eq(__LOC__, U32.size().to_i64(), 4)
}

test_char_literals := test() {
    // Basic chars
    assert_eq(__LOC__, 'a'.to_i64(), 97)
    assert_eq(__LOC__, '0'.to_i64(), 48)
    assert_eq(__LOC__, '('.to_i64(), 40)

    // Escape sequences
    assert_eq(__LOC__, '\n'.to_i64(), 10)
    assert_eq(__LOC__, '\t'.to_i64(), 9)
    assert_eq(__LOC__, '\r'.to_i64(), 13)
    assert_eq(__LOC__, '\\'.to_i64(), 92)
    assert_eq(__LOC__, '\''.to_i64(), 39)
    assert_eq(__LOC__, '\0'.to_i64(), 0)

    // Comparison
    assert(__LOC__, 'a'.eq('a'))
    assert(__LOC__, 'a'.eq('b').not())

    // Arithmetic
    assert(__LOC__, 'a'.add('b'.sub('a')).eq('b'))

    // Type is U8
    c := 'x'
    assert_eq(__LOC__, c.to_i64(), 120)
}

test_switch_i64 := test() {
    mut result := 0
    switch 2 {
    case 1: result = 10
    case 2: result = 20
    case 3: result = 30
    case: result = 99
    }
    assert_eq(__LOC__, result, 20)

    // Default case
    switch 99 {
    case 1: result = 10
    case: result = 0.sub(1)
    }
    assert_eq(__LOC__, result, 0.sub(1))
}

test_switch_str := test() {
    mut result := ""
    switch "bob" {
    case "alice": result = "a"
    case "bob": result = "b"
    case: result = "?"
    }
    assert_eq_str(__LOC__, result, "b")
}

test_switch_char := test() {
    mut result := 0
    switch 'b' {
    case 'a': result = 1
    case 'b': result = 2
    case 'c': result = 3
    }
    assert_eq(__LOC__, result, 2)
}

test_switch_bool := test() {
    mut result := 0
    switch true {
    case true: result = 1
    case false: result = 2
    }
    assert_eq(__LOC__, result, 1)
}

test_switch_default_only := test() {
    mut result := 0
    switch 42 {
    case: result = 99
    }
    assert_eq(__LOC__, result, 99)
}

test_switch_no_default := test() {
    mut result := 0
    switch 1 {
    case 1: result = 10
    case 2: result = 20
    }
    assert_eq(__LOC__, result, 10)

    // No match, no default — nothing happens
    result = 0
    switch 5 {
    case 1: result = 10
    }
    assert_eq(__LOC__, result, 0)
}

test_switch_nested := test() {
    mut result := 0
    switch 1 {
    case 1:
        switch "a" {
        case "a": result = 11
        case "b": result = 12
        }
    case 2: result = 20
    }
    assert_eq(__LOC__, result, 11)
}

test_switch_in_loop := test() {
    // break inside switch body should exit enclosing loop, not the switch
    mut total := 0
    for i in 0..10 {
        switch i.mod(3) {
        case 0: total = total.add(i.to_i64())
        case 1: total = total.add(1)
        case: total = total.add(0)
        }
    }
    // i=0: +0, i=1: +1, i=2: +0, i=3: +3, i=4: +1, i=5: +0, i=6: +6, i=7: +1, i=8: +0, i=9: +9
    assert_eq(__LOC__, total, 21)
}

test_switch_multi_stmt := test() {
    mut a := 0
    mut b := 0
    switch 2 {
    case 1:
        a = 1
        b = 10
    case 2:
        a = 2
        b = 20
    case:
        a = 0
        b = 0
    }
    assert_eq(__LOC__, a, 2)
    assert_eq(__LOC__, b, 20)
}

// Phase 2: Range cases
test_switch_range_i64 := test() {
    mut result := ""
    switch 5 {
    case 0..3: result = "low"
    case 4..7: result = "mid"
    case 8..10: result = "high"
    case: result = "other"
    }
    assert_eq_str(__LOC__, result, "mid")
}

test_switch_range_char := test() {
    mut result := ""
    switch 'e' {
    case 'a'..'z': result = "lower"
    case 'A'..'Z': result = "upper"
    case '0'..'9': result = "digit"
    case: result = "other"
    }
    assert_eq_str(__LOC__, result, "lower")
}

test_switch_range_mixed := test() {
    // Mix ranges, exact values, and default
    mut result := 0
    switch 5 {
    case 0: result = 1
    case 1..4: result = 2
    case 5: result = 3
    case 6..9: result = 4
    case: result = 5
    }
    assert_eq(__LOC__, result, 3)
}

test_switch_range_boundary := test() {
    // Inclusive: end value should match
    mut result := false
    switch 'z' {
    case 'a'..'z': result = true
    }
    assert(__LOC__, result)

    result = false
    switch '9' {
    case '0'..'9': result = true
    }
    assert(__LOC__, result)

    // Start value should also match
    result = false
    switch 'a' {
    case 'a'..'z': result = true
    }
    assert(__LOC__, result)
}

// Phase 3: Enum matching (works via .eq() from Phase 1)
Color := enum { Red, Green, Blue }

test_switch_enum := test() {
    mut result := ""
    switch Color.Green {
    case Color.Red: result = "red"
    case Color.Green: result = "green"
    case Color.Blue: result = "blue"
    }
    assert_eq_str(__LOC__, result, "green")
}

// Phase 4: Payload extraction
Token := enum { Num: I64, Name: Str, Eof }

test_switch_payload := test() {
    mut result := 0
    switch Token.Num(42) {
    case Token.Num(value): result = value
    case Token.Name(s): result = 0.sub(1)
    case Token.Eof: result = 0.sub(2)
    }
    assert_eq(__LOC__, result, 42)
}

test_switch_payload_multi := test() {
    mut num_val := 0
    mut str_val := ""
    mut is_eof := false

    switch Token.Name("hello") {
    case Token.Num(n):
        num_val = n
    case Token.Name(s):
        str_val = s
    case Token.Eof:
        is_eof = true
    }
    assert_eq(__LOC__, num_val, 0)
    assert_eq_str(__LOC__, str_val, "hello")
    assert(__LOC__, is_eof.not())
}

test_switch_payload_with_default := test() {
    mut result := ""
    switch Token.Eof {
    case Token.Num(n): result = "num"
    case Token.Name(s): result = "name"
    case: result = "other"
    }
    assert_eq_str(__LOC__, result, "other")
}

// --- NULL literal + ref struct fields ---

test_null_ref_local := test() {
    // ref local can be NULL
    ref x : I64 = NULL
    accept_null(x)
}

accept_null := proc(x: I64) {
    // borrowed param can receive NULL
    assert(__LOC__, is_null(x))
}

test_null_borrowed_arg := test() {
    accept_null(NULL)
}

RefNode := struct {
    value := 0
    ref mut next : RefNode = NULL
}

test_ref_struct_field := test() {
    a := RefNode(value = 10)
    b := RefNode(value = 20)
    a.next = b
    assert_eq(__LOC__, a.value, 10)
    assert_eq(__LOC__, a.next.value, 20)

    // clone copies the pointer (not deep clone)
    c := a.clone()
    assert_eq(__LOC__, c.value, 10)
    assert_eq(__LOC__, c.next.value, 20)
}

// --- shallow keyword tests ---

shallow_add := func(shallow a: I64, shallow b: I64) returns I64 {
    return a.add(b)
}

shallow_mixed := func(shallow a: I64, b: I64) returns I64 {
    return a.add(b)
}

shallow_bool := func(shallow a: Bool, shallow b: Bool) returns Bool {
    return a.and(b)
}

shallow_chain := func(shallow x: I64) returns I64 {
    return x.mul(2)
}

test_shallow := test() {
    assert_eq(__LOC__, shallow_add(3, 4), 7)
    assert_eq(__LOC__, shallow_mixed(10, 20), 30)
    assert(__LOC__, shallow_bool(true, true))
    assert(__LOC__, shallow_bool(true, false).not())
    assert_eq(__LOC__, shallow_chain(5), 10)
    // shallow param passed to another shallow func
    assert_eq(__LOC__, shallow_add(shallow_chain(3), 1), 7)
}
