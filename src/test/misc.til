mode script

a := 34
b := 35
println(a.add(b).to_str())

s := "Hello"
println(s)

x : I64 = 35
println(x.to_str())

greeting : Str = "Hi there"
println(greeting)

t := true
f := false
println(t.to_str())
println(f.to_str())
println(and(true, true).to_str())
println(and(true, false).to_str())
println(or(false, false).to_str())
println(or(false, true).to_str())

if true {
    println("if true works")
}

if false {
    println("FAIL")
} else {
    println("else works")
}

if and(true, true) {
    println("and(true, true) is truthy")
}

if and(true, false) {
    println("FAIL")
} else {
    println("and(true, false) is falsy")
}

while false {
    println("FAIL")
}
println("while false skipped")

println(1.eq(1).to_str())
println(1.lt(2).to_str())
println(2.gt(1).to_str())

{
    inner := "scoped"
    println(inner)
}
println("after block")

println(1.lte(2).to_str())
println(2.lte(2).to_str())
println(3.lte(2).to_str())
println(3.gte(2).to_str())
println(2.gte(2).to_str())
println(1.gte(2).to_str())
println(1.neq(2).to_str())
println(2.neq(2).to_str())
println(10.mod(3).to_str())
println(10.mod(5).to_str())
println(42.neg().to_str())

mut counter := 0
counter = 1
counter = counter.add(1)
println(counter.to_str())

mut msg : Str = "hello"
msg = "world"
println(msg)

mut i := 0
while i.lt(5) {
    print(i.to_str(), " ")
    i = i.add(1)
}
println("")

// explicit FunctionDef type annotation
double : FunctionDef = func(n: I64) returns I64 {
    return n.mul(2)
}
assert_eq(loc(), double(5), 10)

greet_person : FunctionDef = proc(name: Str) {
    println("hello, ", name)
}
greet_person("world")

Point : StructDef = struct {
    mut x := 0
    mut y := 0
}
p := Point()
println(p.x.to_str())
println(p.y.to_str())
p.x = 5
p.y = 10
println(p.x.to_str())
println(p.y.to_str())
println(loc())
assert(loc(), true)
assert(loc(), 1.eq(1))
println(concat("hello", " world"))
println(format("a", "b", "c"))
test(loc(), 2.eq(2), "2 should equal 2")
assert_eq(loc(), 1.add(1), 2)
assert_eq_str(loc(), concat("a", "b"), "ab")
