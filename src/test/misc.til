mode test

Foo := struct {
    x := 0
    namespace:
    bar := func(self: Foo) returns I64 { return self.x }
}

test_dyn_has_method := test() {
    // TODO(#15): dummy references so scavenger keeps clone
    assert_eq(loc(), 1.clone(), 1)
    assert_eq_str(loc(), "hi".clone(), "hi")

    expect(loc(), dyn_has_method("I64", "delete"), "I64 has delete")
    expect(loc(), dyn_has_method("I64", "clone"), "I64 has clone")
    expect(loc(), dyn_has_method("I64", "nonexistent").not(), "I64 no nonexistent")
    expect(loc(), dyn_has_method("Str", "delete"), "Str has delete")
    expect(loc(), dyn_has_method("Str", "nonexistent").not(), "Str no nonexistent")
    expect(loc(), dyn_has_method("Bool", "eq"), "Bool has eq")
    expect(loc(), dyn_has_method("Bool", "not").not(), "Bool no not (moved to top-level)")
    f := Foo(x=0)
    assert_eq(loc(), f.bar(), 0)
    expect(loc(), dyn_has_method("Foo", "bar"), "Foo has bar")
    expect(loc(), dyn_has_method("Foo", "baz").not(), "Foo no baz")
}

test_cmp := test() {
    assert_eq(loc(), I64.cmp(1, 2), 0.sub(1))
    assert_eq(loc(), I64.cmp(5, 5), 0)
    assert_eq(loc(), I64.cmp(3, 1), 1)
    assert_eq(loc(), U8.cmp(U8.from_i64(1), U8.from_i64(2)), 0.sub(1))
    assert_eq(loc(), U8.cmp(U8.from_i64(5), U8.from_i64(5)), 0)
    assert_eq(loc(), U8.cmp(U8.from_i64(3), U8.from_i64(1)), 1)
    assert_eq(loc(), Bool.cmp(false, false), 0)
    assert_eq(loc(), Bool.cmp(true, true), 0)
    assert_eq(loc(), Bool.cmp(false, true), 0.sub(1))
    assert_eq(loc(), Bool.cmp(true, false), 1)
    assert_eq(loc(), Str.cmp("abc", "abd"), 0.sub(1))
    assert_eq(loc(), Str.cmp("hello", "hello"), 0)
    assert_eq(loc(), Str.cmp("b", "a"), 1)
    assert_eq(loc(), Str.cmp("ab", "a"), 1)
    assert_eq(loc(), Str.cmp("a", "ab"), 0.sub(1))
}

// variadic args
variadic_sum := func(nums: ..I64) returns I64 {
    mut total := 0
    for n : I64 in nums {
        total = total.add(n)
    }
    return total
}

test_variadic := test() {
    assert_eq(loc(), variadic_sum(1, 2, 3), 6)
    assert_eq(loc(), variadic_sum(10), 10)
    assert_eq(loc(), variadic_sum(), 0)
}

// proc-based variadic test (not constant-foldable)
variadic_print := proc(nums: ..I64) {
    for i in 0..nums.len() {
        ref n: I64 = nums.get(i)
        print(n.to_str())
        if i.lt(nums.len().sub(1)) { print(",") }
    }
    println("")
}

test_variadic_proc := test() {
    variadic_print(10, 20, 30)
}

// Dynamic arg narrowing (#20): pass Dynamic where concrete type expected
test_dynamic_narrowing := test() {
    my_vec := vec("I64", 10, 20, 30)
    ref x2 : I64 = my_vec.get(0)
    assert_eq(loc(), x2, 10)
    // Dynamic value as typed argument
    assert_eq(loc(), 34.add(my_vec.get(0)), 44)
    // Chaining with typed start: 0.add(Dynamic) returns I64, chain continues
    assert_eq(loc(), 0.add(my_vec.get(0)).add(my_vec.get(1)).add(my_vec.get(2)), 60)
    // Top-level UFCS on Dynamic receiver: and/or/not are unique top-level functions
    my_bvec := vec("Bool", true, false)
    assert(loc(), my_bvec.get(0).and(my_bvec.get(0)))
    assert(loc(), my_bvec.get(1).or(my_bvec.get(0)))
    // TODO: my_bvec.get(1).not() — Bool values in Vec don't round-trip correctly (false→true)
}

test_i16 := test() {
    // Arithmetic
    a : I16 = I16.from_i64(100)
    b : I16 = I16.from_i64(42)
    assert_eq(loc(), a.add(b).to_i64(), 142)
    assert_eq(loc(), a.sub(b).to_i64(), 58)
    assert_eq(loc(), a.mul(b).to_i64(), 4200)
    assert_eq(loc(), a.div(b).to_i64(), 2)
    assert_eq(loc(), a.mod(b).to_i64(), 16)

    // Negative values
    c : I16 = I16.from_i64(100.neg())
    assert_eq(loc(), c.to_i64(), 100.neg())
    assert_eq(loc(), c.neg().to_i64(), 100)
    assert_eq(loc(), c.add(a).to_i64(), 0)

    // Comparisons
    assert(loc(), a.gt(b))
    assert(loc(), b.lt(a))
    assert(loc(), a.gte(a))
    assert(loc(), a.lte(a))
    assert(loc(), a.neq(b))
    assert(loc(), a.eq(a))
    assert(loc(), c.lt(a))

    // to_str
    assert_eq_str(loc(), I16.from_i64(12345).to_str(), "12345")
    assert_eq_str(loc(), I16.from_i64(100.neg()).to_str(), "-100")

    // size
    assert_eq(loc(), I16.size(), 2)
}

test_i32 := test() {
    a : I32 = I32.from_i64(100)
    b : I32 = I32.from_i64(42)
    assert_eq(loc(), a.add(b).to_i64(), 142)
    assert_eq(loc(), a.sub(b).to_i64(), 58)
    assert_eq(loc(), a.mul(b).to_i64(), 4200)
    assert_eq(loc(), a.div(b).to_i64(), 2)
    assert_eq(loc(), a.mod(b).to_i64(), 16)

    // Negative
    c : I32 = I32.from_i64(100.neg())
    assert_eq(loc(), c.to_i64(), 100.neg())
    assert_eq(loc(), c.neg().to_i64(), 100)

    // Comparisons
    assert(loc(), a.gt(b))
    assert(loc(), b.lt(a))
    assert(loc(), a.eq(a))
    assert(loc(), a.neq(b))
    assert(loc(), c.lt(a))

    // to_str
    assert_eq_str(loc(), I32.from_i64(12345).to_str(), "12345")
    assert_eq_str(loc(), I32.from_i64(100.neg()).to_str(), "-100")

    // size
    assert_eq(loc(), I32.size(), 4)
}

test_u32 := test() {
    // Arithmetic
    a : U32 = U32.from_i64(100)
    b : U32 = U32.from_i64(42)
    assert_eq(loc(), a.add(b).to_i64(), 142)
    assert_eq(loc(), a.sub(b).to_i64(), 58)
    assert_eq(loc(), a.mul(b).to_i64(), 4200)
    assert_eq(loc(), a.div(b).to_i64(), 2)
    assert_eq(loc(), a.mod(b).to_i64(), 16)

    // Comparisons (auto-generated from cmp)
    assert(loc(), a.gt(b))
    assert(loc(), b.lt(a))
    assert(loc(), a.gte(a))
    assert(loc(), a.lte(a))
    assert(loc(), a.neq(b))
    assert(loc(), a.eq(a))

    // Bitwise (0xFF00=65280, 0x0FF0=4080, AND=3840, OR=65520, XOR=61680)
    x : U32 = U32.from_i64(65280)
    y : U32 = U32.from_i64(4080)
    assert_eq(loc(), x.and(y).to_i64(), 3840)
    assert_eq(loc(), x.or(y).to_i64(), 65520)
    assert_eq(loc(), x.xor(y).to_i64(), 61680)

    // to_str
    assert_eq_str(loc(), U32.from_i64(12345).to_str(), "12345")

    // size
    assert_eq(loc(), U32.size(), 4)
}
