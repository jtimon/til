mode script

a := 34
b := 35
println(to_str(add(a, b)))

s := "Hello"
println(s)

x : I64 = 35
println(to_str(x))

greeting : Str = "Hi there"
println(greeting)

t := true
f := false
println(to_str(t))
println(to_str(f))
println(to_str(and(true, true)))
println(to_str(and(true, false)))
println(to_str(or(false, false)))
println(to_str(or(false, true)))

if true {
    println("if true works")
}

if false {
    println("FAIL")
} else {
    println("else works")
}

if and(true, true) {
    println("and(true, true) is truthy")
}

if and(true, false) {
    println("FAIL")
} else {
    println("and(true, false) is falsy")
}

while false {
    println("FAIL")
}
println("while false skipped")

println(to_str(eq(1, 1)))
println(to_str(lt(1, 2)))
println(to_str(gt(2, 1)))

{
    inner := "scoped"
    println(inner)
}
println("after block")

println(to_str(lte(1, 2)))
println(to_str(lte(2, 2)))
println(to_str(lte(3, 2)))
println(to_str(gte(3, 2)))
println(to_str(gte(2, 2)))
println(to_str(gte(1, 2)))
println(to_str(neq(1, 2)))
println(to_str(neq(2, 2)))
println(to_str(mod(10, 3)))
println(to_str(mod(10, 5)))
println(to_str(neg(42)))

mut counter := 0
counter = 1
counter = add(counter, 1)
println(to_str(counter))

mut msg : Str = "hello"
msg = "world"
println(msg)

mut i := 0
while lt(i, 5) {
    print(to_str(i), " ")
    i = add(i, 1)
}
println("")

Point := struct {
    mut x := 0
    mut y := 0
}
p := Point()
println(to_str(p.x))
println(to_str(p.y))
p.x = 5
p.y = 10
println(to_str(p.x))
println(to_str(p.y))
println(loc())
