mode script

a := 34
b := 35
println(to_str(add(a, b)))

s := "Hello"
println(s)

x : I64 = 35
println(to_str(x))

greeting : Str = "Hi there"
println(greeting)

t := true
f := false
println(to_str(t))
println(to_str(f))
println(to_str(and(true, true)))
println(to_str(and(true, false)))
println(to_str(or(false, false)))
println(to_str(or(false, true)))

if true {
    println("if true works")
}

if false {
    println("FAIL")
} else {
    println("else works")
}

if and(true, true) {
    println("and(true, true) is truthy")
}

if and(true, false) {
    println("FAIL")
} else {
    println("and(true, false) is falsy")
}

while false {
    println("FAIL")
}
println("while false skipped")

println(to_str(eq(1, 1)))
println(to_str(lt(1, 2)))
println(to_str(gt(2, 1)))
