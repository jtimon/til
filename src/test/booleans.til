mode test

test_and := test() {
    assert(loc(), and(true, true))
    assert(loc(), and(true, false).not())
    assert(loc(), and(false, true).not())
    assert(loc(), and(false, false).not())
    assert(loc(), true.and(true))
    assert(loc(), true.and(false).not())
}

test_or := test() {
    assert(loc(), or(true, false))
    assert(loc(), or(false, true))
    assert(loc(), or(true, true))
    assert(loc(), or(false, false).not())
    assert(loc(), false.or(true))
    assert(loc(), false.or(false).not())
}

test_not := test() {
    assert(loc(), not(false))
    assert(loc(), not(true).not())
    assert(loc(), false.not())
    assert(loc(), true.not().not())
}

test_chaining := test() {
    assert(loc(), true.and(true).or(false))
    assert(loc(), false.or(true).and(true))
    assert(loc(), false.and(true).or(true))
    assert(loc(), not(and(false, true)))
    assert(loc(), or(not(true), true))
}
