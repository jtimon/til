mode test

test_and := test() {
    assert(__LOC__, and(true, true))
    assert(__LOC__, and(true, false).not())
    assert(__LOC__, and(false, true).not())
    assert(__LOC__, and(false, false).not())
    assert(__LOC__, true.and(true))
    assert(__LOC__, true.and(false).not())
}

test_or := test() {
    assert(__LOC__, or(true, false))
    assert(__LOC__, or(false, true))
    assert(__LOC__, or(true, true))
    assert(__LOC__, or(false, false).not())
    assert(__LOC__, false.or(true))
    assert(__LOC__, false.or(false).not())
}

test_not := test() {
    assert(__LOC__, not(false))
    assert(__LOC__, not(true).not())
    assert(__LOC__, false.not())
    assert(__LOC__, true.not().not())
}

test_chaining := test() {
    assert(__LOC__, true.and(true).or(false))
    assert(__LOC__, false.or(true).and(true))
    assert(__LOC__, false.and(true).or(true))
    assert(__LOC__, not(and(false, true)))
    assert(__LOC__, or(not(true), true))
}
