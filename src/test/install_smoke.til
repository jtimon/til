mode cli

run_shell := proc(mut out: Str, cmd: Str) returns I64 {
    return run_cmd(out, "sh", "-lc", cmd)
}

check := proc(cond: Bool, msg: Str, out: Str = "") {
    if cond { return }
    println("install FAIL: ", msg)
    if out.len().gt(0) {
        print(out)
    }
    exit(1)
}

check_exists := proc(path: Str) {
    check(file_mtime(path).gte(0), format("missing ", path))
}

main := proc(args: ..Str) {
    check(args.len().gte(1), "missing til binary path")
    ref til_bin : Str = args.get(0)
    prefix := "tmp/install_root"
    mut out := ""

    _cleanup := run_shell(out, "rm -rf tmp/install_root tmp/install_cwd")

    out = ""
    mut ec := run_shell(out, format(til_bin, " install --prefix=", prefix, " examples/hello_cli.til"))
    check(ec.eq(0), "install hello_cli", out)

    out = ""
    ec = run_shell(out, "mkdir -p tmp/install_cwd && cd tmp/install_cwd && ../install_root/bin/hello_cli")
    check(ec.eq(0).and(out.eq("Hello World!\n")), "run installed hello_cli from another cwd", out)

    out = ""
    ec = run_shell(out, format(til_bin, " install --prefix=", prefix, " src/til.til"))
    check(ec.eq(0), "install compiler", out)

    check_exists(prefix.concat("/bin/til"))
    check_exists(prefix.concat("/lib/til/src/core/core.til"))
    check_exists(prefix.concat("/lib/til/src/lib/libffi.til"))
    check_exists(prefix.concat("/lib/til/boot/modes.h"))
    check_exists(prefix.concat("/lib/til/lib/libffi/.built"))

    out = ""
    ec = run_shell(out, "mkdir -p tmp/install_cwd && cd tmp/install_cwd && ../install_root/bin/til interpret ../../examples/hello_cli.til")
    check(ec.eq(0).and(out.eq("Hello World!\n")), "run installed compiler from another cwd", out)

    out = ""
    ec = run_shell(out, format(prefix, "/bin/til install --prefix=", prefix, " src/test/install_lib.til"))
    check(ec.eq(0), "install library with installed compiler", out)

    check_exists(prefix.concat("/lib/libinstall_lib.so"))
    check_exists(prefix.concat("/lib/libinstall_lib.a"))
    check_exists(prefix.concat("/include/install_lib.h"))
    check_exists(prefix.concat("/lib/til/src/lib/install_lib.til"))
    check_exists(prefix.concat("/lib/til/src/lib/install_lib.py"))

    out = ""
    ec = run_shell(out, "mkdir -p tmp/install_cwd && cd tmp/install_cwd && ../install_root/bin/til interpret ../../src/test/install_consumer.til")
    check(ec.eq(0).and(out.eq("42\ninstalled library ok\n")), "import installed library by name", out)

    println("install PASS")
}
