mode test

test_i64_array_literal := test() {
    arr := array("I64", 1, 2, 3)
    assert_eq(loc(), arr.len(), 3)
    ref a0 : I64 = arr.get(0)
    ref a1 : I64 = arr.get(1)
    ref a2 : I64 = arr.get(2)
    assert_eq(loc(), a0, 1)
    assert_eq(loc(), a1, 2)
    assert_eq(loc(), a2, 3)
}

test_i64_vec_literal := test() {
    myvec := vec("I64", 10, 20, 30)
    assert_eq(loc(), myvec.len(), 3)
    ref v0 : I64 = myvec.get(0)
    ref v1 : I64 = myvec.get(1)
    ref v2 : I64 = myvec.get(2)
    assert_eq(loc(), v0, 10)
    assert_eq(loc(), v1, 20)
    assert_eq(loc(), v2, 30)
}

test_str_array_literal := test() {
    sarr := array("Str", "hello", "world")
    assert_eq(loc(), sarr.len(), 2)
    ref s0 : Str = sarr.get(0)
    ref s1 : Str = sarr.get(1)
    assert_eq_str(loc(), s0, "hello")
    assert_eq_str(loc(), s1, "world")
}

test_str_vec_literal := test() {
    svec := vec("Str", "foo", "bar", "baz")
    assert_eq(loc(), svec.len(), 3)
    ref sv0 : Str = svec.get(0)
    ref sv1 : Str = svec.get(1)
    ref sv2 : Str = svec.get(2)
    assert_eq_str(loc(), sv0, "foo")
    assert_eq_str(loc(), sv1, "bar")
    assert_eq_str(loc(), sv2, "baz")
}
