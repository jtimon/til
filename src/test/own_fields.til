mode test

Point := struct {
    mut x := 0
    mut y := 0
}

Line := struct {
    own mut start := Point(x=0, y=0)
    own mut end := Point(x=0, y=0)
}

# Test 1: own field access with constructor args
test_own_field_access := test() {
    line := Line(start=Point(x=1, y=2), end=Point(x=3, y=4))
    assert_eq(__LOC__, line.start.x, 1)
    assert_eq(__LOC__, line.start.y, 2)
    assert_eq(__LOC__, line.end.x, 3)
    assert_eq(__LOC__, line.end.y, 4)
}

# Test 2: default constructor
test_own_field_defaults := test() {
    line := Line()
    assert_eq(__LOC__, line.start.x, 0)
    assert_eq(__LOC__, line.start.y, 0)
    assert_eq(__LOC__, line.end.x, 0)
    assert_eq(__LOC__, line.end.y, 0)
}

# Test 3: clone struct with own fields
test_own_field_clone := test() {
    line := Line(start=Point(x=1, y=2), end=Point(x=3, y=4))
    line2 := line.clone()
    assert_eq(__LOC__, line2.start.x, 1)
    assert_eq(__LOC__, line2.end.y, 4)
}

# Test 4: field assignment through own field
test_own_field_nested_assign := test() {
    line := Line(start=Point(x=1, y=2), end=Point(x=3, y=4))
    line.start.x = 10
    assert_eq(__LOC__, line.start.x, 10)
    assert_eq(__LOC__, line.start.y, 2)
}

# Test 5: own field replacement
test_own_field_replace := test() {
    line := Line(start=Point(x=1, y=2), end=Point(x=3, y=4))
    line.start = Point(x=100, y=200)
    assert_eq(__LOC__, line.start.x, 100)
    assert_eq(__LOC__, line.start.y, 200)
}

# Test 6: clone independence
test_own_field_clone_independence := test() {
    line := Line(start=Point(x=1, y=2), end=Point(x=3, y=4))
    line2 := line.clone()
    line.start.x = 99
    assert_eq(__LOC__, line2.start.x, 1)
    assert_eq(__LOC__, line.start.x, 99)
}
