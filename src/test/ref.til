mode test

# --- ref returns with I64 ---

min := func(a: I64, b: I64) returns ref I64 {
    if a.lt(b) { return a } else { return b }
}

test_ref_i64 := test() {
    x := 3
    y := 7
    ref m := min(x, y)
    assert_eq(__LOC__, m, 3)
}

# --- ref returns with Str ---

shorter := func(a: Str, b: Str) returns ref Str {
    if a.len().lt(b.len()) { return a } else { return b }
}

test_ref_str := test() {
    a := "hi"
    b := "hello"
    ref s := shorter(a, b)
    assert_eq_str(__LOC__, s, "hi")
}

# --- ref from parameter ---

identity := func(x: I64) returns ref I64 {
    return x
}

test_ref_from_param := test() {
    v := 42
    ref r := identity(v)
    assert_eq(__LOC__, r, 42)
}

# --- ref from owned compound local ---

RefPoint := struct {
    mut x := 0
    mut y := 0
}

test_ref_from_owned_compound := test() {
    p := RefPoint(x = 42, y = 99)
    ref r : RefPoint = p
    assert_eq(__LOC__, r.x, 42)
    assert_eq(__LOC__, r.y, 99)
}

# --- ref from field access ---

RefBox := struct {
    mut n := 0
    namespace:
    get_n := func(self: RefBox) returns ref I64 {
        return self.n
    }
}

test_ref_from_field_return := test() {
    b := RefBox(n = 9)
    ref n : I64 = b.get_n()
    assert_eq(__LOC__, n, 9)
}

test_ref_decl_from_field := test() {
    b := RefBox(n = 11)
    ref n : I64 = b.n
    assert_eq(__LOC__, n, 11)
}

# --- ref Dynamic from owned compound ---

test_ref_dynamic_from_struct := test() {
    p := RefPoint(x = 10, y = 20)
    ref d : Dynamic = p
    ref p2 : RefPoint = d
    assert_eq(__LOC__, p2.x, 10)
    assert_eq(__LOC__, p2.y, 20)
}
