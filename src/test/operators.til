mode test

test_arithmetic := test() {
    assert_eq(__LOC__, 34.add(35), 69)
    assert_eq(__LOC__, 10.sub(3), 7)
    assert_eq(__LOC__, 6.mul(7), 42)
    assert_eq(__LOC__, 10.div(3), 3)
    assert_eq(__LOC__, 10.mod(3), 1)
    assert_eq(__LOC__, 10.mod(5), 0)
    assert_eq(__LOC__, 42.neg(), -42)

    // Negative literal syntax: -N desugars to 0.sub(N)
    assert_eq(__LOC__, -1, 0.sub(1))
    assert_eq(__LOC__, -42, 0.sub(42))
    assert_eq(__LOC__, -100, 0.sub(100))
    assert_eq(__LOC__, 10.add(-3), 7)
    assert_eq(__LOC__, -5.add(3), -2)
    assert_eq(__LOC__, -1.neg(), 1)
}

test_comparison := test() {
    assert(__LOC__, 1.eq(1))
    assert(__LOC__, 1.lt(2))
    assert(__LOC__, 2.gt(1))
    assert(__LOC__, 1.lte(2))
    assert(__LOC__, 2.lte(2))
    assert(__LOC__, 3.lte(2).not())
    assert(__LOC__, 3.gte(2))
    assert(__LOC__, 2.gte(2))
    assert(__LOC__, 1.gte(2).not())
    assert(__LOC__, 1.neq(2))
    assert(__LOC__, 2.neq(2).not())
}

test_boolean := test() {
    assert(__LOC__, true.and(true))
    assert(__LOC__, true.and(false).not())
    assert(__LOC__, false.or(false).not())
    assert(__LOC__, false.or(true))
    assert(__LOC__, true.not().not())
    assert(__LOC__, false.not())
}

test_bitwise := test() {
    assert_eq(__LOC__, 6.and(3), 2)
    assert_eq(__LOC__, 6.or(3), 7)
    assert_eq(__LOC__, 6.xor(3), 5)
}

test_f32_arithmetic := test() {
    a := 10.to_f32()
    b := 3.to_f32()

    assert_eq(__LOC__, a.add(b).to_i64(), 13)
    assert_eq(__LOC__, a.sub(b).to_i64(), 7)
    assert_eq(__LOC__, a.mul(b).to_i64(), 30)
    assert_eq(__LOC__, a.div(b).to_i64(), 3)

    // Float precision with literals
    x : F32 = 3.14
    assert_eq_str(__LOC__, x.to_str(), "3.14")

    y : F32 = 2.5
    assert_eq_str(__LOC__, y.add(y).to_str(), "5")
    assert_eq_str(__LOC__, y.mul(y).to_str(), "6.25")

    // Comparisons
    assert(__LOC__, a.eq(10.to_f32()))
    assert(__LOC__, a.eq(b).not())
    assert_eq(__LOC__, a.cmp(b), 1)
    assert_eq(__LOC__, b.cmp(a), -1)
    assert_eq(__LOC__, a.cmp(10.to_f32()), 0)

    // Conversions
    assert_eq(__LOC__, F32.size().to_i64(), 4)
    z : F32 = 7.9
    assert_eq(__LOC__, z.to_i64(), 7)
}

test_mutation := test() {
    mut counter := 0
    counter = 1
    counter = counter.add(1)
    assert_eq(__LOC__, counter, 2)
    mut msg : Str = "hello"
    msg = "world"
    assert_eq_str(__LOC__, msg, "world")
}

// --- Operator syntax tests (#22) ---

test_op_arithmetic := test() {
    assert_eq(__LOC__, 34 + 35, 69)
    assert_eq(__LOC__, 10 - 3, 7)
    assert_eq(__LOC__, 6 * 7, 42)
    assert_eq(__LOC__, 10 / 3, 3)
    assert_eq(__LOC__, 10 % 3, 1)
    assert_eq(__LOC__, 10 % 5, 0)
}

test_op_comparison := test() {
    assert(__LOC__, 1 == 1)
    assert(__LOC__, 1 < 2)
    assert(__LOC__, 2 > 1)
    assert(__LOC__, 1 <= 2)
    assert(__LOC__, 2 <= 2)
    assert(__LOC__, (3 <= 2).not())
    assert(__LOC__, 3 >= 2)
    assert(__LOC__, 2 >= 2)
    assert(__LOC__, (1 >= 2).not())
    assert(__LOC__, 1 != 2)
    assert(__LOC__, (2 != 2).not())
}

test_op_precedence := test() {
    // * / % bind tighter than + -
    assert_eq(__LOC__, 2 + 3 * 4, 14)
    assert_eq(__LOC__, 10 - 2 * 3, 4)
    assert_eq(__LOC__, 2 * 3 + 4 * 5, 26)

    // Grouping parens override precedence
    assert_eq(__LOC__, (2 + 3) * 4, 20)
    assert_eq(__LOC__, (10 - 2) * 3, 24)

    // Comparison is lower than arithmetic
    assert(__LOC__, 2 + 3 == 5)
    assert(__LOC__, 10 - 3 > 5)
    assert(__LOC__, 2 * 3 < 10)
    assert(__LOC__, 10 / 2 >= 5)
    assert(__LOC__, 10 % 3 <= 1)
    assert(__LOC__, 2 + 3 != 6)
}

test_op_with_variables := test() {
    a := 10
    b := 3
    assert_eq(__LOC__, a + b, 13)
    assert_eq(__LOC__, a - b, 7)
    assert_eq(__LOC__, a * b, 30)
    assert_eq(__LOC__, a / b, 3)
    assert_eq(__LOC__, a % b, 1)
    assert(__LOC__, a > b)
    assert(__LOC__, b < a)
    assert(__LOC__, a != b)
    assert(__LOC__, a == 10)
}

test_op_mixed_with_methods := test() {
    // Operators mixed with method calls
    assert_eq(__LOC__, 5.add(3) * 2, 16)
    assert_eq(__LOC__, (2 + 3).mul(4), 20)
    assert(__LOC__, "hello".len().to_i64() == 5)

    // Negative literals still work with operators
    assert_eq(__LOC__, -1 + 2, 1)
    assert_eq(__LOC__, 10 + -3, 7)

    // Mutation with operators
    mut counter := 0
    counter = counter + 1
    counter = counter + 1
    assert_eq(__LOC__, counter, 2)
}
