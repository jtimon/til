mode test

// Auto-generated inc/dec from add+sub+unity

Vec2 := struct {
    mut x : I64 = 0
    mut y : I64 = 0
namespace:
    add := func(a: Vec2, b: Vec2) returns Vec2 {
        return Vec2(x = a.x.add(b.x), y = a.y.add(b.y))
    }
    sub := func(a: Vec2, b: Vec2) returns Vec2 {
        return Vec2(x = a.x.sub(b.x), y = a.y.sub(b.y))
    }
    unity := func(_self: Vec2) returns Vec2 { return Vec2(x = 1, y = 1) }
    cmp := func(a: Vec2, b: Vec2) returns I64 {
        if a.x.lt(b.x) { return -1 }
        if a.x.gt(b.x) { return 1 }
        return a.y.cmp(b.y)
    }
    to_str := func(self: Vec2) returns Str { return self.x.to_str() }
}

test_vec2_inc_dec := test() {
    mut v := Vec2(x = 3, y = 5)
    v.inc()
    assert_eq(__LOC__, v.x, 4)
    assert_eq(__LOC__, v.y, 6)
    v.dec()
    assert_eq(__LOC__, v.x, 3)
    assert_eq(__LOC__, v.y, 5)
}
