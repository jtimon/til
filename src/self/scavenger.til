mode lib

// Check if a FieldAccess is a namespace access (type-level, not instance).
// The typer marks type-name idents with StructDef/EnumDef til_type.
priv scav_fa_is_ns := func(e: Expr) returns Bool {
    if e.children.len().eq(0) { return false }
    ref obj : Expr = e.child(0)
    switch obj.node_type {
    case NodeType.Ident(id):
        obj_type_name := til_type_name(obj.expr_til_type())
        if obj_type_name.eq("StructDef").or(obj_type_name.eq("EnumDef")) {
            return true
        }
        // Also check: if ident name matches struct_name, it's a type reference
        if obj_type_name.len().gt(0).and(obj_type_name.eq(id.ident_name())) { return true }
    case:
    }
    return false
}

priv qualified_name := func(type_name: Str, method_name: Str) returns Str {
    return type_name.format(".", method_name)
}

vec_push_str := func(mut v: Vec, s: Str) {
    v.push(own s.clone())
}

// Compact+delete: mark dropped indices in a bool buffer, delete them,
// then compact kept elements forward.
priv children_filter := func(mut v: Vec, marks: Dynamic, n: USize) {
    // Delete marked elements and zero their bytes
    mut i : USize = 0
    while i.lt(n) {
        ref mark : Bool = ptr_add(marks, i)
        if mark {
            v.elem_delete(ptr_add(v.data, i.mul(v.elem_size)), false)
            memset(ptr_add(v.data, i.mul(v.elem_size)), 0, v.elem_size)
        }
        i = i.add(1)
    }
    // Compact: move kept elements forward
    mut w : USize = 0
    mut r : USize = 0
    while r.lt(n) {
        ref mark : Bool = ptr_add(marks, r)
        if mark.not() {
            if w.neq(r) {
                memcpy(ptr_add(v.data, w.mul(v.elem_size)), ptr_add(v.data, r.mul(v.elem_size)), v.elem_size)
            }
            w = w.add(1)
        }
        r = r.add(1)
    }
    v.count = w
}

// Push qualified "Type.method" refs into v
push_qn := func(mut v: Vec, type_name: Str, method: Str) {
    v.push(own qualified_name(type_name, method))
}

priv push_builtin_methods := func(mut v: Vec, builtin_name: Str, m1: Str, m2: Str, m3: Str) {
    v.push(own qualified_name(builtin_name, m1))
    v.push(own qualified_name(builtin_name, m2))
    v.push(own qualified_name(builtin_name, m3))
}

collect_refs := func(e: Expr, mut refs: Vec) {
    if e.is_null() { return }

    switch e.node_type {
    case NodeType.Ident(ident):
        vec_push_str(refs, ident.ident_name())
    case NodeType.FCall:
        // Check for namespace method call: Type.method(args...)
        if e.children.len().gt(0) {
            if e.child(0).node_type.is(NodeType.FieldAccess) {
                if scav_fa_is_ns(e.child(0)) {
                    ref fa : Expr = e.child(0)
                    switch fa.child(0).node_type {
                    case NodeType.Ident(type_name):
                        switch fa.node_type {
                        case NodeType.FieldAccess(method):
                            vec_push_str(refs, type_name.ident_name())
                            push_qn(refs, type_name.ident_name(), method.field_access_name())
                            // Issue #56/#57: when the typer rewrites a Type-typed
                            // arg (e.g. count_variants(Color3) where T: Type) into
                            // Type.Enum("Color3") / Type.Struct(...) / Type.Custom(...),
                            // the underlying type name only survives as the string
                            // literal arg. Without recording it here the scavenger
                            // would prune the enum/struct decl as unused.
                            if type_name.ident_name().eq("Type") {
                                mn := method.field_access_name()
                                is_named_type_ctor := mn.eq("Enum").or(mn.eq("Struct")).or(mn.eq("Custom"))
                                if is_named_type_ctor.and(e.children.len().gte(2)) {
                                    switch e.child(1).node_type {
                                    case NodeType.Literal(Literal.Str(tname)):
                                        vec_push_str(refs, tname)
                                    case:
                                    }
                                }
                            }
                        case:
                            UNREACHABLE(__LOC__)
                            return
                        }
                    case:
                        UNREACHABLE(__LOC__)
                        return
                    }
                    // Recurse into args (skip callee -- already handled)
                    for i in 1..e.children.len() {
                        collect_refs(e.child(i), refs)
                    }
                    return
                }
            }
        }
        // array()/vec() builtins need Array/Vec constructor methods
        if e.children.len().gte(2) {
            if e.child(0).node_type.is(NodeType.Ident) {
                switch e.child(0).node_type {
                case NodeType.Ident(cn):
                    if cn.ident_name().eq("array") {
                        push_builtin_methods(refs, "Array", "new", "set", "delete")
                    } else if cn.ident_name().eq("vec") {
                        push_builtin_methods(refs, "Vec", "new", "push", "delete")
                    } else if cn.ident_name().eq("struct_def_of").or(cn.ident_name().eq("enum_def_of")) {
                        // Issue #56/#57: struct_def_of("X") / enum_def_of("X")
                        // builds a runtime StructDef/EnumDef value by querying
                        // the introspection primitives for type X. Pull X out
                        // of the string-literal arg so the underlying decl
                        // isn't scavenged as unused.
                        switch e.child(1).node_type {
                        case NodeType.Literal(Literal.Str(tname2)):
                            vec_push_str(refs, tname2)
                        case:
                        }
                    }
                case:
                    UNREACHABLE(__LOC__)
                }
            }
        }
    case NodeType.FuncDef(fdef):
        for p : Declaration in fdef.params {
            if p.explicit_type.len().gt(0) {
                vec_push_str(refs, p.explicit_type)
            }
        }
        if fdef.variadic_index.gte(0) {
            vec_push_str(refs, "Array")
            push_qn(refs, "Array", "new")
            push_qn(refs, "Array", "set")
            push_qn(refs, "Array", "delete")
        }
        if fdef.return_type.len().gt(0) {
            vec_push_str(refs, fdef.return_type)
        }
    case NodeType.FieldAccess(field_name):
        if scav_fa_is_ns(e) {
            if e.child(0).node_type.is(NodeType.Ident) {
                switch e.child(0).node_type {
                case NodeType.Ident(type_name):
                    vec_push_str(refs, type_name.ident_name())
                    push_qn(refs, type_name.ident_name(), field_name.field_access_name())
                case:
                    UNREACHABLE(__LOC__)
                }
            }
        }
    case NodeType.FieldAssign(fad):
        field_name := fad.name
        if scav_fa_is_ns(e) {
            if e.child(0).node_type.is(NodeType.Ident) {
                switch e.child(0).node_type {
                case NodeType.Ident(type_name):
                    vec_push_str(refs, type_name.ident_name())
                    push_qn(refs, type_name.ident_name(), field_name)
                case:
                    UNREACHABLE(__LOC__)
                }
            }
        }
    case NodeType.Decl(decl):
        if decl.explicit_type.len().gt(0) {
            vec_push_str(refs, decl.explicit_type)
        }
    case:
    }

    // Also traverse sdd.fields for structs
    switch e.node_type {
    case NodeType.StructDef(cr_sdd):
        for cr_fd : Declaration in cr_sdd.fields {
            if cr_fd.default_value.is_null().not() {
                collect_refs(cr_fd.default_value, refs)
            }
            if cr_fd.explicit_type.len().gt(0) {
                vec_push_str(refs, cr_fd.explicit_type)
            }
        }
    case:
    }
    // Also traverse ns_decls entries (not in Expr children tree)
    if e.node_type.is(NodeType.StructDef).or(e.node_type.is(NodeType.EnumDef)) {
        ref cr_ns : Vec = def_ns_decls(e)
        for cr_d : Declaration in cr_ns {
            if cr_d.default_value.is_null().not() {
                collect_refs(cr_d.default_value, refs)
            }
        }
    }

    // Recurse into children
    for c : Expr in e.children {
        collect_refs(c, refs)
    }
}

// Filter top-level declarations and namespace methods in-place using a
// precomputed visited set.
scavenge_filter := func(mut program: Expr, visited: Set) {
    pn := program.children.len()
    pm : Dynamic = malloc(pn)
    memset(pm, 0, pn)
    for i in 0..pn {
        ref stmt : Expr = program.child(i)
        if is_def(stmt) {
            switch stmt.node_type {
            case NodeType.Decl(d):
                // Issue #56/#57: synthetic anon-lifted decls (AnonStructN /
                // AnonEnumN) are emitted by the parser only when there's a
                // matching user site, so they're always reachable in spirit.
                // The scavenger's reachability walk can lose track of them
                // when the typer rewrites a Type-ident into a constructor
                // call and the hoister moves the type-name string into a
                // hoisted Str temp; keep them unconditionally rather than
                // duplicating that indirection here.
                is_anon_lifted := d.name.starts_with("AnonStruct").or(d.name.starts_with("AnonEnum"))
                if visited.has(d.name).not().and(is_anon_lifted.not()) {
                    memset(ptr_add(pm, i), 1, 1)
                }
            case:
                UNREACHABLE(__LOC__)
            }
        }
    }
    children_filter(program.children, pm, pn)
    free(own pm)

    for stmt : Expr in program.children {
        if is_struct_or_enum(stmt).not() { continue }
        switch stmt.node_type {
        case NodeType.Decl(sdecl):
            ref scv_ns2 : Vec = def_ns_decls(stmt.child(0))
            scv_nn2 := scv_ns2.len()
            if scv_nn2.gt(0) {
                scv_nm2 : Dynamic = malloc(scv_nn2)
                memset(scv_nm2, 0, scv_nn2)
                for j in 0..scv_nn2 {
                    ref nsd : Declaration = scv_ns2[j]
                    scv_qn2 := qualified_name(sdecl.name, nsd.name)
                    if visited.has(scv_qn2).not() {
                        memset(ptr_add(scv_nm2, j), 1, 1)
                    }
                }
                children_filter(scv_ns2, scv_nm2, scv_nn2)
                free(own scv_nm2)
            }
        case:
            UNREACHABLE(__LOC__)
        }
    }
}

// --- Body-level DCE (post-precomp dead temp elimination) -----------------

// Constant folding in precomp replaces FCall nodes with literals, but the
// arg-temps that the typer hoisted (`hoisted__<Type>_<n>`) remain as sibling
// Decls with no remaining references. They're side-effect-free (literal
// RHS, by-value primitive type), so we can drop them outright instead of
// papering over the unused-variable warning with a `(void)<name>;`.

// dyn_call/dyn_call_ret FCalls carry args beyond `nargs` that the
// builder discards (see `is_dyn_call_name` handling in builder.til). So
// `dyn_call_ret(self, "method", nargs, arg1, ..., argN, extra...)` only
// "really uses" args up to index 4+nargs-1; later children are weak
// refs that should not pin a hoisted temp.
priv dyn_call_real_arg_count := func(e: Expr) returns USize {
    if e.node_type.is(NodeType.FCall).not() { return e.children.len() }
    if e.children.len().lt(4) { return e.children.len() }
    ref callee : Expr = e.child(0)
    mut is_dc := false
    switch callee.node_type {
    case NodeType.Ident(cn): is_dc = cn.ident_name().eq("dyn_call").or(cn.ident_name().eq("dyn_call_ret"))
    case:
    }
    if is_dc.not() { return e.children.len() }
    ref nargs_e : Expr = e.child(3)
    mut nargs : USize = 0
    switch nargs_e.node_type {
    case NodeType.Literal(Literal.Num(s)):
        nargs = s.literal_num_text().to_usize()
    case:
        return e.children.len()
    }
    real := nargs.add(4)
    if real.gt(e.children.len()) { return e.children.len() }
    return real
}

// Collect Ident/Assign refs anywhere in the subtree. Inside any Body,
// skip trivial `<Type>.delete(<candidate>, false)` cleanup calls (at
// any nesting depth) so a candidate's auto-generated cleanup doesn't
// pin it. Phase 3 prunes those cleanup stmts alongside the candidate.
priv collect_body_refs := proc(e: Expr, mut refs: Set, candidates: Set) {
    if e.is_null() { return }
    switch e.node_type {
    case NodeType.Ident(name):
        refs.add(own name.ident_name())
    case NodeType.Assign(adata):
        refs.add(own adata.name.clone())
    case:
    }
    is_body := e.node_type.is(NodeType.Body)
    real_n := dyn_call_real_arg_count(e)
    mut idx : USize = 0
    for c : Expr in e.children {
        if idx.gte(real_n) { break }
        if is_body {
            target := match_trivial_delete(c)
            if target.len().gt(0).and(candidates.has(target)) {
                idx = idx.add(1)
                continue
            }
        }
        collect_body_refs(c, refs, candidates)
        idx = idx.add(1)
    }
}

// Recognize the typer-emitted "trivial delete" pattern:
//
//     <TypeName>.delete(<Ident>, LiteralBool false)
//
// These are auto-generated cleanup calls for hoisted primitive temps
// and for LiteralStr arg-temps (which the typer marks Shallow so
// call_free=false). They emit as a bare `;` (the builder's by-value-
// delete shortcut) or as a no-op cleanup of a stack compound literal
// (TIL_CAP_LIT view), so dropping them with the temp is safe and lets
// DCE actually remove the temp without false-positive ref hits from
// the cleanup itself.
//
// Returns the target Ident name on match, "" otherwise.
priv match_trivial_delete := func(stmt: Expr) returns Str {
    if stmt.node_type.is(NodeType.FCall).not() { return "" }
    if stmt.children.len().neq(3) { return "" }
    ref callee : Expr = stmt.child(0)
    if callee.node_type.is(NodeType.FieldAccess).not() { return "" }
    mut method := ""
    switch callee.node_type {
    case NodeType.FieldAccess(m): method = m.field_access_name()
    case:
    }
    if method.eq("delete").not() { return "" }
    if callee.children.len().neq(1) { return "" }
    ref tname : Expr = callee.child(0)
    if tname.node_type.is(NodeType.Ident).not() { return "" }
    ref arg0 : Expr = stmt.child(1)
    if arg0.node_type.is(NodeType.Ident).not() { return "" }
    ref arg1 : Expr = stmt.child(2)
    if arg1.node_type.is_literal_bool().not() { return "" }
    mut bv := false
    switch arg1.node_type {
    case NodeType.Literal(Literal.Bool(b)): bv = b
    case:
    }
    if bv { return "" }
    mut tn := ""
    switch arg0.node_type {
    case NodeType.Ident(n): tn = n.ident_name()
    case:
    }
    return tn
}

// Side-effect-free, by-value RHS: dropping the binding cannot leak or
// observe anything. LiteralStr is included because the typer marks
// LiteralStr decls Shallow, the builder emits them as stack compound
// literals (no malloc), and the paired Str.delete uses call_free=false
// (no-op view cleanup) -- so dropping the Decl + its trivial delete
// has no observable effect.
priv rhs_is_pure_byvalue := func(e: Expr) returns Bool {
    if e.is_null() { return false }
    switch e.node_type {
    case NodeType.Literal(Literal.Num):  return true
    case NodeType.Literal(Literal.Bool): return true
    case NodeType.Literal(Literal.Null): return true
    case NodeType.Literal(Literal.Str):  return true
    case:
    }
    return false
}

// One DCE pass over a single Body. Returns true if anything was removed.
// Mark codes for body rewrite: 0=keep (default), 1=delete, 2=replace-with-rhs.
priv MARK_DELETE : U8 = 1
priv MARK_REPLACE_RHS : U8 = 2

// Recursively prune trivial-delete stmts from any Body in the subtree
// when they target a name in `dropped`. Used after candidates have
// been dropped/replaced in the outer body, since their cleanup calls
// also live in nested early-return bodies (if-then deletes before a
// return) that the outer body's phase 3 didn't reach.
priv prune_trivial_deletes := proc(mut e: Expr, dropped: Set) {
    if e.is_null() { return }
    if e.node_type.is(NodeType.Body) {
        n := e.children.len()
        if n.gt(0) {
            marks : Dynamic = malloc(n)
            memset(marks, 0, n)
            mut any := false
            for i in 0..n {
                ref stmt : Expr = e.child(i)
                target := match_trivial_delete(stmt)
                if target.len().eq(0) { continue }
                if dropped.has(target).not() { continue }
                memset(ptr_add(marks, i), 1, 1)
                any = true
            }
            if any { children_filter(e.children, marks, n) }
            free(own marks)
        }
    }
    for j in 0..e.children.len() {
        prune_trivial_deletes(e.child(j), dropped)
    }
}

// `at_top_level` is true for the program-root body (which becomes
// main() for non-library modes). At top level we restrict candidates
// to compiler-internal `hoisted__*` names so we never drop a
// user-named global -- those may be exported and referenced from
// outside this body's view.
priv dce_one_body := proc(mut body: Expr, at_top_level: Bool) returns Bool {
    n := body.children.len()
    if n.eq(0) { return false }

    // Phase 1: identify candidate temp Decls. Two flavors:
    //   - literal-RHS by-value temps (LiteralNum/Bool/Null/Str): the
    //     whole Decl can be deleted outright. LiteralStr qualifies
    //     because the typer marks these decls Shallow and the builder
    //     emits them as stack compound literals -- no allocation, and
    //     the paired delete is a no-op view cleanup.
    //   - `_t_*` with FCall RHS: the binding is unused, but the FCall
    //     may have side effects, so we replace the Decl stmt with the
    //     bare FCall rather than dropping it.
    candidates := Set.new(Str)
    candidates_replace := Set.new(Str)
    for i in 0..n {
        ref stmt : Expr = body.child(i)
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        if stmt.children.len().eq(0) { continue }
        switch stmt.node_type {
        case NodeType.Decl(dd):
            if dd.is_mut { continue }
            // At top level only ever drop compiler-internal temps;
            // user-named globals may be exported. Both hoisted__* and
            // codegen _t_* temps are compiler-internal (users cannot name
            // a leading-underscore binding), so both are safe to drop --
            // _t_* matters since precomp's ext_func folding (issue #136
            // item 1) orphans arg temps like `_t_I64_858 = -2` in main()'s
            // top-level init.
            if at_top_level {
                is_internal := dd.name.starts_with("hoisted__").or(dd.name.starts_with("_t_"))
                if is_internal.not() { continue }
            }
            ref rhs : Expr = stmt.child(0)
            if dd.own_type.is(OwnType.Ref) {
                // Ref-typed hoisted temps come from stmt-level FCalls
                // whose declared return is `ref T` (e.g. advance(p)):
                // the borrow binding is never read, but the FCall has
                // the real side effect we need to keep.
                if rhs.node_type.is(NodeType.FCall).and(dd.name.starts_with("hoisted__")) {
                    candidates.add(own dd.name.clone())
                    candidates_replace.add(own dd.name.clone())
                }
            } else if rhs_is_pure_byvalue(rhs) {
                candidates.add(own dd.name.clone())
            } else if rhs.node_type.is(NodeType.FCall).and(dd.name.starts_with("hoisted__")) {
                candidates.add(own dd.name.clone())
                candidates_replace.add(own dd.name.clone())
            }
        case:
        }
    }

    // Phase 2: collect "real" refs -- everything except trivial deletes
    // that target a candidate temp. Those are weak refs we'll drop along
    // with the candidate.
    refs := Set.new(Str)
    for i in 0..n {
        ref stmt : Expr = body.child(i)
        target := match_trivial_delete(stmt)
        if target.len().gt(0).and(candidates.has(target)) { continue }
        collect_body_refs(stmt, refs, candidates)
    }

    // Phase 3: mark Decls (delete or replace-with-rhs) and the
    // matching trivial-delete stmts.
    marks : Dynamic = malloc(n)
    memset(marks, 0, n)
    dropped := Set.new(Str)
    mut any := false
    for i in 0..n {
        ref stmt : Expr = body.child(i)
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        switch stmt.node_type {
        case NodeType.Decl(dd):
            if candidates.has(dd.name).not() { continue }
            if refs.has(dd.name) { continue }
            mut code : U8 = MARK_DELETE
            if candidates_replace.has(dd.name) { code = MARK_REPLACE_RHS }
            memset(ptr_add(marks, i), code, 1)
            dropped.add(own dd.name.clone())
            any = true
        case:
        }
    }
    if any {
        for j in 0..n {
            ref stmt : Expr = body.child(j)
            target := match_trivial_delete(stmt)
            if target.len().eq(0) { continue }
            if dropped.has(target).not() { continue }
            memset(ptr_add(marks, j), MARK_DELETE, 1)
        }
        // Rebuild body.children honoring the marks. DELETE skips the
        // stmt; REPLACE_RHS swaps the Decl for its RHS (the FCall is
        // moved in via push_take from a temporary Vec).
        mut old := Vec.new(Expr)
        old.move_from(body.children)
        mut new_ch := Vec.new(Expr)
        for k in 0..n {
            ref mark : U8 = ptr_add(marks, k)
            if mark.eq(MARK_DELETE) { continue }
            if mark.eq(MARK_REPLACE_RHS) {
                ref decl_stmt : Expr = old[k]
                mut decl_children := Vec.new(Expr)
                decl_children.move_from(decl_stmt.children)
                new_ch.push_take(decl_children, 0)
                Vec.delete(own decl_children, true)
                continue
            }
            new_ch.push_take(old, k)
        }
        body.children.move_from(new_ch)
        Vec.delete(own old, true)
        Vec.delete(own new_ch, true)

        // Prune trivial-delete stmts targeting dropped names from any
        // nested body (e.g. early-return cleanup inside an if-then).
        for j in 0..body.children.len() {
            prune_trivial_deletes(body.child(j), dropped)
        }
    }
    free(own marks)
    Set.delete(own refs, true)
    Set.delete(own candidates, true)
    Set.delete(own candidates_replace, true)
    Set.delete(own dropped, true)
    return any
}

// Match `<Type>.delete(<Ident name>, LiteralBool _)` without
// constraining the bool value. Used by the stale-Own LiteralStr
// fixup to find a Decl's paired cleanup when the cleanup's
// call_free flag may still carry the typer's pre-precomp `true`.
priv match_named_delete := func(stmt: Expr, name: Str) returns Bool {
    if stmt.node_type.is(NodeType.FCall).not() { return false }
    if stmt.children.len().neq(3) { return false }
    ref callee : Expr = stmt.child(0)
    if callee.node_type.is(NodeType.FieldAccess).not() { return false }
    mut method_eq := false
    switch callee.node_type {
    case NodeType.FieldAccess(m): method_eq = m.field_access_name().eq("delete")
    case:
    }
    if method_eq.not() { return false }
    if callee.children.len().neq(1) { return false }
    if callee.child(0).node_type.is(NodeType.Ident).not() { return false }
    ref arg0 : Expr = stmt.child(1)
    if arg0.node_type.is(NodeType.Ident).not() { return false }
    mut name_eq := false
    switch arg0.node_type {
    case NodeType.Ident(n): name_eq = n.ident_name().eq(name)
    case:
    }
    if name_eq.not() { return false }
    return stmt.child(2).node_type.is_literal_bool()
}

// Precomp folds an FCall RHS to a LiteralStr in place but doesn't
// touch the surrounding Decl's `own_type` or the matching cleanup's
// call_free flag -- the typer already committed to Own + call_free=true
// when the RHS was still an FCall returning an owned Str. The builder
// papers over the mismatch at emission (stack compound literal +
// forced `&(Bool){0}`), but the stale Own hides these decls from body
// DCE. Restore the typer's LiteralStr-decl invariant (Shallow + paired
// delete with call_free=false) so DCE can drop them.
priv fix_stale_litstr_in_body := func(mut body: Expr) {
    n := body.children.len()
    if n.eq(0) { return }
    for i in 0..n {
        ref stmt : Expr = body.child(i)
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        if stmt.children.len().eq(0) { continue }
        switch stmt.node_type {
        case NodeType.Decl(dd):
            if dd.own_type.is(OwnType.Own).not() { continue }
            ref rhs : Expr = stmt.child(0)
            if rhs.node_type.is_literal_str().not() { continue }
            ref target : Str = dd.name
            dd.own_type = OwnType.Shallow
            mut j : USize = i.add(1)
            while j.lt(n) {
                ref del : Expr = body.child(j)
                if match_named_delete(del, target) {
                    ref bool_arg : Expr = del.child(2)
                    bool_arg.node_type = NodeType.Literal(Literal.Bool(false))
                    break
                }
                j = j.add(1)
            }
        case:
        }
    }
}

// Recurse into nested bodies bottom-up; iterate to a fixed point so that
// removing a Decl in an inner body can free up references that let an
// outer Decl drop too. `at_top_level` is true only for the program-root
// body; recursion turns it off when descending into any nested Body
// (which is by definition inside a function/test/proc).
priv body_dce_walk := proc(mut e: Expr, at_top_level: Bool) {
    if e.is_null() { return }
    is_body := e.node_type.is(NodeType.Body)
    child_top := at_top_level.and(is_body.not())
    for i in 0..e.children.len() {
        body_dce_walk(e.child(i), child_top)
    }
    if is_body {
        fix_stale_litstr_in_body(e)
        while dce_one_body(e, at_top_level) {}
    }
}

priv body_dce_ns := proc(rhs: Expr) {
    ref ns : Vec = def_ns_decls(rhs)
    for _nsd_e : Declaration in ns {
        ref nsd : Declaration = _nsd_e
        if nsd.default_value.is_null() { continue }
        if nsd.default_value.node_type.is(NodeType.FuncDef).not() { continue }
        if nsd.default_value.children.len().eq(0) { continue }
        body_dce_walk(nsd.default_value.child(0), false)
    }
}

dce_program_bodies := proc(mut program: Expr) {
    // Walk the program-root body (becomes main() for non-library
    // modes) and every function/test/proc body inside it.
    // body_dce_walk descends through Expr.children, so namespace
    // methods (which live in StructDef.ns_decls outside the children
    // tree) need a separate walk.
    body_dce_walk(program, true)
    for stmt : Expr in program.children {
        if is_def(stmt).not() { continue }
        ref rhs : Expr = stmt.child(0)
        if rhs.node_type.is(NodeType.StructDef).or(rhs.node_type.is(NodeType.EnumDef)) {
            body_dce_ns(rhs)
        }
    }
}
