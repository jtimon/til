mode lib

import("loader.til")
import("targets.til")

system_cmd := ext_func(cmd: Str) returns shallow I32 {}

CollectionInfo := struct {
    ref mut type_name : Str = NULL
    mut is_vec : I32 = 0
}

DynCallInfo := struct {
    ref mut method : Str = NULL
    mut nargs : I32 = 1
    mut has_return := false
}

// --- Globals ---

// Points at the LoadedProgram passed to cmd_build/cmd_run for the duration of
// codegen, so helpers can iterate per-file ASTs without building merged views.
mut codegen_lp_slot : Dynamic = 0
ref mut current_fdef : Expr = NULL
mut func_defs := Map.new("Str", Str.size(), "Dynamic", I64.size())
mut struct_def_exprs := Map.new("Str", Str.size(), "Dynamic", I64.size())
mut script_globals := Set.new("Str", Str.size())
mut has_script_globals := false
mut ref_globals := Set.new("Str", Str.size())
mut has_ref_globals := false
mut in_func_def := false
mut in_main_func := false
mut funcsig_names := Set.new("Str", Str.size())
mut has_funcsig_names := false
mut ctor_seq : I32 = 0
mut stack_locals := Set.new("Str", Str.size())
mut stack_local_types := Map.new("Str", Str.size(), "Str", Str.size())
mut unsafe_to_hoist := Set.new("Str", Str.size())
mut ref_locals := Set.new("Str", Str.size())

codegen_lp := func() returns ref LoadedProgram {
    if is_null(codegen_lp_slot) {
        panic(__LOC__, "builder: codegen_lp_slot is NULL")
    }
    ref lp : LoadedProgram = deref(codegen_lp_slot)
    if is_null(lp) {
        panic(__LOC__, "builder: codegen_lp_slot points to NULL")
    }
    return lp
}

codegen_set_lp := func(lp: LoadedProgram) {
    // Store pointer to stack-owned lp; valid for duration of build.
    codegen_lp_slot = to_ptr(lp)
}

codegen_clear_lp := func() {
    codegen_lp_slot = NULL
}

// --- Leaf functions ---

is_dyn_call_name := func(name: Str, mut has_ret: Bool) returns shallow Bool {
    if name.eq("dyn_call") { has_ret = false; return true }
    if name.eq("dyn_call_ret") { has_ret = true; return true }
    return false
}

fcall_fn_sig := func(fcall: Expr) returns ref Expr {
    if is_null(fcall) { return NULL }
    switch fcall.node_type {
    case NodeType.FCall(fcd):
        return fcd.fn_sig
    case:
        return NULL
    }
}

is_stack_local := func(name: Str) returns shallow Bool {
    return stack_locals.has(name)
}

is_value_global := func(name: Str) returns shallow Bool {
    if has_script_globals.not() { return false }
    return script_globals.has(name)
}

is_ref_global := func(name: Str) returns shallow Bool {
    if has_ref_globals.not() { return false }
    return ref_globals.has(name)
}

is_ref_local := func(name: Str) returns shallow Bool {
    if ref_locals.has(name) { return true }
    return is_ref_global(name)
}

use_dot_access := func(obj: Expr) returns shallow Bool {
    if obj.node_type.is(NodeType.FieldAccess) {
        if builder_fa_is_ptr(obj).not() { return true }
    }
    if obj.node_type.is(NodeType.Ident) {
        ref ident : Str = get_payload(obj.node_type)
        if is_stack_local(ident) { return true }
        if is_value_global(ident) { return true }
    }
    return false
}

is_primitive_type := func(name: Str) returns shallow Bool {
    if name.eq("I64") { return true }
    if name.eq("U8") { return true }
    if name.eq("I16") { return true }
    if name.eq("I32") { return true }
    if name.eq("U32") { return true }
    if name.eq("U64") { return true }
    if name.eq("USize") { return true }
    if name.eq("F32") { return true }
    if name.eq("Bool") { return true }
    return false
}

is_funcsig_type := func(name: Str) returns shallow Bool {
    if has_funcsig_names.not() { return false }
    return funcsig_names.has(name)
}

is_ext_h_type := func(name: Str) returns shallow Bool {
    if name.eq("U8") { return true }
    if name.eq("I16") { return true }
    if name.eq("I32") { return true }
    if name.eq("F32") { return true }
    if name.eq("U32") { return true }
    if name.eq("U64") { return true }
    if name.eq("I64") { return true }
    if name.eq("Bool") { return true }
    return false
}

is_skip_ext_decl := func(name: Str) returns shallow Bool {
    if name.eq("exit") { return true }
    if name.eq("free") { return true }
    if name.eq("malloc") { return true }
    if name.eq("calloc") { return true }
    if name.eq("realloc") { return true }
    if name.eq("memcpy") { return true }
    if name.eq("memmove") { return true }
    if name.eq("memset") { return true }
    if name.eq("print_single") { return true }
    if name.eq("print_flush") { return true }
    return false
}

is_scalar_method_type := func(name: Str) returns shallow Bool {
    if name.eq("U8") { return true }
    if name.eq("I16") { return true }
    if name.eq("I32") { return true }
    if name.eq("F32") { return true }
    if name.eq("U32") { return true }
    if name.eq("U64") { return true }
    if name.eq("I64") { return true }
    if name.eq("Bool") { return true }
    return false
}

is_exported_top_level_global := func(stmt: Expr) returns shallow Bool {
    if stmt.node_type.is(NodeType.Decl).not() { return false }
    ref rhs : Expr = stmt.child(0)
    if rhs.node_type.is(NodeType.FuncDef) { return false }
    if rhs.node_type.is(NodeType.StructDef) { return false }
    if rhs.node_type.is(NodeType.EnumDef) { return false }
    if stmt.til_type.is(TilType.None) {
        if rhs.node_type.is(NodeType.Ident) { return false }
    }
    ref decl : Declaration = get_payload(stmt.node_type)
    if decl.name.len().gte(3) {
        if decl.name.substr(0, 3).eq("_t_") { return false }
    }
    return true
}

find_struct_def := func(name: Str) returns ref Expr {
    if struct_def_exprs.has(name).not() { return NULL }
    return deref(struct_def_exprs.get(name))
}

find_callee_fdef := func(name: Str) returns ref Expr {
    if func_defs.has(name).not() { return NULL }
    return deref(func_defs.get(name))
}

fa_struct_name := func(e: Expr) returns Str {
    if e.children.len().eq(0) { return til_type_name(e.til_type) }
    ref obj : Expr = e.child(0)
    obj_sname := til_type_name(obj.til_type)
    if obj_sname.len().gt(0) { return obj_sname }
    if obj.node_type.is(NodeType.Ident) {
        ref ident : Str = get_payload(obj.node_type)
        return ident.clone()
    }
    return obj_sname
}

// Check if a FieldAccess/FieldAssign accesses an own/ref (pointer) field.
builder_fa_is_ptr := func(e: Expr) returns shallow Bool {
    if e.node_type.is(NodeType.FieldAccess).not().and(e.node_type.is(NodeType.FieldAssign).not()) {
        return false
    }
    sname := fa_struct_name(e)
    ref fname : Str = get_payload(e.node_type)
    ref fap_def : Expr = find_struct_def(sname)
    if is_null(fap_def) { return false }
    switch fap_def.node_type {
    case NodeType.StructDef(fap_sdd):
        for dd : Declaration in fap_sdd.fields {
            if dd.name.eq(fname) {
                return dd.own_type.is(OwnType.Shallow).not()
            }
        }
        return false
    case:
        return false
    }
}

builder_fa_is_ns := func(e: Expr) returns shallow Bool {
    if e.node_type.is(NodeType.FieldAccess).not().and(e.node_type.is(NodeType.FieldAssign).not()) {
        return false
    }
    sname := fa_struct_name(e)
    ref fname : Str = get_payload(e.node_type)
    ref bfn_def : Expr = find_struct_def(sname)
    if is_null(bfn_def) { return false }
    mut has_ns := false
    mut has_inst := false
    ref bfn_ns : Vec = def_ns_decls(bfn_def)
    for bfn_d : Declaration in bfn_ns {
        if bfn_d.name.eq(fname) { has_ns = true }
    }
    switch bfn_def.node_type {
    case NodeType.StructDef(bfn_sdd):
        for dd : Declaration in bfn_sdd.fields {
            if dd.name.eq(fname) { has_inst = true }
        }
    case:
    }
    if has_ns.and(has_inst.not()) { return true }
    if has_ns.not() { return false }
    ref obj : Expr = e.child(0)
    if obj.node_type.is(NodeType.Ident).not() { return false }
    ref ident : Str = get_payload(obj.node_type)
    if ident.eq(sname) { return true }
    if ident.len().gt(0) {
        if ident.get(0).gte('A').and(ident.get(0).lte('Z')) {
            return true
        }
    }
    return false
}

is_shallow_param := func(name: Str) returns shallow Bool {
    if is_null(current_fdef) { return false }
    switch current_fdef.node_type {
    case NodeType.FuncDef(fd):
        for p : Declaration in fd.params {
            if p.own_type.is(OwnType.Shallow) {
                if p.name.eq(name) { return true }
            }
        }
        return false
    case:
        UNREACHABLE(__LOC__)
        return false
    }
}

callee_returns_shallow := func(callee_name: Str) returns shallow Bool {
    ref fdef : Expr = find_callee_fdef(callee_name)
    if is_null(fdef) { return false }
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        return fd.return_own_type.is(OwnType.Shallow)
    case:
        return false
    }
}

callee_returns_dynamic := func(callee_name: Str) returns shallow Bool {
    if callee_name.eq("malloc") { return true }
    if callee_name.eq("calloc") { return true }
    if callee_name.eq("realloc") { return true }
    if callee_name.eq("dyn_call_ret") { return true }
    if callee_name.eq("dyn_fn") { return true }
    ref fdef : Expr = find_callee_fdef(callee_name)
    if is_null(fdef) { return false }
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        return fd.return_type.eq("Dynamic")
    case:
        return false
    }
}

callee_param_is_shallow := func(callee_name: Str, shallow arg_index: U32) returns shallow Bool {
    ref fdef : Expr = find_callee_fdef(callee_name)
    if is_null(fdef) { return false }
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        if arg_index.gte(fd.params.len()) { return false }
        if fd.params.len().eq(0) { return false }
        ref p : Declaration = fd.params.get(arg_index)
        return p.own_type.is(OwnType.Shallow)
    case:
        return false
    }
}

callee_param_is_usize := func(callee_name: Str, shallow arg_index: U32) returns shallow Bool {
    ref fdef : Expr = find_callee_fdef(callee_name)
    if is_null(fdef) { return false }
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        if arg_index.gte(fd.params.len()) { return false }
        ref p : Declaration = fd.params.get(arg_index)
        return p.explicit_type.eq("USize")
    case:
        return false
    }
}

callee_param_is_own := func(callee_name: Str, shallow arg_index: U32) returns shallow Bool {
    ref fdef : Expr = find_callee_fdef(callee_name)
    if is_null(fdef) { return false }
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        if arg_index.gte(fd.params.len()) { return false }
        ref p : Declaration = fd.params.get(arg_index)
        return p.own_type.is(OwnType.Own)
    case:
        return false
    }
}

fcall_is_shallow_return := func(fcall: Expr) returns shallow Bool {
    if fcall.node_type.is(NodeType.FCall).not() { return false }
    ref callee : Expr = fcall.child(0)
    switch callee.node_type {
    case NodeType.Ident(ident):
        if callee_returns_shallow(ident) { return true }
    case NodeType.FieldAccess(mname):
        sname := til_type_name(callee.child(0).til_type)
        if sname.len().eq(0) { return false }
        flat := sname.concat("_").concat(mname)
        if callee_returns_shallow(flat) { return true }
    case:
    }
    ref sig : Expr = fcall_fn_sig(fcall)
    if is_null(sig).not() {
        switch sig.node_type {
        case NodeType.FuncDef(sfd):
            return sfd.return_own_type.is(OwnType.Shallow)
        case:
        }
    }
    return false
}

fcall_returns_dynamic := func(fcall: Expr) returns shallow Bool {
    if fcall.node_type.is(NodeType.FCall).not() { return false }
    ref callee_node : Expr = fcall.child(0)
    switch callee_node.node_type {
    case NodeType.FieldAccess(mname):
        sname := til_type_name(callee_node.child(0).til_type)
        if sname.len().eq(0) { return false }
        flat := sname.concat("_").concat(mname)
        return callee_returns_dynamic(flat)
    case NodeType.Ident(ident):
        return callee_returns_dynamic(ident)
    case:
        return false
    }
}

til_type_to_c := func(shallow t: TilType) returns Str {
    switch t {
    case TilType.I64:     return "I64"
    case TilType.U8:      return "U8"
    case TilType.I16:     return "I16"
    case TilType.I32:     return "I32"
    case TilType.U32:     return "U32"
    case TilType.U64:     return "U64"
    case TilType.F32:     return "F32"
    case TilType.Bool:    return "Bool"
    case TilType.None:    return "void"
    case TilType.Dynamic: return "void *"
    case TilType.FuncPtr: return "void *"
    case:                 return "I64"
    }
}

// Resolve the C type for an `extern` global decl. Replaces the
// `mut ctype := ""; if dyn { ... } else { ... }` reassign-leak
// pattern in emit_header_global_decls / emit_funcsig_typedefs.
extern_decl_ctype := func(shallow t: TilType, shallow rhs_t: TilType) returns Str {
    if t.is(TilType.Dynamic) { return til_type_to_c(t) }
    return c_type_name(t, til_type_name(rhs_t))
}

// Resolve the C type name for a Decl whose explicit_type may be empty.
// Skips the heap-allocated empty-Str dance from til_type_name when t isn't
// Struct/Enum/FuncPtr (where the name actually matters) -- saves the Str_lit("")
// leak per call.
resolve_decl_ctype := func(shallow t: TilType, shallow rhs_t: TilType, explicit: Str) returns Str {
    if t.is(TilType.Struct).or(t.is(TilType.Enum)).or(t.is(TilType.FuncPtr)) {
        sn := til_type_name(t)
        if sn.len().gt(0) { return c_type_name(t, sn) }
        sn2 := til_type_name(rhs_t)
        if sn2.len().gt(0) { return c_type_name(t, sn2) }
        return c_type_name(t, explicit)
    }
    return c_type_name(t, "")
}

c_type_name := func(shallow t: TilType, struct_name: Str) returns Str {
    if t.is(TilType.Struct).or(t.is(TilType.Enum)) {
        if is_null(struct_name).not() {
            if struct_name.len().gt(0) {
                return struct_name.clone()
            }
        }
    }
    if t.is(TilType.FuncPtr) {
        if is_null(struct_name).not() {
            if struct_name.len().gt(0) {
                if is_funcsig_type(struct_name) { return struct_name.clone() }
            }
        }
    }
    if t.is(TilType.Dynamic) { return "void" }
    return til_type_to_c(t)
}

func_to_c := func(name: Str) returns Str {
    if name.eq("double") { return "double_" }
    return name.clone()
}

type_name_to_c := func(name: Str) returns Str {
    if name.eq("I64") { return "I64 *" }
    if name.eq("U8") { return "U8 *" }
    if name.eq("I16") { return "I16 *" }
    if name.eq("I32") { return "I32 *" }
    if name.eq("U32") { return "U32 *" }
    if name.eq("U64") { return "U64 *" }
    if name.eq("USize") { return "USize *" }
    if name.eq("F32") { return "F32 *" }
    if name.eq("Bool") { return "Bool *" }
    if name.eq("Dynamic") { return "void *" }
    if name.eq("Fn") { return "void *" }
    if has_funcsig_names {
        if funcsig_names.has(name) { return name.clone() }
    }
    return name.concat(" *")
}

type_name_to_c_value := func(name: Str) returns Str {
    if name.eq("I64") { return "I64" }
    if name.eq("U8") { return "U8" }
    if name.eq("I16") { return "I16" }
    if name.eq("I32") { return "I32" }
    if name.eq("U32") { return "U32" }
    if name.eq("U64") { return "U64" }
    if name.eq("USize") { return "USize" }
    if name.eq("F32") { return "F32" }
    if name.eq("Bool") { return "Bool" }
    if name.eq("Dynamic") { return "void *" }
    if name.eq("Fn") { return "void *" }
    if has_funcsig_names {
        if funcsig_names.has(name) { return name.clone() }
    }
    return name.clone()
}

emit_u64 := proc(f: File, shallow v: U64) {
    f.write(v.to_i64().to_str())
}

emit_i32 := proc(f: File, shallow v: I32) {
    f.write(v.to_i64().to_str())
}

emit_indent := proc(f: File, shallow depth: I32) {
    for _ : I32 in 0..depth {
        f.write("    ")
    }
}

emit_til_default := proc(f: File, shallow t: TilType) {
    if t.is(TilType.I64).or(t.is(TilType.I16)).or(t.is(TilType.I32))
    .or(t.is(TilType.U32)).or(t.is(TilType.U64)).or(t.is(TilType.F32))
    .or(t.is(TilType.U8)) {
        f.write("0")
    } else if t.is(TilType.Bool) {
        f.write("false")
    } else if t.is(TilType.Struct).or(t.is(TilType.Enum)) {
        name := til_type_name(t)
        if name.eq("Str") {
            f.write("\"\"")
        } else if name.len().gt(0) {
            f.write(name)
            f.write("()")
        } else {
            f.write("0")
        }
    } else {
        f.write("0")
    }
}

callee_return_ctype := ext_func(callee_name: Str) returns Str {}

// Resolve the C parameter type for fd.params[i]. Avoids the
// `mut ptype := ""` pre-init pattern in emit_param_list, whose empty
// Str leaked once per parameter on each call.
param_ctype := func(fd: FunctionDef, shallow i: USize) returns Str {
    ii := i.to_i64().to_i32()
    if ii.eq(fd.variadic_index) { return "Array *" }
    ref p : Declaration = fd.params.get(i)
    if ii.eq(fd.kwargs_index) { return type_name_to_c(p.explicit_type) }
    if p.own_type.is(OwnType.Shallow) { return type_name_to_c_value(p.explicit_type) }
    return type_name_to_c(p.explicit_type)
}

emit_param_list := proc(f: File, fdef: Expr, shallow with_names: Bool) {
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        if fd.params.len().eq(0) {
            f.write("void")
        } else {
            for i in 0..fd.params.len() {
                if i.gt(0) { f.write(", ") }
                ptype := param_ctype(fd, i)
                if with_names {
                    ref p : Declaration = fd.params.get(i)
                    f.write(ptype)
                    f.write(" ")
                    f.write(p.name)
                } else {
                    f.write(ptype)
                }
            }
        }
    case:
        UNREACHABLE(__LOC__)
    }
}

collect_dyn_methods := proc(e: Expr, mut methods: Vec) {
    if is_null(e) { return }
    if e.node_type.is(NodeType.FCall) {
        if e.children.len().gt(0) {
            if e.child(0).node_type.is(NodeType.Ident) {
                if e.children.len().gte(3) {
                    if e.child(2).node_type.is(NodeType.LiteralStr) {
                        ref callee_name : Str = get_payload(e.child(0).node_type)
                        mut has_ret := false
                        if is_dyn_call_name(callee_name, has_ret) {
                            ref method : Str = get_payload(e.child(2).node_type)
                            mut nargs := 1.to_i32()
                            if e.children.len().gte(4) {
                                if e.child(3).node_type.is(NodeType.LiteralNum) {
                                    ref num_str : Str = get_payload(e.child(3).node_type)
                                    nargs = num_str.to_i64().to_i32()
                                }
                            }
                            mut found := false
                            for existing : DynCallInfo in methods {
                                if existing.method.eq(method) { found = true }
                            }
                            if found.not() {
                                info := DynCallInfo(method = method, nargs = nargs, has_return = has_ret)
                                methods.push(own info)
                            }
                        }
                    }
                }
            }
        }
    }
    if e.node_type.is(NodeType.StructDef).or(e.node_type.is(NodeType.EnumDef)) {
        ref cdm_ns : Vec = def_ns_decls(e)
        for cdm_d : Declaration in cdm_ns {
            if is_null(cdm_d.default_value).not() {
                collect_dyn_methods(cdm_d.default_value, methods)
            }
        }
    }
    for e_ci : Expr in e.children {
        collect_dyn_methods(e_ci, methods)
    }
}

collect_collection_builtins := proc(e: Expr, mut infos: Vec) {
    if is_null(e) { return }
    if e.node_type.is(NodeType.FCall) {
        if e.children.len().gt(0) {
            if e.child(0).node_type.is(NodeType.Ident) {
                if e.children.len().gte(2) {
                    if e.child(1).node_type.is(NodeType.LiteralStr) {
                        ref name : Str = get_payload(e.child(0).node_type)
                        mut is_vec := -1.to_i32()
                        if name.eq("array") { is_vec = 0.to_i32() }
                        else if name.eq("vec") { is_vec = 1.to_i32() }
                        if is_vec.gte(0.to_i32()) {
                            ref type_name : Str = get_payload(e.child(1).node_type)
                            mut found := false
                            for existing : CollectionInfo in infos {
                                if existing.type_name.eq(type_name) {
                                    if existing.is_vec.eq(is_vec) { found = true }
                                }
                            }
                            if found.not() {
                                info := CollectionInfo(type_name = type_name, is_vec = is_vec)
                                infos.push(own info)
                            }
                        }
                    }
                }
            }
        }
    }
    if e.node_type.is(NodeType.StructDef).or(e.node_type.is(NodeType.EnumDef)) {
        ref ccb_ns : Vec = def_ns_decls(e)
        for ccb_d : Declaration in ccb_ns {
            if is_null(ccb_d.default_value).not() {
                collect_collection_builtins(ccb_d.default_value, infos)
            }
        }
    }
    for e_ci : Expr in e.children {
        collect_collection_builtins(e_ci, infos)
    }
}

emit_field := proc(f: File, var: Str, field: Str) {
    f.write(var)
    if is_stack_local(var).or(is_value_global(var)) {
        f.write(".")
    } else {
        f.write("->")
    }
    f.write(field)
}

get_stack_local_ctype := func(name: Str) returns ref Str {
    if stack_local_types.has(name) {
        ref p : Str = stack_local_types.get(name)
        return p
    }
    return NULL
}

resolve_callee_name := ext_func(fcall: Expr) returns Str {}

resolve_callee_name := func(fcall: Expr) returns Str {
    ref callee_node : Expr = fcall.child(0)
    switch callee_node.node_type {
    case NodeType.FieldAccess(mname):
        sname := til_type_name(callee_node.child(0).til_type)
        if sname.len().eq(0) { return "" }
        return sname.concat("_").concat(mname)
    case NodeType.Ident(ident):
        return ident.clone()
    case:
        return ""
    }
}

callee_return_ctype := func(callee_name: Str) returns Str {
    ref fdef : Expr = find_callee_fdef(callee_name)
    if is_null(fdef) { return "" }
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        if fd.return_type.len().eq(0) { return "" }
        return type_name_to_c_value(fd.return_type)
    case:
        return ""
    }
}

fcall_return_ctype := func(fcall: Expr) returns Str {
    if fcall.node_type.is(NodeType.FCall).not() { return "" }
    callee := resolve_callee_name(fcall)
    if callee.len().eq(0) { return "" }
    return callee_return_ctype(callee)
}

check_fcall_mut_args := proc(e: Expr) {
    if is_null(e) { return }
    if e.node_type.is(NodeType.FCall) {
        ref mut fdef : Expr = fcall_fn_sig(e)
        if is_null(fdef) {
            callee := resolve_callee_name(e)
            if callee.len().gt(0) {
                fdef = find_callee_fdef(callee)
            }
        }
        if is_null(fdef).not() {
            switch fdef.node_type {
            case NodeType.FuncDef(fd):
                if fd.params.len().gt(0) {
                    for a in 1..e.children.len() {
                        pi := a.sub(1)
                        if pi.lt(fd.params.len()) {
                            ref p : Declaration = fd.params.get(pi)
                            if p.is_mut {
                                ref arg : Expr = e.child(a)
                                if arg.node_type.is(NodeType.Ident) {
                                    ref arg_name : Str = get_payload(arg.node_type)
                                    unsafe_to_hoist.add(own arg_name.clone())
                                }
                            }
                        }
                    }
                }
            case:
            }
        }
    }
    for e_ci : Expr in e.children {
        check_fcall_mut_args(e_ci)
    }
}

collect_unsafe_to_hoist := proc(body: Expr) {
    for stmt : Expr in body.children {
        check_fcall_mut_args(stmt)
        if stmt.node_type.is(NodeType.Decl) {
            ref dd : Declaration = get_payload(stmt.node_type)
            if dd.own_type.is(OwnType.Ref) {
                ref rhs : Expr = stmt.child(0)
                if rhs.node_type.is(NodeType.Ident) {
                    ref rhs_name : Str = get_payload(rhs.node_type)
                    unsafe_to_hoist.add(own rhs_name.clone())
                }
                if rhs.node_type.is(NodeType.FCall) {
                    callee := resolve_callee_name(rhs)
                    if callee.len().gt(0) {
                        ref fdef : Expr = find_callee_fdef(callee)
                        if is_null(fdef).not() {
                            switch fdef.node_type {
                            case NodeType.FuncDef(fd):
                                if fd.return_own_type.is(OwnType.Ref) {
                                    for a in 1..rhs.children.len() {
                                        ref arg : Expr = rhs.child(a)
                                        if arg.node_type.is(NodeType.Ident) {
                                            ref arg_name : Str = get_payload(arg.node_type)
                                            unsafe_to_hoist.add(own arg_name.clone())
                                        }
                                    }
                                }
                            case:
                            }
                        }
                    }
                }
            }
        }
        if stmt.node_type.is(NodeType.If) {
            for c in 1..stmt.children.len() {
                collect_unsafe_to_hoist(stmt.child(c))
            }
        }
        if stmt.node_type.is(NodeType.While) {
            if stmt.children.len().gt(1) {
                collect_unsafe_to_hoist(stmt.child(1))
            }
        }
        if stmt.node_type.is(NodeType.Body) {
            collect_unsafe_to_hoist(stmt)
        }
    }
}

collect_dyn_has_methods := proc(e: Expr, mut methods: Vec) {
    if is_null(e) { return }
    if e.node_type.is(NodeType.FCall) {
        if e.children.len().gt(0) {
            if e.child(0).node_type.is(NodeType.Ident) {
                ref cname : Str = get_payload(e.child(0).node_type)
                if cname.eq("dyn_has_method") {
                    if e.children.len().gte(3) {
                        if e.child(2).node_type.is(NodeType.LiteralStr) {
                            ref method : Str = get_payload(e.child(2).node_type)
                            mut found := false
                            for existing : Str in methods {
                                if existing.eq(method) { found = true }
                            }
                            if found.not() {
                                methods.push(own method.clone())
                            }
                        }
                    }
                }
            }
        }
    }
    if e.node_type.is(NodeType.StructDef).or(e.node_type.is(NodeType.EnumDef)) {
        ref cdh_ns : Vec = def_ns_decls(e)
        for cdh_d : Declaration in cdh_ns {
            if is_null(cdh_d.default_value).not() {
                collect_dyn_has_methods(cdh_d.default_value, methods)
            }
        }
    }
    for e_ci : Expr in e.children {
        collect_dyn_has_methods(e_ci, methods)
    }
}

// Emit layer
emit_stmt_decl := proc(f: File, e: Expr, shallow depth: I32) {
    ref dd : Declaration = get_payload(e.node_type)
    if e.children.len().eq(0) { return }
    ref rhs : Expr = e.child(0)
    if e.til_type.is(TilType.FuncPtr).and(dd.own_type.is(OwnType.Ref).not()).and(rhs.node_type.is(NodeType.FuncDef).not()) {
        mut ct := "void *"
        mut is_typedef := false
        if dd.explicit_type.len().gt(0) {
            if is_funcsig_type(dd.explicit_type) {
                ct = dd.explicit_type.clone()
                is_typedef = true
            }
        }
        if is_typedef { f.write(ct); f.write(" "); f.write(dd.name); f.write(" = ") }
        else { f.write(ct); f.write(dd.name); f.write(" = ") }
        emit_expr(f, rhs, depth); f.write(";\n")
        emit_indent(f, depth); f.write("(void)"); f.write(dd.name); f.write(";\n")
    } else if rhs.node_type.is(NodeType.FuncDef) {
        f.write("/* TODO: nested func "); f.write(dd.name); f.write(" */\n")
    } else if rhs.node_type.is(NodeType.StructDef).or(rhs.node_type.is(NodeType.EnumDef)) {
        f.write("/* ")
        if rhs.node_type.is(NodeType.EnumDef) { f.write("enum") } else { f.write("struct") }
        f.write(" "); f.write(dd.name); f.write(" defined above */\n")
    } else if e.til_type.is(TilType.None).and(rhs.node_type.is(NodeType.Ident)) {
        // Type alias -- no-op
    } else {
        if dd.own_type.is(OwnType.Ref) {
            is_rg := is_ref_global(dd.name).and(in_func_def.not())
            if is_rg.not() { ref_locals.add(own dd.name.clone()) }
            ctype := resolve_decl_ctype(e.til_type, rhs.til_type, dd.explicit_type)
            if is_rg { f.write(dd.name); f.write(" = ") }
            else { f.write(ctype); f.write(" *"); f.write(dd.name); f.write(" = ") }
            emit_as_ptr(f, rhs, depth, false); f.write(";\n")
        } else {
            ctype := resolve_decl_ctype(e.til_type, rhs.til_type, dd.explicit_type)
            is_global := is_value_global(dd.name).and(in_func_def.not())
            if e.til_type.is(TilType.Dynamic) {
                if is_global { f.write(dd.name); f.write(" = ") }
                else { tc := til_type_to_c(e.til_type); f.write(tc); f.write(" "); f.write(dd.name); f.write(" = ") }
                emit_deref(f, rhs, depth); f.write(";\n")
            } else {
                can_hoist := is_global.not().and(dd.own_type.is(OwnType.Own).not())
                .and(e.til_type.is(TilType.FuncPtr).not()).and(e.til_type.is(TilType.Dynamic).not())
                .and(rhs.node_type.is(NodeType.FCall).and(fcall_returns_dynamic(rhs)).not())
                // Struct constructor
                rhs_sname := til_type_name(rhs.til_type)
                mut is_ctor := rhs.node_type.is(NodeType.FCall).and(rhs_sname.len().gt(0))
                if is_ctor {
                    if rhs.children.len().gt(0).and(rhs.child(0).node_type.is(NodeType.Ident)) {
                        ref ci : Str = get_payload(rhs.child(0).node_type)
                        is_ctor = ci.eq(rhs_sname)
                    } else { is_ctor = false }
                }
                if is_ctor {
                    if is_global {
                        f.write("memset(&"); f.write(dd.name); f.write(", 0, sizeof("); f.write(ctype); f.write("));\n")
                    } else {
                        f.write(ctype); f.write(" *"); f.write(dd.name); f.write(" = malloc(sizeof("); f.write(ctype); f.write("));\n")
                    }
                    emit_ctor_fields(f, dd.name, rhs, depth)
                } else if rhs.node_type.is(NodeType.FCall).or(rhs.node_type.is(NodeType.LiteralStr))
                .or(rhs.node_type.is(NodeType.FieldAccess).and(builder_fa_is_ns(rhs)).and(rhs.til_type.is(TilType.Enum))) {
                    if is_global {
                        if rhs.node_type.is(NodeType.FCall).and(fcall_is_shallow_return(rhs)) {
                            f.write(dd.name); f.write(" = "); emit_expr(f, rhs, depth); f.write(";\n")
                        } else if rhs.node_type.is(NodeType.FCall) {
                            mut htype := fcall_return_ctype(rhs)
                            if htype.len().eq(0) { htype = ctype.clone() }
                            f.write("{ "); f.write(htype); f.write(" *_hp = ("); f.write(htype); f.write(" *)")
                            emit_expr(f, rhs, depth)
                            f.write("; "); f.write(dd.name); f.write(" = *_hp; free(_hp); }\n")
                        } else {
                            f.write(dd.name); f.write(" = "); emit_deref(f, rhs, depth); f.write(";\n")
                        }
                    } else if rhs.node_type.is(NodeType.FCall).and(fcall_is_shallow_return(rhs)) {
                        // Shallow returns are by-value -- always stack-alloc.
                        // The malloc'd-and-deref'd path leaks the heap box (the
                        // typer doesn't track these for delete).
                        mut htype := fcall_return_ctype(rhs)
                        if htype.len().eq(0) { htype = ctype.clone() }
                        f.write(htype); f.write(" "); f.write(dd.name); f.write(" = ")
                        emit_expr(f, rhs, depth); f.write(";\n")
                        stack_locals.add(own dd.name.clone())
                        stack_local_types.set(own dd.name.clone(), own htype.clone())
                    } else if can_hoist.and(rhs.node_type.is(NodeType.FCall)) {
                        mut htype := fcall_return_ctype(rhs)
                        if htype.len().eq(0) { htype = ctype.clone() }
                        f.write(htype); f.write(" "); f.write(dd.name); f.write("; { "); f.write(htype); f.write(" *_hp = ("); f.write(htype); f.write(" *)")
                        emit_expr(f, rhs, depth)
                        f.write("; "); f.write(dd.name); f.write(" = *_hp; free(_hp); }\n")
                        stack_locals.add(own dd.name.clone())
                        stack_local_types.set(own dd.name.clone(), own htype.clone())
                    } else if can_hoist {
                        f.write(ctype); f.write(" "); f.write(dd.name); f.write("; { "); f.write(ctype); f.write(" *_hp = ("); f.write(ctype); f.write(" *)")
                        emit_expr(f, rhs, depth)
                        f.write("; "); f.write(dd.name); f.write(" = *_hp; free(_hp); }\n")
                        stack_locals.add(own dd.name.clone())
                        stack_local_types.set(own dd.name.clone(), own ctype.clone())
                    } else {
                        if is_global { f.write(dd.name); f.write(" = ") }
                        else { f.write(ctype); f.write(" *"); f.write(dd.name); f.write(" = ") }
                        emit_expr(f, rhs, depth); f.write(";\n")
                    }
                } else {
                    if is_global {
                        f.write(dd.name); f.write(" = "); emit_deref(f, rhs, depth); f.write(";\n")
                    } else if can_hoist {
                        f.write(ctype); f.write(" "); f.write(dd.name); f.write(" = ")
                        emit_deref(f, rhs, depth); f.write(";\n")
                        stack_locals.add(own dd.name.clone())
                        stack_local_types.set(own dd.name.clone(), own ctype.clone())
                    } else {
                        f.write(ctype); f.write(" *"); f.write(dd.name); f.write(" = malloc(sizeof("); f.write(ctype); f.write("));\n")
                        emit_indent(f, depth)
                        f.write("*"); f.write(dd.name); f.write(" = "); emit_deref(f, rhs, depth); f.write(";\n")
                    }
                }
            }
        }
        emit_indent(f, depth); f.write("(void)"); f.write(dd.name); f.write(";\n")
    }
}
emit_return_ctype := func(rv: Expr) returns Str {
    if is_null(current_fdef).not() {
        switch current_fdef.node_type {
        case NodeType.FuncDef(fd):
            if fd.return_type.len().gt(0) { return type_name_to_c_value(fd.return_type) }
        case:
        }
    }
    return c_type_name(rv.til_type, til_type_name(rv.til_type))
}

emit_return_box := proc(f: File, rv: Expr, shallow depth: I32) {
    ctype := emit_return_ctype(rv)
    f.write("{ "); f.write(ctype); f.write(" *_r = malloc(sizeof("); f.write(ctype); f.write(")); *_r = ")
    emit_expr(f, rv, depth)
    f.write("; return _r; }\n")
}

emit_stmt_return := proc(f: File, e: Expr, shallow depth: I32) {
    if e.children.len().eq(0) {
        if in_main_func { f.write("return 0;\n") }
        else { f.write("return;\n") }
    } else {
        ref rv : Expr = e.child(0)
        // Struct constructor return
        rv_sname := til_type_name(rv.til_type)
        if rv.node_type.is(NodeType.FCall).and(rv_sname.len().gt(0)).and(rv.children.len().gt(0)) {
            if rv.child(0).node_type.is(NodeType.Ident) {
                ref ci : Str = get_payload(rv.child(0).node_type)
                if ci.eq(rv_sname) {
                    ctype := c_type_name(rv.til_type, rv_sname)
                    f.write("{ "); f.write(ctype); f.write(" *_r = malloc(sizeof("); f.write(ctype); f.write("));\n")
                    emit_ctor_fields(f, "_r", rv, depth)
                    emit_indent(f, depth); f.write("return _r; }\n")
                    return
                }
            }
        }
        // Ref return
        if is_null(current_fdef).not() {
            switch current_fdef.node_type {
            case NodeType.FuncDef(fd):
                if fd.return_own_type.is(OwnType.Ref) {
                    f.write("return "); emit_as_ptr(f, rv, depth, false); f.write(";\n"); return
                }
                if fd.return_own_type.is(OwnType.Shallow) {
                    f.write("return ")
                    if rv.node_type.is(NodeType.FCall).and(fcall_is_shallow_return(rv)) { emit_expr(f, rv, depth) }
                    else { emit_deref(f, rv, depth) }
                    f.write(";\n"); return
                }
            case:
            }
        }
        // Inline field value: box for return
        if rv.node_type.is(NodeType.FieldAccess).and(builder_fa_is_ptr(rv).not())
        .and(builder_fa_is_ns(rv).not()).and(rv.til_type.is(TilType.Dynamic).not()) {
            emit_return_box(f, rv, depth)
            // Shallow fcall: box for return
        } else if rv.node_type.is(NodeType.FCall).and(fcall_is_shallow_return(rv)) {
            emit_return_box(f, rv, depth)
            // Hoisted local: box for return
        } else if rv.node_type.is(NodeType.Ident) {
            ref rv_name : Str = get_payload(rv.node_type)
            mut is_shallow_ret := false
            if is_null(current_fdef).not() {
                switch current_fdef.node_type {
                case NodeType.FuncDef(fd):
                    is_shallow_ret = fd.return_own_type.is(OwnType.Shallow)
                case:
                }
            }
            if is_stack_local(rv_name).or(is_value_global(rv_name)) {
                if is_shallow_ret.not() {
                    ctype := emit_return_ctype(rv)
                    f.write("{ "); f.write(ctype); f.write(" *_r = malloc(sizeof("); f.write(ctype); f.write(")); *_r = "); f.write(rv_name); f.write("; return _r; }\n")
                } else {
                    f.write("return "); emit_expr(f, rv, depth); f.write(";\n")
                }
            } else {
                f.write("return "); emit_expr(f, rv, depth); f.write(";\n")
            }
            // Bare enum variant ref: heap-allocate
        } else if rv.node_type.is(NodeType.FieldAccess).and(builder_fa_is_ns(rv)).and(rv.til_type.is(TilType.Enum)) {
            sn := til_type_name(rv.child(0).til_type)
            ref vname : Str = get_payload(rv.node_type)
            f.write("{ "); f.write(sn); f.write(" *_r = malloc(sizeof("); f.write(sn); f.write(")); _r->tag = "); f.write(sn); f.write("_TAG_"); f.write(vname); f.write("; return _r; }\n")
        } else {
            f.write("return "); emit_expr(f, rv, depth); f.write(";\n")
        }
    }
}

emit_stmt := proc(f: File, e: Expr, shallow depth: I32) {
    emit_indent(f, depth)
    switch e.node_type {
    case NodeType.Decl:
        emit_stmt_decl(f, e, depth)
    case NodeType.Assign(ad):
        aname := ad.name
        ref rhs : Expr = e.child(0)
        if is_ref_local(aname) {
            mut do_rebind := false
            switch rhs.node_type {
            case NodeType.FieldAccess: do_rebind = true
            case NodeType.Ident(rhs_ident):
                if is_stack_local(rhs_ident).not() { do_rebind = true }
            case:
            }
            if do_rebind {
                f.write(aname); f.write(" = ")
                emit_as_ptr(f, rhs, depth, false)
                f.write(";\n"); return
            }
        }
        if ad.save_old_delete {
            ctype := c_type_name(e.til_type, til_type_name(e.til_type))
            if is_stack_local(aname).or(is_value_global(aname)) {
                f.write("{ "); f.write(ctype); f.write(" *_new = ("); f.write(ctype); f.write(" *)")
                emit_expr(f, rhs, depth)
                f.write("; "); f.write(ctype); f.write("_delete(&"); f.write(aname); f.write(", &(Bool){0}); "); f.write(aname); f.write(" = *_new; free(_new); }\n")
            } else {
                f.write("{ "); f.write(ctype); f.write(" *_old = "); f.write(aname); f.write("; "); f.write(aname); f.write(" = ")
                emit_expr(f, rhs, depth)
                f.write("; "); f.write(ctype); f.write("_delete(_old, &(Bool){1}); }\n")
            }
            return
        }
        is_hoisted := is_stack_local(aname).or(is_value_global(aname))
        if e.til_type.is(TilType.Dynamic) {
            f.write(aname); f.write(" = "); emit_deref(f, rhs, depth); f.write(";\n"); return
        }
        if is_hoisted {
            if rhs.node_type.is(NodeType.FCall).and(fcall_is_shallow_return(rhs)) {
                f.write(aname); f.write(" = "); emit_expr(f, rhs, depth); f.write(";\n")
            } else if rhs.node_type.is(NodeType.FCall) {
                ctype := c_type_name(e.til_type, til_type_name(e.til_type))
                f.write("{ "); f.write(ctype); f.write(" *_hp = ("); f.write(ctype); f.write(" *)")
                emit_expr(f, rhs, depth)
                f.write("; "); f.write(aname); f.write(" = *_hp; free(_hp); }\n")
            } else {
                f.write(aname); f.write(" = "); emit_deref(f, rhs, depth); f.write(";\n")
            }
        } else {
            if rhs.node_type.is(NodeType.FCall).or(rhs.node_type.is(NodeType.LiteralStr))
            .or(rhs.node_type.is(NodeType.FieldAccess).and(builder_fa_is_ns(rhs)).and(rhs.til_type.is(TilType.Enum))) {
                if rhs.node_type.is(NodeType.FCall).and(fcall_is_shallow_return(rhs)) {
                    f.write("*"); f.write(aname); f.write(" = ")
                } else {
                    f.write(aname); f.write(" = ")
                }
                emit_expr(f, rhs, depth)
            } else if e.til_type.is(TilType.FuncPtr) {
                f.write(aname); f.write(" = "); emit_expr(f, rhs, depth)
            } else {
                f.write("*"); f.write(aname); f.write(" = "); emit_deref(f, rhs, depth)
            }
            f.write(";\n")
        }
    case NodeType.FieldAssign(fname):
        ref obj : Expr = e.child(0)
        ref rhs_fa : Expr = e.child(1)
        if rhs_fa.node_type.is(NodeType.FCall).and(builder_fa_is_ptr(e).not()).and(builder_fa_is_ns(e).not()) {
            if fcall_is_shallow_return(rhs_fa) {
                emit_expr(f, obj, depth)
                if use_dot_access(obj) { f.write(".") } else { f.write("->") }
                f.write(fname); f.write(" = "); emit_expr(f, rhs_fa, depth); f.write(";\n")
            } else {
                ftype := c_type_name(rhs_fa.til_type, til_type_name(rhs_fa.til_type))
                f.write("{ "); f.write(ftype); f.write(" *_fa = "); emit_expr(f, rhs_fa, depth); f.write("; ")
                emit_expr(f, obj, depth)
                if use_dot_access(obj) { f.write(".") } else { f.write("->") }
                f.write(fname); f.write(" = *_fa; free(_fa); }\n")
            }
        } else {
            if builder_fa_is_ns(e) {
                f.write(til_type_name(obj.til_type)); f.write("_"); f.write(fname); f.write(" = ")
            } else {
                emit_expr(f, obj, depth)
                if use_dot_access(obj) { f.write(".") } else { f.write("->") }
                f.write(fname); f.write(" = ")
            }
            if builder_fa_is_ptr(e) {
                emit_as_ptr(f, rhs_fa, depth, true)
            } else {
                emit_deref(f, rhs_fa, depth)
            }
            f.write(";\n")
        }
    case NodeType.FCall:
        if e.children.len().gt(0).and(e.child(0).node_type.is(NodeType.FieldAccess)) {
            ref del_name : Str = get_payload(e.child(0).node_type)
            if del_name.eq("delete").and(e.children.len().gte(2)) {
                if e.child(1).node_type.is(NodeType.Ident) {
                    ref del_arg : Str = get_payload(e.child(1).node_type)
                    if is_stack_local(del_arg).and(e.child(1).til_type.is(TilType.Struct).not()).and(e.child(1).til_type.is(TilType.Enum).not()) {
                        f.write(";\n"); return
                    }
                }
            }
        }
        e_sname := til_type_name(e.til_type)
        if e_sname.len().gt(0).and(e.children.len().gt(0)) {
            if e.child(0).node_type.is(NodeType.Ident) {
                ref cname : Str = get_payload(e.child(0).node_type)
                if cname.eq(e_sname) { f.write("/* discarded struct constructor */;\n"); return }
            }
        }
        emit_expr(f, e, depth); f.write(";\n")
    case NodeType.Return:
        emit_stmt_return(f, e, depth)
    case NodeType.Body:
        f.write("{\n"); emit_body_scoped(f, e, depth.add(1.to_i32())); emit_indent(f, depth); f.write("}\n")
    case NodeType.If:
        f.write("if ("); emit_deref(f, e.child(0), depth); f.write(") {\n")
        emit_body_scoped(f, e.child(1), depth.add(1.to_i32())); emit_indent(f, depth)
        if e.children.len().gt(2) { f.write("} else {\n"); emit_body_scoped(f, e.child(2), depth.add(1.to_i32())); emit_indent(f, depth) }
        f.write("}\n")
    case NodeType.While:
        f.write("while ("); emit_deref(f, e.child(0), depth); f.write(") {\n")
        emit_body_scoped(f, e.child(1), depth.add(1.to_i32())); emit_indent(f, depth); f.write("}\n")
    case NodeType.Break: f.write("break;\n")
    case NodeType.Continue: f.write("continue;\n")
    case: f.write("/* TODO: unknown stmt type */\n")
    }
}

emit_fcall_funcptr_cast := proc(f: File, e: Expr, sig: Expr) {
    switch sig.node_type {
    case NodeType.FuncDef(sfd):
        ret_shallow := sfd.return_own_type.is(OwnType.Shallow)
        mut ret_c := "void *"
        if sfd.return_type.len().eq(0) {
            ret_c = "void"
        } else if e.til_type.is(TilType.None).not().and(e.til_type.is(TilType.Unknown).not())
        .and(e.til_type.is(TilType.Dynamic).not()) {
            ret_c = til_type_to_c(e.til_type)
            if e.til_type.is(TilType.Struct).or(e.til_type.is(TilType.Enum)) {
                e_sname := til_type_name(e.til_type)
                if e_sname.len().gt(0) { ret_c = e_sname }
            }
            if ret_shallow.not() { ret_c = ret_c.concat(" *") }
        }
        f.write("((")
        f.write(ret_c)
        f.write(" (*)(")
        for i in 1..e.children.len() {
            if i.gt(1) { f.write(", ") }
            ref arg : Expr = e.child(i)
            mut arg_shallow := false
            if i.sub(1).lt(sfd.params.len()) {
                ref p : Declaration = sfd.params.get(i.sub(1))
                arg_shallow = p.own_type.is(OwnType.Shallow)
            }
            mut arg_c := "void *"
            if arg.til_type.is(TilType.Unknown).not().and(arg.til_type.is(TilType.Dynamic).not()) {
                arg_c = til_type_to_c(arg.til_type)
                if arg.til_type.is(TilType.Struct).or(arg.til_type.is(TilType.Enum)) {
                    arg_sname := til_type_name(arg.til_type)
                    if arg_sname.len().gt(0) { arg_c = arg_sname }
                }
                if arg_shallow.not() { arg_c = arg_c.concat(" *") }
            }
            f.write(arg_c)
        }
        if e.children.len().eq(1) { f.write("void") }
    case:
        UNREACHABLE(__LOC__)
    }
}

emit_fcall_funcptr_args := proc(f: File, e: Expr, sig: Expr, shallow depth: I32) {
    switch sig.node_type {
    case NodeType.FuncDef(sfd):
        for i in 1..e.children.len() {
            if i.gt(1) { f.write(", ") }
            mut arg_shallow := false
            if i.sub(1).lt(sfd.params.len()) {
                ref p : Declaration = sfd.params.get(i.sub(1))
                arg_shallow = p.own_type.is(OwnType.Shallow)
            }
            if arg_shallow { emit_deref(f, e.child(i), depth) }
            else { emit_as_ptr(f, e.child(i), depth, get_own_arg(e, i)) }
        }
    case:
        UNREACHABLE(__LOC__)
    }
}

emit_expr := proc(f: File, e: Expr, shallow depth: I32) {
    switch e.node_type {
    case NodeType.LiteralStr(s):
        f.write("Str_lit(\"")
        f.write(s)
        f.write("\", ")
        emit_u64(f, s.len().to_i64().to_u64())
        f.write("ULL)")
    case NodeType.LiteralNum(num):
        f.write(num)
    case NodeType.LiteralBool(b):
        if b { emit_i32(f, 1.to_i32()) } else { emit_i32(f, 0.to_i32()) }
    case NodeType.LiteralNull:
        f.write("NULL")
    case NodeType.Ident(ident):
        if e.til_type.is(TilType.FuncPtr) {
            f.write("(void *)")
            fc := func_to_c(ident)
            f.write(fc)
        } else {
            f.write(ident)
        }
    case NodeType.FCall:
        ref callee : Expr = e.child(0)
        // Indirect call through FuncSig-typed struct field
        if callee.node_type.is(NodeType.FieldAccess) {
            if callee.til_type.is(TilType.FuncPtr) {
                ref sig : Expr = fcall_fn_sig(e)
                if is_null(sig).not() {
                    emit_fcall_funcptr_cast(f, e, sig)
                    f.write("))(void *)(")
                    emit_expr(f, callee, depth)
                    f.write("))(")
                    emit_fcall_funcptr_args(f, e, sig, depth)
                    f.write(")")
                    return
                }
            }
            // Namespace method call
            sname := til_type_name(callee.child(0).til_type)
            ref mname : Str = get_payload(callee.node_type)
            flat := sname.concat("_").concat(mname)
            f.write(sname)
            f.write("_")
            f.write(mname)
            f.write("(")
            for i in 1..e.children.len() {
                if i.gt(1) { f.write(", ") }
                if callee_param_is_shallow(flat, i.sub(1)) {
                    emit_deref(f, e.child(i), depth)
                } else if callee_param_is_usize(flat, i.sub(1)).and(callee_param_is_own(flat, i.sub(1)).not()) {
                    emit_usize_ref(f, e.child(i), depth)
                } else {
                    emit_as_ptr(f, e.child(i), depth, get_own_arg(e, i))
                }
            }
            f.write(")")
            return
        }
        ref name : Str = get_payload(callee.node_type)
        if name.eq("dyn_call").or(name.eq("dyn_call_ret")) {
            ref method : Str = get_payload(e.child(2).node_type)
            ref nargs_str : Str = get_payload(e.child(3).node_type)
            nargs := nargs_str.to_i64().to_i32()
            f.write("dyn_call_")
            f.write(method)
            f.write("(")
            emit_as_ptr(f, e.child(1), depth, false)
            for ai : I32 in 0..nargs {
                f.write(", ")
                emit_as_ptr(f, e.child(ai.to_i64().add(4).to_u32()), depth, false)
            }
            f.write(")")
        } else if name.eq("dyn_fn") {
            f.write("dyn_fn(")
            emit_as_ptr(f, e.child(1), depth, false)
            f.write(", ")
            ref method_arg : Expr = e.child(2)
            if method_arg.node_type.is(NodeType.LiteralStr) {
                ref ms : Str = get_payload(method_arg.node_type)
                f.write("&(Str){.c_str=(U8*)\"")
                f.write(ms)
                f.write("\", .count=")
                emit_u64(f, ms.len().to_i64().to_u64())
                f.write("ULL, .cap=TIL_CAP_LIT}")
            } else {
                emit_as_ptr(f, method_arg, depth, false)
            }
            f.write(")")
        } else if name.eq("array").or(name.eq("vec")) {
            ref elem_type : Str = get_payload(e.child(1).node_type)
            count := e.children.len().sub(2).to_i64().to_i32()
            if name.eq("array") { f.write("array") } else { f.write("vec") }
            f.write("_of_")
            f.write(elem_type)
            f.write("(")
            emit_i32(f, count)
            for i in 2..e.children.len() {
                f.write(", ")
                emit_as_ptr(f, e.child(i), depth, false)
            }
            f.write(")")
        } else if name.eq("dyn_has_method") {
            ref method : Str = get_payload(e.child(2).node_type)
            f.write("dyn_has_")
            f.write(method)
            f.write("(")
            emit_as_ptr(f, e.child(1), depth, false)
            f.write(")")
        } else if til_type_name(e.til_type).len().gt(0).and(name.eq(til_type_name(e.til_type))) {
            // Struct constructor
            ctype := c_type_name(e.til_type, til_type_name(e.til_type))
            ctor_seq = ctor_seq.add(1.to_i32())
            id := ctor_seq
            f.write("({ ")
            f.write(ctype)
            f.write(" *_sc")
            emit_i32(f, id)
            f.write(" = malloc(sizeof(")
            f.write(ctype)
            f.write(")); ")
            tmp := "_sc".concat(id.to_i64().to_str())
            emit_ctor_fields(f, tmp, e, depth)
            f.write(" _sc")
            emit_i32(f, id)
            f.write("; })")
        } else if callee.til_type.is(TilType.FuncPtr) {
            // Indirect call through function pointer variable
            ref sig : Expr = fcall_fn_sig(e)
            emit_fcall_funcptr_cast(f, e, sig)
            if is_ref_local(name) {
                f.write("))(void *)(*")
                f.write(name)
                f.write("))(")
            } else {
                f.write("))(void *)")
                f.write(name)
                f.write(")(")
            }
            emit_fcall_funcptr_args(f, e, sig, depth)
            f.write(")")
        } else {
            // User-defined function call
            fc := func_to_c(name)
            f.write(fc)
            f.write("(")
            for i in 1..e.children.len() {
                if i.gt(1) { f.write(", ") }
                if callee_param_is_shallow(name, i.sub(1)) {
                    emit_deref(f, e.child(i), depth)
                } else if callee_param_is_usize(name, i.sub(1)).and(callee_param_is_own(name, i.sub(1)).not()) {
                    emit_usize_ref(f, e.child(i), depth)
                } else {
                    emit_as_ptr(f, e.child(i), depth, get_own_arg(e, i))
                }
            }
            f.write(")")
        }
    case NodeType.FieldAccess(fname):
        ref obj : Expr = e.child(0)
        if builder_fa_is_ns(e) {
            obj_sname := til_type_name(obj.til_type)
            if e.til_type.is(TilType.Enum) {
                f.write("&(")
                f.write(obj_sname)
                f.write("){.tag = ")
                f.write(obj_sname)
                f.write("_TAG_")
                f.write(fname)
                f.write("}")
            } else {
                f.write(obj_sname)
                f.write("_")
                f.write(fname)
            }
        } else {
            emit_expr(f, obj, depth)
            if use_dot_access(obj) { f.write(".") } else { f.write("->") }
            f.write(fname)
        }
    case:
        f.write("/* TODO: unknown expr type */")
    }
}

emit_body := proc(f: File, body: Expr, shallow depth: I32) {
    for e_i : Expr in body.children {
        emit_stmt(f, e_i, depth)
    }
}
emit_ctor_fields := proc(f: File, var: Str, ctor: Expr, shallow depth: I32) {
    ref ecf_def : Expr = find_struct_def(til_type_name(ctor.til_type))
    mut fi : U32 = 0
    for i in 1..ctor.children.len() {
        mut fld_own := OwnType.Shallow
        mut field_type := TilType.Unknown
        mut fname := ""
        if is_null(ecf_def).not() {
            if ecf_def.node_type.is(NodeType.StructDef) {
                ref ecf_sdd : StructDef = get_payload(ecf_def.node_type)
                if fi.lt(ecf_sdd.fields.len()) {
                    ref dd : Declaration = ecf_sdd.fields.get(fi)
                    fld_own = dd.own_type
                    field_type = dd.til_type
                    fname = dd.name
                    fi = fi.add(1)
                }
            }
        }
        ref arg : Expr = ctor.child(i)
        emit_indent(f, depth)
        if fld_own.is(OwnType.Ref) {
            emit_field(f, var, fname)
            f.write(" = ")
            emit_expr(f, arg, depth)
            f.write(";\n")
        } else if fld_own.is(OwnType.Own) {
            if arg.node_type.is(NodeType.FCall) {
                arg_sname := til_type_name(arg.til_type)
                if arg_sname.len().gt(0) {
                    if arg.child(0).node_type.is(NodeType.Ident) {
                        ref callee_ident : Str = get_payload(arg.child(0).node_type)
                        if callee_ident.eq(arg_sname) {
                            ct := c_type_name(arg.til_type, arg_sname)
                            ctor_seq = ctor_seq.add(1.to_i32())
                            id := ctor_seq
                            tmp := "_cs".concat(id.to_i64().to_str())
                            f.write(ct)
                            f.write(" *")
                            f.write(tmp)
                            f.write(" = malloc(sizeof(")
                            f.write(ct)
                            f.write("));\n")
                            emit_ctor_fields(f, tmp, arg, depth)
                            emit_indent(f, depth)
                            emit_field(f, var, fname)
                            f.write(" = ")
                            f.write(tmp)
                            f.write(";\n")
                        } else {
                            emit_field(f, var, fname)
                            f.write(" = ")
                            emit_as_ptr(f, arg, depth, true)
                            f.write(";\n")
                        }
                    } else {
                        emit_field(f, var, fname)
                        f.write(" = ")
                        emit_as_ptr(f, arg, depth, true)
                        f.write(";\n")
                    }
                } else {
                    emit_field(f, var, fname)
                    f.write(" = ")
                    emit_as_ptr(f, arg, depth, true)
                    f.write(";\n")
                }
            } else {
                emit_field(f, var, fname)
                f.write(" = ")
                emit_as_ptr(f, arg, depth, true)
                f.write(";\n")
            }
        } else if arg.node_type.is(NodeType.FCall) {
            arg_sname2 := til_type_name(arg.til_type)
            if arg_sname2.len().gt(0) {
                if arg.child(0).node_type.is(NodeType.Ident) {
                    ref callee_ident : Str = get_payload(arg.child(0).node_type)
                    if callee_ident.eq(arg_sname2) {
                        ct := c_type_name(arg.til_type, arg_sname2)
                        ctor_seq = ctor_seq.add(1.to_i32())
                        id := ctor_seq
                        tmp := "_cs".concat(id.to_i64().to_str())
                        f.write(ct)
                        f.write(" *")
                        f.write(tmp)
                        f.write(" = malloc(sizeof(")
                        f.write(ct)
                        f.write("));\n")
                        emit_ctor_fields(f, tmp, arg, depth)
                        emit_indent(f, depth)
                        emit_field(f, var, fname)
                        f.write(" = *")
                        f.write(tmp)
                        f.write("; free(")
                        f.write(tmp)
                        f.write(");\n")
                    } else {
                        if field_type.is(TilType.FuncPtr).or(field_type.is(TilType.Dynamic))
                        .or(fcall_is_shallow_return(arg)).or(fcall_returns_dynamic(arg)) {
                            emit_field(f, var, fname)
                            f.write(" = ")
                            emit_expr(f, arg, depth)
                            f.write(";\n")
                        } else {
                            ftype := c_type_name(arg.til_type, arg_sname2)
                            f.write("{ ")
                            f.write(ftype)
                            f.write(" *_ca = ")
                            emit_expr(f, arg, depth)
                            f.write("; ")
                            emit_field(f, var, fname)
                            f.write(" = *_ca; free(_ca); }\n")
                        }
                    }
                } else {
                    if field_type.is(TilType.FuncPtr).or(field_type.is(TilType.Dynamic))
                    .or(fcall_is_shallow_return(arg)).or(fcall_returns_dynamic(arg)) {
                        emit_field(f, var, fname)
                        f.write(" = ")
                        emit_expr(f, arg, depth)
                        f.write(";\n")
                    } else {
                        ftype := c_type_name(arg.til_type, arg_sname2)
                        f.write("{ ")
                        f.write(ftype)
                        f.write(" *_ca = ")
                        emit_expr(f, arg, depth)
                        f.write("; ")
                        emit_field(f, var, fname)
                        f.write(" = *_ca; free(_ca); }\n")
                    }
                }
            } else {
                if field_type.is(TilType.FuncPtr).or(field_type.is(TilType.Dynamic))
                .or(fcall_is_shallow_return(arg)).or(fcall_returns_dynamic(arg)) {
                    emit_field(f, var, fname)
                    f.write(" = ")
                    emit_expr(f, arg, depth)
                    f.write(";\n")
                } else {
                    ftype := c_type_name(arg.til_type, arg_sname2)
                    f.write("{ ")
                    f.write(ftype)
                    f.write(" *_ca = ")
                    emit_expr(f, arg, depth)
                    f.write("; ")
                    emit_field(f, var, fname)
                    f.write(" = *_ca; free(_ca); }\n")
                }
            }
        } else {
            emit_field(f, var, fname)
            f.write(" = ")
            emit_deref(f, arg, depth)
            f.write(";\n")
        }
    }
}

emit_ns_inits := proc(f: File, shallow depth: I32) {
    ref lp : LoadedProgram = codegen_lp()
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            for i in 0..iu.ast.children.len() {
                ref stmt : Expr = iu.ast.child(i)
                if is_struct_or_enum(stmt) {
                    ref sname : Str = get_payload(stmt.node_type)
                    ref edef : Expr = stmt.child(0)
                    if edef.node_type.is(NodeType.EnumDef) { continue }
                    ref ni_ns : Vec = def_ns_decls(edef)
                    for dd : Declaration in ni_ns {
                        if is_null(dd.default_value) { continue }
                        if dd.default_value.node_type.is(NodeType.FuncDef) { continue }
                        emit_indent(f, depth)
                        f.write(sname)
                        f.write("_")
                        f.write(dd.name)
                        f.write(" = ")
                        emit_deref(f, dd.default_value, depth)
                        f.write(";\n")
                    }
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        for i in 0..iu.ast.children.len() {
            ref stmt : Expr = iu.ast.child(i)
            if is_struct_or_enum(stmt) {
                ref sname : Str = get_payload(stmt.node_type)
                ref edef : Expr = stmt.child(0)
                if edef.node_type.is(NodeType.EnumDef) { continue }
                ref ni_ns : Vec = def_ns_decls(edef)
                for dd : Declaration in ni_ns {
                    if is_null(dd.default_value) { continue }
                    if dd.default_value.node_type.is(NodeType.FuncDef) { continue }
                    emit_indent(f, depth)
                    f.write(sname)
                    f.write("_")
                    f.write(dd.name)
                    f.write(" = ")
                    emit_deref(f, dd.default_value, depth)
                    f.write(";\n")
                }
            }
        }
    }
}

emit_body_scoped := proc(f: File, body: Expr, shallow depth: I32) {
    saved_sl := stack_locals.clone()
    saved_rl := ref_locals.clone()
    emit_body(f, body, depth)
    own stack_locals.delete()
    own ref_locals.delete()
    stack_locals = saved_sl
    ref_locals = saved_rl
}

emit_deref := proc(f: File, e: Expr, shallow depth: I32) {
    if e.til_type.is(TilType.Dynamic) {
        emit_expr(f, e, depth)
    } else if e.til_type.is(TilType.FuncPtr) {
        if e.node_type.is(NodeType.Ident) {
            ref ident : Str = get_payload(e.node_type)
            if is_ref_local(ident) {
                f.write("(void *)DEREF(")
                emit_expr(f, e, depth)
                f.write(")")
            } else {
                f.write("(void *)")
                emit_expr(f, e, depth)
            }
        } else {
            f.write("(void *)")
            emit_expr(f, e, depth)
        }
    } else {
        switch e.node_type {
        case NodeType.Ident(ident):
            if is_shallow_param(ident).or(is_stack_local(ident)).or(is_value_global(ident)) {
                emit_expr(f, e, depth)
            } else {
                f.write("DEREF(")
                emit_expr(f, e, depth)
                f.write(")")
            }
        case NodeType.LiteralStr(s):
            f.write("(Str){.c_str=(U8*)\"")
            f.write(s)
            f.write("\", .count=")
            emit_u64(f, s.len().to_i64().to_u64())
            f.write("ULL, .cap=TIL_CAP_LIT}")
        case NodeType.FieldAccess:
            if builder_fa_is_ns(e).and(e.til_type.is(TilType.Enum)) {
                f.write("(*")
                emit_expr(f, e, depth)
                f.write(")")
            } else {
                emit_expr(f, e, depth)
            }
        case:
            emit_expr(f, e, depth)
        }
    }
}

emit_as_ptr := proc(f: File, e: Expr, shallow depth: I32, shallow is_own: Bool) {
    switch e.node_type {
    case NodeType.Ident(ident):
        if is_shallow_param(ident).or(is_stack_local(ident)).or(is_value_global(ident)) {
            if is_own {
                ref mut ctype : Str = get_stack_local_ctype(ident)
                if is_null(ctype) { ctype = c_type_name(e.til_type, til_type_name(e.til_type)) }
                f.write("({ ")
                f.write(ctype)
                f.write(" *_oa = malloc(sizeof(")
                f.write(ctype)
                f.write(")); *_oa = ")
                emit_expr(f, e, depth)
                f.write("; _oa; })")
            } else {
                f.write("&")
                f.write(ident)
            }
        } else {
            emit_expr(f, e, depth)
        }
    case NodeType.FCall:
        e_sname := til_type_name(e.til_type)
        if e_sname.len().gt(0).and(e.children.len().gt(0)) {
            if e.child(0).node_type.is(NodeType.Ident) {
                ref callee_ident : Str = get_payload(e.child(0).node_type)
                if callee_ident.eq(e_sname) {
                    ctype := c_type_name(e.til_type, e_sname)
                    ctor_seq = ctor_seq.add(1.to_i32())
                    id := ctor_seq
                    f.write("({ ")
                    f.write(ctype)
                    f.write(" *_sc")
                    emit_i32(f, id)
                    f.write(" = malloc(sizeof(")
                    f.write(ctype)
                    f.write(")); ")
                    tmp := "_sc".concat(id.to_i64().to_str())
                    emit_ctor_fields(f, tmp, e, depth)
                    f.write(" _sc")
                    emit_i32(f, id)
                    f.write("; })")
                    return
                }
            }
        }
        emit_expr(f, e, depth)
    case NodeType.LiteralStr:
        emit_expr(f, e, depth)
    case NodeType.FieldAccess(fname):
        if builder_fa_is_ptr(e) {
            emit_expr(f, e, depth)
        } else if builder_fa_is_ns(e).and(e.til_type.is(TilType.Enum)) {
            if is_own {
                ref obj : Expr = e.child(0)
                obj_sname := til_type_name(obj.til_type)
                f.write("({ ")
                f.write(obj_sname)
                f.write(" *_oa = malloc(sizeof(")
                f.write(obj_sname)
                f.write(")); *_oa = (")
                f.write(obj_sname)
                f.write("){.tag = ")
                f.write(obj_sname)
                f.write("_TAG_")
                f.write(fname)
                f.write("}; _oa; })")
            } else {
                emit_expr(f, e, depth)
            }
        } else if e.til_type.is(TilType.Dynamic) {
            emit_expr(f, e, depth)
        } else {
            f.write("&")
            emit_expr(f, e, depth)
        }
    case NodeType.LiteralNull:
        f.write("NULL")
    case:
        ctype := c_type_name(e.til_type, til_type_name(e.til_type))
        f.write("&(")
        f.write(ctype)
        f.write("){")
        emit_expr(f, e, depth)
        f.write("}")
    }
}

emit_usize_ref := proc(f: File, e: Expr, shallow depth: I32) {
    f.write("USIZE_REF(")
    emit_deref(f, e, depth)
    f.write(")")
}

emit_cli_parse_arg := proc(f: File, pname: Str, ptype: Str, shallow argi: I32) {
    if ptype.eq("Str") {
        f.write("    Str *"); f.write(pname); f.write(" = Str_clone(&(Str){.c_str = (U8 *)argv["); emit_i32(f, argi); f.write("], .count = strlen(argv["); emit_i32(f, argi); f.write("]), .cap = TIL_CAP_LIT});\n")
    } else if ptype.eq("I64") {
        f.write("    I64 *"); f.write(pname); f.write(" = cli_parse_i64(argv["); emit_i32(f, argi); f.write("]);\n")
    } else if ptype.eq("U8") {
        f.write("    U8 *"); f.write(pname); f.write(" = cli_parse_u8(argv["); emit_i32(f, argi); f.write("]);\n")
    } else if ptype.eq("I16") {
        f.write("    I16 *"); f.write(pname); f.write(" = cli_parse_i16(argv["); emit_i32(f, argi); f.write("]);\n")
    } else if ptype.eq("I32") {
        f.write("    I32 *"); f.write(pname); f.write(" = cli_parse_i32(argv["); emit_i32(f, argi); f.write("]);\n")
    } else if ptype.eq("U32") {
        f.write("    U32 *"); f.write(pname); f.write(" = cli_parse_u32(argv["); emit_i32(f, argi); f.write("]);\n")
    } else if ptype.eq("U64") {
        f.write("    U64 *"); f.write(pname); f.write(" = cli_parse_u64(argv["); emit_i32(f, argi); f.write("]);\n")
    } else if ptype.eq("USize") {
        f.write("    USize *"); f.write(pname); f.write(" = (USize *)cli_parse_u64(argv["); emit_i32(f, argi); f.write("]);\n")
    } else if ptype.eq("Bool") {
        f.write("    Bool *"); f.write(pname); f.write(" = cli_parse_bool(argv["); emit_i32(f, argi); f.write("]);\n")
    } else {
        f.write("    // unsupported CLI arg type: "); f.write(ptype); f.write("\n")
        f.write("    fprintf(stderr, \"error: unsupported CLI argument type '"); f.write(ptype); f.write("'\\n\"); return 1;\n")
    }
}

emit_func_def := proc(f: File, name: Str, func_def: Expr, mode: Mode, shallow is_static: Bool) {
    ref fd : FunctionDef = get_payload(func_def.node_type)
    ref body : Expr = func_def.child(0)
    mut is_main := false
    if is_null(mode).not() {
        if mode.needs_main { is_main = name.eq("main") }
    }

    if is_main {
        nparam := fd.params.len()
        vi := fd.variadic_index
        if nparam.eq(0) {
            f.write("int main(int argc, char **argv) {\n")
            f.write("    (void)argv;\n")
            f.write("    if (argc > 1) { fprintf(stderr, \"error: main expects no arguments, got %d\\n\", argc - 1); return 1; }\n")
        } else {
            f.write("int main(int argc, char **argv) {\n")
            mut fixed := nparam.to_i64().to_i32()
            if vi.gte(0.to_i32()) { fixed = fixed.sub(1.to_i32()) }
            if vi.gte(0.to_i32()) {
                f.write("    if (argc - 1 < "); emit_i32(f, fixed); f.write(") { fprintf(stderr, \"error: main expects at least "); emit_i32(f, fixed); f.write(" argument(s), got %d\\n\", argc - 1); return 1; }\n")
            } else {
                f.write("    if (argc - 1 != "); emit_i32(f, nparam.to_i64().to_i32()); f.write(") { fprintf(stderr, \"error: main expects "); emit_i32(f, nparam.to_i64().to_i32()); f.write(" argument(s), got %d\\n\", argc - 1); return 1; }\n")
            }
        }
        emit_ns_inits(f, 1.to_i32())
        if has_script_globals {
            ref lp : LoadedProgram = codegen_lp()
            if lp.skip_core.not() {
                for u : ProgramUnit in lp.core_units {
                    ref iu : ImportUnit = lp.ctx.imported.get(u.path)
                    for gi in 0..iu.ast.children.len() {
                        ref gs : Expr = iu.ast.child(gi)
                        if gs.node_type.is(NodeType.Decl) {
                            ref rhs : Expr = gs.child(0)
                            if rhs.node_type.is(NodeType.FuncDef).or(rhs.node_type.is(NodeType.StructDef)).or(rhs.node_type.is(NodeType.EnumDef)) { continue }
                            if gs.til_type.is(TilType.None).and(rhs.node_type.is(NodeType.Ident)) { continue }
                        } else if gs.node_type.is(NodeType.FCall).not() { continue }
                        emit_stmt(f, gs, 1.to_i32())
                    }
                }
            }
            for u : ProgramUnit in lp.units {
                ref iu : ImportUnit = lp.ctx.imported.get(u.path)
                for gi in 0..iu.ast.children.len() {
                    ref gs : Expr = iu.ast.child(gi)
                    if gs.node_type.is(NodeType.Decl) {
                        ref rhs : Expr = gs.child(0)
                        if rhs.node_type.is(NodeType.FuncDef).or(rhs.node_type.is(NodeType.StructDef)).or(rhs.node_type.is(NodeType.EnumDef)) { continue }
                        if gs.til_type.is(TilType.None).and(rhs.node_type.is(NodeType.Ident)) { continue }
                    } else if gs.node_type.is(NodeType.FCall).not() { continue }
                    emit_stmt(f, gs, 1.to_i32())
                }
            }
        }
        if nparam.gt(0) {
            mut argi := 1.to_i32()
            for i in 0..nparam {
                ref p : Declaration = fd.params.get(i)
                ii := i.to_i64().to_i32()
                if ii.eq(vi) {
                    // Variadic array
                    f.write("    int _va_argc = argc - "); emit_i32(f, argi); f.write(";\n")
                    f.write("    USize _va_esz = sizeof("); f.write(p.explicit_type); f.write(");\n")
                    f.write("    USize _va_cap = _va_argc;\n")
                    f.write("    Array *"); f.write(p.name); f.write(" = Array_new(&(Str){.c_str = (U8 *)\""); f.write(p.explicit_type); f.write("\", .count = "); emit_u64(f, p.explicit_type.len().to_i64().to_u64()); f.write("ULL, .cap = TIL_CAP_LIT}, &(USize){_va_esz}, &(USize){_va_cap});\n")
                    f.write("    for (int _i = 0; _i < _va_argc; _i++) {\n")
                    f.write("        USize _idx = _i;\n")
                    if p.explicit_type.eq("Str") {
                        f.write("        Str *_val = Str_clone(&(Str){.c_str = (U8 *)argv["); emit_i32(f, argi); f.write(" + _i], .count = strlen(argv["); emit_i32(f, argi); f.write(" + _i]), .cap = TIL_CAP_LIT});\n")
                    } else if p.explicit_type.eq("I64") {
                        f.write("        I64 *_val = cli_parse_i64(argv["); emit_i32(f, argi); f.write(" + _i]);\n")
                    } else if p.explicit_type.eq("U8") {
                        f.write("        U8 *_val = cli_parse_u8(argv["); emit_i32(f, argi); f.write(" + _i]);\n")
                    } else if p.explicit_type.eq("I16") {
                        f.write("        I16 *_val = cli_parse_i16(argv["); emit_i32(f, argi); f.write(" + _i]);\n")
                    } else if p.explicit_type.eq("I32") {
                        f.write("        I32 *_val = cli_parse_i32(argv["); emit_i32(f, argi); f.write(" + _i]);\n")
                    } else if p.explicit_type.eq("U32") {
                        f.write("        U32 *_val = cli_parse_u32(argv["); emit_i32(f, argi); f.write(" + _i]);\n")
                    } else if p.explicit_type.eq("U64") {
                        f.write("        U64 *_val = cli_parse_u64(argv["); emit_i32(f, argi); f.write(" + _i]);\n")
                    } else if p.explicit_type.eq("USize") {
                        f.write("        USize *_val = (USize *)cli_parse_u64(argv["); emit_i32(f, argi); f.write(" + _i]);\n")
                    } else if p.explicit_type.eq("Bool") {
                        f.write("        Bool *_val = cli_parse_bool(argv["); emit_i32(f, argi); f.write(" + _i]);\n")
                    }
                    f.write("        Array_set("); f.write(p.name); f.write(", &(USize){_idx}, _val);\n")
                    f.write("    }\n")
                } else {
                    emit_cli_parse_arg(f, p.name, p.explicit_type, argi)
                    argi = argi.add(1.to_i32())
                }
            }
        }
        saved_sl := stack_locals; saved_slt := stack_local_types; saved_uth := unsafe_to_hoist; saved_rl := ref_locals
        stack_locals = Set.new("Str", Str.size()); stack_local_types = Map.new("Str", Str.size(), "Str", Str.size())
        unsafe_to_hoist = Set.new("Str", Str.size()); ref_locals = Set.new("Str", Str.size())
        collect_unsafe_to_hoist(body)
        in_main_func = true
        emit_body(f, body, 1.to_i32())
        in_main_func = false
        own stack_locals.delete(); own stack_local_types.delete(); own unsafe_to_hoist.delete(); own ref_locals.delete()
        stack_locals = saved_sl; stack_local_types = saved_slt; unsafe_to_hoist = saved_uth; ref_locals = saved_rl
        f.write("    return 0;\n")
        f.write("}\n")
    } else {
        // Return type
        ret := func_return_ctype(fd)
        // Signature
        if is_static { f.write("static __attribute__((unused)) ") }
        f.write(ret); f.write(" "); fc := func_to_c(name); f.write(fc); f.write("(")
        emit_param_list(f, func_def, true)
        f.write(") {\n")
        for p : Declaration in fd.params {
            f.write("    (void)"); f.write(p.name); f.write(";\n")
        }
        in_func_def = true
        current_fdef = func_def
        saved_sl := stack_locals; saved_slt := stack_local_types; saved_uth := unsafe_to_hoist; saved_rl := ref_locals
        stack_locals = Set.new("Str", Str.size()); stack_local_types = Map.new("Str", Str.size(), "Str", Str.size())
        unsafe_to_hoist = Set.new("Str", Str.size()); ref_locals = Set.new("Str", Str.size())
        collect_unsafe_to_hoist(body)
        emit_body(f, body, 1.to_i32())
        own stack_locals.delete(); own stack_local_types.delete(); own unsafe_to_hoist.delete(); own ref_locals.delete()
        stack_locals = saved_sl; stack_local_types = saved_slt; unsafe_to_hoist = saved_uth; ref_locals = saved_rl
        in_func_def = false
        f.write("}\n")
    }
}

emit_struct_typedef := proc(f: File, name: Str, struct_def: Expr) {
    if is_ext_h_type(name) { return }
    switch struct_def.node_type {
    case NodeType.StructDef(sdd):
        if sdd.c_tag.eq("@anon") {
            f.write("typedef struct {\n")
        } else if sdd.c_tag.len().gt(0) {
            f.write("typedef struct "); f.write(sdd.c_tag); f.write(" {\n")
        } else {
            f.write("typedef struct "); f.write(name); f.write(" {\n")
        }
        if sdd.fields.len().eq(0) { f.write("    char _;\n") }
        for dd : Declaration in sdd.fields {
            if dd.own_type.is(OwnType.Shallow).not() {
                if dd.til_type.is(TilType.Struct).or(dd.til_type.is(TilType.Enum)) {
                    sname := til_type_name(dd.til_type)
                    if sname.len().gt(0) {
                        f.write("    "); f.write(sname); f.write(" *"); f.write(dd.name); f.write(";\n")
                    } else {
                        tc := til_type_to_c(dd.til_type); f.write("    "); f.write(tc); f.write(" *"); f.write(dd.name); f.write(";\n")
                    }
                } else {
                    tc := til_type_to_c(dd.til_type); f.write("    "); f.write(tc); f.write(" *"); f.write(dd.name); f.write(";\n")
                }
            } else if dd.til_type.is(TilType.Struct).or(dd.til_type.is(TilType.Enum)) {
                sname := til_type_name(dd.til_type)
                if sname.len().gt(0) {
                    f.write("    "); f.write(sname); f.write(" "); f.write(dd.name); f.write(";\n")
                } else {
                    tc := til_type_to_c(dd.til_type); f.write("    "); f.write(tc); f.write(" "); f.write(dd.name); f.write(";\n")
                }
            } else {
                tc := til_type_to_c(dd.til_type); f.write("    "); f.write(tc); f.write(" "); f.write(dd.name); f.write(";\n")
            }
        }
        f.write("} "); f.write(name); f.write(";\n\n")
    case:
        UNREACHABLE(__LOC__)
    }
    // Namespace non-function fields as globals
    ref ng_ns : Vec = def_ns_decls(struct_def)
    for dd : Declaration in ng_ns {
        if is_null(dd.default_value) { continue }
        if dd.default_value.node_type.is(NodeType.FuncDef) { continue }
        if dd.til_type.is(TilType.Struct).or(dd.til_type.is(TilType.Enum)) {
            ng_sname := til_type_name(dd.default_value.til_type)
            if ng_sname.len().gt(0) {
                f.write(ng_sname); f.write(" "); f.write(name); f.write("_"); f.write(dd.name); f.write(";\n")
            } else {
                tc := til_type_to_c(dd.til_type); f.write(tc); f.write(" "); f.write(name); f.write("_"); f.write(dd.name); f.write(";\n")
            }
        } else {
            tc := til_type_to_c(dd.til_type); f.write(tc); f.write(" "); f.write(name); f.write("_"); f.write(dd.name); f.write(";\n")
        }
    }
}

emit_ns_method := proc(f: File, name: Str, dd_name: Str, fdef: Expr) {
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)) { return }
    case:
        UNREACHABLE(__LOC__)
        return
    }
    full_name := name.concat("_").concat(dd_name)
    emit_func_def(f, full_name, fdef, NULL, false)
    f.write("\n")
}

emit_struct_funcs := proc(f: File, name: Str, struct_def: Expr) {
    // User-defined from ns_decls
    ref ns : Vec = def_ns_decls(struct_def)
    for dd : Declaration in ns {
        if is_null(dd.default_value) { continue }
        if dd.default_value.node_type.is(NodeType.NoDefaultArg) { continue }
        if dd.default_value.node_type.is(NodeType.FuncDef) {
            emit_ns_method(f, name, dd.name, dd.default_value)
        }
    }
}

emit_enum_def := proc(f: File, name: Str, enum_def: Expr) {
    switch enum_def.node_type {
    case NodeType.EnumDef(edd):
        hp := enum_has_payloads(enum_def)
        if hp.not() {
            // Simple enum
            for vn : Str in edd.variants {
                f.write(name); f.write(" *"); f.write(name); f.write("_"); f.write(vn); f.write("() {\n")
                f.write("    "); f.write(name); f.write(" *r = malloc(sizeof("); f.write(name); f.write("));\n")
                f.write("    *r = ("); f.write(name); f.write("){ .tag = "); f.write(name); f.write("_TAG_"); f.write(vn); f.write(" };\n")
                f.write("    return r;\n"); f.write("}\n")
            }
        } else {
            // Payload enum
            for i in 0..edd.variants.len() {
                ref vn : Str = edd.variants.get(i)
                vt := enum_variant_type(enum_def, i.to_i64().to_i32())
                if vt.len().eq(0) {
                    f.write(name); f.write(" *"); f.write(name); f.write("_"); f.write(vn); f.write("() {\n")
                    f.write("    "); f.write(name); f.write(" *r = malloc(sizeof("); f.write(name); f.write("));\n")
                    f.write("    r->tag = "); f.write(name); f.write("_TAG_"); f.write(vn); f.write(";\n")
                    f.write("    return r;\n"); f.write("}\n")
                    continue
                }
                ptype := type_name_to_c(vt)
                f.write(name); f.write(" *"); f.write(name); f.write("_"); f.write(vn); f.write("("); f.write(ptype); f.write(" val) {\n")
                f.write("    "); f.write(name); f.write(" *r = malloc(sizeof("); f.write(name); f.write("));\n")
                f.write("    r->tag = "); f.write(name); f.write("_TAG_"); f.write(vn); f.write(";\n")
                if is_primitive_type(vt) {
                    f.write("    r->data."); f.write(vn); f.write(" = *val;\n")
                } else if is_funcsig_type(vt).or(vt.eq("Dynamic")) {
                    f.write("    r->data."); f.write(vn); f.write(" = val;\n")
                } else {
                    tnc := type_name_to_c(vt)
                    f.write("    { "); f.write(tnc); f.write(" _tmp = "); f.write(vt); f.write("_clone(val); r->data."); f.write(vn); f.write(" = *_tmp; free(_tmp); }\n")
                }
                f.write("    return r;\n"); f.write("}\n")
            }
        }
    case:
        UNREACHABLE(__LOC__)
    }
    // Namespace methods from ns_decls
    ref _ens : Vec = def_ns_decls(enum_def)
    for dd : Declaration in _ens {
        if is_null(dd.default_value) { continue }
        if dd.default_value.node_type.is(NodeType.FuncDef).not() { continue }
        emit_ns_method(f, name, dd.name, dd.default_value)
    }
}

emit_enum_struct_body := proc(f: File, ename: Str, enum_def: Expr) {
    f.write("struct "); f.write(ename); f.write(" {\n")
    f.write("    "); f.write(ename); f.write("_tag tag;\n")
    if enum_has_payloads(enum_def) {
        f.write("    union {\n")
        switch enum_def.node_type {
        case NodeType.EnumDef(edd):
            for j in 0..edd.variants.len() {
                ref vn : Str = edd.variants.get(j)
                vt := enum_variant_type(enum_def, j.to_i64().to_i32())
                if vt.len().gt(0) {
                    tnv := type_name_to_c_value(vt)
                    f.write("        "); f.write(tnv); f.write(" "); f.write(vn); f.write(";\n")
                }
            }
        case:
            UNREACHABLE(__LOC__)
        }
        f.write("    } data;\n")
    }
    f.write("};\n\n")
}

topo_emit_struct_enum_defs := proc(f: File, prog: Expr, mut emitted: Set) {
    mut indices := Vec.new("U32", U32.size())
    for i in 0..prog.children.len() {
        ref stmt : Expr = prog.child(i)
        if stmt.node_type.is(NodeType.Decl) {
            if stmt.children.len().gt(0) {
                if stmt.child(0).node_type.is(NodeType.StructDef).or(stmt.child(0).node_type.is(NodeType.EnumDef)) {
                    mut idx := i
                    indices.push(own idx)
                }
            }
        }
    }
    mut remaining := indices.len()
    mut done := Array.new("Bool", Bool.size(), indices.len())
    for di in 0..indices.len() {
        mut f_val := false
        done.set(di, own f_val)
    }
    while remaining.gt(0) {
        mut progress := false
        for ei in 0..indices.len() {
            ref d : Bool = done.get(ei)
            if d { continue }
            ref idx : U32 = indices.get(ei)
            ref stmt : Expr = prog.child(idx)
            ref sname : Str = get_payload(stmt.node_type)
            ref def : Expr = stmt.child(0)
            mut deps_ok := true
            switch def.node_type {
            case NodeType.StructDef(dep_sdd):
                for dd : Declaration in dep_sdd.fields {
                    if dd.own_type.is(OwnType.Shallow) {
                        if dd.til_type.is(TilType.Struct).or(dd.til_type.is(TilType.Enum)) {
                            dep_sname := til_type_name(dd.til_type)
                            if dep_sname.len().gt(0) {
                                if emitted.has(dep_sname).not() { deps_ok = false }
                            }
                        }
                    }
                }
            case NodeType.EnumDef(dep_edd):
                for fi in 0..dep_edd.variants.len() {
                    dep_vt := enum_variant_type(def, fi.to_i64().to_i32())
                    if dep_vt.len().gt(0) {
                        if is_primitive_type(dep_vt).not().and(is_funcsig_type(dep_vt).not()) {
                            if emitted.has(dep_vt).not() { deps_ok = false }
                        }
                    }
                }
            case:
            }
            if deps_ok.not() { continue }
            if def.node_type.is(NodeType.StructDef) {
                emit_struct_typedef(f, sname, def)
                f.write("\n")
            } else {
                emit_enum_struct_body(f, sname, def)
            }
            emitted.add(own sname.clone())
            mut t_val := true
            done.set(ei, own t_val)
            remaining = remaining.sub(1)
            progress = true
        }
        if progress.not() {
            for ei in 0..indices.len() {
                ref d : Bool = done.get(ei)
                if d { continue }
                ref idx : U32 = indices.get(ei)
                ref stmt : Expr = prog.child(idx)
                ref sname : Str = get_payload(stmt.node_type)
                ref def : Expr = stmt.child(0)
                if def.node_type.is(NodeType.StructDef) {
                    emit_struct_typedef(f, sname, def)
                    f.write("\n")
                } else {
                    emit_enum_struct_body(f, sname, def)
                }
            }
            break
        }
    }
    own done.delete()
    own indices.delete()
}

// Topologically emit struct/enum typedefs across all per-file units in lp.
topo_emit_struct_enum_defs_lp := proc(f: File, mut emitted: Set) {
    ref lp : LoadedProgram = codegen_lp()
    // Vec<Dynamic> stores raw pointers (8-byte values). Each push takes an
    // allocated 8-byte temp, copies the pointer bytes, then frees the temp.
    mut items := Vec.new("Dynamic", I64.size())
    // Collect pointers to all struct/enum decl statements in stable order.
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            for i in 0..iu.ast.children.len() {
                ref stmt : Expr = iu.ast.child(i)
                if stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0)) {
                    if stmt.child(0).node_type.is(NodeType.StructDef).or(stmt.child(0).node_type.is(NodeType.EnumDef)) {
                        tmp : Dynamic = malloc(I64.size())
                        write_ptr(tmp, stmt)
                        items.push(own tmp)
                    }
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        for i in 0..iu.ast.children.len() {
            ref stmt : Expr = iu.ast.child(i)
            if stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0)) {
                if stmt.child(0).node_type.is(NodeType.StructDef).or(stmt.child(0).node_type.is(NodeType.EnumDef)) {
                    tmp2 : Dynamic = malloc(I64.size())
                    write_ptr(tmp2, stmt)
                    items.push(own tmp2)
                }
            }
        }
    }

    mut remaining := items.len()
    mut done := Array.new("Bool", Bool.size(), items.len())
    for di in 0..items.len() {
        mut f_val := false
        done.set(di, own f_val)
    }

    while remaining.gt(0) {
        mut progress := false
        for ei in 0..items.len() {
            ref d : Bool = done.get(ei)
            if d { continue }
            ref ptr : Dynamic = items.get(ei)
            ref stmt : Expr = deref(ptr)
            ref sname : Str = get_payload(stmt.node_type)
            ref def : Expr = stmt.child(0)
            mut deps_ok := true
            if def.node_type.is(NodeType.StructDef) {
                ref dep_sdd : StructDef = get_payload(def.node_type)
                for dd : Declaration in dep_sdd.fields {
                    if dd.own_type.is(OwnType.Shallow) {
                        if dd.til_type.is(TilType.Struct).or(dd.til_type.is(TilType.Enum)) {
                            dep_sname := til_type_name(dd.til_type)
                            if dep_sname.len().gt(0) {
                                if emitted.has(dep_sname).not() { deps_ok = false }
                            }
                        }
                    }
                }
            } else {
                ref dep_edd : EnumDef = get_payload(def.node_type)
                for fi in 0..dep_edd.variants.len() {
                    dep_vt := enum_variant_type(def, fi.to_i64().to_i32())
                    if dep_vt.len().gt(0) {
                        if is_primitive_type(dep_vt).not().and(is_funcsig_type(dep_vt).not()) {
                            if emitted.has(dep_vt).not() { deps_ok = false }
                        }
                    }
                }
            }
            if deps_ok.not() { continue }
            if def.node_type.is(NodeType.StructDef) {
                emit_struct_typedef(f, sname, def)
                f.write("\n")
            } else {
                emit_enum_struct_body(f, sname, def)
            }
            emitted.add(own sname.clone())
            mut t_val := true
            done.set(ei, own t_val)
            remaining = remaining.sub(1)
            progress = true
        }
        if progress.not() {
            // Fallback: emit remaining in scan order.
            for ei in 0..items.len() {
                ref d : Bool = done.get(ei)
                if d { continue }
                ref ptr2 : Dynamic = items.get(ei)
                ref stmt : Expr = deref(ptr2)
                ref sname : Str = get_payload(stmt.node_type)
                ref def : Expr = stmt.child(0)
                if def.node_type.is(NodeType.StructDef) {
                    emit_struct_typedef(f, sname, def)
                    f.write("\n")
                } else {
                    emit_enum_struct_body(f, sname, def)
                }
                emitted.add(own sname.clone())
            }
            break
        }
    }

    own items.delete()
    own done.delete()
}

// Resolve the C return type for a FunctionDef; "void" when the proc
// has no return type. Avoids the `mut ret := "void"` reassign pattern
// in emit_func_forward_decl / emit_funcsig_typedef whose default
// "void" Str_lit leaked when reassigned.
func_return_ctype := func(fd: FunctionDef) returns Str {
    if fd.return_type.len().eq(0) { return "void" }
    if fd.return_own_type.is(OwnType.Shallow) { return type_name_to_c_value(fd.return_type) }
    return type_name_to_c(fd.return_type)
}

emit_func_forward_decl := proc(f: File, name: Str, fdef: Expr) {
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        ret := func_return_ctype(fd)
        f.write(ret); f.write(" "); f.write(name); f.write("(")
        emit_param_list(f, fdef, true)
        f.write(");\n")
    case:
        UNREACHABLE(__LOC__)
    }
}

emit_funcsig_typedef := proc(f: File, name: Str, fdef: Expr) {
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        ret := func_return_ctype(fd)
        f.write("typedef "); f.write(ret); f.write(" (*"); f.write(name); f.write(")(")
        emit_param_list(f, fdef, false)
        f.write(");\n")
    case:
        UNREACHABLE(__LOC__)
    }
}

emit_funcsig_typedefs := proc(f: File, core_program: Expr, program: Expr) {
    for prog_idx in 0..2 {
        ref mut prog : Expr = NULL
        if prog_idx.eq(0) { prog = core_program } else { prog = program }
        if is_null(prog) { continue }
        for stmt : Expr in prog.children {
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            if stmt.children.len().eq(0) { continue }
            ref dd : Declaration = get_payload(stmt.node_type)
            ref rhs : Expr = stmt.child(0)
            if rhs.node_type.is(NodeType.FuncDef) {
                if rhs.children.len().eq(0) {
                    emit_funcsig_typedef(f, dd.name, rhs)
                }
            } else if rhs.node_type.is(NodeType.Ident) {
                if stmt.til_type.is(TilType.None) {
                    ref rhs_name : Str = get_payload(rhs.node_type)
                    if is_funcsig_type(rhs_name) {
                        f.write("typedef "); f.write(rhs_name); f.write(" "); f.write(dd.name); f.write(";\n")
                    }
                }
            }
        }
    }
    f.write("\n")
}

emit_funcsig_typedefs_lp := proc(f: File) {
    ref lp : LoadedProgram = codegen_lp()
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            for i in 0..iu.ast.children.len() {
                ref stmt : Expr = iu.ast.child(i)
                if stmt.node_type.is(NodeType.Decl).not() { continue }
                if stmt.children.len().eq(0) { continue }
                ref dd : Declaration = get_payload(stmt.node_type)
                ref rhs : Expr = stmt.child(0)
                if rhs.node_type.is(NodeType.FuncDef) {
                    if rhs.children.len().eq(0) {
                        emit_funcsig_typedef(f, dd.name, rhs)
                    }
                } else if rhs.node_type.is(NodeType.Ident) {
                    if stmt.til_type.is(TilType.None) {
                        ref rhs_name : Str = get_payload(rhs.node_type)
                        if is_funcsig_type(rhs_name) {
                            f.write("typedef "); f.write(rhs_name); f.write(" "); f.write(dd.name); f.write(";\n")
                        }
                    }
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        for i in 0..iu.ast.children.len() {
            ref stmt : Expr = iu.ast.child(i)
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            if stmt.children.len().eq(0) { continue }
            ref dd : Declaration = get_payload(stmt.node_type)
            ref rhs : Expr = stmt.child(0)
            if rhs.node_type.is(NodeType.FuncDef) {
                if rhs.children.len().eq(0) {
                    emit_funcsig_typedef(f, dd.name, rhs)
                }
            } else if rhs.node_type.is(NodeType.Ident) {
                if stmt.til_type.is(TilType.None) {
                    ref rhs_name : Str = get_payload(rhs.node_type)
                    if is_funcsig_type(rhs_name) {
                        f.write("typedef "); f.write(rhs_name); f.write(" "); f.write(dd.name); f.write(";\n")
                    }
                }
            }
        }
    }
    f.write("\n")
}

emit_header_forward_decls := proc(f: File, core_program: Expr, program: Expr) {
    for prog_idx in 0..2 {
        ref mut prog : Expr = NULL
        if prog_idx.eq(0) { prog = core_program } else { prog = program }
        if is_null(prog) { continue }
        for stmt : Expr in prog.children {
            if stmt.node_type.is(NodeType.Decl) {
                ref dd : Declaration = get_payload(stmt.node_type)
                if stmt.children.len().eq(0) { continue }
                ref rhs : Expr = stmt.child(0)
                if rhs.node_type.is(NodeType.StructDef) {
                    if is_ext_h_type(dd.name) { continue }
                    ref fwd_sdd : StructDef = get_payload(rhs.node_type)
                    if fwd_sdd.c_tag.eq("@anon") {
                        // anonymous ext_struct: no forward decl possible
                    } else if fwd_sdd.c_tag.len().gt(0) {
                        f.write("typedef struct "); f.write(fwd_sdd.c_tag); f.write(" "); f.write(dd.name); f.write(";\n")
                    } else {
                        f.write("typedef struct "); f.write(dd.name); f.write(" "); f.write(dd.name); f.write(";\n")
                    }
                }
                if rhs.node_type.is(NodeType.EnumDef) {
                    ref fwd_edd : EnumDef = get_payload(rhs.node_type)
                    f.write("typedef enum {\n")
                    for j in 0..fwd_edd.variants.len() {
                        ref fwd_vn : Str = fwd_edd.variants.get(j)
                        if j.gt(0) { f.write(",\n") }
                        f.write("    "); f.write(dd.name); f.write("_TAG_"); f.write(fwd_vn)
                    }
                    f.write("\n} "); f.write(dd.name); f.write("_tag;\n")
                    f.write("typedef struct "); f.write(dd.name); f.write(" "); f.write(dd.name); f.write(";\n")
                }
            }
        }
    }
    f.write("\n")
}

emit_header_forward_decls_lp := proc(f: File) {
    ref lp : LoadedProgram = codegen_lp()
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            for i in 0..iu.ast.children.len() {
                ref stmt : Expr = iu.ast.child(i)
                if stmt.node_type.is(NodeType.Decl) {
                    ref dd : Declaration = get_payload(stmt.node_type)
                    if stmt.children.len().eq(0) { continue }
                    ref rhs : Expr = stmt.child(0)
                    if rhs.node_type.is(NodeType.StructDef) {
                        if is_ext_h_type(dd.name) { continue }
                        ref fwd_sdd : StructDef = get_payload(rhs.node_type)
                        if fwd_sdd.c_tag.eq("@anon") {
                            // anonymous ext_struct: no forward decl possible
                        } else if fwd_sdd.c_tag.len().gt(0) {
                            f.write("typedef struct "); f.write(fwd_sdd.c_tag); f.write(" "); f.write(dd.name); f.write(";\n")
                        } else {
                            f.write("typedef struct "); f.write(dd.name); f.write(" "); f.write(dd.name); f.write(";\n")
                        }
                    }
                    if rhs.node_type.is(NodeType.EnumDef) {
                        ref fwd_edd : EnumDef = get_payload(rhs.node_type)
                        f.write("typedef enum {\n")
                        for j in 0..fwd_edd.variants.len() {
                            ref fwd_vn : Str = fwd_edd.variants.get(j)
                            if j.gt(0) { f.write(",\n") }
                            f.write("    "); f.write(dd.name); f.write("_TAG_"); f.write(fwd_vn)
                        }
                        f.write("\n} "); f.write(dd.name); f.write("_tag;\n")
                        f.write("typedef struct "); f.write(dd.name); f.write(" "); f.write(dd.name); f.write(";\n")
                    }
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        for i in 0..iu.ast.children.len() {
            ref stmt : Expr = iu.ast.child(i)
            if stmt.node_type.is(NodeType.Decl) {
                ref dd : Declaration = get_payload(stmt.node_type)
                if stmt.children.len().eq(0) { continue }
                ref rhs : Expr = stmt.child(0)
                if rhs.node_type.is(NodeType.StructDef) {
                    if is_ext_h_type(dd.name) { continue }
                    ref fwd_sdd : StructDef = get_payload(rhs.node_type)
                    if fwd_sdd.c_tag.eq("@anon") {
                        // anonymous ext_struct: no forward decl possible
                    } else if fwd_sdd.c_tag.len().gt(0) {
                        f.write("typedef struct "); f.write(fwd_sdd.c_tag); f.write(" "); f.write(dd.name); f.write(";\n")
                    } else {
                        f.write("typedef struct "); f.write(dd.name); f.write(" "); f.write(dd.name); f.write(";\n")
                    }
                }
                if rhs.node_type.is(NodeType.EnumDef) {
                    ref fwd_edd : EnumDef = get_payload(rhs.node_type)
                    f.write("typedef enum {\n")
                    for j in 0..fwd_edd.variants.len() {
                        ref fwd_vn : Str = fwd_edd.variants.get(j)
                        if j.gt(0) { f.write(",\n") }
                        f.write("    "); f.write(dd.name); f.write("_TAG_"); f.write(fwd_vn)
                    }
                    f.write("\n} "); f.write(dd.name); f.write("_tag;\n")
                    f.write("typedef struct "); f.write(dd.name); f.write(" "); f.write(dd.name); f.write(";\n")
                }
            }
        }
    }
    f.write("\n")
}

emit_header_defs_and_funcs := proc(f: File, core_program: Expr, program: Expr) {
    mut emitted_h := Set.new("Str", Str.size())
    emitted_h.add(own "U8".clone()); emitted_h.add(own "I16".clone()); emitted_h.add(own "I32".clone())
    emitted_h.add(own "U32".clone()); emitted_h.add(own "U64".clone()); emitted_h.add(own "I64".clone())
    emitted_h.add(own "F32".clone()); emitted_h.add(own "Bool".clone())
    if is_null(core_program).not() { topo_emit_struct_enum_defs(f, core_program, emitted_h) }
    topo_emit_struct_enum_defs(f, program, emitted_h)
    own emitted_h.delete()

    // Function forward declarations
    for prog_idx in 0..2 {
        ref mut prog : Expr = NULL
        if prog_idx.eq(0) { prog = core_program } else { prog = program }
        if is_null(prog) { continue }
        is_core_pass := prog_idx.eq(0).and(is_null(core_program).not())
        for stmt : Expr in prog.children {
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            ref dd : Declaration = get_payload(stmt.node_type)
            if stmt.children.len().eq(0) { continue }
            ref rhs : Expr = stmt.child(0)
            if rhs.node_type.is(NodeType.StructDef).or(rhs.node_type.is(NodeType.EnumDef)) {
                // Forward-declare from ns_decls (user-defined)
                ref fwd_ns : Vec = def_ns_decls(rhs)
                for fdd : Declaration in fwd_ns {
                    if is_null(fdd.default_value) { continue }
                    switch fdd.default_value.node_type {
                    case NodeType.FuncDef(fd):
                        if is_core_pass.and(fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc))) { continue }
                        full_name := dd.name.concat("_").concat(fdd.name)
                        emit_func_forward_decl(f, full_name, fdd.default_value)
                    case:
                    }
                }
            } else {
                switch rhs.node_type {
                case NodeType.FuncDef(fd):
                    if rhs.children.len().eq(0) { continue }
                    if is_core_pass.and(fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc))) { continue }
                    fc := func_to_c(dd.name)
                    emit_func_forward_decl(f, fc, rhs)
                case:
                }
            }
        }
    }

    // Enum auto-helper forward declarations
    for stmt : Expr in program.children {
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        ref dd : Declaration = get_payload(stmt.node_type)
        if stmt.children.len().eq(0) { continue }
        if stmt.child(0).node_type.is(NodeType.EnumDef).not() { continue }
        // Find eq fdef from ns_decls
        mut eq_fdef := Expr.new(NodeType.Body, stmt.line, stmt.col)
        mut has_eq_fdef := false
        ref eq_ns : Vec = def_ns_decls(stmt.child(0))
        for nsd : Declaration in eq_ns {
            if nsd.name.eq("eq").and(is_null(nsd.default_value).not()) {
                if nsd.default_value.node_type.is(NodeType.FuncDef) {
                    eq_fdef = nsd.default_value.clone()
                    has_eq_fdef = true
                    break
                }
            }
        }
        mut eq_ret := "Bool *"
        if has_eq_fdef {
            ref eqfd : FunctionDef = get_payload(eq_fdef.node_type)
            if eqfd.return_own_type.is(OwnType.Shallow) { eq_ret = "Bool" }
        }
        f.write(eq_ret); f.write(" "); f.write(dd.name); f.write("_eq("); f.write(dd.name); f.write(" *, "); f.write(dd.name); f.write(" *);\n")
        ref hdr_edd : EnumDef = get_payload(stmt.child(0).node_type)
        mut hdr_vi : USize = 0
        for hdr_vn : Str in hdr_edd.variants {
            hdr_vt := enum_variant_type(stmt.child(0), hdr_vi.to_i64().to_i32())
            if hdr_vt.len().gt(0) {
                tnc := type_name_to_c(hdr_vt)
                f.write(dd.name); f.write(" *"); f.write(dd.name); f.write("_"); f.write(hdr_vn); f.write("("); f.write(tnc); f.write(");\n")
            } else {
                f.write(dd.name); f.write(" *"); f.write(dd.name); f.write("_"); f.write(hdr_vn); f.write("();\n")
            }
            hdr_vi = hdr_vi.add(1)
        }
    }
    f.write("\n")
}

emit_header_defs_and_funcs_lp := proc(f: File) {
    mut emitted_h := Set.new("Str", Str.size())
    emitted_h.add(own "U8".clone()); emitted_h.add(own "I16".clone()); emitted_h.add(own "I32".clone())
    emitted_h.add(own "U32".clone()); emitted_h.add(own "U64".clone()); emitted_h.add(own "I64".clone())
    emitted_h.add(own "F32".clone()); emitted_h.add(own "Bool".clone())
    topo_emit_struct_enum_defs_lp(f, emitted_h)
    own emitted_h.delete()

    ref lp : LoadedProgram = codegen_lp()

    // Function forward declarations
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            for i in 0..iu.ast.children.len() {
                ref stmt : Expr = iu.ast.child(i)
                if stmt.node_type.is(NodeType.Decl).not() { continue }
                ref dd : Declaration = get_payload(stmt.node_type)
                if stmt.children.len().eq(0) { continue }
                ref rhs : Expr = stmt.child(0)
                if rhs.node_type.is(NodeType.StructDef).or(rhs.node_type.is(NodeType.EnumDef)) {
                    ref fwd_ns : Vec = def_ns_decls(rhs)
                    for fdd : Declaration in fwd_ns {
                        if is_null(fdd.default_value) { continue }
                        if fdd.default_value.node_type.is(NodeType.FuncDef).not() { continue }
                        ref fd : FunctionDef = get_payload(fdd.default_value.node_type)
                        if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)) { continue }
                        full_name := dd.name.concat("_").concat(fdd.name)
                        emit_func_forward_decl(f, full_name, fdd.default_value)
                    }
                } else if rhs.node_type.is(NodeType.FuncDef) {
                    if rhs.children.len().eq(0) { continue }
                    ref fd : FunctionDef = get_payload(rhs.node_type)
                    if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)) { continue }
                    fc := func_to_c(dd.name)
                    emit_func_forward_decl(f, fc, rhs)
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        for i in 0..iu.ast.children.len() {
            ref stmt : Expr = iu.ast.child(i)
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            ref dd : Declaration = get_payload(stmt.node_type)
            if stmt.children.len().eq(0) { continue }
            ref rhs : Expr = stmt.child(0)
            if rhs.node_type.is(NodeType.StructDef).or(rhs.node_type.is(NodeType.EnumDef)) {
                ref fwd_ns : Vec = def_ns_decls(rhs)
                for fdd : Declaration in fwd_ns {
                    if is_null(fdd.default_value) { continue }
                    if fdd.default_value.node_type.is(NodeType.FuncDef).not() { continue }
                    full_name := dd.name.concat("_").concat(fdd.name)
                    emit_func_forward_decl(f, full_name, fdd.default_value)
                }
            } else if rhs.node_type.is(NodeType.FuncDef) {
                if rhs.children.len().eq(0) { continue }
                fc := func_to_c(dd.name)
                emit_func_forward_decl(f, fc, rhs)
            }
        }
    }

    // Enum auto-helper forward declarations (user units only)
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        for i in 0..iu.ast.children.len() {
            ref stmt : Expr = iu.ast.child(i)
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            ref dd : Declaration = get_payload(stmt.node_type)
            if stmt.children.len().eq(0) { continue }
            if stmt.child(0).node_type.is(NodeType.EnumDef).not() { continue }
            // Find eq fdef from ns_decls
            mut eq_fdef := Expr.new(NodeType.Body, stmt.line, stmt.col)
            mut has_eq_fdef := false
            ref eq_ns : Vec = def_ns_decls(stmt.child(0))
            for nsd : Declaration in eq_ns {
                if nsd.name.eq("eq").and(is_null(nsd.default_value).not()) {
                    if nsd.default_value.node_type.is(NodeType.FuncDef) {
                        eq_fdef = nsd.default_value.clone()
                        has_eq_fdef = true
                        break
                    }
                }
            }
            mut eq_ret := "Bool *"
            if has_eq_fdef {
                ref eqfd : FunctionDef = get_payload(eq_fdef.node_type)
                if eqfd.return_own_type.is(OwnType.Shallow) { eq_ret = "Bool" }
            }
            f.write(eq_ret); f.write(" "); f.write(dd.name); f.write("_eq("); f.write(dd.name); f.write(" *, "); f.write(dd.name); f.write(" *);\n")
            ref hdr_edd : EnumDef = get_payload(stmt.child(0).node_type)
            mut hdr_vi : USize = 0
            for hdr_vn : Str in hdr_edd.variants {
                hdr_vt := enum_variant_type(stmt.child(0), hdr_vi.to_i64().to_i32())
                if hdr_vt.len().gt(0) {
                    tnc := type_name_to_c(hdr_vt)
                    f.write(dd.name); f.write(" *"); f.write(dd.name); f.write("_"); f.write(hdr_vn); f.write("("); f.write(tnc); f.write(");\n")
                } else {
                    f.write(dd.name); f.write(" *"); f.write(dd.name); f.write("_"); f.write(hdr_vn); f.write("();\n")
                }
                hdr_vi = hdr_vi.add(1)
            }
        }
    }
    f.write("\n")
}

emit_header_global_decls := proc(f: File, core_program: Expr, program: Expr) {
    for prog_idx in 0..2 {
        ref mut prog : Expr = NULL
        if prog_idx.eq(0) { prog = core_program } else { prog = program }
        if is_null(prog) { continue }
        for stmt : Expr in prog.children {
            if is_exported_top_level_global(stmt).not() { continue }
            ref rhs : Expr = stmt.child(0)
            ref dd : Declaration = get_payload(stmt.node_type)
            ctype := extern_decl_ctype(stmt.til_type, rhs.til_type)
            if dd.own_type.is(OwnType.Ref) {
                f.write("extern "); f.write(ctype); f.write(" *"); f.write(dd.name); f.write(";\n")
            } else {
                f.write("extern "); f.write(ctype); f.write(" "); f.write(dd.name); f.write(";\n")
            }
        }
    }
    f.write("\n")
}

emit_header_global_decls_lp := proc(f: File) {
    ref lp : LoadedProgram = codegen_lp()
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            for i in 0..iu.ast.children.len() {
                ref stmt : Expr = iu.ast.child(i)
                if is_exported_top_level_global(stmt).not() { continue }
                ref rhs : Expr = stmt.child(0)
                ref dd : Declaration = get_payload(stmt.node_type)
                ctype := extern_decl_ctype(stmt.til_type, rhs.til_type)
                if dd.own_type.is(OwnType.Ref) {
                    f.write("extern "); f.write(ctype); f.write(" *"); f.write(dd.name); f.write(";\n")
                } else {
                    f.write("extern "); f.write(ctype); f.write(" "); f.write(dd.name); f.write(";\n")
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        for i in 0..iu.ast.children.len() {
            ref stmt : Expr = iu.ast.child(i)
            if is_exported_top_level_global(stmt).not() { continue }
            ref rhs : Expr = stmt.child(0)
            ref dd : Declaration = get_payload(stmt.node_type)
            ctype := extern_decl_ctype(stmt.til_type, rhs.til_type)
            if dd.own_type.is(OwnType.Ref) {
                f.write("extern "); f.write(ctype); f.write(" *"); f.write(dd.name); f.write(";\n")
            } else {
                f.write("extern "); f.write(ctype); f.write(" "); f.write(dd.name); f.write(";\n")
            }
        }
    }
    f.write("\n")
}

build_forward_header := proc(core_program: Expr, program: Expr, fwd_path: Str) returns shallow I32 {
    build_register_funcsig_names(core_program, program)
    f := File.new(fwd_path, true)
    f.write("#pragma once\n#include \"ext.h\"\n\n")
    emit_header_forward_decls(f, core_program, program)
    emit_funcsig_typedefs(f, core_program, program)
    emit_header_defs_and_funcs(f, core_program, program)
    emit_header_global_decls(f, core_program, program)
    f.close()
    return 0.to_i32()
}

build_forward_header_lp := proc(fwd_path: Str) returns shallow I32 {
    build_register_funcsig_names_lp()
    f := File.new(fwd_path, true)
    f.write("#pragma once\n#include \"ext.h\"\n\n")
    emit_header_forward_decls_lp(f)
    emit_funcsig_typedefs_lp(f)
    emit_header_defs_and_funcs_lp(f)
    emit_header_global_decls_lp(f)
    f.close()
    return 0.to_i32()
}

build_header := proc(core_program: Expr, program: Expr, h_path: Str) returns shallow I32 {
    build_register_funcsig_names(core_program, program)
    f := File.new(h_path, true)
    f.write("#pragma once\n#include \"ext.h\"\n\n")
    emit_header_forward_decls(f, core_program, program)
    emit_funcsig_typedefs(f, core_program, program)
    emit_header_defs_and_funcs(f, core_program, program)
    emit_header_global_decls(f, core_program, program)
    f.write("#include \"ext.h\"\n\n")
    f.close()
    return 0.to_i32()
}

build_header_lp := proc(h_path: Str) returns shallow I32 {
    build_register_funcsig_names_lp()
    f := File.new(h_path, true)
    f.write("#pragma once\n#include \"ext.h\"\n\n")
    emit_header_forward_decls_lp(f)
    emit_funcsig_typedefs_lp(f)
    emit_header_defs_and_funcs_lp(f)
    emit_header_global_decls_lp(f)
    f.write("#include \"ext.h\"\n\n")
    f.close()
    return 0.to_i32()
}

emit_binding_ns_method := proc(f: File, fdd_name: Str, fd: FunctionDef, mut has_ns: Bool) returns shallow Bool {
    if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)) { return has_ns }
    if has_ns.not() { f.write("    namespace:\n"); has_ns = true }
    mut kw := "ext_func"
    if fd.func_type.is(FuncType.Proc).or(fd.func_type.is(FuncType.Test)) { kw = "ext_proc" }
    f.write("    "); f.write(fdd_name); f.write(" := "); f.write(kw); f.write("(")
    for p in 0..fd.params.len() {
        if p.gt(0) { f.write(", ") }
        ref param : Declaration = fd.params.get(p)
        if param.own_type.is(OwnType.Own) { f.write("own ") }
        f.write(param.name); f.write(": "); f.write(param.explicit_type)
    }
    f.write(")")
    if fd.return_type.len().gt(0) {
        f.write(" returns ")
        if fd.return_own_type.is(OwnType.Ref) { f.write("ref ") }
        if fd.return_own_type.is(OwnType.Shallow) { f.write("shallow ") }
        f.write(fd.return_type)
    }
    f.write(" {}\n")
    return has_ns
}

emit_binding_ns_methods := proc(f: File, def: Expr) {
    mut has_ns := false
    ref ebn_ns : Vec = def_ns_decls(def)
    for nsd : Declaration in ebn_ns {
        if is_null(nsd.default_value) { continue }
        if nsd.default_value.node_type.is(NodeType.FuncDef).not() { continue }
        ref fd : FunctionDef = get_payload(nsd.default_value.node_type)
        has_ns = emit_binding_ns_method(f, nsd.name, fd, has_ns)
    }
}

build_til_binding := proc(program: Expr, til_path: Str, lib_name: Str) returns shallow I32 {
    // program is kept for signature compatibility; emit from lp units.
    if is_null(program) { }
    ref lp : LoadedProgram = codegen_lp()
    f := File.new(til_path, true)
    f.write("// Auto-generated FFI binding for "); f.write(lib_name); f.write("\n")
    f.write("link(\""); f.write(lib_name); f.write("\")\n\n")
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        for stmt : Expr in iu.ast.children {
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            ref dd : Declaration = get_payload(stmt.node_type)
            if stmt.children.len().eq(0) { continue }
            ref rhs : Expr = stmt.child(0)
            switch rhs.node_type {
            case NodeType.StructDef(btb_sdd):
                f.write(dd.name); f.write(" := struct {\n")
                for fdd : Declaration in btb_sdd.fields {
                    f.write("    ")
                    if fdd.is_mut { f.write("mut ") }
                    if fdd.own_type.is(OwnType.Own) { f.write("own ") }
                    f.write(fdd.name)
                    if fdd.explicit_type.len().gt(0) { f.write(" : "); f.write(fdd.explicit_type) }
                    f.write(" := ")
                    if is_null(fdd.default_value).not() { emit_til_default(f, fdd.til_type) }
                    else { f.write("0") }
                    f.write("\n")
                }
                emit_binding_ns_methods(f, rhs)
                f.write("}\n\n")
            case NodeType.EnumDef(bind_edd):
                f.write(dd.name); f.write(" := enum {\n")
                mut bind_vi : USize = 0
                for bind_vn : Str in bind_edd.variants {
                    bind_vt := enum_variant_type(rhs, bind_vi.to_i64().to_i32())
                    f.write("    "); f.write(bind_vn)
                    if bind_vt.len().gt(0) { f.write(": "); f.write(bind_vt) }
                    f.write(",\n")
                    bind_vi = bind_vi.add(1)
                }
                emit_binding_ns_methods(f, rhs)
                f.write("}\n\n")
            case NodeType.FuncDef(fd):
                if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)) { continue }
                if fd.func_type.is(FuncType.Test) { continue }
                mut kw := "ext_func"
                if fd.func_type.is(FuncType.Proc) { kw = "ext_proc" }
                f.write(dd.name); f.write(" := "); f.write(kw); f.write("(")
                for p in 0..fd.params.len() {
                    if p.gt(0) { f.write(", ") }
                    ref param : Declaration = fd.params.get(p)
                    if param.own_type.is(OwnType.Own) { f.write("own ") }
                    pi := p.to_i64().to_i32()
                    if pi.eq(fd.variadic_index) { f.write("..") }
                    if pi.eq(fd.kwargs_index) {
                        f.write(param.name); f.write(": ...")
                    } else {
                        f.write(param.name); f.write(": "); f.write(param.explicit_type)
                    }
                }
                f.write(")")
                if fd.return_type.len().gt(0) {
                    f.write(" returns ")
                    if fd.return_own_type.is(OwnType.Ref) { f.write("ref ") }
                    if fd.return_own_type.is(OwnType.Shallow) { f.write("shallow ") }
                    f.write(fd.return_type)
                }
                f.write(" {}\n\n")
            case:
            }
        }
    }
    f.close()
    return 0.to_i32()
}

type_name_to_ctypes := func(name: Str) returns Str {
    if name.eq("I64") { return "ctypes.c_longlong" }
    if name.eq("U8") { return "ctypes.c_ubyte" }
    if name.eq("I16") { return "ctypes.c_short" }
    if name.eq("I32") { return "ctypes.c_int" }
    if name.eq("U32") { return "ctypes.c_uint" }
    if name.eq("U64") { return "ctypes.c_ulonglong" }
    if name.eq("F32") { return "ctypes.c_float" }
    if name.eq("Bool") { return "ctypes.c_bool" }
    if name.eq("Str") { return "Str" }
    if name.eq("Dynamic") { return "ctypes.c_void_p" }
    return name.clone()
}

type_name_to_ctypes_param := func(name: Str, shallow is_shallow: Bool) returns Str {
    base := type_name_to_ctypes(name)
    if is_shallow { return base }
    return "ctypes.POINTER(".concat(base).concat(")")
}

type_name_to_ctypes_return := func(name: Str, shallow is_shallow: Bool) returns Str {
    base := type_name_to_ctypes(name)
    if is_shallow { return base }
    return "ctypes.POINTER(".concat(base).concat(")")
}

build_python_binding := proc(program: Expr, py_path: Str, lib_name: Str) returns shallow I32 {
    // program is kept for signature compatibility; emit from lp units.
    if is_null(program) { }
    ref lp : LoadedProgram = codegen_lp()
    f := File.new(py_path, true)
    f.write("# Auto-generated Python binding for "); f.write(lib_name); f.write("\n")
    f.write("import ctypes\n")
    f.write("import os\n\n")
    f.write("_dir = os.path.dirname(os.path.abspath(__file__))\n")
    f.write("_lib = ctypes.CDLL(os.path.join(_dir, '..', 'lib', 'lib")
    f.write(lib_name); f.write(".so'))\n\n")

    f.write("\nclass Str(ctypes.Structure):\n")
    f.write("    _fields_ = [\n")
    f.write("        ('c_str', ctypes.POINTER(ctypes.c_ubyte)),\n")
    f.write("        ('count', ctypes.c_uint),\n")
    f.write("        ('cap', ctypes.c_uint),\n")
    f.write("    ]\n\n")
    f.write("\nclass Array(ctypes.Structure):\n")
    f.write("    _fields_ = [\n")
    f.write("        ('data', ctypes.POINTER(ctypes.c_ubyte)),\n")
    f.write("        ('cap', ctypes.c_uint),\n")
    f.write("        ('elem_size', ctypes.c_uint),\n")
    f.write("        ('elem_type', Str),\n")
    f.write("        ('elem_clone', ctypes.c_void_p),\n")
    f.write("        ('elem_delete', ctypes.c_void_p),\n")
    f.write("    ]\n\n")

    // Forward-declare all struct/enum classes
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        for stmt : Expr in iu.ast.children {
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            ref dd : Declaration = get_payload(stmt.node_type)
            if stmt.children.len().eq(0) { continue }
            ref rhs : Expr = stmt.child(0)
            if rhs.node_type.is(NodeType.StructDef) {
                f.write("\nclass "); f.write(dd.name); f.write("(ctypes.Structure):\n")
                f.write("    pass\n")
            } else if rhs.node_type.is(NodeType.EnumDef) {
                f.write("\nclass "); f.write(dd.name); f.write("(ctypes.Structure):\n")
                f.write("    pass\n")
            }
        }
    }
    f.write("\n")

    // Emit struct field definitions and enum definitions
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        for stmt : Expr in iu.ast.children {
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            ref dd : Declaration = get_payload(stmt.node_type)
            if stmt.children.len().eq(0) { continue }
            ref rhs : Expr = stmt.child(0)

            switch rhs.node_type {
            case NodeType.StructDef(bpb_sdd):
                f.write("\n"); f.write(dd.name); f.write("._fields_ = [\n")
                for fdd : Declaration in bpb_sdd.fields {
                    mut ct := ""
                    if fdd.explicit_type.len().gt(0) {
                        ct = type_name_to_ctypes_param(fdd.explicit_type, false)
                    } else {
                        switch fdd.til_type {
                        case TilType.I64:  ct = "ctypes.POINTER(ctypes.c_longlong)"
                        case TilType.U8:   ct = "ctypes.POINTER(ctypes.c_ubyte)"
                        case TilType.I16:  ct = "ctypes.POINTER(ctypes.c_short)"
                        case TilType.I32:  ct = "ctypes.POINTER(ctypes.c_int)"
                        case TilType.U32:  ct = "ctypes.POINTER(ctypes.c_uint)"
                        case TilType.U64:  ct = "ctypes.POINTER(ctypes.c_ulonglong)"
                        case TilType.F32:  ct = "ctypes.POINTER(ctypes.c_float)"
                        case TilType.Bool: ct = "ctypes.POINTER(ctypes.c_bool)"
                        case:              ct = "ctypes.c_void_p"
                        }
                    }
                    f.write("    ('"); f.write(fdd.name); f.write("', ")
                    f.write(ct); f.write("),\n")
                }
                f.write("]\n")

            case NodeType.EnumDef(ct_edd):
                hp := enum_has_payloads(rhs)

                // Emit tag constants
                mut tag := 0
                for ct_vn : Str in ct_edd.variants {
                    f.write(dd.name); f.write("_TAG_"); f.write(ct_vn)
                    f.write(" = "); f.write(tag.to_str()); f.write("\n")
                    tag = tag.add(1)
                }

                // Emit union if has payloads
                if hp {
                    f.write("\nclass "); f.write(dd.name); f.write("_data(ctypes.Union):\n")
                    f.write("    _fields_ = [\n")
                    mut ct_vi : USize = 0
                    for ct_uvn : Str in ct_edd.variants {
                        ct_vt := enum_variant_type(rhs, ct_vi.to_i64().to_i32())
                        if ct_vt.len().gt(0) {
                            f.write("        ('"); f.write(ct_uvn); f.write("', ")
                            f.write(type_name_to_ctypes_param(ct_vt, false))
                            f.write("),\n")
                        }
                        ct_vi = ct_vi.add(1)
                    }
                    f.write("    ]\n")
                }

                // Emit enum struct _fields_
                f.write("\n"); f.write(dd.name); f.write("._fields_ = [\n")
                f.write("    ('tag', ctypes.c_int),\n")
                if hp {
                    f.write("    ('data', "); f.write(dd.name); f.write("_data),\n")
                }
                f.write("]\n")
            case:
            }
        }
    }
    f.write("\n")

    // Emit function bindings
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        for stmt : Expr in iu.ast.children {
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            ref dd : Declaration = get_payload(stmt.node_type)
            if stmt.children.len().eq(0) { continue }
            ref rhs : Expr = stmt.child(0)

            if rhs.node_type.is(NodeType.StructDef).or(rhs.node_type.is(NodeType.EnumDef)) {
                // Emit namespace method bindings from ns_decls
                ref pyb_ns : Vec = def_ns_decls(rhs)
                for nsd : Declaration in pyb_ns {
                    if is_null(nsd.default_value) { continue }
                    if nsd.default_value.node_type.is(NodeType.FuncDef).not() { continue }
                    ref fd : FunctionDef = get_payload(nsd.default_value.node_type)
                    if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)) { continue }
                    f.write("_lib."); f.write(dd.name); f.write("_"); f.write(nsd.name)
                    f.write(".argtypes = [")
                    for p in 0..fd.params.len() {
                        if p.gt(0) { f.write(", ") }
                        ref param : Declaration = fd.params.get(p)
                        ps := param.own_type.is(OwnType.Shallow)
                        f.write(type_name_to_ctypes_param(param.explicit_type, ps))
                    }
                    f.write("]\n")
                    if fd.return_type.len().gt(0) {
                        rs := fd.return_own_type.is(OwnType.Shallow)
                        f.write("_lib."); f.write(dd.name); f.write("_"); f.write(nsd.name)
                        f.write(".restype = ")
                        f.write(type_name_to_ctypes_return(fd.return_type, rs)); f.write("\n")
                    } else {
                        f.write("_lib."); f.write(dd.name); f.write("_"); f.write(nsd.name)
                        f.write(".restype = None\n")
                    }
                    f.write("\n")
                }

            } else {
                switch rhs.node_type {
                case NodeType.FuncDef(fd):
                    if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)) { continue }
                    if fd.func_type.is(FuncType.Test) { continue }

                    c_name := func_to_c(dd.name)

                    // argtypes
                    f.write("_lib."); f.write(c_name); f.write(".argtypes = [")
                    for p in 0..fd.params.len() {
                        if p.gt(0) { f.write(", ") }
                        ref param : Declaration = fd.params.get(p)
                        pi := p.to_i64().to_i32()
                        if pi.eq(fd.variadic_index) {
                            f.write("ctypes.POINTER(Array)")
                        } else {
                            ps := param.own_type.is(OwnType.Shallow)
                            f.write(type_name_to_ctypes_param(param.explicit_type, ps))
                        }
                    }
                    f.write("]\n")

                    // restype
                    if fd.return_type.len().gt(0) {
                        rs := fd.return_own_type.is(OwnType.Shallow)
                        f.write("_lib."); f.write(c_name); f.write(".restype = ")
                        f.write(type_name_to_ctypes_return(fd.return_type, rs)); f.write("\n")
                    } else {
                        f.write("_lib."); f.write(c_name); f.write(".restype = None\n")
                    }
                    f.write("\n")
                case:
                }
            }
        }
    }

    // Emit enum auto-helper bindings (eq, constructors, is_Variant, get_Variant)
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        for stmt : Expr in iu.ast.children {
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            ref dd : Declaration = get_payload(stmt.node_type)
            if stmt.children.len().eq(0) { continue }
            ref rhs : Expr = stmt.child(0)
            if rhs.node_type.is(NodeType.EnumDef).not() { continue }
            sname := dd.name
            hp := enum_has_payloads(rhs)

            // Find eq fdef to check return shallow
            mut eq_shallow := false
            ref py_eq_ns : Vec = def_ns_decls(rhs)
            mut py_eq_found := false
            for nsd : Declaration in py_eq_ns {
                if nsd.name.eq("eq").and(is_null(nsd.default_value).not()) {
                    if nsd.default_value.node_type.is(NodeType.FuncDef) {
                        ref eqfd : FunctionDef = get_payload(nsd.default_value.node_type)
                        eq_shallow = eqfd.return_own_type.is(OwnType.Shallow)
                        py_eq_found = true
                    }
                    break
                }
            }
            mut eq_ret := "ctypes.POINTER(ctypes.c_bool)"
            if eq_shallow { eq_ret = "ctypes.c_bool" }

            // eq
            f.write("_lib."); f.write(sname); f.write("_eq.argtypes = [ctypes.POINTER(")
            f.write(sname); f.write("), ctypes.POINTER("); f.write(sname); f.write(")]\n")
            f.write("_lib."); f.write(sname); f.write("_eq.restype = ")
            f.write(eq_ret); f.write("\n\n")

            // Per-variant helpers
            ref py_edd : EnumDef = get_payload(rhs.node_type)
            mut py_vi : USize = 0
            for py_vn : Str in py_edd.variants {
                py_vt := enum_variant_type(rhs, py_vi.to_i64().to_i32())

                if hp {
                    // is_Variant
                    f.write("_lib."); f.write(sname); f.write("_is_"); f.write(py_vn)
                    f.write(".argtypes = [ctypes.POINTER("); f.write(sname); f.write(")]\n")
                    f.write("_lib."); f.write(sname); f.write("_is_"); f.write(py_vn)
                    f.write(".restype = "); f.write(eq_ret); f.write("\n\n")
                }

                if py_vt.len().gt(0) {
                    // Constructor: takes payload, returns POINTER(Enum)
                    f.write("_lib."); f.write(sname); f.write("_"); f.write(py_vn)
                    f.write(".argtypes = [")
                    f.write(type_name_to_ctypes_param(py_vt, false)); f.write("]\n")
                    f.write("_lib."); f.write(sname); f.write("_"); f.write(py_vn)
                    f.write(".restype = ctypes.POINTER("); f.write(sname); f.write(")\n\n")
                    // get_Variant
                    f.write("_lib."); f.write(sname); f.write("_get_"); f.write(py_vn)
                    f.write(".argtypes = [ctypes.POINTER("); f.write(sname); f.write(")]\n")
                    f.write("_lib."); f.write(sname); f.write("_get_"); f.write(py_vn)
                    f.write(".restype = ")
                    f.write(type_name_to_ctypes_param(py_vt, false)); f.write("\n\n")
                } else {
                    // Constructor: no args, returns POINTER(Enum)
                    f.write("_lib."); f.write(sname); f.write("_"); f.write(py_vn)
                    f.write(".argtypes = []\n")
                    f.write("_lib."); f.write(sname); f.write("_"); f.write(py_vn)
                    f.write(".restype = ctypes.POINTER("); f.write(sname); f.write(")\n\n")
                }
                py_vi = py_vi.add(1)
            }
        }
    }

    f.close()
    return 0.to_i32()
}

compile_lib := proc(c_path: Str, lib_name: Str, ext_c_path: Str, user_c_path: Str, link_flags: Str, include_flags: Str, target: Target, cc_override: Str) returns shallow I32 {
    mut uc := user_c_path
    mut lf := link_flags
    mut ifl := include_flags
    if uc.len().eq(0) { uc = "" }
    if lf.len().eq(0) { lf = "" }
    if ifl.len().eq(0) { ifl = "" }

    mut compiler := cc_override
    if compiler.len().eq(0) { compiler = toolchain_command(target, Lang.C) }
    extra := toolchain_extra_args(target, compiler)

    // Extract directory from ext_c_path for -I flag
    mut ext_dir := "."
    slash := ext_c_path.rfind("/")
    if slash.gte(0) { ext_dir = ext_c_path.substr(0, slash.to_usize()).clone() }

    // Compile library .c to object
    obj_path := "gen/lib/".concat(lib_name).concat(".o")
    mut cmd := compiler.concat(extra).concat(" -Werror -fPIC -I").concat(ext_dir)
    .concat(" -c ").concat(c_path).concat(" -o ").concat(obj_path)
    mut result := system_cmd(cmd)
    if result.neq(0) {
        println("error: library compilation failed")
        return 1.to_i32()
    }

    // Compile ext.c to object
    ext_obj := "gen/lib/ext.o"
    cmd = compiler.concat(extra).concat(" -Werror -fPIC -I").concat(ext_dir)
    .concat(" -c ").concat(ext_c_path).concat(" -o ").concat(ext_obj)
    result = system_cmd(cmd)
    if result.neq(0) {
        println("error: ext.c compilation failed")
        return 1.to_i32()
    }

    // Compile user .c to object if present
    mut user_obj := ""
    if uc.len().gt(0) {
        user_obj = "gen/lib/user.o"
        cmd = compiler.concat(extra).concat(" -Werror -fPIC -I").concat(ext_dir).concat(ifl)
        .concat(" -c ").concat(uc).concat(" -o ").concat(user_obj)
        result = system_cmd(cmd)
        if result.neq(0) {
            println("error: user .c compilation failed")
            return 1.to_i32()
        }
    }

    // Create shared library
    so_path := "gen/lib/lib".concat(lib_name).concat(".so")
    cmd = compiler.concat(" -shared -o ").concat(so_path)
    .concat(" ").concat(obj_path).concat(" ").concat(ext_obj)
    .concat(" ").concat(user_obj).concat(lf)
    result = system_cmd(cmd)
    if result.neq(0) {
        println("error: shared library creation failed")
        return 1.to_i32()
    }

    // Create static library
    a_path := "gen/lib/lib".concat(lib_name).concat(".a")
    cmd = "ar rcs ".concat(a_path)
    .concat(" ").concat(obj_path).concat(" ").concat(ext_obj)
    .concat(" ").concat(user_obj)
    result = system_cmd(cmd)
    if result.neq(0) {
        println("error: static library creation failed")
        return 1.to_i32()
    }

    return 0.to_i32()
}

compile_c := proc(c_path: Str, bin_path: Str, ext_c_path: Str, user_c_path: Str, link_flags: Str, include_flags: Str, target: Target, cc_override: Str) returns shallow I32 {
    mut uc := user_c_path
    mut lf := link_flags
    mut ifl := include_flags
    if uc.len().eq(0) { uc = "" }
    if lf.len().eq(0) { lf = "" }
    if ifl.len().eq(0) { ifl = "" }

    mut compiler := cc_override
    if compiler.len().eq(0) { compiler = toolchain_command(target, Lang.C) }
    extra := toolchain_extra_args(target, compiler)

    // Extract directory from ext_c_path for -I flag
    mut ext_dir := "."
    slash := ext_c_path.rfind("/")
    if slash.gte(0) { ext_dir = ext_c_path.substr(0, slash.to_usize()).clone() }

    // If link_c files present, compile each to .o separately with -include forward.h
    mut user_part := ""
    if uc.len().gt(0) {
        c_slash := c_path.rfind("/")
        mut c_dir := "."
        if c_slash.gte(0) { c_dir = c_path.substr(0, c_slash.to_usize()).clone() }
        c_dot := c_path.rfind(".")
        mut c_base := c_path
        if c_dot.gt(c_slash) { c_base = c_path.substr(0, c_dot.to_usize()) }
        fwd_path := c_base.concat("_forward.h")

        // Split space-separated link_c files and compile each individually
        files := uc.split(" ")
        mut all_objs := ""
        for fi in 0..files.len() {
            ref file : Str = files.get(fi)
            if file.len().eq(0) { continue }
            user_obj := c_dir.concat("/user_").concat(fi.to_i64().to_str()).concat(".o")

            // Skip -include forward.h for src/c/ files
            mut fwd_flag := " -include ".concat(fwd_path)
            if file.starts_with("src/c/") { fwd_flag = " -Isrc/c -Iboot" }
            obj_cmd := compiler.concat(extra).concat(" -Werror -I").concat(ext_dir)
            .concat(fwd_flag).concat(ifl).concat(" -c ").concat(file)
            .concat(" -o ").concat(user_obj)

            obj_result := system_cmd(obj_cmd)
            if obj_result.neq(0) {
                println("error: link_c compilation failed for ".concat(file))
                return 1.to_i32()
            }
            all_objs = all_objs.concat(" ").concat(user_obj)
        }
        user_part = all_objs
    }

    // -rdynamic is a Linux/ELF gcc driver flag for exporting symbols to dlsym.
    // mingw silently ignores it but clangs error out, so only add for non-Windows.
    mut dyn_flag := " -rdynamic"
    if target.is(Target.WindowsX64) { dyn_flag = "" }
    // Windows FFI / peak_rss helpers in ext.c call GetProcessMemoryInfo and
    // EnumProcessModules from psapi.
    mut plat_libs := ""
    if target.is(Target.WindowsX64) { plat_libs = " -lpsapi" }

    cmd := compiler.concat(extra).concat(" -Werror -g").concat(dyn_flag).concat(" -I").concat(ext_dir)
    .concat(" -o ").concat(bin_path).concat(" ").concat(c_path)
    .concat(" ").concat(ext_c_path).concat(user_part).concat(lf).concat(plat_libs)

    result := system_cmd(cmd)
    if result.neq(0) {
        println("error: C compilation failed")
        return 1.to_i32()
    }
    return 0.to_i32()
}

register_funcsig_prog := func(prog: Expr) {
    for stmt : Expr in prog.children {
        if stmt.node_type.is(NodeType.Decl) {
            ref rhs : Expr = stmt.child(0)
            if rhs.node_type.is(NodeType.FuncDef) {
                if rhs.children.len().eq(0) {
                    ref dd : Declaration = get_payload(stmt.node_type)
                    funcsig_names.add(own dd.name.clone())
                }
            }
            if stmt.til_type.is(TilType.None) {
                if rhs.node_type.is(NodeType.Ident) {
                    ref rhs_name : Str = get_payload(rhs.node_type)
                    if funcsig_names.has(rhs_name) {
                        ref dd : Declaration = get_payload(stmt.node_type)
                        funcsig_names.add(own dd.name.clone())
                    }
                }
            }
        }
    }
}

emit_global_inits_prog := proc(f: File, prog: Expr) {
    for gs : Expr in prog.children {
        if gs.node_type.is(NodeType.Decl) {
            ref rhs : Expr = gs.child(0)
            if rhs.node_type.is(NodeType.FuncDef).or(rhs.node_type.is(NodeType.StructDef))
            .or(rhs.node_type.is(NodeType.EnumDef)) { continue }
            if gs.til_type.is(TilType.None) {
                if rhs.node_type.is(NodeType.Ident) { continue }
            }
        } else {
            if gs.node_type.is(NodeType.FCall).not() { continue }
        }
        emit_stmt(f, gs, 1)
    }
}

emit_global_inits := proc(f: File) {
    if has_script_globals.not() { return }
    ref lp : LoadedProgram = codegen_lp()
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            emit_global_inits_prog(f, iu.ast)
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        emit_global_inits_prog(f, iu.ast)
    }
}

build_register_funcsig_names := func(core_program: Expr, program: Expr) {
    funcsig_names = Set.new("Str", Str.size())
    has_funcsig_names = true
    for prog_idx in 0..2 {
        ref mut prog : Expr = NULL
        if prog_idx.eq(0) { prog = core_program } else { prog = program }
        if is_null(prog) { continue }
        for stmt : Expr in prog.children {
            if stmt.node_type.is(NodeType.Decl) {
                ref rhs : Expr = stmt.child(0)
                if rhs.node_type.is(NodeType.FuncDef) {
                    if rhs.children.len().eq(0) {
                        ref dd : Declaration = get_payload(stmt.node_type)
                        funcsig_names.add(own dd.name.clone())
                    }
                }
                if stmt.til_type.is(TilType.None) {
                    if rhs.node_type.is(NodeType.Ident) {
                        ref rhs_name : Str = get_payload(rhs.node_type)
                        if funcsig_names.has(rhs_name) {
                            ref dd : Declaration = get_payload(stmt.node_type)
                            funcsig_names.add(own dd.name.clone())
                        }
                    }
                }
            }
        }
    }
}

build_register_funcsig_names_lp := func() {
    funcsig_names = Set.new("Str", Str.size())
    has_funcsig_names = true
    ref lp : LoadedProgram = codegen_lp()
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            register_funcsig_prog(iu.ast)
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        register_funcsig_prog(iu.ast)
    }
}

register_lookups_prog := func(prog: Expr) {
    for stmt : Expr in prog.children {
        if stmt.node_type.is(NodeType.Decl) {
            ref rhs : Expr = stmt.child(0)
            if rhs.node_type.is(NodeType.StructDef).or(rhs.node_type.is(NodeType.EnumDef)) {
                ref dd : Declaration = get_payload(stmt.node_type)
                _sdv : Dynamic = malloc(I64.size())
                write_ptr(_sdv, rhs)
                struct_def_exprs.set(own dd.name.clone(), own _sdv)
                // Register ns_decls methods into func_defs
                ref rl_ns : Vec = def_ns_decls(rhs)
                for d_j : Declaration in rl_ns {
                    ref nsd : Declaration = d_j
                    if is_null(nsd.default_value) { continue }
                    if nsd.default_value.node_type.is(NodeType.FuncDef).not() { continue }
                    key := dd.name.concat("_").concat(nsd.name)
                    if func_defs.has(key) { continue }
                    fv : Dynamic = malloc(I64.size())
                    write_ptr(fv, nsd.default_value)
                    func_defs.set(own key, own fv)
                    if nsd.default_value.children.len().gt(0) {
                        ref fbody : Expr = nsd.default_value.child(0)
                        for nested : Expr in fbody.children {
                            if is_func_decl(nested).not() { continue }
                            ref nfdef : Expr = nested.child(0)
                            ref nd : Declaration = get_payload(nested.node_type)
                            nv : Dynamic = malloc(I64.size())
                            write_ptr(nv, nfdef)
                            func_defs.set(own nd.name.clone(), own nv)
                        }
                    }
                }
            }
            if rhs.node_type.is(NodeType.FuncDef) {
                ref dd2 : Declaration = get_payload(stmt.node_type)
                fv2 : Dynamic = malloc(I64.size())
                write_ptr(fv2, rhs)
                func_defs.set(own dd2.name.clone(), own fv2)
            }
        }
    }
}

// #135: can't use for prog_idx in 0..2 with ref mut prog here because
// the clone bug makes stored pointers point to cloned nodes
build_register_lookups := func(core_program: Expr, program: Expr) {
    struct_def_exprs = Map.new("Str", Str.size(), "Dynamic", I64.size())
    func_defs = Map.new("Str", Str.size(), "Dynamic", I64.size())
    stack_locals = Set.new("Str", Str.size())
    stack_local_types = Map.new("Str", Str.size(), "Str", Str.size())
    unsafe_to_hoist = Set.new("Str", Str.size())
    ref_locals = Set.new("Str", Str.size())
    if is_null(core_program).not() { register_lookups_prog(core_program) }
    register_lookups_prog(program)
}

build_register_lookups_lp := func() {
    struct_def_exprs = Map.new("Str", Str.size(), "Dynamic", I64.size())
    func_defs = Map.new("Str", Str.size(), "Dynamic", I64.size())
    stack_locals = Set.new("Str", Str.size())
    stack_local_types = Map.new("Str", Str.size(), "Str", Str.size())
    unsafe_to_hoist = Set.new("Str", Str.size())
    ref_locals = Set.new("Str", Str.size())

    ref lp : LoadedProgram = codegen_lp()
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            register_lookups_prog(iu.ast)
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        register_lookups_prog(iu.ast)
    }
}

emit_monolithic_header := proc(f: File, core_program: Expr, program: Expr, mode: Mode) {
    f.write("#include \"ext.h\"\n\n")
    emit_header_forward_decls(f, core_program, program)
    emit_funcsig_typedefs(f, core_program, program)

    // Topo-sort struct/enum defs
    mut emitted_mh := Set.new("Str", Str.size())
    emitted_mh.add(own "U8".clone()); emitted_mh.add(own "I16".clone()); emitted_mh.add(own "I32".clone())
    emitted_mh.add(own "U32".clone()); emitted_mh.add(own "U64".clone()); emitted_mh.add(own "I64".clone())
    emitted_mh.add(own "F32".clone()); emitted_mh.add(own "Bool".clone())
    if is_null(core_program).not() { topo_emit_struct_enum_defs(f, core_program, emitted_mh) }
    topo_emit_struct_enum_defs(f, program, emitted_mh)
    own emitted_mh.delete()

    // Emit function declarations
    for prog_idx in 0..2 {
        ref mut prog : Expr = NULL
        if prog_idx.eq(0) { prog = core_program } else { prog = program }
        if is_null(prog) { continue }
        for stmt : Expr in prog.children {
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            ref dd : Declaration = get_payload(stmt.node_type)
            if stmt.children.len().eq(0) { continue }
            ref rhs : Expr = stmt.child(0)
            if rhs.node_type.is(NodeType.StructDef).or(rhs.node_type.is(NodeType.EnumDef)) {
                ref fwd_ns2 : Vec = def_ns_decls(rhs)
                for j in 0..fwd_ns2.len() {
                    ref fdd : Declaration = fwd_ns2.get(j)
                    if is_null(fdd.default_value) { continue }
                    if fdd.default_value.node_type.is(NodeType.FuncDef).not() { continue }
                    ref fd : FunctionDef = get_payload(fdd.default_value.node_type)
                    if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)) { continue }
                    full_name := dd.name.concat("_").concat(fdd.name)
                    emit_func_forward_decl(f, full_name, fdd.default_value)
                }
            } else if rhs.node_type.is(NodeType.FuncDef) {
                if rhs.children.len().eq(0) { continue }
                ref fd : FunctionDef = get_payload(rhs.node_type)
                if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)) { continue }
                if is_null(mode).not() {
                    if mode.needs_main {
                        if dd.name.eq("main") { continue }
                    }
                }
                fc := func_to_c(dd.name)
                emit_func_forward_decl(f, fc, rhs)
            }
        }
    }
    // Enum auto-helper declarations (user program only)
    for stmt : Expr in program.children {
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        ref dd : Declaration = get_payload(stmt.node_type)
        if stmt.children.len().eq(0) { continue }
        if stmt.child(0).node_type.is(NodeType.EnumDef).not() { continue }
        mut eq_fdef := Expr.new(NodeType.Body, stmt.line, stmt.col)
        mut has_eq_fdef := false
        ref sh3_eq_ns : Vec = def_ns_decls(stmt.child(0))
        for d_j : Declaration in sh3_eq_ns {
            ref nsd : Declaration = d_j
            if nsd.name.eq("eq").and(is_null(nsd.default_value).not()) {
                if nsd.default_value.node_type.is(NodeType.FuncDef) {
                    eq_fdef = nsd.default_value.clone()
                    has_eq_fdef = true
                    break
                }
            }
        }
        mut eq_ret := "Bool *"
        if has_eq_fdef {
            ref eqfd : FunctionDef = get_payload(eq_fdef.node_type)
            if eqfd.return_own_type.is(OwnType.Shallow) { eq_ret = "Bool" }
        }
        f.write(eq_ret); f.write(" "); f.write(dd.name); f.write("_eq("); f.write(dd.name); f.write(" *, "); f.write(dd.name); f.write(" *);\n")
        ref hdr_edd : EnumDef = get_payload(stmt.child(0).node_type)
        mut hdr_vi : USize = 0
        for hdr_vn : Str in hdr_edd.variants {
            hdr_vt := enum_variant_type(stmt.child(0), hdr_vi.to_i64().to_i32())
            if hdr_vt.len().gt(0) {
                tnc := type_name_to_c(hdr_vt)
                f.write(dd.name); f.write(" *"); f.write(dd.name); f.write("_"); f.write(hdr_vn); f.write("("); f.write(tnc); f.write(");\n")
            } else {
                f.write(dd.name); f.write(" *"); f.write(dd.name); f.write("_"); f.write(hdr_vn); f.write("();\n")
            }
            hdr_vi = hdr_vi.add(1)
        }
    }
}

emit_monolithic_header_lp := proc(f: File, mode: Mode) {
    f.write("#include \"ext.h\"\n\n")
    emit_header_forward_decls_lp(f)
    emit_funcsig_typedefs_lp(f)

    // Topo-sort struct/enum defs across all units
    mut emitted_mh := Set.new("Str", Str.size())
    emitted_mh.add(own "U8".clone()); emitted_mh.add(own "I16".clone()); emitted_mh.add(own "I32".clone())
    emitted_mh.add(own "U32".clone()); emitted_mh.add(own "U64".clone()); emitted_mh.add(own "I64".clone())
    emitted_mh.add(own "F32".clone()); emitted_mh.add(own "Bool".clone())
    topo_emit_struct_enum_defs_lp(f, emitted_mh)
    own emitted_mh.delete()

    ref lp : LoadedProgram = codegen_lp()

    // Emit function declarations
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            for i in 0..iu.ast.children.len() {
                ref stmt : Expr = iu.ast.child(i)
                if stmt.node_type.is(NodeType.Decl).not() { continue }
                ref dd : Declaration = get_payload(stmt.node_type)
                if stmt.children.len().eq(0) { continue }
                ref rhs : Expr = stmt.child(0)
                if rhs.node_type.is(NodeType.StructDef).or(rhs.node_type.is(NodeType.EnumDef)) {
                    ref fwd_ns2 : Vec = def_ns_decls(rhs)
                    for fdd : Declaration in fwd_ns2 {
                        if is_null(fdd.default_value) { continue }
                        if fdd.default_value.node_type.is(NodeType.FuncDef).not() { continue }
                        ref fd : FunctionDef = get_payload(fdd.default_value.node_type)
                        if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)) { continue }
                        full_name := dd.name.concat("_").concat(fdd.name)
                        emit_func_forward_decl(f, full_name, fdd.default_value)
                    }
                } else if rhs.node_type.is(NodeType.FuncDef) {
                    if rhs.children.len().eq(0) { continue }
                    ref fd : FunctionDef = get_payload(rhs.node_type)
                    if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)) { continue }
                    if is_null(mode).not() {
                        if mode.needs_main {
                            if dd.name.eq("main") { continue }
                        }
                    }
                    fc := func_to_c(dd.name)
                    emit_func_forward_decl(f, fc, rhs)
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        for i in 0..iu.ast.children.len() {
            ref stmt : Expr = iu.ast.child(i)
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            ref dd : Declaration = get_payload(stmt.node_type)
            if stmt.children.len().eq(0) { continue }
            ref rhs : Expr = stmt.child(0)
            if rhs.node_type.is(NodeType.StructDef).or(rhs.node_type.is(NodeType.EnumDef)) {
                ref fwd_ns2 : Vec = def_ns_decls(rhs)
                for fdd : Declaration in fwd_ns2 {
                    if is_null(fdd.default_value) { continue }
                    if fdd.default_value.node_type.is(NodeType.FuncDef).not() { continue }
                    ref fd : FunctionDef = get_payload(fdd.default_value.node_type)
                    if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)) { continue }
                    full_name := dd.name.concat("_").concat(fdd.name)
                    emit_func_forward_decl(f, full_name, fdd.default_value)
                }
            } else if rhs.node_type.is(NodeType.FuncDef) {
                if rhs.children.len().eq(0) { continue }
                ref fd : FunctionDef = get_payload(rhs.node_type)
                if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)) { continue }
                if is_null(mode).not() {
                    if mode.needs_main {
                        if dd.name.eq("main") { continue }
                    }
                }
                fc := func_to_c(dd.name)
                emit_func_forward_decl(f, fc, rhs)
            }
        }
    }

    // Enum auto-helper declarations (user units only)
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        for i in 0..iu.ast.children.len() {
            ref stmt : Expr = iu.ast.child(i)
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            ref dd : Declaration = get_payload(stmt.node_type)
            if stmt.children.len().eq(0) { continue }
            if stmt.child(0).node_type.is(NodeType.EnumDef).not() { continue }
            mut eq_fdef := Expr.new(NodeType.Body, stmt.line, stmt.col)
            mut has_eq_fdef := false
            ref sh3_eq_ns : Vec = def_ns_decls(stmt.child(0))
            for nsd : Declaration in sh3_eq_ns {
                if nsd.name.eq("eq").and(is_null(nsd.default_value).not()) {
                    if nsd.default_value.node_type.is(NodeType.FuncDef) {
                        eq_fdef = nsd.default_value.clone()
                        has_eq_fdef = true
                        break
                    }
                }
            }
            mut eq_ret := "Bool *"
            if has_eq_fdef {
                ref eqfd : FunctionDef = get_payload(eq_fdef.node_type)
                if eqfd.return_own_type.is(OwnType.Shallow) { eq_ret = "Bool" }
            }
            f.write(eq_ret); f.write(" "); f.write(dd.name); f.write("_eq("); f.write(dd.name); f.write(" *, "); f.write(dd.name); f.write(" *);\n")
            ref hdr_edd : EnumDef = get_payload(stmt.child(0).node_type)
            mut hdr_vi : USize = 0
            for hdr_vn : Str in hdr_edd.variants {
                hdr_vt := enum_variant_type(stmt.child(0), hdr_vi.to_i64().to_i32())
                if hdr_vt.len().gt(0) {
                    tnc := type_name_to_c(hdr_vt)
                    f.write(dd.name); f.write(" *"); f.write(dd.name); f.write("_"); f.write(hdr_vn); f.write("("); f.write(tnc); f.write(");\n")
                } else {
                    f.write(dd.name); f.write(" *"); f.write(dd.name); f.write("_"); f.write(hdr_vn); f.write("();\n")
                }
                hdr_vi = hdr_vi.add(1)
            }
        }
    }
}

emit_all_forward_declarations := proc(f: File, mode: Mode) {
    ref lp : LoadedProgram = codegen_lp()
    // Forward-declare struct/enum namespace methods and top-level functions
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            for i in 0..iu.ast.children.len() {
                ref stmt : Expr = iu.ast.child(i)
                if stmt.node_type.is(NodeType.Decl).not() { continue }
                ref dd : Declaration = get_payload(stmt.node_type)
                if stmt.children.len().eq(0) { continue }
                ref rhs : Expr = stmt.child(0)
                if rhs.node_type.is(NodeType.StructDef).or(rhs.node_type.is(NodeType.EnumDef)) {
                    ref afd_ns : Vec = def_ns_decls(rhs)
                    for fdd : Declaration in afd_ns {
                        if is_null(fdd.default_value) { continue }
                        if fdd.default_value.node_type.is(NodeType.FuncDef).not() { continue }
                        ref fd : FunctionDef = get_payload(fdd.default_value.node_type)
                        if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)) { continue }
                        full_name := dd.name.concat("_").concat(fdd.name)
                        emit_func_forward_decl(f, full_name, fdd.default_value)
                    }
                } else if rhs.node_type.is(NodeType.FuncDef) {
                    if rhs.children.len().eq(0) { continue }
                    ref fd : FunctionDef = get_payload(rhs.node_type)
                    if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)) { continue }
                    if is_null(mode).not() {
                        if mode.needs_main {
                            if dd.name.eq("main") { continue }
                        }
                    }
                    fc := func_to_c(dd.name)
                    emit_func_forward_decl(f, fc, rhs)
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        for i in 0..iu.ast.children.len() {
            ref stmt : Expr = iu.ast.child(i)
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            ref dd : Declaration = get_payload(stmt.node_type)
            if stmt.children.len().eq(0) { continue }
            ref rhs : Expr = stmt.child(0)
            if rhs.node_type.is(NodeType.StructDef).or(rhs.node_type.is(NodeType.EnumDef)) {
                ref afd_ns : Vec = def_ns_decls(rhs)
                for fdd : Declaration in afd_ns {
                    if is_null(fdd.default_value) { continue }
                    if fdd.default_value.node_type.is(NodeType.FuncDef).not() { continue }
                    full_name := dd.name.concat("_").concat(fdd.name)
                    emit_func_forward_decl(f, full_name, fdd.default_value)
                }
            } else if rhs.node_type.is(NodeType.FuncDef) {
                if rhs.children.len().eq(0) { continue }
                ref fd : FunctionDef = get_payload(rhs.node_type)
                if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)) { continue }
                if is_null(mode).not() {
                    if mode.needs_main {
                        if dd.name.eq("main") { continue }
                    }
                }
                fc := func_to_c(dd.name)
                emit_func_forward_decl(f, fc, rhs)
            }
        }
    }

    // Forward-declare enum ext methods (eq, constructors)
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            for i in 0..iu.ast.children.len() {
                ref stmt : Expr = iu.ast.child(i)
                if stmt.node_type.is(NodeType.Decl).not() { continue }
                if stmt.children.len().eq(0) { continue }
                if stmt.child(0).node_type.is(NodeType.EnumDef).not() { continue }
                ref dd : Declaration = get_payload(stmt.node_type)
                mut eq_fdef := Expr.new(NodeType.Body, stmt.line, stmt.col)
                mut has_eq_fdef := false
                ref sh_eq_ns : Vec = def_ns_decls(stmt.child(0))
                for nsd : Declaration in sh_eq_ns {
                    if nsd.name.eq("eq").and(is_null(nsd.default_value).not()) {
                        if nsd.default_value.node_type.is(NodeType.FuncDef) {
                            eq_fdef = nsd.default_value.clone()
                            has_eq_fdef = true
                            break
                        }
                    }
                }
                mut eq_ret := "Bool *"
                if has_eq_fdef {
                    ref eqfd : FunctionDef = get_payload(eq_fdef.node_type)
                    if eqfd.return_own_type.is(OwnType.Shallow) { eq_ret = "Bool" }
                }
                f.write(eq_ret); f.write(" "); f.write(dd.name); f.write("_eq("); f.write(dd.name); f.write(" *, "); f.write(dd.name); f.write(" *);\n")
                ref shdr_edd : EnumDef = get_payload(stmt.child(0).node_type)
                mut shdr_vi : USize = 0
                for shdr_vn : Str in shdr_edd.variants {
                    shdr_vt := enum_variant_type(stmt.child(0), shdr_vi.to_i64().to_i32())
                    if shdr_vt.len().gt(0) {
                        tnc := type_name_to_c(shdr_vt)
                        f.write(dd.name); f.write(" *"); f.write(dd.name); f.write("_"); f.write(shdr_vn); f.write("("); f.write(tnc); f.write(");\n")
                    } else {
                        f.write(dd.name); f.write(" *"); f.write(dd.name); f.write("_"); f.write(shdr_vn); f.write("();\n")
                    }
                    shdr_vi = shdr_vi.add(1)
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        for i in 0..iu.ast.children.len() {
            ref stmt : Expr = iu.ast.child(i)
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            if stmt.children.len().eq(0) { continue }
            if stmt.child(0).node_type.is(NodeType.EnumDef).not() { continue }
            ref dd : Declaration = get_payload(stmt.node_type)
            mut eq_fdef := Expr.new(NodeType.Body, stmt.line, stmt.col)
            mut has_eq_fdef := false
            ref sh_eq_ns : Vec = def_ns_decls(stmt.child(0))
            for nsd : Declaration in sh_eq_ns {
                if nsd.name.eq("eq").and(is_null(nsd.default_value).not()) {
                    if nsd.default_value.node_type.is(NodeType.FuncDef) {
                        eq_fdef = nsd.default_value.clone()
                        has_eq_fdef = true
                        break
                    }
                }
            }
            mut eq_ret := "Bool *"
            if has_eq_fdef {
                ref eqfd : FunctionDef = get_payload(eq_fdef.node_type)
                if eqfd.return_own_type.is(OwnType.Shallow) { eq_ret = "Bool" }
            }
            f.write(eq_ret); f.write(" "); f.write(dd.name); f.write("_eq("); f.write(dd.name); f.write(" *, "); f.write(dd.name); f.write(" *);\n")
            ref shdr_edd : EnumDef = get_payload(stmt.child(0).node_type)
            mut shdr_vi : USize = 0
            for shdr_vn : Str in shdr_edd.variants {
                shdr_vt := enum_variant_type(stmt.child(0), shdr_vi.to_i64().to_i32())
                if shdr_vt.len().gt(0) {
                    tnc := type_name_to_c(shdr_vt)
                    f.write(dd.name); f.write(" *"); f.write(dd.name); f.write("_"); f.write(shdr_vn); f.write("("); f.write(tnc); f.write(");\n")
                } else {
                    f.write(dd.name); f.write(" *"); f.write(dd.name); f.write("_"); f.write(shdr_vn); f.write("();\n")
                }
                shdr_vi = shdr_vi.add(1)
            }
        }
    }
    f.write("\n")

    // Forward declarations for dyn_call dispatch functions
    mut dyn_methods := Vec.new("DynCallInfo", DynCallInfo.size())
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            collect_dyn_methods(iu.ast, dyn_methods)
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        collect_dyn_methods(iu.ast, dyn_methods)
    }
    for info : DynCallInfo in dyn_methods {
        if info.has_return {
            if info.nargs.eq(1) {
                f.write("void *dyn_call_"); f.write(info.method); f.write("(Str *type_name, void *val);\n")
            } else {
                f.write("void *dyn_call_"); f.write(info.method); f.write("(Str *type_name, void *val, void *arg2);\n")
            }
        } else {
            if info.nargs.eq(1) {
                f.write("void dyn_call_"); f.write(info.method); f.write("(Str *type_name, void *val);\n")
            } else {
                f.write("void dyn_call_"); f.write(info.method); f.write("(Str *type_name, void *val, void *arg2);\n")
            }
        }
    }
    f.write("void *dyn_fn(Str *type_name, Str *method);\n")
    f.write("\n")
    own dyn_methods.delete()

    // Forward declarations for dyn_has_method dispatch functions
    mut dyn_has_shallow := false
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            if dyn_has_shallow { break }
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            for stmt : Expr in iu.ast.children {
                if is_func_decl(stmt).not() { continue }
                ref sdd : Declaration = get_payload(stmt.node_type)
                if sdd.name.eq("dyn_has_method") {
                    ref fd : FunctionDef = get_payload(stmt.child(0).node_type)
                    dyn_has_shallow = fd.return_own_type.is(OwnType.Shallow)
                    break
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        if dyn_has_shallow { break }
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        for stmt : Expr in iu.ast.children {
            if is_func_decl(stmt).not() { continue }
            ref sdd : Declaration = get_payload(stmt.node_type)
            if sdd.name.eq("dyn_has_method") {
                ref fd : FunctionDef = get_payload(stmt.child(0).node_type)
                dyn_has_shallow = fd.return_own_type.is(OwnType.Shallow)
                break
            }
        }
    }
    mut dyn_has_ret := "Bool *"
    if dyn_has_shallow { dyn_has_ret = "Bool" }
    mut has_methods := Vec.new("Str", Str.size())
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            collect_dyn_has_methods(iu.ast, has_methods)
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        collect_dyn_has_methods(iu.ast, has_methods)
    }
    for method : Str in has_methods {
        f.write(dyn_has_ret); f.write(" dyn_has_"); f.write(method); f.write("(Str *type_name);\n")
    }
    if has_methods.len().gt(0) { f.write("\n") }
    own has_methods.delete()

    // Forward declarations for array/vec builtin helpers
    mut coll_infos := Vec.new("CollectionInfo", CollectionInfo.size())
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            collect_collection_builtins(iu.ast, coll_infos)
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        collect_collection_builtins(iu.ast, coll_infos)
    }
    for ci : CollectionInfo in coll_infos {
        mut prefix := "array"
        mut ret := "Array"
        if ci.is_vec.neq(0) { prefix = "vec"; ret = "Vec" }
        f.write(ret); f.write(" *"); f.write(prefix); f.write("_of_"); f.write(ci.type_name); f.write("(int count, ...);\n")
    }
    if coll_infos.len().gt(0) { f.write("\n") }
    own coll_infos.delete()
}

emit_dyn_fn_wrapper := proc(f: File, type_name: Str, method_name: Str, fd: FunctionDef) {
    np := fd.params.len()
    ret_shallow := fd.return_own_type.is(OwnType.Shallow)
    has_return := fd.return_type.len().gt(0)
    mut any_shallow := ret_shallow
    for p in 0..np {
        ref pp : Declaration = fd.params.get(p)
        if pp.own_type.is(OwnType.Shallow) { any_shallow = true }
    }
    if any_shallow.not() { return }
    if has_return {
        f.write("void *"); f.write(type_name); f.write("_"); f.write(method_name); f.write("_dyn(")
    } else {
        f.write("void "); f.write(type_name); f.write("_"); f.write(method_name); f.write("_dyn(")
    }
    for p in 0..np {
        if p.gt(0) { f.write(", ") }
        f.write("void *_a"); emit_i32(f, p.to_i64().to_i32())
    }
    if np.eq(0) { f.write("void") }
    f.write(") {\n")
    if has_return {
        if ret_shallow {
            rc := type_name_to_c_value(fd.return_type)
            f.write("    "); f.write(rc); f.write(" *_r = malloc(sizeof("); f.write(rc); f.write(")); *_r = "); f.write(type_name); f.write("_"); f.write(method_name); f.write("(")
        } else {
            f.write("    return (void *)"); f.write(type_name); f.write("_"); f.write(method_name); f.write("(")
        }
    } else {
        f.write("    "); f.write(type_name); f.write("_"); f.write(method_name); f.write("(")
    }
    for p in 0..np {
        if p.gt(0) { f.write(", ") }
        ref pp : Declaration = fd.params.get(p)
        if pp.own_type.is(OwnType.Shallow) {
            pc := type_name_to_c_value(pp.explicit_type)
            f.write("*("); f.write(pc); f.write(" *)_a"); emit_i32(f, p.to_i64().to_i32())
        } else {
            f.write("_a"); emit_i32(f, p.to_i64().to_i32())
        }
    }
    f.write(");")
    if has_return {
        if ret_shallow { f.write(" return _r;") }
    }
    f.write("\n}\n")
}

emit_dyn_fn_wrappers := proc(f: File) {
    ref lp : LoadedProgram = codegen_lp()
    // Emit wrapper functions that normalize calling convention
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            for stmt : Expr in iu.ast.children {
                if is_struct_or_enum(stmt).not() { continue }
                ref def : Expr = stmt.child(0)
                ref dd : Declaration = get_payload(stmt.node_type)
                ref dfw_ns : Vec = def_ns_decls(def)
                for d_j : Declaration in dfw_ns {
                    ref nsd : Declaration = d_j
                    if is_null(nsd.default_value) { continue }
                    if nsd.default_value.node_type.is(NodeType.FuncDef).not() { continue }
                    ref fd : FunctionDef = get_payload(nsd.default_value.node_type)
                    emit_dyn_fn_wrapper(f, dd.name, nsd.name, fd)
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        for stmt : Expr in iu.ast.children {
            if is_struct_or_enum(stmt).not() { continue }
            ref def : Expr = stmt.child(0)
            ref dd : Declaration = get_payload(stmt.node_type)
            ref dfw_ns : Vec = def_ns_decls(def)
            for d_j : Declaration in dfw_ns {
                ref nsd : Declaration = d_j
                if is_null(nsd.default_value) { continue }
                if nsd.default_value.node_type.is(NodeType.FuncDef).not() { continue }
                ref fd : FunctionDef = get_payload(nsd.default_value.node_type)
                emit_dyn_fn_wrapper(f, dd.name, nsd.name, fd)
            }
        }
    }
    // Emit dyn_fn dispatch
    f.write("void *dyn_fn(Str *type_name, Str *method) {\n    (void)type_name; (void)method;\n")
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            for stmt : Expr in iu.ast.children {
                if is_struct_or_enum(stmt).not() { continue }
                ref def : Expr = stmt.child(0)
                ref dd : Declaration = get_payload(stmt.node_type)
                ref dfn_ns : Vec = def_ns_decls(def)
                for d_j : Declaration in dfn_ns {
                    ref nsd : Declaration = d_j
                    if is_null(nsd.default_value) { continue }
                    if nsd.default_value.node_type.is(NodeType.FuncDef).not() { continue }
                    ref fd : FunctionDef = get_payload(nsd.default_value.node_type)
                    mut any_shallow := fd.return_own_type.is(OwnType.Shallow)
                    for pp : Declaration in fd.params {
                        if pp.own_type.is(OwnType.Shallow) { any_shallow = true }
                    }
                    mut suffix := ""
                    if any_shallow { suffix = "_dyn" }
                    tlen := dd.name.len().to_i64().to_u64()
                    mlen := nsd.name.len().to_i64().to_u64()
                    f.write("    if (type_name->count == "); emit_u64(f, tlen); f.write("ULL && memcmp(type_name->c_str, \""); f.write(dd.name); f.write("\", "); emit_u64(f, tlen); f.write("ULL) == 0 && method->count == "); emit_u64(f, mlen); f.write("ULL && memcmp(method->c_str, \""); f.write(nsd.name); f.write("\", "); emit_u64(f, mlen); f.write("ULL) == 0) return (void*)"); f.write(dd.name); f.write("_"); f.write(nsd.name); f.write(suffix); f.write(";\n")
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        for stmt : Expr in iu.ast.children {
            if is_struct_or_enum(stmt).not() { continue }
            ref def : Expr = stmt.child(0)
            ref dd : Declaration = get_payload(stmt.node_type)
            ref dfn_ns : Vec = def_ns_decls(def)
            for d_j : Declaration in dfn_ns {
                ref nsd : Declaration = d_j
                if is_null(nsd.default_value) { continue }
                if nsd.default_value.node_type.is(NodeType.FuncDef).not() { continue }
                ref fd : FunctionDef = get_payload(nsd.default_value.node_type)
                mut any_shallow := fd.return_own_type.is(OwnType.Shallow)
                for pp : Declaration in fd.params {
                    if pp.own_type.is(OwnType.Shallow) { any_shallow = true }
                }
                mut suffix := ""
                if any_shallow { suffix = "_dyn" }
                tlen := dd.name.len().to_i64().to_u64()
                mlen := nsd.name.len().to_i64().to_u64()
                f.write("    if (type_name->count == "); emit_u64(f, tlen); f.write("ULL && memcmp(type_name->c_str, \""); f.write(dd.name); f.write("\", "); emit_u64(f, tlen); f.write("ULL) == 0 && method->count == "); emit_u64(f, mlen); f.write("ULL && memcmp(method->c_str, \""); f.write(nsd.name); f.write("\", "); emit_u64(f, mlen); f.write("ULL) == 0) return (void*)"); f.write(dd.name); f.write("_"); f.write(nsd.name); f.write(suffix); f.write(";\n")
            }
        }
    }
    f.write("    fprintf(stderr, \"dyn_fn: unknown %s.%s\\n\", (char*)type_name->c_str, (char*)method->c_str);\n")
    f.write("    exit(1);\n")
    f.write("}\n\n")
}

emit_dyn_call_bodies := proc(f: File) {
    ref lp : LoadedProgram = codegen_lp()
    mut dyn_methods := Vec.new("DynCallInfo", DynCallInfo.size())
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            collect_dyn_methods(iu.ast, dyn_methods)
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        collect_dyn_methods(iu.ast, dyn_methods)
    }
    for info : DynCallInfo in dyn_methods {
        ref method : Str = info.method
        mut ret_type := "void "
        if info.has_return { ret_type = "void *" }
        if info.nargs.eq(1) {
            f.write(ret_type); f.write("dyn_call_"); f.write(method); f.write("(Str *type_name, void *val) {\n")
        } else {
            f.write(ret_type); f.write("dyn_call_"); f.write(method); f.write("(Str *type_name, void *val, void *arg2) {\n")
        }
        if lp.skip_core.not() {
            for u : ProgramUnit in lp.core_units {
                ref iu : ImportUnit = lp.ctx.imported.get(u.path)
                for e_i : Expr in iu.ast.children {
                    ref stmt : Expr = e_i
                    if is_struct_or_enum(stmt).not() { continue }
                    ref def : Expr = stmt.child(0)
                    ref dd : Declaration = get_payload(stmt.node_type)
                    // Search ns_decls
                    ref mut method_fdef : Expr = NULL
                    ref dcb_ns : Vec = def_ns_decls(def)
                    for nsd : Declaration in dcb_ns {
                        if nsd.name.eq(method) {
                            if is_null(nsd.default_value).not() {
                                if nsd.default_value.node_type.is(NodeType.FuncDef) {
                                    method_fdef = nsd.default_value
                                    break
                                }
                            }
                        }
                    }
                    if is_null(method_fdef) { continue }
                    ref mfd : FunctionDef = get_payload(method_fdef.node_type)
                    mut arg1 := "val"
                    if mfd.params.len().gt(0) {
                        ref p0 : Declaration = mfd.params.get(0)
                        if p0.own_type.is(OwnType.Shallow) { arg1 = "*(".concat(dd.name).concat(" *)val") }
                    }
                    mut arg2_s := "arg2"
                    if info.nargs.eq(2) {
                        if mfd.params.len().gt(1) {
                            if mfd.params.len().gt(1) {
                                ref p1 : Declaration = mfd.params.get(1)
                                if p1.own_type.is(OwnType.Shallow) { arg2_s = "*(".concat(dd.name).concat(" *)arg2") }
                            }
                        }
                    }
                    ret_sh := mfd.return_own_type.is(OwnType.Shallow)
                    mut ret_ct := ""
                    if info.has_return {
                        if ret_sh {
                            if mfd.return_type.len().gt(0) { ret_ct = type_name_to_c_value(mfd.return_type) }
                        }
                    }
                    tlen := dd.name.len().to_i64().to_u64()
                    if info.nargs.eq(2) {
                        if info.has_return {
                            if ret_sh {
                                f.write("    if (type_name->count == "); emit_u64(f, tlen); f.write("ULL && memcmp(type_name->c_str, \""); f.write(dd.name); f.write("\", "); emit_u64(f, tlen); f.write("ULL) == 0) { "); f.write(ret_ct); f.write(" *_r = malloc(sizeof("); f.write(ret_ct); f.write(")); *_r = "); f.write(dd.name); f.write("_"); f.write(method); f.write("("); f.write(arg1); f.write(", "); f.write(arg2_s); f.write("); return _r; }\n")
                            } else {
                                f.write("    if (type_name->count == "); emit_u64(f, tlen); f.write("ULL && memcmp(type_name->c_str, \""); f.write(dd.name); f.write("\", "); emit_u64(f, tlen); f.write("ULL) == 0) return (void *)"); f.write(dd.name); f.write("_"); f.write(method); f.write("("); f.write(arg1); f.write(", "); f.write(arg2_s); f.write(");\n")
                            }
                        } else {
                            f.write("    if (type_name->count == "); emit_u64(f, tlen); f.write("ULL && memcmp(type_name->c_str, \""); f.write(dd.name); f.write("\", "); emit_u64(f, tlen); f.write("ULL) == 0) { "); f.write(dd.name); f.write("_"); f.write(method); f.write("("); f.write(arg1); f.write(", "); f.write(arg2_s); f.write("); return; }\n")
                        }
                    } else {
                        if info.has_return {
                            if ret_sh {
                                f.write("    if (type_name->count == "); emit_u64(f, tlen); f.write("ULL && memcmp(type_name->c_str, \""); f.write(dd.name); f.write("\", "); emit_u64(f, tlen); f.write("ULL) == 0) { "); f.write(ret_ct); f.write(" *_r = malloc(sizeof("); f.write(ret_ct); f.write(")); *_r = "); f.write(dd.name); f.write("_"); f.write(method); f.write("("); f.write(arg1); f.write("); return _r; }\n")
                            } else {
                                f.write("    if (type_name->count == "); emit_u64(f, tlen); f.write("ULL && memcmp(type_name->c_str, \""); f.write(dd.name); f.write("\", "); emit_u64(f, tlen); f.write("ULL) == 0) return (void *)"); f.write(dd.name); f.write("_"); f.write(method); f.write("("); f.write(arg1); f.write(");\n")
                            }
                        } else {
                            f.write("    if (type_name->count == "); emit_u64(f, tlen); f.write("ULL && memcmp(type_name->c_str, \""); f.write(dd.name); f.write("\", "); emit_u64(f, tlen); f.write("ULL) == 0) { "); f.write(dd.name); f.write("_"); f.write(method); f.write("("); f.write(arg1); f.write("); return; }\n")
                        }
                    }
                }
            }
        }
        for u : ProgramUnit in lp.units {
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            for e_i : Expr in iu.ast.children {
                ref stmt : Expr = e_i
                if is_struct_or_enum(stmt).not() { continue }
                ref def : Expr = stmt.child(0)
                ref dd : Declaration = get_payload(stmt.node_type)
                // Search ns_decls
                ref mut method_fdef : Expr = NULL
                ref dcb_ns : Vec = def_ns_decls(def)
                for nsd : Declaration in dcb_ns {
                    if nsd.name.eq(method) {
                        if is_null(nsd.default_value).not() {
                            if nsd.default_value.node_type.is(NodeType.FuncDef) {
                                method_fdef = nsd.default_value
                                break
                            }
                        }
                    }
                }
                if is_null(method_fdef) { continue }
                ref mfd : FunctionDef = get_payload(method_fdef.node_type)
                mut arg1 := "val"
                if mfd.params.len().gt(0) {
                    ref p0 : Declaration = mfd.params.get(0)
                    if p0.own_type.is(OwnType.Shallow) { arg1 = "*(".concat(dd.name).concat(" *)val") }
                }
                mut arg2_s := "arg2"
                if info.nargs.eq(2) {
                    if mfd.params.len().gt(1) {
                        if mfd.params.len().gt(1) {
                            ref p1 : Declaration = mfd.params.get(1)
                            if p1.own_type.is(OwnType.Shallow) { arg2_s = "*(".concat(dd.name).concat(" *)arg2") }
                        }
                    }
                }
                ret_sh := mfd.return_own_type.is(OwnType.Shallow)
                mut ret_ct := ""
                if info.has_return {
                    if ret_sh {
                        if mfd.return_type.len().gt(0) { ret_ct = type_name_to_c_value(mfd.return_type) }
                    }
                }
                tlen := dd.name.len().to_i64().to_u64()
                if info.nargs.eq(2) {
                    if info.has_return {
                        if ret_sh {
                            f.write("    if (type_name->count == "); emit_u64(f, tlen); f.write("ULL && memcmp(type_name->c_str, \""); f.write(dd.name); f.write("\", "); emit_u64(f, tlen); f.write("ULL) == 0) { "); f.write(ret_ct); f.write(" *_r = malloc(sizeof("); f.write(ret_ct); f.write(")); *_r = "); f.write(dd.name); f.write("_"); f.write(method); f.write("("); f.write(arg1); f.write(", "); f.write(arg2_s); f.write("); return _r; }\n")
                        } else {
                            f.write("    if (type_name->count == "); emit_u64(f, tlen); f.write("ULL && memcmp(type_name->c_str, \""); f.write(dd.name); f.write("\", "); emit_u64(f, tlen); f.write("ULL) == 0) return (void *)"); f.write(dd.name); f.write("_"); f.write(method); f.write("("); f.write(arg1); f.write(", "); f.write(arg2_s); f.write(");\n")
                        }
                    } else {
                        f.write("    if (type_name->count == "); emit_u64(f, tlen); f.write("ULL && memcmp(type_name->c_str, \""); f.write(dd.name); f.write("\", "); emit_u64(f, tlen); f.write("ULL) == 0) { "); f.write(dd.name); f.write("_"); f.write(method); f.write("("); f.write(arg1); f.write(", "); f.write(arg2_s); f.write("); return; }\n")
                    }
                } else {
                    if info.has_return {
                        if ret_sh {
                            f.write("    if (type_name->count == "); emit_u64(f, tlen); f.write("ULL && memcmp(type_name->c_str, \""); f.write(dd.name); f.write("\", "); emit_u64(f, tlen); f.write("ULL) == 0) { "); f.write(ret_ct); f.write(" *_r = malloc(sizeof("); f.write(ret_ct); f.write(")); *_r = "); f.write(dd.name); f.write("_"); f.write(method); f.write("("); f.write(arg1); f.write("); return _r; }\n")
                        } else {
                            f.write("    if (type_name->count == "); emit_u64(f, tlen); f.write("ULL && memcmp(type_name->c_str, \""); f.write(dd.name); f.write("\", "); emit_u64(f, tlen); f.write("ULL) == 0) return (void *)"); f.write(dd.name); f.write("_"); f.write(method); f.write("("); f.write(arg1); f.write(");\n")
                        }
                    } else {
                        f.write("    if (type_name->count == "); emit_u64(f, tlen); f.write("ULL && memcmp(type_name->c_str, \""); f.write(dd.name); f.write("\", "); emit_u64(f, tlen); f.write("ULL) == 0) { "); f.write(dd.name); f.write("_"); f.write(method); f.write("("); f.write(arg1); f.write("); return; }\n")
                    }
                }
            }
        }
        f.write("    fprintf(stderr, \"dyn_call: unknown type for "); f.write(method); f.write("\\n\");\n")
        f.write("    exit(1);\n")
        f.write("}\n\n")
    }
    own dyn_methods.delete()
}

emit_dyn_has_bodies := proc(f: File) {
    ref lp : LoadedProgram = codegen_lp()

    // Find dyn_has_method to check return_is_shallow
    mut dyn_has_shallow := false
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            if dyn_has_shallow { break }
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            for stmt : Expr in iu.ast.children {
                if stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0)).and(stmt.child(0).node_type.is(NodeType.FuncDef)) {
                    ref dd : Declaration = get_payload(stmt.node_type)
                    if dd.name.eq("dyn_has_method") {
                        ref fd : FunctionDef = get_payload(stmt.child(0).node_type)
                        dyn_has_shallow = fd.return_own_type.is(OwnType.Shallow)
                        break
                    }
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        if dyn_has_shallow { break }
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        for stmt : Expr in iu.ast.children {
            if stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0)).and(stmt.child(0).node_type.is(NodeType.FuncDef)) {
                ref dd : Declaration = get_payload(stmt.node_type)
                if dd.name.eq("dyn_has_method") {
                    ref fd : FunctionDef = get_payload(stmt.child(0).node_type)
                    dyn_has_shallow = fd.return_own_type.is(OwnType.Shallow)
                    break
                }
            }
        }
    }
    mut dyn_has_ret := "Bool *"
    if dyn_has_shallow { dyn_has_ret = "Bool" }
    mut has_methods := Vec.new("Str", Str.size())
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            collect_dyn_has_methods(iu.ast, has_methods)
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        collect_dyn_has_methods(iu.ast, has_methods)
    }
    for method : Str in has_methods {
        f.write(dyn_has_ret); f.write(" dyn_has_"); f.write(method); f.write("(Str *type_name) {\n    (void)type_name;\n")
        if lp.skip_core.not() {
            for u : ProgramUnit in lp.core_units {
                ref iu : ImportUnit = lp.ctx.imported.get(u.path)
                for e_i : Expr in iu.ast.children {
                    ref stmt : Expr = e_i
                    if is_struct_or_enum(stmt).not() { continue }
                    ref rhs : Expr = stmt.child(0)
                    ref dd : Declaration = get_payload(stmt.node_type)
                    mut found := false
                    ref dhb_ns : Vec = def_ns_decls(rhs)
                    for nsd : Declaration in dhb_ns {
                        if nsd.name.eq(method) { found = true; break }
                    }
                    if found.not() { continue }
                    if dyn_has_shallow {
                        f.write("    if (type_name->count == "); emit_u64(f, dd.name.len().to_i64().to_u64()); f.write("ULL && memcmp(type_name->c_str, \""); f.write(dd.name); f.write("\", "); emit_u64(f, dd.name.len().to_i64().to_u64()); f.write("ULL) == 0) return 1;\n")
                    } else {
                        f.write("    if (type_name->count == "); emit_u64(f, dd.name.len().to_i64().to_u64()); f.write("ULL && memcmp(type_name->c_str, \""); f.write(dd.name); f.write("\", "); emit_u64(f, dd.name.len().to_i64().to_u64()); f.write("ULL) == 0) { Bool *r = malloc(sizeof(Bool)); *r = 1; return r; }\n")
                    }
                }
            }
        }
        for u : ProgramUnit in lp.units {
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            for e_i : Expr in iu.ast.children {
                ref stmt : Expr = e_i
                if is_struct_or_enum(stmt).not() { continue }
                ref rhs : Expr = stmt.child(0)
                ref dd : Declaration = get_payload(stmt.node_type)
                mut found := false
                ref dhb_ns : Vec = def_ns_decls(rhs)
                for nsd : Declaration in dhb_ns {
                    if nsd.name.eq(method) { found = true; break }
                }
                if found.not() { continue }
                if dyn_has_shallow {
                    f.write("    if (type_name->count == "); emit_u64(f, dd.name.len().to_i64().to_u64()); f.write("ULL && memcmp(type_name->c_str, \""); f.write(dd.name); f.write("\", "); emit_u64(f, dd.name.len().to_i64().to_u64()); f.write("ULL) == 0) return 1;\n")
                } else {
                    f.write("    if (type_name->count == "); emit_u64(f, dd.name.len().to_i64().to_u64()); f.write("ULL && memcmp(type_name->c_str, \""); f.write(dd.name); f.write("\", "); emit_u64(f, dd.name.len().to_i64().to_u64()); f.write("ULL) == 0) { Bool *r = malloc(sizeof(Bool)); *r = 1; return r; }\n")
                }
            }
        }
        if dyn_has_shallow { f.write("    return 0;\n") }
        else { f.write("    Bool *r = malloc(sizeof(Bool)); *r = 0; return r;\n") }
        f.write("}\n\n")
    }
    own has_methods.delete()
}

emit_collection_helpers := proc(f: File) {
    ref lp : LoadedProgram = codegen_lp()
    mut coll_infos := Vec.new("CollectionInfo", CollectionInfo.size())
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            collect_collection_builtins(iu.ast, coll_infos)
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        collect_collection_builtins(iu.ast, coll_infos)
    }
    for ci : CollectionInfo in coll_infos {
        et := ci.type_name
        et_len := et.len().to_i64().to_u64()
        if ci.is_vec.neq(0) {
            f.write("Vec *vec_of_"); f.write(et); f.write("(int count, ...) {\n")
            f.write("    USize _esz = sizeof("); f.write(et); f.write(");\n")
            f.write("    Vec *_v = Vec_new(&(Str){.c_str = (U8 *)\""); f.write(et); f.write("\", .count = "); emit_u64(f, et_len); f.write("ULL, .cap = TIL_CAP_LIT}, &(USize){_esz});\n")
            f.write("    va_list ap; va_start(ap, count);\n")
            f.write("    for (int _i = 0; _i < count; _i++) {\n")
            cn := et.concat("_clone")
            is_shallow := callee_returns_shallow(cn)
            if is_shallow {
                f.write("        "); f.write(et); f.write(" *_val = malloc(sizeof("); f.write(et); f.write(")); *_val = "); f.write(et); f.write("_clone(va_arg(ap, "); f.write(et); f.write(" *));\n")
            } else {
                f.write("        "); f.write(et); f.write(" *_val = "); f.write(et); f.write("_clone(va_arg(ap, "); f.write(et); f.write(" *));\n")
            }
            f.write("        Vec_push(_v, _val);\n")
            f.write("    }\n")
            f.write("    va_end(ap);\n")
            f.write("    return _v;\n")
            f.write("}\n\n")
        } else {
            f.write("Array *array_of_"); f.write(et); f.write("(int count, ...) {\n")
            f.write("    USize _esz = sizeof("); f.write(et); f.write(");\n")
            f.write("    USize _cap = count;\n")
            f.write("    Array *_a = Array_new(&(Str){.c_str = (U8 *)\""); f.write(et); f.write("\", .count = "); emit_u64(f, et_len); f.write("ULL, .cap = TIL_CAP_LIT}, &(USize){_esz}, &(USize){_cap});\n")
            f.write("    va_list ap; va_start(ap, count);\n")
            f.write("    for (int _i = 0; _i < count; _i++) {\n")
            f.write("        USize _idx = _i;\n")
            cn := et.concat("_clone")
            is_shallow := callee_returns_shallow(cn)
            if is_shallow {
                f.write("        "); f.write(et); f.write(" *_val = malloc(sizeof("); f.write(et); f.write(")); *_val = "); f.write(et); f.write("_clone(va_arg(ap, "); f.write(et); f.write(" *));\n")
            } else {
                f.write("        "); f.write(et); f.write(" *_val = "); f.write(et); f.write("_clone(va_arg(ap, "); f.write(et); f.write(" *));\n")
            }
            f.write("        Array_set(_a, &(USize){_idx}, _val);\n")
            f.write("    }\n")
            f.write("    va_end(ap);\n")
            f.write("    return _a;\n")
            f.write("}\n\n")
        }
    }
    own coll_infos.delete()
}

emit_global_declarations := proc(f: File) {
    script_globals = Set.new("Str", Str.size())
    has_script_globals = true
    ref_globals = Set.new("Str", Str.size())
    has_ref_globals = true
    ref lp : LoadedProgram = codegen_lp()
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            for stmt : Expr in iu.ast.children {
                if is_exported_top_level_global(stmt).not() { continue }
                ref rhs : Expr = stmt.child(0)
                ctype := extern_decl_ctype(stmt.til_type, rhs.til_type)
                ref dd : Declaration = get_payload(stmt.node_type)
                if dd.own_type.is(OwnType.Ref) {
                    f.write(ctype); f.write(" *"); f.write(dd.name); f.write(";\n")
                    ref_globals.add(own dd.name.clone())
                } else {
                    f.write(ctype); f.write(" "); f.write(dd.name); f.write(";\n")
                    script_globals.add(own dd.name.clone())
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        for stmt : Expr in iu.ast.children {
            if is_exported_top_level_global(stmt).not() { continue }
            ref rhs : Expr = stmt.child(0)
            ctype := extern_decl_ctype(stmt.til_type, rhs.til_type)
            ref dd : Declaration = get_payload(stmt.node_type)
            if dd.own_type.is(OwnType.Ref) {
                f.write(ctype); f.write(" *"); f.write(dd.name); f.write(";\n")
                ref_globals.add(own dd.name.clone())
            } else {
                f.write(ctype); f.write(" "); f.write(dd.name); f.write(";\n")
                script_globals.add(own dd.name.clone())
            }
        }
    }
    f.write("\n")
}

emit_test_main := proc(f: File, program: Expr) {
    f.write("int main(void) {\n")
    emit_ns_inits(f, 1)
    emit_global_inits(f)
    mut test_count : I32 = 0
    for stmt : Expr in program.children {
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        ref rhs : Expr = stmt.child(0)
        if rhs.node_type.is(NodeType.FuncDef).not() { continue }
        ref fd : FunctionDef = get_payload(rhs.node_type)
        if fd.func_type.is(FuncType.Test).not() { continue }
        ref dd : Declaration = get_payload(stmt.node_type)
        f.write("    "); f.write(dd.name); f.write("();\n")
        f.write("    fprintf(stderr, \"  pass: %s\\n\", \""); f.write(dd.name); f.write("\");\n")
        test_count = test_count.add(1.to_i32())
    }
    if test_count.eq(0.to_i32()) {
        f.write("    fprintf(stderr, \"no tests found\\n\");\n")
    } else {
        f.write("    fprintf(stderr, \""); emit_i32(f, test_count); f.write("/"); emit_i32(f, test_count); f.write(" tests passed\\n\");\n")
    }
    f.write("    return 0;\n")
    f.write("}\n")
}

emit_script_main := proc(f: File) {
    f.write("int main(void) {\n")
    emit_ns_inits(f, 1)
    unsafe_to_hoist = Set.new("Str", Str.size())
    ref lp : LoadedProgram = codegen_lp()
    // Collect hoist restrictions across all user units.
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        collect_unsafe_to_hoist(iu.ast)
    }
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            for gi in 0..iu.ast.children.len() {
                ref gs : Expr = iu.ast.child(gi)
                if gs.node_type.is(NodeType.Decl) {
                    ref rhs : Expr = gs.child(0)
                    if rhs.node_type.is(NodeType.FuncDef).or(rhs.node_type.is(NodeType.StructDef)).or(rhs.node_type.is(NodeType.EnumDef)) { continue }
                    if gs.til_type.is(TilType.None).and(rhs.node_type.is(NodeType.Ident)) { continue }
                } else if gs.node_type.is(NodeType.FCall).not() { continue }
                emit_stmt(f, gs, 1)
            }
        }
    }
    // Emit top-level non-def statements across all user units, in order.
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        for gi in 0..iu.ast.children.len() {
            ref stmt : Expr = iu.ast.child(gi)
            if stmt.node_type.is(NodeType.Decl) {
                ref rhs : Expr = stmt.child(0)
                if rhs.node_type.is(NodeType.FuncDef).or(rhs.node_type.is(NodeType.StructDef)).or(rhs.node_type.is(NodeType.EnumDef)) { continue }
            }
            emit_stmt(f, stmt, 1)
        }
    }
    f.write("    return 0;\n")
    f.write("}\n")
    own script_globals.delete()
    has_script_globals = false
}

emit_function_bodies := proc(f: File, mode: Mode) {
    ref lp : LoadedProgram = codegen_lp()
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            for stmt : Expr in iu.ast.children {
                if stmt.node_type.is(NodeType.Decl).not() { continue }
                ref dd : Declaration = get_payload(stmt.node_type)
                ref rhs : Expr = stmt.child(0)
                switch rhs.node_type {
                case NodeType.StructDef:
                    emit_struct_funcs(f, dd.name, rhs)
                case NodeType.EnumDef:
                    emit_enum_def(f, dd.name, rhs)
                    f.write("\n")
                case NodeType.FuncDef(fd):
                    if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)) { continue }
                    if rhs.children.len().eq(0) { continue }
                    emit_func_def(f, dd.name, rhs, mode, false)
                    f.write("\n")
                case:
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        for stmt : Expr in iu.ast.children {
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            ref dd : Declaration = get_payload(stmt.node_type)
            ref rhs : Expr = stmt.child(0)
            switch rhs.node_type {
            case NodeType.StructDef:
                emit_struct_funcs(f, dd.name, rhs)
            case NodeType.EnumDef:
                emit_enum_def(f, dd.name, rhs)
                f.write("\n")
            case NodeType.FuncDef(fd):
                if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)) { continue }
                if rhs.children.len().eq(0) { continue }
                emit_func_def(f, dd.name, rhs, mode, false)
                f.write("\n")
            case:
            }
        }
    }
}

emit_ext_func_declarations := proc(f: File, program: Expr) {
    for stmt : Expr in program.children {
        if is_func_decl(stmt).not() { continue }
        ref fdef : Expr = stmt.child(0)
        ref fd : FunctionDef = get_payload(fdef.node_type)
        if fd.func_type.is(FuncType.ExtFunc).not().and(fd.func_type.is(FuncType.ExtProc).not()) { continue }
        ref dd : Declaration = get_payload(stmt.node_type)
        if is_skip_ext_decl(dd.name) { continue }
        if fd.return_type.len().gt(0) {
            mut rt := ""
            if fd.return_own_type.is(OwnType.Shallow) { rt = type_name_to_c_value(fd.return_type) }
            else { rt = type_name_to_c(fd.return_type) }
            f.write(rt); f.write(" "); fc := func_to_c(dd.name); f.write(fc); f.write("(")
        } else {
            f.write("void "); fc := func_to_c(dd.name); f.write(fc); f.write("(")
        }
        emit_param_list(f, fdef, false)
        f.write(");\n")
    }
    f.write("\n")
}

emit_lib_init := proc(f: File) {
    f.write("__attribute__((constructor))\nstatic void _til_lib_init(void) {\n")
    emit_ns_inits(f, 1)
    emit_global_inits(f)
    f.write("}\n\n")
}

build := proc(mode: Mode, shallow run_tests: Bool, c_output_path: Str) returns shallow I32 {
    mut is_lib := false
    if is_null(mode).not() { is_lib = mode.is_library }

    build_register_lookups_lp()
    build_register_funcsig_names_lp()
    f := File.new(c_output_path, true)
    if is_null(f) { return 1.to_i32() }

    f.write("#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <stdarg.h>\n#include <limits.h>\n\n")

    mut is_script := true
    if is_null(mode).not() {
        if mode.decls_only { is_script = false }
    }

    emit_monolithic_header_lp(f, mode)
    f.write("#include \"ext.h\"\n\n")

    // Ext decls from user units only.
    ref lp : LoadedProgram = codegen_lp()
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        emit_ext_func_declarations(f, iu.ast)
    }

    f.write("Str *Str_lit(const char *s, unsigned long long len);\n")
    f.write("void print_single(Str *s);\n")
    f.write("void print_flush();\n\n")

    emit_all_forward_declarations(f, mode)

    f.write("#define DEREF(p) (*(p ? p : (fprintf(stderr, \"panic: null deref\\n\"), exit(1), p)))\n")

    f.write("#define TIL_CAP_LIT ((USize)-1)\n")
    f.write("Str *Str_lit(const char *s, unsigned long long len) {\n")
    f.write("    (void)len;\n")
    f.write("    Str *r = malloc(sizeof(Str));\n")
    f.write("    r->c_str = (U8 *)s;\n")
    f.write("    r->count = (USize)strlen(s);\n")
    f.write("    r->cap = TIL_CAP_LIT;\n")
    f.write("    return r;\n")
    f.write("}\n")
    f.write("void print_single(Str *s) {\n")
    f.write("    fwrite(s->c_str, 1, (size_t)s->count, stdout);\n")
    f.write("}\n")
    f.write("void print_flush() {\n")
    f.write("    putchar('\\n');\n")
    f.write("}\n\n")

    emit_global_declarations(f)
    emit_function_bodies(f, mode)

    emit_dyn_call_bodies(f)
    emit_dyn_fn_wrappers(f)
    emit_dyn_has_bodies(f)
    emit_collection_helpers(f)

    if run_tests {
        // Test discovery from user entrypoint only.
        ref lp2 : LoadedProgram = codegen_lp()
        ref root : ProgramUnit = lp2.units.get(lp2.units.len().sub(1))
        ref iu2 : ImportUnit = lp2.ctx.imported.get(root.path)
        emit_test_main(f, iu2.ast)
    }
    if run_tests.not() {
        if is_script.not() {
            if is_lib {
                if has_script_globals { emit_lib_init(f) }
            }
        }
    }
    if run_tests.not() {
        if is_script {
            mut needs_main := false
            if is_null(mode).not() { needs_main = mode.needs_main }
            if needs_main.not() {
                emit_script_main(f)
            }
        }
    }

    f.close()
    own func_defs.delete()
    func_defs = Map.new("Str", Str.size(), "Dynamic", I64.size())
    own stack_locals.delete()
    stack_locals = Set.new("Str", Str.size())
    own stack_local_types.delete()
    stack_local_types = Map.new("Str", Str.size(), "Str", Str.size())
    own unsafe_to_hoist.delete()
    unsafe_to_hoist = Set.new("Str", Str.size())
    return 0.to_i32()
}

BuildPaths := struct {
    mut name := ""
    mut c_path := ""
    mut bin_path := ""
    mut fwd_path := ""
    mut h_path := ""
    mut til_path := ""
    mut py_path := ""
    mut do_lib := false
}

derive_build_paths := func(lp: LoadedProgram, custom_bin: Str, custom_c: Str, target: Target) returns BuildPaths {
    mut paths := BuildPaths()

    last_slash := lp.path.rfind("/")
    mut basename := lp.path
    if last_slash.gte(0) {
        last_slash_u : USize = last_slash.to_u32()
        basename = lp.path.substr(last_slash_u.add(1), lp.path.len().sub(last_slash_u).sub(1))
    }
    mut name_len := basename.len()
    if basename.ends_with(".til") {
        name_len = name_len.sub(4)
    }
    name := basename.substr(0, name_len)
    paths.name = name.clone()

    mut c_path := "gen/til/".concat(name).concat(".c")
    if custom_c.len().gt(0) { c_path = custom_c.clone() }
    mut bin_path := "bin/".concat(name).concat(executable_extension(target))
    if custom_bin.len().gt(0) { bin_path = custom_bin.clone() }

    paths.c_path = c_path
    paths.bin_path = bin_path
    paths.fwd_path = forward_header_path(c_path)
    paths.h_path = "gen/til/".concat(name).concat(".h")
    paths.til_path = "gen/til/".concat(name).concat(".til")
    paths.py_path = "gen/til/".concat(name).concat(".py")
    paths.do_lib = lp.cur_mode.is_library
    return paths
}

make_build_dirs := func(paths: BuildPaths) {
    if paths.do_lib {
        system_cmd("mkdir -p gen/til gen/lib")
    } else {
        cp_slash := paths.c_path.rfind("/")
        bp_slash := paths.bin_path.rfind("/")
        mut cp_dir := "gen/til"
        if cp_slash.gt(0) {
            cp_slash_u : USize = cp_slash.to_u32()
            cp_dir = paths.c_path.substr(0, cp_slash_u)
        }
        mut bp_dir := "bin"
        if bp_slash.gt(0) {
            bp_slash_u : USize = bp_slash.to_u32()
            bp_dir = paths.bin_path.substr(0, bp_slash_u)
        }
        system_cmd("mkdir -p ".concat(cp_dir).concat(" ").concat(bp_dir))
    }
}

translate_ast := proc(lp: LoadedProgram, paths: BuildPaths) returns shallow I32 {
    codegen_set_lp(lp)
    mut result := build_forward_header_lp(paths.fwd_path)
    if result.eq(0) {
        result = build(lp.cur_mode, lp.run_tests, paths.c_path)
    }
    if result.eq(0).and(paths.do_lib) {
        result = build_header_lp(paths.h_path)
        if result.eq(0) {
            result = build_til_binding(NULL, paths.til_path, paths.name)
        }
        if result.eq(0) {
            result = build_python_binding(NULL, paths.py_path, paths.name)
        }
    }
    codegen_clear_lp()
    return result
}

print_translate_success := proc(paths: BuildPaths) {
    println("Generated: ".concat(paths.c_path))
    println("Generated: ".concat(paths.fwd_path))
    if paths.do_lib {
        println("Generated: ".concat(paths.h_path))
        println("Generated: ".concat(paths.til_path))
        println("Generated: ".concat(paths.py_path))
    }
}

compile_ast := proc(lp: LoadedProgram, paths: BuildPaths, target: Target, cc_override: Str) returns shallow I32 {
    if paths.do_lib {
        return compile_lib(paths.c_path, paths.name, lp.ext_c_path, lp.link_c_paths, lp.link_flags, lp.include_flags, target, cc_override)
    }
    return compile_c(paths.c_path, paths.bin_path, lp.ext_c_path, lp.link_c_paths, lp.link_flags, lp.include_flags, target, cc_override)
}

cmd_translate := proc(lp: LoadedProgram, custom_c: Str) returns shallow I32 {
    paths := derive_build_paths(lp, "", custom_c, detect_current_target())
    make_build_dirs(paths)
    result := translate_ast(lp, paths)
    if result.eq(0) { print_translate_success(paths) }
    return result
}

cmd_build := proc(lp: LoadedProgram, custom_bin: Str, custom_c: Str, target: Target, cc_override: Str) returns shallow I32 {
    paths := derive_build_paths(lp, custom_bin, custom_c, target)
    make_build_dirs(paths)
    mut result := translate_ast(lp, paths)
    if result.eq(0) { result = compile_ast(lp, paths, target, cc_override) }
    if result.eq(0).and(paths.do_lib) {
        print_translate_success(paths)
        println("Generated: gen/lib/lib".concat(paths.name).concat(".so"))
        println("Generated: gen/lib/lib".concat(paths.name).concat(".a"))
    }
    return result
}

cmd_run := proc(lp: LoadedProgram, custom_bin: Str, custom_c: Str, user_argv: Vec, target: Target, cc_override: Str) returns shallow I32 {
    if lp.cur_mode.is_library {
        panic(__LOC__, "cannot run a library -- use translate or build")
    }
    paths := derive_build_paths(lp, custom_bin, custom_c, target)
    make_build_dirs(paths)
    mut result := translate_ast(lp, paths)
    if result.eq(0) { result = compile_ast(lp, paths, target, cc_override) }
    if result.eq(0) {
        mut cmd := paths.bin_path
        for uarg : Str in user_argv {
            cmd = cmd.concat(" '").concat(uarg).concat("'")
        }
        result = system_cmd(cmd)
    }
    return result
}
