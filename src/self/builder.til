mode lib
import("context")

import("loader")
import("targets")
import("../std/sys")

system_cmd := ext_proc(cmd: Str) returns shallow I32 {}

priv CollectionInfo := struct {
    ref type_name : Str = NULL
    is_vec : I32 = 0
}

priv DynCallInfo := struct {
    ref method : Str = NULL
    nargs : I32 = 1
    has_return := false
}

closure_call_name := func(name: Str) returns Str {
    return format(func_to_c(name), "__til_closure_call")
}

closure_value_name := func(name: Str) returns Str {
    return format(func_to_c(name), "__til_closure")
}

// in_func_def / in_main_func / ctor_seq previously lived here as
// module-level mut; they moved to Context (see initer.til). The active
// LoadedProgram is threaded explicitly as an `lp` parameter (and `ctx`
// for Context-only consumers) rather than parked in a module global.

// --- Leaf functions ---

priv resolve_local_fn_sig := func(ctx: Context, name: Str) returns ref Expr {
    ref slot : Dynamic = ctx.builder_func.local_fn_sigs.get(name)?
    catch (e: KeyNotFound) { return NULL }
    return deref(slot)
}

priv resolve_decl_fn_sig := func(rhs: Expr, dd: Declaration, scope: TypeScope, ctx: Context) returns ref Expr {
    switch rhs.node_type {
    case NodeType.Ident(rhs_name):
        ref fdef : Expr = find_callee_fdef(rhs_name.ident_name(), ctx)
        if fdef.is_null().not() { return fdef }
        sf := scope.find(rhs_name.ident_name())
        switch sf {
        case ScopeFind.Found(b):
            ref bfd : Expr = scope.lookup_func(b.name)
            if bfd.is_null().not() { return bfd }
        case:
        }
    case NodeType.FCall:
        ref fdef : Expr = resolve_fn_sig(rhs, scope)
        if fdef.is_null().not() { return fdef }
    case NodeType.FuncDef(rhs_fd):
        if rhs_fd.captures.len() > 0 { return rhs }
    case:
    }
    // Fall back to the declared FuncSig alias name. Issue #58 / #147
    // step 5: read the name off dd.til_type's FuncPtrSig payload instead
    // of dd.explicit_type. til_type_name returns "" for a non-FuncPtrSig
    // type, so the empty-check below still guards the lookup.
    sig_name := til_type_name(dd.til_type)
    if sig_name.len() == 0 { return NULL }
    ref sig_bfd : Expr = scope.lookup_func(sig_name)
    if sig_bfd.is_null().not() {
        if sig_bfd.children.len() == 0 { return sig_bfd }
    }
    return NULL
}

priv fcall_fn_sig := func(fcall: Expr, ctx: Context) returns ref Expr {
    if fcall.is_null() { return NULL }
    if fcall.node_type.is(NodeType.FCall).not() { return NULL }
    if fcall.children.len() == 0 { return NULL }
    ref callee : Expr = fcall.children[0]
    // Only FuncPtr-typed callees go through the indirect-call emit path, so
    // this is the only shape that actually needs an answer. Other callees
    // (struct constructors, regular func calls) have null fn_sig today.
    if callee.expr_til_type().is_funcptr().not() { return NULL }
    ref s : TypeScope = ctx.scope
    ref via_scope : Expr = resolve_fn_sig(fcall, s)
    if via_scope.is_null().not() { return via_scope }
    // resolve_fn_sig only sees globals + struct fields. The remaining FuncPtr
    // shapes are params and locals of the function currently being emitted;
    // their bindings lived in a transient func_scope that is gone by now.
    switch callee.node_type {
    case NodeType.Ident(name):
        // Fallback 1: FuncPtr param of the current function. Issue #58
        // / #147 step 5: the FuncSig alias name lives on param.til_type
        // as Type.FuncPtrSig(name) -- read it via til_type_name(t)
        // instead of through param.explicit_type + scope.find indirection.
        // The Type.FuncPtrSig predicate filters out non-FuncSig params
        // (Struct/Enum) without needing the bodyless-FuncDef gate.
        ref cf1 : Expr = ctx.current_fdef
        if cf1.is_null().not() {
            switch cf1.node_type {
            case NodeType.FuncDef(cur_fd):
                for p : Declaration in cur_fd.params {
                    if p.name.eq(name.ident_name()).not() { continue }
                    if p.til_type.is(Type.FuncPtrSig).not() { return NULL }
                    sig_name := til_type_name(p.til_type)
                    if sig_name.len() == 0 { return NULL }
                    ref pftbfd : Expr = s.lookup_func(sig_name)
                    if pftbfd.is_null() { return NULL }
                    if pftbfd.children.len() != 0 { return NULL }
                    return pftbfd
                }
            case:
            }
        }
        // Fallback 2: local FuncPtr decl whose signature was captured at
        // emit_stmt_decl time.
        ref via_local : Expr = resolve_local_fn_sig(ctx, name.ident_name())
        if via_local.is_null().not() { return via_local }
        // Fallback 3: the Ident itself is a known global function name used
        // as a FuncPtr value (e.g. an inlined ref to a top-level func).
        ref via_global : Expr = find_callee_fdef(name.ident_name(), ctx)
        if via_global.is_null().not() { return via_global }
        return NULL
    case NodeType.FCall:
        // Issue #58: `cast(value, BinaryOp)(args)`. The cast's til_type
        // is Type.FuncPtr (set by infer_cast_fcall on the user FuncSig
        // path), and child(2) is the FuncSig Ident kept verbatim so we
        // can resolve the signature here.
        if callee.children.len() != 3 { return NULL }
        ref cast_head : Expr = callee.children[0]
        switch cast_head.node_type {
        case NodeType.Ident(cn):
            if cn.ident_name().eq("cast").not() { return NULL }
        case:
            return NULL
        }
        mut sig_name := ""
        switch callee.children[2].node_type {
        case NodeType.Ident(tn): sig_name = Str.clone(tn.ident_name())
        case: return NULL
        }
        sf := s.find(sig_name)
        switch sf {
        case ScopeFind.Found(ftb):
            ref ftbfd : Expr = s.lookup_func(ftb.name)
            if ftbfd.is_null() { return NULL }
            if ftbfd.children.len() != 0 { return NULL }
            return ftbfd
        case:
        }
        return NULL
    case:
        return NULL
    }
}

priv is_stack_local := func(name: Str, ctx: Context) returns Bool {
    return ctx.builder_func.stack_locals.has(name)
}

priv is_stack_lit_str_local := func(name: Str, ctx: Context) returns Bool {
    return ctx.builder_func.stack_lit_str_locals.has(name)
}

priv is_current_func_param := func(name: Str, ctx: Context) returns Bool {
    ref cf : Expr = ctx.current_fdef
    if cf.is_null() { return false }
    switch cf.node_type {
    case NodeType.FuncDef(fd):
        for p : Declaration in fd.params {
            if p.name == name { return true }
        }
        return false
    case:
        return false
    }
}

priv is_value_global := func(name: Str, ctx: Context) returns Bool {
    if is_current_func_param(name, ctx) { return false }
    // A local (loop var, decl) inside the current function shadows a
    // script global of the same name. Without this guard a library
    // function like Map.new_type_names (local `m`) would inherit the
    // value-global classification of the script's top-level `m`, and
    // codegen would emit `.` field access / value returns against a
    // `Type *` local -- invalid C. See issue #220.
    if is_stack_local(name, ctx) { return false }
    if ctx.builder_func.ref_locals.has(name) { return false }
    if ctx.builder_func.ptr_locals.has(name) { return false }
    return ctx.script_globals.has(name)
}

priv is_ref_global := func(name: Str, ctx: Context) returns Bool {
    if is_current_func_param(name, ctx) { return false }
    // Same shadowing rule as is_value_global: a current-function local
    // beats a script-level ref global of the same name.
    if is_stack_local(name, ctx) { return false }
    if ctx.builder_func.ref_locals.has(name) { return false }
    if ctx.builder_func.ptr_locals.has(name) { return false }
    return ctx.ref_globals.has(name)
}

priv is_ref_local := func(name: Str, ctx: Context) returns Bool {
    if ctx.builder_func.ref_locals.has(name) { return true }
    return is_ref_global(name, ctx)
}

priv use_dot_access := func(obj: Expr, ctx: Context) returns Bool {
    if obj.node_type.is(NodeType.FieldAccess) {
        if builder_fa_is_ptr(obj, ctx).not() { return true }
    }
    switch obj.node_type {
    case NodeType.Ident(ident):
        if is_stack_local(ident.ident_name(), ctx) { return true }
        if is_value_global(ident.ident_name(), ctx) { return true }
        // Issue #223 step 3: a shallow (value) param -- e.g. an auto-shallow
        // small struct passed by value -- is accessed with '.' not '->'.
        if is_shallow_param(ident.ident_name(), ctx) { return true }
    case:
    }
    return false
}

priv is_primitive_type := func(name: Str) returns Bool {
    if name == "I64" { return true }
    if name == "U8" { return true }
    if name == "I8" { return true }
    if name == "I16" { return true }
    if name == "U16" { return true }
    if name == "I32" { return true }
    if name == "U32" { return true }
    if name == "U64" { return true }
    if name == "USize" { return true }
    if name == "UPtr" { return true }
    if name == "F32" { return true }
    if name == "Bool" { return true }
    return false
}

// A POD enum has no variant payloads, so every variant is fully
// representable as a single `tag` field assignment.  The typer wraps
// `c := Color.Red` as `c := Color.clone(Color.Red)` for ownership
// semantics, but for POD enums the wrap is a wasteful round-trip
// (malloc + deref + free of a stack compound literal).  The Decl
// emission path recognises the wrap and emits the value directly.
priv is_pod_enum := func(enum_name: Str, ctx: Context) returns Bool {
    if enum_name.len() == 0 { return false }
    ref ed : Expr = find_struct_def(enum_name, ctx)
    if ed.is_null() { return false }
    if ed.node_type.is(NodeType.EnumDef).not() { return false }
    if enum_has_payloads(ed) { return false }
    return true
}

// Matches the typer-emitted `<Enum>.clone(<value>)` wrap around Ident /
// FieldAccess RHSes of Enum type. True when the wrap can be skipped
// (whole enum is POD, or the clone arg is a payload-less variant of
// an otherwise-payload-carrying enum).
priv is_pod_enum_clone_call := func(e: Expr, ctx: Context) returns Bool {
    tname := clone_call_type_name(e)
    if tname.len() == 0 { return false }
    return is_pod_enum_clone_of(e, find_struct_def(tname, ctx))
}

// Matches user-written `<value>.clone()` where the typer's expansion
// lands `<value>` as e.children[1] and the callee's receiver carries the
// POD-struct type. Fires when the arg is an Ident of a stack_local /
// param (struct value) or a FieldAccess (struct field, possibly
// pointer-typed -- caller derefs explicitly).
priv is_pod_struct_user_clone := func(e: Expr, ctx: Context) returns Bool {
    if e.node_type.is(NodeType.FCall).not() { return false }
    if e.children.len() < 2 { return false }
    ref callee : Expr = e.children[0]
    if callee.node_type.is(NodeType.FieldAccess).not() { return false }
    mut is_clone := false
    switch callee.node_type {
    case NodeType.FieldAccess(m): is_clone = m.field_access_name() == "clone"
    case:
    }
    if is_clone.not() { return false }
    if callee.children.len() == 0 { return false }
    ref recv : Expr = callee.children[0]
    if recv.expr_til_type().is(Type.Struct).not() { return false }
    tname := til_type_name(recv.expr_til_type())
    if is_pod_struct(tname, ctx).not() { return false }
    switch e.children[1].node_type {
    case NodeType.Ident(an):
        ref aname : Str = an.ident_name()
        return is_stack_local(aname, ctx).or(is_current_func_param(aname, ctx))
    case NodeType.FieldAccess:
        return true
    case:
        return false
    }
}

// Emit the POD-struct user-clone arg as a struct value: dereference
// pointer-typed FieldAccesses, otherwise emit as-is (Idents map to
// stack-locals, params, or globals which emit_expr renders as values).
priv emit_pod_struct_user_clone_arg := proc(f: File, e: Expr, depth: I32, ctx: Context) {
    ref arg : Expr = e.children[1]
    if arg.node_type.is(NodeType.FieldAccess).and(builder_fa_is_ptr(arg, ctx)) {
        f.write("*"); emit_expr(f, arg, depth, ctx)
        return
    }
    emit_expr(f, arg, depth, ctx)
}

// Emit the clone arg as `(T){.tag = T_TAG_X}` when it's a ns-Enum
// variant FieldAccess; otherwise fall back to emit_deref.
priv emit_pod_enum_clone_arg := proc(f: File, e: Expr, depth: I32, ctx: Context) {
    ref pe_arg : Expr = e.children[1]
    if pe_arg.node_type.is(NodeType.FieldAccess).and(builder_fa_is_ns(pe_arg, ctx)).and(pe_arg.expr_til_type().is(Type.Enum)) {
        switch pe_arg.node_type {
        case NodeType.FieldAccess(pe_vn):
            pe_sname := til_type_name(pe_arg.children[0].expr_til_type())
            f.write("(").write(pe_sname).write("){.tag = ")
            f.write(pe_sname).write("_TAG_").write(pe_vn.field_access_name()).write("}")
            return
        case:
        }
    }
    emit_deref(f, pe_arg, depth, ctx)
}

// A POD struct has only Shallow-owned fields that are themselves
// stack-cheap: primitives, or nested POD structs. No Str / Vec /
// Array / Own-marked fields that would need recursive heap cleanup.
// Ctor Decls for these structs can live on the stack as a C compound
// literal (no malloc / no recursive free), and the same emission
// works inline as an expression when a non-POD parent struct has a
// POD field set from a ctor FCall.  Callers must still pair this with
// a non-freeing delete at scope end (call_free=false) so the cleanup
// doesn't try to free a stack pointer.
priv is_pod_struct := func(struct_name: Str, ctx: Context) returns Bool {
    if struct_name.len() == 0 { return false }
    if is_primitive_type(struct_name) { return false }
    ref sdef : Expr = find_struct_def(struct_name, ctx)
    if sdef.is_null() { return false }
    switch sdef.node_type {
    case NodeType.StructDef(sdd):
        if sdd.fields.len() == 0 { return false }
        for fd : Declaration in sdd.fields {
            if fd.own_type.is(OwnType.Own) { return false }
            if fd.own_type.is(OwnType.Ref) { return false }
            if is_primitive_type(fd.explicit_type) { continue }
            if is_pod_struct(fd.explicit_type, ctx) { continue }
            return false
        }
        return true
    case:
    }
    return false
}

priv is_funcsig_type := func(name: Str, ctx: Context) returns Bool {
    return ctx.funcsig_names.has(name)
}

priv is_ext_h_type := func(name: Str) returns Bool {
    if name == "U8" { return true }
    if name == "I8" { return true }
    if name == "I16" { return true }
    if name == "U16" { return true }
    if name == "I32" { return true }
    if name == "F32" { return true }
    if name == "U32" { return true }
    if name == "U64" { return true }
    if name == "I64" { return true }
    if name == "Bool" { return true }
    return false
}

// print_single / print_flush have hand-written prototypes emitted as
// part of the standard prelude (see emit_header_defs_and_funcs_lp);
// suppressing the ext_proc-side emission avoids a duplicate decl.
priv is_exported_top_level_global := func(stmt: Expr) returns Bool {
    if stmt.node_type.is(NodeType.Decl).not() { return false }
    ref rhs : Expr = stmt.children[0]
    if rhs.node_type.is(NodeType.FuncDef) { return false }
    if rhs.node_type.is(NodeType.StructDef) { return false }
    if rhs.node_type.is(NodeType.EnumDef) { return false }
    if stmt.expr_til_type().is(Type.None) {
        if rhs.node_type.is(NodeType.Ident) { return false }
    }
    switch stmt.node_type {
    case NodeType.Decl(decl):
        if decl.name.starts_with("hoisted__") { return false }
        return true
    case:
        UNREACHABLE()
        return false
    }
}

priv find_struct_def := func(name: Str, ctx: Context) returns ref Expr {
    ref slot : Dynamic = ctx.struct_def_exprs.get(name)?
    catch (e: KeyNotFound) { return NULL }
    return deref(slot)
}

priv find_callee_fdef := func(name: Str, ctx: Context) returns ref Expr {
    ref slot : Dynamic = ctx.func_defs.get(name)?
    catch (e: KeyNotFound) { return NULL }
    return deref(slot)
}

// --- len/unsafe_get accessor inlining (issue #300) ---
// A `for x in c` loop desugars to c.len() (the loop bound) and c.unsafe_get(i)
// (the element) every iteration, so a real call to those accessors is
// per-iteration overhead on every container. These helpers inline such an
// accessor's OWN body at the call site, for ANY type -- keyed on the accessor
// method with a trivial single-`return EXPR` body, not on the container type
// (this replaces the old Vec-hardcoded peephole). The interpreter is untouched:
// it runs the accessor body as a normal func, so both modes agree.

// Substitute the callee's params with the call's argument expressions inside a
// (cloned) body node: every Ident naming a param becomes a clone of the
// matching argument. A replaced argument is not re-descended.
priv inline_subst := proc(e: Expr, params: Vec(Declaration), call: Expr) {
    for ci in 0..e.children.len() {
        mut matched := false
        switch e.children[ci].node_type {
        case NodeType.Ident(id):
            ref nm : Str = id.ident_name()
            for pi in 0..params.len() {
                if params[pi].name.eq(nm) {
                    e.children[ci] = call.children[pi.add(1)].clone()
                    matched = true
                }
            }
        case:
        }
        if matched.not() {
            inline_subst(e.children[ci], params, call)
        }
    }
}

// True when a `len`/`unsafe_get` accessor call is inlinable: the callee resolves
// to a plain func whose body is a single `return EXPR`. Any type qualifies.
priv builder_is_inline_accessor := func(mname: Str, flat: Str, ctx: Context) returns Bool {
    if mname.eq("len").or(mname.eq("unsafe_get")).not() { return false }
    ref fdef : Expr = find_callee_fdef(flat, ctx)
    if fdef.is_null() { return false }
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        if fd.func_type.is(FuncType.Func).not() { return false }
        if fdef.children.len() == 0 { return false }
        ref body : Expr = fdef.children[0]
        if body.children.len() != 1 { return false }
        ref stmt : Expr = body.children[0]
        return stmt.node_type.is(NodeType.Return).and(stmt.children.len().gt(0))
    case:
        return false
    }
}

// Emit an inlinable accessor call by splicing its (param-substituted) return
// expression -- a value or a ref return depending on the accessor's return_own.
priv emit_inline_accessor := proc(f: File, e: Expr, fdef: Expr, depth: I32, ctx: Context) {
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        ref body : Expr = fdef.children[0]
        mut ret := body.children[0].clone()
        inline_subst(ret, fd.params, e)
        ref rv : Expr = ret.children[0]
        f.write("(")
        if fd.return_own_type.is(OwnType.Ref) {
            emit_as_ptr(f, rv, depth, false, ctx)
        } else {
            emit_expr(f, rv, depth, ctx)
        }
        f.write(")")
    case:
        UNREACHABLE()
    }
}

// #288 Stage 3: true when the flat-named callee resolves to a core_func /
// core_proc -- a primitive intrinsic the C backend lowers to a native
// operator instead of a call (no emitted symbol).
priv builder_callee_is_core := func(name: Str, ctx: Context) returns Bool {
    ref fdef : Expr = find_callee_fdef(name, ctx)
    if fdef.is_null() { return false }
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        return fd.func_type.is(FuncType.CoreFunc).or(fd.func_type.is(FuncType.CoreProc))
    case:
        return false
    }
}

// The C operator a scalar core_func binary op lowers to. "" for an op that is
// not a recognised inline binary primitive (the caller panics on "").
priv core_binop_to_c := func(op: Str) returns Str {
    switch op {
    case "add":  return "+"
    case "sub":  return "-"
    case "mul":  return "*"
    case "eq":   return "=="
    case "neq":  return "!="
    case "lt":   return "<"
    case "gt":   return ">"
    case "lte":  return "<="
    case "gte":  return ">="
    case "band": return "&"
    case "bor":  return "|"
    case "bxor": return "^"
    case "shl":  return "<<"
    case "shr":  return ">>"
    }
    return ""
}

priv fa_struct_name := func(e: Expr) returns Str {
    if e.children.len() == 0 { return til_type_name(e.expr_til_type()) }
    ref obj : Expr = e.children[0]
    obj_sname := til_type_name(obj.expr_til_type())
    if obj_sname.len() > 0 { return obj_sname }
    switch obj.node_type {
    case NodeType.Ident(ident): return Str.clone(ident.ident_name())
    case:
    }
    return obj_sname
}

priv builder_fa_is_ptr_with_fname := func(sname: Str, fname: Str, ctx: Context) returns Bool {
    ref fap_def : Expr = find_struct_def(sname, ctx)
    if fap_def.is_null() { return false }
    switch fap_def.node_type {
    case NodeType.StructDef(fap_sdd):
        for dd : Declaration in fap_sdd.fields {
            if dd.name == fname {
                return dd.own_type.is(OwnType.Shallow).not()
            }
        }
        return false
    case:
        return false
    }
}

// Check if a FieldAccess/FieldAssign accesses an own/ref (pointer) field.
priv builder_fa_is_ptr := func(e: Expr, ctx: Context) returns Bool {
    sname := fa_struct_name(e)
    switch e.node_type {
    case NodeType.FieldAccess(fname):
        return builder_fa_is_ptr_with_fname(sname, fname.field_access_name(), ctx)
    case NodeType.FieldAssign(fad):
        return builder_fa_is_ptr_with_fname(sname, fad.name, ctx)
    case:
        return false
    }
}

priv builder_fa_is_ns_with_fname := func(e: Expr, sname: Str, fname: Str, ctx: Context) returns Bool {
    ref bfn_def : Expr = find_struct_def(sname, ctx)
    if bfn_def.is_null() { return false }
    mut has_ns := false
    mut has_inst := false
    ref bfn_ns : Vec(Declaration) = def_ns_decls(bfn_def)
    for bfn_d : Declaration in bfn_ns {
        if bfn_d.name == fname { has_ns = true }
    }
    switch bfn_def.node_type {
    case NodeType.StructDef(bfn_sdd):
        for dd : Declaration in bfn_sdd.fields {
            if dd.name == fname { has_inst = true }
        }
    case:
    }
    if has_ns.and(has_inst.not()) { return true }
    if has_ns.not() { return false }
    switch e.children[0].node_type {
    case NodeType.Ident(ident):
        if ident.ident_name() == sname { return true }
        if ident.len() > 0 {
            if ident.get(0).gte('A').and(ident.get(0).lte('Z')) {
                return true
            }
        }
    case:
    }
    return false
}

priv builder_fa_is_ns := func(e: Expr, ctx: Context) returns Bool {
    sname := fa_struct_name(e)
    switch e.node_type {
    case NodeType.FieldAccess(fname):
        return builder_fa_is_ns_with_fname(e, sname, fname.field_access_name(), ctx)
    case NodeType.FieldAssign(fad):
        return builder_fa_is_ns_with_fname(e, sname, fad.name, ctx)
    case:
        return false
    }
}

priv is_shallow_param := func(name: Str, ctx: Context) returns Bool {
    ref cf : Expr = ctx.current_fdef
    if cf.is_null() { return false }
    switch cf.node_type {
    case NodeType.FuncDef(fd):
        for p : Declaration in fd.params {
            if p.own_type.is(OwnType.Shallow) {
                if p.name == name { return true }
            }
        }
        return false
    case NodeType.BodyValue:
        return false
    case:
        UNREACHABLE()
        return false
    }
}

priv callee_returns_shallow := func(callee_name: Str, ctx: Context) returns Bool {
    ref fdef : Expr = find_callee_fdef(callee_name, ctx)
    if fdef.is_null() { return false }
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        return fd.return_own_type.is(OwnType.Shallow)
    case:
        return false
    }
}

priv callee_returns_dynamic := func(callee_name: Str, ctx: Context) returns Bool {
    if callee_name == "malloc" { return true }
    if callee_name == "calloc" { return true }
    if callee_name == "realloc" { return true }
    if callee_name == "dyn_call_ret" { return true }
    if callee_name == "dyn_fn" { return true }
    ref fdef : Expr = find_callee_fdef(callee_name, ctx)
    if fdef.is_null() { return false }
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        return fd.return_type == "Dynamic"
    case:
        return false
    }
}

// Issue #223 step 1: call_free is passed by value for auto-generated and
// hand-written til deletes (Bool is a primitive). An ext-declared delete may
// still take a `Bool *call_free` to match its hand-written C signature, so
// emit the address-of form only when the callee's delete explicitly keeps
// call_free non-shallow. Defaults to the by-value form when the delete is not
// found (the common case).
priv delete_call_free_lit := func(type_name: Str, set_free: Bool, ctx: Context) returns Str {
    mut lit := "(Bool){0}"
    if set_free { lit = "(Bool){1}" }
    ref fdef : Expr = find_callee_fdef(type_name.format("_delete"), ctx)
    if fdef.is_null() { return lit }
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        if fd.params.len() > 1 {
            ref p : Declaration = fd.params[1]
            if p.own_type.is(OwnType.Shallow).not() { return format("&", lit) }
        }
        return lit
    case:
        return lit
    }
}

priv callee_param_is_shallow := func(callee_name: Str, arg_index: USize, ctx: Context) returns Bool {
    ref fdef : Expr = find_callee_fdef(callee_name, ctx)
    if fdef.is_null() { return false }
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        if arg_index >= fd.params.len() { return false }
        if fd.params.len() == 0 { return false }
        return fd.params[arg_index].own_type.is(OwnType.Shallow)
    case:
        return false
    }
}

priv callee_param_is_usize := func(callee_name: Str, arg_index: USize, ctx: Context) returns Bool {
    ref fdef : Expr = find_callee_fdef(callee_name, ctx)
    if fdef.is_null() { return false }
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        if arg_index >= fd.params.len() { return false }
        return fd.params[arg_index].explicit_type == "USize"
    case:
        return false
    }
}

priv callee_param_is_uptr := func(callee_name: Str, arg_index: USize, ctx: Context) returns Bool {
    ref fdef : Expr = find_callee_fdef(callee_name, ctx)
    if fdef.is_null() { return false }
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        if arg_index >= fd.params.len() { return false }
        return fd.params[arg_index].explicit_type == "UPtr"
    case:
        return false
    }
}

priv callee_param_is_own := func(callee_name: Str, arg_index: USize, ctx: Context) returns Bool {
    ref fdef : Expr = find_callee_fdef(callee_name, ctx)
    if fdef.is_null() { return false }
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        if arg_index >= fd.params.len() { return false }
        return fd.params[arg_index].own_type.is(OwnType.Own)
    case:
        return false
    }
}

priv callee_param_explicit_type := func(callee_name: Str, arg_index: USize, ctx: Context) returns Str {
    ref fdef : Expr = find_callee_fdef(callee_name, ctx)
    if fdef.is_null() { return "" }
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        if arg_index >= fd.params.len() { return "" }
        ref p : Declaration = fd.params[arg_index]
        return p.explicit_type.clone()
    case:
        return ""
    }
}

priv fcall_is_shallow_return := func(fcall: Expr, ctx: Context) returns Bool {
    if fcall.node_type.is(NodeType.FCall).not() { return false }
    ref callee : Expr = fcall.children[0]
    switch callee.node_type {
    case NodeType.Ident(ident):
        if callee_returns_shallow(ident.ident_name(), ctx) { return true }
    case NodeType.FieldAccess(mname):
        sname := til_type_name(callee.children[0].expr_til_type())
        if sname.len() == 0 { return false }
        flat := sname.concat3("_", mname.field_access_name())
        if callee_returns_shallow(flat, ctx) { return true }
    case:
    }
    ref sig : Expr = fcall_fn_sig(fcall, ctx)
    if sig.is_null().not() {
        switch sig.node_type {
        case NodeType.FuncDef(sfd):
            return sfd.return_own_type.is(OwnType.Shallow)
        case:
        }
    }
    return false
}

priv fcall_returns_dynamic := func(fcall: Expr, ctx: Context) returns Bool {
    if fcall.node_type.is(NodeType.FCall).not() { return false }
    // Same override-aware short-circuit as fcall_is_shallow_return:
    // cast(e, T) is declared `returns shallow Dynamic` but the typer
    // sets the call's til_type to T. Trust the override.
    if fcall.expr_til_type().is(Type.Dynamic).not() { return false }
    ref callee_node : Expr = fcall.children[0]
    switch callee_node.node_type {
    case NodeType.FieldAccess(mname):
        sname := til_type_name(callee_node.children[0].expr_til_type())
        if sname.len() == 0 { return false }
        flat := sname.concat3("_", mname.field_access_name())
        return callee_returns_dynamic(flat, ctx)
    case NodeType.Ident(ident): return callee_returns_dynamic(ident.ident_name(), ctx)
    case:
        return false
    }
}

priv til_type_to_c := func(shallow t: Type) returns Str {
    switch t {
    case Type.Primitive(Primitive.I64):     return "I64"
    case Type.Primitive(Primitive.U8):      return "U8"
    case Type.Primitive(Primitive.I8):      return "I8"
    case Type.Primitive(Primitive.I16):     return "I16"
    case Type.Primitive(Primitive.U16):     return "U16"
    case Type.Primitive(Primitive.I32):     return "I32"
    case Type.Primitive(Primitive.U32):     return "U32"
    case Type.Primitive(Primitive.U64):     return "U64"
    case Type.Primitive(Primitive.F32):     return "F32"
    case Type.Primitive(Primitive.Bool):    return "Bool"
    case Type.None:    return "void"
    case Type.Dynamic: return "void *"
    case Type.FuncPtr:    return "TilClosure *"
    case Type.FuncPtrSig: return "TilClosure *"
    case Type.Body:       return "TilClosure *"
    case:                 return "I64"
    }
}

// Single source of truth for the set of primitive type names. The header
// emission passes seed their "already emitted / builtin scalar" sets with
// every primitive so they are not re-declared; centralizing the list here
// keeps adding a primitive a one-place edit instead of an N-place one
// (#115).
priv seed_primitive_names := func(mut emitted: Set(Str)) {
    emitted.add(own "U8"); emitted.add(own "I8"); emitted.add(own "I16"); emitted.add(own "U16"); emitted.add(own "I32")
    emitted.add(own "U32"); emitted.add(own "U64"); emitted.add(own "I64")
    emitted.add(own "F32"); emitted.add(own "Bool")
}

// Resolve the C type for an `extern` global decl. Replaces the
// `mut ctype := ""; if dyn { ... } else { ... }` reassign-leak
// pattern in emit_header_global_decls / emit_funcsig_typedefs.
priv extern_decl_ctype := func(shallow t: Type, shallow rhs_t: Type, ctx: Context) returns Str {
    if t.is(Type.Dynamic) { return til_type_to_c(t) }
    return c_type_name(t, til_type_name(rhs_t), ctx)
}

// Resolve the C type name for a Decl whose explicit_type may be empty.
// Skips the heap-allocated empty-Str dance from til_type_name when t isn't
// Struct/Enum/FuncPtr (where the name actually matters) -- saves the Str_lit("")
// leak per call.
priv resolve_decl_ctype := func(shallow t: Type, shallow rhs_t: Type, explicit: Str, ctx: Context) returns Str {
    if t.is(Type.Struct).or(t.is(Type.Enum)).or(t.is_funcptr()) {
        sn := til_type_name(t)
        if sn.len() > 0 { return c_type_name(t, sn, ctx) }
        sn2 := til_type_name(rhs_t)
        if sn2.len() > 0 { return c_type_name(t, sn2, ctx) }
        return c_type_name(t, explicit, ctx)
    }
    return c_type_name(t, "", ctx)
}

// #192: emit the C type for a struct field. USize/UPtr are target-dependent
// aliases; spell the field with the alias name (resolved by ext.h's typedef)
// rather than the concrete primitive from til_type, so the field's ABI width
// is governed solely by ext.h and stays consistent regardless of which
// compiler emits it. All other fields use their resolved primitive/struct.
priv field_emit_ctype := func(dd: Declaration) returns Str {
    if dd.explicit_type == "USize" { return "USize" }
    if dd.explicit_type == "UPtr" { return "UPtr" }
    return til_type_to_c(dd.til_type)
}

priv c_type_name := func(shallow t: Type, struct_name: Str, ctx: Context) returns Str {
    if t.is(Type.Struct).or(t.is(Type.Enum)) {
        if struct_name.is_null().not() {
            if struct_name.len() > 0 {
                return struct_name
            }
        }
    }
    if t.is_funcptr() {
        if struct_name.is_null().not() {
            if struct_name.len() > 0 {
                if is_funcsig_type(struct_name, ctx) { return struct_name }
            }
        }
    }
    if t.is(Type.Dynamic) { return "void" }
    return til_type_to_c(t)
}

priv func_to_c := func(name: Str) returns Str {
    if name == "double" { return "double_" }
    return name
}

priv type_name_to_c := func(name: Str, ctx: Context) returns Str {
    if name == "I64" { return "I64 *" }
    if name == "U8" { return "U8 *" }
    if name == "I8" { return "I8 *" }
    if name == "I16" { return "I16 *" }
    if name == "U16" { return "U16 *" }
    if name == "I32" { return "I32 *" }
    if name == "U32" { return "U32 *" }
    if name == "U64" { return "U64 *" }
    if name == "USize" { return "USize *" }
    if name == "UPtr" { return "UPtr *" }
    if name == "F32" { return "F32 *" }
    if name == "Bool" { return "Bool *" }
    if name == "Dynamic" { return "void *" }
    if name == "Fn" { return "TilClosure *" }
    if name == "Body" { return "TilClosure *" }
    if ctx.funcsig_names.has(name) { return name }
    return name.format(" *")
}

priv type_name_to_c_value := func(name: Str, ctx: Context) returns Str {
    if name == "I64" { return "I64" }
    if name == "U8" { return "U8" }
    if name == "I8" { return "I8" }
    if name == "I16" { return "I16" }
    if name == "U16" { return "U16" }
    if name == "I32" { return "I32" }
    if name == "U32" { return "U32" }
    if name == "U64" { return "U64" }
    if name == "USize" { return "USize" }
    if name == "UPtr" { return "UPtr" }
    if name == "F32" { return "F32" }
    if name == "Bool" { return "Bool" }
    if name == "Dynamic" { return "void *" }
    if name == "Fn" { return "TilClosure *" }
    if name == "Body" { return "TilClosure *" }
    if ctx.funcsig_names.has(name) { return name }
    return name
}

priv builder_is_type_gen_macro_def := func(fdef: Expr) returns Bool {
    if fdef.is_null() { return false }
    if fdef.node_type.is(NodeType.FuncDef).not() { return false }
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        if fd.func_type.is(FuncType.Macro).not() { return false }
        return fd.return_type.eq("StructDef")
            .or(fd.return_type.eq("EnumDef"))
            .or(fd.return_type.eq("FuncDef"))
    case:
    }
    return false
}

priv builder_variadic_array_type_name := func(ctx: Context, elem_type: Str) returns Str {
    concrete := format("Array__", elem_type)
    if ctx.scope.get_struct(concrete).is_null().not() { return concrete }
    ref array_func : Expr = ctx.scope.lookup_func("Array")
    if builder_is_type_gen_macro_def(array_func) { return concrete }
    if ctx.scope.get_struct("Array").is_null().not() { return "Array" }
    return concrete
}

priv builder_variadic_vec_type_name := func(ctx: Context, elem_type: Str) returns Str {
    concrete := format("Vec__", elem_type)
    if ctx.scope.get_struct(concrete).is_null().not() { return concrete }
    ref vec_func : Expr = ctx.scope.lookup_func("Vec")
    if builder_is_type_gen_macro_def(vec_func) { return concrete }
    if ctx.scope.get_struct("Vec").is_null().not() { return "Vec" }
    return concrete
}

priv builder_variadic_array_ctype := func(ctx: Context, elem_type: Str) returns Str {
    return type_name_to_c(builder_variadic_array_type_name(ctx, elem_type), ctx)
}

priv builder_variadic_vec_ctype := func(ctx: Context, elem_type: Str) returns Str {
    return type_name_to_c(builder_variadic_vec_type_name(ctx, elem_type), ctx)
}

priv enum_ctor_payload_is_own := func(callee_name: Str, fcall: Expr, ctx: Context) returns Bool {
    if fcall.children.len() != 2 { return false }
    ename := til_type_name(fcall.expr_til_type())
    if ename.len() == 0 { return false }
    prefix := format(ename, "_")
    if callee_name.starts_with(prefix).not() { return false }
    ref def : Expr = ctx.scope.get_struct(ename)
    if def.is_null() { return false }
    if def.node_type.is(NodeType.EnumDef).not() { return false }
    vname := callee_name.substr(prefix.len(), callee_name.len() - prefix.len())
    switch def.node_type {
    case NodeType.EnumDef(edd):
        for i in 0..edd.variants.len() {
            if edd.variants[i].eq(vname).not() { continue }
            vt := enum_variant_type(def, i.to_i32())
            if vt.len() == 0 { return false }
            if is_primitive_type(vt) { return false }
            if is_funcsig_type(vt, ctx).or(vt.eq("Dynamic")) { return false }
            return true
        }
    case:
    }
    return false
}

priv templated_container_method_arg_is_own := func(sname: Str, method: Str, arg_index: USize) returns Bool {
    if sname.starts_with("Vec").and(method.eq("push")).and(arg_index.eq(1)) { return true }
    if sname.starts_with("Set").and(method.eq("add")).and(arg_index.eq(1)) { return true }
    if sname.starts_with("Array").and(method.eq("set")).and(arg_index.eq(2)) { return true }
    if sname.starts_with("Map").and(method.eq("set")).and(arg_index.eq(2)) { return true }
    return false
}

priv templated_container_fcall_arg_is_own := func(callee_name: Str, arg_index: USize) returns Bool {
    if callee_name.starts_with("Vec__").and(callee_name.ends_with("_push")).and(arg_index.eq(1)) { return true }
    if callee_name.starts_with("Set__").and(callee_name.ends_with("_add")).and(arg_index.eq(1)) { return true }
    if callee_name.starts_with("Array__").and(callee_name.ends_with("_set")).and(arg_index.eq(2)) { return true }
    if callee_name.starts_with("Map__").and(callee_name.ends_with("_set")).and(arg_index.eq(2)) { return true }
    if callee_name.eq("push").and(arg_index.eq(1)) { return true }
    if callee_name.eq("add").and(arg_index.eq(1)) { return true }
    if callee_name.eq("set").and(arg_index.eq(2)) { return true }
    if callee_name.ends_with(".push").and(arg_index.eq(1)) { return true }
    if callee_name.ends_with(".add").and(arg_index.eq(1)) { return true }
    if callee_name.ends_with(".set").and(arg_index.eq(2)) { return true }
    return false
}

// Returns ref File so `f.emit_usize(v).write(...)` chains via UFCS.
priv emit_usize := proc(f: File, shallow v: USize) returns ref File {
    f.write(v.to_str())
    return f
}

// Returns ref File so `f.emit_i32(v).write(...)` chains via UFCS.
priv emit_i32 := proc(f: File, shallow v: I32) returns ref File {
    f.write(v.to_str())
    return f
}

priv emit_indent := proc(f: File, shallow depth: I32) returns ref File {
    for _ : I32 in 0..depth {
        f.write("    ")
    }
    return f
}

// Post-escape byte count for a source-form string literal: each `\n`,
// `\t`, `\xNN`, etc. collapses to one byte. The emitted `.count` must
// be this, not the source-form length.
priv c_lit_byte_count := func(s: Str) returns USize {
    n := s.len()
    mut count : USize = 0
    mut i : USize = 0
    while i < n {
        ref b : I8 = s.unsafe_get(i)
        if b.eq('\\').and(i.add(1).lt(n)) {
            ref nx : I8 = s.unsafe_get(i + 1)
            if nx.eq('x').and(i.add(3).lt(n)) {
                i = i + 4
                count++
                continue
            }
            i = i + 2
            count++
            continue
        }
        // str_to_source_form emits a `""` (close-quote + open-quote) after
        // every `\xNN` so the C lexer doesn't greedily consume following
        // hex/digit chars into the escape. The C compiler concatenates the
        // two adjacent literals and the `""` contributes zero bytes to the
        // resulting global array, so don't count them.
        if b.eq('"').and(i.add(1).lt(n)).and(s.unsafe_get(i + 1).eq('"')) {
            i = i + 2
            continue
        }
        i++
        count++
    }
    return count
}

// Collect every Ident reference under `e` into `refs`. Used by the
// function-body entry pass to decide which params actually need the
// `(void)<name>;` unused-arg suppressor.
priv collect_ident_refs := proc(e: Expr, mut refs: Set(Str)) {
    expect(e.is_null().not(), "e is null")
    switch e.node_type {
    case NodeType.Ident(name): refs.add(own Str.clone(name.ident_name()))
    case NodeType.Assign(ad):  refs.add(own ad.name.clone())
    case:
    }
    for c : Expr in e.children {
        collect_ident_refs(c, refs)
    }
}

priv emit_til_default := proc(f: File, shallow t: Type) {
    if type_is_primitive(t, Primitive.Bool) {
        f.write("false")
    } else if is_primitive(t) {
        f.write("0")
    } else if t.is(Type.Struct).or(t.is(Type.Enum)) {
        name := til_type_name(t)
        if name == "Str" {
            f.write("\"\"")
        } else if name.len() > 0 {
            f.write(name)
            f.write("()")
        } else {
            f.write("0")
        }
    } else {
        f.write("0")
    }
}

// Resolve the C parameter type for fd.params[i]. Avoids the
// `mut ptype := ""` pre-init pattern in emit_param_list, whose empty
// Str leaked once per parameter on each call.
priv param_ctype := func(fd: FunctionDef, i: USize, ctx: Context) returns Str {
    ii := i.to_i32()
    ref p : Declaration = fd.params[i]
    if ii == fd.variadic_index { return builder_variadic_array_ctype(ctx, p.explicit_type) }
    if ii == fd.kwargs_index { return type_name_to_c(p.explicit_type, ctx) }
    if p.own_type.is(OwnType.Shallow) { return type_name_to_c_value(p.explicit_type, ctx) }
    return type_name_to_c(p.explicit_type, ctx)
}

priv emit_param_list := proc(f: File, fdef: Expr, with_names: Bool, for_ext_decl: Bool, ctx: Context) {
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        if fd.params.len() == 0 {
            f.write("void")
        } else {
            for i in 0..fd.params.len() {
                if i > 0 { f.write(", ") }
                ii := i.to_i32()
                // Issue #176 bullet 1: emit `const` for non-mut Ref pointer
                // params at the FFI boundary. Variadic / kwargs are excluded
                // (their C type is fixed by codegen, not the user's qualifier);
                // shallow / own params are excluded (const adds nothing or is
                // wrong). `mut` stays as the escape hatch.
                mut const_prefix := false
                if for_ext_decl.and(ii.neq(fd.variadic_index)).and(ii.neq(fd.kwargs_index)) {
                    ref pp : Declaration = fd.params[i]
                    if pp.own_type.is(OwnType.Ref).and(pp.is_mut.not()) {
                        const_prefix = true
                    }
                }
                ptype := param_ctype(fd, i, ctx)
                if with_names {
                    if const_prefix { f.write("const ") }
                    f.write(ptype)
                    f.write(" ")
                    f.write(fd.params[i].name)
                } else {
                    if const_prefix { f.write("const ") }
                    f.write(ptype)
                }
            }
        }
    case:
        UNREACHABLE()
    }
}

priv collect_dyn_methods := proc(e: Expr, mut methods: Vec(DynCallInfo)) {
    expect(e.is_null().not(), "e is null")
    if e.node_type.is(NodeType.FCall) {
        if e.children.len() >= 3 {
            switch e.children[0].node_type {
            case NodeType.Ident(callee_name):
                switch e.children[2].node_type {
                case NodeType.Literal(Literal.Str(method)):
                    ref cn : Str = callee_name.ident_name()
                    mut has_ret := false
                    if cn == "dyn_call_ret" { has_ret = true }
                    if cn.eq("dyn_call").or(cn.eq("dyn_call_ret")) {
                        mut nargs : I32 = 1
                        if e.children.len() >= 4 {
                            switch e.children[3].node_type {
                            case NodeType.Literal(Literal.Num(num_str)):
                                nargs = num_str.literal_num_text().to_i32()
                            case:
                            }
                        }
                        mut found := false
                        for existing : DynCallInfo in methods {
                            if existing.method == method { found = true }
                        }
                        if found.not() {
                            info := DynCallInfo(method = method, nargs = nargs, has_return = has_ret)
                            methods.push(own info)
                        }
                    }
                case:
                }
            case:
            }
        }
    }
    if e.node_type.is(NodeType.StructDef).or(e.node_type.is(NodeType.EnumDef)) {
        ref cdm_ns : Vec(Declaration) = def_ns_decls(e)
        for cdm_d : Declaration in cdm_ns {
            if cdm_d.default_value.is_null().not() {
                collect_dyn_methods(cdm_d.default_value, methods)
            }
        }
    }
    for e_ci : Expr in e.children {
        collect_dyn_methods(e_ci, methods)
    }
}

priv collect_collection_builtins := proc(e: Expr, mut infos: Vec(CollectionInfo)) {
    expect(e.is_null().not(), "e is null")
    if e.node_type.is(NodeType.FCall) {
        if e.children.len() >= 2 {
            switch e.children[0].node_type {
            case NodeType.Ident(name):
                mut is_vec : I32 = -1
                if name.ident_name() == "array" { is_vec = 0 }
                else if name.ident_name() == "vec" { is_vec = 1 }
                if is_vec >= 0 {
                    type_name := array_vec_elem_type_name(e)
                    if type_name.len() > 0 {
                        mut found := false
                        for existing : CollectionInfo in infos {
                            if existing.type_name == type_name {
                                if existing.is_vec == is_vec { found = true }
                            }
                        }
                        if found.not() {
                            info := CollectionInfo(type_name = type_name, is_vec = is_vec)
                            infos.push(own info)
                        }
                    }
                }
            case:
            }
        }
    }
    if e.node_type.is(NodeType.StructDef).or(e.node_type.is(NodeType.EnumDef)) {
        ref ccb_ns : Vec(Declaration) = def_ns_decls(e)
        for ccb_d : Declaration in ccb_ns {
            if ccb_d.default_value.is_null().not() {
                collect_collection_builtins(ccb_d.default_value, infos)
            }
        }
    }
    for e_ci : Expr in e.children {
        collect_collection_builtins(e_ci, infos)
    }
}

priv emit_field := proc(f: File, var: Str, field: Str, ctx: Context) {
    f.write(var)
    // Issue #223 step 3: shallow (value) params join stack locals / value
    // globals on the dot-access path.
    if is_stack_local(var, ctx).or(is_value_global(var, ctx)).or(is_shallow_param(var, ctx)) {
        f.write(".")
    } else {
        f.write("->")
    }
    f.write(field)
}

priv get_stack_local_ctype := func(name: Str, ctx: Context) returns ref Str {
    ref m : Map(Str, Str) = ctx.builder_func.stack_local_types
    if m.has(name) {
        return m[name]
    }
    return NULL
}

priv resolve_callee_name := ext_func(fcall: Expr) returns Str {}

priv resolve_callee_name := func(fcall: Expr) returns Str {
    ref callee_node : Expr = fcall.children[0]
    switch callee_node.node_type {
    case NodeType.FieldAccess(mname):
        sname := til_type_name(callee_node.children[0].expr_til_type())
        if sname.len() == 0 { return "" }
        return sname.concat3("_", mname.field_access_name())
    case NodeType.Ident(ident): return Str.clone(ident.ident_name())
    case:
        return ""
    }
}

priv fcall_return_ctype := func(fcall: Expr, ctx: Context) returns Str {
    if fcall.node_type.is(NodeType.FCall).not() { return "" }
    callee := resolve_callee_name(fcall)
    if callee.len() == 0 { return "" }
    // cast(e, T) is declared `returns shallow Dynamic` but the typer
    // narrows the FCall's til_type to T. For such typer-overridden
    // Dynamic returns, prefer the concrete C type (otherwise we get
    // "void *" from callee_return_ctype). Limited to the Dynamic case
    // so struct-returning calls (like Array_new) keep their lookup.
    if callee_returns_dynamic(callee, ctx) {
        t := fcall.expr_til_type()
        if t.is(Type.Unknown).not().and(t.is(Type.Dynamic).not()) {
            return til_type_to_c(t)
        }
    }
    ref fdef : Expr = find_callee_fdef(callee, ctx)
    if fdef.is_null() { return "" }
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        if fd.return_type.len() == 0 { return "" }
        return type_name_to_c_value(fd.return_type, ctx)
    case:
        return ""
    }
}

priv fcall_has_inline_capturing_func_arg := func(e: Expr) returns Bool {
    if e.node_type.is(NodeType.FCall).not() { return false }
    for i in 1..e.children.len() {
        ref arg : Expr = e.children[i]
        switch arg.node_type {
        case NodeType.FuncDef(fd):
            if fd.captures.len() > 0 { return true }
        case:
        }
    }
    return false
}

priv emit_til_closure_cleanup := proc(f: File, name: Str) {
    f.fwrite("if (", name, " && ", name, "->drop) { ", name, "->drop(", name, "->env); free(", name, "); }")
}

priv emit_user_fcall_args := proc(f: File, e: Expr, callee_name: Str, depth: I32, ctx: Context, wrap_inline_closures: Bool) {
    for i in 1..e.children.len() {
        if i > 1 { f.write(", ") }
        ref arg : Expr = e.children[i]
        mut emitted_inline_closure := false
        if wrap_inline_closures {
            switch arg.node_type {
            case NodeType.FuncDef(fd):
                if fd.captures.len() > 0 {
                    f.write("til_closure_arg_"); emit_i32(f, i.to_i32())
                    emitted_inline_closure = true
                }
            case:
            }
        }
        if emitted_inline_closure { continue }
        if callee_param_is_shallow(callee_name, i - 1, ctx) {
            emit_deref(f, arg, depth, ctx)
        } else if callee_param_is_usize(callee_name, i - 1, ctx).and(callee_param_is_own(callee_name, i - 1, ctx).not()) {
            f.write("USIZE_REF(").emit_deref(arg, depth, ctx).write(")")
        } else if callee_param_is_uptr(callee_name, i - 1, ctx).and(callee_param_is_own(callee_name, i - 1, ctx).not()) {
            f.write("UPTR_REF(").emit_deref(arg, depth, ctx).write(")")
        } else {
            mut own_arg := get_own_arg(e, i)
            if templated_container_fcall_arg_is_own(callee_name, i - 1) { own_arg = true }
            saved_force_heap := ctx.builder_func.force_heap_stack_lit_str_own
            if own_arg.and(callee_param_explicit_type(callee_name, i - 1, ctx).eq("Dynamic")) {
                ctx.builder_func.force_heap_stack_lit_str_own = true
            }
            emit_as_ptr(f, arg, depth, own_arg, ctx)
            ctx.builder_func.force_heap_stack_lit_str_own = saved_force_heap
        }
    }
}

priv emit_user_fcall_with_inline_closure_cleanup := proc(f: File, e: Expr, source_name: Str, cname: Str, depth: I32, ctx: Context) {
    f.write("({ ")
    for i in 1..e.children.len() {
        ref arg : Expr = e.children[i]
        switch arg.node_type {
        case NodeType.FuncDef(fd):
            if fd.captures.len() > 0 {
                f.write("TilClosure *til_closure_arg_"); emit_i32(f, i.to_i32()); f.write(" = ")
                emit_expr(f, arg, depth, ctx)
                f.write("; ")
            }
        case:
        }
    }
    ret_ctype := fcall_return_ctype(e, ctx)
    if ret_ctype.len() > 0 { f.fwrite(ret_ctype, " til_closure_result = ") }
    f.fwrite(cname, "(")
    emit_user_fcall_args(f, e, source_name, depth, ctx, true)
    f.write("); ")
    for i2 in 1..e.children.len() {
        switch e.children[i2].node_type {
        case NodeType.FuncDef(fd2):
            if fd2.captures.len() > 0 {
                emit_til_closure_cleanup(f, format("til_closure_arg_", i2.to_str()))
                f.write(" ")
            }
        case:
        }
    }
    if ret_ctype.len() > 0 { f.write("til_closure_result; ") }
    f.write("})")
}

priv check_fcall_mut_args := proc(ctx: Context, e: Expr) {
    expect(e.is_null().not(), "e is null")
    if e.node_type.is(NodeType.FCall) {
        ref mut fdef : Expr = fcall_fn_sig(e, ctx)
        if fdef.is_null() {
            callee := resolve_callee_name(e)
            if callee.len() > 0 {
                fdef = find_callee_fdef(callee, ctx)
            }
        }
        if fdef.is_null().not() {
            switch fdef.node_type {
            case NodeType.FuncDef(fd):
                if fd.params.len() > 0 {
                    for a in 1..e.children.len() {
                        pi := a - 1
                        if pi < fd.params.len() {
                            if fd.params[pi].is_mut {
                                switch e.children[a].node_type {
                                case NodeType.Ident(arg_name):
                                    ctx.builder_func.unsafe_to_hoist.add(own Str.clone(arg_name.ident_name()))
                                case:
                                }
                            }
                        }
                    }
                }
            case:
            }
        }
    }
    for e_ci : Expr in e.children {
        check_fcall_mut_args(ctx, e_ci)
    }
}

priv collect_unsafe_to_hoist := proc(ctx: Context, body: Expr) {
    for stmt : Expr in body.children {
        check_fcall_mut_args(ctx, stmt)
        if stmt.node_type.is(NodeType.Decl) {
            switch stmt.node_type {
            case NodeType.Decl(dd):
                if dd.own_type.is(OwnType.Ref) {
                    ref rhs : Expr = stmt.children[0]
                    switch rhs.node_type {
                    case NodeType.Ident(rhs_name):
                        ctx.builder_func.unsafe_to_hoist.add(own Str.clone(rhs_name.ident_name()))
                    case NodeType.FCall:
                        callee := resolve_callee_name(rhs)
                        if callee.len() > 0 {
                            ref fdef : Expr = find_callee_fdef(callee, ctx)
                            if fdef.is_null().not() {
                                switch fdef.node_type {
                                case NodeType.FuncDef(fd):
                                    if fd.return_own_type.is(OwnType.Ref) {
                                        for a in 1..rhs.children.len() {
                                            switch rhs.children[a].node_type {
                                            case NodeType.Ident(arg_name):
                                                ctx.builder_func.unsafe_to_hoist.add(own Str.clone(arg_name.ident_name()))
                                            case:
                                            }
                                        }
                                    }
                                case:
                                }
                            }
                        }
                    case:
                    }
                }
            case:
                UNREACHABLE()
            }
        }
        if stmt.node_type.is(NodeType.If) {
            for c in 1..stmt.children.len() {
                collect_unsafe_to_hoist(ctx, stmt.children[c])
            }
        }
        if stmt.node_type.is(NodeType.While) {
            if stmt.children.len() > 1 {
                collect_unsafe_to_hoist(ctx, stmt.children[1])
            }
        }
        if stmt.node_type.is(NodeType.Body) {
            collect_unsafe_to_hoist(ctx, stmt)
        }
    }
}

priv builder_reset_func_scratch := func(mut ctx: Context) {
    ctx.builder_func.stack_locals = Set(Str).new()
    ctx.builder_func.stack_local_types = Map(Str, Str).new()
    ctx.builder_func.stack_lit_str_locals = Set(Str).new()
    ctx.builder_func.force_heap_stack_lit_str_own = false
    ctx.builder_func.unsafe_to_hoist = Set(Str).new()
    ctx.builder_func.ref_locals = Set(Str).new()
    ctx.builder_func.ref_dyn_locals = Set(Str).new()
    ctx.builder_func.ptr_locals = Set(Str).new()
    ctx.builder_func.local_fn_sigs = Map(Str, Dynamic).new()
}

priv builder_is_hoisted_str_lit_ident := func(name: Str) returns Bool {
    return name.starts_with("hoisted__Str_")
}

priv builder_reset_str_lit_pool := func(mut ctx: Context) {
    ctx.builder_str_lit_symbols = Map(Str, Str).new()
    ctx.builder_str_lit_values = Vec(Str).new()
    ctx.builder_str_lit_ident_symbols = Map(Str, Str).new()
}

priv builder_register_str_lit := func(mut ctx: Context, s: Str) returns Str {
    if ctx.builder_str_lit_symbols.has(s) { return ctx.builder_str_lit_symbols[s].clone() }
    sym := format("_til_str_lit_", ctx.builder_str_lit_values.len().to_str())
    ctx.builder_str_lit_symbols.set(s, own sym.clone())
    ctx.builder_str_lit_values.push(own s.clone())
    return sym
}

priv builder_register_str_lit_ident := func(mut ctx: Context, name: Str, s: Str) {
    sym := builder_register_str_lit(ctx, s)
    if ctx.builder_str_lit_ident_symbols.has(name).not() { ctx.builder_str_lit_ident_symbols.set(name, own sym) }
}

priv builder_resolve_c_ident_name := func(name: Str, ctx: Context) returns Str {
    if ctx.builder_str_lit_ident_symbols.has(name) { return ctx.builder_str_lit_ident_symbols[name].clone() }
    return name.clone()
}

priv builder_emit_str_lit_decl := proc(f: File, name: Str, s: Str) {
    f.write("static __attribute__((unused)) Str ").write(name).write(" = (Str){.c_str = (void *)\"")
    f.write(s)
    f.write("\", .count = ")
    emit_usize(f, c_lit_byte_count(s))
    f.write("ULL, .cap = TIL_CAP_LIT};\n")
}

priv builder_register_str_lits_for_expr := proc(e: Expr, mut ctx: Context) {
    expect(e.is_null().not(), "e is null")
    switch e.node_type {
    case NodeType.Decl(dd):
        if e.children.len().gt(0) {
            ref rhs : Expr = e.children[0]
            switch rhs.node_type {
            case NodeType.Literal(Literal.Str(s)):
                builder_register_str_lit(ctx, s)
                if dd.is_mut.not().and(builder_is_hoisted_str_lit_ident(dd.name)) {
                    builder_register_str_lit_ident(ctx, dd.name, s)
                }
            case NodeType.StructDef(sd):
                for field : Declaration in sd.fields {
                    builder_register_str_lit(ctx, field.name)
                    builder_register_str_lit(ctx, field.explicit_type)
                }
            case NodeType.EnumDef(ed):
                for i in 0..ed.variants.len() {
                    builder_register_str_lit(ctx, ed.variants[i])
                    idx := i.to_i64()
                    if ed.payload_types.has(idx) { builder_register_str_lit(ctx, ed.payload_types[idx]) }
                }
                builder_register_str_lit(ctx, "")
            case NodeType.FuncDef(fd):
                if rhs.children.len().eq(0) {
                    for p : Declaration in fd.params { builder_register_str_lit(ctx, p.explicit_type) }
                    if fd.return_type.len().gt(0) { builder_register_str_lit(ctx, fd.return_type) }
                    for tt : Str in fd.throw_types { builder_register_str_lit(ctx, tt) }
                }
            case:
            }
        }
    case:
        switch e.node_type {
        case NodeType.Literal(Literal.Str(s2)):
            builder_register_str_lit(ctx, s2)
        case:
        }
    }
    for child : Expr in e.children { builder_register_str_lits_for_expr(child, ctx) }
}

priv builder_register_dyn_type_to_str_lits := func(lp: LoadedProgram) {
    mut variant_names := Vec(Str).new()
    mut variant_types := Vec(Str).new()
    if find_loaded_enum_variants("Type", variant_names, variant_types, lp).not() { return }
    for j in 0..variant_names.len() {
        ref vn : Str = variant_names[j]
        ref vt : Str = variant_types[j]
        if vt.len().eq(0) {
            display := dyn_type_str_display(vn)
            builder_register_str_lit(lp.ctx, display)
        } else if vt.eq("Str") {
        } else {
            mut inner_names := Vec(Str).new()
            mut inner_types := Vec(Str).new()
            if find_loaded_enum_variants(vt, inner_names, inner_types, lp) {
                for ivn : Str in inner_names { builder_register_str_lit(lp.ctx, ivn) }
            }
        }
    }
    builder_register_str_lit(lp.ctx, "?")
}

priv builder_register_str_lits := proc(lp: LoadedProgram) {
    builder_reset_str_lit_pool(lp.ctx)
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            builder_register_str_lits_for_expr(iu.ast, lp.ctx)
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        builder_register_str_lits_for_expr(iu.ast, lp.ctx)
    }
    builder_register_dyn_type_to_str_lits(lp)
}

priv builder_emit_str_lit_pool := proc(f: File, ctx: Context) {
    for i in 0..ctx.builder_str_lit_values.len() {
        ref val : Str = ctx.builder_str_lit_values[i]
        ref sym : Str = ctx.builder_str_lit_symbols[val]
        builder_emit_str_lit_decl(f, sym, val)
    }
    if ctx.builder_str_lit_values.len().gt(0) { f.write("\n") }
}

priv collect_dyn_has_methods := proc(e: Expr, mut methods: Vec(Str)) {
    expect(e.is_null().not(), "e is null")
    if e.node_type.is(NodeType.FCall) {
        if e.children.len() >= 3 {
            switch e.children[0].node_type {
            case NodeType.Ident(cname):
                if cname.ident_name() == "dyn_has_method" {
                    switch e.children[2].node_type {
                    case NodeType.Literal(Literal.Str(method)):
                        mut found := false
                        for existing : Str in methods {
                            if existing == method { found = true }
                        }
                        if found.not() {
                            methods.push(own method.clone())
                        }
                    case:
                    }
                }
            case:
            }
        }
    }
    if e.node_type.is(NodeType.StructDef).or(e.node_type.is(NodeType.EnumDef)) {
        ref cdh_ns : Vec(Declaration) = def_ns_decls(e)
        for cdh_d : Declaration in cdh_ns {
            if cdh_d.default_value.is_null().not() {
                collect_dyn_has_methods(cdh_d.default_value, methods)
            }
        }
    }
    for e_ci : Expr in e.children {
        collect_dyn_has_methods(e_ci, methods)
    }
}

// True when `e` is a struct constructor FCall (callee is the
// struct-name Ident), not a method call like Point.clone(...) whose
// callee is a FieldAccess. The POD compound-literal path uses this
// to decide whether the FCall's children are positional field
// initializers (ctor) vs an arbitrary call (which would type-clash
// inside a `.field = ...` initializer).
priv fcall_is_struct_ctor := func(e: Expr) returns Bool {
    if e.node_type.is(NodeType.FCall).not() { return false }
    if e.children.len() == 0 { return false }
    sname := til_type_name(e.expr_til_type())
    if sname.len() == 0 { return false }
    switch e.children[0].node_type {
    case NodeType.Ident(ci): return ci.ident_name() == sname
    case:
    }
    return false
}

// True when every FCall arg of `ctor` is either non-FCall or itself a
// POD-struct ctor (recursively safe). The POD compound-literal path
// requires this -- a non-ctor FCall arg (e.g. Point.clone(...)) would
// either type-clash with the positional field assumption or return a
// pointer that can't be assigned into a value field.
priv pod_ctor_args_are_safe := func(ctor: Expr, ctx: Context) returns Bool {
    for i in 1..ctor.children.len() {
        ref arg : Expr = ctor.children[i]
        if arg.node_type.is(NodeType.FCall).not() { continue }
        if fcall_is_struct_ctor(arg).not() { return false }
        arg_sname := til_type_name(arg.expr_til_type())
        if is_pod_struct(arg_sname, ctx).not() { return false }
        if pod_ctor_args_are_safe(arg, ctx).not() { return false }
    }
    return true
}

// Emit a C compound literal initializer for a POD-struct ctor FCall:
// `(Type){.f1 = v1, .f2 = v2, ...}`.  Nested POD ctor args recurse so
// `(Line){.start = (Point){.x = ..., .y = ...}, .end = ...}` works.
// Caller must have verified is_pod_struct(ctor type, ctx) AND
// pod_ctor_args_are_safe(ctor, ctx). Caller is responsible for trailing
// punctuation -- this emits the `(...){...}` expression with no
// semicolon.
priv emit_pod_compound_literal := proc(f: File, ctor: Expr, depth: I32, ctx: Context) {
    ctor_sname := til_type_name(ctor.expr_til_type())
    ctype := c_type_name(ctor.expr_til_type(), ctor_sname, ctx)
    f.write("(").write(ctype).write("){")
    ref pod_def : Expr = find_struct_def(ctor_sname, ctx)
    if pod_def.is_null().not() {
        switch pod_def.node_type {
        case NodeType.StructDef(pod_sdd):
            mut pod_fi : USize = 0
            for i in 1..ctor.children.len() {
                if i > 1 { f.write(", ") }
                mut pod_fname := ""
                if pod_fi < pod_sdd.fields.len() {
                    pod_fname = pod_sdd.fields[pod_fi].name
                    pod_fi++
                }
                f.write(".").write(pod_fname).write(" = ")
                ref arg : Expr = ctor.children[i]
                if fcall_is_struct_ctor(arg) {
                    emit_pod_compound_literal(f, arg, depth, ctx)
                } else {
                    emit_deref(f, arg, depth, ctx)
                }
            }
        case:
        }
    }
    f.write("}")
}

// Emit layer
priv emit_stmt_decl := proc(f: File, e: Expr, depth: I32, ctx: Context) {
    if e.children.len() == 0 { return }
    switch e.node_type {
    case NodeType.Decl(dd):
    ref rhs : Expr = e.children[0]
    // #220: any decl inside a function body introduces a local that
    // shadows a same-named script global. is_global / is_rg below are
    // both gated on ctx.in_func_def.not(), so inside a function every
    // decl is emitted as a local -- record the name so the use-site
    // classifiers (is_value_global / is_ref_global) don't mistake it for
    // the global and emit `.`/`&`/value-return against a local. ptr_locals
    // is consulted ONLY by those two classifiers, so this is surgical:
    // it changes the global-vs-local decision and nothing else. (stack_locals
    // and ref_locals already cover their own cases; adding here is harmless
    // overlap.)
    if ctx.in_func_def { ctx.builder_func.ptr_locals.add(own dd.name.clone()) }
    // For any FuncPtr-typed decl (own, ref, or value), capture the local's
    // signature so fcall_fn_sig can recover it at the eventual call site.
    // The original typer scope where `dd` lived is gone by emit time, so we
    // pin the FuncDef pointer here while we still have access to the rhs.
    if e.expr_til_type().is_funcptr() {
        ref decl_sig : Expr = resolve_decl_fn_sig(rhs, dd, ctx.scope, ctx)
        if decl_sig.is_null().not() {
            sig_buf : Dynamic = malloc(I64.size().cast(U64))
            write_ptr(sig_buf, decl_sig)
            ref mut m : Map(Str, Dynamic) = ctx.builder_func.local_fn_sigs
            m.set(dd.name, own sig_buf)
        }
    }
    mut rhs_is_capturing_func := false
    switch rhs.node_type {
    case NodeType.FuncDef(rhs_fd): rhs_is_capturing_func = rhs_fd.captures.len() > 0
    case:
    }
    if e.expr_til_type().is_funcptr().and(dd.own_type.is(OwnType.Ref).not()).and(rhs.node_type.is(NodeType.FuncDef).not().or(rhs_is_capturing_func)) {
        mut ct := "void *"
        mut is_typedef := false
        // Issue #58 / #147 step 5: the FuncSig alias name now lives on
        // the type itself (Type.FuncPtrSig(name)). til_type_name extracts
        // it for FuncPtrSig and returns "" for the bare Type.FuncPtr
        // (anonymous), so the empty-check below correctly skips the
        // typedef branch for un-named function-pointer locals -- same
        // gate the previous `is_funcsig_type(dd.explicit_type, ctx)`
        // check effectively gave, but read from til_type instead of from
        // Declaration.explicit_type (#147 step 5 path).
        sig_name := til_type_name(e.expr_til_type())
        if sig_name.len() > 0 {
            ct = sig_name
            is_typedef = true
        }
        // Issue #236: a script-global FuncPtr decl already has its
        // `void * X;` emitted by emit_globals; the init in main() must
        // be a plain assignment so we don't shadow it with a local
        // (which trips -Werror=unused-variable and leaves the global
        // unset). Same gate the non-FuncPtr branch below uses.
        is_global_fp := is_value_global(dd.name, ctx).and(ctx.in_func_def.not())
        if is_global_fp { f.write(dd.name).write(" = ") }
        else if is_typedef { f.fwrite(ct, " ", dd.name, " = ") }
        else { f.fwrite(ct, dd.name, " = ") }
        emit_expr(f, rhs, depth, ctx); f.write(";\n")
    } else if e.expr_til_type().is(Type.Body).and(dd.own_type.is(OwnType.Ref).not()) {
        is_global_body := is_value_global(dd.name, ctx).and(ctx.in_func_def.not())
        if is_global_body { f.write(dd.name).write(" = ") }
        else { f.write("TilClosure *").write(dd.name).write(" = ") }
        emit_expr(f, rhs, depth, ctx); f.write(";\n")
    } else if rhs.node_type.is(NodeType.FuncDef) {
        f.fwrite("/* TODO: nested func ", dd.name, " */\n")
    } else if rhs.node_type.is(NodeType.StructDef).or(rhs.node_type.is(NodeType.EnumDef)) {
        f.write("/* ")
        if rhs.node_type.is(NodeType.EnumDef) { f.write("enum") } else { f.write("struct") }
        f.fwrite(" ", dd.name, " defined above */\n")
    } else if e.expr_til_type().is(Type.None).and(rhs.node_type.is(NodeType.Ident)) {
        // REM Type alias -- no-op
    } else {
        if dd.own_type.is(OwnType.Ref) {
            is_rg := is_ref_global(dd.name, ctx).and(ctx.in_func_def.not())
            if is_rg.not() {
                ctx.builder_func.ref_locals.add(own dd.name.clone())
                // #185: track ref-Dynamic locals so emit_deref can typed-
                // cast at use sites where narrow_dynamic has retyped the
                // Ident to a concrete primitive.
                if dd.explicit_type == "Dynamic" {
                    ctx.builder_func.ref_dyn_locals.add(own dd.name.clone())
                }
            }
            ctype := resolve_decl_ctype(e.expr_til_type(), rhs.expr_til_type(), dd.explicit_type, ctx)
            if is_rg { f.write(dd.name).write(" = ") }
            else { f.fwrite(ctype, " *", dd.name, " = ") }
            emit_as_ptr(f, rhs, depth, false, ctx); f.write(";\n")
            // `_x` Ref decls (e.g. switch-case payload binds named `_s`)
            // are til's deliberately-unused convention; the typer skips
            // them in check_unused_locals, so we need a (void) guard to
            // keep C's -Wunused-variable quiet.
            if dd.name.starts_with("_").or(dd.name.starts_with("hoisted__")) {
                emit_indent(f, depth); f.write("(void)").write(builder_resolve_c_ident_name(dd.name, ctx)).write(";\n")
            }
        } else {
            ctype := resolve_decl_ctype(e.expr_til_type(), rhs.expr_til_type(), dd.explicit_type, ctx)
            is_global := is_value_global(dd.name, ctx).and(ctx.in_func_def.not())
            if e.expr_til_type().is(Type.Dynamic) {
                if is_global { f.write(dd.name).write(" = ") }
                else { tc := til_type_to_c(e.expr_til_type()); f.fwrite(tc, " ", dd.name, " = ") }
                emit_deref(f, rhs, depth, ctx); f.write(";\n")
            } else {
                can_hoist := is_global.not().and(dd.own_type.is(OwnType.Own).not())
                .and(e.expr_til_type().is_funcptr().not()).and(e.expr_til_type().is(Type.Dynamic).not())
                .and(rhs.node_type.is(NodeType.FCall).and(fcall_returns_dynamic(rhs, ctx)).not())
                // Struct constructor
                rhs_sname := til_type_name(rhs.expr_til_type())
                mut is_ctor := rhs.node_type.is(NodeType.FCall).and(rhs_sname.len().gt(0))
                if is_ctor {
                    if rhs.children.len() > 0 {
                        switch rhs.children[0].node_type {
                        case NodeType.Ident(ci):
                            is_ctor = ci.ident_name() == rhs_sname
                        case:
                            is_ctor = false
                        }
                    } else { is_ctor = false }
                }
                if is_ctor {
                    if is_global {
                        f.fwrite("memset(&", dd.name, ", 0, sizeof(", ctype, "));\n")
                        emit_ctor_fields(f, dd.name, rhs, depth, ctx)
                    } else if is_pod_struct(rhs_sname, ctx).and(pod_ctor_args_are_safe(rhs, ctx)) {
                        // POD struct ctor: emit as a stack value
                        // initialized with a C compound literal,
                        // mirroring the LiteralStr Decl path. Matching
                        // delete is forced to call_free=false in the
                        // shim at emit_stmt (NodeType.FCall case) so
                        // we never call free() on the stack pointer.
                        f.write(ctype).write(" ").write(dd.name).write(" = ")
                        emit_pod_compound_literal(f, rhs, depth, ctx)
                        f.write(";\n")
                        ctx.builder_func.stack_locals.add(own dd.name.clone())
                        ctx.builder_func.stack_local_types.set(dd.name, own ctype.clone())
                    } else {
                        f.write(ctype).write(" *").write(dd.name).write(" = malloc(sizeof(").write(ctype).write("));\n")
                        emit_ctor_fields(f, dd.name, rhs, depth, ctx)
                    }
                } else if rhs.node_type.is_literal_str().and(is_global.not()) {
                    // Str literal: emit a wrapper value -- no malloc, no Str_lit. Pairs with the
                    // typer's hoist/promote pass keeping LiteralStr decls
                    // Shallow so make_delete_call emits call_free=false and
                    // the existing FCall-arg emission writes `&name` for
                    // non-own slots. For own-taking callees (Array_set,
                    // Vec_push, etc.) emit_as_ptr's stack_local + is_own=true
                    // branch does the usual malloc round-trip so `free(own
                    // val)` still operates on a heap wrapper.
                    if dd.is_mut.not().and(ctx.builder_str_lit_ident_symbols.has(dd.name)) {
                        f.write("(void)").write(builder_resolve_c_ident_name(dd.name, ctx)).write(";\n")
                    } else {
                        if dd.is_mut.not() { f.write("static ") }
                        f.write(ctype).write(" ").write(dd.name).write(" = (Str){.c_str = (void *)\"")
                        switch rhs.node_type {
                        case NodeType.Literal(Literal.Str(s)):
                            f.write(s)
                            f.write("\", .count = ")
                            emit_usize(f, c_lit_byte_count(s))
                        case:
                        }
                        f.write("ULL, .cap = TIL_CAP_LIT};\n")
                    }
                    ctx.builder_func.stack_locals.add(own dd.name.clone())
                    ctx.builder_func.stack_local_types.set(dd.name, own ctype.clone())
                    if dd.is_mut.not() { ctx.builder_func.stack_lit_str_locals.add(own dd.name.clone()) }
                } else if rhs.node_type.is(NodeType.FCall).or(rhs.node_type.is_literal_str())
                .or(rhs.node_type.is(NodeType.FieldAccess).and(builder_fa_is_ns(rhs, ctx)).and(rhs.expr_til_type().is(Type.Enum))) {
                    if is_global {
                        if rhs.node_type.is(NodeType.FCall).and(fcall_is_shallow_return(rhs, ctx)) {
                            f.write(dd.name).write(" = "); emit_expr(f, rhs, depth, ctx); f.write(";\n")
                        } else if rhs.node_type.is(NodeType.FCall) {
                            mut htype := fcall_return_ctype(rhs, ctx)
                            if htype.len() == 0 { htype = ctype.clone() }
                            f.write("{ ").write(htype).write(" *_hp = (").write(htype).write(" *)")
                            emit_expr(f, rhs, depth, ctx)
                            f.write("; ").write(dd.name).write(" = *_hp; free(_hp); }\n")
                        } else {
                            f.write(dd.name).write(" = "); emit_deref(f, rhs, depth, ctx); f.write(";\n")
                        }
                    } else if rhs.node_type.is(NodeType.FCall).and(fcall_is_shallow_return(rhs, ctx)) {
                        // Shallow returns are by-value -- always stack-alloc.
                        // The malloc'd-and-deref'd path leaks the heap box (the
                        // typer doesn't track these for delete).
                        mut htype := fcall_return_ctype(rhs, ctx)
                        if htype.len() == 0 { htype = ctype.clone() }
                        f.write(htype).write(" ").write(dd.name).write(" = ")
                        emit_expr(f, rhs, depth, ctx); f.write(";\n")
                        ctx.builder_func.stack_locals.add(own dd.name.clone())
                        ctx.builder_func.stack_local_types.set(dd.name, own htype.clone())
                    } else if can_hoist.and(is_pod_enum_clone_call(rhs, ctx)) {
                        // POD enum clone wrap: typer wraps
                        // `c := Color.Red` as `c := Color.clone(Color.Red)`
                        // for ownership semantics.  For payload-less
                        // enums the clone is a wasteful malloc+deref+
                        // free of a stack compound literal -- emit the
                        // value directly via the clone's arg.  When the
                        // arg is a ns-Enum variant access we know the
                        // exact compound-literal shape; emit it inline
                        // so we don't produce the cosmetic `(*&...)`
                        // round-trip that emit_deref would generate.
                        f.write(ctype).write(" ").write(dd.name).write(" = ")
                        emit_pod_enum_clone_arg(f, rhs, depth, ctx)
                        f.write(";\n")
                        ctx.builder_func.stack_locals.add(own dd.name.clone())
                        ctx.builder_func.stack_local_types.set(dd.name, own ctype.clone())
                    } else if can_hoist.and(rhs.node_type.is(NodeType.FCall)) {
                        mut htype := fcall_return_ctype(rhs, ctx)
                        if htype.len() == 0 { htype = ctype.clone() }
                        f.write(htype).write(" ").write(dd.name).write("; { ").write(htype).write(" *_hp = (").write(htype).write(" *)")
                        emit_expr(f, rhs, depth, ctx)
                        f.write("; ").write(dd.name).write(" = *_hp; free(_hp); }\n")
                        ctx.builder_func.stack_locals.add(own dd.name.clone())
                        ctx.builder_func.stack_local_types.set(dd.name, own htype.clone())
                    } else if can_hoist {
                        f.write(ctype).write(" ").write(dd.name).write("; { ").write(ctype).write(" *_hp = (").write(ctype).write(" *)")
                        emit_expr(f, rhs, depth, ctx)
                        f.write("; ").write(dd.name).write(" = *_hp; free(_hp); }\n")
                        ctx.builder_func.stack_locals.add(own dd.name.clone())
                        ctx.builder_func.stack_local_types.set(dd.name, own ctype.clone())
                    } else if is_pod_enum_clone_call(rhs, ctx).and(is_global.not()) {
                        // POD-enum heap-Decl variant: emit as stack
                        // value, garbager skips heap-promote, delete
                        // gets elided by is_noop_delete_stmt.
                        f.write(ctype).write(" ").write(dd.name).write(" = ")
                        emit_pod_enum_clone_arg(f, rhs, depth, ctx)
                        f.write(";\n")
                        ctx.builder_func.stack_locals.add(own dd.name.clone())
                        ctx.builder_func.stack_local_types.set(dd.name, own ctype.clone())
                    } else if is_pod_struct_user_clone(rhs, ctx).and(is_global.not()) {
                        // POD-struct `.clone()`: emit a struct value-copy.
                        f.write(ctype).write(" ").write(dd.name).write(" = ")
                        emit_pod_struct_user_clone_arg(f, rhs, depth, ctx)
                        f.write(";\n")
                        ctx.builder_func.stack_locals.add(own dd.name.clone())
                        ctx.builder_func.stack_local_types.set(dd.name, own ctype.clone())
                    } else {
                        if is_global { f.write(dd.name).write(" = ") }
                        else { f.write(ctype).write(" *").write(dd.name).write(" = ") }
                        emit_expr(f, rhs, depth, ctx); f.write(";\n")
                    }
                } else {
                    if is_global {
                        f.write(dd.name).write(" = "); emit_deref(f, rhs, depth, ctx); f.write(";\n")
                    } else if can_hoist {
                        f.write(ctype).write(" ").write(dd.name).write(" = ")
                        emit_deref(f, rhs, depth, ctx); f.write(";\n")
                        ctx.builder_func.stack_locals.add(own dd.name.clone())
                        ctx.builder_func.stack_local_types.set(dd.name, own ctype.clone())
                    } else {
                        f.write(ctype).write(" *").write(dd.name).write(" = malloc(sizeof(").write(ctype).write("));\n")
                        emit_indent(f, depth)
                        f.write("*").write(dd.name).write(" = "); emit_deref(f, rhs, depth, ctx); f.write(";\n")
                    }
                }
            }
        }
        // `_x` locals are til's deliberately-unused convention; the
        // typer skips them in check_unused_locals, so we need a (void)
        // guard for C. Any non-_-prefixed local that reaches here is
        // either used or a typer bug -- gcc surfacing it is fine.
        if dd.name.starts_with("_").or(dd.name.starts_with("hoisted__")) {
            emit_indent(f, depth); f.write("(void)").write(builder_resolve_c_ident_name(dd.name, ctx)).write(";\n")
        }
    }
    case:
        UNREACHABLE()
    }
}
priv builder_get_c_return_type := func(ctx: Context) returns Str {
    ref cf : Expr = ctx.current_fdef
    if cf.is_null().not() {
        switch cf.node_type {
        case NodeType.FuncDef(fd):
            return func_return_ctype(fd, ctx)
        case:
        }
    }
    return "void *"
}

priv emit_return_ctype := func(rv: Expr, ctx: Context) returns Str {
    ref cf : Expr = ctx.current_fdef
    if cf.is_null().not() {
        switch cf.node_type {
        case NodeType.FuncDef(fd):
            if fd.return_type.len() > 0 { return type_name_to_c_value(fd.return_type, ctx) }
        case:
        }
    }
    return c_type_name(rv.expr_til_type(), til_type_name(rv.expr_til_type()), ctx)
}

priv emit_return_box := proc(f: File, e: Expr, depth: I32, ctx: Context) {
    ref rv : Expr = e.children[0]
    ctype := emit_return_ctype(rv, ctx)
    f.write("{ ").write(ctype).write(" *_r = malloc(sizeof(").write(ctype).write(")); *_r = ")
    emit_expr(f, rv, depth, ctx)
    if ctype == "Str" { f.write("; if (_r->cap == TIL_CAP_LIT) { _r->cap = TIL_CAP_VIEW; }") }
    f.write(";\n")
    for i in 1..e.children.len() {
        emit_indent(f, depth)
        emit_stmt(f, e.children[i], depth, ctx)
    }
    emit_indent(f, depth)
    f.write("return _r; }\n")
}

priv emit_stmt_return := proc(f: File, e: Expr, depth: I32, ctx: Context) {
    if e.children.len() == 0 {
        if ctx.in_main_func { f.write("return 0;\n") }
        else { f.write("return;\n") }
    } else {
        ref rv : Expr = e.children[0]
        // Struct constructor return
        rv_sname := til_type_name(rv.expr_til_type())
        if rv.node_type.is(NodeType.FCall).and(rv_sname.len().gt(0)).and(rv.children.len().gt(0)) {
            switch rv.children[0].node_type {
            case NodeType.Ident(ci):
                if ci.ident_name() == rv_sname {
                    ctype := c_type_name(rv.expr_til_type(), rv_sname, ctx)
                    f.write("{ ").write(ctype).write(" *_r = malloc(sizeof(").write(ctype).write("));\n")
                    emit_ctor_fields(f, "_r", rv, depth, ctx)
                    for i in 1..e.children.len() {
                        emit_indent(f, depth)
                        emit_stmt(f, e.children[i], depth, ctx)
                    }
                    emit_indent(f, depth); f.write("return _r; }\n")
                    return
                }
            case:
            }
        }
        // Ref return
        ref cf2 : Expr = ctx.current_fdef
        if cf2.is_null().not() {
            switch cf2.node_type {
            case NodeType.FuncDef(fd):
                if fd.return_own_type.is(OwnType.Ref) {
                    if e.children.len() > 1 {
                        ctype := builder_get_c_return_type(ctx)
                        f.write("{ ").write(ctype).write(" _ret_val = "); emit_as_ptr(f, rv, depth, false, ctx); f.write(";\n")
                        for i in 1..e.children.len() { emit_indent(f, depth); emit_stmt(f, e.children[i], depth, ctx) }
                        emit_indent(f, depth); f.write("return _ret_val; }\n")
                    } else {
                        f.write("return "); emit_as_ptr(f, rv, depth, false, ctx); f.write(";\n")
                    }
                    return
                }
                if fd.return_own_type.is(OwnType.Shallow) {
                    if rv.node_type.is(NodeType.FCall).and(fcall_is_shallow_return(rv, ctx)) {
                        if e.children.len() > 1 {
                            ctype := builder_get_c_return_type(ctx)
                            f.write("{ ").write(ctype).write(" _ret_val = "); emit_expr(f, rv, depth, ctx); f.write(";\n")
                            for i in 1..e.children.len() { emit_indent(f, depth); emit_stmt(f, e.children[i], depth, ctx) }
                            emit_indent(f, depth); f.write("return _ret_val; }\n")
                        } else {
                            f.write("return "); emit_expr(f, rv, depth, ctx); f.write(";\n")
                        }
                        return
                    }
                    // Asap fix: shallow return of a hoisted compiler temp
                    // (hoist_to_temp always heap-promotes Own for FCall /
                    // Literal*) -- the typer's insert_exit_deletes_into_stmt
                    // skips locals used in the return expr, so the wrapper
                    // would otherwise leak. Capture by value, raw-free the
                    // wrapper, return the captured value.
                    if rv.node_type.is(NodeType.Ident) {
                        switch rv.node_type {
                        case NodeType.Ident(rv_name):
                            if rv_name.starts_with("hoisted__").and(
                                is_stack_local(rv_name.ident_name(), ctx).not()).and(
                                is_value_global(rv_name.ident_name(), ctx).not()).and(
                                rv.expr_til_type().is(Type.Dynamic).not()) {
                                ctype := emit_return_ctype(rv, ctx)
                                cname := builder_resolve_c_ident_name(rv_name.ident_name(), ctx)
                                f.write("{ ").write(ctype).write(" _ret = DEREF(").write(cname).write("); free(").write(cname).write(");\n")
                                for i in 1..e.children.len() { emit_indent(f, depth); emit_stmt(f, e.children[i], depth, ctx) }
                                emit_indent(f, depth); f.write("return _ret; }\n")
                                return
                            }
                        case:
                        }
                    }
                    if e.children.len() > 1 {
                        ctype := builder_get_c_return_type(ctx)
                        f.write("{ ").write(ctype).write(" _ret_val = "); emit_deref(f, rv, depth, ctx); f.write(";\n")
                        for i in 1..e.children.len() { emit_indent(f, depth); emit_stmt(f, e.children[i], depth, ctx) }
                        emit_indent(f, depth); f.write("return _ret_val; }\n")
                    } else {
                        f.write("return "); emit_deref(f, rv, depth, ctx); f.write(";\n")
                    }
                    return
                }
            case:
            }
        }
        // Inline field value: box for return
        if rv.node_type.is(NodeType.FieldAccess).and(builder_fa_is_ptr(rv, ctx).not())
        .and(builder_fa_is_ns(rv, ctx).not()).and(rv.expr_til_type().is(Type.Dynamic).not()) {
            emit_return_box(f, e, depth, ctx)
            // Shallow fcall: box for return
        } else if rv.node_type.is(NodeType.FCall).and(fcall_is_shallow_return(rv, ctx)) {
            emit_return_box(f, e, depth, ctx)
            // Hoisted local: box for return
        } else if rv.node_type.is(NodeType.Ident) {
            switch rv.node_type {
            case NodeType.Ident(rv_name):
                mut is_shallow_ret := false
                ref cf3 : Expr = ctx.current_fdef
                if cf3.is_null().not() {
                    switch cf3.node_type {
                    case NodeType.FuncDef(fd):
                        is_shallow_ret = fd.return_own_type.is(OwnType.Shallow)
                    case:
                    }
                }
                if is_stack_local(rv_name.ident_name(), ctx).or(is_value_global(rv_name.ident_name(), ctx)) {
                    if is_shallow_ret.not() {
                        ctype := emit_return_ctype(rv, ctx)
                        cname := builder_resolve_c_ident_name(rv_name.ident_name(), ctx)
                        f.write("{ ").write(ctype).write(" *_r = malloc(sizeof(").write(ctype).write(")); *_r = ").write(cname)
                        if ctype == "Str" { f.write("; if (_r->cap == TIL_CAP_LIT) { _r->cap = TIL_CAP_VIEW; }") }
                        f.write(";\n")
                        for i in 1..e.children.len() { emit_indent(f, depth); emit_stmt(f, e.children[i], depth, ctx) }
                        emit_indent(f, depth); f.write("return _r; }\n")
                    } else {
                        if e.children.len() > 1 {
                            ctype := builder_get_c_return_type(ctx)
                            f.write("{ ").write(ctype).write(" _ret_val = "); emit_expr(f, rv, depth, ctx); f.write(";\n")
                            for i in 1..e.children.len() { emit_indent(f, depth); emit_stmt(f, e.children[i], depth, ctx) }
                            emit_indent(f, depth); f.write("return _ret_val; }\n")
                        } else {
                            f.write("return "); emit_expr(f, rv, depth, ctx); f.write(";\n")
                        }
                    }
                } else {
                    if e.children.len() > 1 {
                        ctype := builder_get_c_return_type(ctx)
                        f.write("{ ").write(ctype).write(" _ret_val = "); emit_expr(f, rv, depth, ctx); f.write(";\n")
                        for i in 1..e.children.len() { emit_indent(f, depth); emit_stmt(f, e.children[i], depth, ctx) }
                        emit_indent(f, depth); f.write("return _ret_val; }\n")
                    } else {
                        f.write("return "); emit_expr(f, rv, depth, ctx); f.write(";\n")
                    }
                }
            case:
                UNREACHABLE()
            }
            // Bare enum variant ref: heap-allocate
        } else if rv.node_type.is(NodeType.FieldAccess).and(builder_fa_is_ns(rv, ctx)).and(rv.expr_til_type().is(Type.Enum)) {
            sn := til_type_name(rv.children[0].expr_til_type())
            switch rv.node_type {
            case NodeType.FieldAccess(vname):
                f.write("{ ").write(sn).write(" *_r = malloc(sizeof(").write(sn).write(")); _r->tag = ").write(sn).write("_TAG_").write(vname.field_access_name()).write(";\n")
                for i in 1..e.children.len() { emit_indent(f, depth); emit_stmt(f, e.children[i], depth, ctx) }
                emit_indent(f, depth); f.write("return _r; }\n")
            case:
                UNREACHABLE()
            }
        } else {
            if e.children.len() > 1 {
                ctype := builder_get_c_return_type(ctx)
                f.write("{ ").write(ctype).write(" _ret_val = "); emit_expr(f, rv, depth, ctx); f.write(";\n")
                for i in 1..e.children.len() { emit_indent(f, depth); emit_stmt(f, e.children[i], depth, ctx) }
                emit_indent(f, depth); f.write("return _ret_val; }\n")
            } else {
                f.write("return "); emit_expr(f, rv, depth, ctx); f.write(";\n")
            }
        }
    }
}

// Trivial no-op delete: `Type.delete(stack_local_primitive, ...)` -- the
// typer emits these for hoisted stack temps whose type has no destructor
// work to do. The builder previously suppressed the call body but still
// wrote indent+";", littering generated C with lonely semicolons. Detect
// the shape here so emit_stmt can skip the indent too.
priv is_noop_delete_stmt := func(e: Expr, ctx: Context) returns Bool {
    if e.node_type.is(NodeType.FCall).not() { return false }
    if e.children.len() < 2 { return false }
    switch e.children[0].node_type {
    case NodeType.FieldAccess(del_name):
        if del_name.field_access_name().eq("delete").not() { return false }
    case:
        return false
    }
    ref c1 : Expr = e.children[1]
    switch c1.node_type {
    case NodeType.Ident(del_arg):
        if is_stack_local(del_arg.ident_name(), ctx).not() { return false }
        if c1.expr_til_type().is(Type.Enum) {
            // POD enum (no variant payload): destructor is just
            // `if (call_free) free(self);`. With the local on the
            // stack and the value reclaimed at block exit, the call
            // is pure overhead.
            tname := til_type_name(c1.expr_til_type())
            if is_pod_enum(tname, ctx) { return true }
            return false
        }
        if c1.expr_til_type().is(Type.Struct) { return false }
        return true
    case:
        return false
    }
}

// #254: emit a C `switch` for a switch the typer left un-desugared (C-like:
// integer/char scrutinee, constant literal case labels). Each case body is
// wrapped in a `{ }` block (so case-local C decls are legal) and terminated
// with `break;` -- til cases never fall through, and a case-level til `break`
// would target the enclosing loop, so the typer keeps such switches out of the
// C-like set (see switch_is_clike). A til `continue` maps to C `continue`,
// which a C `switch` does not capture, so it reaches the enclosing loop.
priv emit_stmt_switch := proc(f: File, e: Expr, depth: I32, ctx: Context) {
    ref scrut : Expr = e.children[0]
    is_enum := scrut.expr_til_type().is(Type.Enum)
    mut enum_name := ""
    if is_enum { enum_name = til_type_name(scrut.expr_til_type()) }
    f.write("switch (")
    if is_enum {
        // Switch on the tag field. emit_deref yields the enum value, so
        // `(value).tag` is the discriminant; labels are <Enum>_TAG_<Variant>.
        f.write("(")
        emit_deref(f, scrut, depth, ctx)
        f.write(").tag")
    } else {
        emit_deref(f, scrut, depth, ctx)
    }
    f.write(") {\n")
    for ci in 1..e.children.len() {
        ref cn : Expr = e.children[ci]
        emit_indent(f, depth)
        if cn.children.len() == 1 {
            f.write("default: {\n")
            emit_body_scoped(f, cn.children[0], depth + 1, ctx)
        } else {
            f.write("case ")
            if is_enum {
                // #276: a payload-binding case `Type.V(x)` is an FCall whose
                // FieldAccess callee names the variant; a bare `Type.V` is the
                // FieldAccess itself. The binding decl already rides the body.
                mut vn := ""
                ref pat : Expr = cn.children[0]
                switch pat.node_type {
                case NodeType.FieldAccess(fa): vn = Str.clone(fa.field_access_name())
                case NodeType.FCall:
                    switch pat.children[0].node_type {
                    case NodeType.FieldAccess(fa2): vn = Str.clone(fa2.field_access_name())
                    case:
                    }
                case:
                }
                f.write(enum_name)
                f.write("_TAG_")
                f.write(vn)
            } else if is_range_new_call(cn.children[0]) {
                // #254 range case `lo..hi` -> C case range `lo ... hi`.
                emit_expr(f, cn.children[0].children[1], depth, ctx)
                f.write(" ... ")
                emit_expr(f, cn.children[0].children[2], depth, ctx)
            } else {
                emit_expr(f, cn.children[0], depth, ctx)
            }
            f.write(": {\n")
            emit_body_scoped(f, cn.children[1], depth + 1, ctx)
        }
        emit_indent(f, depth + 1)
        f.write("break;\n")
        emit_indent(f, depth)
        f.write("}\n")
    }
    emit_indent(f, depth)
    f.write("}\n")
}

priv emit_stmt := proc(f: File, e: Expr, depth: I32, ctx: Context) {
    if is_noop_delete_stmt(e, ctx) { return }
    emit_indent(f, depth)
    switch e.node_type {
    case NodeType.Decl:
        emit_stmt_decl(f, e, depth, ctx)
    case NodeType.Assign(ad):
        aname := ad.name
        ref rhs : Expr = e.children[0]
        if ctx.closure_emit_captures.has(aname) {
            f.write("(*").write(ctx.closure_emit_env).write("->").write(aname).write(") = ")
            emit_deref(f, rhs, depth, ctx)
            f.write(";\n")
            return
        }
        if is_ref_local(aname, ctx) {
            // #221: `ref mut p : Str = get_payload(<enum>); p = "literal"`
            // must write the Str struct THROUGH `p` into the enum's payload
            // memory, not rebind the local pointer to a fresh heap Str.
            // A ref assignment must write through `p`, not rebind it to the
            // literal wrapper pointer. Emit the value directly:
            // `*p = (Str){.c_str = "lit", ...};`.
            if rhs.node_type.is_literal_str() {
                f.write("*").write(aname).write(" = (Str){.c_str = (void *)\"")
                switch rhs.node_type {
                case NodeType.Literal(Literal.Str(lit_s)):
                    f.write(lit_s).write("\", .count = ").emit_usize(c_lit_byte_count(lit_s))
                case:
                }
                f.write("ULL, .cap = TIL_CAP_LIT};\n")
                return
            }
            mut do_rebind := false
            switch rhs.node_type {
            case NodeType.FieldAccess: do_rebind = true
            case NodeType.Ident(rhs_ident):
                // Issue #226: function parameters live on the stack frame
                // like stack-local decls, but is_stack_local returns false
                // for them so the rebind branch was emitting `aname =
                // &param;` (pointer rebind to the param's storage) when
                // the user wrote `aname = param` intending a deref-write.
                // For primitive params especially this left the original
                // target uninitialized. Treat params like stack locals
                // here so the deref-write path runs.
                ref rname : Str = rhs_ident.ident_name()
                if is_stack_local(rname, ctx).not()
                    .and(is_current_func_param(rname, ctx).not()) { do_rebind = true }
            case:
            }
            if do_rebind {
                f.write(aname).write(" = ")
                emit_as_ptr(f, rhs, depth, false, ctx)
                f.write(";\n"); return
            }
        }
        if ad.save_old_delete {
            ctype := c_type_name(e.expr_til_type(), til_type_name(e.expr_til_type()), ctx)
            if is_stack_local(aname, ctx).or(is_value_global(aname, ctx)) {
                // LiteralStr RHS can be written directly into the stack-local
                // after running the old destructor.
                if rhs.node_type.is_literal_str() {
                    f.write("{ ").write(ctype).write("_delete(&").write(aname).write(", ").write(delete_call_free_lit(ctype, false, ctx)).write("); ")
                    f.write(aname).write(" = (Str){.c_str = (void *)\"")
                    switch rhs.node_type {
                    case NodeType.Literal(Literal.Str(lit_s)):
                        f.write(lit_s).write("\", .count = ").emit_usize(c_lit_byte_count(lit_s))
                    case:
                    }
                    f.write("ULL, .cap = TIL_CAP_LIT}; }\n")
                } else if rhs.node_type.is(NodeType.FCall).and(fcall_is_shallow_return(rhs, ctx)) {
                    // Issue #223 step 3: a shallow-returning call yields a value,
                    // not a heap pointer -- run the old destructor, then assign
                    // the value directly (no `*_new` pointer dance / free).
                    f.write("{ ").write(ctype).write("_delete(&").write(aname).write(", ").write(delete_call_free_lit(ctype, false, ctx)).write("); ")
                    f.write(aname).write(" = ")
                    emit_expr(f, rhs, depth, ctx)
                    f.write("; }\n")
                } else if is_pod_enum_clone_call(rhs, ctx) {
                    // POD-enum stack-local Assign: old destructor is a
                    // no-op (call_free=false), new value is the variant
                    // literal -- skip the clone wrap and rebind.
                    f.write(aname).write(" = ")
                    emit_pod_enum_clone_arg(f, rhs, depth, ctx)
                    f.write(";\n")
                } else if is_pod_struct_user_clone(rhs, ctx) {
                    // POD-struct stack-local Assign: value-copy, no wrap.
                    f.write(aname).write(" = ")
                    emit_pod_struct_user_clone_arg(f, rhs, depth, ctx)
                    f.write(";\n")
                } else {
                    f.write("{ ").write(ctype).write(" *_new = (").write(ctype).write(" *)")
                    emit_expr(f, rhs, depth, ctx)
                    f.write("; ").write(ctype).write("_delete(&").write(aname).write(", ").write(delete_call_free_lit(ctype, false, ctx)).write("); ").write(aname).write(" = *_new; free(_new); }\n")
                }
            } else {
                f.write("{ ").write(ctype).write(" *_old = ").write(aname).write("; ").write(aname).write(" = ")
                if ctype.eq("Str").and(rhs.node_type.is_literal_str()) {
                    switch rhs.node_type {
                    case NodeType.Literal(Literal.Str(lit_s)):
                        emit_str_lit_expr(f, lit_s, ctx)
                    case:
                    }
                } else {
                    emit_expr(f, rhs, depth, ctx)
                }
                f.write("; ").write(ctype).write("_delete(_old, ").write(delete_call_free_lit(ctype, true, ctx)).write("); }\n")
            }
            return
        }
        is_hoisted := is_stack_local(aname, ctx).or(is_value_global(aname, ctx))
        if e.expr_til_type().is(Type.Dynamic) {
            f.write(aname).write(" = "); emit_deref(f, rhs, depth, ctx); f.write(";\n"); return
        }
        if ad.is_payload_alias {
            mut is_compound := false
            if e.expr_til_type().is(Type.Struct).or(e.expr_til_type().is(Type.Enum)) { is_compound = true }
            if is_compound.and(rhs.node_type.is(NodeType.FCall).and(fcall_is_shallow_return(rhs, ctx))) {
                // Issue #223 step 3: shallow-returning call yields a value;
                // delete the old payload, then deref-assign the value directly.
                ctype := c_type_name(e.expr_til_type(), til_type_name(e.expr_til_type()), ctx)
                f.write("{ ").write(ctype).write("_delete(").write(aname).write(", ").write(delete_call_free_lit(ctype, false, ctx)).write("); ")
                f.write("*").write(aname).write(" = ")
                emit_expr(f, rhs, depth, ctx)
                f.write("; }\n")
            } else if is_compound.and(rhs.node_type.is(NodeType.FCall).or(rhs.node_type.is_literal_str())) {
                ctype := c_type_name(e.expr_til_type(), til_type_name(e.expr_til_type()), ctx)
                f.write("{ ").write(ctype).write("_delete(").write(aname).write(", ").write(delete_call_free_lit(ctype, false, ctx)).write("); ")
                f.write(ctype).write(" *_new = (").write(ctype).write(" *)")
                emit_expr(f, rhs, depth, ctx)
                f.write("; *").write(aname).write(" = *_new; free(_new); }\n")
            } else {
                f.write("*").write(aname).write(" = ")
                mut is_ref_rhs := false
                switch rhs.node_type {
                case NodeType.Ident(rid):
                    if is_ref_local(rid.ident_name(), ctx) {
                        is_ref_rhs = true
                        f.write("*").write(builder_resolve_c_ident_name(rid.ident_name(), ctx))
                    }
                case:
                }
                if is_ref_rhs.not() {
                    emit_deref(f, rhs, depth, ctx)
                }
                f.write(";\n")
            }
            return
        }
        if is_hoisted {
            if rhs.node_type.is(NodeType.FCall).and(fcall_is_shallow_return(rhs, ctx)) {
                f.write(aname).write(" = "); emit_expr(f, rhs, depth, ctx); f.write(";\n")
            } else if rhs.node_type.is(NodeType.FCall) {
                ctype := c_type_name(e.expr_til_type(), til_type_name(e.expr_til_type()), ctx)
                f.write("{ ").write(ctype).write(" *_hp = (").write(ctype).write(" *)")
                emit_expr(f, rhs, depth, ctx)
                f.write("; ").write(aname).write(" = *_hp; free(_hp); }\n")
            } else {
                f.write(aname).write(" = "); emit_deref(f, rhs, depth, ctx); f.write(";\n")
            }
        } else {
            if rhs.node_type.is(NodeType.FCall).or(rhs.node_type.is_literal_str())
            .or(rhs.node_type.is(NodeType.FieldAccess).and(builder_fa_is_ns(rhs, ctx)).and(rhs.expr_til_type().is(Type.Enum))) {
                if rhs.node_type.is(NodeType.FCall).and(fcall_is_shallow_return(rhs, ctx)) {
                    f.write("*").write(aname).write(" = ")
                } else {
                    f.write(aname).write(" = ")
                }
                emit_expr(f, rhs, depth, ctx)
            } else if e.expr_til_type().is_funcptr().or(e.expr_til_type().is(Type.Body)) {
                f.write(aname).write(" = "); emit_expr(f, rhs, depth, ctx)
            } else {
                f.write("*").write(aname).write(" = "); emit_deref(f, rhs, depth, ctx)
            }
            f.write(";\n")
        }
    case NodeType.FieldAssign(fad):
        fname := fad.name
        ref obj : Expr = e.children[0]
        ref rhs_fa : Expr = e.children[1]
        did_save_old := fad.save_old_delete
        mut old_ctype := ""
        if did_save_old {
            old_ctype = c_type_name(rhs_fa.expr_til_type(), til_type_name(rhs_fa.expr_til_type()), ctx)
            f.write("{ ") f.write(old_ctype)
            if builder_fa_is_ptr(e, ctx) {
                f.write(" *_old = ")
            } else {
                f.write(" _old = ")
            }
            emit_expr(f, obj, depth, ctx)
            if use_dot_access(obj, ctx) { f.write(".") } else { f.write("->") }
            f.write(fname) f.write(";\n")
            emit_indent(f, depth)
        }

        if rhs_fa.node_type.is(NodeType.FCall).and(builder_fa_is_ptr(e, ctx).not()).and(builder_fa_is_ns(e, ctx).not()) {
            if fcall_is_shallow_return(rhs_fa, ctx) {
                emit_expr(f, obj, depth, ctx)
                if use_dot_access(obj, ctx) { f.write(".") } else { f.write("->") }
                f.write(fname).write(" = "); emit_expr(f, rhs_fa, depth, ctx); f.write(";\n")
            } else if is_pod_enum_clone_call(rhs_fa, ctx) {
                // POD-enum FieldAssign: skip the malloc-copy-free wrapper.
                emit_expr(f, obj, depth, ctx)
                if use_dot_access(obj, ctx) { f.write(".") } else { f.write("->") }
                f.write(fname).write(" = ")
                emit_pod_enum_clone_arg(f, rhs_fa, depth, ctx)
                f.write(";\n")
            } else if is_pod_struct_user_clone(rhs_fa, ctx) {
                // POD-struct `.clone()`: struct value-copy, no clone wrap.
                emit_expr(f, obj, depth, ctx)
                if use_dot_access(obj, ctx) { f.write(".") } else { f.write("->") }
                f.write(fname).write(" = ")
                emit_pod_struct_user_clone_arg(f, rhs_fa, depth, ctx)
                f.write(";\n")
            } else {
                ftype := c_type_name(rhs_fa.expr_til_type(), til_type_name(rhs_fa.expr_til_type()), ctx)
                f.write("{ ").write(ftype).write(" *_fa = "); emit_expr(f, rhs_fa, depth, ctx); f.write("; ")
                emit_expr(f, obj, depth, ctx)
                if use_dot_access(obj, ctx) { f.write(".") } else { f.write("->") }
                f.write(fname).write(" = *_fa; ")
                if ftype == "Str" { f.write("if (_fa->cap != TIL_CAP_LIT) { free(_fa); }") }
                else { f.write("free(_fa);") }
                f.write(" }\n")
            }
        } else {
            if builder_fa_is_ns(e, ctx) {
                f.write(til_type_name(obj.expr_til_type())).write("_").write(fname).write(" = ")
            } else {
                emit_expr(f, obj, depth, ctx)
                if use_dot_access(obj, ctx) { f.write(".") } else { f.write("->") }
                f.write(fname).write(" = ")
            }
            if builder_fa_is_ptr(e, ctx) {
                emit_as_ptr(f, rhs_fa, depth, true, ctx)
            } else {
                emit_deref(f, rhs_fa, depth, ctx)
            }
            f.write(";\n")
        }

        if did_save_old {
            emit_indent(f, depth)
            f.write(old_ctype) f.write("_delete(")
            if builder_fa_is_ptr(e, ctx) {
                f.write("_old, ").write(delete_call_free_lit(old_ctype, true, ctx)).write("); }\n")
            } else {
                f.write("&_old, ").write(delete_call_free_lit(old_ctype, false, ctx)).write("); }\n")
            }
        }
    case NodeType.FCall:
        // Issue #210: emit explicit delete-copy-free for swap calls
        // marked by hoist_param_swap_assign.
        switch e.node_type {
        case NodeType.FCall(fcd):
            if fcd.swap_replace.and(e.children.len().gte(3)) {
                ref swap_target : Expr = e.children[1]
                mut target_name := ""
                mut temp_name := ""
                switch swap_target.node_type {
                case NodeType.Ident(tid): target_name = Str.clone(tid.ident_name())
                case:
                }
                switch e.children[2].node_type {
                case NodeType.Ident(stid): temp_name = Str.clone(stid.ident_name())
                case:
                }
                if target_name.len().gt(0).and(temp_name.len().gt(0)) {
                    arg_type := swap_target.expr_til_type()
                    arg_tname := til_type_name(arg_type)
                    if arg_tname == "Str" {
                        // If the temp is a stack-local (Str value, not pointer),
                        // assign directly without dereference and free.
                        if is_stack_local(temp_name, ctx) {
                            f.write("{ Str_delete(").write(target_name).write(", ").write(delete_call_free_lit("Str", false, ctx)).write("); *").write(target_name).write(" = ").write(builder_resolve_c_ident_name(temp_name, ctx)).write("; }\n")
                        } else {
                            f.write("{ Str_delete(").write(target_name).write(", ").write(delete_call_free_lit("Str", false, ctx)).write("); *").write(target_name).write(" = *").write(temp_name).write("; free(").write(temp_name).write("); }\n")
                            ctx.swap_freed.add(own temp_name.clone())
                        }
                        return
                    }
                }
            }
        case:
        }
        if e.children.len() > 0 {
            ref c0 : Expr = e.children[0]
            switch c0.node_type {
            case NodeType.Ident(cname0):
                if cname0.ident_name() == "til_closure_delete" {
                    if e.children.len() >= 2 {
                        switch e.children[1].node_type {
                        case NodeType.Ident(del_arg):
                            if ctx.swap_freed.has(del_arg.ident_name()) { return }
                        case:
                        }
                        f.write("{ TilClosure *til_closure = ")
                        emit_expr(f, e.children[1], depth, ctx)
                        f.write("; if (til_closure && til_closure->drop) { til_closure->drop(til_closure->env); free(til_closure); } }\n")
                        return
                    }
                }
                if cname0.ident_name() == "til_closure_slot_delete" {
                    if e.children.len() >= 2 {
                        f.write("{ TilClosure **til_closure_slot = (TilClosure **)(")
                        emit_expr(f, e.children[1], depth, ctx)
                        f.write("); TilClosure *til_closure = *til_closure_slot; if (til_closure && til_closure->drop) { til_closure->drop(til_closure->env); free(til_closure); } *til_closure_slot = NULL; }\n")
                        return
                    }
                }
            case:
            }
            switch c0.node_type {
            case NodeType.FieldAccess(del_name):
                if del_name.field_access_name().eq("delete").and(e.children.len().gte(2)) {
                    ref c1 : Expr = e.children[1]
                    switch c1.node_type {
                    case NodeType.Ident(del_arg):
                        if ctx.swap_freed.has(del_arg.ident_name()) {
                            return
                        }
                        // Stack-local primitive deletes are filtered out by
                        // is_noop_delete_stmt above before any indent is
                        // written, so we never reach here for them.
                        // Stack-local Str (compound-literal init). The typer
                        // may have generated this delete with arg_is_own=true
                        // and call_free=true because the binding's own_type
                        // was Own pre-constfolder. Force the safe shape:
                        // `Str_delete(&name, (Bool){0});` (no malloc, no
                        // free on a stack pointer). cap=CAP_LIT means the
                        // c_str data isn't freed either -- delete becomes
                        // a no-op at runtime. Also `(void)` the hoisted
                        // call_free temp if present, so -Wunused-variable
                        // doesn't trip.
                        if is_stack_local(del_arg.ident_name(), ctx).and(c1.expr_til_type().is(Type.Struct)) {
                            ref del_ct : Str = get_stack_local_ctype(del_arg.ident_name(), ctx)
                            if del_ct.is_null().not().and(del_ct.eq("Str").or(is_pod_struct(del_ct, ctx))) {
                                if e.children.len() >= 3 {
                                    switch e.children[2].node_type {
                                    case NodeType.Ident(cf_name):
                                        f.write("(void)").write(builder_resolve_c_ident_name(cf_name.ident_name(), ctx)).write("; ")
                                    case:
                                    }
                                }
                                f.write(del_ct).write("_delete(&").write(builder_resolve_c_ident_name(del_arg.ident_name(), ctx)).write(", ").write(delete_call_free_lit(del_ct, false, ctx)).write(");\n"); return
                            }
                        }
                    case:
                    }
                }
            case:
            }
        }
        e_sname := til_type_name(e.expr_til_type())
        if e_sname.len().gt(0).and(e.children.len().gt(0)) {
            switch e.children[0].node_type {
            case NodeType.Ident(cname):
                if cname.ident_name() == e_sname { f.write("/* discarded struct constructor */;\n"); return }
            case:
            }
        }
        // Stmt-level FCalls whose return is Own arrive here in one of
        // two shapes:
        //  - typer's hoist_stmt_fcall left a non-Own bare call -- those
        //    have nothing on the heap, plain `<fcall>;` is correct.
        //  - body DCE replaced an `hoisted__T_X := <fcall>` Decl with
        //    the bare FCall (the temp was unused). The return is an
        //    Own heap pointer; without cleaning it up, we leak. `free`
        //    would also leak for compound types (Str's inner c_str,
        //    Vec's inner buffer, ...). Hand off to `T.delete(self,
        //    call_free=true)` -- the same ASAP path the typer would
        //    have taken if the temp had survived.
        if e.expr_til_type().is(Type.None).not() {
            if fcall_returns_own(e, ctx.scope) {
                tname := type_to_name(e.expr_til_type())
                if tname.len() > 0 {
                    f.write(tname).write("_delete(")
                    emit_expr(f, e, depth, ctx)
                    f.write(", ").write(delete_call_free_lit(tname, true, ctx)).write(");\n")
                    return
                } else {
                    f.write("free(")
                    emit_expr(f, e, depth, ctx)
                    f.write(");\n")
                    return
                }
            }
        }
        emit_expr(f, e, depth, ctx); f.write(";\n")
    case NodeType.Return:
        emit_stmt_return(f, e, depth, ctx)
    case NodeType.Body:
        f.write("{\n"); emit_body_scoped(f, e, depth + 1, ctx); emit_indent(f, depth); f.write("}\n")
    case NodeType.CaptureBlock:
        // Issue #54: capture restriction is a compile-time check; emit the
        // body as a plain scoped block (child 0 is the Body).
        f.write("{\n"); emit_body_scoped(f, e.children[0], depth + 1, ctx); emit_indent(f, depth); f.write("}\n")
    case NodeType.If:
        f.write("if ("); emit_deref(f, e.children[0], depth, ctx); f.write(") {\n")
        emit_body_scoped(f, e.children[1], depth + 1, ctx); emit_indent(f, depth)
        if e.children.len() > 2 { f.write("} else {\n"); emit_body_scoped(f, e.children[2], depth + 1, ctx); emit_indent(f, depth) }
        f.write("}\n")
    case NodeType.While:
        f.write("while ("); emit_deref(f, e.children[0], depth, ctx); f.write(") {\n")
        emit_body_scoped(f, e.children[1], depth + 1, ctx); emit_indent(f, depth); f.write("}\n")
    case NodeType.Break: f.write("break;\n")
    case NodeType.Continue: f.write("continue;\n")
    case NodeType.Switch: emit_stmt_switch(f, e, depth, ctx)
    case: f.write("/* TODO: unknown stmt type */\n")
    }
}

priv emit_fcall_funcptr_cast := proc(f: File, e: Expr, sig: Expr) {
    switch sig.node_type {
    case NodeType.FuncDef(sfd):
        ret_shallow := sfd.return_own_type.is(OwnType.Shallow)
        mut ret_c := "void *"
        if sfd.return_type.len() == 0 {
            ret_c = "void"
        } else if e.expr_til_type().is(Type.None).not().and(e.expr_til_type().is(Type.Unknown).not())
        .and(e.expr_til_type().is(Type.Dynamic).not()) {
            ret_c = til_type_to_c(e.expr_til_type())
            if e.expr_til_type().is(Type.Struct).or(e.expr_til_type().is(Type.Enum)) {
                e_sname := til_type_name(e.expr_til_type())
                if e_sname.len() > 0 { ret_c = e_sname }
            }
            if ret_shallow.not() { ret_c = format(ret_c, " *") }
        }
        f.write("((")
        f.write(ret_c)
        f.write(" (*)(")
        f.write("void *")
        for i in 1..e.children.len() {
            f.write(", ")
            ref arg : Expr = e.children[i]
            mut arg_shallow := false
            if i - 1 < sfd.params.len() {
                ref p : Declaration = sfd.params[i - 1]
                arg_shallow = p.own_type.is(OwnType.Shallow)
            }
            mut arg_c := "void *"
            if arg.expr_til_type().is(Type.Unknown).not().and(arg.expr_til_type().is(Type.Dynamic).not()) {
                arg_c = til_type_to_c(arg.expr_til_type())
                if arg.expr_til_type().is(Type.Struct).or(arg.expr_til_type().is(Type.Enum)) {
                    arg_sname := til_type_name(arg.expr_til_type())
                    if arg_sname.len() > 0 { arg_c = arg_sname }
                }
                if arg_shallow.not() { arg_c = format(arg_c, " *") }
            }
            f.write(arg_c)
        }
    case:
        UNREACHABLE()
    }
}

emit_fcall_closure_call := proc(f: File, e: Expr, callee: Expr, sig: Expr, depth: I32, ctx: Context) {
    f.write("({ TilClosure *til_closure = (TilClosure *)(")
    switch callee.node_type {
    case NodeType.Ident(cname):
        if is_ref_local(cname.ident_name(), ctx) {
            f.write("DEREF(").write(cname.ident_name()).write(")")
        } else {
            emit_expr(f, callee, depth, ctx)
        }
    case:
        emit_expr(f, callee, depth, ctx)
    }
    f.write("); ")
    emit_fcall_funcptr_cast(f, e, sig)
    f.write("))til_closure->call)(til_closure->env")
    if e.children.len() > 1 {
        f.write(", ")
        emit_fcall_funcptr_args(f, e, sig, depth, ctx)
    }
    f.write("); })")
}

emit_body_closure_call := proc(f: File, callee: Expr, depth: I32, ctx: Context) {
    f.write("({ TilClosure *til_closure = (TilClosure *)(")
    emit_expr(f, callee, depth, ctx)
    f.write("); ((void (*)(void *))til_closure->call)(til_closure->env); })")
}

priv emit_fcall_funcptr_args := proc(f: File, e: Expr, sig: Expr, depth: I32, ctx: Context) {
    switch sig.node_type {
    case NodeType.FuncDef(sfd):
        for i in 1..e.children.len() {
            if i > 1 { f.write(", ") }
            mut arg_shallow := false
            if i - 1 < sfd.params.len() {
                ref p : Declaration = sfd.params[i - 1]
                arg_shallow = p.own_type.is(OwnType.Shallow)
            }
            if arg_shallow { emit_deref(f, e.children[i], depth, ctx) }
            else { emit_as_ptr(f, e.children[i], depth, get_own_arg(e, i), ctx) }
        }
    case:
        UNREACHABLE()
    }
}

emit_capturing_closure_value := proc(f: File, e: Expr, _depth: I32, _ctx: Context) returns ref File {
    switch e.node_type {
    case NodeType.FuncDef(fd):
        env_type := format(fd.closure_name, "_env")
        f.write("({ ").write(env_type).write(" *til_env = malloc(sizeof(").write(env_type).write(")); ")
        for cap : Declaration in fd.captures {
            ctype := c_type_name(cap.til_type, til_type_name(cap.til_type), _ctx)
            mut cap_expr := Expr.new(ident_node(cap.name), e.line, e.col)
            cap_expr.set_expr_til_type(cap.til_type.clone())
            if cap.own_type.is(OwnType.Ref) {
                f.write("til_env->").write(cap.name).write(" = ")
                emit_as_ptr(f, cap_expr, _depth, false, _ctx)
                f.write("; ")
            } else if cap.own_type.is(OwnType.Shallow) {
                f.write("til_env->").write(cap.name).write(" = malloc(sizeof(").write(ctype).write(")); ")
                f.write("*til_env->").write(cap.name).write(" = ")
                emit_deref(f, cap_expr, _depth, _ctx)
                f.write("; ")
            } else {
                f.write("til_env->").write(cap.name).write(" = ")
                emit_as_ptr(f, cap_expr, _depth, true, _ctx)
                f.write("; ")
            }
        }
        f.write("TilClosure *til_closure = malloc(sizeof(TilClosure)); ")
        f.write("*til_closure = (TilClosure){ (void *)").write(fd.closure_name).write(", til_env, ").write(fd.closure_name).write("_drop }; til_closure; })")
    case NodeType.BodyValue(bd):
        env_type2 := format(bd.closure_name, "_env")
        f.write("({ ").write(env_type2).write(" *til_env = malloc(sizeof(").write(env_type2).write(")); ")
        for cap_b : Declaration in bd.captures {
            ctype_b := c_type_name(cap_b.til_type, til_type_name(cap_b.til_type), _ctx)
            mut cap_expr_b := Expr.new(ident_node(cap_b.name), e.line, e.col)
            cap_expr_b.set_expr_til_type(cap_b.til_type.clone())
            if cap_b.own_type.is(OwnType.Ref) {
                f.write("til_env->").write(cap_b.name).write(" = ")
                emit_as_ptr(f, cap_expr_b, _depth, false, _ctx)
                f.write("; ")
            } else if cap_b.own_type.is(OwnType.Shallow) {
                f.write("til_env->").write(cap_b.name).write(" = malloc(sizeof(").write(ctype_b).write(")); ")
                f.write("*til_env->").write(cap_b.name).write(" = ")
                emit_deref(f, cap_expr_b, _depth, _ctx)
                f.write("; ")
            } else {
                f.write("til_env->").write(cap_b.name).write(" = ")
                emit_as_ptr(f, cap_expr_b, _depth, true, _ctx)
                f.write("; ")
            }
        }
        f.write("TilClosure *til_closure = malloc(sizeof(TilClosure)); ")
        f.write("*til_closure = (TilClosure){ (void *)").write(bd.closure_name).write(", til_env, ").write(bd.closure_name).write("_drop }; til_closure; })")
    case:
        UNREACHABLE()
    }
    return f
}

priv emit_str_lit_expr := proc(f: File, s: Str, ctx: Context) {
    if ctx.builder_str_lit_symbols.has(s) {
        ref sym : Str = ctx.builder_str_lit_symbols[s]
        f.write("&").write(sym)
        return
    }
    ctx.ctor_seq = ctx.ctor_seq + 1
    id := ctx.ctor_seq
    f.write("({ static Str _lit")
    emit_i32(f, id)
    f.write(" = (Str){.c_str = (void *)\"")
    f.write(s)
    f.write("\", .count = ")
    emit_usize(f, c_lit_byte_count(s))
    f.write("ULL, .cap = TIL_CAP_LIT}; &_lit")
    emit_i32(f, id)
    f.write("; })")
}

priv emit_str_lit_temp_expr := proc(f: File, s: Str) {
    f.write("&(Str){.c_str = (void *)\"")
    f.write(s)
    f.write("\", .count = ")
    emit_usize(f, c_lit_byte_count(s))
    f.write("ULL, .cap = TIL_CAP_LIT}")
}

// Issue #255: number literals accept base prefixes (0x/0b/0o), '_' digit
// separators, and exponents. C accepts hex, decimal, and exponents
// directly but not 0b/0o or '_', so normalise the literal text into a
// valid C constant. Binary/octal are converted to a decimal constant
// (via Str.to_i64); hex/decimal/float pass through with separators
// stripped. The U64 path (#219, huge hex/decimal) is preserved because
// those forms never route through to_i64 here.
priv num_lit_to_c := func(text: Str) returns Str {
    n := text.len()
    mut start : USize = 0
    mut neg := false
    if n.gte(1).and(text.unsafe_get(0).eq('-')) {
        neg = true
        start = 1
    }
    body := text.substr(start, n - start)
    // Binary/octal -> decimal constant (C has no 0b/0o literal syntax).
    if body.len().gte(2).and(body.unsafe_get(0).eq('0')) {
        ref p1 : I8 = body.unsafe_get(1)
        if p1.eq('b').or(p1.eq('B')).or(p1.eq('o')).or(p1.eq('O')) {
            v := body.to_i64().to_str()
            if neg { return format("-", v) }
            return v.clone()
        }
    }
    // Hex / decimal / float: drop '_' separators (the rest is valid C).
    mut out := body.clone()
    if body.contains("_") { out = body.replace("_", "") }
    if neg { return format("-", out) }
    return out
}

priv emit_expr := proc(f: File, e: Expr, shallow depth: I32, ctx: Context) returns ref File {
    switch e.node_type {
    case NodeType.Literal(Literal.Str(s)):
        emit_str_lit_expr(f, s, ctx)
    case NodeType.Literal(Literal.Num(num)):
        f.write(num_lit_to_c(num.literal_num_text()))
        // Issue #219: U64 literals whose value exceeds LLONG_MAX need
        // the ULL suffix or `cc -Werror` rejects "integer constant is
        // so large that it is unsigned". The constfolder marks the
        // type, we just have to emit the suffix.
        if type_is_primitive(e.expr_til_type(), Primitive.U64) {
            f.write("ULL")
        }
    case NodeType.Literal(Literal.Bool(b)):
        if b { emit_i32(f, 1) } else { emit_i32(f, 0) }
    case NodeType.Literal(Literal.Null):
        f.write("NULL")
    case NodeType.Ident(ident):
        if ctx.closure_emit_captures.has(ident.ident_name()) {
            f.write("(*").write(ctx.closure_emit_env).write("->").write(ident.ident_name()).write(")")
            return f
        }
        if e.expr_til_type().is_funcptr() {
            ref ident_fdef : Expr = find_callee_fdef(ident.ident_name(), ctx)
            if ident_fdef.is_null().not().and(ctx.closure_value_names.has(ident.ident_name())).and(is_stack_local(ident.ident_name(), ctx).not()).and(is_ref_local(ident.ident_name(), ctx).not()).and(ctx.builder_func.ptr_locals.has(ident.ident_name()).not()) {
                f.write("&")
                f.write(closure_value_name(ident.ident_name()))
            } else {
                f.write(builder_resolve_c_ident_name(ident.ident_name(), ctx))
            }
        } else {
            f.write(builder_resolve_c_ident_name(ident.ident_name(), ctx))
        }
    case NodeType.FCall:
        ref callee : Expr = e.children[0]
        // Issue #58: indirect call through a cast result -- the
        // `cast(value, BinaryOp)(args)` shape. Same C emission as the
        // FuncSig-typed struct field below: emit the cast result as a
        // void*, cast it to the C function-pointer type, and apply the
        // args. fcall_fn_sig resolves the FuncSig via the cast's
        // child(2) Ident.
        if callee.node_type.is(NodeType.FCall) {
            if callee.expr_til_type().is(Type.Body) {
                emit_body_closure_call(f, callee, depth, ctx)
                return f
            }
            if callee.expr_til_type().is_funcptr() {
                ref sig_cc : Expr = fcall_fn_sig(e, ctx)
                if sig_cc.is_null().not() {
                    emit_fcall_closure_call(f, e, callee, sig_cc, depth, ctx)
                    return f
                }
            }
        }
        // Indirect call through FuncSig-typed struct field
        if callee.node_type.is(NodeType.FieldAccess) {
            if callee.expr_til_type().is(Type.Body) {
                emit_body_closure_call(f, callee, depth, ctx)
                return f
            }
            if callee.expr_til_type().is_funcptr() {
                ref sig : Expr = fcall_fn_sig(e, ctx)
                if sig.is_null().not() {
                    emit_fcall_closure_call(f, e, callee, sig, depth, ctx)
                    return f
                }
            }
            // Namespace method call
            sname := til_type_name(callee.children[0].expr_til_type())
            switch callee.node_type {
            case NodeType.FieldAccess(mname):
                flat := sname.concat3("_", mname.field_access_name())
                if builder_callee_is_core(flat, ctx) {
                    // #288 Stage 3: a core_func scalar op lowers to a native C
                    // operator inline -- no call, no symbol. The result cast is
                    // the method's declared return type, e.g. ((U32)(a + b)).
                    ref core_op : Str = mname.field_access_name()
                    core_ret_c := til_type_name_c(e.expr_til_type())
                    if core_op == "bnot" {
                        f.write("((")
                        f.write(core_ret_c)
                        f.write(")(~(")
                        emit_deref(f, e.children[1], depth, ctx)
                        f.write(")))")
                    } else if (core_op == "div").or(core_op == "mod") {
                        // #288 follow-up: div/mod keep ext.c's divide-by-zero
                        // guard -- they return 0 on a zero divisor (safe_div is
                        // the throwing variant). A statement expression binds
                        // both operands to temps so the guarded divisor is
                        // evaluated exactly once: ((T)(_b==0 ? 0 : _a OP _b)).
                        mut divmod_c_op := "/"
                        if core_op == "mod" { divmod_c_op = "%" }
                        f.write("({ ")
                        f.write(core_ret_c)
                        f.write(" _cf_a = ")
                        emit_deref(f, e.children[1], depth, ctx)
                        f.write("; ")
                        f.write(core_ret_c)
                        f.write(" _cf_b = ")
                        emit_deref(f, e.children[2], depth, ctx)
                        f.write("; (")
                        f.write(core_ret_c)
                        f.write(")((_cf_b == 0) ? 0 : (_cf_a ")
                        f.write(divmod_c_op)
                        f.write(" _cf_b)); })")
                    } else {
                        core_c_op := core_binop_to_c(core_op)
                        if core_c_op.len() == 0 { panic(__LOC__, ": core_func backend lowering: unknown op '", core_op, "'") }
                        f.write("((")
                        f.write(core_ret_c)
                        f.write(")(")
                        emit_deref(f, e.children[1], depth, ctx)
                        f.write(" ")
                        f.write(core_c_op)
                        f.write(" ")
                        emit_deref(f, e.children[2], depth, ctx)
                        f.write("))")
                    }
                } else if builder_is_inline_accessor(mname.field_access_name(), flat, ctx) {
                    // Generalized len/unsafe_get inline (issue #300): splice the
                    // accessor's own body for ANY type, not just Vec, since a
                    // `for x in c` loop desugars to c.len()/c.unsafe_get(i) and
                    // must not pay a call per iteration on any container. Keyed
                    // on the accessor method (single-return-expr body), not the
                    // container type -- no longer Vec-hardcoded.
                    emit_inline_accessor(f, e, find_callee_fdef(flat, ctx), depth, ctx)
                } else if (sname == "Bool").and(mname.field_access_name() == "eq") {
                    // Peephole: inline Bool.eq as native `==` -- a hot ext_func
                    // call (1.8B in the --prof profile). Bool stays an ext_func
                    // (the interpreter FFIs it, so both modes agree); same
                    // approach as the `is` inline.
                    f.write("((")
                    f.write(til_type_name_c(e.expr_til_type()))
                    f.write(")(")
                    emit_deref(f, e.children[1], depth, ctx)
                    f.write(" == ")
                    emit_deref(f, e.children[2], depth, ctx)
                    f.write("))")
                } else if (mname.field_access_name() == "clone").and(is_primitive(e.expr_til_type())).and(builder_fa_is_ptr(e.children[1], ctx).not()) {
                    // Peephole: a value primitive's clone is a value copy --
                    // emit the value directly instead of a <Prim>_clone() call
                    // (13.6M U32_clone + 9M Bool_clone in --prof). Done in the
                    // builder so the clone node stays in the AST and the
                    // ownership/liveness analysis is untouched. Gated on a
                    // non-pointer arg: an `own U8`/`own I8` field (Str.c_str,
                    // Vec.data, DynPtrBox.p) is typed Primitive but is a heap
                    // buffer pointer whose clone deep-copies, so those keep the
                    // real <Prim>_clone call. <Prim>_clone stays a real func
                    // (interp + reflective dispatch), so both modes agree.
                    f.write("(")
                    emit_deref(f, e.children[1], depth, ctx)
                    f.write(")")
                } else {
                    f.write(sname)
                    f.write("_")
                    f.write(mname.field_access_name())
                    f.write("(")
                    for i in 1..e.children.len() {
                        if i > 1 { f.write(", ") }
                        if callee_param_is_shallow(flat, i - 1, ctx) {
                            emit_deref(f, e.children[i], depth, ctx)
                        } else if callee_param_is_usize(flat, i - 1, ctx).and(callee_param_is_own(flat, i - 1, ctx).not()) {
                            f.write("USIZE_REF(").emit_deref(e.children[i], depth, ctx).write(")")
                        } else if callee_param_is_uptr(flat, i - 1, ctx).and(callee_param_is_own(flat, i - 1, ctx).not()) {
                            f.write("UPTR_REF(").emit_deref(e.children[i], depth, ctx).write(")")
                        } else {
                            mut own_arg := get_own_arg(e, i)
                            if i.eq(1).and(enum_ctor_payload_is_own(flat, e, ctx)) { own_arg = true }
                            if templated_container_method_arg_is_own(sname, mname.field_access_name(), i - 1) { own_arg = true }
                            saved_force_heap := ctx.builder_func.force_heap_stack_lit_str_own
                            if own_arg.and(callee_param_explicit_type(flat, i - 1, ctx).eq("Dynamic")) {
                                ctx.builder_func.force_heap_stack_lit_str_own = true
                            }
                            emit_as_ptr(f, e.children[i], depth, own_arg, ctx)
                            ctx.builder_func.force_heap_stack_lit_str_own = saved_force_heap
                        }
                    }
                    f.write(")")
                }
            case:
                UNREACHABLE()
            }
        } else {
        switch callee.node_type {
        case NodeType.Ident(name):
            if name.ident_name().eq("memset").and(e.children.len().eq(4)) {
                ref memset_arg : Expr = e.children[1]
                memset_arg_type := c_type_name(memset_arg.expr_til_type(), til_type_name(memset_arg.expr_til_type()), ctx)
                if memset_arg_type == "Str" {
                    f.write("if ((")
                    emit_expr(f, memset_arg, depth, ctx)
                    f.write(")->cap != TIL_CAP_LIT) { memset(")
                    emit_expr(f, memset_arg, depth, ctx)
                    f.write(", ")
                    emit_deref(f, e.children[2], depth, ctx)
                    f.write(", ")
                    emit_deref(f, e.children[3], depth, ctx)
                    f.write("); }")
                } else {
                    f.write("memset(")
                    emit_user_fcall_args(f, e, "memset", depth, ctx, false)
                    f.write(")")
                }
            } else if name.ident_name().eq("free").and(e.children.len().eq(2)) {
                ref free_arg : Expr = e.children[1]
                free_arg_type := c_type_name(free_arg.expr_til_type(), til_type_name(free_arg.expr_til_type()), ctx)
                if free_arg_type == "Str" {
                    f.write("if ((")
                    emit_expr(f, free_arg, depth, ctx)
                    f.write(")->cap != TIL_CAP_LIT) { free(")
                    emit_expr(f, free_arg, depth, ctx)
                    f.write("); }")
                } else {
                    f.write("free(")
                    emit_user_fcall_args(f, e, "free", depth, ctx, false)
                    f.write(")")
                }
            } else if name.ident_name().eq("dyn_call").or(name.ident_name().eq("dyn_call_ret")) {
                ref c2 : Expr = e.children[2]
                ref c3 : Expr = e.children[3]
                switch c2.node_type {
                case NodeType.Literal(Literal.Str(method)):
                    switch c3.node_type {
                    case NodeType.Literal(Literal.Num(nargs_str)):
                        nargs := nargs_str.literal_num_text().to_i32()
                        f.write("dyn_call_")
                        f.write(method)
                        f.write("(")
                        emit_as_ptr(f, e.children[1], depth, false, ctx)
                        for ai : I32 in 0..nargs {
                            f.write(", ")
                            emit_as_ptr(f, e.children[ai.add(4).to_usize()], depth, false, ctx)
                        }
                        f.write(")")
                    case:
                        UNREACHABLE()
                    }
                case:
                    UNREACHABLE()
                }
            } else if name.ident_name() == "dyn_fn" {
                f.write("dyn_fn(")
                emit_as_ptr(f, e.children[1], depth, false, ctx)
                f.write(", ")
                ref method_arg : Expr = e.children[2]
                switch method_arg.node_type {
                case NodeType.Literal(Literal.Str(ms)):
                    f.write("&(Str){.c_str=(void*)\"")
                    f.write(ms)
                    f.write("\", .count=")
                    emit_usize(f, ms.len())
                    f.write("ULL, .cap=TIL_CAP_LIT}")
                case:
                    emit_as_ptr(f, method_arg, depth, false, ctx)
                }
                f.write(")")
            } else if name.ident_name() == "cast" {
                // Issue #212: integer reinterpret or same-signedness
                // widening -> bare C cast. The typer set this FCall's
                // til_type to the target type T.
                mut cast_c_type := til_type_name_c(e.expr_til_type())
                // Issue #58: cast-to-FuncSig. til_type_name_c yields "Fn",
                // which is not a C type. For Dynamic -> FuncPtr the source
                // is a slot pointer (Vec.get returned the slot address);
                // we read the actual function pointer with one deref. For
                // FuncPtr -> FuncPtr (identity) we just pass through as
                // void *.
                if (cast_c_type == "Fn").or(cast_c_type == "Body") {
                    if e.children[1].expr_til_type().is(Type.Dynamic) {
                        f.write("(*(void **)(")
                        emit_deref(f, e.children[1], depth, ctx)
                        f.write("))")
                    } else {
                        f.write("(void *)(")
                        emit_deref(f, e.children[1], depth, ctx)
                        f.write(")")
                    }
                } else {
                    f.write("(")
                    f.write(cast_c_type)
                    f.write(")(")
                    emit_deref(f, e.children[1], depth, ctx)
                    f.write(")")
                }
            } else if name.ident_name() == "dyn_size_of" {
                f.write("dyn_size_of(")
                emit_as_ptr(f, e.children[1], depth, false, ctx)
                f.write(")")
            } else if name.ident_name() == "dyn_type_to_str" {
                f.write("dyn_type_to_str(")
                emit_as_ptr(f, e.children[1], depth, false, ctx)
                f.write(")")
            } else if name.ident_name() == "struct_field_count" {
                f.write("struct_field_count(")
                emit_as_ptr(f, e.children[1], depth, false, ctx)
                f.write(")")
            } else if name.ident_name().eq("struct_field_name").or(name.ident_name().eq("struct_field_is_mut")).or(name.ident_name().eq("struct_field_type")) {
                f.write(name.ident_name())
                f.write("(")
                emit_as_ptr(f, e.children[1], depth, false, ctx)
                f.write(", ")
                emit_as_ptr(f, e.children[2], depth, false, ctx)
                f.write(")")
            } else if name.ident_name() == "enum_variant_count" {
                f.write("enum_variant_count(")
                emit_as_ptr(f, e.children[1], depth, false, ctx)
                f.write(")")
            } else if name.ident_name().eq("enum_variant_name").or(name.ident_name().eq("enum_variant_has_payload")).or(name.ident_name().eq("enum_variant_payload_type")) {
                f.write(name.ident_name())
                f.write("(")
                emit_as_ptr(f, e.children[1], depth, false, ctx)
                f.write(", ")
                emit_as_ptr(f, e.children[2], depth, false, ctx)
                f.write(")")
            } else if name.ident_name().eq("func_sig_param_count").or(name.ident_name().eq("func_sig_return_count")).or(name.ident_name().eq("func_sig_throw_count")) {
                f.write(name.ident_name())
                f.write("(")
                emit_as_ptr(f, e.children[1], depth, false, ctx)
                f.write(")")
            } else if name.ident_name().eq("func_sig_param_type").or(name.ident_name().eq("func_sig_return_type")).or(name.ident_name().eq("func_sig_throw_type")) {
                f.write(name.ident_name())
                f.write("(")
                emit_as_ptr(f, e.children[1], depth, false, ctx)
                f.write(", ")
                emit_as_ptr(f, e.children[2], depth, false, ctx)
                f.write(")")
            } else if name.ident_name() == "dyn_has_method" {
                switch e.children[2].node_type {
                case NodeType.Literal(Literal.Str(method)):
                    f.write("dyn_has_")
                    f.write(method)
                    f.write("(")
                    emit_as_ptr(f, e.children[1], depth, false, ctx)
                    f.write(")")
                case:
                    UNREACHABLE()
                }
            } else if til_type_name(e.expr_til_type()).len().gt(0).and(name.ident_name().eq(til_type_name(e.expr_til_type()))) {
                // Struct constructor
                ctype := c_type_name(e.expr_til_type(), til_type_name(e.expr_til_type()), ctx)
                ctx.ctor_seq = ctx.ctor_seq + 1
                id := ctx.ctor_seq
                f.write("({ ")
                f.write(ctype)
                f.write(" *_sc")
                emit_i32(f, id)
                f.write(" = malloc(sizeof(")
                f.write(ctype)
                f.write(")); ")
                tmp := format("_sc", id.to_str())
                emit_ctor_fields(f, tmp, e, depth, ctx)
                f.write(" _sc")
                emit_i32(f, id)
                f.write("; })")
            } else if callee.expr_til_type().is(Type.Body) {
                emit_body_closure_call(f, callee, depth, ctx)
            } else if callee.expr_til_type().is_funcptr() {
                // Indirect call through function pointer variable
                ref sig : Expr = fcall_fn_sig(e, ctx)
                emit_fcall_closure_call(f, e, callee, sig, depth, ctx)
            } else if name.ident_name() == "is_n" {
                // Peephole: inline `is_n`, the variable-width enum-tag check,
                // by reading each operand's `tag` field through its enum C
                // struct: ((E*)a)->tag == ((E*)b)->tag. Every enum is a struct
                // with `tag` at offset 0, and the field's declared width
                // (U8/U16/U32/U64) makes the compare width-correct with no size
                // arg -- which is why this works where reading the size literal
                // does not (a normalization pass hoists it into a temp, so by
                // here children[3] is an Ident). is_n is the sole tag-check
                // primitive (the old 4-byte-only `is` folded into it, since the
                // typed tag read handles any width) -- the #1 --prof CPU entry
                // (93M calls). is_n stays an ext_func (the interpreter FFIs it,
                // reading the same offset-0 tag), so both modes agree.
                isn_ret_c := til_type_name_c(e.expr_til_type())
                enum_c := til_type_name(e.children[1].expr_til_type())
                f.write("((")
                f.write(isn_ret_c)
                f.write(")(((")
                f.write(enum_c)
                f.write(" *)(")
                emit_as_ptr(f, e.children[1], depth, get_own_arg(e, 1), ctx)
                f.write("))->tag == ((")
                f.write(enum_c)
                f.write(" *)(")
                emit_as_ptr(f, e.children[2], depth, get_own_arg(e, 2), ctx)
                f.write("))->tag))")
            } else if name.ident_name() == "is_null" {
                // Peephole: inline is_null(p) -- defined as p.ptr_eq(NULL) -- as
                // a direct null test, dropping the is_null and its nested ptr_eq
                // call (6.2M --prof calls). The Dynamic arg emits as the pointer
                // value (emit_as_ptr), exactly as the real call passes it. The
                // test is `(UPtr)p == 0` rather than `p == NULL`: for a value
                // arg emit_as_ptr yields `&local`, and `&local == NULL` trips
                // gcc -Waddress (always false); the integer compare is the same
                // result without the diagnostic. is_null stays a real func (the
                // interpreter runs its body), so both modes agree.
                f.write("((")
                f.write(til_type_name_c(e.expr_til_type()))
                f.write(")((UPtr)(")
                emit_as_ptr(f, e.children[1], depth, get_own_arg(e, 1), ctx)
                f.write(") == 0))")
            } else if name.ident_name() == "not" {
                // #288 follow-up: Bool.not is now a core_func -- lower it to
                // native `!` inline instead of a real call (~9.4M --prof). The
                // interpreter keeps evaluating it via the registered h_Bool_not
                // handler, so both modes agree; same name-gated shape as `is`.
                f.write("((")
                f.write(til_type_name_c(e.expr_til_type()))
                f.write(")(!(")
                emit_deref(f, e.children[1], depth, ctx)
                f.write(")))")
            } else if name.ident_name().eq("ptr_add").and(builder_callee_is_core(name.ident_name(), ctx)) {
                // ptr_add core_func: lower to native pointer arithmetic inline
                // instead of a call. The cast to void* mirrors ext.c's
                // `void *ptr_add(...)` return, so the result still assigns to any
                // typed pointer without -Wincompatible-pointer-types (a bare U8*
                // would not convert). ext.c keeps the symbol for pass-1 til_boot,
                // which predates this inline and emits a real call; the
                // interpreter reaches ptr_add via the registered h_ptr_add
                // handler, not FFI (a core_func is not FFI-registered), so both
                // modes agree.
                f.write("((void *)((U8 *)(")
                emit_as_ptr(f, e.children[1], depth, get_own_arg(e, 1), ctx)
                f.write(") + (")
                emit_deref(f, e.children[2], depth, ctx)
                f.write(")))")
            } else {
                // User-defined function call
                fc := func_to_c(name.ident_name())
                if enum_ctor_payload_is_own(name.ident_name(), e, ctx) {
                    f.write(fc)
                    f.write("(")
                    emit_as_ptr(f, e.children[1], depth, true, ctx)
                    f.write(")")
                } else if fcall_has_inline_capturing_func_arg(e) {
                    emit_user_fcall_with_inline_closure_cleanup(f, e, name.ident_name(), fc, depth, ctx)
                } else {
                    f.write(fc)
                    f.write("(")
                    emit_user_fcall_args(f, e, name.ident_name(), depth, ctx, false)
                    f.write(")")
                }
            }
        case:
            UNREACHABLE()
        }
        }
    case NodeType.FuncDef(fd):
        if fd.captures.len() > 0 { emit_capturing_closure_value(f, e, depth, ctx) }
        else { f.write("NULL") }
    case NodeType.BodyValue:
        emit_capturing_closure_value(f, e, depth, ctx)
    case NodeType.FieldAccess(fname):
        ref obj : Expr = e.children[0]
        if builder_fa_is_ns(e, ctx) {
            obj_sname := til_type_name(obj.expr_til_type())
            if e.expr_til_type().is(Type.Enum) {
                f.write("&(")
                f.write(obj_sname)
                f.write("){.tag = ")
                f.write(obj_sname)
                f.write("_TAG_")
                f.write(fname.field_access_name())
                f.write("}")
            } else {
                f.write(obj_sname)
                f.write("_")
                f.write(fname.field_access_name())
            }
        } else {
            // Issue #36: a field access whose receiver is the typer-internal
            // ~get_payload~ FCall (used by struct-pattern desugar inside enum
            // variants) needs an explicit C cast -- get_payload's C signature
            // returns ~void *~, but the typer preserves the variant payload's
            // Struct/Enum til_type on the FCall. Without the cast the
            // generated ~get_payload(&s)->x~ fails C compilation.
            mut obj_is_get_payload := false
            if obj.node_type.is(NodeType.FCall) {
                if obj.children.len() > 0 {
                    if obj.children[0].node_type.is(ident_node("get_payload")) {
                        obj_is_get_payload = true
                    }
                }
            }
            if obj_is_get_payload {
                obj_sname_cast := til_type_name(obj.expr_til_type())
                if obj_sname_cast.len() > 0 {
                    f.write("((")
                    f.write(obj_sname_cast)
                    f.write(" *)")
                    emit_expr(f, obj, depth, ctx)
                    f.write(")->")
                    f.write(fname.field_access_name())
                } else {
                    emit_expr(f, obj, depth, ctx)
                    if use_dot_access(obj, ctx) { f.write(".") } else { f.write("->") }
                    f.write(fname.field_access_name())
                }
            } else {
                // Field access on a Str literal (e.g. `"foo".c_str`): emit a
                // stack compound literal and dot-access the field.
                mut obj_is_str_lit := false
                switch obj.node_type {
                case NodeType.Literal(Literal.Str(_sl)):
                    obj_is_str_lit = true
                case:
                }
                if obj_is_str_lit {
                    switch obj.node_type {
                    case NodeType.Literal(Literal.Str(slit)):
                        f.write("(Str){.c_str = (void *)\"")
                        f.write(slit)
                        f.write("\", .count = ")
                        emit_usize(f, c_lit_byte_count(slit))
                        f.write("ULL, .cap = TIL_CAP_LIT}.")
                        f.write(fname.field_access_name())
                    case:
                        UNREACHABLE()
                    }
                } else {
                    emit_expr(f, obj, depth, ctx)
                    if use_dot_access(obj, ctx) { f.write(".") } else { f.write("->") }
                    f.write(fname.field_access_name())
                }
            }
        }
    case:
        f.write("/* TODO: unknown expr type */")
    }
    return f
}

priv emit_body := proc(f: File, body: Expr, depth: I32, ctx: Context) {
    for e_i : Expr in body.children {
        emit_stmt(f, e_i, depth, ctx)
    }
}
priv emit_ctor_fields := proc(f: File, var: Str, ctor: Expr, depth: I32, ctx: Context) {
    ref ecf_def : Expr = find_struct_def(til_type_name(ctor.expr_til_type()), ctx)
    mut fi : USize = 0
    for i in 1..ctor.children.len() {
        mut fld_own := OwnType.Shallow
        mut field_type := Type.Unknown
        mut fname := ""
        if ecf_def.is_null().not() {
            switch ecf_def.node_type {
            case NodeType.StructDef(ecf_sdd):
                if fi < ecf_sdd.fields.len() {
                    ref dd : Declaration = ecf_sdd.fields[fi]
                    fld_own = dd.own_type
                    field_type = dd.til_type
                    fname = dd.name
                    fi++
                }
            case:
            }
        }
        ref arg : Expr = ctor.children[i]
        if field_type.is_funcptr().or(field_type.is(Type.Body)) {
            switch arg.node_type {
            case NodeType.Ident(arg_ident):
                if arg_ident.ident_name().starts_with("hoisted__") {
                    ctx.swap_freed.add(own Str.clone(arg_ident.ident_name()))
                }
            case:
            }
        }
        emit_indent(f, depth)
        if fld_own.is(OwnType.Ref) {
            emit_field(f, var, fname, ctx)
            f.write(" = ")
            emit_expr(f, arg, depth, ctx)
            f.write(";\n")
        } else if fld_own.is(OwnType.Own) {
            if arg.node_type.is_literal_str() {
                emit_field(f, var, fname, ctx)
                f.write(" = ")
                switch arg.node_type {
                case NodeType.Literal(Literal.Str(s)):
                    emit_str_lit_expr(f, s, ctx)
                case:
                }
                f.write(";\n")
            } else if arg.node_type.is(NodeType.FCall) {
                arg_sname := til_type_name(arg.expr_til_type())
                if arg_sname.len() > 0 {
                    mut handled := false
                    switch arg.children[0].node_type {
                    case NodeType.Ident(callee_ident):
                        if callee_ident.ident_name() == arg_sname {
                            ct := c_type_name(arg.expr_til_type(), arg_sname, ctx)
                            ctx.ctor_seq = ctx.ctor_seq + 1
                            id := ctx.ctor_seq
                            tmp := format("_cs", id.to_str())
                            f.write(ct)
                            f.write(" *")
                            f.write(tmp)
                            f.write(" = malloc(sizeof(")
                            f.write(ct)
                            f.write("));\n")
                            emit_ctor_fields(f, tmp, arg, depth, ctx)
                            emit_indent(f, depth)
                            emit_field(f, var, fname, ctx)
                            f.write(" = ")
                            f.write(tmp)
                            f.write(";\n")
                            handled = true
                        }
                    case:
                    }
                    if handled.not() {
                        emit_field(f, var, fname, ctx)
                        f.write(" = ")
                        emit_as_ptr(f, arg, depth, true, ctx)
                        f.write(";\n")
                    }
                } else {
                    emit_field(f, var, fname, ctx)
                    f.write(" = ")
                    emit_as_ptr(f, arg, depth, true, ctx)
                    f.write(";\n")
                }
            } else {
                emit_field(f, var, fname, ctx)
                f.write(" = ")
                emit_as_ptr(f, arg, depth, true, ctx)
                f.write(";\n")
            }
        } else if arg.node_type.is(NodeType.FCall) {
            arg_sname2 := til_type_name(arg.expr_til_type())
            if arg_sname2.len() > 0 {
                mut is_ctor_call := false
                switch arg.children[0].node_type {
                case NodeType.Ident(callee_ident):
                    if callee_ident.ident_name() == arg_sname2 {
                        // POD nested ctor: emit the field assign with
                        // a direct compound literal, skipping the
                        // malloc-deref-free dance below.
                        if is_pod_struct(arg_sname2, ctx).and(pod_ctor_args_are_safe(arg, ctx)) {
                            emit_field(f, var, fname, ctx)
                            f.write(" = ")
                            emit_pod_compound_literal(f, arg, depth, ctx)
                            f.write(";\n")
                            is_ctor_call = true
                        } else {
                        ct := c_type_name(arg.expr_til_type(), arg_sname2, ctx)
                        ctx.ctor_seq = ctx.ctor_seq + 1
                        id := ctx.ctor_seq
                        tmp := format("_cs", id.to_str())
                        f.write(ct)
                        f.write(" *")
                        f.write(tmp)
                        f.write(" = malloc(sizeof(")
                        f.write(ct)
                        f.write("));\n")
                        emit_ctor_fields(f, tmp, arg, depth, ctx)
                        emit_indent(f, depth)
                        emit_field(f, var, fname, ctx)
                        f.write(" = *")
                        f.write(tmp)
                        f.write("; free(")
                        f.write(tmp)
                        f.write(");\n")
                        is_ctor_call = true
                        }
                    }
                case:
                }
                if is_ctor_call.not() {
                    if field_type.is_funcptr().or(field_type.is(Type.Body)).or(field_type.is(Type.Dynamic))
                    .or(fcall_is_shallow_return(arg, ctx)).or(fcall_returns_dynamic(arg, ctx)) {
                        emit_field(f, var, fname, ctx)
                        f.write(" = ")
                        emit_expr(f, arg, depth, ctx)
                        f.write(";\n")
                    } else {
                        ftype := c_type_name(arg.expr_til_type(), arg_sname2, ctx)
                        f.write("{ ")
                        f.write(ftype)
                        f.write(" *_ca = ")
                        emit_expr(f, arg, depth, ctx)
                        f.write("; ")
                        emit_field(f, var, fname, ctx)
                        f.write(" = *_ca; free(_ca); }\n")
                    }
                }
            } else {
                if field_type.is_funcptr().or(field_type.is(Type.Body)).or(field_type.is(Type.Dynamic))
                .or(fcall_is_shallow_return(arg, ctx)).or(fcall_returns_dynamic(arg, ctx)) {
                    emit_field(f, var, fname, ctx)
                    f.write(" = ")
                    emit_expr(f, arg, depth, ctx)
                    f.write(";\n")
                } else {
                    ftype := c_type_name(arg.expr_til_type(), arg_sname2, ctx)
                    f.write("{ ")
                    f.write(ftype)
                    f.write(" *_ca = ")
                    emit_expr(f, arg, depth, ctx)
                    f.write("; ")
                    emit_field(f, var, fname, ctx)
                    f.write(" = *_ca; free(_ca); }\n")
                }
            }
        } else {
            emit_field(f, var, fname, ctx)
            f.write(" = ")
            emit_deref(f, arg, depth, ctx)
            f.write(";\n")
        }
    }
}

priv emit_ns_inits := proc(f: File, depth: I32, lp: LoadedProgram) {
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            for stmt : Expr in iu.ast.children {
                if is_struct_or_enum(stmt) {
                    switch stmt.node_type {
                    case NodeType.Decl(sdecl):
                        ref edef : Expr = stmt.children[0]
                        if edef.node_type.is(NodeType.EnumDef) { continue }
                        ref ni_ns : Vec(Declaration) = def_ns_decls(edef)
                        for dd : Declaration in ni_ns {
                            if dd.default_value.is_null() { continue }
                            if dd.default_value.node_type.is(NodeType.FuncDef) { continue }
                            if dd.default_value.node_type.is(NodeType.StructDef).or(dd.default_value.node_type.is(NodeType.EnumDef)) { continue }
                            emit_indent(f, depth)
                            f.write(sdecl.name)
                            f.write("_")
                            f.write(dd.name)
                            f.write(" = ")
                            emit_deref(f, dd.default_value, depth, lp.ctx)
                            f.write(";\n")
                        }
                    case:
                        UNREACHABLE()
                    }
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for stmt : Expr in iu.ast.children {
            if is_struct_or_enum(stmt) {
                switch stmt.node_type {
                case NodeType.Decl(sdecl):
                    ref edef : Expr = stmt.children[0]
                    if edef.node_type.is(NodeType.EnumDef) { continue }
                    ref ni_ns : Vec(Declaration) = def_ns_decls(edef)
                    for dd : Declaration in ni_ns {
                        if dd.default_value.is_null() { continue }
                        if dd.default_value.node_type.is(NodeType.FuncDef) { continue }
                        if dd.default_value.node_type.is(NodeType.StructDef).or(dd.default_value.node_type.is(NodeType.EnumDef)) { continue }
                        emit_indent(f, depth)
                        f.write(sdecl.name)
                        f.write("_")
                        f.write(dd.name)
                        f.write(" = ")
                        emit_deref(f, dd.default_value, depth, lp.ctx)
                        f.write(";\n")
                    }
                case:
                    UNREACHABLE()
                }
            }
        }
    }
}

priv emit_body_scoped := proc(f: File, body: Expr, depth: I32, ctx: Context) {
    saved_sl := ctx.builder_func.stack_locals.clone()
    saved_lsl := ctx.builder_func.stack_lit_str_locals.clone()
    saved_rl := ctx.builder_func.ref_locals.clone()
    saved_rdl := ctx.builder_func.ref_dyn_locals.clone()
    emit_body(f, body, depth, ctx)
    ctx.builder_func.stack_locals = saved_sl
    ctx.builder_func.stack_lit_str_locals = saved_lsl
    ctx.builder_func.ref_locals = saved_rl
    ctx.builder_func.ref_dyn_locals = saved_rdl
}

priv emit_deref := proc(f: File, e: Expr, shallow depth: I32, ctx: Context) returns ref File {
    switch e.node_type {
    case NodeType.Ident(ident):
        if ctx.closure_emit_captures.has(ident.ident_name()) {
            emit_expr(f, e, depth, ctx)
            return f
        }
    case:
    }
    if e.expr_til_type().is(Type.Dynamic) {
        emit_expr(f, e, depth, ctx)
    } else if e.expr_til_type().is_funcptr().or(e.expr_til_type().is(Type.Body)) {
        switch e.node_type {
        case NodeType.Ident(ident):
            if is_ref_local(ident.ident_name(), ctx) {
                f.write("(void *)DEREF(").emit_expr(e, depth, ctx).write(")")
            } else {
                f.write("(void *)").emit_expr(e, depth, ctx)
            }
        case:
            f.write("(void *)").emit_expr(e, depth, ctx)
        }
    } else {
        switch e.node_type {
        case NodeType.Ident(ident):
            // Issue #223 step 3: a ref local is unambiguously a borrowed
            // pointer and must be DEREF'd, even if its name happens to
            // collide with a shallow parameter of another function (the
            // is_shallow_param check below matches by name and can false-
            // positive across funcs). Check ref-local before that shortcut,
            // but after the ref-Dynamic case (#185), which needs a typed cast.
            if ctx.builder_func.ref_dyn_locals.has(ident.ident_name()) {
                // #185: ident is a ref-Dynamic local but the typer's
                // narrow_dynamic has retyped this use to a concrete
                // primitive. Emit a typed cast so DEREF doesn't try to
                // dereference a `void *` (which is invalid C).
                ctype := til_type_to_c(e.expr_til_type())
                f.write("DEREF((").write(ctype).write(" *)").emit_expr(e, depth, ctx).write(")")
            } else if is_ref_local(ident.ident_name(), ctx) {
                f.write("DEREF(").emit_expr(e, depth, ctx).write(")")
            } else if is_shallow_param(ident.ident_name(), ctx).or(is_stack_local(ident.ident_name(), ctx)).or(is_value_global(ident.ident_name(), ctx)) {
                emit_expr(f, e, depth, ctx)
            } else {
                f.write("DEREF(").emit_expr(e, depth, ctx).write(")")
            }
        case NodeType.Literal(Literal.Str(s)):
            f.write("(Str){.c_str=(void*)\"").write(s).write("\", .count=").emit_usize(c_lit_byte_count(s)).write("ULL, .cap=TIL_CAP_LIT}")
        case NodeType.FieldAccess:
            if builder_fa_is_ns(e, ctx).and(e.expr_til_type().is(Type.Enum)) {
                f.write("(*").emit_expr(e, depth, ctx).write(")")
            } else {
                emit_expr(f, e, depth, ctx)
            }
        case:
            emit_expr(f, e, depth, ctx)
        }
    }
    return f
}

priv emit_as_ptr := proc(f: File, e: Expr, shallow depth: I32, shallow is_own: Bool, ctx: Context) returns ref File {
    if e.expr_til_type().is_funcptr().or(e.expr_til_type().is(Type.Body)) {
        switch e.node_type {
        case NodeType.Ident(ident):
            if is_ref_local(ident.ident_name(), ctx) { emit_deref(f, e, depth, ctx) }
            else { emit_expr(f, e, depth, ctx) }
        case:
            emit_expr(f, e, depth, ctx)
        }
        return f
    }
    switch e.node_type {
    case NodeType.Ident(ident):
        if ctx.closure_emit_captures.has(ident.ident_name()) {
            f.write(ctx.closure_emit_env).write("->").write(ident.ident_name())
            return f
        }
        if is_shallow_param(ident.ident_name(), ctx).or(is_stack_local(ident.ident_name(), ctx)).or(is_value_global(ident.ident_name(), ctx)) {
            if is_own {
                ref existing : Str = get_stack_local_ctype(ident.ident_name(), ctx)
                mut ctype := ""
                if existing.is_null().not() { ctype = existing.clone() } else { ctype = c_type_name(e.expr_til_type(), til_type_name(e.expr_til_type()), ctx) }
                if ctype.eq("Str").and(is_stack_lit_str_local(ident.ident_name(), ctx)).and(ctx.builder_func.force_heap_stack_lit_str_own.not()) {
                    f.write("&")
                    f.write(builder_resolve_c_ident_name(ident.ident_name(), ctx))
                } else {
                    f.write("({ ")
                    f.write(ctype)
                    f.write(" *_oa = malloc(sizeof(")
                    f.write(ctype)
                    f.write(")); *_oa = ")
                    emit_expr(f, e, depth, ctx)
                    f.write("; _oa; })")
                }
            } else {
                f.write("&")
                f.write(builder_resolve_c_ident_name(ident.ident_name(), ctx))
            }
        } else {
            emit_expr(f, e, depth, ctx)
        }
    case NodeType.FCall:
        e_sname := til_type_name(e.expr_til_type())
        if e_sname.len().gt(0).and(e.children.len().gt(0)) {
            switch e.children[0].node_type {
            case NodeType.Ident(callee_ident):
                if callee_ident.ident_name() == e_sname {
                    ctype := c_type_name(e.expr_til_type(), e_sname, ctx)
                    ctx.ctor_seq = ctx.ctor_seq + 1
                    id := ctx.ctor_seq
                    f.write("({ ")
                    f.write(ctype)
                    f.write(" *_sc")
                    emit_i32(f, id)
                    f.write(" = malloc(sizeof(")
                    f.write(ctype)
                    f.write(")); ")
                    tmp := format("_sc", id.to_str())
                    emit_ctor_fields(f, tmp, e, depth, ctx)
                    f.write(" _sc")
                    emit_i32(f, id)
                    f.write("; })")
                    return f
                }
            case:
            }
        }
        emit_expr(f, e, depth, ctx)
    case NodeType.Literal(Literal.Str):
        switch e.node_type {
        case NodeType.Literal(Literal.Str(s)):
            if is_own { emit_str_lit_temp_expr(f, s) }
            else { emit_expr(f, e, depth, ctx) }
        case:
        }
    case NodeType.FieldAccess(fname):
        if builder_fa_is_ptr(e, ctx) {
            emit_expr(f, e, depth, ctx)
        } else if builder_fa_is_ns(e, ctx).and(e.expr_til_type().is(Type.Enum)) {
            if is_own {
                obj_sname := til_type_name(e.children[0].expr_til_type())
                f.write("({ ")
                f.write(obj_sname)
                f.write(" *_oa = malloc(sizeof(")
                f.write(obj_sname)
                f.write(")); *_oa = (")
                f.write(obj_sname)
                f.write("){.tag = ")
                f.write(obj_sname)
                f.write("_TAG_")
                f.write(fname.field_access_name())
                f.write("}; _oa; })")
            } else {
                emit_expr(f, e, depth, ctx)
            }
        } else if e.expr_til_type().is(Type.Dynamic) {
            emit_expr(f, e, depth, ctx)
        } else {
            f.write("&")
            emit_expr(f, e, depth, ctx)
        }
    case NodeType.Literal(Literal.Null):
        f.write("NULL")
    case:
        ctype := c_type_name(e.expr_til_type(), til_type_name(e.expr_til_type()), ctx)
        f.write("&(")
        f.write(ctype)
        f.write("){")
        emit_expr(f, e, depth, ctx)
        f.write("}")
    }
    return f
}

// C statement-expression that parses the argv c-string `arg` into a value of
// C type `ctype` via the Str.from_c_str view, then heap-boxes it. `conv` is
// the C expression producing the value, written in terms of the view `_cv`
// (e.g. "Str_to_i64(_cv)"). The `({ ... })` block scopes its own temps, so
// sibling args never clash. Inlines what the old cli_parse_* helpers did.
priv cli_view_box := func(ctype: Str, conv: Str, arg: Str) returns Str {
    return "({ Str *_cv = Str_from_c_str(".format(arg, "); ", ctype, " _v = ", conv,
        "; Str_delete(_cv, (Bool){1}); ", ctype, " *_p = malloc(sizeof(", ctype,
        ")); *_p = _v; _p; })")
}

// C expression evaluating to a freshly heap-allocated `<ttype> *` parsed from
// the argv c-string `arg`, for every CLI arg type. Returns "" for unsupported
// types. Str is the one outlier: it owns a deep copy of the bytes (Str_clone)
// rather than parsing a borrowed view, so it can't share the from_c_str
// pipeline. Bool's conversion is an inline ternary that bails via exit(1) on a
// non-true/false value (consistent with the other CLI validation in main()).
priv cli_box_expr := func(ttype: Str, arg: Str) returns Str {
    if ttype == "Str" {
        return "Str_clone(&(Str){.c_str = (void *)".format(arg, ", .count = strlen(", arg, "), .cap = TIL_CAP_LIT})")
    }
    if ttype == "I64" { return cli_view_box("I64", "Str_to_i64(_cv)", arg) }
    if ttype == "U8" { return cli_view_box("U8", "Str_to_u8(_cv)", arg) }
    if ttype == "I8" { return cli_view_box("I8", "I64_to_i8(Str_to_i64(_cv))", arg) }
    if ttype == "I16" { return cli_view_box("I16", "I64_to_i16(Str_to_i64(_cv))", arg) }
    if ttype == "U16" { return cli_view_box("U16", "I64_to_u16(Str_to_i64(_cv))", arg) }
    if ttype == "I32" { return cli_view_box("I32", "Str_to_i32(_cv)", arg) }
    if ttype == "U32" { return cli_view_box("U32", "Str_to_u32(_cv)", arg) }
    if ttype == "U64" { return cli_view_box("U64", "Str_to_u64(_cv)", arg) }
    if ttype == "USize" { return cli_view_box("USize", "Str_to_u64(_cv)", arg) }
    if ttype == "UPtr" { return cli_view_box("UPtr", "Str_to_u64(_cv)", arg) }
    if ttype == "F32" { return cli_view_box("F32", "Str_to_f32(_cv)", arg) }
    if ttype == "Bool" {
        true_lit := "&(Str){.c_str = (void *)\"true\", .count = 4ULL, .cap = TIL_CAP_LIT}"
        false_lit := "&(Str){.c_str = (void *)\"false\", .count = 5ULL, .cap = TIL_CAP_LIT}"
        conv := "Str_cmp(_cv, ".format(true_lit, ") == 0 ? 1 : (Str_cmp(_cv, ", false_lit,
            ") == 0 ? 0 : (fprintf(stderr, \"error: cannot parse '%s' as Bool (expected true/false)\\n\", ",
            arg, "), exit(1), 0))")
        return cli_view_box("Bool", conv, arg)
    }
    return ""
}

// Emit the indented C declaration that binds CLI argument `var` of til type
// `ttype`, parsed from the argv c-string expression `arg`. Used by both the
// fixed-arg and variadic-arg paths in main()'s generated entry wrapper.
priv emit_cli_parse_value := proc(f: File, ind: Str, ttype: Str, var: Str, arg: Str) {
    expr := cli_box_expr(ttype, arg)
    if expr == "" {
        f.write(ind).write("// unsupported CLI arg type: ").write(ttype).write("\n")
        f.write(ind).write("fprintf(stderr, \"error: unsupported CLI argument type '").write(ttype).write("'\\n\"); return 1;\n")
        return
    }
    f.write(ind).write(ttype).write(" *").write(var).write(" = ").write(expr).write(";\n")
}

// True if executing `e` can never fall through to the statement that would
// follow it: it always returns, or every branch of it does. A non-void
// function whose body diverges gets a trailing `__builtin_unreachable()`
// (see emit_diverge_terminator) so GCC's -Wreturn-type stays quiet under
// ASAN -- `-fsanitize=address` mutates the CFG enough that GCC can no longer
// prove an exhaustive switch/if never falls off the end of a non-void
// function, and mis-fires "control reaches end of non-void function".
// The check is SOUND (only true when control genuinely cannot reach the end),
// so a genuinely missing return is never hidden: such a body does NOT diverge,
// no terminator is emitted, and GCC's -Werror=return-type still fires on it --
// til's only all-paths-return safety net.
priv body_diverges := func(e: Expr) returns Bool {
    switch e.node_type {
    case NodeType.Return:
        return true
    case NodeType.Body:
        // A block never falls through iff one of its statements diverges: the
        // garbager appends an owned-local cleanup after the real terminator,
        // so "any child diverges" is what marks the block as non-falling.
        for c : Expr in e.children {
            if body_diverges(c) { return true }
        }
        return false
    case NodeType.If:
        // Needs an else branch (children[2]) AND both branches diverging.
        if e.children.len() <= 2 { return false }
        return body_diverges(e.children[1]).and(body_diverges(e.children[2]))
    case NodeType.Switch:
        // C-exhaustive (a `default:`, emitted for the `case:` wildcard) and
        // every arm diverges. Without a default GCC treats the switch as able
        // to fall off its end, so the default is required to claim divergence.
        mut has_default := false
        for ci in 1..e.children.len() {
            ref cn : Expr = e.children[ci]
            if cn.children.len() == 1 {
                has_default = true
                if body_diverges(cn.children[0]).not() { return false }
            } else {
                if body_diverges(cn.children[1]).not() { return false }
            }
        }
        return has_default
    case:
        return false
    }
}

// Emit the trailing `__builtin_unreachable()` for a non-void function whose
// body never falls through (see body_diverges). No-op for void functions
// (they may legally fall off the end) and for bodies that can fall through
// (leaving GCC's -Werror=return-type to catch a genuinely missing return).
priv emit_diverge_terminator := proc(f: File, ret: Str, body: Expr) {
    if ret.eq("void").not().and(body_diverges(body)) {
        f.write("    __builtin_unreachable();\n")
    }
}

priv emit_func_def := proc(f: File, name: Str, func_def: Expr, mode: Mode, is_static: Bool, lp: LoadedProgram) {
    switch func_def.node_type {
    case NodeType.FuncDef(fd):
    ref body : Expr = func_def.children[0]
    mut is_main := false
    if mode.is_null().not() {
        if mode.needs_main { is_main = name == "main" }
    }

    if is_main {
        nparam := fd.params.len()
        vi := fd.variadic_index
        if nparam == 0 {
            f.write("int main(int argc, char **argv) {\n")
            f.write("    (void)argv;\n")
            f.write("    if (argc > 1) { fprintf(stderr, \"error: main expects no arguments, got %d\\n\", argc - 1); return 1; }\n")
        } else {
            f.write("int main(int argc, char **argv) {\n")
            mut fixed := nparam.to_i32()
            if vi >= 0 {
                fixed--
                f.write("    if (argc - 1 < "); emit_i32(f, fixed); f.write(") { fprintf(stderr, \"error: main expects at least "); emit_i32(f, fixed); f.write(" argument(s), got %d\\n\", argc - 1); return 1; }\n")
            } else {
                f.write("    if (argc - 1 != "); emit_i32(f, nparam.to_i32()); f.write(") { fprintf(stderr, \"error: main expects "); emit_i32(f, nparam.to_i32()); f.write(" argument(s), got %d\\n\", argc - 1); return 1; }\n")
            }
        }
        emit_ns_inits(f, 1, lp)
        if lp.ctx.script_globals.len() > 0 {
            if lp.skip_core.not() {
                for u : ProgramUnit in lp.core_units {
                    ref iu : ImportUnit = lp.ctx.imported[u.path]
                    for gs : Expr in iu.ast.children {
                        if gs.node_type.is(NodeType.Decl) {
                            ref rhs : Expr = gs.children[0]
                            if rhs.node_type.is(NodeType.FuncDef).or(rhs.node_type.is(NodeType.StructDef)).or(rhs.node_type.is(NodeType.EnumDef)) { continue }
                            if gs.expr_til_type().is(Type.None).and(rhs.node_type.is(NodeType.Ident)) { continue }
                        } else if gs.node_type.is(NodeType.FCall).not() { continue }
                        emit_stmt(f, gs, 1, lp.ctx)
                    }
                }
            }
            for u : ProgramUnit in lp.units {
                ref iu : ImportUnit = lp.ctx.imported[u.path]
                for gs : Expr in iu.ast.children {
                    if gs.node_type.is(NodeType.Decl) {
                        ref rhs : Expr = gs.children[0]
                        if rhs.node_type.is(NodeType.FuncDef).or(rhs.node_type.is(NodeType.StructDef)).or(rhs.node_type.is(NodeType.EnumDef)) { continue }
                        if gs.expr_til_type().is(Type.None).and(rhs.node_type.is(NodeType.Ident)) { continue }
                    } else if gs.node_type.is(NodeType.FCall).not() { continue }
                    emit_stmt(f, gs, 1, lp.ctx)
                }
            }
        }
        if nparam > 0 {
            mut argi : I32 = 1
            for i in 0..nparam {
                ref p : Declaration = fd.params[i]
                ii := i.to_i32()
                if ii == vi {
                    // Variadic array
                    arr_type := builder_variadic_array_type_name(lp.ctx, p.explicit_type)
                    arr_ctype := type_name_to_c(arr_type, lp.ctx)
                    f.write("    int _va_argc = argc - "); emit_i32(f, argi); f.write(";\n")
                    f.write("    USize _va_cap = _va_argc;\n")
                    f.write("    ").write(arr_ctype).write(" ").write(p.name).write(" = ")
                    if arr_type == "Array" {
                        f.write("Array_new_type_name(&(Str){.c_str = (void *)\"").write(p.explicit_type).write("\", .count = "); emit_usize(f, p.explicit_type.len()); f.write("ULL, .cap = TIL_CAP_LIT}, _va_cap);\n")
                    } else {
                        f.write("malloc(sizeof(").write(arr_type).write("));\n")
                        f.write("    ").write(p.name).write("->data = calloc(_va_cap, sizeof(").write(p.explicit_type).write("));\n")
                        f.write("    ").write(p.name).write("->cap = _va_cap;\n")
                    }
                    f.write("    for (int _i = 0; _i < _va_argc; _i++) {\n")
                    f.write("        USize _idx = _i;\n")
                    varg := "argv[".format(argi.to_str(), " + _i]")
                    emit_cli_parse_value(f, "        ", p.explicit_type, "_val", varg)
                    // Issue #225: write the element directly instead of via
                    // Array.set. Array.set is about to start throwing
                    // OutOfBounds (so `arr[i] = v` can desugar to
                    // `arr.set(i, own v)!`), which changes its arity and would
                    // break this generated call. The slot is freshly
                    // zero-allocated and `_idx` is always in bounds here, so a
                    // raw memcpy is correct -- identical to the Vec path.
                    f.write("        memcpy(ptr_add(").write(p.name).write("->data, ((U64)_idx) * sizeof(").write(p.explicit_type).write(")), _val, sizeof(").write(p.explicit_type).write("));\n")
                    f.write("        memset(_val, 0, sizeof(").write(p.explicit_type).write("));\n")
                    f.write("        ").write(p.explicit_type).write("_delete(_val, 1);\n")
                    f.write("    }\n")
                } else {
                    arg := "argv[".format(argi.to_str(), "]")
                    emit_cli_parse_value(f, "    ", p.explicit_type, p.name, arg)
                    argi++
                }
            }
        }
        builder_reset_func_scratch(lp.ctx)
        collect_unsafe_to_hoist(lp.ctx, body)
        lp.ctx.in_main_func = true
        emit_body(f, body, 1, lp.ctx)
        lp.ctx.in_main_func = false
        f.write("    return 0;\n")
        f.write("}\n")
    } else {
        // Return type
        ret := func_return_ctype(fd, lp.ctx)
        // Signature
        if is_static { f.write("static __attribute__((unused)) ") }
        f.write(ret).write(" "); fc := func_to_c(name); f.write(fc).write("(")
        emit_param_list(f, func_def, true, false, lp.ctx)
        f.write(") {\n")
        // Suppress -Wunused-parameter for params that aren't referenced
        // in the body. At this point any non-_ param is body-referenced
        // (otherwise check_unused_params would have errored), so this
        // narrows to `_x`-prefixed deliberately-unused params.
        body_refs := Set(Str).new()
        collect_ident_refs(body, body_refs)
        for p : Declaration in fd.params {
            if body_refs.has(p.name).not() {
                f.write("    (void)").write(p.name).write(";\n")
            }
        }
        own body_refs.delete(true)
        lp.ctx.in_func_def = true
        lp.ctx.current_fdef = func_def
        builder_reset_func_scratch(lp.ctx)
        collect_unsafe_to_hoist(lp.ctx, body)
        emit_body(f, body, 1, lp.ctx)
        lp.ctx.in_func_def = false
        emit_diverge_terminator(f, ret, body)
        f.write("}\n")
    }
    case:
        UNREACHABLE()
    }
}

emit_capturing_closure_func := proc(f: File, closure_expr: Expr, mut emitted: Set(Str), lp: LoadedProgram) {
    switch closure_expr.node_type {
    case NodeType.FuncDef(fd):
        if fd.captures.len().eq(0).or(fd.closure_name.len().eq(0)) { return }
        if emitted.has(fd.closure_name) { return }
        emitted.add(own fd.closure_name.clone())
        env_type := format(fd.closure_name, "_env")
        f.write("typedef struct ").write(env_type).write(" {\n")
        for cap : Declaration in fd.captures {
            ctype := c_type_name(cap.til_type, til_type_name(cap.til_type), lp.ctx)
            f.write("    ").write(ctype).write(" *").write(cap.name).write(";\n")
        }
        f.write("} ").write(env_type).write(";\n")
        f.write("static __attribute__((unused)) void ").write(fd.closure_name).write("_drop(void *til_env_raw) {\n")
        f.write("    ").write(env_type).write(" *til_env = (").write(env_type).write(" *)til_env_raw;\n")
        for drop_cap : Declaration in fd.captures {
            if drop_cap.own_type.is(OwnType.Ref).not() {
                drop_type := type_to_name(drop_cap.til_type)
                if is_primitive_type(drop_type) {
                    f.write("    free(til_env->").write(drop_cap.name).write(");\n")
                } else {
                    f.write("    ").write(drop_type).write("_delete(til_env->").write(drop_cap.name).write(", ").write(delete_call_free_lit(drop_type, true, lp.ctx)).write(");\n")
                }
            }
        }
        f.write("    free(til_env);\n")
        f.write("}\n")
        ret := func_return_ctype(fd, lp.ctx)
        f.write("static __attribute__((unused)) ").write(ret).write(" ").write(fd.closure_name).write("(void *til_env_raw")
        if fd.params.len() > 0 {
            f.write(", ")
            emit_param_list(f, closure_expr, true, false, lp.ctx)
        }
        f.write(") {\n")
        f.write("    ").write(env_type).write(" *til_env = (").write(env_type).write(" *)til_env_raw;\n")
        // Issue #295: the body may not reference any capture (e.g. a captured
        // constant const-folds away), leaving til_env unused under -Werror.
        f.write("    (void)til_env;\n")
        saved_env := lp.ctx.closure_emit_env.clone()
        saved_caps := lp.ctx.closure_emit_captures.clone()
        saved_in_func_def := lp.ctx.in_func_def
        ref saved_current_fdef : Expr = lp.ctx.current_fdef
        saved_builder_func := lp.ctx.builder_func.clone()
        lp.ctx.closure_emit_env = "til_env"
        lp.ctx.closure_emit_captures = Set(Str).new()
        for cap2 : Declaration in fd.captures { lp.ctx.closure_emit_captures.add(own cap2.name.clone()) }
        lp.ctx.in_func_def = true
        lp.ctx.current_fdef = closure_expr
        builder_reset_func_scratch(lp.ctx)
        collect_unsafe_to_hoist(lp.ctx, closure_expr.children[0])
        emit_body(f, closure_expr.children[0], 1, lp.ctx)
        lp.ctx.closure_emit_env = saved_env
        lp.ctx.closure_emit_captures = saved_caps
        lp.ctx.in_func_def = saved_in_func_def
        lp.ctx.current_fdef = saved_current_fdef
        lp.ctx.builder_func = saved_builder_func
        emit_diverge_terminator(f, ret, closure_expr.children[0])
        f.write("}\n\n")
    case NodeType.BodyValue(bd):
        if bd.closure_name.len().eq(0) { return }
        if emitted.has(bd.closure_name) { return }
        emitted.add(own bd.closure_name.clone())
        env_type_b := format(bd.closure_name, "_env")
        f.write("typedef struct ").write(env_type_b).write(" {\n")
        if bd.captures.len() == 0 { f.write("    char unused;\n") }
        for cap_b2 : Declaration in bd.captures {
            ctype_b2 := c_type_name(cap_b2.til_type, til_type_name(cap_b2.til_type), lp.ctx)
            f.write("    ").write(ctype_b2).write(" *").write(cap_b2.name).write(";\n")
        }
        f.write("} ").write(env_type_b).write(";\n")
        f.write("static __attribute__((unused)) void ").write(bd.closure_name).write("_drop(void *til_env_raw) {\n")
        f.write("    ").write(env_type_b).write(" *til_env = (").write(env_type_b).write(" *)til_env_raw;\n")
        for drop_cap_b : Declaration in bd.captures {
            if drop_cap_b.own_type.is(OwnType.Ref).not() {
                drop_type_b := type_to_name(drop_cap_b.til_type)
                if is_primitive_type(drop_type_b) {
                    f.write("    free(til_env->").write(drop_cap_b.name).write(");\n")
                } else {
                    f.write("    ").write(drop_type_b).write("_delete(til_env->").write(drop_cap_b.name).write(", ").write(delete_call_free_lit(drop_type_b, true, lp.ctx)).write(");\n")
                }
            }
        }
        f.write("    free(til_env);\n")
        f.write("}\n")
        f.write("static __attribute__((unused)) void ").write(bd.closure_name).write("(void *til_env_raw) {\n")
        f.write("    ").write(env_type_b).write(" *til_env = (").write(env_type_b).write(" *)til_env_raw;\n")
        f.write("    (void)til_env;\n")
        saved_env_b := lp.ctx.closure_emit_env.clone()
        saved_caps_b := lp.ctx.closure_emit_captures.clone()
        saved_in_func_def_b := lp.ctx.in_func_def
        ref saved_current_fdef_b : Expr = lp.ctx.current_fdef
        saved_builder_func_b := lp.ctx.builder_func.clone()
        lp.ctx.closure_emit_env = "til_env"
        lp.ctx.closure_emit_captures = Set(Str).new()
        for cap_b3 : Declaration in bd.captures { lp.ctx.closure_emit_captures.add(own cap_b3.name.clone()) }
        lp.ctx.in_func_def = true
        lp.ctx.current_fdef = closure_expr
        builder_reset_func_scratch(lp.ctx)
        collect_unsafe_to_hoist(lp.ctx, closure_expr.children[0])
        emit_body(f, closure_expr.children[0], 1, lp.ctx)
        lp.ctx.closure_emit_env = saved_env_b
        lp.ctx.closure_emit_captures = saved_caps_b
        lp.ctx.in_func_def = saved_in_func_def_b
        lp.ctx.current_fdef = saved_current_fdef_b
        lp.ctx.builder_func = saved_builder_func_b
        f.write("}\n\n")
    case:
    }
}

emit_capturing_closures_in_expr := proc(f: File, e: Expr, mut emitted: Set(Str), lp: LoadedProgram) {
    expect(e.is_null().not(), "e is null")
    emit_capturing_closure_func(f, e, emitted, lp)
    switch e.node_type {
    case NodeType.FuncDef(fd):
        for p : Declaration in fd.params { emit_capturing_closures_in_expr(f, p.default_value, emitted, lp) }
    case NodeType.StructDef(sdd):
        for sf : Declaration in sdd.fields { emit_capturing_closures_in_expr(f, sf.default_value, emitted, lp) }
        for nd : Declaration in sdd.ns_decls { emit_capturing_closures_in_expr(f, nd.default_value, emitted, lp) }
    case NodeType.EnumDef(edd):
        for nd : Declaration in edd.ns_decls { emit_capturing_closures_in_expr(f, nd.default_value, emitted, lp) }
    case:
    }
    for c : Expr in e.children { emit_capturing_closures_in_expr(f, c, emitted, lp) }
}

emit_capturing_closures_lp := proc(f: File, lp: LoadedProgram) {
    mut emitted := Set(Str).new()
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            emit_capturing_closures_in_expr(f, iu.ast, emitted, lp)
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        emit_capturing_closures_in_expr(f, iu.ast, emitted, lp)
    }
}

priv emit_struct_typedef := proc(f: File, name: Str, struct_def: Expr, mut emitted_tags: Set(Str)) {
    if is_ext_h_type(name) { return }
    switch struct_def.node_type {
    case NodeType.StructDef(sdd):
        if sdd.c_tag.len().gt(0).and(sdd.c_tag.eq("@anon").not()) {
            if emitted_tags.has(sdd.c_tag) {
                // Two ext_structs sharing one C tag (e.g. nng_sockaddr_ipc
                // aliasing "nng_sockaddr_path"): defining `struct TAG` twice
                // is a C error. Emit a typedef alias to the first
                // definition instead. (#269's scavenger wildcard keeps all
                // dyn-reachable types, so tag aliases that the scavenger
                // used to prune now reach this emitter.)
                f.write("typedef struct ").write(sdd.c_tag).write(" ").write(name).write(";\n")
                return
            }
            emitted_tags.add(own sdd.c_tag.clone())
        }
        if sdd.c_tag == "@anon" {
            f.write("typedef struct {\n")
        } else if sdd.c_tag.len() > 0 {
            f.write("typedef struct ").write(sdd.c_tag).write(" {\n")
        } else {
            f.write("typedef struct ").write(name).write(" {\n")
        }
        if sdd.fields.len() == 0 { f.write("    char _;\n") }
        for dd : Declaration in sdd.fields {
            if dd.own_type.is(OwnType.Shallow).not() {
                if dd.til_type.is(Type.Struct).or(dd.til_type.is(Type.Enum)) {
                    sname := til_type_name(dd.til_type)
                    if sname.len() > 0 {
                        f.write("    ").write(sname).write(" *").write(dd.name).write(";\n")
                    } else {
                        tc := field_emit_ctype(dd); f.write("    ").write(tc).write(" *").write(dd.name).write(";\n")
                    }
                } else {
                    tc := field_emit_ctype(dd); f.write("    ").write(tc).write(" *").write(dd.name).write(";\n")
                }
            } else if dd.til_type.is(Type.Struct).or(dd.til_type.is(Type.Enum)) {
                sname := til_type_name(dd.til_type)
                if sname.len() > 0 {
                    f.write("    ").write(sname).write(" ").write(dd.name).write(";\n")
                } else {
                    tc := field_emit_ctype(dd); f.write("    ").write(tc).write(" ").write(dd.name).write(";\n")
                }
            } else {
                tc := field_emit_ctype(dd); f.write("    ").write(tc).write(" ").write(dd.name).write(";\n")
            }
        }
        f.write("} ").write(name).write(";\n\n")
    case:
        UNREACHABLE()
    }
}

priv emit_ns_method := proc(f: File, name: Str, dd_name: Str, fdef: Expr, lp: LoadedProgram) {
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)).or(fd.func_type.is(FuncType.CoreFunc)).or(fd.func_type.is(FuncType.CoreProc)) { return }
    case:
        UNREACHABLE()
        return
    }
    // A bodyless namespace signature (interface method, issue #251) is a
    // FuncSig type, not an implementation -- it emits no C function.
    if fdef.children.len() == 0 { return }
    full_name := name.concat3("_", dd_name)
    emit_func_def(f, full_name, fdef, NULL, false, lp)
    f.write("\n")
}

priv emit_struct_funcs := proc(f: File, name: Str, struct_def: Expr, lp: LoadedProgram) {
    // User-defined from ns_decls
    ref ns : Vec(Declaration) = def_ns_decls(struct_def)
    for dd : Declaration in ns {
        if dd.default_value.is_null() { continue }
        if dd.default_value.node_type.is(NodeType.NoDefaultArg) { continue }
        if dd.default_value.node_type.is(NodeType.FuncDef) {
            emit_ns_method(f, name, dd.name, dd.default_value, lp)
        }
    }
}

priv emit_enum_def := proc(f: File, name: Str, enum_def: Expr, lp: LoadedProgram) {
    switch enum_def.node_type {
    case NodeType.EnumDef(edd):
        hp := enum_has_payloads(enum_def)
        if hp.not() {
            // Simple enum
            for vn : Str in edd.variants {
                f.write(name).write(" *").write(name).write("_").write(vn).write("() {\n")
                f.write("    ").write(name).write(" *r = malloc(sizeof(").write(name).write("));\n")
                f.write("    *r = (").write(name).write("){ .tag = ").write(name).write("_TAG_").write(vn).write(" };\n")
                f.write("    return r;\n").write("}\n")
            }
        } else {
            // Payload enum
            for i in 0..edd.variants.len() {
                ref vn : Str = edd.variants[i]
                vt := enum_variant_type(enum_def, i.to_i32())
                if vt.len() == 0 {
                    f.write(name).write(" *").write(name).write("_").write(vn).write("() {\n")
                    f.write("    ").write(name).write(" *r = malloc(sizeof(").write(name).write("));\n")
                    f.write("    r->tag = ").write(name).write("_TAG_").write(vn).write(";\n")
                    f.write("    return r;\n").write("}\n")
                    continue
                }
                ptype := type_name_to_c(vt, lp.ctx)
                f.write(name).write(" *").write(name).write("_").write(vn).write("(").write(ptype).write(" val) {\n")
                f.write("    ").write(name).write(" *r = malloc(sizeof(").write(name).write("));\n")
                f.write("    r->tag = ").write(name).write("_TAG_").write(vn).write(";\n")
                if is_primitive_type(vt) {
                    f.write("    r->data.").write(vn).write(" = *val;\n")
                } else if is_funcsig_type(vt, lp.ctx).or(vt.eq("Dynamic")) {
                    f.write("    r->data.").write(vn).write(" = val;\n")
                } else {
                    // Issue #109: payload param is Own -- caller transferred
                    // the heap `val`, so move its contents and free it.
                    f.write("    r->data.").write(vn).write(" = *val;\n")
                    if vt == "Str" { f.write("    if (val->cap != TIL_CAP_LIT) { free(val); }\n") }
                    else { f.write("    free(val);\n") }
                }
                f.write("    return r;\n").write("}\n")
            }
        }
    case:
        UNREACHABLE()
    }
    // Namespace methods from ns_decls
    ref ens : Vec(Declaration) = def_ns_decls(enum_def)
    for dd : Declaration in ens {
        if dd.default_value.is_null() { continue }
        if dd.default_value.node_type.is(NodeType.FuncDef).not() { continue }
        emit_ns_method(f, name, dd.name, dd.default_value, lp)
    }
}

priv emit_enum_struct_body := proc(f: File, ename: Str, enum_def: Expr, ctx: Context) {
    f.write("struct ").write(ename).write(" {\n")
    // #264: emit the tag field with the discriminant's integer type so
    // sizeof matches the chosen width (default U8); the `<ename>_TAG_X`
    // enum constants stay usable as plain integer values.
    tag_ctype := type_name_to_c_value(enum_tag_type(enum_def), ctx)
    f.write("    ").write(tag_ctype).write(" tag;\n")
    if enum_has_payloads(enum_def) {
        f.write("    union {\n")
        switch enum_def.node_type {
        case NodeType.EnumDef(edd):
            for j in 0..edd.variants.len() {
                vt := enum_variant_type(enum_def, j.to_i32())
                if vt.len() > 0 {
                    tnv := type_name_to_c_value(vt, ctx)
                    f.write("        ").write(tnv).write(" ").write(edd.variants[j]).write(";\n")
                }
            }
        case:
            UNREACHABLE()
        }
        f.write("    } data;\n")
    }
    f.write("};\n\n")
}

// Topologically emit struct/enum typedefs across all per-file units in ctx.
priv topo_emit_struct_enum_defs_lp := proc(f: File, mut emitted: Set(Str), lp: LoadedProgram) {
    // C struct tags already emitted with a full body; repeats become
    // typedef aliases (see emit_struct_typedef).
    mut emitted_tags := Set(Str).new()
    // Vec<Dynamic> stores raw pointers (8-byte values). Each push takes an
    // allocated 8-byte temp, copies the pointer bytes, then frees the temp.
    mut items := Vec(Dynamic).new()
    // Collect pointers to all struct/enum decl statements in stable order.
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            for stmt : Expr in iu.ast.children {
                if stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0)) {
                    ref decl_value : Expr = stmt.children[0]
                    if decl_value.node_type.is(NodeType.StructDef).or(decl_value.node_type.is(NodeType.EnumDef)) {
                        tmp : Dynamic = malloc(I64.size().cast(U64))
                        write_ptr(tmp, stmt)
                        items.push(own tmp)
                    }
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for stmt : Expr in iu.ast.children {
            if stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0)) {
                ref decl_value2 : Expr = stmt.children[0]
                if decl_value2.node_type.is(NodeType.StructDef).or(decl_value2.node_type.is(NodeType.EnumDef)) {
                    tmp2 : Dynamic = malloc(I64.size().cast(U64))
                    write_ptr(tmp2, stmt)
                    items.push(own tmp2)
                }
            }
        }
    }

    mut remaining := items.len()
    mut done := Array(Bool).new(items.len())
    for di in 0..items.len() {
        mut f_val := false
        done[di] = f_val
    }

    while remaining > 0 {
        mut progress := false
        for ei in 0..items.len() {
            if done[ei] { continue }
            ref ptr : Dynamic = items[ei]
            ref stmt : Expr = deref(ptr)
            switch stmt.node_type {
            case NodeType.Decl(sdecl):
                ref def : Expr = stmt.children[0]
                mut deps_ok := true
                switch def.node_type {
                case NodeType.StructDef(dep_sdd):
                    for dd : Declaration in dep_sdd.fields {
                        if dd.own_type.is(OwnType.Shallow) {
                            if is_aggregate(dd.til_type) {
                                dep_sname := til_type_name(dd.til_type)
                                if dep_sname.len() > 0 {
                                    if emitted.has(dep_sname).not() { deps_ok = false }
                                }
                            }
                        }
                    }
                case NodeType.EnumDef(dep_edd):
                    for fi in 0..dep_edd.variants.len() {
                        dep_vt := enum_variant_type(def, fi.to_i32())
                        if dep_vt.len() > 0 {
                            if is_primitive_type(dep_vt).not().and(is_funcsig_type(dep_vt, lp.ctx).not()) {
                                if emitted.has(dep_vt).not() { deps_ok = false }
                            }
                        }
                    }
                case:
                    UNREACHABLE()
                }
                if deps_ok.not() { continue }
                if def.node_type.is(NodeType.StructDef) {
                    emit_struct_typedef(f, sdecl.name, def, emitted_tags)
                    f.write("\n")
                } else {
                    emit_enum_struct_body(f, sdecl.name, def, lp.ctx)
                }
                emitted.add(own sdecl.name.clone())
                mut t_val := true
                done[ei] = t_val
                remaining--
                progress = true
            case:
                UNREACHABLE()
            }
        }
        if progress.not() {
            // Fallback: emit remaining in scan order.
            for ei in 0..items.len() {
                if done[ei] { continue }
                ref ptr2 : Dynamic = items[ei]
                ref stmt : Expr = deref(ptr2)
                switch stmt.node_type {
                case NodeType.Decl(sdecl):
                    ref def : Expr = stmt.children[0]
                    if def.node_type.is(NodeType.StructDef) {
                        emit_struct_typedef(f, sdecl.name, def, emitted_tags)
                        f.write("\n")
                    } else {
                        emit_enum_struct_body(f, sdecl.name, def, lp.ctx)
                    }
                    emitted.add(own sdecl.name.clone())
                case:
                    UNREACHABLE()
                }
            }
            break
        }
    }

    own items.delete()
    own done.delete()
}

// Resolve the C return type for a FunctionDef; "void" when the proc
// has no return type. Avoids the `mut ret := "void"` reassign pattern
// in emit_func_forward_decl / emit_funcsig_typedef whose default
// "void" Str_lit leaked when reassigned.
priv func_return_ctype := func(fd: FunctionDef, ctx: Context) returns Str {
    if fd.return_type.len() == 0 { return "void" }
    if fd.return_own_type.is(OwnType.Shallow) { return type_name_to_c_value(fd.return_type, ctx) }
    return type_name_to_c(fd.return_type, ctx)
}

priv emit_func_forward_decl := proc(f: File, name: Str, fdef: Expr, top_level: Bool, ctx: Context) {
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        // Issue #176: top-level ext_func / ext_proc prototypes are emitted by
        // emit_ext_func_declarations (with the FFI const convention). Skip
        // them here so til_forward.h / monolithic headers don't contain a
        // second non-const prototype that clashes with the const definition
        // in ext.c / ext.h. Namespace ext_func methods still need their
        // forward decl from this path (top_level=false) -- nothing else
        // covers them.
        if top_level.and(fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)).or(fd.func_type.is(FuncType.CoreFunc)).or(fd.func_type.is(FuncType.CoreProc))) { return }
        if name == "main" { return }
        ret := func_return_ctype(fd, ctx)
        f.write(ret).write(" ").write(name).write("(")
        emit_param_list(f, fdef, true, false, ctx)
        f.write(");\n")
    case:
        UNREACHABLE()
    }
}

priv emit_closure_forward_decl := proc(f: File, name: Str, fdef: Expr, ctx: Context) {
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        ret := func_return_ctype(fd, ctx)
        call_name := closure_call_name(name)
        value_name := closure_value_name(name)
        f.write("static ").write(ret).write(" ").write(call_name).write("(void *til_env")
        if fd.params.len() > 0 {
            f.write(", ")
            emit_param_list(f, fdef, true, false, ctx)
        }
        f.write(");\n")
        f.write("static __attribute__((unused)) TilClosure ").write(value_name).write(";\n")
    case:
        UNREACHABLE()
    }
}

priv emit_closure_wrapper_def := proc(f: File, name: Str, fdef: Expr, ctx: Context) {
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        ret := func_return_ctype(fd, ctx)
        call_name := closure_call_name(name)
        value_name := closure_value_name(name)
        f.write("static ").write(ret).write(" ").write(call_name).write("(void *til_env")
        if fd.params.len() > 0 {
            f.write(", ")
            emit_param_list(f, fdef, true, false, ctx)
        }
        f.write(") {\n")
        f.write("    (void)til_env;\n")
        if fd.return_type.len() > 0 { f.write("    return ") }
        else { f.write("    ") }
        f.write(func_to_c(name)).write("(")
        for i in 0..fd.params.len() {
            if i > 0 { f.write(", ") }
            f.write(fd.params[i].name)
        }
        f.write(");\n")
        f.write("}\n")
        f.write("static __attribute__((unused)) TilClosure ").write(value_name).write(" = { (void *)").write(call_name).write(", NULL, NULL };\n")
    case:
        UNREACHABLE()
    }
}

priv emit_funcsig_typedef := proc(f: File, name: Str, fdef: Expr, _ctx: Context) {
    switch fdef.node_type {
    case NodeType.FuncDef:
        f.write("typedef TilClosure *").write(name).write(";\n")
    case:
        UNREACHABLE()
    }
}

emit_closure_runtime_types := proc(f: File) {
    f.write("typedef struct TilClosure TilClosure;\n")
    f.write("struct TilClosure {\n")
    f.write("    void *call;\n")
    f.write("    void *env;\n")
    f.write("    void (*drop)(void *);\n")
    f.write("};\n\n")
}

emit_funcsig_typedefs_prog := proc(f: File, prog: Expr, ctx: Context) {
    for stmt : Expr in prog.children {
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        if stmt.children.len() == 0 { continue }
        switch stmt.node_type {
        case NodeType.Decl(dd):
            ref rhs : Expr = stmt.children[0]
            if rhs.node_type.is(NodeType.FuncDef) {
                if rhs.children.len() == 0 {
                    emit_funcsig_typedef(f, dd.name, rhs, ctx)
                }
            } else {
                switch rhs.node_type {
                case NodeType.Ident(rhs_name):
                    if stmt.expr_til_type().is(Type.None).and(is_funcsig_type(rhs_name.ident_name(), ctx)) {
                        f.write("typedef ").write(rhs_name.ident_name()).write(" ").write(dd.name).write(";\n")
                    }
                case:
                }
            }
        case:
            UNREACHABLE()
        }
    }
}

emit_funcsig_typedefs := proc(f: File, core_program: Expr, program: Expr, ctx: Context) {
    if core_program.is_null().not() { emit_funcsig_typedefs_prog(f, core_program, ctx) }
    if program.is_null().not()      { emit_funcsig_typedefs_prog(f, program, ctx) }
    f.write("\n")
}

priv emit_funcsig_typedefs_lp := proc(f: File, lp: LoadedProgram) {
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            for stmt : Expr in iu.ast.children {
                if stmt.node_type.is(NodeType.Decl).not() { continue }
                if stmt.children.len() == 0 { continue }
                switch stmt.node_type {
                case NodeType.Decl(dd):
                    ref rhs : Expr = stmt.children[0]
                    if rhs.node_type.is(NodeType.FuncDef) {
                        if rhs.children.len() == 0 {
                            emit_funcsig_typedef(f, dd.name, rhs, lp.ctx)
                        }
                    } else {
                        switch rhs.node_type {
                        case NodeType.Ident(rhs_name):
                            if stmt.expr_til_type().is(Type.None).and(is_funcsig_type(rhs_name.ident_name(), lp.ctx)) {
                                f.write("typedef ").write(rhs_name.ident_name()).write(" ").write(dd.name).write(";\n")
                            }
                        case:
                        }
                    }
                case:
                    UNREACHABLE()
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for stmt : Expr in iu.ast.children {
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            if stmt.children.len() == 0 { continue }
            switch stmt.node_type {
            case NodeType.Decl(dd):
                ref rhs : Expr = stmt.children[0]
                if rhs.node_type.is(NodeType.FuncDef) {
                    if rhs.children.len() == 0 {
                        emit_funcsig_typedef(f, dd.name, rhs, lp.ctx)
                    }
                } else {
                    switch rhs.node_type {
                    case NodeType.Ident(rhs_name):
                        if stmt.expr_til_type().is(Type.None).and(is_funcsig_type(rhs_name.ident_name(), lp.ctx)) {
                            f.write("typedef ").write(rhs_name.ident_name()).write(" ").write(dd.name).write(";\n")
                        }
                    case:
                    }
                }
            case:
                UNREACHABLE()
            }
        }
    }
    f.write("\n")
}

priv emit_header_forward_decls_lp := proc(f: File, lp: LoadedProgram) {
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            for stmt : Expr in iu.ast.children {
                if stmt.node_type.is(NodeType.Decl).not() { continue }
                if stmt.children.len() == 0 { continue }
                switch stmt.node_type {
                case NodeType.Decl(dd):
                    switch stmt.children[0].node_type {
                    case NodeType.StructDef(fwd_sdd):
                        if is_ext_h_type(dd.name) { continue }
                        if fwd_sdd.c_tag == "@anon" {
                            // anonymous ext_struct: no forward decl possible
                        } else if fwd_sdd.c_tag.len() > 0 {
                            f.fwrite("typedef struct ", fwd_sdd.c_tag, " ", dd.name, ";\n")
                        } else {
                            f.fwrite("typedef struct ", dd.name, " ", dd.name, ";\n")
                        }
                    case NodeType.EnumDef(fwd_edd):
                        f.write("typedef enum {\n")
                        for j in 0..fwd_edd.variants.len() {
                            if j > 0 { f.write(",\n") }
                            f.fwrite("    ", dd.name, "_TAG_", fwd_edd.variants[j])
                            // Stage C (#264 follow-up): emit an explicit tag value when
                            // it differs from the auto-number (index). GCC widens the
                            // enum's underlying type for >int values (no -Wpedantic).
                            if j < fwd_edd.tag_values.len() {
                                ref tvj : I64 = fwd_edd.tag_values[j]
                                if tvj != j.to_i64() { f.write(" = ").write(tvj.to_str()) }
                            }
                        }
                        f.fwrite("\n} ", dd.name, "_tag;\n")
                        f.fwrite("typedef struct ", dd.name, " ", dd.name, ";\n")
                    case:
                    }
                case:
                    UNREACHABLE()
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for stmt : Expr in iu.ast.children {
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            if stmt.children.len() == 0 { continue }
            switch stmt.node_type {
            case NodeType.Decl(dd):
                switch stmt.children[0].node_type {
                case NodeType.StructDef(fwd_sdd):
                    if is_ext_h_type(dd.name) { continue }
                    if fwd_sdd.c_tag == "@anon" {
                        // anonymous ext_struct: no forward decl possible
                    } else if fwd_sdd.c_tag.len() > 0 {
                        f.fwrite("typedef struct ", fwd_sdd.c_tag, " ", dd.name, ";\n")
                    } else {
                        f.fwrite("typedef struct ", dd.name, " ", dd.name, ";\n")
                    }
                case NodeType.EnumDef(fwd_edd):
                    f.write("typedef enum {\n")
                    for j in 0..fwd_edd.variants.len() {
                        if j > 0 { f.write(",\n") }
                        f.fwrite("    ", dd.name, "_TAG_", fwd_edd.variants[j])
                        if j < fwd_edd.tag_values.len() {
                            ref tvj : I64 = fwd_edd.tag_values[j]
                            if tvj != j.to_i64() { f.write(" = ").write(tvj.to_str()) }
                        }
                    }
                    f.fwrite("\n} ", dd.name, "_tag;\n")
                    f.fwrite("typedef struct ", dd.name, " ", dd.name, ";\n")
                case:
                }
            case:
                UNREACHABLE()
            }
        }
    }
    f.write("\n")
}

priv builder_ns_has_func := func(def: Expr, method: Str) returns Bool {
    if def.is_null() { return false }
    ref ns : Vec(Declaration) = def_ns_decls(def)
    for nsd : Declaration in ns {
        if nsd.name.eq(method).and(nsd.default_value.is_null().not()) {
            if nsd.default_value.node_type.is(NodeType.FuncDef) { return true }
        }
    }
    return false
}

priv builder_ns_func_returns_shallow := func(def: Expr, method: Str) returns Bool {
    if def.is_null() { return false }
    ref ns : Vec(Declaration) = def_ns_decls(def)
    for nsd : Declaration in ns {
        if nsd.name.eq(method).and(nsd.default_value.is_null().not()) {
            switch nsd.default_value.node_type {
            case NodeType.FuncDef(fd): return fd.return_own_type.is(OwnType.Shallow)
            case:
            }
        }
    }
    return false
}

priv emit_enum_eq_ext_decl := proc(f: File, enum_name: Str, enum_def: Expr) {
    if builder_ns_has_func(enum_def, "eq").not() { return }
    mut eq_ret := "Bool *"
    if builder_ns_func_returns_shallow(enum_def, "eq") { eq_ret = "Bool" }
    f.fwrite(eq_ret, " ", enum_name, "_eq(", enum_name, " *, ", enum_name, " *);\n")
}

priv emit_header_defs_and_funcs_lp := proc(f: File, lp: LoadedProgram) {
    mut emitted_h := Set(Str).new()
    seed_primitive_names(emitted_h)
    topo_emit_struct_enum_defs_lp(f, emitted_h, lp)
    own emitted_h.delete()

    // Function forward declarations
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            for stmt : Expr in iu.ast.children {
                if stmt.node_type.is(NodeType.Decl).not() { continue }
                if stmt.children.len() == 0 { continue }
                switch stmt.node_type {
                case NodeType.Decl(dd):
                    ref rhs : Expr = stmt.children[0]
                    if rhs.node_type.is(NodeType.StructDef).or(rhs.node_type.is(NodeType.EnumDef)) {
                        ref fwd_ns : Vec(Declaration) = def_ns_decls(rhs)
                        for fdd : Declaration in fwd_ns {
                            if fdd.default_value.is_null() { continue }
                            switch fdd.default_value.node_type {
                            case NodeType.FuncDef(fd):
                                full_name := dd.name.concat3("_", fdd.name)
                                if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)).or(fd.func_type.is(FuncType.CoreFunc)).or(fd.func_type.is(FuncType.CoreProc)) { continue }
                                emit_func_forward_decl(f, full_name, fdd.default_value, false, lp.ctx)
                            case:
                            }
                        }
                    } else {
                        switch rhs.node_type {
                        case NodeType.FuncDef(fd):
                            if builder_is_type_gen_macro_def(rhs) { continue }
                            if rhs.children.len() == 0 { continue }
                            if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)).or(fd.func_type.is(FuncType.CoreFunc)).or(fd.func_type.is(FuncType.CoreProc)) { continue }
                            fc := func_to_c(dd.name)
                            if fc == "main" { continue }
                            emit_func_forward_decl(f, fc, rhs, true, lp.ctx)
                        case:
                        }
                    }
                case:
                    UNREACHABLE()
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for stmt : Expr in iu.ast.children {
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            if stmt.children.len() == 0 { continue }
            switch stmt.node_type {
            case NodeType.Decl(dd):
                ref rhs : Expr = stmt.children[0]
                if rhs.node_type.is(NodeType.StructDef).or(rhs.node_type.is(NodeType.EnumDef)) {
                    ref fwd_ns : Vec(Declaration) = def_ns_decls(rhs)
                    for fdd : Declaration in fwd_ns {
                        if fdd.default_value.is_null() { continue }
                        if fdd.default_value.node_type.is(NodeType.FuncDef).not() { continue }
                        full_name := dd.name.concat3("_", fdd.name)
                        emit_func_forward_decl(f, full_name, fdd.default_value, false, lp.ctx)
                    }
                } else if rhs.node_type.is(NodeType.FuncDef) {
                    if builder_is_type_gen_macro_def(rhs) { continue }
                    if rhs.children.len() == 0 { continue }
                    fc := func_to_c(dd.name)
                    if fc == "main" { continue }
                    emit_func_forward_decl(f, fc, rhs, true, lp.ctx)
                }
            case:
                UNREACHABLE()
            }
        }
    }

    // Enum auto-helper forward declarations (user units only)
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for stmt : Expr in iu.ast.children {
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            if stmt.children.len() == 0 { continue }
            if stmt.children[0].node_type.is(NodeType.EnumDef).not() { continue }
            switch stmt.node_type {
            case NodeType.Decl(dd):
                emit_enum_eq_ext_decl(f, dd.name, stmt.children[0])
                switch stmt.children[0].node_type {
                case NodeType.EnumDef(hdr_edd):
                    mut hdr_vi : USize = 0
                    for hdr_vn : Str in hdr_edd.variants {
                        hdr_vt := enum_variant_type(stmt.children[0], hdr_vi.to_i32())
                        if hdr_vt.len() > 0 {
                            tnc := type_name_to_c(hdr_vt, lp.ctx)
                            f.write(dd.name).write(" *").write(dd.name).write("_").write(hdr_vn).write("(").write(tnc).write(");\n")
                        } else {
                            f.write(dd.name).write(" *").write(dd.name).write("_").write(hdr_vn).write("();\n")
                        }
                        hdr_vi++
                    }
                case:
                    UNREACHABLE()
                }
            case:
                UNREACHABLE()
            }
        }
    }
    f.write("\n")
}

priv emit_header_global_decls_lp := proc(f: File, lp: LoadedProgram) {
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            for stmt : Expr in iu.ast.children {
                if is_exported_top_level_global(stmt).not() { continue }
                switch stmt.node_type {
                case NodeType.Decl(dd):
                    ctype := extern_decl_ctype(stmt.expr_til_type(), stmt.children[0].expr_til_type(), lp.ctx)
                    if dd.own_type.is(OwnType.Ref) {
                        f.write("extern ").write(ctype).write(" *").write(dd.name).write(";\n")
                    } else {
                        f.write("extern ").write(ctype).write(" ").write(dd.name).write(";\n")
                    }
                case:
                    UNREACHABLE()
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for stmt : Expr in iu.ast.children {
            if is_exported_top_level_global(stmt).not() { continue }
            switch stmt.node_type {
            case NodeType.Decl(dd):
                ctype := extern_decl_ctype(stmt.expr_til_type(), stmt.children[0].expr_til_type(), lp.ctx)
                if dd.own_type.is(OwnType.Ref) {
                    f.write("extern ").write(ctype).write(" *").write(dd.name).write(";\n")
                } else {
                    f.write("extern ").write(ctype).write(" ").write(dd.name).write(";\n")
                }
            case:
                UNREACHABLE()
            }
        }
    }
    f.write("\n")
}

build_forward_header_lp := proc(fwd_path: Str, lp: LoadedProgram) returns I32 {
    build_register_funcsig_names_lp(lp)
    f := File.new(fwd_path, true)
    f.write("#pragma once\n#include \"ext.h\"\n\n")
    emit_closure_runtime_types(f)
    emit_header_forward_decls_lp(f, lp)
    emit_funcsig_typedefs_lp(f, lp)
    emit_header_defs_and_funcs_lp(f, lp)
    emit_header_global_decls_lp(f, lp)
    return 0
}

priv build_header_lp := proc(h_path: Str, lp: LoadedProgram) returns I32 {
    build_register_funcsig_names_lp(lp)
    f := File.new(h_path, true)
    f.write("#pragma once\n#include \"ext.h\"\n\n")
    emit_closure_runtime_types(f)
    emit_header_forward_decls_lp(f, lp)
    emit_funcsig_typedefs_lp(f, lp)
    emit_header_defs_and_funcs_lp(f, lp)
    emit_header_global_decls_lp(f, lp)
    f.write("#include \"ext.h\"\n\n")
    return 0
}

priv emit_binding_ns_method := proc(f: File, fdd_name: Str, fd: FunctionDef, mut has_ns: Bool) returns Bool {
    if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)).or(fd.func_type.is(FuncType.CoreFunc)).or(fd.func_type.is(FuncType.CoreProc)) { return has_ns }
    if has_ns.not() { f.write("    namespace:\n"); has_ns = true }
    mut kw := "ext_func"
    if fd.func_type.is(FuncType.Proc).or(fd.func_type.is(FuncType.Test)) { kw = "ext_proc" }
    f.write("    ").write(fdd_name).write(" := ").write(kw).write("(")
    for p in 0..fd.params.len() {
        if p > 0 { f.write(", ") }
        ref param : Declaration = fd.params[p]
        if param.own_type.is(OwnType.Own) { f.write("own ") }
        f.write(param.name).write(": ").write(param.explicit_type)
    }
    f.write(")")
    if fd.return_type.len() > 0 {
        f.write(" returns ")
        if fd.return_own_type.is(OwnType.Ref) { f.write("ref ") }
        if fd.return_own_type.is(OwnType.Shallow) { f.write("shallow ") }
        f.write(fd.return_type)
    }
    f.write(" {}\n")
    return has_ns
}

priv emit_binding_ns_methods := proc(f: File, def: Expr) {
    mut has_ns := false
    ref ebn_ns : Vec(Declaration) = def_ns_decls(def)
    for nsd : Declaration in ebn_ns {
        if nsd.default_value.is_null() { continue }
        switch nsd.default_value.node_type {
        case NodeType.FuncDef(fd):
            has_ns = emit_binding_ns_method(f, nsd.name, fd, has_ns)
        case:
        }
    }
}

priv build_til_binding := proc(lp: LoadedProgram, til_path: Str, lib_name: Str) returns I32 {
    f := File.new(til_path, true)
    f.write("// Auto-generated FFI binding for ").write(lib_name).write("\n")
    f.write("link(\"").write(lib_name).write("\")\n\n")
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for stmt : Expr in iu.ast.children {
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            if stmt.children.len() == 0 { continue }
            switch stmt.node_type {
            case NodeType.Decl(dd):
            ref rhs : Expr = stmt.children[0]
            switch rhs.node_type {
            case NodeType.StructDef(btb_sdd):
                f.write(dd.name).write(" := struct {\n")
                for fdd : Declaration in btb_sdd.fields {
                    f.write("    ")
                    if fdd.own_type.is(OwnType.Own) { f.write("own ") }
                    // #211: fields are mutable by default; emit `const` only
                    // for immutable fields (never the redundant `mut`).
                    if fdd.is_mut.not() { f.write("const ") }
                    f.write(fdd.name)
                    if fdd.explicit_type.len() > 0 { f.write(" : ").write(fdd.explicit_type) }
                    f.write(" := ")
                    if fdd.default_value.is_null().not() { emit_til_default(f, fdd.til_type) }
                    else { f.write("0") }
                    f.write("\n")
                }
                emit_binding_ns_methods(f, rhs)
                f.write("}\n\n")
            case NodeType.EnumDef(bind_edd):
                f.write(dd.name).write(" := enum {\n")
                mut bind_vi : USize = 0
                for bind_vn : Str in bind_edd.variants {
                    bind_vt := enum_variant_type(rhs, bind_vi.to_i32())
                    f.write("    ").write(bind_vn)
                    if bind_vt.len() > 0 { f.write(": ").write(bind_vt) }
                    f.write(",\n")
                    bind_vi++
                }
                emit_binding_ns_methods(f, rhs)
                f.write("}\n\n")
            case NodeType.FuncDef(fd):
                if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)).or(fd.func_type.is(FuncType.CoreFunc)).or(fd.func_type.is(FuncType.CoreProc)) { continue }
                if fd.func_type.is(FuncType.Test) { continue }
                mut kw := "ext_func"
                if fd.func_type.is(FuncType.Proc) { kw = "ext_proc" }
                f.write(dd.name).write(" := ").write(kw).write("(")
                for p in 0..fd.params.len() {
                    if p > 0 { f.write(", ") }
                    ref param : Declaration = fd.params[p]
                    if param.own_type.is(OwnType.Own) { f.write("own ") }
                    pi := p.to_i32()
                    if pi == fd.variadic_index { f.write("..") }
                    if pi == fd.kwargs_index {
                        f.write(param.name).write(": ...")
                    } else {
                        f.write(param.name).write(": ").write(param.explicit_type)
                    }
                }
                f.write(")")
                if fd.return_type.len() > 0 {
                    f.write(" returns ")
                    if fd.return_own_type.is(OwnType.Ref) { f.write("ref ") }
                    if fd.return_own_type.is(OwnType.Shallow) { f.write("shallow ") }
                    f.write(fd.return_type)
                }
                f.write(" {}\n\n")
            case:
            }
            case:
                UNREACHABLE()
            }
        }
    }
    return 0
}

priv type_name_to_ctypes := func(name: Str) returns Str {
    if name == "I64" { return "ctypes.c_longlong" }
    if name == "U8" { return "ctypes.c_ubyte" }
    if name == "I8" { return "ctypes.c_byte" }
    if name == "I16" { return "ctypes.c_short" }
    if name == "U16" { return "ctypes.c_ushort" }
    if name == "I32" { return "ctypes.c_int" }
    if name == "U32" { return "ctypes.c_uint" }
    if name == "U64" { return "ctypes.c_ulonglong" }
    if name == "F32" { return "ctypes.c_float" }
    if name == "Bool" { return "ctypes.c_bool" }
    if name == "Str" { return "Str" }
    if name == "Dynamic" { return "ctypes.c_void_p" }
    return name
}

priv type_name_to_ctypes_param := func(name: Str, is_shallow: Bool) returns Str {
    base := type_name_to_ctypes(name)
    if is_shallow { return base }
    return format("ctypes.POINTER(", base, ")")
}

priv type_name_to_ctypes_return := func(name: Str, is_shallow: Bool) returns Str {
    base := type_name_to_ctypes(name)
    if is_shallow { return base }
    return format("ctypes.POINTER(", base, ")")
}

priv build_python_binding := proc(lp: LoadedProgram, py_path: Str, lib_name: Str) returns I32 {
    f := File.new(py_path, true)
    f.write("# Auto-generated Python binding for ").write(lib_name).write("\n")
    f.write("import ctypes\n")
    f.write("import os\n\n")
    f.write("_dir = os.path.dirname(os.path.abspath(__file__))\n")
    f.write("_candidates = [\n")
    f.write("    os.path.abspath(os.path.join(_dir, '..', 'lib', 'lib")
    f.write(lib_name).write(".so')),\n")
    f.write("    os.path.abspath(os.path.join(_dir, '..', '..', '..', 'lib")
    f.write(lib_name).write(".so')),\n")
    f.write("]\n")
    f.write("_lib = None\n")
    f.write("for _path in _candidates:\n")
    f.write("    if os.path.exists(_path):\n")
    f.write("        _lib = ctypes.CDLL(_path)\n")
    f.write("        break\n")
    f.write("if _lib is None:\n")
    f.write("    raise OSError('could not find lib")
    f.write(lib_name).write(".so')\n\n")

    f.write("\nclass Str(ctypes.Structure):\n")
    f.write("    _fields_ = [\n")
    f.write("        ('c_str', ctypes.POINTER(ctypes.c_ubyte)),\n")
    f.write("        ('count', ctypes.c_uint),\n")
    f.write("        ('cap', ctypes.c_uint),\n")
    f.write("    ]\n\n")
    f.write("\nclass Array(ctypes.Structure):\n")
    f.write("    _fields_ = [\n")
    f.write("        ('data', ctypes.POINTER(ctypes.c_ubyte)),\n")
    f.write("        ('cap', ctypes.c_uint),\n")
    f.write("        ('elem_size', ctypes.c_uint),\n")
    f.write("        ('elem_clone', ctypes.c_void_p),\n")
    f.write("        ('elem_delete', ctypes.c_void_p),\n")
    f.write("    ]\n\n")

    // Forward-declare all struct/enum classes
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for stmt : Expr in iu.ast.children {
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            if stmt.children.len() == 0 { continue }
            switch stmt.node_type {
            case NodeType.Decl(dd):
                ref rhs : Expr = stmt.children[0]
                if rhs.node_type.is(NodeType.StructDef).or(rhs.node_type.is(NodeType.EnumDef)) {
                    f.write("\nclass ").write(dd.name).write("(ctypes.Structure):\n")
                    f.write("    pass\n")
                }
            case:
                UNREACHABLE()
            }
        }
    }
    f.write("\n")

    // Emit struct field definitions and enum definitions
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for stmt : Expr in iu.ast.children {
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            if stmt.children.len() == 0 { continue }
            switch stmt.node_type {
            case NodeType.Decl(dd):
            ref rhs : Expr = stmt.children[0]

            switch rhs.node_type {
            case NodeType.StructDef(bpb_sdd):
                f.write("\n").write(dd.name).write("._fields_ = [\n")
                for fdd : Declaration in bpb_sdd.fields {
                    mut ct := ""
                    if fdd.explicit_type.len() > 0 {
                        ct = type_name_to_ctypes_param(fdd.explicit_type, false)
                    } else {
                        switch fdd.til_type {
                        case Type.Primitive(Primitive.I64):  ct = "ctypes.POINTER(ctypes.c_longlong)"
                        case Type.Primitive(Primitive.U8):   ct = "ctypes.POINTER(ctypes.c_ubyte)"
                        case Type.Primitive(Primitive.I8):   ct = "ctypes.POINTER(ctypes.c_byte)"
                        case Type.Primitive(Primitive.I16):  ct = "ctypes.POINTER(ctypes.c_short)"
                        case Type.Primitive(Primitive.U16):  ct = "ctypes.POINTER(ctypes.c_ushort)"
                        case Type.Primitive(Primitive.I32):  ct = "ctypes.POINTER(ctypes.c_int)"
                        case Type.Primitive(Primitive.U32):  ct = "ctypes.POINTER(ctypes.c_uint)"
                        case Type.Primitive(Primitive.U64):  ct = "ctypes.POINTER(ctypes.c_ulonglong)"
                        case Type.Primitive(Primitive.F32):  ct = "ctypes.POINTER(ctypes.c_float)"
                        case Type.Primitive(Primitive.Bool): ct = "ctypes.POINTER(ctypes.c_bool)"
                        case:              ct = "ctypes.c_void_p"
                        }
                    }
                    f.write("    ('").write(fdd.name).write("', ")
                    f.write(ct).write("),\n")
                }
                f.write("]\n")

            case NodeType.EnumDef(ct_edd):
                hp := enum_has_payloads(rhs)

                // Emit tag constants
                mut tag := 0
                for ct_vn : Str in ct_edd.variants {
                    f.write(dd.name).write("_TAG_").write(ct_vn)
                    f.write(" = ").write(tag.to_str()).write("\n")
                    tag++
                }

                // Emit union if has payloads
                if hp {
                    f.write("\nclass ").write(dd.name).write("_data(ctypes.Union):\n")
                    f.write("    _fields_ = [\n")
                    mut ct_vi : USize = 0
                    for ct_uvn : Str in ct_edd.variants {
                        ct_vt := enum_variant_type(rhs, ct_vi.to_i32())
                        if ct_vt.len() > 0 {
                            f.write("        ('").write(ct_uvn).write("', ")
                            f.write(type_name_to_ctypes_param(ct_vt, false))
                            f.write("),\n")
                        }
                        ct_vi++
                    }
                    f.write("    ]\n")
                }

                // Emit enum struct _fields_
                f.write("\n").write(dd.name).write("._fields_ = [\n")
                f.write("    ('tag', ctypes.c_int),\n")
                if hp {
                    f.write("    ('data', ").write(dd.name).write("_data),\n")
                }
                f.write("]\n")
            case:
            }
            case:
                UNREACHABLE()
            }
        }
    }
    f.write("\n")

    // Emit function bindings
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for stmt : Expr in iu.ast.children {
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            if stmt.children.len() == 0 { continue }
            switch stmt.node_type {
            case NodeType.Decl(dd):
            ref rhs : Expr = stmt.children[0]

            if rhs.node_type.is(NodeType.StructDef).or(rhs.node_type.is(NodeType.EnumDef)) {
                // Emit namespace method bindings from ns_decls
                ref pyb_ns : Vec(Declaration) = def_ns_decls(rhs)
                for nsd : Declaration in pyb_ns {
                    if nsd.default_value.is_null() { continue }
                    switch nsd.default_value.node_type {
                    case NodeType.FuncDef(fd):
                    if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)).or(fd.func_type.is(FuncType.CoreFunc)).or(fd.func_type.is(FuncType.CoreProc)) { continue }
                    f.write("_lib.").write(dd.name).write("_").write(nsd.name)
                    f.write(".argtypes = [")
                    for p in 0..fd.params.len() {
                        if p > 0 { f.write(", ") }
                        ref param : Declaration = fd.params[p]
                        ps := param.own_type.is(OwnType.Shallow)
                        f.write(type_name_to_ctypes_param(param.explicit_type, ps))
                    }
                    f.write("]\n")
                    if fd.return_type.len() > 0 {
                        rs := fd.return_own_type.is(OwnType.Shallow)
                        f.write("_lib.").write(dd.name).write("_").write(nsd.name)
                        f.write(".restype = ")
                        f.write(type_name_to_ctypes_return(fd.return_type, rs)).write("\n")
                    } else {
                        f.write("_lib.").write(dd.name).write("_").write(nsd.name)
                        f.write(".restype = None\n")
                    }
                    f.write("\n")
                    case:
                    }
                }

            } else {
                switch rhs.node_type {
                case NodeType.FuncDef(fd):
                    if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)).or(fd.func_type.is(FuncType.CoreFunc)).or(fd.func_type.is(FuncType.CoreProc)) { continue }
                    if fd.func_type.is(FuncType.Test) { continue }

                    c_name := func_to_c(dd.name)

                    // argtypes
                    f.write("_lib.").write(c_name).write(".argtypes = [")
                    for p in 0..fd.params.len() {
                        if p > 0 { f.write(", ") }
                        ref param : Declaration = fd.params[p]
                        pi := p.to_i32()
                        if pi == fd.variadic_index {
                            f.write("ctypes.POINTER(Array)")
                        } else {
                            ps := param.own_type.is(OwnType.Shallow)
                            f.write(type_name_to_ctypes_param(param.explicit_type, ps))
                        }
                    }
                    f.write("]\n")

                    // restype
                    if fd.return_type.len() > 0 {
                        rs := fd.return_own_type.is(OwnType.Shallow)
                        f.write("_lib.").write(c_name).write(".restype = ")
                        f.write(type_name_to_ctypes_return(fd.return_type, rs)).write("\n")
                    } else {
                        f.write("_lib.").write(c_name).write(".restype = None\n")
                    }
                    f.write("\n")
                case:
                }
            }
            case:
                UNREACHABLE()
            }
        }
    }

    // Emit enum auto-helper bindings (eq, constructors, is_Variant, get_Variant)
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for stmt : Expr in iu.ast.children {
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            if stmt.children.len() == 0 { continue }
            switch stmt.node_type {
            case NodeType.Decl(dd):
                ref rhs : Expr = stmt.children[0]
                if rhs.node_type.is(NodeType.EnumDef).not() { continue }
                sname := dd.name
                hp := enum_has_payloads(rhs)

                has_eq := builder_ns_has_func(rhs, "eq")
                mut eq_ret := "ctypes.POINTER(ctypes.c_bool)"
                if builder_ns_func_returns_shallow(rhs, "eq") { eq_ret = "ctypes.c_bool" }
                mut is_ret := "ctypes.POINTER(ctypes.c_bool)"
                if builder_ns_func_returns_shallow(rhs, "is") { is_ret = "ctypes.c_bool" }

                // eq
                if has_eq {
                    f.write("_lib.").write(sname).write("_eq.argtypes = [ctypes.POINTER(")
                    f.write(sname).write("), ctypes.POINTER(").write(sname).write(")]\n")
                    f.write("_lib.").write(sname).write("_eq.restype = ")
                    f.write(eq_ret).write("\n\n")
                }

                // Per-variant helpers
                switch rhs.node_type {
                case NodeType.EnumDef(py_edd):
                    mut py_vi : USize = 0
                    for py_vn : Str in py_edd.variants {
                        py_vt := enum_variant_type(rhs, py_vi.to_i32())

                        if hp {
                            // is_Variant
                            f.write("_lib.").write(sname).write("_is_").write(py_vn)
                            f.write(".argtypes = [ctypes.POINTER(").write(sname).write(")]\n")
                            f.write("_lib.").write(sname).write("_is_").write(py_vn)
                            f.write(".restype = ").write(is_ret).write("\n\n")
                        }

                        if py_vt.len() > 0 {
                            // Constructor: takes payload, returns POINTER(Enum)
                            f.write("_lib.").write(sname).write("_").write(py_vn)
                            f.write(".argtypes = [")
                            f.write(type_name_to_ctypes_param(py_vt, false)).write("]\n")
                            f.write("_lib.").write(sname).write("_").write(py_vn)
                            f.write(".restype = ctypes.POINTER(").write(sname).write(")\n\n")
                            // get_Variant
                            f.write("_lib.").write(sname).write("_get_").write(py_vn)
                            f.write(".argtypes = [ctypes.POINTER(").write(sname).write(")]\n")
                            f.write("_lib.").write(sname).write("_get_").write(py_vn)
                            f.write(".restype = ")
                            f.write(type_name_to_ctypes_param(py_vt, false)).write("\n\n")
                        } else {
                            // Constructor: no args, returns POINTER(Enum)
                            f.write("_lib.").write(sname).write("_").write(py_vn)
                            f.write(".argtypes = []\n")
                            f.write("_lib.").write(sname).write("_").write(py_vn)
                            f.write(".restype = ctypes.POINTER(").write(sname).write(")\n\n")
                        }
                        py_vi++
                    }
                case:
                    UNREACHABLE()
                }
            case:
                UNREACHABLE()
            }
        }
    }
    return 0
}

priv compile_lib := proc(c_path: Str, lib_name: Str, ext_c_path: Str, user_c_path: Str, link_flags: Str, include_flags: Str, target: Target, cc_override: Str, asan: Bool) returns I32 {
    mut uc := user_c_path
    mut lf := link_flags
    mut ifl := include_flags
    if uc.len() == 0 { uc = "" }
    if lf.len() == 0 { lf = "" }
    if ifl.len() == 0 { ifl = "" }

    mut compiler := cc_override
    if compiler.len() == 0 { compiler = toolchain_command(target, Lang.C) }
    extra := toolchain_extra_args(target, compiler)

    // ASAN builds run under the same full -Werror as non-ASAN. Historically
    // -fsanitize=address inserted __asan_* hooks that mutated the CFG enough
    // that GCC could no longer prove an exhaustive switch/if never falls off
    // the end of a non-void function, mis-firing -Werror=return-type (issue
    // #240 demoted just that check with -Wno-error=return-type). The emitter
    // now closes every diverging non-void body with __builtin_unreachable()
    // (see body_diverges / emit_diverge_terminator), so GCC no longer needs
    // to prove it and the false positive is gone -- return-type is a real
    // error again under ASAN too, still catching a genuinely missing return.
    werr := " -Werror"
    mut asan_flags := ""
    if asan {
        asan_flags = " -fsanitize=address -fno-omit-frame-pointer"
    }

    // Extract directory from ext_c_path for -I flag
    mut ext_dir := "."
    slash := ext_c_path.rfind("/")
    if slash >= 0 { ext_dir = ext_c_path.substr(0, slash.to_usize()).clone() }

    // Compile library .c to object
    obj_path := format("gen/lib/", lib_name, ".o")
    mut cmd := compiler.format(extra, werr, asan_flags, " -fPIC -I", ext_dir,
        " -c ", c_path, " -o ", obj_path)
    mut result := system_cmd(cmd)
    if result != 0 {
        println("error: library compilation failed")
        return 1
    }

    // Compile ext.c to object
    ext_obj := "gen/lib/ext.o"
    cmd = compiler.format(extra, werr, asan_flags, " -fPIC -I", ext_dir,
        " -c ", ext_c_path, " -o ", ext_obj)
    result = system_cmd(cmd)
    if result != 0 {
        println("error: ext.c compilation failed")
        return 1
    }

    // Compile user .c to object if present
    mut user_obj := ""
    if uc.len() > 0 {
        user_obj = "gen/lib/user.o"
        cmd = compiler.format(extra, werr, asan_flags, " -fPIC -I", ext_dir, ifl,
            " -c ", uc, " -o ", user_obj)
        result = system_cmd(cmd)
        if result != 0 {
            println("error: user .c compilation failed")
            return 1
        }
    }

    // Create shared library
    so_path := format("gen/lib/lib", lib_name, ".so")
    cmd = compiler.format(asan_flags, " -shared -o ", so_path,
        " ", obj_path, " ", ext_obj,
        " ", user_obj, lf)
    result = system_cmd(cmd)
    if result != 0 {
        println("error: shared library creation failed")
        return 1
    }

    // Create static library
    a_path := format("gen/lib/lib", lib_name, ".a")
    cmd = format("ar rcs ", a_path,
        " ", obj_path, " ", ext_obj,
        " ", user_obj)
    result = system_cmd(cmd)
    if result != 0 {
        println("error: static library creation failed")
        return 1
    }

    return 0
}

priv is_gui_auto_import := func(auto_import: Str) returns Bool {
    return auto_import.eq("gui").or(auto_import.eq("src/modes/gui")).or(auto_import.ends_with("/gui"))
}

priv compile_c := proc(c_path: Str, bin_path: Str, ext_c_path: Str, user_c_path: Str, link_flags: Str, include_flags: Str, target: Target, cc_override: Str, mode_auto_import: Str, asan: Bool, prof: Bool) returns I32 {
    mut uc := user_c_path
    mut lf := link_flags
    mut ifl := include_flags
    if uc.len() == 0 { uc = "" }
    if lf.len() == 0 { lf = "" }
    if ifl.len() == 0 { ifl = "" }

    wasm_gui := target.is(Target.Wasm32).and(is_gui_auto_import(mode_auto_import))
    mut compiler := cc_override
    if compiler.len() == 0 {
        if wasm_gui { compiler = "emcc" }
        else { compiler = toolchain_command(target, Lang.C) }
    }
    mut extra := toolchain_extra_args(target, compiler)
    if wasm_gui {
        extra = " -Wall -Wextra -Wno-sometimes-uninitialized -Wno-self-assign -Wno-uninitialized -Wno-unused-function -sUSE_GLFW=3 -sASYNCIFY -sALLOW_MEMORY_GROWTH=1"
    }

    // ASAN builds run under the same full -Werror as non-ASAN (single cc
    // invocation, so the flags cover compile and link in one go).
    // -fsanitize=address used to mutate the CFG enough that GCC mis-fired
    // -Werror=return-type on exhaustive non-void functions (issue #240
    // demoted it with -Wno-error=return-type). The emitter now terminates
    // every diverging non-void body with __builtin_unreachable() (see
    // body_diverges / emit_diverge_terminator), so the false positive is
    // gone and return-type stays a hard error under ASAN too.
    werr := " -Werror"
    mut asan_flags := ""
    if asan {
        asan_flags = " -fsanitize=address -fno-omit-frame-pointer"
    }

    // --prof: -finstrument-functions makes gcc emit __cyg_profile_func_enter/
    // exit hooks at every function boundary; the runtime that accumulates and
    // reports per-function counts/time lives in src/c/ext.c. Linux/-rdynamic
    // only (the ext.c runtime is #ifndef _WIN32), so skip it for Windows.
    // The exit hook is appended on the return path, so for til functions that
    // end in a noreturn call (panic/exit) gcc then mis-fires
    // -Werror=return-type ("control reaches end of non-void function"). The
    // non-prof build validates return-type strictly, so relax just that check
    // for instrumented builds.
    //
    // For the allocation profile, -DTIL_PROF_ALLOC turns on the wrap hooks in
    // ext.c and -Wl,--wrap=malloc/calloc/realloc (link-only) routes heap
    // allocation through them. asan owns malloc, so the wrap is skipped when
    // both are set; CPU profiling still works.
    mut prof_flags := ""
    mut prof_link_flags := ""
    if prof.and(target.is(Target.WindowsX64).not()) {
        prof_flags = " -finstrument-functions -Wno-error=return-type"
        if asan.not() {
            prof_flags = format(prof_flags, " -DTIL_PROF_ALLOC")
            prof_link_flags = " -Wl,--wrap=malloc -Wl,--wrap=calloc -Wl,--wrap=realloc"
        }
    }

    // Extract directory from ext_c_path for -I flag
    mut ext_dir := "."
    slash := ext_c_path.rfind("/")
    if slash >= 0 { ext_dir = ext_c_path.substr(0, slash.to_usize()).clone() }

    // If link_c files present, compile each to .o separately with -include forward.h
    mut user_part := ""
    if uc.len() > 0 {
        c_slash := c_path.rfind("/")
        mut c_dir := "."
        if c_slash >= 0 { c_dir = c_path.substr(0, c_slash.to_usize()).clone() }
        c_dot := c_path.rfind(".")
        mut c_base := c_path
        if c_dot > c_slash { c_base = c_path.substr(0, c_dot.to_usize()) }
        fwd_path := c_base.format("_forward.h")

        // Split space-separated link_c files and compile each individually
        files : Vec(Str) = uc.split(" ")
        mut all_objs := ""
        for fi in 0..files.len() {
            ref file : Str = files[fi]
            if file.len() == 0 { continue }
            user_obj := c_dir.format("/user_", fi.to_str(), ".o")

            // Skip -include forward.h for src/c/ files
            mut fwd_flag := format(" -include ", fwd_path)
            if file.starts_with("src/c/") { fwd_flag = " -Isrc/c -Iboot" }
            obj_cmd := compiler.format(extra, werr, asan_flags, prof_flags, " -I", ext_dir,
                fwd_flag, ifl, " -c ", file,
                " -o ", user_obj)

            obj_result := system_cmd(obj_cmd)
            if obj_result != 0 {
                println(format("error: link_c compilation failed for ", file))
                return 1
            }
            all_objs = all_objs.format(" ", user_obj)
        }
        user_part = all_objs
    }

    // -rdynamic is a Linux/ELF gcc driver flag for exporting symbols to dlsym.
    // mingw silently ignores it but clangs error out, so only add for non-Windows.
    mut dyn_flag := " -rdynamic"
    if target.is(Target.WindowsX64).or(target.is(Target.Wasm32)) { dyn_flag = "" }

    // For Windows cross-compile, rewrite link_flags inherited from
    // vendor/bindings/{raylib,libffi,tinyfd}.til. Their link() directives carry
    // hardcoded Linux paths and POSIX-only -l flags; mingw doesn't ship
    // -ldl/-lrt and can't load Linux ELF .a files. The Windows variants
    // are added via target_gui_libs / target_ffi_lib / target_system_libs
    // below, so it's safe to strip the Linux ones here.
    if target.is(Target.WindowsX64).or(target.is(Target.Wasm32)) {
        lf = lf.replace(" -ldl", "")
        lf = lf.replace("-ldl", "")
        lf = lf.replace(" -lrt", "")
        lf = lf.replace("-lrt", "")
        lf = lf.replace(" -lpthread", "")
        lf = lf.replace("-lpthread", "")
        lf = lf.replace(" -lm", "")
        lf = lf.replace("-lm", "")
        lf = lf.replace(" vendor/raylib/src/libraylib.a", "")
        lf = lf.replace("vendor/raylib/src/libraylib.a", "")
        lf = lf.replace(" vendor/tinyfiledialogs/libtinyfd.a", "")
        lf = lf.replace("vendor/tinyfiledialogs/libtinyfd.a", "")
        lf = lf.replace(" vendor/libffi/x86_64-pc-linux-gnu/.libs/libffi.a", "")
        lf = lf.replace("vendor/libffi/x86_64-pc-linux-gnu/.libs/libffi.a", "")
    }
    if wasm_gui { lf = "" }

    // Per-target system + ffi + (gui) link flags. Tables in
    // src/self/targets.til. mode_auto_import points at gui iff the program
    // declared mode gui.
    sys_libs := target_system_libs(target)
    ffi_lib  := target_ffi_lib(target)
    mut gui_part := ""
    if is_gui_auto_import(mode_auto_import) { gui_part = format(" ", target_gui_libs(target)) }

    cmd := compiler.format(extra, werr, asan_flags, prof_flags, prof_link_flags, " -g", dyn_flag, " -I", ext_dir,
        " -o ", bin_path, " ", c_path,
        " ", ext_c_path, user_part, lf,
        " ", ffi_lib, gui_part, " ", sys_libs)

    result := system_cmd(cmd)
    if result != 0 {
        println("error: C compilation failed")
        return 1
    }
    return 0
}

priv register_funcsig_prog := func(prog: Expr, ctx: Context) {
    for stmt : Expr in prog.children {
        if stmt.node_type.is(NodeType.Decl) {
            switch stmt.node_type {
            case NodeType.Decl(dd):
                ref rhs : Expr = stmt.children[0]
                if rhs.node_type.is(NodeType.FuncDef) {
                    if rhs.children.len() == 0 {
                        ctx.funcsig_names.add(own dd.name.clone())
                    }
                }
                if stmt.expr_til_type().is(Type.None) {
                    switch rhs.node_type {
                    case NodeType.Ident(rhs_name):
                        if ctx.funcsig_names.has(rhs_name.ident_name()) {
                            ctx.funcsig_names.add(own dd.name.clone())
                        }
                    case:
                    }
                }
            case:
                UNREACHABLE()
            }
        }
    }
}

priv emit_global_inits_prog := proc(f: File, prog: Expr, ctx: Context) {
    for gs : Expr in prog.children {
        if gs.node_type.is(NodeType.Decl) {
            ref rhs : Expr = gs.children[0]
            if rhs.node_type.is(NodeType.FuncDef).or(rhs.node_type.is(NodeType.StructDef))
            .or(rhs.node_type.is(NodeType.EnumDef)) { continue }
            if gs.expr_til_type().is(Type.None) {
                if rhs.node_type.is(NodeType.Ident) { continue }
            }
        } else {
            if gs.node_type.is(NodeType.FCall).not() { continue }
        }
        emit_stmt(f, gs, 1, ctx)
    }
}

priv emit_global_inits := proc(f: File, lp: LoadedProgram) {
    if lp.ctx.script_globals.len() == 0 { return }
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            emit_global_inits_prog(f, iu.ast, lp.ctx)
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        emit_global_inits_prog(f, iu.ast, lp.ctx)
    }
}

priv build_register_funcsig_names_lp := func(lp: LoadedProgram) {
        lp.ctx.funcsig_names = Set(Str).new()
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            register_funcsig_prog(iu.ast, lp.ctx)
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        register_funcsig_prog(iu.ast, lp.ctx)
    }
}

priv register_lookups_prog := func(prog: Expr, ctx: Context) {
    for stmt : Expr in prog.children {
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        switch stmt.node_type {
        case NodeType.Decl(dd):
            ref rhs : Expr = stmt.children[0]
            if rhs.node_type.is(NodeType.StructDef).or(rhs.node_type.is(NodeType.EnumDef)) {
                sdv : Dynamic = malloc(I64.size().cast(U64))
                write_ptr(sdv, rhs)
                ctx.struct_def_exprs.set(dd.name, own sdv)
                // Register ns_decls methods into func_defs
                ref rl_ns : Vec(Declaration) = def_ns_decls(rhs)
                for d_j : Declaration in rl_ns {
                    ref nsd : Declaration = d_j
                    if nsd.default_value.is_null() { continue }
                    if nsd.default_value.node_type.is(NodeType.FuncDef).not() { continue }
                    key := dd.name.concat3("_", nsd.name)
                    if ctx.func_defs.has(key) { continue }
                    fv : Dynamic = malloc(I64.size().cast(U64))
                    write_ptr(fv, nsd.default_value)
                    ctx.func_defs.set(key, own fv)
                    if nsd.default_value.children.len() > 0 {
                        ref fbody : Expr = nsd.default_value.children[0]
                        for nested : Expr in fbody.children {
                            if is_func_decl(nested).not() { continue }
                            switch nested.node_type {
                            case NodeType.Decl(nd):
                                nv : Dynamic = malloc(I64.size().cast(U64))
                                write_ptr(nv, nested.children[0])
                                ctx.func_defs.set(nd.name, own nv)
                            case:
                                UNREACHABLE()
                            }
                        }
                    }
                }
            }
            if rhs.node_type.is(NodeType.FuncDef) {
                fv2 : Dynamic = malloc(I64.size().cast(U64))
                write_ptr(fv2, rhs)
                ctx.func_defs.set(dd.name, own fv2)
            }
        case:
            UNREACHABLE()
        }
    }
}

collect_closure_value_names := proc(e: Expr, mut names: Set(Str), ctx: Context) {
    expect(e.is_null().not(), "e is null")
    switch e.node_type {
    case NodeType.Ident(ident):
        if e.expr_til_type().is_funcptr() {
            ref fdef : Expr = find_callee_fdef(ident.ident_name(), ctx)
            if fdef.is_null().not() { names.add(own Str.clone(ident.ident_name())) }
        }
    case NodeType.FuncDef(fd):
        for p : Declaration in fd.params {
            collect_closure_value_names(p.default_value, names, ctx)
        }
    case NodeType.StructDef(sdd):
        for sf : Declaration in sdd.fields {
            collect_closure_value_names(sf.default_value, names, ctx)
        }
        for nd : Declaration in sdd.ns_decls {
            collect_closure_value_names(nd.default_value, names, ctx)
        }
    case NodeType.EnumDef(edd):
        for nd : Declaration in edd.ns_decls {
            collect_closure_value_names(nd.default_value, names, ctx)
        }
    case:
    }
    for c : Expr in e.children {
        collect_closure_value_names(c, names, ctx)
    }
}

build_register_closure_values_lp := proc(lp: LoadedProgram) {
    lp.ctx.closure_value_names = Set(Str).new()
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            collect_closure_value_names(iu.ast, lp.ctx.closure_value_names, lp.ctx)
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        collect_closure_value_names(iu.ast, lp.ctx.closure_value_names, lp.ctx)
    }
}

priv build_register_lookups_lp := func(lp: LoadedProgram) {
    lp.ctx.struct_def_exprs = Map(Str, Dynamic).new()
    lp.ctx.func_defs = Map(Str, Dynamic).new()
    builder_reset_func_scratch(lp.ctx)

    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            register_lookups_prog(iu.ast, lp.ctx)
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        register_lookups_prog(iu.ast, lp.ctx)
    }
}


priv emit_monolithic_header_lp := proc(f: File, mode: Mode, lp: LoadedProgram) {
    f.write("#include \"ext.h\"\n\n")
    emit_closure_runtime_types(f)
    emit_header_forward_decls_lp(f, lp)
    emit_funcsig_typedefs_lp(f, lp)

    // Topo-sort struct/enum defs across all units
    mut emitted_mh := Set(Str).new()
    seed_primitive_names(emitted_mh)
    topo_emit_struct_enum_defs_lp(f, emitted_mh, lp)
    own emitted_mh.delete()

    // Emit function declarations
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            for stmt : Expr in iu.ast.children {
                if stmt.node_type.is(NodeType.Decl).not() { continue }
                if stmt.children.len() == 0 { continue }
                switch stmt.node_type {
                case NodeType.Decl(dd):
                    ref rhs : Expr = stmt.children[0]
                    if rhs.node_type.is(NodeType.StructDef).or(rhs.node_type.is(NodeType.EnumDef)) {
                        ref fwd_ns2 : Vec(Declaration) = def_ns_decls(rhs)
                        for fdd : Declaration in fwd_ns2 {
                            if fdd.default_value.is_null() { continue }
                            switch fdd.default_value.node_type {
                            case NodeType.FuncDef(fd):
                                if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)).or(fd.func_type.is(FuncType.CoreFunc)).or(fd.func_type.is(FuncType.CoreProc)) { continue }
                                full_name := dd.name.concat3("_", fdd.name)
                                emit_func_forward_decl(f, full_name, fdd.default_value, false, lp.ctx)
                            case:
                            }
                        }
                    } else {
                        switch rhs.node_type {
                        case NodeType.FuncDef(fd):
                            if builder_is_type_gen_macro_def(rhs) { continue }
                            if rhs.children.len() == 0 { continue }
                            if mode.is_null().not() {
                                if mode.needs_main {
                                    if dd.name == "main" { continue }
                                }
                            }
                            fc := func_to_c(dd.name)
                            if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)).or(fd.func_type.is(FuncType.CoreFunc)).or(fd.func_type.is(FuncType.CoreProc)) {
                                continue
                            }
                            emit_func_forward_decl(f, fc, rhs, true, lp.ctx)
                            if lp.ctx.closure_value_names.has(dd.name) { emit_closure_forward_decl(f, fc, rhs, lp.ctx) }
                        case:
                        }
                    }
                case:
                    UNREACHABLE()
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for stmt : Expr in iu.ast.children {
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            if stmt.children.len() == 0 { continue }
            switch stmt.node_type {
            case NodeType.Decl(dd):
                ref rhs : Expr = stmt.children[0]
                if rhs.node_type.is(NodeType.StructDef).or(rhs.node_type.is(NodeType.EnumDef)) {
                    ref fwd_ns2 : Vec(Declaration) = def_ns_decls(rhs)
                    for fdd : Declaration in fwd_ns2 {
                        if fdd.default_value.is_null() { continue }
                        switch fdd.default_value.node_type {
                        case NodeType.FuncDef(fd):
                            if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)).or(fd.func_type.is(FuncType.CoreFunc)).or(fd.func_type.is(FuncType.CoreProc)) { continue }
                            full_name := dd.name.concat3("_", fdd.name)
                            emit_func_forward_decl(f, full_name, fdd.default_value, false, lp.ctx)
                        case:
                        }
                    }
                } else {
                    switch rhs.node_type {
                    case NodeType.FuncDef(fd):
                        if builder_is_type_gen_macro_def(rhs) { continue }
                        if rhs.children.len() == 0 { continue }
                        if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)).or(fd.func_type.is(FuncType.CoreFunc)).or(fd.func_type.is(FuncType.CoreProc)) { continue }
                        if mode.is_null().not() {
                            if mode.needs_main {
                                if dd.name == "main" { continue }
                            }
                        }
                        fc := func_to_c(dd.name)
                        emit_func_forward_decl(f, fc, rhs, true, lp.ctx)
                        if lp.ctx.closure_value_names.has(dd.name) { emit_closure_forward_decl(f, fc, rhs, lp.ctx) }
                    case:
                    }
                }
            case:
                UNREACHABLE()
            }
        }
    }

    // Enum auto-helper declarations (user units only)
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for stmt : Expr in iu.ast.children {
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            if stmt.children.len() == 0 { continue }
            if stmt.children[0].node_type.is(NodeType.EnumDef).not() { continue }
            switch stmt.node_type {
            case NodeType.Decl(dd):
                emit_enum_eq_ext_decl(f, dd.name, stmt.children[0])
                switch stmt.children[0].node_type {
                case NodeType.EnumDef(hdr_edd):
                    mut hdr_vi : USize = 0
                    for hdr_vn : Str in hdr_edd.variants {
                        hdr_vt := enum_variant_type(stmt.children[0], hdr_vi.to_i32())
                        if hdr_vt.len() > 0 {
                            tnc := type_name_to_c(hdr_vt, lp.ctx)
                            f.write(dd.name).write(" *").write(dd.name).write("_").write(hdr_vn).write("(").write(tnc).write(");\n")
                        } else {
                            f.write(dd.name).write(" *").write(dd.name).write("_").write(hdr_vn).write("();\n")
                        }
                        hdr_vi++
                    }
                case:
                    UNREACHABLE()
                }
            case:
                UNREACHABLE()
            }
        }
    }
}

priv emit_all_forward_declarations := proc(f: File, mode: Mode, lp: LoadedProgram) {
    // Forward-declare struct/enum namespace methods and top-level functions
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            for stmt : Expr in iu.ast.children {
                if stmt.node_type.is(NodeType.Decl).not() { continue }
                if stmt.children.len() == 0 { continue }
                switch stmt.node_type {
                case NodeType.Decl(dd):
                    ref rhs : Expr = stmt.children[0]
                    if rhs.node_type.is(NodeType.StructDef).or(rhs.node_type.is(NodeType.EnumDef)) {
                        ref afd_ns : Vec(Declaration) = def_ns_decls(rhs)
                        for fdd : Declaration in afd_ns {
                            if fdd.default_value.is_null() { continue }
                            switch fdd.default_value.node_type {
                            case NodeType.FuncDef(fd):
                                if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)).or(fd.func_type.is(FuncType.CoreFunc)).or(fd.func_type.is(FuncType.CoreProc)) { continue }
                                full_name := dd.name.concat3("_", fdd.name)
                                emit_func_forward_decl(f, full_name, fdd.default_value, false, lp.ctx)
                            case:
                            }
                        }
                    } else {
                        switch rhs.node_type {
                        case NodeType.FuncDef(fd):
                            if builder_is_type_gen_macro_def(rhs) { continue }
                            if rhs.children.len() == 0 { continue }
                            if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)).or(fd.func_type.is(FuncType.CoreFunc)).or(fd.func_type.is(FuncType.CoreProc)) { continue }
                            if mode.is_null().not() {
                                if mode.needs_main {
                                    if dd.name == "main" { continue }
                                }
                            }
                            fc := func_to_c(dd.name)
                            emit_func_forward_decl(f, fc, rhs, true, lp.ctx)
                        case:
                        }
                    }
                case:
                    UNREACHABLE()
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for stmt : Expr in iu.ast.children {
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            if stmt.children.len() == 0 { continue }
            switch stmt.node_type {
            case NodeType.Decl(dd):
                ref rhs : Expr = stmt.children[0]
                if rhs.node_type.is(NodeType.StructDef).or(rhs.node_type.is(NodeType.EnumDef)) {
                    ref afd_ns : Vec(Declaration) = def_ns_decls(rhs)
                    for fdd : Declaration in afd_ns {
                        if fdd.default_value.is_null() { continue }
                        if fdd.default_value.node_type.is(NodeType.FuncDef).not() { continue }
                        full_name := dd.name.concat3("_", fdd.name)
                        emit_func_forward_decl(f, full_name, fdd.default_value, false, lp.ctx)
                    }
                } else {
                    switch rhs.node_type {
                    case NodeType.FuncDef(fd):
                        if builder_is_type_gen_macro_def(rhs) { continue }
                        if rhs.children.len() == 0 { continue }
                        if mode.is_null().not() {
                            if mode.needs_main {
                                if dd.name == "main" { continue }
                            }
                        }
                        fc := func_to_c(dd.name)
                        if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)).or(fd.func_type.is(FuncType.CoreFunc)).or(fd.func_type.is(FuncType.CoreProc)) {
                            continue
                        }
                        emit_func_forward_decl(f, fc, rhs, true, lp.ctx)
                        if lp.ctx.closure_value_names.has(dd.name) { emit_closure_forward_decl(f, fc, rhs, lp.ctx) }
                    case:
                    }
                }
            case:
                UNREACHABLE()
            }
        }
    }

    // Forward-declare enum ext methods (eq, constructors)
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            for stmt : Expr in iu.ast.children {
                if stmt.node_type.is(NodeType.Decl).not() { continue }
                if stmt.children.len() == 0 { continue }
                if stmt.children[0].node_type.is(NodeType.EnumDef).not() { continue }
                switch stmt.node_type {
                case NodeType.Decl(dd):
                    emit_enum_eq_ext_decl(f, dd.name, stmt.children[0])
                    switch stmt.children[0].node_type {
                    case NodeType.EnumDef(shdr_edd):
                        mut shdr_vi : USize = 0
                        for shdr_vn : Str in shdr_edd.variants {
                            shdr_vt := enum_variant_type(stmt.children[0], shdr_vi.to_i32())
                            if shdr_vt.len() > 0 {
                                tnc := type_name_to_c(shdr_vt, lp.ctx)
                                f.write(dd.name).write(" *").write(dd.name).write("_").write(shdr_vn).write("(").write(tnc).write(");\n")
                            } else {
                                f.write(dd.name).write(" *").write(dd.name).write("_").write(shdr_vn).write("();\n")
                            }
                            shdr_vi++
                        }
                    case:
                        UNREACHABLE()
                    }
                case:
                    UNREACHABLE()
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for stmt : Expr in iu.ast.children {
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            if stmt.children.len() == 0 { continue }
            if stmt.children[0].node_type.is(NodeType.EnumDef).not() { continue }
            switch stmt.node_type {
            case NodeType.Decl(dd):
            emit_enum_eq_ext_decl(f, dd.name, stmt.children[0])
            switch stmt.children[0].node_type {
            case NodeType.EnumDef(shdr_edd):
                mut shdr_vi : USize = 0
                for shdr_vn : Str in shdr_edd.variants {
                    shdr_vt := enum_variant_type(stmt.children[0], shdr_vi.to_i32())
                    if shdr_vt.len() > 0 {
                        tnc := type_name_to_c(shdr_vt, lp.ctx)
                        f.write(dd.name).write(" *").write(dd.name).write("_").write(shdr_vn).write("(").write(tnc).write(");\n")
                    } else {
                        f.write(dd.name).write(" *").write(dd.name).write("_").write(shdr_vn).write("();\n")
                    }
                    shdr_vi++
                }
            case:
                UNREACHABLE()
            }
            case:
                UNREACHABLE()
            }
        }
    }
    f.write("\n")

    // Forward declarations for dyn_call dispatch functions
    mut dyn_methods := Vec(DynCallInfo).new()
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            collect_dyn_methods(iu.ast, dyn_methods)
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        collect_dyn_methods(iu.ast, dyn_methods)
    }
    for info : DynCallInfo in dyn_methods {
        if info.has_return {
            if info.nargs == 1 {
                f.write("void *dyn_call_").write(info.method).write("(Str *type_name, void *val);\n")
            } else {
                f.write("void *dyn_call_").write(info.method).write("(Str *type_name, void *val, void *arg2);\n")
            }
        } else {
            if info.nargs == 1 {
                f.write("void dyn_call_").write(info.method).write("(Str *type_name, void *val);\n")
            } else {
                f.write("void dyn_call_").write(info.method).write("(Str *type_name, void *val, void *arg2);\n")
            }
        }
    }
    mut has_dyn_type_to_str := false
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            if has_dyn_type_to_str { break }
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            for stmt : Expr in iu.ast.children {
                if is_func_decl(stmt).not() { continue }
                switch stmt.node_type {
                case NodeType.Decl(sdd):
                    if sdd.name == "dyn_type_to_str" {
                        has_dyn_type_to_str = true
                        break
                    }
                case:
                    UNREACHABLE()
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        if has_dyn_type_to_str { break }
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for stmt : Expr in iu.ast.children {
            if is_func_decl(stmt).not() { continue }
            switch stmt.node_type {
            case NodeType.Decl(sdd):
                if sdd.name == "dyn_type_to_str" {
                    has_dyn_type_to_str = true
                    break
                }
            case:
                UNREACHABLE()
            }
        }
    }
    f.write("void *dyn_fn(Str *type_name, Str *method);\n")
    f.write("U32 dyn_size_of(Str *type_name);\n")
    f.write("I64 struct_field_count(Str *type_name);\n")
    f.write("Str *struct_field_name(Str *type_name, I64 *index);\n")
    f.write("I64 struct_field_is_mut(Str *type_name, I64 *index);\n")
    f.write("Str *struct_field_type(Str *type_name, I64 *index);\n")
    f.write("I64 enum_variant_count(Str *type_name);\n")
    f.write("Str *enum_variant_name(Str *type_name, I64 *index);\n")
    f.write("I64 enum_variant_has_payload(Str *type_name, I64 *index);\n")
    f.write("Str *enum_variant_payload_type(Str *type_name, I64 *index);\n")
    f.write("I64 func_sig_param_count(Str *type_name);\n")
    f.write("Str *func_sig_param_type(Str *type_name, I64 *index);\n")
    f.write("I64 func_sig_return_count(Str *type_name);\n")
    f.write("Str *func_sig_return_type(Str *type_name, I64 *index);\n")
    f.write("I64 func_sig_throw_count(Str *type_name);\n")
    f.write("Str *func_sig_throw_type(Str *type_name, I64 *index);\n")
    if has_dyn_type_to_str {
        f.write("Str *dyn_type_to_str(Type *type);\n")
    }
    f.write("\n")
    own dyn_methods.delete()

    // Forward declarations for dyn_has_method dispatch functions
    mut dyn_has_shallow := false
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            if dyn_has_shallow { break }
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            for stmt : Expr in iu.ast.children {
                if is_func_decl(stmt).not() { continue }
                switch stmt.node_type {
                case NodeType.Decl(sdd):
                    if sdd.name == "dyn_has_method" {
                        switch stmt.children[0].node_type {
                        case NodeType.FuncDef(fd):
                            dyn_has_shallow = fd.return_own_type.is(OwnType.Shallow)
                        case:
                            UNREACHABLE()
                        }
                        break
                    }
                case:
                    UNREACHABLE()
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        if dyn_has_shallow { break }
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for stmt : Expr in iu.ast.children {
            if is_func_decl(stmt).not() { continue }
            switch stmt.node_type {
            case NodeType.Decl(sdd):
                if sdd.name == "dyn_has_method" {
                    switch stmt.children[0].node_type {
                    case NodeType.FuncDef(fd):
                        dyn_has_shallow = fd.return_own_type.is(OwnType.Shallow)
                    case:
                        UNREACHABLE()
                    }
                    break
                }
            case:
                UNREACHABLE()
            }
        }
    }
    mut dyn_has_ret := "Bool *"
    if dyn_has_shallow { dyn_has_ret = "Bool" }
    mut has_methods := Vec(Str).new()
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            collect_dyn_has_methods(iu.ast, has_methods)
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        collect_dyn_has_methods(iu.ast, has_methods)
    }
    for method : Str in has_methods {
        f.write(dyn_has_ret).write(" dyn_has_").write(method).write("(Str *type_name);\n")
    }
    if has_methods.len() > 0 { f.write("\n") }
    own has_methods.delete()

    // Forward declarations for array/vec builtin helpers
    mut coll_infos := Vec(CollectionInfo).new()
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            collect_collection_builtins(iu.ast, coll_infos)
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        collect_collection_builtins(iu.ast, coll_infos)
    }
    for ci : CollectionInfo in coll_infos {
        mut prefix := "array"
        mut ret := "Array"
        if ci.is_vec != 0 {
            prefix = "vec"
            ret = builder_variadic_vec_ctype(lp.ctx, ci.type_name)
        }
        f.write(ret).write(" *").write(prefix).write("_of_").write(ci.type_name).write("(int count, ...);\n")
    }
    if coll_infos.len() > 0 { f.write("\n") }
    own coll_infos.delete()
}

priv emit_dyn_fn_wrapper := proc(f: File, type_name: Str, method_name: Str, fd: FunctionDef, ctx: Context) {
    np := fd.params.len()
    ret_shallow := fd.return_own_type.is(OwnType.Shallow)
    has_return := fd.return_type.len() > 0
    // The dyn_fn funcptr aliases (CloneFn/DeleteFn/CmpFn, ...) use a uniform
    // dyn ABI. The wrapper bridges that ABI to the concrete method ABI:
    //   - return: clone uniquely produces an owned element stored as an opaque
    //     void* (CloneFn returns Dynamic), so a shallow clone return is boxed
    //     onto the heap. Every other shallow return (cmp/eq/hash) passes
    //     through by value, matching the value-returning alias. Non-shallow
    //     returns are opaque void* pointers (struct clone returns Type*).
    //   - params: element-data params (the dispatched type) and pointer params
    //     arrive as opaque void*; an element-data value param is deref'd to its
    //     value. The lone auxiliary shallow primitive is delete's call_free
    //     (param index >= 1 of delete), which the collection passes by value;
    //     every other param is element data of the dispatched type.
    box_ret := ret_shallow.and(method_name.eq("clone"))
    ret_value := ret_shallow.and(box_ret.not())
    if has_return {
        if ret_value { f.write(type_name_to_c_value(fd.return_type, ctx)).write(" ") }
        else { f.write("void *") }
    } else {
        f.write("void ")
    }
    f.write(type_name).write("_").write(method_name).write("_dyn(void *til_env")
    if np > 0 { f.write(", ") }
    for p in 0..np {
        if p > 0 { f.write(", ") }
        ref pp : Declaration = fd.params[p]
        is_call_free := method_name.eq("delete").and(p.gt(0))
        if pp.own_type.is(OwnType.Shallow).and(is_call_free) {
            f.write(type_name_to_c_value(pp.explicit_type, ctx)).write(" _a"); emit_i32(f, p.to_i32())
        } else {
            f.write("void *_a"); emit_i32(f, p.to_i32())
        }
    }
    f.write(") {\n")
    f.write("    (void)til_env;\n")
    if box_ret {
        rc := type_name_to_c_value(fd.return_type, ctx)
        f.write("    ").write(rc).write(" *_r = malloc(sizeof(").write(rc).write(")); *_r = ")
    } else {
        f.write("    ")
        if has_return {
            f.write("return ")
            if ret_value.not() { f.write("(void *)") }
        }
    }
    f.write(type_name).write("_").write(method_name).write("(")
    for p in 0..np {
        if p > 0 { f.write(", ") }
        ref pp : Declaration = fd.params[p]
        is_call_free := method_name.eq("delete").and(p.gt(0))
        if pp.own_type.is(OwnType.Shallow).and(is_call_free.not()) {
            f.write("*(").write(type_name_to_c_value(pp.explicit_type, ctx)).write(" *)_a"); emit_i32(f, p.to_i32())
        } else {
            f.write("_a"); emit_i32(f, p.to_i32())
        }
    }
    f.write(");")
    if box_ret { f.write(" return _r;") }
    f.write("\n}\n")
}

// #269: an ext_func/ext_proc namespace member is ABSTRACT (no C function
// behind it) only inside an interface; on any other type it is a C-backed
// external and must keep its dyn wrappers / dispatch entries.
priv def_is_interface := func(def: Expr) returns Bool {
    switch def.node_type {
    case NodeType.StructDef(sdd):
        return sdd.is_interface
    case:
        return false
    }
}

// #288: a core_func/core_proc is a symbol-less primitive intrinsic -- it can
// never be dyn_fn'd (the typer enforces this), so it gets NO dyn wrapper, NO
// closure value, and NO dyn_fn dispatch entry. The call lowers inline instead.
priv func_type_is_core := func(ft: FuncType) returns Bool {
    return ft.is(FuncType.CoreFunc).or(ft.is(FuncType.CoreProc))
}

emit_dyn_fn_closure_value := proc(f: File, type_name: Str, method_name: Str, suffix: Str) {
    value_name := type_name.format("_", method_name, suffix, "__til_closure")
    call_name := type_name.format("_", method_name, suffix)
    f.write("static __attribute__((unused)) TilClosure ").write(value_name).write(" = { (void *)").write(call_name).write(", NULL, NULL };\n")
}

priv emit_dyn_fn_wrappers := proc(f: File, lp: LoadedProgram) {
    // Emit wrapper functions that normalize calling convention
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            for stmt : Expr in iu.ast.children {
                if is_struct_or_enum(stmt).not() { continue }
                ref def : Expr = stmt.children[0]
                switch stmt.node_type {
                case NodeType.Decl(dd):
                    ref dfw_ns : Vec(Declaration) = def_ns_decls(def)
                    for d_j : Declaration in dfw_ns {
                        ref nsd : Declaration = d_j
                        if nsd.default_value.is_null() { continue }
                        switch nsd.default_value.node_type {
                        case NodeType.FuncDef(fd):
                            // #269: no wrapper for abstract interface
                            // methods -- there is no C function behind them.
                            // ext_funcs on non-interface types are C-backed.
                            if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)).and(def_is_interface(def)).not().and(func_type_is_core(fd.func_type).not()) {
                                emit_dyn_fn_wrapper(f, dd.name, nsd.name, fd, lp.ctx)
                                emit_dyn_fn_closure_value(f, dd.name, nsd.name, "_dyn")
                            }
                        case:
                        }
                    }
                case:
                    UNREACHABLE()
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for stmt : Expr in iu.ast.children {
            if is_struct_or_enum(stmt).not() { continue }
            ref def : Expr = stmt.children[0]
            switch stmt.node_type {
            case NodeType.Decl(dd):
                ref dfw_ns : Vec(Declaration) = def_ns_decls(def)
                for d_j : Declaration in dfw_ns {
                    ref nsd : Declaration = d_j
                    if nsd.default_value.is_null() { continue }
                    switch nsd.default_value.node_type {
                    case NodeType.FuncDef(fd):
                        // #269: no wrapper for abstract interface methods --
                        // there is no C function behind them. ext_funcs on
                        // non-interface types are C-backed.
                        if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)).and(def_is_interface(def)).not().and(func_type_is_core(fd.func_type).not()) {
                            emit_dyn_fn_wrapper(f, dd.name, nsd.name, fd, lp.ctx)
                            emit_dyn_fn_closure_value(f, dd.name, nsd.name, "_dyn")
                        }
                    case:
                    }
                }
            case:
                UNREACHABLE()
            }
        }
    }
    // Emit dyn_fn dispatch
    f.write("void *dyn_fn(Str *type_name, Str *method) {\n    (void)type_name; (void)method;\n")
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            for stmt : Expr in iu.ast.children {
                if is_struct_or_enum(stmt).not() { continue }
                ref def : Expr = stmt.children[0]
                switch stmt.node_type {
                case NodeType.Decl(dd):
                    ref dfn_ns : Vec(Declaration) = def_ns_decls(def)
                    for d_j : Declaration in dfn_ns {
                        ref nsd : Declaration = d_j
                        if nsd.default_value.is_null() { continue }
                        switch nsd.default_value.node_type {
                        case NodeType.FuncDef(dfn_fd):
                            // #269: abstract interface methods have no
                            // _dyn wrapper closure to point at. ext_funcs
                            // on non-interface types are C-backed.
                            if dfn_fd.func_type.is(FuncType.ExtFunc).or(dfn_fd.func_type.is(FuncType.ExtProc)).and(def_is_interface(def)).not().and(func_type_is_core(dfn_fd.func_type).not()) {
                                tlen := dd.name.len()
                                mlen := nsd.name.len()
                                f.write("    if (type_name->count == "); emit_usize(f, tlen); f.write("ULL && memcmp(type_name->c_str, \"").write(dd.name).write("\", "); emit_usize(f, tlen); f.write("ULL) == 0 && method->count == "); emit_usize(f, mlen); f.write("ULL && memcmp(method->c_str, \"").write(nsd.name).write("\", "); emit_usize(f, mlen); f.write("ULL) == 0) return (void*)&").write(dd.name).write("_").write(nsd.name).write("_dyn__til_closure;\n")
                            }
                        case:
                        }
                    }
                case:
                    UNREACHABLE()
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for stmt : Expr in iu.ast.children {
            if is_struct_or_enum(stmt).not() { continue }
            ref def : Expr = stmt.children[0]
            switch stmt.node_type {
            case NodeType.Decl(dd):
                ref dfn_ns : Vec(Declaration) = def_ns_decls(def)
                for d_j : Declaration in dfn_ns {
                    ref nsd : Declaration = d_j
                    if nsd.default_value.is_null() { continue }
                    switch nsd.default_value.node_type {
                    case NodeType.FuncDef(dfn_fd2):
                        // #269: abstract interface methods have no _dyn
                        // wrapper closure to point at. ext_funcs on
                        // non-interface types are C-backed.
                        if dfn_fd2.func_type.is(FuncType.ExtFunc).or(dfn_fd2.func_type.is(FuncType.ExtProc)).and(def_is_interface(def)).not().and(func_type_is_core(dfn_fd2.func_type).not()) {
                            tlen := dd.name.len()
                            mlen := nsd.name.len()
                            f.write("    if (type_name->count == "); emit_usize(f, tlen); f.write("ULL && memcmp(type_name->c_str, \"").write(dd.name).write("\", "); emit_usize(f, tlen); f.write("ULL) == 0 && method->count == "); emit_usize(f, mlen); f.write("ULL && memcmp(method->c_str, \"").write(nsd.name).write("\", "); emit_usize(f, mlen); f.write("ULL) == 0) return (void*)&").write(dd.name).write("_").write(nsd.name).write("_dyn__til_closure;\n")
                        }
                    case:
                    }
                }
            case:
                UNREACHABLE()
            }
        }
    }
    f.write("    fprintf(stderr, \"dyn_fn: unknown %s.%s\\n\", (char*)type_name->c_str, (char*)method->c_str);\n")
    f.write("    exit(1);\n")
    f.write("}\n\n")
}

priv emit_dyn_size_of_body := proc(f: File, lp: LoadedProgram) {
    f.write("U32 dyn_size_of(Str *type_name) {\n    (void)type_name;\n")
    f.write("    if (type_name->count == 7ULL && memcmp(type_name->c_str, \"Dynamic\", 7ULL) == 0) return sizeof(Dynamic);\n")
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            for stmt : Expr in iu.ast.children {
                if is_struct_or_enum(stmt).not() { continue }
                switch stmt.node_type {
                case NodeType.Decl(dd):
                    tlen := dd.name.len()
                    f.write("    if (type_name->count == "); emit_usize(f, tlen); f.write("ULL && memcmp(type_name->c_str, \"").write(dd.name).write("\", "); emit_usize(f, tlen); f.write("ULL) == 0) return sizeof(").write(dd.name).write(");\n")
                case:
                    UNREACHABLE()
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for stmt : Expr in iu.ast.children {
            if is_struct_or_enum(stmt).not() { continue }
            switch stmt.node_type {
            case NodeType.Decl(dd):
                tlen := dd.name.len()
                f.write("    if (type_name->count == "); emit_usize(f, tlen); f.write("ULL && memcmp(type_name->c_str, \"").write(dd.name).write("\", "); emit_usize(f, tlen); f.write("ULL) == 0) return sizeof(").write(dd.name).write(");\n")
            case:
                UNREACHABLE()
            }
        }
    }
    f.write("    fprintf(stderr, \"dyn_size_of: unknown type %.*s\\n\", (int)type_name->count, (char*)type_name->c_str);\n")
    f.write("    exit(1);\n")
    f.write("}\n\n")
}

// Issue #56/#58: emit one struct's branch for a struct_field_* function.
// kind 0 = count (return field count), 1 = name, 2 = is_mut, 3 = type.
priv emit_struct_field_branch_for_stmt := proc(f: File, stmt: Expr, kind: I32, ctx: Context) {
    if stmt.node_type.is(NodeType.Decl).not() { return }
    if stmt.children.len() == 0 { return }
    if stmt.children[0].node_type.is(NodeType.StructDef).not() { return }
    mut sname := ""
    switch stmt.node_type {
    case NodeType.Decl(dd): sname = dd.name
    case: return
    }
    switch stmt.children[0].node_type {
    case NodeType.StructDef(sd):
        tlen := sname.len()
        f.write("    if (type_name->count == "); emit_usize(f, tlen); f.write("ULL && memcmp(type_name->c_str, \"").write(sname).write("\", "); emit_usize(f, tlen); f.write("ULL) == 0) {\n")
        if kind == 0 {
            f.write("        return "); emit_usize(f, sd.fields.len()); f.write("LL;\n")
        } else {
            for i in 0..sd.fields.len() {
                ref fd : Declaration = sd.fields[i]
                f.write("        if (*index == "); emit_usize(f, i); f.write("LL) return ")
                if kind == 1 {
                    emit_str_lit_expr(f, fd.name, ctx)
                } else if kind == 2 {
                    if fd.is_mut { f.write("1") } else { f.write("0") }
                } else {
                    emit_str_lit_expr(f, fd.explicit_type, ctx)
                }
                f.write(";\n")
            }
        }
        f.write("    }\n")
    case:
    }
}

priv emit_struct_field_branches := proc(f: File, kind: I32, lp: LoadedProgram) {
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            for stmt : Expr in iu.ast.children {
                emit_struct_field_branch_for_stmt(f, stmt, kind, lp.ctx)
            }
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for stmt : Expr in iu.ast.children {
            emit_struct_field_branch_for_stmt(f, stmt, kind, lp.ctx)
        }
    }
}

// Issue #56/#58: emit the C bodies for the struct_field_* introspection
// primitives, mirroring rstil's emit_introspection_metadata. Each is a
// strcmp chain over every loaded struct type.
priv emit_struct_introspection_bodies := proc(f: File, lp: LoadedProgram) {
    f.write("I64 struct_field_count(Str *type_name) {\n    (void)type_name;\n")
    emit_struct_field_branches(f, 0, lp)
    f.write("    fprintf(stderr, \"struct_field_count: type '%.*s' not found\\n\", (int)type_name->count, (char*)type_name->c_str);\n    exit(1);\n}\n\n")

    f.write("Str *struct_field_name(Str *type_name, I64 *index) {\n    (void)type_name; (void)index;\n")
    emit_struct_field_branches(f, 1, lp)
    f.write("    fprintf(stderr, \"struct_field_name: type '%.*s' index out of range\\n\", (int)type_name->count, (char*)type_name->c_str);\n    exit(1);\n}\n\n")

    f.write("I64 struct_field_is_mut(Str *type_name, I64 *index) {\n    (void)type_name; (void)index;\n")
    emit_struct_field_branches(f, 2, lp)
    f.write("    fprintf(stderr, \"struct_field_is_mut: type '%.*s' index out of range\\n\", (int)type_name->count, (char*)type_name->c_str);\n    exit(1);\n}\n\n")

    f.write("Str *struct_field_type(Str *type_name, I64 *index) {\n    (void)type_name; (void)index;\n")
    emit_struct_field_branches(f, 3, lp)
    f.write("    fprintf(stderr, \"struct_field_type: type '%.*s' index out of range\\n\", (int)type_name->count, (char*)type_name->c_str);\n    exit(1);\n}\n\n")
}

// Issue #57/#58: emit one enum's branch for an enum_variant_* function.
// kind 0 = count, 1 = name, 2 = has_payload, 3 = payload_type.
priv emit_enum_variant_branch_for_stmt := proc(f: File, stmt: Expr, kind: I32, ctx: Context) {
    if stmt.node_type.is(NodeType.Decl).not() { return }
    if stmt.children.len() == 0 { return }
    if stmt.children[0].node_type.is(NodeType.EnumDef).not() { return }
    mut ename := ""
    switch stmt.node_type {
    case NodeType.Decl(dd): ename = dd.name
    case: return
    }
    switch stmt.children[0].node_type {
    case NodeType.EnumDef(ed):
        tlen := ename.len()
        f.write("    if (type_name->count == "); emit_usize(f, tlen); f.write("ULL && memcmp(type_name->c_str, \"").write(ename).write("\", "); emit_usize(f, tlen); f.write("ULL) == 0) {\n")
        if kind == 0 {
            f.write("        return "); emit_usize(f, ed.variants.len()); f.write("LL;\n")
        } else {
            for i in 0..ed.variants.len() {
                idx := i.to_i64()
                mut has_pl := false
                if ed.payload_types.has(idx) {
                    if ed.payload_types[idx].len() > 0 { has_pl = true }
                }
                f.write("        if (*index == "); emit_usize(f, i); f.write("LL) return ")
                if kind == 1 {
                    ref vn : Str = ed.variants[i]
                    emit_str_lit_expr(f, vn, ctx)
                } else if kind == 2 {
                    if has_pl { f.write("1") } else { f.write("0") }
                } else {
                    if has_pl {
                        ref pt2 : Str = ed.payload_types[idx]
                        emit_str_lit_expr(f, pt2, ctx)
                    } else {
                        emit_str_lit_expr(f, "", ctx)
                    }
                }
                f.write(";\n")
            }
        }
        f.write("    }\n")
    case:
    }
}

priv emit_enum_variant_branches := proc(f: File, kind: I32, lp: LoadedProgram) {
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            for stmt : Expr in iu.ast.children {
                emit_enum_variant_branch_for_stmt(f, stmt, kind, lp.ctx)
            }
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for stmt : Expr in iu.ast.children {
            emit_enum_variant_branch_for_stmt(f, stmt, kind, lp.ctx)
        }
    }
}

// Issue #57/#58: emit the C bodies for the enum_variant_* introspection
// primitives. Each is a strcmp chain over every loaded enum type.
priv emit_enum_introspection_bodies := proc(f: File, lp: LoadedProgram) {
    f.write("I64 enum_variant_count(Str *type_name) {\n    (void)type_name;\n")
    emit_enum_variant_branches(f, 0, lp)
    f.write("    fprintf(stderr, \"enum_variant_count: type '%.*s' not found\\n\", (int)type_name->count, (char*)type_name->c_str);\n    exit(1);\n}\n\n")

    f.write("Str *enum_variant_name(Str *type_name, I64 *index) {\n    (void)type_name; (void)index;\n")
    emit_enum_variant_branches(f, 1, lp)
    f.write("    fprintf(stderr, \"enum_variant_name: type '%.*s' index out of range\\n\", (int)type_name->count, (char*)type_name->c_str);\n    exit(1);\n}\n\n")

    f.write("I64 enum_variant_has_payload(Str *type_name, I64 *index) {\n    (void)type_name; (void)index;\n")
    emit_enum_variant_branches(f, 2, lp)
    f.write("    fprintf(stderr, \"enum_variant_has_payload: type '%.*s' index out of range\\n\", (int)type_name->count, (char*)type_name->c_str);\n    exit(1);\n}\n\n")

    f.write("Str *enum_variant_payload_type(Str *type_name, I64 *index) {\n    (void)type_name; (void)index;\n")
    emit_enum_variant_branches(f, 3, lp)
    f.write("    fprintf(stderr, \"enum_variant_payload_type: type '%.*s' index out of range\\n\", (int)type_name->count, (char*)type_name->c_str);\n    exit(1);\n}\n\n")
}

// Issue #58: emit one FuncSig's branch for a func_sig_* function. A
// FuncSig is a bodyless func/proc decl. kind 0 = param_count,
// 1 = param_type, 2 = return_count, 3 = return_type, 4 = throw_count,
// 5 = throw_type.
priv emit_funcsig_branch_for_stmt := proc(f: File, stmt: Expr, kind: I32, ctx: Context) {
    if stmt.node_type.is(NodeType.Decl).not() { return }
    if stmt.children.len() == 0 { return }
    if stmt.children[0].node_type.is(NodeType.FuncDef).not() { return }
    if stmt.children[0].children.len() != 0 { return }
    mut fname := ""
    switch stmt.node_type {
    case NodeType.Decl(dd): fname = dd.name
    case: return
    }
    switch stmt.children[0].node_type {
    case NodeType.FuncDef(fd):
        tlen := fname.len()
        f.write("    if (type_name->count == "); emit_usize(f, tlen); f.write("ULL && memcmp(type_name->c_str, \"").write(fname).write("\", "); emit_usize(f, tlen); f.write("ULL) == 0) {\n")
        if kind == 0 {
            f.write("        return "); emit_usize(f, fd.params.len()); f.write("LL;\n")
        } else if kind == 2 {
            if fd.return_type.len() > 0 { f.write("        return 1LL;\n") } else { f.write("        return 0LL;\n") }
        } else if kind == 4 {
            f.write("        return "); emit_usize(f, fd.throw_types.len()); f.write("LL;\n")
        } else if kind == 1 {
            for i in 0..fd.params.len() {
                f.write("        if (*index == "); emit_usize(f, i); f.write("LL) return ")
                emit_str_lit_expr(f, fd.params[i].explicit_type, ctx)
                f.write(";\n")
            }
        } else if kind == 3 {
            if fd.return_type.len() > 0 {
                f.write("        if (*index == 0LL) return ")
                emit_str_lit_expr(f, fd.return_type, ctx)
                f.write(";\n")
            }
        } else {
            for i in 0..fd.throw_types.len() {
                f.write("        if (*index == "); emit_usize(f, i); f.write("LL) return ")
                emit_str_lit_expr(f, fd.throw_types[i], ctx)
                f.write(";\n")
            }
        }
        f.write("    }\n")
    case:
    }
}

priv emit_funcsig_branches := proc(f: File, kind: I32, lp: LoadedProgram) {
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            for stmt : Expr in iu.ast.children {
                emit_funcsig_branch_for_stmt(f, stmt, kind, lp.ctx)
            }
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for stmt : Expr in iu.ast.children {
            emit_funcsig_branch_for_stmt(f, stmt, kind, lp.ctx)
        }
    }
}

// Issue #58: emit the C bodies for the func_sig_* introspection
// primitives. Each is a strcmp chain over every loaded FuncSig type.
priv emit_funcsig_introspection_bodies := proc(f: File, lp: LoadedProgram) {
    f.write("I64 func_sig_param_count(Str *type_name) {\n    (void)type_name;\n")
    emit_funcsig_branches(f, 0, lp)
    f.write("    fprintf(stderr, \"func_sig_param_count: type '%.*s' not found\\n\", (int)type_name->count, (char*)type_name->c_str);\n    exit(1);\n}\n\n")

    f.write("Str *func_sig_param_type(Str *type_name, I64 *index) {\n    (void)type_name; (void)index;\n")
    emit_funcsig_branches(f, 1, lp)
    f.write("    fprintf(stderr, \"func_sig_param_type: type '%.*s' index out of range\\n\", (int)type_name->count, (char*)type_name->c_str);\n    exit(1);\n}\n\n")

    f.write("I64 func_sig_return_count(Str *type_name) {\n    (void)type_name;\n")
    emit_funcsig_branches(f, 2, lp)
    f.write("    fprintf(stderr, \"func_sig_return_count: type '%.*s' not found\\n\", (int)type_name->count, (char*)type_name->c_str);\n    exit(1);\n}\n\n")

    f.write("Str *func_sig_return_type(Str *type_name, I64 *index) {\n    (void)type_name; (void)index;\n")
    emit_funcsig_branches(f, 3, lp)
    f.write("    fprintf(stderr, \"func_sig_return_type: type '%.*s' index out of range\\n\", (int)type_name->count, (char*)type_name->c_str);\n    exit(1);\n}\n\n")

    f.write("I64 func_sig_throw_count(Str *type_name) {\n    (void)type_name;\n")
    emit_funcsig_branches(f, 4, lp)
    f.write("    fprintf(stderr, \"func_sig_throw_count: type '%.*s' not found\\n\", (int)type_name->count, (char*)type_name->c_str);\n    exit(1);\n}\n\n")

    f.write("Str *func_sig_throw_type(Str *type_name, I64 *index) {\n    (void)type_name; (void)index;\n")
    emit_funcsig_branches(f, 5, lp)
    f.write("    fprintf(stderr, \"func_sig_throw_type: type '%.*s' index out of range\\n\", (int)type_name->count, (char*)type_name->c_str);\n    exit(1);\n}\n\n")
}

// Display strings for variants that don't follow the
// "case Type_TAG_<vn>: return <vn>" default (legacy idiosyncrasies
// preserved so dyn_type_to_str output stays stable).
priv dyn_type_str_display := func(vn: Str) returns Str {
    if vn == "Unknown" { return "" }
    if vn == "None"    { return "" }
    if vn == "FuncDef" { return "FunctionDef" }
    if vn == "FuncPtr" { return "Fn" }
    return vn
}

// Locate the variants of an enum definition by name in the loaded
// program. Returns true iff found. The first hit wins; out-vecs are
// only written on a hit.
priv find_loaded_enum_variants := func(ename: Str, mut variant_names: Vec(Str), mut variant_types: Vec(Str), lp: LoadedProgram) returns Bool {
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            for stmt : Expr in iu.ast.children {
                if is_struct_or_enum(stmt).not() { continue }
                switch stmt.node_type {
                case NodeType.Decl(dd):
                    if dd.name.eq(ename).not() { continue }
                    if stmt.children[0].node_type.is(NodeType.EnumDef).not() { continue }
                    mut hp := false
                    collect_enum_variants(stmt.children[0], variant_names, variant_types, hp)
                    return true
                case:
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for stmt : Expr in iu.ast.children {
            if is_struct_or_enum(stmt).not() { continue }
            switch stmt.node_type {
            case NodeType.Decl(dd):
                if dd.name.eq(ename).not() { continue }
                if stmt.children[0].node_type.is(NodeType.EnumDef).not() { continue }
                mut hp := false
                collect_enum_variants(stmt.children[0], variant_names, variant_types, hp)
                return true
            case:
            }
        }
    }
    return false
}

// Data-driven: walk the user's ~Type~ enum and emit one case per
// variant. Tag-only -> literal string return. Str payload ->
// Str_clone(&type->data.<v>). Enum payload (e.g. Primitive) ->
// inner switch over the payload enum's variants. Issue #203: this
// replaces the previous hardcoded list of emit_tag_case calls so
// migrating a primitive in/out of Type doesn't require editing
// this function in lockstep.
priv emit_dyn_type_to_str_body := proc(f: File, lp: LoadedProgram) {
    f.write("Str *dyn_type_to_str(Type *type) {\n")
    mut variant_names := Vec(Str).new()
    mut variant_types := Vec(Str).new()
    if find_loaded_enum_variants("Type", variant_names, variant_types, lp).not() {
        panic("emit_dyn_type_to_str_body: cannot find Type enum in loaded program")
    }
    f.write("    switch (type->tag) {\n")
    for j in 0..variant_names.len() {
        ref vn : Str = variant_names[j]
        ref vt : Str = variant_types[j]
        if vt.len() == 0 {
            display := dyn_type_str_display(vn)
            f.write("    case Type_TAG_")
            f.write(vn)
            f.write(": return ")
            emit_str_lit_expr(f, display, lp.ctx)
            f.write(";\n")
        } else if vt == "Str" {
            f.write("    case Type_TAG_")
            f.write(vn)
            f.write(": return Str_clone(&type->data.")
            f.write(vn)
            f.write(");\n")
        } else {
            // Nested enum
            mut inner_names := Vec(Str).new()
            mut inner_types := Vec(Str).new()
            if find_loaded_enum_variants(vt, inner_names, inner_types, lp).not() {
                panic("emit_dyn_type_to_str_body: cannot find payload enum '", vt, "'")
            }
            f.write("    case Type_TAG_")
            f.write(vn)
            f.write(":\n")
            f.write("        switch (type->data.")
            f.write(vn)
            f.write(".tag) {\n")
            for ivn : Str in inner_names {
                f.write("        case ")
                f.write(vt)
                f.write("_TAG_")
                f.write(ivn)
                f.write(": return ")
                emit_str_lit_expr(f, ivn, lp.ctx)
                f.write(";\n")
            }
            f.write("        }\n")
            f.write("        break;\n")
        }
    }
    f.write("    default: break;\n")
    f.write("    }\n")
    f.write("    return ")
    emit_str_lit_expr(f, "?", lp.ctx)
    f.write(";\n")
    f.write("}\n\n")
}

priv emit_dyn_call_bodies := proc(f: File, lp: LoadedProgram) {
    mut dyn_methods := Vec(DynCallInfo).new()
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            collect_dyn_methods(iu.ast, dyn_methods)
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        collect_dyn_methods(iu.ast, dyn_methods)
    }
    for info : DynCallInfo in dyn_methods {
        ref method : Str = info.method
        mut ret_type := "void "
        if info.has_return { ret_type = "void *" }
        if info.nargs == 1 {
            f.write(ret_type).write("dyn_call_").write(method).write("(Str *type_name, void *val) {\n")
        } else {
            f.write(ret_type).write("dyn_call_").write(method).write("(Str *type_name, void *val, void *arg2) {\n")
        }
        if lp.skip_core.not() {
            for u : ProgramUnit in lp.core_units {
                ref iu : ImportUnit = lp.ctx.imported[u.path]
                for e_i : Expr in iu.ast.children {
                    ref stmt : Expr = e_i
                    if is_struct_or_enum(stmt).not() { continue }
                    ref def : Expr = stmt.children[0]
                    ref method_fdef : Expr = find_namespace_func(def, method, lp.ctx.scope)
                    if method_fdef.is_null() { continue }
                    if method_fdef.node_type.is(NodeType.FuncDef).not() { continue }
                    // #269: skip abstract interface methods (ext_func/ext_proc
                    // inside an interface) -- there is no C function to
                    // dispatch to. ext_funcs on other types are C-backed.
                    mut dyn_skip_abstract := false
                    switch method_fdef.node_type {
                    case NodeType.FuncDef(abs_mfd):
                        if abs_mfd.func_type.is(FuncType.ExtFunc).or(abs_mfd.func_type.is(FuncType.ExtProc)) {
                            dyn_skip_abstract = true
                        }
                    case:
                    }
                    if dyn_skip_abstract.and(def_is_interface(def)) { continue }
                    switch stmt.node_type {
                    case NodeType.Decl(dd):
                    switch method_fdef.node_type {
                    case NodeType.FuncDef(mfd):
                    mut arg1 := "val"
                    if mfd.params.len() > 0 {
                        ref p0 : Declaration = mfd.params[0]
                        if p0.own_type.is(OwnType.Shallow) { arg1 = format("*(", dd.name, " *)val") }
                    }
                    mut arg2_s := "arg2"
                    if info.nargs == 2 {
                        if mfd.params.len() > 1 {
                            ref p1 : Declaration = mfd.params[1]
                            // Issue #223 step 1: the second param is not
                            // always the dispatched type (e.g. delete's
                            // call_free: Bool). Cast arg2 to the param's
                            // own value type, not dd.name.
                            if p1.own_type.is(OwnType.Shallow) { arg2_s = format("*(", type_name_to_c_value(p1.explicit_type, lp.ctx), " *)arg2") }
                        }
                    }
                    ret_sh := mfd.return_own_type.is(OwnType.Shallow)
                    mut ret_ct := ""
                    if info.has_return {
                        if ret_sh {
                            if mfd.return_type.len() > 0 { ret_ct = type_name_to_c_value(mfd.return_type, lp.ctx) }
                        }
                    }
                    tlen := dd.name.len()
                    if info.nargs == 2 {
                        if info.has_return {
                            if ret_sh {
                                f.write("    if (type_name->count == "); emit_usize(f, tlen); f.write("ULL && memcmp(type_name->c_str, \"").write(dd.name).write("\", "); emit_usize(f, tlen); f.write("ULL) == 0) { ").write(ret_ct).write(" *_r = malloc(sizeof(").write(ret_ct).write(")); *_r = ").write(dd.name).write("_").write(method).write("(").write(arg1).write(", ").write(arg2_s).write("); return _r; }\n")
                            } else {
                                f.write("    if (type_name->count == "); emit_usize(f, tlen); f.write("ULL && memcmp(type_name->c_str, \"").write(dd.name).write("\", "); emit_usize(f, tlen); f.write("ULL) == 0) return (void *)").write(dd.name).write("_").write(method).write("(").write(arg1).write(", ").write(arg2_s).write(");\n")
                            }
                        } else {
                            f.write("    if (type_name->count == "); emit_usize(f, tlen); f.write("ULL && memcmp(type_name->c_str, \"").write(dd.name).write("\", "); emit_usize(f, tlen); f.write("ULL) == 0) { ").write(dd.name).write("_").write(method).write("(").write(arg1).write(", ").write(arg2_s).write("); return; }\n")
                        }
                    } else {
                        if info.has_return {
                            if ret_sh {
                                f.write("    if (type_name->count == "); emit_usize(f, tlen); f.write("ULL && memcmp(type_name->c_str, \"").write(dd.name).write("\", "); emit_usize(f, tlen); f.write("ULL) == 0) { ").write(ret_ct).write(" *_r = malloc(sizeof(").write(ret_ct).write(")); *_r = ").write(dd.name).write("_").write(method).write("(").write(arg1).write("); return _r; }\n")
                            } else {
                                f.write("    if (type_name->count == "); emit_usize(f, tlen); f.write("ULL && memcmp(type_name->c_str, \"").write(dd.name).write("\", "); emit_usize(f, tlen); f.write("ULL) == 0) return (void *)").write(dd.name).write("_").write(method).write("(").write(arg1).write(");\n")
                            }
                        } else {
                            f.write("    if (type_name->count == "); emit_usize(f, tlen); f.write("ULL && memcmp(type_name->c_str, \"").write(dd.name).write("\", "); emit_usize(f, tlen); f.write("ULL) == 0) { ").write(dd.name).write("_").write(method).write("(").write(arg1).write("); return; }\n")
                        }
                    }
                    case:
                        UNREACHABLE()
                    }
                    case:
                        UNREACHABLE()
                    }
                }
            }
        }
        for u : ProgramUnit in lp.units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            for e_i : Expr in iu.ast.children {
                ref stmt : Expr = e_i
                if is_struct_or_enum(stmt).not() { continue }
                ref def : Expr = stmt.children[0]
                ref method_fdef : Expr = find_namespace_func(def, method, lp.ctx.scope)
                if method_fdef.is_null() { continue }
                if method_fdef.node_type.is(NodeType.FuncDef).not() { continue }
                // #269: skip abstract interface methods (ext_func/ext_proc
                // inside an interface) -- there is no C function to
                // dispatch to. ext_funcs on other types are C-backed.
                mut dyn_skip_abstract2 := false
                switch method_fdef.node_type {
                case NodeType.FuncDef(abs_mfd2):
                    if abs_mfd2.func_type.is(FuncType.ExtFunc).or(abs_mfd2.func_type.is(FuncType.ExtProc)) {
                        dyn_skip_abstract2 = true
                    }
                case:
                }
                if dyn_skip_abstract2.and(def_is_interface(def)) { continue }
                switch stmt.node_type {
                case NodeType.Decl(dd):
                switch method_fdef.node_type {
                case NodeType.FuncDef(mfd):
                mut arg1 := "val"
                if mfd.params.len() > 0 {
                    if mfd.params[0].own_type.is(OwnType.Shallow) { arg1 = format("*(", dd.name, " *)val") }
                }
                mut arg2_s := "arg2"
                if info.nargs == 2 {
                    if mfd.params.len() > 1 {
                        ref p1 : Declaration = mfd.params[1]
                        // Issue #223 step 1: cast arg2 to the param's own
                        // value type (e.g. delete's call_free: Bool), not
                        // the dispatched type dd.name.
                        if p1.own_type.is(OwnType.Shallow) { arg2_s = format("*(", type_name_to_c_value(p1.explicit_type, lp.ctx), " *)arg2") }
                    }
                }
                ret_sh := mfd.return_own_type.is(OwnType.Shallow)
                mut ret_ct := ""
                if info.has_return {
                    if ret_sh {
                        if mfd.return_type.len() > 0 { ret_ct = type_name_to_c_value(mfd.return_type, lp.ctx) }
                    }
                }
                tlen := dd.name.len()
                if info.nargs == 2 {
                    if info.has_return {
                        if ret_sh {
                            f.write("    if (type_name->count == "); emit_usize(f, tlen); f.write("ULL && memcmp(type_name->c_str, \"").write(dd.name).write("\", "); emit_usize(f, tlen); f.write("ULL) == 0) { ").write(ret_ct).write(" *_r = malloc(sizeof(").write(ret_ct).write(")); *_r = ").write(dd.name).write("_").write(method).write("(").write(arg1).write(", ").write(arg2_s).write("); return _r; }\n")
                        } else {
                            f.write("    if (type_name->count == "); emit_usize(f, tlen); f.write("ULL && memcmp(type_name->c_str, \"").write(dd.name).write("\", "); emit_usize(f, tlen); f.write("ULL) == 0) return (void *)").write(dd.name).write("_").write(method).write("(").write(arg1).write(", ").write(arg2_s).write(");\n")
                        }
                    } else {
                        f.write("    if (type_name->count == "); emit_usize(f, tlen); f.write("ULL && memcmp(type_name->c_str, \"").write(dd.name).write("\", "); emit_usize(f, tlen); f.write("ULL) == 0) { ").write(dd.name).write("_").write(method).write("(").write(arg1).write(", ").write(arg2_s).write("); return; }\n")
                    }
                } else {
                    if info.has_return {
                        if ret_sh {
                            f.write("    if (type_name->count == "); emit_usize(f, tlen); f.write("ULL && memcmp(type_name->c_str, \"").write(dd.name).write("\", "); emit_usize(f, tlen); f.write("ULL) == 0) { ").write(ret_ct).write(" *_r = malloc(sizeof(").write(ret_ct).write(")); *_r = ").write(dd.name).write("_").write(method).write("(").write(arg1).write("); return _r; }\n")
                        } else {
                            f.write("    if (type_name->count == "); emit_usize(f, tlen); f.write("ULL && memcmp(type_name->c_str, \"").write(dd.name).write("\", "); emit_usize(f, tlen); f.write("ULL) == 0) return (void *)").write(dd.name).write("_").write(method).write("(").write(arg1).write(");\n")
                        }
                    } else {
                        f.write("    if (type_name->count == "); emit_usize(f, tlen); f.write("ULL && memcmp(type_name->c_str, \"").write(dd.name).write("\", "); emit_usize(f, tlen); f.write("ULL) == 0) { ").write(dd.name).write("_").write(method).write("(").write(arg1).write("); return; }\n")
                    }
                }
                case:
                    UNREACHABLE()
                }
                case:
                    UNREACHABLE()
                }
            }
        }
        f.write("    fprintf(stderr, \"dyn_call: unknown type for ").write(method).write("\\n\");\n")
        f.write("    exit(1);\n")
        f.write("}\n\n")
    }
    own dyn_methods.delete()
}

priv emit_dyn_has_bodies := proc(f: File, lp: LoadedProgram) {

    // Find dyn_has_method to check return_is_shallow
    mut dyn_has_shallow := false
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            if dyn_has_shallow { break }
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            for stmt : Expr in iu.ast.children {
                if stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0)).and(stmt.children[0].node_type.is(NodeType.FuncDef)) {
                    switch stmt.node_type {
                    case NodeType.Decl(dd):
                        if dd.name == "dyn_has_method" {
                            switch stmt.children[0].node_type {
                            case NodeType.FuncDef(fd):
                                dyn_has_shallow = fd.return_own_type.is(OwnType.Shallow)
                            case:
                                UNREACHABLE()
                            }
                            break
                        }
                    case:
                        UNREACHABLE()
                    }
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        if dyn_has_shallow { break }
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for stmt : Expr in iu.ast.children {
            if stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0)).and(stmt.children[0].node_type.is(NodeType.FuncDef)) {
                switch stmt.node_type {
                case NodeType.Decl(dd):
                    if dd.name == "dyn_has_method" {
                        switch stmt.children[0].node_type {
                        case NodeType.FuncDef(fd):
                            dyn_has_shallow = fd.return_own_type.is(OwnType.Shallow)
                        case:
                            UNREACHABLE()
                        }
                        break
                    }
                case:
                    UNREACHABLE()
                }
            }
        }
    }
    mut dyn_has_ret := "Bool *"
    if dyn_has_shallow { dyn_has_ret = "Bool" }
    mut has_methods := Vec(Str).new()
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            collect_dyn_has_methods(iu.ast, has_methods)
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        collect_dyn_has_methods(iu.ast, has_methods)
    }
    for method : Str in has_methods {
        f.write(dyn_has_ret).write(" dyn_has_").write(method).write("(Str *type_name) {\n    (void)type_name;\n")
        if lp.skip_core.not() {
            for u : ProgramUnit in lp.core_units {
                ref iu : ImportUnit = lp.ctx.imported[u.path]
                for e_i : Expr in iu.ast.children {
                    ref stmt : Expr = e_i
                    if is_struct_or_enum(stmt).not() { continue }
                    ref rhs : Expr = stmt.children[0]
                    switch stmt.node_type {
                    case NodeType.Decl(dd):
                        mut found := false
                        ref dhb_ns : Vec(Declaration) = def_ns_decls(rhs)
                        for nsd : Declaration in dhb_ns {
                            if nsd.name == method { found = true; break }
                        }
                        if found.not() { continue }
                        if dyn_has_shallow {
                            f.write("    if (type_name->count == "); emit_usize(f, dd.name.len()); f.write("ULL && memcmp(type_name->c_str, \"").write(dd.name).write("\", "); emit_usize(f, dd.name.len()); f.write("ULL) == 0) return 1;\n")
                        } else {
                            f.write("    if (type_name->count == "); emit_usize(f, dd.name.len()); f.write("ULL && memcmp(type_name->c_str, \"").write(dd.name).write("\", "); emit_usize(f, dd.name.len()); f.write("ULL) == 0) { Bool *r = malloc(sizeof(Bool)); *r = 1; return r; }\n")
                        }
                    case:
                        UNREACHABLE()
                    }
                }
            }
        }
        for u : ProgramUnit in lp.units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            for e_i : Expr in iu.ast.children {
                ref stmt : Expr = e_i
                if is_struct_or_enum(stmt).not() { continue }
                ref rhs : Expr = stmt.children[0]
                switch stmt.node_type {
                case NodeType.Decl(dd):
                    mut found := false
                    ref dhb_ns : Vec(Declaration) = def_ns_decls(rhs)
                    for nsd : Declaration in dhb_ns {
                        if nsd.name == method { found = true; break }
                    }
                    if found.not() { continue }
                    if dyn_has_shallow {
                        f.write("    if (type_name->count == "); emit_usize(f, dd.name.len()); f.write("ULL && memcmp(type_name->c_str, \"").write(dd.name).write("\", "); emit_usize(f, dd.name.len()); f.write("ULL) == 0) return 1;\n")
                    } else {
                        f.write("    if (type_name->count == "); emit_usize(f, dd.name.len()); f.write("ULL && memcmp(type_name->c_str, \"").write(dd.name).write("\", "); emit_usize(f, dd.name.len()); f.write("ULL) == 0) { Bool *r = malloc(sizeof(Bool)); *r = 1; return r; }\n")
                    }
                case:
                    UNREACHABLE()
                }
            }
        }
        if dyn_has_shallow { f.write("    return 0;\n") }
        else { f.write("    Bool *r = malloc(sizeof(Bool)); *r = 0; return r;\n") }
        f.write("}\n\n")
    }
    own has_methods.delete()
}

priv emit_collection_helpers := proc(f: File, lp: LoadedProgram) {
    mut coll_infos := Vec(CollectionInfo).new()
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            collect_collection_builtins(iu.ast, coll_infos)
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        collect_collection_builtins(iu.ast, coll_infos)
    }
    for ci : CollectionInfo in coll_infos {
        et := ci.type_name
        et_len := et.len()
        if ci.is_vec != 0 {
            vec_type := builder_variadic_vec_type_name(lp.ctx, et)
            vec_ctype := type_name_to_c(vec_type, lp.ctx)
            f.write(vec_ctype).write(" *vec_of_").write(et).write("(int count, ...) {\n")
            if vec_type == "Vec" {
                f.write("    USize _esz = sizeof(").write(et).write(");\n")
                f.write("    Vec *_v = Vec_new(&(Str){.c_str = (void *)\"").write(et).write("\", .count = "); emit_usize(f, et_len); f.write("ULL, .cap = TIL_CAP_LIT}, &(USize){_esz});\n")
            } else {
                f.write("    ").write(vec_ctype).write(" *_v = ").write(vec_type).write("_new();\n")
            }
            f.write("    va_list ap; va_start(ap, count);\n")
            f.write("    for (int _i = 0; _i < count; _i++) {\n")
            cn := et.format("_clone")
            is_shallow := callee_returns_shallow(cn, lp.ctx)
            if is_shallow {
                f.write("        ").write(et).write(" *_val = malloc(sizeof(").write(et).write(")); *_val = ").write(et).write("_clone(va_arg(ap, ").write(et).write(" *));\n")
            } else {
                f.write("        ").write(et).write(" *_val = ").write(et).write("_clone(va_arg(ap, ").write(et).write(" *));\n")
            }
            f.write("        ").write(vec_type).write("_push(_v, _val);\n")
            f.write("    }\n")
            f.write("    va_end(ap);\n")
            f.write("    return _v;\n")
            f.write("}\n\n")
        } else {
            arr_type := builder_variadic_array_type_name(lp.ctx, et)
            arr_ctype := type_name_to_c(arr_type, lp.ctx)
            f.write(arr_ctype).write(" array_of_").write(et).write("(int count, ...) {\n")
            f.write("    USize _cap = count;\n")
            f.write("    ").write(arr_ctype).write(" _a = ")
            if arr_type == "Array" {
                f.write("Array_new_type_name(&(Str){.c_str = (void *)\"").write(et).write("\", .count = "); emit_usize(f, et_len); f.write("ULL, .cap = TIL_CAP_LIT}, _cap);\n")
            } else {
                f.write("malloc(sizeof(").write(arr_type).write("));\n")
                f.write("    _a->data = calloc(_cap, sizeof(").write(et).write("));\n")
                f.write("    _a->cap = _cap;\n")
            }
            f.write("    va_list ap; va_start(ap, count);\n")
            f.write("    for (int _i = 0; _i < count; _i++) {\n")
            f.write("        USize _idx = _i;\n")
            cn := et.format("_clone")
            is_shallow := callee_returns_shallow(cn, lp.ctx)
            if is_shallow {
                f.write("        ").write(et).write(" *_val = malloc(sizeof(").write(et).write(")); *_val = ").write(et).write("_clone(va_arg(ap, ").write(et).write(" *));\n")
            } else {
                f.write("        ").write(et).write(" *_val = ").write(et).write("_clone(va_arg(ap, ").write(et).write(" *));\n")
            }
            // Issue #225: write directly rather than via Array.set (see the
            // matching note in main()'s variadic wrapper). The slot is freshly
            // zero-allocated and `_idx` is in bounds, so memcpy is correct and
            // decoupled from Array.set's signature.
            f.write("        memcpy(ptr_add(_a->data, ((U64)_idx) * sizeof(").write(et).write(")), _val, sizeof(").write(et).write("));\n")
            f.write("        memset(_val, 0, sizeof(").write(et).write("));\n")
            f.write("        ").write(et).write("_delete(_val, 1);\n")
            f.write("    }\n")
            f.write("    va_end(ap);\n")
            f.write("    return _a;\n")
            f.write("}\n\n")
        }
    }
    own coll_infos.delete()
}

priv emit_global_declarations := proc(f: File, lp: LoadedProgram) {
    lp.ctx.script_globals = Set(Str).new()
    lp.ctx.ref_globals = Set(Str).new()
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            for stmt : Expr in iu.ast.children {
                if is_exported_top_level_global(stmt).not() { continue }
                ctype := extern_decl_ctype(stmt.expr_til_type(), stmt.children[0].expr_til_type(), lp.ctx)
                switch stmt.node_type {
                case NodeType.Decl(dd):
                    if dd.own_type.is(OwnType.Ref) {
                        f.write(ctype).write(" *").write(dd.name).write(";\n")
                        lp.ctx.ref_globals.add(own dd.name.clone())
                    } else {
                        f.write(ctype).write(" ").write(dd.name).write(";\n")
                        lp.ctx.script_globals.add(own dd.name.clone())
                    }
                case:
                    UNREACHABLE()
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for stmt : Expr in iu.ast.children {
            if is_exported_top_level_global(stmt).not() { continue }
            ctype := extern_decl_ctype(stmt.expr_til_type(), stmt.children[0].expr_til_type(), lp.ctx)
            switch stmt.node_type {
            case NodeType.Decl(dd):
                if dd.own_type.is(OwnType.Ref) {
                    f.write(ctype).write(" *").write(dd.name).write(";\n")
                    lp.ctx.ref_globals.add(own dd.name.clone())
                } else {
                    f.write(ctype).write(" ").write(dd.name).write(";\n")
                    lp.ctx.script_globals.add(own dd.name.clone())
                }
            case:
                UNREACHABLE()
            }
        }
    }
    emit_ns_const_global_defs(f, lp)
    f.write("\n")
}

// #264 follow-up: namespace DATA constants (e.g. U8.MAX) are emitted as
// file-scope globals in the main TU here -- defined once (uninitialised,
// since values like U64.bnot(0) aren't C constant expressions) and
// initialised in main via emit_ns_inits. Covers ext.h primitive types,
// whose typedef is skipped by emit_struct_typedef. Single TU, so no
// extern/header split is needed.
priv emit_ns_const_defs_for_stmt := proc(f: File, stmt: Expr) {
    if is_struct_or_enum(stmt).not() { return }
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        ref edef : Expr = stmt.children[0]
        if edef.node_type.is(NodeType.EnumDef) { return }
        ref ns : Vec(Declaration) = def_ns_decls(edef)
        for dd : Declaration in ns {
            if dd.default_value.is_null() { continue }
            if dd.default_value.node_type.is(NodeType.FuncDef) { continue }
            if dd.default_value.node_type.is(NodeType.StructDef).or(dd.default_value.node_type.is(NodeType.EnumDef)) { continue }
            if dd.til_type.is(Type.Struct).or(dd.til_type.is(Type.Enum)) {
                ng_sname := til_type_name(dd.default_value.expr_til_type())
                if ng_sname.len() > 0 {
                    f.write(ng_sname).write(" ").write(sdecl.name).write("_").write(dd.name).write(";\n")
                } else {
                    tc := til_type_to_c(dd.til_type); f.write(tc).write(" ").write(sdecl.name).write("_").write(dd.name).write(";\n")
                }
            } else {
                tc := til_type_to_c(dd.til_type); f.write(tc).write(" ").write(sdecl.name).write("_").write(dd.name).write(";\n")
            }
        }
    case:
    }
}

priv emit_ns_const_global_defs := proc(f: File, lp: LoadedProgram) {
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            for stmt : Expr in iu.ast.children {
                emit_ns_const_defs_for_stmt(f, stmt)
            }
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for stmt : Expr in iu.ast.children {
            emit_ns_const_defs_for_stmt(f, stmt)
        }
    }
}

priv emit_test_main := proc(f: File, lp: LoadedProgram) {
    f.write("int main(void) {\n")
    emit_ns_inits(f, 1, lp)
    emit_global_inits(f, lp)
    mut test_count : I32 = 0
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for stmt : Expr in iu.ast.children {
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            if stmt.children.len() == 0 { continue }
            switch stmt.node_type {
            case NodeType.Decl(dd):
                ref rhs : Expr = stmt.children[0]
                if rhs.node_type.is(NodeType.FuncDef) {
                    switch rhs.node_type {
                    case NodeType.FuncDef(fd):
                        if fd.func_type.is(FuncType.Test).not() { continue }
                        f.write("    ").write(dd.name).write("();\n")
                        f.write("    fprintf(stderr, \"  pass: %s\\n\", \"").write(dd.name).write("\");\n")
                        test_count++
                    case:
                        UNREACHABLE()
                    }
                    continue
                }
                if rhs.node_type.is(NodeType.StructDef).or(rhs.node_type.is(NodeType.EnumDef)) {
                    ref ns : Vec(Declaration) = def_ns_decls(rhs)
                    for nsd : Declaration in ns {
                        ref nsfdef : Expr = nsd.default_value
                        if nsfdef.is_null() { continue }
                        switch nsfdef.node_type {
                        case NodeType.FuncDef(nsfd):
                            if nsfd.func_type.is(FuncType.Test).not() { continue }
                            full_name := dd.name.concat3("_", nsd.name)
                            qual_name := dd.name.format(".", nsd.name)
                            f.write("    ").write(full_name).write("();\n")
                            f.write("    fprintf(stderr, \"  pass: %s\\n\", \"").write(qual_name).write("\");\n")
                            test_count++
                        case:
                        }
                    }
                }
            case:
                UNREACHABLE()
            }
        }
    }
    if test_count == 0 {
        f.write("    fprintf(stderr, \"no tests found\\n\");\n")
    } else {
        f.write("    fprintf(stderr, \""); emit_i32(f, test_count); f.write("/"); emit_i32(f, test_count); f.write(" tests passed\\n\");\n")
    }
    f.write("    return 0;\n")
    f.write("}\n")
}

priv emit_script_main := proc(f: File, lp: LoadedProgram) {
    f.write("int main(void) {\n")
    emit_ns_inits(f, 1, lp)
        lp.ctx.builder_func.unsafe_to_hoist = Set(Str).new()
    // Collect hoist restrictions across all user units.
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        collect_unsafe_to_hoist(lp.ctx, iu.ast)
    }
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            for gs : Expr in iu.ast.children {
                if gs.node_type.is(NodeType.Decl) {
                    ref rhs : Expr = gs.children[0]
                    if rhs.node_type.is(NodeType.FuncDef).or(rhs.node_type.is(NodeType.StructDef)).or(rhs.node_type.is(NodeType.EnumDef)) { continue }
                    if gs.expr_til_type().is(Type.None).and(rhs.node_type.is(NodeType.Ident)) { continue }
                } else if gs.node_type.is(NodeType.FCall).not() { continue }
                emit_stmt(f, gs, 1, lp.ctx)
            }
        }
    }
    // Emit top-level non-def statements across all user units, in order.
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for stmt : Expr in iu.ast.children {
            if stmt.node_type.is(NodeType.Decl) {
                ref rhs : Expr = stmt.children[0]
                if rhs.node_type.is(NodeType.FuncDef).or(rhs.node_type.is(NodeType.StructDef)).or(rhs.node_type.is(NodeType.EnumDef)) { continue }
            }
            emit_stmt(f, stmt, 1, lp.ctx)
        }
    }
    f.write("    return 0;\n")
    f.write("}\n")
    lp.ctx.script_globals = Set(Str).new()
}

priv emit_function_bodies := proc(f: File, mode: Mode, lp: LoadedProgram) {
    emit_capturing_closures_lp(f, lp)
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            for stmt : Expr in iu.ast.children {
                if stmt.node_type.is(NodeType.Decl).not() { continue }
                switch stmt.node_type {
                case NodeType.Decl(dd):
                    ref rhs : Expr = stmt.children[0]
                    switch rhs.node_type {
                    case NodeType.StructDef:
                        emit_struct_funcs(f, dd.name, rhs, lp)
                    case NodeType.EnumDef:
                        emit_enum_def(f, dd.name, rhs, lp)
                        f.write("\n")
                    case NodeType.FuncDef(fd):
                        if builder_is_type_gen_macro_def(rhs) { continue }
                        if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)).or(fd.func_type.is(FuncType.CoreFunc)).or(fd.func_type.is(FuncType.CoreProc)) { continue }
                        if rhs.children.len() == 0 { continue }
                        emit_func_def(f, dd.name, rhs, mode, false, lp)
                        if lp.ctx.closure_value_names.has(dd.name) { emit_closure_wrapper_def(f, dd.name, rhs, lp.ctx) }
                        f.write("\n")
                    case:
                    }
                case:
                    UNREACHABLE()
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for stmt : Expr in iu.ast.children {
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            switch stmt.node_type {
            case NodeType.Decl(dd):
                ref rhs : Expr = stmt.children[0]
                switch rhs.node_type {
                case NodeType.StructDef:
                    emit_struct_funcs(f, dd.name, rhs, lp)
                case NodeType.EnumDef:
                    emit_enum_def(f, dd.name, rhs, lp)
                    f.write("\n")
                case NodeType.FuncDef(fd):
                    if builder_is_type_gen_macro_def(rhs) { continue }
                    if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)).or(fd.func_type.is(FuncType.CoreFunc)).or(fd.func_type.is(FuncType.CoreProc)) { continue }
                    if rhs.children.len() == 0 { continue }
                    emit_func_def(f, dd.name, rhs, mode, false, lp)
                    if lp.ctx.closure_value_names.has(dd.name) { emit_closure_wrapper_def(f, dd.name, rhs, lp.ctx) }
                    f.write("\n")
                case:
                }
            case:
                UNREACHABLE()
            }
        }
    }
}

priv emit_ext_func_declarations := proc(f: File, program: Expr, ctx: Context) {
    for stmt : Expr in program.children {
        if is_func_decl(stmt).not() { continue }
        ref fdef : Expr = stmt.children[0]
        switch fdef.node_type {
        case NodeType.FuncDef(fd):
            if fd.func_type.is(FuncType.ExtFunc).not().and(fd.func_type.is(FuncType.ExtProc).not()) { continue }
            switch stmt.node_type {
            case NodeType.Decl(dd):
                if dd.name.eq("print_single").or(dd.name.eq("print_flush")) { continue }
                // Issue #176: builder.til (and similar units) use the
                // ext_func / ext_proc declaration as a forward-decl
                // shim so a regular func / proc body defined later can be
                // referenced earlier. When a real func / proc with the
                // same name exists, the canonical prototype + body comes
                // from that definition's own forward-decl emit path; the
                // ext_decl here would be a redundant prototype that
                // disagrees with the body on const-ness, so skip it.
                ref shadow_fdef : Expr = find_callee_fdef(dd.name, ctx)
                mut shadowed_by_func := false
                if shadow_fdef.is_null().not() {
                    switch shadow_fdef.node_type {
                    case NodeType.FuncDef(sfd):
                        if sfd.func_type.is(FuncType.ExtFunc).not().and(sfd.func_type.is(FuncType.ExtProc).not()) {
                            shadowed_by_func = true
                        }
                    case:
                    }
                }
                if shadowed_by_func { continue }
                if fd.return_type.len() > 0 {
                    mut rt := ""
                    if fd.return_own_type.is(OwnType.Shallow) { rt = type_name_to_c_value(fd.return_type, ctx) }
                    else { rt = type_name_to_c(fd.return_type, ctx) }
                    f.write(rt).write(" "); fc := func_to_c(dd.name); f.write(fc).write("(")
                } else {
                    f.write("void "); fc := func_to_c(dd.name); f.write(fc).write("(")
                }
                emit_param_list(f, fdef, false, true, ctx)
                f.write(");\n")
            case:
                UNREACHABLE()
            }
        case:
            UNREACHABLE()
        }
    }
    f.write("\n")
}

priv emit_lib_init := proc(f: File, lp: LoadedProgram) {
    f.write("__attribute__((constructor))\nstatic void _til_lib_init(void) {\n")
    emit_ns_inits(f, 1, lp)
    emit_global_inits(f, lp)
    f.write("}\n\n")
}

priv build := proc(mode: Mode, run_tests: Bool, c_output_path: Str, lp: LoadedProgram) returns I32 {
    mut is_lib := false
    if mode.is_null().not() { is_lib = mode.is_library }

    build_register_lookups_lp(lp)
    build_register_funcsig_names_lp(lp)
    build_register_closure_values_lp(lp)
    f := File.new(c_output_path, true)
    expect(f.is_null().not(), "f is null")

    f.write("#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <stdarg.h>\n#include <limits.h>\n\n")

    mut is_script := true
    if mode.is_null().not() {
        if mode.decls_only { is_script = false }
    }

    emit_monolithic_header_lp(f, mode, lp)
    f.write("#include \"ext.h\"\n\n")

    // Ext decls from user units only.
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        emit_ext_func_declarations(f, iu.ast, lp.ctx)
    }

    f.write("void print_single(Str *s);\n")
    f.write("void print_flush();\n\n")

    emit_all_forward_declarations(f, mode, lp)

    f.write("#define DEREF(p) (*(p ? p : (fprintf(stderr, \"panic: null deref\\n\"), exit(1), p)))\n")

    f.write("#define TIL_CAP_LIT ((USize)-1)\n")
    f.write("#define TIL_CAP_VIEW ((USize)-2)\n")
    f.write("void print_single(Str *s) {\n")
    f.write("    fwrite(s->c_str, 1, (size_t)s->count, stdout);\n")
    f.write("}\n")
    f.write("void print_flush() {\n")
    f.write("    putchar('\\n');\n")
    f.write("}\n\n")

    builder_register_str_lits(lp)
    builder_emit_str_lit_pool(f, lp.ctx)

    emit_global_declarations(f, lp)
    emit_function_bodies(f, mode, lp)

    emit_dyn_call_bodies(f, lp)
    emit_dyn_fn_wrappers(f, lp)
    emit_dyn_has_bodies(f, lp)
    emit_dyn_size_of_body(f, lp)
    emit_struct_introspection_bodies(f, lp)
    emit_enum_introspection_bodies(f, lp)
    emit_funcsig_introspection_bodies(f, lp)
    mut has_dyn_type_to_str2 := false
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            if has_dyn_type_to_str2 { break }
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            for stmt : Expr in iu.ast.children {
                if is_func_decl(stmt).not() { continue }
                switch stmt.node_type {
                case NodeType.Decl(sdd):
                    if sdd.name == "dyn_type_to_str" {
                        has_dyn_type_to_str2 = true
                        break
                    }
                case:
                    UNREACHABLE()
                }
            }
        }
    }
    for u : ProgramUnit in lp.units {
        if has_dyn_type_to_str2 { break }
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for stmt : Expr in iu.ast.children {
            if is_func_decl(stmt).not() { continue }
            switch stmt.node_type {
            case NodeType.Decl(sdd):
                if sdd.name == "dyn_type_to_str" {
                    has_dyn_type_to_str2 = true
                    break
                }
            case:
                UNREACHABLE()
            }
        }
    }
    if has_dyn_type_to_str2 {
        emit_dyn_type_to_str_body(f, lp)
    }
    emit_collection_helpers(f, lp)

    if run_tests {
        // Discover tests across every loaded user unit (matches the
        // interpret pass), so `til test foo.til` runs tests inline in
        // foo.til's imports, recursively (issue #51).
        emit_test_main(f, lp)
    }
    if run_tests.not() {
        if is_script.not() {
            if is_lib {
                if lp.ctx.script_globals.len() > 0 { emit_lib_init(f, lp) }
            }
        }
    }
    if run_tests.not() {
        if is_script {
            mut needs_main := false
            if mode.is_null().not() { needs_main = mode.needs_main }
            if needs_main.not() {
                emit_script_main(f, lp)
            }
        }
    }
    lp.ctx.func_defs = Map(Str, Dynamic).new()
    builder_reset_func_scratch(lp.ctx)
    return 0
}

priv BuildPaths := struct {
    name := ""
    c_path := ""
    bin_path := ""
    fwd_path := ""
    h_path := ""
    til_path := ""
    py_path := ""
    do_lib := false
}

priv derive_build_paths := func(lp: LoadedProgram, custom_bin: Str, custom_c: Str, target: Target) returns BuildPaths {
    mut paths := BuildPaths()

    last_slash := lp.path.rfind("/")
    mut basename := lp.path
    if last_slash >= 0 {
        last_slash_u : USize = last_slash.to_usize()
        basename = lp.path.substr(last_slash_u + 1, lp.path.len().sub(last_slash_u) - 1)
    }
    mut name_len := basename.len()
    if basename.ends_with(".til") {
        name_len = name_len - 4
    }
    name := basename.substr(0, name_len)
    paths.name = name.clone()

    mut c_path := format("gen/til/", name, ".c")
    if custom_c.len() > 0 { c_path = custom_c.clone() }
    mut ext := executable_extension(target)
    if target.is(Target.Wasm32).and(is_gui_auto_import(lp.cur_mode.auto_import)) { ext = ".html" }
    mut bin_path := format("bin/", name, ext)
    if custom_bin.len() > 0 { bin_path = custom_bin.clone() }

    paths.c_path = c_path
    paths.bin_path = bin_path
    paths.fwd_path = forward_header_path(c_path)
    paths.h_path = format("gen/til/", name, ".h")
    paths.til_path = format("gen/til/", name, ".til")
    paths.py_path = format("gen/til/", name, ".py")
    paths.do_lib = lp.cur_mode.is_library
    return paths
}

priv make_build_dirs := proc(paths: BuildPaths) {
    if paths.do_lib {
        if mkdir_p("gen/til") != 0 { panic("failed to create gen/til") }
        if mkdir_p("gen/lib") != 0 { panic("failed to create gen/lib") }
    } else {
        cp_slash := paths.c_path.rfind("/")
        bp_slash := paths.bin_path.rfind("/")
        mut cp_dir := "gen/til"
        if cp_slash > 0 {
            cp_slash_u : USize = cp_slash.to_usize()
            cp_dir = paths.c_path.substr(0, cp_slash_u)
        }
        mut bp_dir := "bin"
        if bp_slash > 0 {
            bp_slash_u : USize = bp_slash.to_usize()
            bp_dir = paths.bin_path.substr(0, bp_slash_u)
        }
        if mkdir_p(cp_dir) != 0 { panic("failed to create build output dir") }
        if mkdir_p(bp_dir) != 0 { panic("failed to create binary output dir") }
    }
}

priv translate_ast := proc(lp: LoadedProgram, paths: BuildPaths) returns I32 {
    mut result := build_forward_header_lp(paths.fwd_path, lp)
    if result == 0 {
        result = build(lp.cur_mode, lp.run_tests, paths.c_path, lp)
    }
    if result.eq(0).and(paths.do_lib) {
        result = build_header_lp(paths.h_path, lp)
        if result == 0 {
            result = build_til_binding(lp, paths.til_path, paths.name)
        }
        if result == 0 {
            result = build_python_binding(lp, paths.py_path, paths.name)
        }
    }
    return result
}

priv print_translate_success := proc(paths: BuildPaths) {
    println(format("Generated: ", paths.c_path))
    println(format("Generated: ", paths.fwd_path))
    if paths.do_lib {
        println(format("Generated: ", paths.h_path))
        println(format("Generated: ", paths.til_path))
        println(format("Generated: ", paths.py_path))
    }
}

priv compile_ast := proc(lp: LoadedProgram, paths: BuildPaths, target: Target, cc_override: Str, asan: Bool, prof: Bool) returns I32 {
    if paths.do_lib {
        return compile_lib(paths.c_path, paths.name, lp.ext_c_path, lp.link_c_paths, lp.link_flags, lp.include_flags, target, cc_override, asan)
    }
    return compile_c(paths.c_path, paths.bin_path, lp.ext_c_path, lp.link_c_paths, lp.link_flags, lp.include_flags, target, cc_override, lp.cur_mode.auto_import, asan, prof)
}

cmd_translate := proc(lp: LoadedProgram, custom_c: Str, target: Target) returns I32 {
    paths := derive_build_paths(lp, "", custom_c, target)
    make_build_dirs(paths)
    result := translate_ast(lp, paths)
    if result == 0 { print_translate_success(paths) }
    return result
}

cmd_build := proc(lp: LoadedProgram, custom_bin: Str, custom_c: Str, target: Target, cc_override: Str, asan: Bool, prof: Bool) returns I32 {
    paths := derive_build_paths(lp, custom_bin, custom_c, target)
    make_build_dirs(paths)
    mut result := translate_ast(lp, paths)
    if result == 0 { result = compile_ast(lp, paths, target, cc_override, asan, prof) }
    if result.eq(0).and(paths.do_lib) {
        print_translate_success(paths)
        println(format("Generated: gen/lib/lib", paths.name, ".so"))
        println(format("Generated: gen/lib/lib", paths.name, ".a"))
    }
    return result
}

priv default_install_prefix := proc() returns Str {
    if host_os() == "windows" {
        return "C:/Program Files/til"
    }
    return "/usr/local"
}

priv check_install_rc := proc(rc: I32, what: Str) returns I32 {
    if rc != 0 {
        println(format("error: failed to ", what))
        return 1
    }
    return 0
}

priv builder_compiler_root := func(lp: LoadedProgram) returns Str {
    return lp.ext_c_path.strip_suffix("/src/c/ext.c")
}

priv support_root := func(prefix: Str) returns Str {
    return format(prefix, "/lib/til")
}

priv install_file := proc(src: Str, dst: Str, what: Str) returns I32 {
    return check_install_rc(copy_file(src, dst), what)
}

priv install_tree := proc(src: Str, dst: Str, what: Str) returns I32 {
    return check_install_rc(copy_tree(src, dst), what)
}

priv is_compiler_install := func(lp: LoadedProgram, paths: BuildPaths) returns Bool {
    if paths.name.eq("til").not() { return false }
    if lp.path.eq("src/til.til").or(lp.path.eq("./src/til.til")) { return true }
    return lp.path.ends_with("/src/til.til")
}

priv install_compiler_support := proc(lp: LoadedProgram, prefix: Str) returns I32 {
    root := builder_compiler_root(lp)
    dst_root := support_root(prefix)
    mut rc := install_tree(format(root, "/src/core"), format(dst_root, "/src/core"), "install compiler core sources")
    if rc != 0 { return rc }
    rc = install_tree(format(root, "/lib"), format(dst_root, "/lib"), "install compiler library sources")
    if rc != 0 { return rc }
    rc = install_tree(format(root, "/src/modes"), format(dst_root, "/src/modes"), "install compiler mode sources")
    if rc != 0 { return rc }
    rc = install_tree(format(root, "/src/c"), format(dst_root, "/src/c"), "install compiler C sources")
    if rc != 0 { return rc }
    rc = install_tree(format(root, "/boot"), format(dst_root, "/boot"), "install compiler boot files")
    if rc != 0 { return rc }
    rc = install_tree(format(root, "/lib"), format(dst_root, "/lib"), "install bundled dependency tree")
    if rc != 0 { return rc }
    rc = install_file(root.format("/", REPL_CORE_INFO_CACHE), dst_root.format("/", REPL_CORE_INFO_CACHE), "install REPL doc info cache")
    if rc != 0 { return rc }
    rc = install_file(root.format("/", REPL_CORE_DOCS_CACHE), dst_root.format("/", REPL_CORE_DOCS_CACHE), "install REPL doc docs cache")
    if rc != 0 { return rc }
    return 0
}

priv print_install_success := proc(path: Str) {
    println(format("Installed: ", path))
}

cmd_install := proc(lp: LoadedProgram, install_prefix_in: Str, target: Target, cc_override: Str, asan: Bool, prof: Bool) returns I32 {
    mut install_prefix := install_prefix_in
    if install_prefix.len() == 0 {
        install_prefix = default_install_prefix()
    }

    paths := derive_build_paths(lp, "", "", target)
    make_build_dirs(paths)
    mut result := translate_ast(lp, paths)
    if result == 0 { result = compile_ast(lp, paths, target, cc_override, asan, prof) }
    if result != 0 { return result }

    if paths.do_lib {
        so_dst := format(install_prefix, "/lib/lib", paths.name, ".so")
        a_dst := format(install_prefix, "/lib/lib", paths.name, ".a")
        h_dst := format(install_prefix, "/include/", paths.name, ".h")
        til_dst := format(support_root(install_prefix), "/lib/", paths.name, ".til")
        py_dst := format(support_root(install_prefix), "/lib/", paths.name, ".py")

        result = install_file(format("gen/lib/lib", paths.name, ".so"), so_dst, "install shared library")
        if result == 0 { result = install_file(format("gen/lib/lib", paths.name, ".a"), a_dst, "install static library") }
        if result == 0 { result = install_file(paths.h_path, h_dst, "install C header") }
        if result == 0 { result = install_file(paths.til_path, til_dst, "install til binding") }
        if result == 0 { result = install_file(paths.py_path, py_dst, "install Python binding") }
        if result == 0 {
            print_install_success(so_dst)
            print_install_success(a_dst)
            print_install_success(h_dst)
            print_install_success(til_dst)
            print_install_success(py_dst)
        }
        return result
    }

    bin_dst := format(install_prefix, "/bin/", paths.name, executable_extension(target))
    result = install_file(paths.bin_path, bin_dst, "install executable")
    if result != 0 { return result }
    print_install_success(bin_dst)

    if is_compiler_install(lp, paths) {
        result = install_compiler_support(lp, install_prefix)
        if result != 0 { return result }
        print_install_success(support_root(install_prefix))
    }
    return 0
}

// Prefix used when spawning a child binary that was just built with --asan.
// til may itself be running under ASAN with detect_leaks=0 (the asan_safe_cmd
// wrap in tests.til, used to suppress the compiler's own known leaks). Without
// this override the child process tree inherits detect_leaks=0 and the
// compiled binary's leak check is silently skipped. Forcing detect_leaks=1
// keeps the child's leak detection on regardless of how the compiler was
// invoked, so `til run --asan` / `til test --asan` are self-contained.
priv asan_child_prefix := func(asan: Bool) returns Str {
    if asan { return "ASAN_OPTIONS=detect_leaks=1 " }
    return ""
}

cmd_run := proc(lp: LoadedProgram, custom_bin: Str, custom_c: Str, user_argv: Vec(Str), target: Target, cc_override: Str, asan: Bool, prof: Bool) returns I32 {
    if lp.cur_mode.is_library {
        panic("cannot run a library -- use translate or build")
    }
    paths := derive_build_paths(lp, custom_bin, custom_c, target)
    make_build_dirs(paths)
    mut result := translate_ast(lp, paths)
    if result == 0 { result = compile_ast(lp, paths, target, cc_override, asan, prof) }
    if result == 0 {
        mut cmd := format(asan_child_prefix(asan), paths.bin_path)
        for uarg : Str in user_argv {
            cmd = cmd.format(" '", uarg, "'")
        }
        result = system_cmd(cmd)
    }
    return result
}

// Compile and run a test binary. Forces do_lib=false so library-mode
// files still produce an executable -- emit_test_main is gated on
// lp.run_tests, so the C output has a real main().
cmd_test_build_run := proc(lp: LoadedProgram, custom_bin: Str, custom_c: Str, target: Target, cc_override: Str, asan: Bool, prof: Bool) returns I32 {
    mut paths := derive_build_paths(lp, custom_bin, custom_c, target)
    paths.do_lib = false
    make_build_dirs(paths)
    mut result := translate_ast(lp, paths)
    if result == 0 { result = compile_ast(lp, paths, target, cc_override, asan, prof) }
    if result == 0 { result = system_cmd(format(asan_child_prefix(asan), paths.bin_path)) }
    return result
}

// --- til doc <path> -- documentation generator ---

DocEntry := struct {
    name := ""
    id := ""
    unit_path := ""
    group := ""
    page := ""
    body := ""
    info := ""
    since := ""
    deprecated := ""
}

DocCatalog := struct {
    entries := Vec(DocEntry).new()
}

priv doc_decl_hidden := func(dd: Declaration, meta: DocMeta) returns Bool {
    return dd.name.starts_with("hoisted__")
        .or(dd.name.starts_with("priv___"))
        .or(dd.is_priv)
        .or(meta.hidden)
}

priv doc_index_link_path := func(out_path: Str) returns Str {
    if out_path.starts_with("doc/gen/") { return out_path.strip_prefix("doc/gen/").clone() }
    return out_path.clone()
}

priv doc_unit_path_normalized := func(unit_path: Str) returns Str {
    mut path := unit_path.clone()
    if path.starts_with("./") { path = path.strip_prefix("./").clone() }
    return path
}

priv doc_unit_key := func(unit_path: Str) returns Str {
    mut key := doc_unit_path_normalized(unit_path)
    if key.ends_with(".til") { key = key.strip_suffix(".til").clone() }
    key = key.replace("/", ".")
    return key
}

priv doc_entry_id := func(unit_path: Str, name: Str) returns Str {
    return format("til.", doc_unit_key(unit_path), ".", name)
}

priv doc_default_group := func(unit_path: Str) returns Str {
    path := doc_unit_path_normalized(unit_path)
    if path.starts_with("src/core/") { return "Core" }
    if path.starts_with("src/std/") { return "Standard library" }
    if path == "src/til.til" { return "CLI" }
    if path.starts_with("vendor/bindings/") { return "Vendor bindings" }
    if path.eq("src/self/lexer.til")
        .or(path.eq("src/self/parser.til"))
        .or(path.eq("src/self/context.til"))
        .or(path.eq("src/self/modes.til"))
        .or(path.eq("src/self/loader.til"))
        .or(path.eq("src/self/initer.til"))
        .or(path.eq("src/self/desugarer.til"))
        .or(path.eq("src/self/typer.til")) {
        return "Compiler frontend"
    }
    if path.eq("src/self/garbager.til")
        .or(path.eq("src/self/constfolder.til"))
        .or(path.eq("src/self/scavenger.til"))
        .or(path.eq("src/self/targets.til"))
        .or(path.eq("src/self/builder.til")) {
        return "Compiler backend"
    }
    if path.eq("src/self/interpreter.til")
        .or(path.eq("src/self/binder.til"))
        .or(path.eq("src/self/eval_heap.til")) {
        return "Compiler tools"
    }
    return ""
}

priv doc_effective_group := func(unit_path: Str, meta: DocMeta) returns Str {
    if meta.group.is_empty().not() { return meta.group.clone() }
    return doc_default_group(unit_path)
}

priv collect_unit_doc_catalog := func(u: ProgramUnit, ctx: Context, mut catalog: DocCatalog) {
    ref iu : ImportUnit = ctx.imported[u.path]
    page := doc_index_link_path(til_doc_out_path(u.path))
    for stmt : Expr in iu.ast.children {
        if stmt.node_type.is(NodeType.Decl) {
            switch stmt.node_type {
            case NodeType.Decl(dd):
                meta := parse_doc_meta(dd.doc)
                if doc_decl_hidden(dd, meta).not() {
                    info := format_decl_info(stmt, ctx.scope)
                    catalog.entries.push(own DocEntry(
                        name = dd.name.clone(),
                        id = doc_entry_id(u.path, dd.name),
                        unit_path = u.path.clone(),
                        group = doc_effective_group(u.path, meta),
                        page = page.clone(),
                        body = meta.body.clone(),
                        info = info.clone(),
                        since = meta.since.clone(),
                        deprecated = meta.deprecated.clone()))
                }
            case:
                UNREACHABLE()
            }
        }
    }
}

priv doc_catalog_lookup := func(catalog: DocCatalog, name: Str, loc: Str) returns DocEntry {
    for e : DocEntry in catalog.entries {
        if e.name == name { return e.clone() }
    }
    panic("unresolved til doc link '", name, "' in ", loc)
    return DocEntry()
}

priv doc_entry_org_link := func(e: DocEntry, label: Str) returns Str {
    return format("[[file:", e.page, "::#", e.id, "][", label, "]]")
}

priv doc_find_link_end := func(body: Str, start: USize, loc: Str) returns USize {
    mut i := start
    while i + 1 < body.len() {
        if body.substr(i, 2) == "]]" { return i }
        i++
    }
    panic("unterminated til doc link in ", loc)
    return body.len()
}

priv doc_line_end := func(body: Str, pos: USize) returns USize {
    rest := body.substr(pos, body.len() - pos)
    line_rel := rest.find("\n")
    if line_rel < 0 { return body.len() }
    return pos + line_rel.to_usize()
}

priv doc_next_line_pos := func(body: Str, line_end: USize) returns USize {
    if line_end >= body.len() { return body.len() }
    return line_end + 1
}

priv doc_is_src_begin := func(line: Str) returns Bool {
    return line.trim().starts_with("#+begin_src")
}

priv doc_is_src_end := func(line: Str) returns Bool {
    return line.trim().starts_with("#+end_src")
}

priv doc_expand_til_links := func(body: Str, catalog: DocCatalog, loc: Str) returns Str {
    mut out := ""
    mut pos : USize = 0
    while pos < body.len() {
        rest := body.substr(pos, body.len() - pos)
        link_rel := rest.find("[[til:")
        if link_rel < 0 {
            out = format(out, rest)
            return out
        }

        link_start := pos + link_rel.to_usize()
        if link_start > pos { out = format(out, body.substr(pos, link_start - pos)) }

        content_start := link_start + 6
        link_end := doc_find_link_end(body, content_start, loc)
        content := body.substr(content_start, link_end - content_start)
        sep := content.find("][")
        mut target := ""
        mut label := ""
        if sep < 0 {
            target = content.clone()
            label = content.clone()
        } else {
            sep_u := sep.to_usize()
            target = content.substr(0, sep_u).clone()
            label = content.substr(sep_u + 2, content.len() - sep_u - 2).clone()
        }
        if target.is_empty() { panic("empty til doc link target in ", loc) }
        if label.is_empty() { panic("empty til doc link label in ", loc) }
        entry := doc_catalog_lookup(catalog, target, loc)
        out = format(out, doc_entry_org_link(entry, label))
        pos = link_end + 2
    }
    return out
}

priv expand_doc_catalog_links := func(mut catalog: DocCatalog) {
    expanded := Vec(Str).new()
    for e : DocEntry in catalog.entries {
        expanded.push(own doc_expand_til_links(e.body, catalog, e.name))
    }
    for i in 0..expanded.len() {
        ref mut e : DocEntry = catalog.entries[i]
        ref body : Str = expanded[i]
        e.body = body.clone()
    }
}

priv build_doc_catalog := func(lp: LoadedProgram) returns DocCatalog {
    mut catalog := DocCatalog()
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units { collect_unit_doc_catalog(u, lp.ctx, catalog) }
    }
    for u : ProgramUnit in lp.units { collect_unit_doc_catalog(u, lp.ctx, catalog) }
    expand_doc_catalog_links(catalog)
    return catalog
}

priv append_doc_properties := func(mut out: Str, e: DocEntry, include_group: Bool, include_id: Bool) {
    has_group := include_group.and(e.group.is_empty().not())
    has_id := include_id.and(e.id.is_empty().not())
    if e.since.is_empty().not().or(e.deprecated.is_empty().not()).or(has_group).or(has_id) {
        out.push_str(":PROPERTIES:\n")
        if has_id {
            out.push_str(":CUSTOM_ID: "); out.push_str(e.id); out.push_str("\n")
        }
        if e.since.is_empty().not() {
            out.push_str(":since: "); out.push_str(e.since); out.push_str("\n")
        }
        if e.deprecated.is_empty().not() {
            out.push_str(":deprecated: "); out.push_str(e.deprecated); out.push_str("\n")
        }
        if has_group {
            out.push_str(":group: "); out.push_str(e.group); out.push_str("\n")
        }
        out.push_str(":END:\n")
    }
}

priv doc_unit_entry_capacity := func(e: DocEntry) returns USize {
    return e.name.len()
        .add(e.id.len())
        .add(e.body.len())
        .add(e.since.len())
        .add(e.deprecated.len())
        .add(e.group.len())
        .add(e.info.len())
         + 160
}

priv append_doc_unit_entry := func(mut out: Str, e: DocEntry) {
    out.push_str("* ")
    out.push_str(e.name)
    out.push_str("\n")
    append_doc_properties(out, e, true, true)
    if e.since.is_empty().not().or(e.deprecated.is_empty().not()).or(e.group.is_empty().not()).or(e.id.is_empty().not()) {
        out.push_str("\n")
    }
    if e.body.is_empty().not() {
        out.push_str(e.body)
        if e.body.ends_with("\n").not() { out.push_str("\n") }
        out.push_str("\n")
    }
    if e.info.is_empty().not() {
        out.push_str("#+begin_src til\n")
        out.push_str(e.info)
        if e.info.ends_with("\n").not() { out.push_str("\n") }
        out.push_str("#+end_src\n\n")
    }
}

// Render one source file's catalog entries as an org-mode page.
// One headline per public Decl, with the /// doc text and a kind/signature
// info block collected from the typed AST.
priv format_unit_doc_org := func(unit_path: Str, catalog: DocCatalog) returns Str {
    // Strip a leading "./" via a self-reassign from a substring of `title`.
    // This (`title = title.strip_prefix(...).clone()`) is compiled correctly
    // since issue #238 fixed the asap-destruction delete-ordering / clone-elision.
    mut title := unit_path.clone()
    if title.starts_with("./") {
        title = title.strip_prefix("./").clone()
    }
    mut total : USize = title.len() + 64
    for e : DocEntry in catalog.entries {
        if e.unit_path == unit_path { total = total + doc_unit_entry_capacity(e) }
    }
    mut buf := Str.with_capacity(total)
    buf.push_str("#+TITLE: ")
    buf.push_str(title)
    buf.push_str("\n#+OPTIONS: toc:t\n\n")
    for e : DocEntry in catalog.entries {
        if e.unit_path == unit_path { append_doc_unit_entry(buf, e) }
    }
    if buf.ends_with("\n\n") { buf = buf.strip_suffix("\n").clone() }
    return buf
}

priv doc_index_has_group := func(groups: Vec(Str), group: Str) returns Bool {
    for existing : Str in groups {
        if existing == group { return true }
    }
    return false
}

priv append_doc_index_entry := func(mut out: Str, e: DocEntry) {
    out.push_str("** [[file:")
    out.push_str(e.page)
    out.push_str("::#")
    out.push_str(e.id)
    out.push_str("][")
    out.push_str(e.name)
    out.push_str("]]\n")
    append_doc_properties(out, e, false, false)
    if e.info.is_empty().not() {
        out.push_str("#+begin_src til\n")
        out.push_str(e.info)
        if e.info.ends_with("\n").not() { out.push_str("\n") }
        out.push_str("#+end_src\n")
    }
    out.push_str("\n")
}

priv doc_index_entry_capacity := func(e: DocEntry) returns USize {
    return e.name.len().mul(2)
        .add(e.page.len())
        .add(e.id.len())
        .add(e.info.len())
        .add(e.since.len())
        .add(e.deprecated.len())
         + 160
}

priv doc_index_add_group_if_present := func(mut groups: Vec(Str), catalog: DocCatalog, group: Str) {
    if doc_index_has_group(groups, group) { return }
    for e : DocEntry in catalog.entries {
        if e.group == group {
            groups.push(own group.clone())
            return
        }
    }
}

priv doc_index_collect_groups := func(catalog: DocCatalog) returns Vec(Str) {
    groups := Vec(Str).new()
    doc_index_add_group_if_present(groups, catalog, "Core")
    doc_index_add_group_if_present(groups, catalog, "Standard library")
    doc_index_add_group_if_present(groups, catalog, "Compiler frontend")
    doc_index_add_group_if_present(groups, catalog, "Compiler backend")
    doc_index_add_group_if_present(groups, catalog, "Compiler tools")
    doc_index_add_group_if_present(groups, catalog, "CLI")
    doc_index_add_group_if_present(groups, catalog, "Vendor bindings")
    for e : DocEntry in catalog.entries {
        if e.group.is_empty().not().and(doc_index_has_group(groups, e.group).not()) {
            groups.push(own e.group.clone())
        }
    }
    return groups
}

priv format_doc_index_org := func(catalog: DocCatalog) returns Str {
    groups := doc_index_collect_groups(catalog)
    mut has_ungrouped := false
    mut total : USize = 128
    for group : Str in groups { total = total.add(group.len()) + 8 }
    for e : DocEntry in catalog.entries {
        total = total + doc_index_entry_capacity(e)
        if e.group.is_empty() {
            has_ungrouped = true
        }
    }
    if has_ungrouped { total = total + 16 }

    mut out := Str.with_capacity(total)
    out.push_str("#+TITLE: til documentation index\n#+OPTIONS: toc:t\n\n")

    for group : Str in groups {
        out.push_str("* ")
        out.push_str(group)
        out.push_str("\n\n")
        for e : DocEntry in catalog.entries {
            if e.group == group { append_doc_index_entry(out, e) }
        }
    }

    if has_ungrouped {
        out.push_str("* Ungrouped\n\n")
        for e : DocEntry in catalog.entries {
            if e.group.is_empty() { append_doc_index_entry(out, e) }
        }
    }
    if out.ends_with("\n\n") { out = out.strip_suffix("\n").clone() }
    return out
}

priv doc_html_escape := func(s: Str) returns Str {
    mut out := s.replace("&", "&amp;")
    out = out.replace("<", "&lt;")
    out = out.replace(">", "&gt;")
    out = out.replace("\"", "&quot;")
    return out
}

priv doc_js_escape := func(s: Str) returns Str {
    mut out := s.replace("\\", "\\\\")
    out = out.replace("\"", "\\\"")
    out = out.replace("\n", "\\n")
    out = out.replace("\r", "\\r")
    out = out.replace("\t", "\\t")
    return out
}

priv doc_html_path := func(org_path: Str) returns Str {
    if org_path.ends_with(".org").not() { panic("doc HTML path source is not .org: ", org_path) }
    return format(org_path.strip_suffix(".org"), ".html")
}

priv doc_html_relative_prefix := func(from_page: Str) returns Str {
    mut depth : USize = 0
    for i in 0..from_page.len() {
        ref ch : I8 = from_page.unsafe_get(i)
        if ch.eq('/') { depth++ }
    }
    mut out := Str.with_capacity(depth.mul(3))
    for _ in 0..depth { out.push_str("../") }
    return out
}

priv doc_html_href := func(from_page: Str, to_org_page: Str, anchor: Str) returns Str {
    return format(doc_html_relative_prefix(from_page), doc_html_path(to_org_page), "#", anchor)
}

priv doc_search_href := func(e: DocEntry) returns Str {
    return format(doc_html_path(e.page), "#", e.id)
}

priv append_doc_html_file_link := func(mut out: Str, content: Str, current_page: Str, loc: Str) {
    sep := content.find("][")
    if sep < 0 { panic("HTML doc link missing label in ", loc) }
    sep_u := sep.to_usize()
    target := content.substr(0, sep_u)
    label := content.substr(sep_u + 2, content.len() - sep_u - 2)
    if target.is_empty() { panic("HTML doc link target is empty in ", loc) }
    if label.is_empty() { panic("HTML doc link label is empty in ", loc) }

    anchor_sep := target.find("::#")
    if anchor_sep < 0 { panic("HTML doc file link missing anchor in ", loc) }
    anchor_sep_u := anchor_sep.to_usize()
    org_page := target.substr(0, anchor_sep_u)
    anchor := target.substr(anchor_sep_u + 3, target.len() - anchor_sep_u - 3)
    if org_page.is_empty() { panic("HTML doc file link page is empty in ", loc) }
    if anchor.is_empty() { panic("HTML doc file link anchor is empty in ", loc) }

    href := doc_html_href(current_page, org_page, anchor)
    out.push_str("<a href=\"")
    out.push_str(doc_html_escape(href))
    out.push_str("\">")
    out.push_str(doc_html_escape(label))
    out.push_str("</a>")
}

priv append_doc_html_inline := func(mut out: Str, text: Str, current_page: Str, loc: Str) {
    mut pos : USize = 0
    while pos < text.len() {
        rest := text.substr(pos, text.len() - pos)
        link_rel := rest.find("[[file:")
        if link_rel < 0 {
            out.push_str(doc_html_escape(rest))
            return
        }

        link_start := pos + link_rel.to_usize()
        if link_start > pos { out.push_str(doc_html_escape(text.substr(pos, link_start - pos))) }

        content_start := link_start + 7
        link_end := doc_find_link_end(text, content_start, loc)
        content := text.substr(content_start, link_end - content_start)
        append_doc_html_file_link(out, content, current_page, loc)
        pos = link_end + 2
    }
}

priv append_doc_html_body := func(mut out: Str, body: Str, current_page: Str, loc: Str) {
    mut pos : USize = 0
    mut in_para := false
    while pos < body.len() {
        line_end := doc_line_end(body, pos)
        line := body.substr(pos, line_end - pos)
        if doc_is_src_begin(line) {
            if in_para {
                out.push_str("</p>\n")
                in_para = false
            }
            out.push_str("<pre><code class=\"language-til\">")
            pos = doc_next_line_pos(body, line_end)
            mut found_end := false
            while pos < body.len() {
                src_line_end := doc_line_end(body, pos)
                src_line := body.substr(pos, src_line_end - pos)
                if doc_is_src_end(src_line) {
                    found_end = true
                    pos = doc_next_line_pos(body, src_line_end)
                    break
                }
                out.push_str(doc_html_escape(src_line))
                out.push_str("\n")
                pos = doc_next_line_pos(body, src_line_end)
            }
            if found_end.not() { panic("unterminated doc source block in ", loc) }
            out.push_str("</code></pre>\n")
            continue
        } else if line.trim().is_empty() {
            if in_para {
                out.push_str("</p>\n")
                in_para = false
            }
        } else {
            if in_para {
                out.push_str("\n")
            } else {
                out.push_str("<p>")
                in_para = true
            }
            append_doc_html_inline(out, line, current_page, loc)
        }
        pos = doc_next_line_pos(body, line_end)
    }
    if in_para { out.push_str("</p>\n") }
}

priv append_doc_html_meta := func(mut out: Str, e: DocEntry, include_group: Bool) {
    has_group := include_group.and(e.group.is_empty().not())
    if e.since.is_empty().not().or(e.deprecated.is_empty().not()).or(has_group) {
        out.push_str("<dl class=\"meta\">")
        if has_group {
            out.push_str("<dt>Group</dt><dd>")
            out.push_str(doc_html_escape(e.group))
            out.push_str("</dd>")
        }
        if e.since.is_empty().not() {
            out.push_str("<dt>Since</dt><dd>")
            out.push_str(doc_html_escape(e.since))
            out.push_str("</dd>")
        }
        if e.deprecated.is_empty().not() {
            out.push_str("<dt>Deprecated</dt><dd>")
            out.push_str(doc_html_escape(e.deprecated))
            out.push_str("</dd>")
        }
        out.push_str("</dl>\n")
    }
}

priv append_doc_html_head := func(mut out: Str, title: Str, current_page: Str) {
    out.push_str("<!doctype html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n")
    out.push_str("<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n")
    out.push_str("<title>")
    out.push_str(doc_html_escape(title))
    out.push_str("</title>\n")
    out.push_str("<style>\n")
    out.push_str(":root{color-scheme:light dark;--bg:#f8f5ef;--fg:#191714;--muted:#6f665b;--card:#fffdf8;--line:#ded6c9;--link:#7a3e14}\n")
    out.push_str("@media (prefers-color-scheme:dark){:root{--bg:#171512;--fg:#efe7da;--muted:#b8ad9d;--card:#211e1a;--line:#40382f;--link:#f0ad6d}}\n")
    out.push_str("body{margin:0;background:var(--bg);color:var(--fg);font:16px/1.55 ui-sans-serif,system-ui,sans-serif}\n")
    out.push_str("main{max-width:980px;margin:0 auto;padding:2rem 1.25rem 4rem}\n")
    out.push_str("a{color:var(--link)}nav{margin-bottom:1.5rem}.doc-entry{background:var(--card);border:1px solid var(--line);border-radius:10px;padding:1rem 1.25rem;margin:1rem 0}\n")
    out.push_str("h1,h2{line-height:1.2}pre{overflow:auto;background:#111;color:#eee;border-radius:8px;padding:1rem}code{font-family:ui-monospace,monospace}\n")
    out.push_str(".meta{display:flex;flex-wrap:wrap;gap:.35rem .75rem;color:var(--muted);font-size:.9rem}.meta dt{font-weight:700}.meta dd{margin:0}\n")
    out.push_str(".doc-index{list-style:none;padding:0}.doc-index li{margin:.75rem 0}\n")
    out.push_str(".doc-search{background:var(--card);border:1px solid var(--line);border-radius:10px;padding:1rem 1.25rem;margin:0 0 1.5rem}.doc-search label{display:block;font-weight:700;margin-bottom:.35rem}.doc-search input{box-sizing:border-box;width:100%;padding:.55rem .65rem;border:1px solid var(--line);border-radius:8px;background:var(--bg);color:var(--fg);font:inherit}.doc-search-results{margin:.75rem 0 0;padding-left:1.5rem}.doc-search-group{color:var(--muted);font-size:.9rem}\n")
    out.push_str("</style>\n<script src=\"")
    out.push_str(doc_html_escape(format(doc_html_relative_prefix(current_page), "search.js")))
    out.push_str("\" defer></script>\n</head>\n<body>\n<main>\n")
    out.push_str("<section class=\"doc-search\" aria-label=\"Documentation search\">\n<label for=\"til-doc-search\">Search docs</label>\n<input id=\"til-doc-search\" type=\"search\" placeholder=\"Type a name or phrase\" autocomplete=\"off\">\n<ol id=\"til-doc-search-results\" class=\"doc-search-results\"></ol>\n</section>\n")
}

priv append_doc_html_tail := func(mut out: Str) {
    out.push_str("</main>\n</body>\n</html>\n")
}

priv doc_html_entry_capacity := func(e: DocEntry) returns USize {
    return e.name.len()
        .add(e.id.len())
        .add(e.page.len())
        .add(e.group.len())
        .add(e.since.len())
        .add(e.deprecated.len())
        .add(e.body.len())
        .add(e.info.len())
        .mul(6)
        + 1024
}

priv append_doc_html_unit_entry := func(mut out: Str, e: DocEntry, current_page: Str) {
    out.push_str("<article class=\"doc-entry\" id=\"")
    out.push_str(doc_html_escape(e.id))
    out.push_str("\">\n<h2>")
    out.push_str(doc_html_escape(e.name))
    out.push_str("</h2>\n")
    append_doc_html_meta(out, e, true)
    if e.body.is_empty().not() {
        out.push_str("<div class=\"doc-body\">\n")
        append_doc_html_body(out, e.body, current_page, e.name)
        out.push_str("</div>\n")
    }
    if e.info.is_empty().not() {
        out.push_str("<pre><code class=\"language-til\">")
        out.push_str(doc_html_escape(e.info))
        if e.info.ends_with("\n").not() { out.push_str("\n") }
        out.push_str("</code></pre>\n")
    }
    out.push_str("</article>\n")
}

priv format_unit_doc_html := func(unit_path: Str, catalog: DocCatalog) returns Str {
    mut title := unit_path.clone()
    if title.starts_with("./") { title = title.strip_prefix("./").clone() }

    current_page := doc_index_link_path(doc_html_path(til_doc_out_path(unit_path)))
    mut total : USize = title.len().mul(6) + 8192
    for e : DocEntry in catalog.entries {
        if e.unit_path == unit_path { total = total + doc_html_entry_capacity(e) }
    }

    mut out := Str.with_capacity(total)
    append_doc_html_head(out, title, current_page)
    out.push_str("<nav><a href=\"")
    out.push_str(doc_html_escape(format(doc_html_relative_prefix(current_page), "index.html")))
    out.push_str("\">Index</a></nav>\n")
    out.push_str("<h1>")
    out.push_str(doc_html_escape(title))
    out.push_str("</h1>\n")
    for e : DocEntry in catalog.entries {
        if e.unit_path == unit_path { append_doc_html_unit_entry(out, e, current_page) }
    }
    append_doc_html_tail(out)
    return out
}

priv append_doc_html_index_entry := func(mut out: Str, e: DocEntry, current_page: Str) {
    out.push_str("<li><a href=\"")
    out.push_str(doc_html_escape(doc_html_href(current_page, e.page, e.id)))
    out.push_str("\">")
    out.push_str(doc_html_escape(e.name))
    out.push_str("</a>\n")
    append_doc_html_meta(out, e, false)
    if e.info.is_empty().not() {
        out.push_str("<pre><code class=\"language-til\">")
        out.push_str(doc_html_escape(e.info))
        if e.info.ends_with("\n").not() { out.push_str("\n") }
        out.push_str("</code></pre>\n")
    }
    out.push_str("</li>\n")
}

priv format_doc_index_html := func(catalog: DocCatalog) returns Str {
    groups := doc_index_collect_groups(catalog)
    mut has_ungrouped := false
    mut total : USize = 8192
    for group : Str in groups { total = total + group.len().mul(6) + 128 }
    for e : DocEntry in catalog.entries {
        total = total + doc_html_entry_capacity(e)
        if e.group.is_empty() { has_ungrouped = true }
    }

    mut out := Str.with_capacity(total)
    current_page := "index.html"
    append_doc_html_head(out, "til documentation index", current_page)
    out.push_str("<h1>til documentation index</h1>\n")
    for group : Str in groups {
        out.push_str("<section>\n<h2>")
        out.push_str(doc_html_escape(group))
        out.push_str("</h2>\n<ul class=\"doc-index\">\n")
        for e : DocEntry in catalog.entries {
            if e.group == group { append_doc_html_index_entry(out, e, current_page) }
        }
        out.push_str("</ul>\n</section>\n")
    }

    if has_ungrouped {
        out.push_str("<section>\n<h2>Ungrouped</h2>\n<ul class=\"doc-index\">\n")
        for e : DocEntry in catalog.entries {
            if e.group.is_empty() { append_doc_html_index_entry(out, e, current_page) }
        }
        out.push_str("</ul>\n</section>\n")
    }
    append_doc_html_tail(out)
    return out
}

priv doc_search_entry_capacity := func(e: DocEntry) returns USize {
    return e.name.len()
        .add(e.group.len())
        .add(e.page.len())
        .add(e.id.len())
        .add(e.body.len())
        .add(e.info.len())
        .mul(12)
        + 512
}

priv append_doc_search_js_entry := func(mut out: Str, e: DocEntry) {
    out.push_str("  {name:\"")
    out.push_str(doc_js_escape(e.name))
    out.push_str("\",group:\"")
    out.push_str(doc_js_escape(e.group))
    out.push_str("\",href:\"")
    out.push_str(doc_js_escape(doc_search_href(e)))
    out.push_str("\",body:\"")
    out.push_str(doc_js_escape(e.body))
    out.push_str("\",info:\"")
    out.push_str(doc_js_escape(e.info))
    out.push_str("\"},\n")
}

priv format_doc_search_js := func(catalog: DocCatalog) returns Str {
    mut total : USize = 8192
    for e : DocEntry in catalog.entries { total = total + doc_search_entry_capacity(e) }

    mut out := Str.with_capacity(total)
    out.push_str("\"use strict\";\n")
    out.push_str("window.tilDocSearchEntries = [\n")
    for e : DocEntry in catalog.entries { append_doc_search_js_entry(out, e) }
    out.push_str("];\n")
    out.push_str("(function(){\n")
    out.push_str("var script=document.currentScript;\n")
    out.push_str("var base=script&&script.src?script.src.replace(/search\\.js(?:[?#].*)?$/,''):'';\n")
    out.push_str("function ready(fn){if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',fn);}else{fn();}}\n")
    out.push_str("ready(function(){\n")
    out.push_str("var input=document.getElementById('til-doc-search');\n")
    out.push_str("var list=document.getElementById('til-doc-search-results');\n")
    out.push_str("if(!input||!list){return;}\n")
    out.push_str("function textFor(e){return(e.name+' '+e.group+' '+e.body+' '+e.info).toLowerCase();}\n")
    out.push_str("function clear(){while(list.firstChild){list.removeChild(list.firstChild);}}\n")
    out.push_str("function render(){\n")
    out.push_str("var q=input.value.trim().toLowerCase();\n")
    out.push_str("clear();\n")
    out.push_str("if(!q){return;}\n")
    out.push_str("var terms=q.split(/\\s+/);\n")
    out.push_str("var shown=0;\n")
    out.push_str("for(var i=0;i<window.tilDocSearchEntries.length&&shown<20;i++){\n")
    out.push_str("var e=window.tilDocSearchEntries[i];\n")
    out.push_str("var text=textFor(e);\n")
    out.push_str("var ok=true;\n")
    out.push_str("for(var j=0;j<terms.length;j++){if(text.indexOf(terms[j])<0){ok=false;break;}}\n")
    out.push_str("if(!ok){continue;}\n")
    out.push_str("var li=document.createElement('li');\n")
    out.push_str("var a=document.createElement('a');\n")
    out.push_str("a.href=base+e.href;\n")
    out.push_str("a.textContent=e.name;\n")
    out.push_str("li.appendChild(a);\n")
    out.push_str("if(e.group){var g=document.createElement('span');g.className='doc-search-group';g.textContent=' '+e.group;li.appendChild(g);}\n")
    out.push_str("list.appendChild(li);\n")
    out.push_str("shown++;\n")
    out.push_str("}\n")
    out.push_str("if(shown===0){var empty=document.createElement('li');empty.textContent='No matches';list.appendChild(empty);}\n")
    out.push_str("}\n")
    out.push_str("input.addEventListener('input',render);\n")
    out.push_str("});\n")
    out.push_str("}());\n")
    return out
}

priv emit_doc_search := proc(catalog: DocCatalog) {
    out := "doc/gen/search.js"
    ensure_parent_dir(out)
    page := format_doc_search_js(catalog)
    File.writefile(out, page)
    println(format("Generated: ", out))
}

priv emit_doc_index := proc(catalog: DocCatalog) {
    out := "doc/gen/index.org"
    ensure_parent_dir(out)
    page := format_doc_index_org(catalog)
    File.writefile(out, page)
    println(format("Generated: ", out))

    html_out := "doc/gen/index.html"
    html_page := format_doc_index_html(catalog)
    File.writefile(html_out, html_page)
    println(format("Generated: ", html_out))
}

// "src/core/vec.til" -> "doc/gen/src/core/vec.org"
priv til_doc_out_path := func(unit_path: Str) returns Str {
    // Trim a leading "./" and a trailing ".til" via self-reassigns from
    // substrings of `name`. `name = name.strip_prefix(...).clone()` is compiled
    // correctly since issue #238 fixed the asap-destruction delete-ordering /
    // clone-elision (the typer hoists the view-returning substr into a temp
    // aliasing the local; the fix keeps the clone and orders the old-value
    // delete after it).
    mut name := unit_path.clone()
    if name.starts_with("./") { name = name.strip_prefix("./").clone() }
    if name.ends_with(".til") { name = name.strip_suffix(".til").clone() }
    return format("doc/gen/", name, ".org")
}

priv til_doc_html_out_path := func(unit_path: Str) returns Str {
    return doc_html_path(til_doc_out_path(unit_path))
}

// Ensure the parent directory of `path` exists (mkdir -p).
priv ensure_parent_dir := proc(path: Str) {
    last_slash := path.rfind("/")
    if last_slash < 0 { return }
    last_slash_u : USize = last_slash.to_usize()
    dir := path.substr(0, last_slash_u).clone()
    if mkdir_p(dir) != 0 { panic("failed to create parent dir for ", path) }
}

priv emit_unit_doc := proc(u: ProgramUnit, catalog: DocCatalog) {
    out := til_doc_out_path(u.path)
    ensure_parent_dir(out)
    page := format_unit_doc_org(u.path, catalog)
    File.writefile(out, page)
    println(format("Generated: ", out))

    html_out := til_doc_html_out_path(u.path)
    html_page := format_unit_doc_html(u.path, catalog)
    File.writefile(html_out, html_page)
    println(format("Generated: ", html_out))
}

cmd_doc := proc(lp: LoadedProgram) returns I32 {
    catalog := build_doc_catalog(lp)
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units { emit_unit_doc(u, catalog) }
    }
    for u : ProgramUnit in lp.units { emit_unit_doc(u, catalog) }
    emit_doc_index(catalog)
    emit_doc_search(catalog)
    return 0
}

cmd_doc_cache := proc(lp: LoadedProgram) returns I32 {
    cache := build_repl_core_doc_cache(lp)

    ensure_parent_dir(REPL_CORE_INFO_CACHE)
    File.writefile(REPL_CORE_INFO_CACHE, cache.escaped_info)
    println(format("Generated: ", REPL_CORE_INFO_CACHE))

    ensure_parent_dir(REPL_CORE_DOCS_CACHE)
    File.writefile(REPL_CORE_DOCS_CACHE, cache.escaped_docs)
    println(format("Generated: ", REPL_CORE_DOCS_CACHE))
    return 0
}
