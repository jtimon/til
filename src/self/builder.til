mode lib

CollectionInfo := struct {
    ref mut type_name : Str = NULL
    mut is_vec : I32 = 0
}

DynCallInfo := struct {
    ref mut method : Str = NULL
    mut nargs : I32 = 1
    mut has_return := false
}

// --- Globals ---

ref mut codegen_core_program : Expr = NULL
ref mut codegen_program : Expr = NULL
ref mut current_fdef : Expr = NULL
mut struct_bodies := Map.new("Str", Str.size(), "Dynamic", I64.size())
mut func_defs := Map.new("Str", Str.size(), "Dynamic", I64.size())
mut script_globals := Set.new("Str", Str.size())
mut has_script_globals := false
mut ref_globals := Set.new("Str", Str.size())
mut has_ref_globals := false
mut in_func_def := false
mut in_main_func := false
mut funcsig_names := Set.new("Str", Str.size())
mut has_funcsig_names := false
mut _ctor_seq : I32 = 0
mut stack_locals := Set.new("Str", Str.size())
mut stack_local_types := Map.new("Str", Str.size(), "Str", Str.size())
mut unsafe_to_hoist := Set.new("Str", Str.size())
mut ref_locals := Set.new("Str", Str.size())

// --- Leaf functions ---

is_dyn_call_name := func(name: Str, mut has_ret: Bool) returns shallow Bool {
    if name.eq("dyn_call") { has_ret = false; return true }
    if name.eq("dyn_call_ret") { has_ret = true; return true }
    return false
}

fcall_fn_sig := func(fcall: Expr) returns ref Expr {
    if is_null(fcall) { return NULL }
    if is_variant(fcall.data, NodeType.FCall).not() { return NULL }
    ref fc : FCallData = get_payload(fcall.data)
    if is_null(fc.fn_sig).not() { return fc.fn_sig }
    return fcall.fn_sig
}

is_stack_local := func(name: Str) returns shallow Bool {
    return stack_locals.has(name)
}

is_value_global := func(name: Str) returns shallow Bool {
    if has_script_globals.not() { return false }
    return script_globals.has(name)
}

is_ref_global := func(name: Str) returns shallow Bool {
    if has_ref_globals.not() { return false }
    return ref_globals.has(name)
}

is_ref_local := func(name: Str) returns shallow Bool {
    if ref_locals.has(name) { return true }
    return is_ref_global(name)
}

use_dot_access := func(obj: Expr) returns shallow Bool {
    if is_variant(obj.data, NodeType.FieldAccess) {
        if obj.field_own_type.eq(OwnType.Shallow) { return true }
    }
    if is_variant(obj.data, NodeType.Ident) {
        ref ident : Str = get_payload(obj.data)
        if is_stack_local(ident) { return true }
        if is_value_global(ident) { return true }
    }
    return false
}

is_primitive_type := func(name: Str) returns shallow Bool {
    if name.eq("I64") { return true }
    if name.eq("U8") { return true }
    if name.eq("I16") { return true }
    if name.eq("I32") { return true }
    if name.eq("U32") { return true }
    if name.eq("U64") { return true }
    if name.eq("USize") { return true }
    if name.eq("F32") { return true }
    if name.eq("Bool") { return true }
    return false
}

is_funcsig_type := func(name: Str) returns shallow Bool {
    if has_funcsig_names.not() { return false }
    return funcsig_names.has(name)
}

is_ext_h_type := func(name: Str) returns shallow Bool {
    if name.eq("U8") { return true }
    if name.eq("I16") { return true }
    if name.eq("I32") { return true }
    if name.eq("F32") { return true }
    if name.eq("U32") { return true }
    if name.eq("U64") { return true }
    if name.eq("I64") { return true }
    if name.eq("Bool") { return true }
    return false
}

is_skip_ext_decl := func(name: Str) returns shallow Bool {
    if name.eq("exit") { return true }
    if name.eq("free") { return true }
    if name.eq("malloc") { return true }
    if name.eq("calloc") { return true }
    if name.eq("realloc") { return true }
    if name.eq("memcpy") { return true }
    if name.eq("memmove") { return true }
    if name.eq("memset") { return true }
    if name.eq("print_single") { return true }
    if name.eq("print_flush") { return true }
    return false
}

is_scalar_method_type := func(name: Str) returns shallow Bool {
    if name.eq("U8") { return true }
    if name.eq("I16") { return true }
    if name.eq("I32") { return true }
    if name.eq("F32") { return true }
    if name.eq("U32") { return true }
    if name.eq("U64") { return true }
    if name.eq("I64") { return true }
    if name.eq("Bool") { return true }
    return false
}

is_exported_top_level_global := func(stmt: Expr) returns shallow Bool {
    if is_variant(stmt.data, NodeType.Decl).not() { return false }
    ref rhs : Expr = stmt.child(0)
    if is_variant(rhs.data, NodeType.FuncDef) { return false }
    if is_variant(rhs.data, NodeType.StructDef) { return false }
    if is_variant(rhs.data, NodeType.EnumDef) { return false }
    if is_variant(stmt.til_type, TilType.None) {
        if is_variant(rhs.data, NodeType.Ident) { return false }
    }
    ref decl : Declaration = get_payload(stmt.data)
    if decl.name.len().gte(3) {
        if decl.name.substr(0, 3).eq("_t_") { return false }
    }
    return true
}

find_struct_body := func(name: Str) returns ref Expr {
    if struct_bodies.has(name).not() { return NULL }
    return read_ptr(struct_bodies.get(name))
}

find_callee_fdef := func(name: Str) returns ref Expr {
    if func_defs.has(name).not() { return NULL }
    return read_ptr(func_defs.get(name))
}

fa_struct_name := func(e: Expr) returns ref Str {
    if e.child_count().eq(0) { return e.struct_name }
    ref obj : Expr = e.child(0)
    if obj.struct_name.len().gt(0) { return obj.struct_name }
    if is_variant(obj.data, NodeType.Ident) {
        ref ident : Str = get_payload(obj.data)
        return ident
    }
    return obj.struct_name
}

builder_fa_is_ns := func(e: Expr) returns shallow Bool {
    ref sname : Str = fa_struct_name(e)
    ref fname : Str = get_payload(e.data)
    ref body : Expr = find_struct_body(sname)
    if is_null(body) { return false }
    mut has_ns := false
    mut has_inst := false
    for fi in 0..body.child_count() {
        ref f : Expr = body.child(fi)
        ref dd : Declaration = get_payload(f.data)
        if dd.name.eq(fname) {
            if dd.is_namespace { has_ns = true }
            else { has_inst = true }
        }
    }
    if has_ns.and(has_inst.not()) { return true }
    if has_ns.not() { return false }
    ref obj : Expr = e.child(0)
    if is_variant(obj.data, NodeType.Ident).not() { return false }
    ref ident : Str = get_payload(obj.data)
    if ident.eq(sname) { return true }
    if ident.len().gt(0) {
        if ident.get(0).gte('A').and(ident.get(0).lte('Z')) {
            return true
        }
    }
    return false
}

is_shallow_param := func(name: Str) returns shallow Bool {
    if is_null(current_fdef) { return false }
    ref fd : FunctionDef = get_payload(current_fdef.data)
    for pi in 0..fd.nparam {
        ref p : Param = fd.params.get(pi)
        if is_variant(p.own_type, OwnType.Shallow) {
            if p.name.eq(name) { return true }
        }
    }
    return false
}

callee_returns_shallow := func(callee_name: Str) returns shallow Bool {
    ref fdef : Expr = find_callee_fdef(callee_name)
    if is_null(fdef) { return false }
    ref fd : FunctionDef = get_payload(fdef.data)
    return is_variant(fd.return_own_type, OwnType.Shallow)
}

callee_returns_dynamic := func(callee_name: Str) returns shallow Bool {
    if callee_name.eq("malloc") { return true }
    if callee_name.eq("calloc") { return true }
    if callee_name.eq("realloc") { return true }
    if callee_name.eq("dyn_call_ret") { return true }
    if callee_name.eq("dyn_fn") { return true }
    ref fdef : Expr = find_callee_fdef(callee_name)
    if is_null(fdef) { return false }
    ref fd : FunctionDef = get_payload(fdef.data)
    return fd.return_type.eq("Dynamic")
}

callee_param_is_shallow := func(callee_name: Str, shallow arg_index: U32) returns shallow Bool {
    ref fdef : Expr = find_callee_fdef(callee_name)
    if is_null(fdef) { return false }
    ref fd : FunctionDef = get_payload(fdef.data)
    if arg_index.gte(fd.nparam) { return false }
    if fd.params.len().eq(0) { return false }
    ref p : Param = fd.params.get(arg_index)
    return is_variant(p.own_type, OwnType.Shallow)
}

callee_param_is_usize := func(callee_name: Str, shallow arg_index: U32) returns shallow Bool {
    ref fdef : Expr = find_callee_fdef(callee_name)
    if is_null(fdef) { return false }
    ref fd : FunctionDef = get_payload(fdef.data)
    if arg_index.gte(fd.nparam) { return false }
    ref p : Param = fd.params.get(arg_index)
    return p.ptype.eq("USize")
}

callee_param_is_own := func(callee_name: Str, shallow arg_index: U32) returns shallow Bool {
    ref fdef : Expr = find_callee_fdef(callee_name)
    if is_null(fdef) { return false }
    ref fd : FunctionDef = get_payload(fdef.data)
    if arg_index.gte(fd.nparam) { return false }
    ref p : Param = fd.params.get(arg_index)
    return is_variant(p.own_type, OwnType.Own)
}

fcall_is_shallow_return := func(fcall: Expr) returns shallow Bool {
    if is_variant(fcall.data, NodeType.FCall).not() { return false }
    ref callee : Expr = fcall.child(0)
    if is_variant(callee.data, NodeType.Ident) {
        ref ident : Str = get_payload(callee.data)
        return callee_returns_shallow(ident)
    } else if is_variant(callee.data, NodeType.FieldAccess) {
        ref sname : Str = callee.child(0).struct_name
        ref mname : Str = get_payload(callee.data)
        if sname.len().eq(0) { return false }
        flat := sname.concat("_").concat(mname)
        return callee_returns_shallow(flat)
    }
    return false
}

fcall_returns_dynamic := func(fcall: Expr) returns shallow Bool {
    if is_variant(fcall.data, NodeType.FCall).not() { return false }
    ref callee_node : Expr = fcall.child(0)
    if is_variant(callee_node.data, NodeType.FieldAccess) {
        ref sname : Str = callee_node.child(0).struct_name
        ref mname : Str = get_payload(callee_node.data)
        if sname.len().eq(0) { return false }
        flat := sname.concat("_").concat(mname)
        return callee_returns_dynamic(flat)
    } else if is_variant(callee_node.data, NodeType.Ident) {
        ref ident : Str = get_payload(callee_node.data)
        return callee_returns_dynamic(ident)
    }
    return false
}

til_type_to_c := func(shallow t: TilType) returns Str {
    switch t {
    case TilType.I64:     return "I64"
    case TilType.U8:      return "U8"
    case TilType.I16:     return "I16"
    case TilType.I32:     return "I32"
    case TilType.U32:     return "U32"
    case TilType.U64:     return "U64"
    case TilType.F32:     return "F32"
    case TilType.Bool:    return "Bool"
    case TilType.None:    return "void"
    case TilType.Dynamic: return "void *"
    case TilType.FuncPtr: return "void *"
    case:                 return "I64"
    }
}

c_type_name := func(shallow t: TilType, struct_name: Str) returns Str {
    if t.eq(TilType.Struct).or(t.eq(TilType.Enum)) {
        if is_null(struct_name).not() {
            if struct_name.len().gt(0) {
                return struct_name.clone()
            }
        }
    }
    if t.eq(TilType.Dynamic) { return "void" }
    return til_type_to_c(t)
}

func_to_c := func(name: Str) returns Str {
    if name.eq("double") { return "double_" }
    return name.clone()
}

type_name_to_c := func(name: Str) returns Str {
    if name.eq("I64") { return "I64 *" }
    if name.eq("U8") { return "U8 *" }
    if name.eq("I16") { return "I16 *" }
    if name.eq("I32") { return "I32 *" }
    if name.eq("U32") { return "U32 *" }
    if name.eq("U64") { return "U64 *" }
    if name.eq("USize") { return "USize *" }
    if name.eq("F32") { return "F32 *" }
    if name.eq("Bool") { return "Bool *" }
    if name.eq("Dynamic") { return "void *" }
    if name.eq("Fn") { return "void *" }
    if has_funcsig_names {
        if funcsig_names.has(name) { return "void *" }
    }
    return name.concat(" *")
}

type_name_to_c_value := func(name: Str) returns Str {
    if name.eq("I64") { return "I64" }
    if name.eq("U8") { return "U8" }
    if name.eq("I16") { return "I16" }
    if name.eq("I32") { return "I32" }
    if name.eq("U32") { return "U32" }
    if name.eq("U64") { return "U64" }
    if name.eq("USize") { return "USize" }
    if name.eq("F32") { return "F32" }
    if name.eq("Bool") { return "Bool" }
    if name.eq("Dynamic") { return "void *" }
    if name.eq("Fn") { return "void *" }
    if has_funcsig_names {
        if funcsig_names.has(name) { return "void *" }
    }
    return name.clone()
}

emit_u64 := proc(f: File, shallow v: U64) {
    f.write_str(v.to_i64().to_str())
}

emit_i32 := proc(f: File, shallow v: I32) {
    f.write_str(v.to_i64().to_str())
}

emit_indent := proc(f: File, shallow depth: I32) {
    for _i : I32 in 0..depth {
        f.write_str("    ")
    }
}

emit_til_default := proc(f: File, shallow t: TilType, struct_name: Str) {
    if t.eq(TilType.I64).or(t.eq(TilType.I16)).or(t.eq(TilType.I32))
        .or(t.eq(TilType.U32)).or(t.eq(TilType.U64)).or(t.eq(TilType.F32))
        .or(t.eq(TilType.U8)) {
        f.write_str("0")
    } else if t.eq(TilType.Bool) {
        f.write_str("false")
    } else if t.eq(TilType.Struct).or(t.eq(TilType.Enum)) {
        if is_null(struct_name).not() {
            if struct_name.eq("Str") {
                f.write_str("\"\"")
            } else {
                f.write_str(struct_name)
                f.write_str("()")
            }
        } else {
            f.write_str("0")
        }
    } else {
        f.write_str("0")
    }
}

callee_return_ctype := ext_func(callee_name: Str) returns Str {}

emit_param_list := proc(f: File, fdef: Expr, shallow with_names: Bool) {
    ref fd : FunctionDef = get_payload(fdef.data)
    if fd.nparam.eq(0) {
        f.write_str("void")
    } else {
        for i in 0..fd.nparam {
            if i.gt(0) { f.write_str(", ") }
            mut ptype := ""
            ii := i.to_i64().to_i32()
            if ii.eq(fd.variadic_index) {
                ptype = "Array *"
            } else if ii.eq(fd.kwargs_index) {
                ref p : Param = fd.params.get(i)
                ptype = type_name_to_c(p.ptype)
            } else {
                ref p : Param = fd.params.get(i)
                if is_variant(p.own_type, OwnType.Shallow) {
                    ptype = type_name_to_c_value(p.ptype)
                } else {
                    ptype = type_name_to_c(p.ptype)
                }
            }
            if with_names {
                ref p : Param = fd.params.get(i)
                f.write_str(ptype)
                f.write_str(" ")
                f.write_str(p.name)
            } else {
                f.write_str(ptype)
            }
        }
    }
}

collect_dyn_methods := proc(e: Expr, mut methods: Vec) {
    if is_null(e) { return }
    if is_variant(e.data, NodeType.FCall) {
        if e.child_count().gt(0) {
            if is_variant(e.child(0).data, NodeType.Ident) {
                if e.child_count().gte(3) {
                    if is_variant(e.child(2).data, NodeType.LiteralStr) {
                        ref callee_name : Str = get_payload(e.child(0).data)
                        mut has_ret := false
                        if is_dyn_call_name(callee_name, has_ret) {
                            ref method : Str = get_payload(e.child(2).data)
                            mut nargs := 1.to_i32()
                            if e.child_count().gte(4) {
                                if is_variant(e.child(3).data, NodeType.LiteralNum) {
                                    ref num_str : Str = get_payload(e.child(3).data)
                                    nargs = num_str.to_i64().to_i32()
                                }
                            }
                            mut found := false
                            for mi in 0..methods.len() {
                                ref existing : DynCallInfo = methods.get(mi)
                                if existing.method.eq(method) { found = true }
                            }
                            if found.not() {
                                info := DynCallInfo(method = method, nargs = nargs, has_return = has_ret)
                                methods.push(own info)
                            }
                        }
                    }
                }
            }
        }
    }
    for ci in 0..e.child_count() {
        collect_dyn_methods(e.child(ci), methods)
    }
}

collect_collection_builtins := proc(e: Expr, mut infos: Vec) {
    if is_null(e) { return }
    if is_variant(e.data, NodeType.FCall) {
        if e.child_count().gt(0) {
            if is_variant(e.child(0).data, NodeType.Ident) {
                if e.child_count().gte(2) {
                    if is_variant(e.child(1).data, NodeType.LiteralStr) {
                        ref name : Str = get_payload(e.child(0).data)
                        mut is_vec := -1.to_i32()
                        if name.eq("array") { is_vec = 0.to_i32() }
                        else if name.eq("vec") { is_vec = 1.to_i32() }
                        if is_vec.gte(0.to_i32()) {
                            ref type_name : Str = get_payload(e.child(1).data)
                            mut found := false
                            for ci_i in 0..infos.len() {
                                ref existing : CollectionInfo = infos.get(ci_i)
                                if existing.type_name.eq(type_name) {
                                    if existing.is_vec.eq(is_vec) { found = true }
                                }
                            }
                            if found.not() {
                                info := CollectionInfo(type_name = type_name, is_vec = is_vec)
                                infos.push(own info)
                            }
                        }
                    }
                }
            }
        }
    }
    for ci in 0..e.child_count() {
        collect_collection_builtins(e.child(ci), infos)
    }
}

emit_field := proc(f: File, var: Str, field: Str) {
    f.write_str(var)
    if is_stack_local(var).or(is_value_global(var)) {
        f.write_str(".")
    } else {
        f.write_str("->")
    }
    f.write_str(field)
}

get_stack_local_ctype := func(name: Str) returns ref Str {
    if stack_local_types.has(name) {
        ref p : Str = stack_local_types.get(name)
        return p
    }
    return NULL
}

resolve_callee_name := ext_func(fcall: Expr) returns Str {}

resolve_callee_name := func(fcall: Expr) returns Str {
    ref callee_node : Expr = fcall.child(0)
    if is_variant(callee_node.data, NodeType.FieldAccess) {
        ref sname : Str = callee_node.child(0).struct_name
        ref mname : Str = get_payload(callee_node.data)
        if sname.len().eq(0) { return "" }
        return sname.concat("_").concat(mname)
    } else if is_variant(callee_node.data, NodeType.Ident) {
        ref ident : Str = get_payload(callee_node.data)
        return ident.clone()
    }
    return ""
}

callee_return_ctype := func(callee_name: Str) returns Str {
    ref fdef : Expr = find_callee_fdef(callee_name)
    if is_null(fdef) { return "" }
    ref fd : FunctionDef = get_payload(fdef.data)
    if fd.return_type.len().eq(0) { return "" }
    return type_name_to_c_value(fd.return_type)
}

fcall_return_ctype := func(fcall: Expr) returns Str {
    if is_variant(fcall.data, NodeType.FCall).not() { return "" }
    callee := resolve_callee_name(fcall)
    if callee.len().eq(0) { return "" }
    return callee_return_ctype(callee)
}

check_fcall_mut_args := proc(e: Expr) {
    if is_null(e) { return }
    if is_variant(e.data, NodeType.FCall) {
        ref mut fdef : Expr = fcall_fn_sig(e)
        if is_null(fdef) {
            callee := resolve_callee_name(e)
            if callee.len().gt(0) {
                fdef = find_callee_fdef(callee)
            }
        }
        if is_null(fdef).not() {
            ref fd : FunctionDef = get_payload(fdef.data)
            if fd.params.len().gt(0) {
                for a in 1..e.child_count() {
                    pi := a.sub(1)
                    if pi.lt(fd.nparam) {
                        ref p : Param = fd.params.get(pi)
                        if p.is_mut {
                            ref arg : Expr = e.child(a)
                            if is_variant(arg.data, NodeType.Ident) {
                                ref arg_name : Str = get_payload(arg.data)
                                unsafe_to_hoist.add(own arg_name.clone())
                            }
                        }
                    }
                }
            }
        }
    }
    for ci in 0..e.child_count() {
        check_fcall_mut_args(e.child(ci))
    }
}

collect_unsafe_to_hoist := proc(body: Expr) {
    for si in 0..body.child_count() {
        ref stmt : Expr = body.child(si)
        check_fcall_mut_args(stmt)
        if is_variant(stmt.data, NodeType.Decl) {
            ref dd : Declaration = get_payload(stmt.data)
            if is_variant(dd.own_type, OwnType.Ref) {
                ref rhs : Expr = stmt.child(0)
                if is_variant(rhs.data, NodeType.Ident) {
                    ref rhs_name : Str = get_payload(rhs.data)
                    unsafe_to_hoist.add(own rhs_name.clone())
                }
                if is_variant(rhs.data, NodeType.FCall) {
                    callee := resolve_callee_name(rhs)
                    if callee.len().gt(0) {
                        ref fdef : Expr = find_callee_fdef(callee)
                        if is_null(fdef).not() {
                            ref fd : FunctionDef = get_payload(fdef.data)
                            if is_variant(fd.return_own_type, OwnType.Ref) {
                                for a in 1..rhs.child_count() {
                                    ref arg : Expr = rhs.child(a)
                                    if is_variant(arg.data, NodeType.Ident) {
                                        ref arg_name : Str = get_payload(arg.data)
                                        unsafe_to_hoist.add(own arg_name.clone())
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
        if is_variant(stmt.data, NodeType.If) {
            for c in 1..stmt.child_count() {
                collect_unsafe_to_hoist(stmt.child(c))
            }
        }
        if is_variant(stmt.data, NodeType.While) {
            if stmt.child_count().gt(1) {
                collect_unsafe_to_hoist(stmt.child(1))
            }
        }
        if is_variant(stmt.data, NodeType.Body) {
            collect_unsafe_to_hoist(stmt)
        }
    }
}

collect_dyn_has_methods := proc(e: Expr, mut methods: Vec) {
    if is_null(e) { return }
    if is_variant(e.data, NodeType.FCall) {
        if e.child_count().gt(0) {
            if is_variant(e.child(0).data, NodeType.Ident) {
                ref cname : Str = get_payload(e.child(0).data)
                if cname.eq("dyn_has_method") {
                    if e.child_count().gte(3) {
                        if is_variant(e.child(2).data, NodeType.LiteralStr) {
                            ref method : Str = get_payload(e.child(2).data)
                            mut found := false
                            for mi in 0..methods.len() {
                                ref existing : Str = methods.get(mi)
                                if existing.eq(method) { found = true }
                            }
                            if found.not() {
                                methods.push(own method.clone())
                            }
                        }
                    }
                }
            }
        }
    }
    for ci in 0..e.child_count() {
        collect_dyn_has_methods(e.child(ci), methods)
    }
}

// Emit layer
emit_stmt_decl := proc(f: File, e: Expr, shallow depth: I32) {
    ref dd : Declaration = get_payload(e.data)
    if e.child_count().eq(0) { return }
    ref rhs : Expr = e.child(0)
    if e.til_type.eq(TilType.FuncPtr).and(dd.own_type.eq(OwnType.Ref).not()).and(is_variant(rhs.data, NodeType.FuncDef).not()) {
        f.write_str("void *"); f.write_str(dd.name); f.write_str(" = ")
        emit_expr(f, rhs, depth); f.write_str(";\n")
        emit_indent(f, depth); f.write_str("(void)"); f.write_str(dd.name); f.write_str(";\n")
    } else if is_variant(rhs.data, NodeType.FuncDef) {
        f.write_str("/* TODO: nested func "); f.write_str(dd.name); f.write_str(" */\n")
    } else if is_variant(rhs.data, NodeType.StructDef).or(is_variant(rhs.data, NodeType.EnumDef)) {
        f.write_str("/* ")
        if is_variant(rhs.data, NodeType.EnumDef) { f.write_str("enum") } else { f.write_str("struct") }
        f.write_str(" "); f.write_str(dd.name); f.write_str(" defined above */\n")
    } else if e.til_type.eq(TilType.None).and(is_variant(rhs.data, NodeType.Ident)) {
        // Type alias -- no-op
    } else {
        if dd.own_type.eq(OwnType.Ref) {
            is_rg := is_ref_global(dd.name).and(in_func_def.not())
            if is_rg.not() { ref_locals.add(own dd.name.clone()) }
            mut _sn := e.struct_name
            if _sn.len().eq(0) { _sn = rhs.struct_name }
            if _sn.len().eq(0) { _sn = dd.explicit_type }
            ctype := c_type_name(e.til_type, _sn)
            if is_rg { f.write_str(dd.name); f.write_str(" = ") }
            else { f.write_str(ctype); f.write_str(" *"); f.write_str(dd.name); f.write_str(" = ") }
            emit_as_ptr(f, rhs, depth); f.write_str(";\n")
        } else {
            mut _sn := e.struct_name
            if _sn.len().eq(0) { _sn = rhs.struct_name }
            if _sn.len().eq(0) { _sn = dd.explicit_type }
            ctype := c_type_name(e.til_type, _sn)
            is_global := is_value_global(dd.name).and(in_func_def.not())
            if e.til_type.eq(TilType.Dynamic) {
                if is_global { f.write_str(dd.name); f.write_str(" = ") }
                else { tc := til_type_to_c(e.til_type); f.write_str(tc); f.write_str(" "); f.write_str(dd.name); f.write_str(" = ") }
                emit_deref(f, rhs, depth); f.write_str(";\n")
            } else {
                can_hoist := is_global.not().and(dd.own_type.eq(OwnType.Own).not())
                    .and(e.til_type.eq(TilType.FuncPtr).not()).and(e.til_type.eq(TilType.Dynamic).not())
                    .and(is_variant(rhs.data, NodeType.FCall).and(fcall_returns_dynamic(rhs)).not())
                // Struct constructor
                mut is_ctor := is_variant(rhs.data, NodeType.FCall).and(rhs.struct_name.len().gt(0))
                if is_ctor {
                    if rhs.child_count().gt(0).and(is_variant(rhs.child(0).data, NodeType.Ident)) {
                        ref ci : Str = get_payload(rhs.child(0).data)
                        is_ctor = ci.eq(rhs.struct_name)
                    } else { is_ctor = false }
                }
                if is_ctor {
                    if is_global {
                        f.write_str("memset(&"); f.write_str(dd.name); f.write_str(", 0, sizeof("); f.write_str(ctype); f.write_str("));\n")
                    } else if can_hoist {
                        f.write_str(ctype); f.write_str(" "); f.write_str(dd.name); f.write_str("; memset(&"); f.write_str(dd.name); f.write_str(", 0, sizeof("); f.write_str(ctype); f.write_str("));\n")
                        stack_locals.add(own dd.name.clone())
                        stack_local_types.set(own dd.name.clone(), own ctype.clone())
                    } else {
                        f.write_str(ctype); f.write_str(" *"); f.write_str(dd.name); f.write_str(" = malloc(sizeof("); f.write_str(ctype); f.write_str("));\n")
                    }
                    emit_ctor_fields(f, dd.name, rhs, depth)
                } else if is_variant(rhs.data, NodeType.FCall).or(is_variant(rhs.data, NodeType.LiteralStr))
                    .or(is_variant(rhs.data, NodeType.FieldAccess).and(builder_fa_is_ns(rhs)).and(rhs.til_type.eq(TilType.Enum))) {
                    if is_global {
                        if is_variant(rhs.data, NodeType.FCall).and(fcall_is_shallow_return(rhs)) {
                            f.write_str(dd.name); f.write_str(" = "); emit_expr(f, rhs, depth); f.write_str(";\n")
                        } else if is_variant(rhs.data, NodeType.FCall) {
                            mut htype := fcall_return_ctype(rhs)
                            if htype.len().eq(0) { htype = ctype.clone() }
                            f.write_str("{ "); f.write_str(htype); f.write_str(" *_hp = ("); f.write_str(htype); f.write_str(" *)")
                            emit_expr(f, rhs, depth)
                            f.write_str("; "); f.write_str(dd.name); f.write_str(" = *_hp; free(_hp); }\n")
                        } else {
                            f.write_str(dd.name); f.write_str(" = "); emit_deref(f, rhs, depth); f.write_str(";\n")
                        }
                    } else if is_variant(rhs.data, NodeType.FCall).and(fcall_is_shallow_return(rhs)) {
                        if can_hoist {
                            mut htype := fcall_return_ctype(rhs)
                            if htype.len().eq(0) { htype = ctype.clone() }
                            f.write_str(htype); f.write_str(" "); f.write_str(dd.name); f.write_str(" = ")
                            emit_expr(f, rhs, depth); f.write_str(";\n")
                            stack_locals.add(own dd.name.clone())
                            stack_local_types.set(own dd.name.clone(), own htype.clone())
                        } else {
                            f.write_str(ctype); f.write_str(" *"); f.write_str(dd.name); f.write_str(" = malloc(sizeof("); f.write_str(ctype); f.write_str(")); *"); f.write_str(dd.name); f.write_str(" = ")
                            emit_expr(f, rhs, depth); f.write_str(";\n")
                        }
                    } else if can_hoist.and(is_variant(rhs.data, NodeType.FCall)) {
                        mut htype := fcall_return_ctype(rhs)
                        if htype.len().eq(0) { htype = ctype.clone() }
                        f.write_str(htype); f.write_str(" "); f.write_str(dd.name); f.write_str("; { "); f.write_str(htype); f.write_str(" *_hp = ("); f.write_str(htype); f.write_str(" *)")
                        emit_expr(f, rhs, depth)
                        f.write_str("; "); f.write_str(dd.name); f.write_str(" = *_hp; free(_hp); }\n")
                        stack_locals.add(own dd.name.clone())
                        stack_local_types.set(own dd.name.clone(), own htype.clone())
                    } else if can_hoist {
                        f.write_str(ctype); f.write_str(" "); f.write_str(dd.name); f.write_str("; { "); f.write_str(ctype); f.write_str(" *_hp = ("); f.write_str(ctype); f.write_str(" *)")
                        emit_expr(f, rhs, depth)
                        f.write_str("; "); f.write_str(dd.name); f.write_str(" = *_hp; free(_hp); }\n")
                        stack_locals.add(own dd.name.clone())
                        stack_local_types.set(own dd.name.clone(), own ctype.clone())
                    } else {
                        if is_global { f.write_str(dd.name); f.write_str(" = ") }
                        else { f.write_str(ctype); f.write_str(" *"); f.write_str(dd.name); f.write_str(" = ") }
                        emit_expr(f, rhs, depth); f.write_str(";\n")
                    }
                } else {
                    if is_global {
                        f.write_str(dd.name); f.write_str(" = "); emit_deref(f, rhs, depth); f.write_str(";\n")
                    } else if can_hoist {
                        f.write_str(ctype); f.write_str(" "); f.write_str(dd.name); f.write_str(" = ")
                        emit_deref(f, rhs, depth); f.write_str(";\n")
                        stack_locals.add(own dd.name.clone())
                        stack_local_types.set(own dd.name.clone(), own ctype.clone())
                    } else {
                        f.write_str(ctype); f.write_str(" *"); f.write_str(dd.name); f.write_str(" = malloc(sizeof("); f.write_str(ctype); f.write_str("));\n")
                        emit_indent(f, depth)
                        f.write_str("*"); f.write_str(dd.name); f.write_str(" = "); emit_deref(f, rhs, depth); f.write_str(";\n")
                    }
                }
            }
        }
        emit_indent(f, depth); f.write_str("(void)"); f.write_str(dd.name); f.write_str(";\n")
    }
}
emit_return_ctype := func(rv: Expr) returns Str {
    if is_null(current_fdef).not() {
        ref fd : FunctionDef = get_payload(current_fdef.data)
        if fd.return_type.len().gt(0) { return type_name_to_c_value(fd.return_type) }
    }
    return c_type_name(rv.til_type, rv.struct_name)
}

emit_return_box := proc(f: File, rv: Expr, shallow depth: I32) {
    ctype := emit_return_ctype(rv)
    f.write_str("{ "); f.write_str(ctype); f.write_str(" *_r = malloc(sizeof("); f.write_str(ctype); f.write_str(")); *_r = ")
    emit_expr(f, rv, depth)
    f.write_str("; return _r; }\n")
}

emit_stmt_return := proc(f: File, e: Expr, shallow depth: I32) {
    if e.child_count().eq(0) {
        if in_main_func { f.write_str("return 0;\n") }
        else { f.write_str("return;\n") }
    } else {
        ref rv : Expr = e.child(0)
        // Struct constructor return
        if is_variant(rv.data, NodeType.FCall).and(rv.struct_name.len().gt(0)).and(rv.child_count().gt(0)) {
            if is_variant(rv.child(0).data, NodeType.Ident) {
                ref ci : Str = get_payload(rv.child(0).data)
                if ci.eq(rv.struct_name) {
                    ctype := c_type_name(rv.til_type, rv.struct_name)
                    f.write_str("{ "); f.write_str(ctype); f.write_str(" *_r = malloc(sizeof("); f.write_str(ctype); f.write_str("));\n")
                    emit_ctor_fields(f, "_r", rv, depth)
                    emit_indent(f, depth); f.write_str("return _r; }\n")
                    return
                }
            }
        }
        // Ref return
        if is_null(current_fdef).not() {
            ref fd : FunctionDef = get_payload(current_fdef.data)
            if is_variant(fd.return_own_type, OwnType.Ref) {
                f.write_str("return "); emit_as_ptr(f, rv, depth); f.write_str(";\n"); return
            }
            if is_variant(fd.return_own_type, OwnType.Shallow) {
                f.write_str("return ")
                if is_variant(rv.data, NodeType.FCall).and(fcall_is_shallow_return(rv)) { emit_expr(f, rv, depth) }
                else { emit_deref(f, rv, depth) }
                f.write_str(";\n"); return
            }
        }
        // Inline field value: box for return
        if is_variant(rv.data, NodeType.FieldAccess).and(rv.field_own_type.eq(OwnType.Shallow))
            .and(builder_fa_is_ns(rv).not()).and(rv.til_type.eq(TilType.Dynamic).not()) {
            emit_return_box(f, rv, depth)
        // Shallow fcall: box for return
        } else if is_variant(rv.data, NodeType.FCall).and(fcall_is_shallow_return(rv)) {
            emit_return_box(f, rv, depth)
        // Hoisted local: box for return
        } else if is_variant(rv.data, NodeType.Ident) {
            ref rv_name : Str = get_payload(rv.data)
            mut is_shallow_ret := false
            if is_null(current_fdef).not() {
                ref fd : FunctionDef = get_payload(current_fdef.data)
                is_shallow_ret = is_variant(fd.return_own_type, OwnType.Shallow)
            }
            if is_stack_local(rv_name).or(is_value_global(rv_name)) {
                if is_shallow_ret.not() {
                    ctype := emit_return_ctype(rv)
                    f.write_str("{ "); f.write_str(ctype); f.write_str(" *_r = malloc(sizeof("); f.write_str(ctype); f.write_str(")); *_r = "); f.write_str(rv_name); f.write_str("; return _r; }\n")
                } else {
                    f.write_str("return "); emit_expr(f, rv, depth); f.write_str(";\n")
                }
            } else {
                f.write_str("return "); emit_expr(f, rv, depth); f.write_str(";\n")
            }
        // Bare enum variant ref: heap-allocate
        } else if is_variant(rv.data, NodeType.FieldAccess).and(builder_fa_is_ns(rv)).and(rv.til_type.eq(TilType.Enum)) {
            ref sn : Str = rv.child(0).struct_name
            ref vname : Str = get_payload(rv.data)
            f.write_str("{ "); f.write_str(sn); f.write_str(" *_r = malloc(sizeof("); f.write_str(sn); f.write_str(")); _r->tag = "); f.write_str(sn); f.write_str("_TAG_"); f.write_str(vname); f.write_str("; return _r; }\n")
        } else {
            f.write_str("return "); emit_expr(f, rv, depth); f.write_str(";\n")
        }
    }
}

emit_stmt := proc(f: File, e: Expr, shallow depth: I32) {
    emit_indent(f, depth)
    if is_variant(e.data, NodeType.Decl) {
        emit_stmt_decl(f, e, depth)
    } else if is_variant(e.data, NodeType.Assign) {
        ref aname : Str = get_payload(e.data)
        ref rhs : Expr = e.child(0)
        if is_ref_local(aname) {
            mut do_rebind := false
            if is_variant(rhs.data, NodeType.FieldAccess) {
                do_rebind = true
            } else if is_variant(rhs.data, NodeType.Ident) {
                ref rhs_ident : Str = get_payload(rhs.data)
                if is_stack_local(rhs_ident).not() { do_rebind = true }
            }
            if do_rebind {
                f.write_str(aname); f.write_str(" = ")
                emit_as_ptr(f, rhs, depth)
                f.write_str(";\n"); return
            }
        }
        if e.save_old_delete {
            ctype := c_type_name(e.til_type, e.struct_name)
            if is_stack_local(aname).or(is_value_global(aname)) {
                f.write_str("{ "); f.write_str(ctype); f.write_str(" *_new = ("); f.write_str(ctype); f.write_str(" *)")
                emit_expr(f, rhs, depth)
                f.write_str("; "); f.write_str(ctype); f.write_str("_delete(&"); f.write_str(aname); f.write_str(", &(Bool){0}); "); f.write_str(aname); f.write_str(" = *_new; free(_new); }\n")
            } else {
                f.write_str("{ "); f.write_str(ctype); f.write_str(" *_old = "); f.write_str(aname); f.write_str("; "); f.write_str(aname); f.write_str(" = ")
                emit_expr(f, rhs, depth)
                f.write_str("; "); f.write_str(ctype); f.write_str("_delete(_old, &(Bool){1}); }\n")
            }
            return
        }
        is_hoisted := is_stack_local(aname).or(is_value_global(aname))
        if e.til_type.eq(TilType.Dynamic) {
            f.write_str(aname); f.write_str(" = "); emit_deref(f, rhs, depth); f.write_str(";\n"); return
        }
        if is_hoisted {
            if is_variant(rhs.data, NodeType.FCall).and(fcall_is_shallow_return(rhs)) {
                f.write_str(aname); f.write_str(" = "); emit_expr(f, rhs, depth); f.write_str(";\n")
            } else if is_variant(rhs.data, NodeType.FCall) {
                ctype := c_type_name(e.til_type, e.struct_name)
                f.write_str("{ "); f.write_str(ctype); f.write_str(" *_hp = ("); f.write_str(ctype); f.write_str(" *)")
                emit_expr(f, rhs, depth)
                f.write_str("; "); f.write_str(aname); f.write_str(" = *_hp; free(_hp); }\n")
            } else {
                f.write_str(aname); f.write_str(" = "); emit_deref(f, rhs, depth); f.write_str(";\n")
            }
        } else {
            if is_variant(rhs.data, NodeType.FCall).or(is_variant(rhs.data, NodeType.LiteralStr))
                .or(is_variant(rhs.data, NodeType.FieldAccess).and(builder_fa_is_ns(rhs)).and(rhs.til_type.eq(TilType.Enum))) {
                if is_variant(rhs.data, NodeType.FCall).and(fcall_is_shallow_return(rhs)) {
                    f.write_str("*"); f.write_str(aname); f.write_str(" = ")
                } else {
                    f.write_str(aname); f.write_str(" = ")
                }
                emit_expr(f, rhs, depth)
            } else if e.til_type.eq(TilType.FuncPtr) {
                f.write_str(aname); f.write_str(" = "); emit_expr(f, rhs, depth)
            } else {
                f.write_str("*"); f.write_str(aname); f.write_str(" = "); emit_deref(f, rhs, depth)
            }
            f.write_str(";\n")
        }
    } else if is_variant(e.data, NodeType.FieldAssign) {
        ref obj : Expr = e.child(0)
        ref fname : Str = get_payload(e.data)
        ref rhs_fa : Expr = e.child(1)
        if is_variant(rhs_fa.data, NodeType.FCall).and(e.field_own_type.eq(OwnType.Shallow)).and(builder_fa_is_ns(e).not()) {
            if fcall_is_shallow_return(rhs_fa) {
                emit_expr(f, obj, depth)
                if use_dot_access(obj) { f.write_str(".") } else { f.write_str("->") }
                f.write_str(fname); f.write_str(" = "); emit_expr(f, rhs_fa, depth); f.write_str(";\n")
            } else {
                ftype := c_type_name(rhs_fa.til_type, rhs_fa.struct_name)
                f.write_str("{ "); f.write_str(ftype); f.write_str(" *_fa = "); emit_expr(f, rhs_fa, depth); f.write_str("; ")
                emit_expr(f, obj, depth)
                if use_dot_access(obj) { f.write_str(".") } else { f.write_str("->") }
                f.write_str(fname); f.write_str(" = *_fa; free(_fa); }\n")
            }
        } else {
            if builder_fa_is_ns(e) {
                f.write_str(obj.struct_name); f.write_str("_"); f.write_str(fname); f.write_str(" = ")
            } else {
                emit_expr(f, obj, depth)
                if use_dot_access(obj) { f.write_str(".") } else { f.write_str("->") }
                f.write_str(fname); f.write_str(" = ")
            }
            if e.field_own_type.eq(OwnType.Shallow).not() {
                mut own_rhs := rhs_fa
                own_rhs.is_own_arg = true
                emit_as_ptr(f, own_rhs, depth)
            } else {
                emit_deref(f, rhs_fa, depth)
            }
            f.write_str(";\n")
        }
    } else if is_variant(e.data, NodeType.FCall) {
        if e.child_count().gt(0).and(is_variant(e.child(0).data, NodeType.FieldAccess)) {
            ref del_name : Str = get_payload(e.child(0).data)
            if del_name.eq("delete").and(e.child_count().gte(2)) {
                if is_variant(e.child(1).data, NodeType.Ident) {
                    ref del_arg : Str = get_payload(e.child(1).data)
                    if is_stack_local(del_arg).and(e.child(1).til_type.eq(TilType.Struct).not()).and(e.child(1).til_type.eq(TilType.Enum).not()) {
                        f.write_str(";\n"); return
                    }
                }
            }
        }
        if e.struct_name.len().gt(0).and(e.child_count().gt(0)) {
            if is_variant(e.child(0).data, NodeType.Ident) {
                ref cname : Str = get_payload(e.child(0).data)
                if cname.eq(e.struct_name) { f.write_str("/* discarded struct constructor */;\n"); return }
            }
        }
        emit_expr(f, e, depth); f.write_str(";\n")
    } else if is_variant(e.data, NodeType.Return) {
        emit_stmt_return(f, e, depth)
    } else if is_variant(e.data, NodeType.Body) {
        f.write_str("{\n"); emit_body_scoped(f, e, depth.add(1.to_i32())); emit_indent(f, depth); f.write_str("}\n")
    } else if is_variant(e.data, NodeType.If) {
        f.write_str("if ("); emit_deref(f, e.child(0), depth); f.write_str(") {\n")
        emit_body_scoped(f, e.child(1), depth.add(1.to_i32())); emit_indent(f, depth)
        if e.child_count().gt(2) { f.write_str("} else {\n"); emit_body_scoped(f, e.child(2), depth.add(1.to_i32())); emit_indent(f, depth) }
        f.write_str("}\n")
    } else if is_variant(e.data, NodeType.While) {
        f.write_str("while ("); emit_deref(f, e.child(0), depth); f.write_str(") {\n")
        emit_body_scoped(f, e.child(1), depth.add(1.to_i32())); emit_indent(f, depth); f.write_str("}\n")
    } else if is_variant(e.data, NodeType.Break) { f.write_str("break;\n")
    } else if is_variant(e.data, NodeType.Continue) { f.write_str("continue;\n")
    } else { f.write_str("/* TODO: unknown stmt type */\n") }
}

emit_fcall_funcptr_cast := proc(f: File, e: Expr, sig: Expr, shallow depth: I32) {
    ref sfd : FunctionDef = get_payload(sig.data)
    ret_shallow := is_variant(sfd.return_own_type, OwnType.Shallow)
    mut ret_c := "void *"
    if e.til_type.eq(TilType.None).not().and(e.til_type.eq(TilType.Unknown).not())
        .and(e.til_type.eq(TilType.Dynamic).not()) {
        ret_c = til_type_to_c(e.til_type)
        if e.til_type.eq(TilType.Struct).or(e.til_type.eq(TilType.Enum)) {
            if e.struct_name.len().gt(0) { ret_c = e.struct_name.clone() }
        }
        if ret_shallow.not() { ret_c = ret_c.concat(" *") }
    }
    f.write_str("((")
    f.write_str(ret_c)
    f.write_str(" (*)(")
    for i in 1..e.child_count() {
        if i.gt(1) { f.write_str(", ") }
        ref arg : Expr = e.child(i)
        mut arg_shallow := false
        if i.sub(1).lt(sfd.nparam) {
            ref p : Param = sfd.params.get(i.sub(1))
            arg_shallow = is_variant(p.own_type, OwnType.Shallow)
        }
        mut arg_c := "void *"
        if arg.til_type.eq(TilType.Unknown).not().and(arg.til_type.eq(TilType.Dynamic).not()) {
            arg_c = til_type_to_c(arg.til_type)
            if arg.til_type.eq(TilType.Struct).or(arg.til_type.eq(TilType.Enum)) {
                if arg.struct_name.len().gt(0) { arg_c = arg.struct_name.clone() }
            }
            if arg_shallow.not() { arg_c = arg_c.concat(" *") }
        }
        f.write_str(arg_c)
    }
    if e.child_count().eq(1) { f.write_str("void") }
}

emit_fcall_funcptr_args := proc(f: File, e: Expr, sig: Expr, shallow depth: I32) {
    ref sfd : FunctionDef = get_payload(sig.data)
    for i in 1..e.child_count() {
        if i.gt(1) { f.write_str(", ") }
        mut arg_shallow := false
        if i.sub(1).lt(sfd.nparam) {
            ref p : Param = sfd.params.get(i.sub(1))
            arg_shallow = is_variant(p.own_type, OwnType.Shallow)
        }
        if arg_shallow { emit_deref(f, e.child(i), depth) }
        else { emit_as_ptr(f, e.child(i), depth) }
    }
}

emit_expr := proc(f: File, e: Expr, shallow depth: I32) {
    if is_variant(e.data, NodeType.LiteralStr) {
        ref s : Str = get_payload(e.data)
        f.write_str("Str_lit(\"")
        f.write_str(s)
        f.write_str("\", ")
        emit_u64(f, s.len().to_i64().to_u64())
        f.write_str("ULL)")
    } else if is_variant(e.data, NodeType.LiteralNum) {
        ref num : Str = get_payload(e.data)
        f.write_str(num)
    } else if is_variant(e.data, NodeType.LiteralBool) {
        ref b : Bool = get_payload(e.data)
        if b { emit_i32(f, 1.to_i32()) } else { emit_i32(f, 0.to_i32()) }
    } else if is_variant(e.data, NodeType.LiteralNull) {
        f.write_str("NULL")
    } else if is_variant(e.data, NodeType.Ident) {
        ref ident : Str = get_payload(e.data)
        if e.til_type.eq(TilType.FuncPtr) {
            f.write_str("(void *)")
            fc := func_to_c(ident)
            f.write_str(fc)
        } else {
            f.write_str(ident)
        }
    } else if is_variant(e.data, NodeType.FCall) {
        ref callee : Expr = e.child(0)
        // Indirect call through FuncSig-typed struct field
        if is_variant(callee.data, NodeType.FieldAccess) {
            if callee.til_type.eq(TilType.FuncPtr) {
                ref sig : Expr = fcall_fn_sig(e)
                if is_null(sig).not() {
                    emit_fcall_funcptr_cast(f, e, sig, depth)
                    f.write_str("))(")
                    emit_expr(f, callee, depth)
                    f.write_str("))(")
                    emit_fcall_funcptr_args(f, e, sig, depth)
                    f.write_str(")")
                    return
                }
            }
            // Namespace method call
            ref sname : Str = callee.child(0).struct_name
            ref mname : Str = get_payload(callee.data)
            flat := sname.concat("_").concat(mname)
            f.write_str(sname)
            f.write_str("_")
            f.write_str(mname)
            f.write_str("(")
            for i in 1..e.child_count() {
                if i.gt(1) { f.write_str(", ") }
                if callee_param_is_shallow(flat, i.sub(1)) {
                    emit_deref(f, e.child(i), depth)
                } else if callee_param_is_usize(flat, i.sub(1)).and(callee_param_is_own(flat, i.sub(1)).not()) {
                    emit_usize_ref(f, e.child(i), depth)
                } else {
                    emit_as_ptr(f, e.child(i), depth)
                }
            }
            f.write_str(")")
            return
        }
        ref name : Str = get_payload(callee.data)
        if name.eq("dyn_call").or(name.eq("dyn_call_ret")) {
            ref method : Str = get_payload(e.child(2).data)
            ref nargs_str : Str = get_payload(e.child(3).data)
            nargs := nargs_str.to_i64().to_i32()
            f.write_str("dyn_call_")
            f.write_str(method)
            f.write_str("(")
            emit_as_ptr(f, e.child(1), depth)
            for ai : I32 in 0..nargs {
                f.write_str(", ")
                emit_as_ptr(f, e.child(ai.to_i64().add(4).to_u32()), depth)
            }
            f.write_str(")")
        } else if name.eq("dyn_fn") {
            f.write_str("dyn_fn(")
            emit_as_ptr(f, e.child(1), depth)
            f.write_str(", ")
            ref method_arg : Expr = e.child(2)
            if is_variant(method_arg.data, NodeType.LiteralStr) {
                ref ms : Str = get_payload(method_arg.data)
                f.write_str("&(Str){.c_str=(U8*)\"")
                f.write_str(ms)
                f.write_str("\", .count=")
                emit_u64(f, ms.len().to_i64().to_u64())
                f.write_str("ULL, .cap=TIL_CAP_LIT}")
            } else {
                emit_as_ptr(f, method_arg, depth)
            }
            f.write_str(")")
        } else if name.eq("array").or(name.eq("vec")) {
            ref elem_type : Str = get_payload(e.child(1).data)
            count := e.child_count().sub(2).to_i64().to_i32()
            if name.eq("array") { f.write_str("array") } else { f.write_str("vec") }
            f.write_str("_of_")
            f.write_str(elem_type)
            f.write_str("(")
            emit_i32(f, count)
            for i in 2..e.child_count() {
                f.write_str(", ")
                emit_as_ptr(f, e.child(i), depth)
            }
            f.write_str(")")
        } else if name.eq("dyn_has_method") {
            ref method : Str = get_payload(e.child(2).data)
            f.write_str("dyn_has_")
            f.write_str(method)
            f.write_str("(")
            emit_as_ptr(f, e.child(1), depth)
            f.write_str(")")
        } else if e.struct_name.len().gt(0).and(name.eq(e.struct_name)) {
            // Struct constructor
            ctype := c_type_name(e.til_type, e.struct_name)
            _ctor_seq = _ctor_seq.add(1.to_i32())
            id := _ctor_seq
            f.write_str("({ ")
            f.write_str(ctype)
            f.write_str(" *_sc")
            emit_i32(f, id)
            f.write_str(" = malloc(sizeof(")
            f.write_str(ctype)
            f.write_str(")); ")
            tmp := "_sc".concat(id.to_i64().to_str())
            emit_ctor_fields(f, tmp, e, depth)
            f.write_str(" _sc")
            emit_i32(f, id)
            f.write_str("; })")
        } else if callee.til_type.eq(TilType.FuncPtr) {
            // Indirect call through function pointer variable
            ref sig : Expr = fcall_fn_sig(e)
            emit_fcall_funcptr_cast(f, e, sig, depth)
            if is_ref_local(name) {
                f.write_str("))(*")
                f.write_str(name)
                f.write_str("))(")
            } else {
                f.write_str("))")
                f.write_str(name)
                f.write_str(")(")
            }
            emit_fcall_funcptr_args(f, e, sig, depth)
            f.write_str(")")
        } else {
            // User-defined function call
            fc := func_to_c(name)
            f.write_str(fc)
            f.write_str("(")
            for i in 1..e.child_count() {
                if i.gt(1) { f.write_str(", ") }
                if callee_param_is_shallow(name, i.sub(1)) {
                    emit_deref(f, e.child(i), depth)
                } else if callee_param_is_usize(name, i.sub(1)).and(callee_param_is_own(name, i.sub(1)).not()) {
                    emit_usize_ref(f, e.child(i), depth)
                } else {
                    emit_as_ptr(f, e.child(i), depth)
                }
            }
            f.write_str(")")
        }
    } else if is_variant(e.data, NodeType.FieldAccess) {
        ref obj : Expr = e.child(0)
        ref fname : Str = get_payload(e.data)
        if builder_fa_is_ns(e) {
            if e.til_type.eq(TilType.Enum) {
                f.write_str("&(")
                f.write_str(obj.struct_name)
                f.write_str("){.tag = ")
                f.write_str(obj.struct_name)
                f.write_str("_TAG_")
                f.write_str(fname)
                f.write_str("}")
            } else {
                f.write_str(obj.struct_name)
                f.write_str("_")
                f.write_str(fname)
            }
        } else {
            emit_expr(f, obj, depth)
            if use_dot_access(obj) { f.write_str(".") } else { f.write_str("->") }
            f.write_str(fname)
        }
    } else {
        f.write_str("/* TODO: unknown expr type */")
    }
}

emit_body := proc(f: File, body: Expr, shallow depth: I32) {
    for i in 0..body.child_count() {
        emit_stmt(f, body.child(i), depth)
    }
}
emit_ctor_fields := proc(f: File, var: Str, ctor: Expr, shallow depth: I32) {
    ref sbody : Expr = find_struct_body(ctor.struct_name)
    mut fi : U32 = 0
    for i in 1..ctor.child_count() {
        mut fld_own := OwnType.Shallow
        mut field_type := TilType.Unknown
        mut fname := ""
        if is_null(sbody).not() {
            while fi.lt(sbody.child_count()) {
                ref fld : Expr = sbody.child(fi)
                ref dd : Declaration = get_payload(fld.data)
                if dd.is_namespace.not() {
                    fld_own = dd.own_type
                    field_type = fld.til_type
                    fname = dd.name
                    fi = fi.add(1)
                    break
                }
                fi = fi.add(1)
            }
        }
        ref arg : Expr = ctor.child(i)
        emit_indent(f, depth)
        if fld_own.eq(OwnType.Ref) {
            emit_field(f, var, fname)
            f.write_str(" = ")
            emit_expr(f, arg, depth)
            f.write_str(";\n")
        } else if fld_own.eq(OwnType.Own) {
            if is_variant(arg.data, NodeType.FCall) {
                if arg.struct_name.len().gt(0) {
                    if is_variant(arg.child(0).data, NodeType.Ident) {
                        ref callee_ident : Str = get_payload(arg.child(0).data)
                        if callee_ident.eq(arg.struct_name) {
                            ct := c_type_name(arg.til_type, arg.struct_name)
                            _ctor_seq = _ctor_seq.add(1.to_i32())
                            id := _ctor_seq
                            tmp := "_cs".concat(id.to_i64().to_str())
                            f.write_str(ct)
                            f.write_str(" *")
                            f.write_str(tmp)
                            f.write_str(" = malloc(sizeof(")
                            f.write_str(ct)
                            f.write_str("));\n")
                            emit_ctor_fields(f, tmp, arg, depth)
                            emit_indent(f, depth)
                            emit_field(f, var, fname)
                            f.write_str(" = ")
                            f.write_str(tmp)
                            f.write_str(";\n")
                        } else {
                            emit_field(f, var, fname)
                            f.write_str(" = ")
                            mut own_arg := arg
                            own_arg.is_own_arg = true
                            emit_as_ptr(f, own_arg, depth)
                            f.write_str(";\n")
                        }
                    } else {
                        emit_field(f, var, fname)
                        f.write_str(" = ")
                        mut own_arg := arg
                        own_arg.is_own_arg = true
                        emit_as_ptr(f, own_arg, depth)
                        f.write_str(";\n")
                    }
                } else {
                    emit_field(f, var, fname)
                    f.write_str(" = ")
                    mut own_arg := arg
                    own_arg.is_own_arg = true
                    emit_as_ptr(f, own_arg, depth)
                    f.write_str(";\n")
                }
            } else {
                emit_field(f, var, fname)
                f.write_str(" = ")
                mut own_arg := arg
                own_arg.is_own_arg = true
                emit_as_ptr(f, own_arg, depth)
                f.write_str(";\n")
            }
        } else if is_variant(arg.data, NodeType.FCall) {
            if arg.struct_name.len().gt(0) {
                if is_variant(arg.child(0).data, NodeType.Ident) {
                    ref callee_ident : Str = get_payload(arg.child(0).data)
                    if callee_ident.eq(arg.struct_name) {
                        ct := c_type_name(arg.til_type, arg.struct_name)
                        _ctor_seq = _ctor_seq.add(1.to_i32())
                        id := _ctor_seq
                        tmp := "_cs".concat(id.to_i64().to_str())
                        f.write_str(ct)
                        f.write_str(" *")
                        f.write_str(tmp)
                        f.write_str(" = malloc(sizeof(")
                        f.write_str(ct)
                        f.write_str("));\n")
                        emit_ctor_fields(f, tmp, arg, depth)
                        emit_indent(f, depth)
                        emit_field(f, var, fname)
                        f.write_str(" = *")
                        f.write_str(tmp)
                        f.write_str("; free(")
                        f.write_str(tmp)
                        f.write_str(");\n")
                    } else {
                        if field_type.eq(TilType.FuncPtr).or(field_type.eq(TilType.Dynamic))
                            .or(fcall_is_shallow_return(arg)).or(fcall_returns_dynamic(arg)) {
                            emit_field(f, var, fname)
                            f.write_str(" = ")
                            emit_expr(f, arg, depth)
                            f.write_str(";\n")
                        } else {
                            ftype := c_type_name(arg.til_type, arg.struct_name)
                            f.write_str("{ ")
                            f.write_str(ftype)
                            f.write_str(" *_ca = ")
                            emit_expr(f, arg, depth)
                            f.write_str("; ")
                            emit_field(f, var, fname)
                            f.write_str(" = *_ca; free(_ca); }\n")
                        }
                    }
                } else {
                    if field_type.eq(TilType.FuncPtr).or(field_type.eq(TilType.Dynamic))
                        .or(fcall_is_shallow_return(arg)).or(fcall_returns_dynamic(arg)) {
                        emit_field(f, var, fname)
                        f.write_str(" = ")
                        emit_expr(f, arg, depth)
                        f.write_str(";\n")
                    } else {
                        ftype := c_type_name(arg.til_type, arg.struct_name)
                        f.write_str("{ ")
                        f.write_str(ftype)
                        f.write_str(" *_ca = ")
                        emit_expr(f, arg, depth)
                        f.write_str("; ")
                        emit_field(f, var, fname)
                        f.write_str(" = *_ca; free(_ca); }\n")
                    }
                }
            } else {
                if field_type.eq(TilType.FuncPtr).or(field_type.eq(TilType.Dynamic))
                    .or(fcall_is_shallow_return(arg)).or(fcall_returns_dynamic(arg)) {
                    emit_field(f, var, fname)
                    f.write_str(" = ")
                    emit_expr(f, arg, depth)
                    f.write_str(";\n")
                } else {
                    ftype := c_type_name(arg.til_type, arg.struct_name)
                    f.write_str("{ ")
                    f.write_str(ftype)
                    f.write_str(" *_ca = ")
                    emit_expr(f, arg, depth)
                    f.write_str("; ")
                    emit_field(f, var, fname)
                    f.write_str(" = *_ca; free(_ca); }\n")
                }
            }
        } else {
            emit_field(f, var, fname)
            f.write_str(" = ")
            emit_deref(f, arg, depth)
            f.write_str(";\n")
        }
    }
}

emit_ns_inits := proc(f: File, shallow depth: I32) {
    for prog_idx in 0..2 {
        ref mut prog : Expr = NULL
        if prog_idx.eq(0) { prog = codegen_core_program }
        else { prog = codegen_program }
        if is_null(prog) { continue }
        for i in 0..prog.child_count() {
            ref stmt : Expr = prog.child(i)
            if is_variant(stmt.data, NodeType.Decl) {
                ref rhs : Expr = stmt.child(0)
                if is_variant(rhs.data, NodeType.StructDef).or(is_variant(rhs.data, NodeType.EnumDef)) {
                    ref sname : Str = get_payload(stmt.data)
                    ref edef : Expr = stmt.child(0)
                    ref body : Expr = edef.child(0)
                    for j in 0..body.child_count() {
                        ref field : Expr = body.child(j)
                        ref dd : Declaration = get_payload(field.data)
                        if dd.is_namespace.not() { continue }
                        if field.child_count().eq(0) { continue }
                        if is_variant(field.child(0).data, NodeType.FuncDef) { continue }
                        if is_variant(edef.data, NodeType.EnumDef) { continue }
                        emit_indent(f, depth)
                        f.write_str(sname)
                        f.write_str("_")
                        f.write_str(dd.name)
                        f.write_str(" = ")
                        emit_deref(f, field.child(0), depth)
                        f.write_str(";\n")
                    }
                }
            }
        }
    }
}

emit_body_scoped := proc(f: File, body: Expr, shallow depth: I32) {
    saved_sl := stack_locals.clone()
    saved_rl := ref_locals.clone()
    emit_body(f, body, depth)
    own stack_locals.delete()
    own ref_locals.delete()
    stack_locals = saved_sl
    ref_locals = saved_rl
}

emit_deref := proc(f: File, e: Expr, shallow depth: I32) {
    if e.til_type.eq(TilType.Dynamic) {
        emit_expr(f, e, depth)
    } else if e.til_type.eq(TilType.FuncPtr) {
        if is_variant(e.data, NodeType.Ident) {
            ref ident : Str = get_payload(e.data)
            if is_ref_local(ident) {
                f.write_str("(void *)DEREF(")
                emit_expr(f, e, depth)
                f.write_str(")")
            } else {
                f.write_str("(void *)")
                emit_expr(f, e, depth)
            }
        } else {
            f.write_str("(void *)")
            emit_expr(f, e, depth)
        }
    } else if is_variant(e.data, NodeType.Ident) {
        ref ident : Str = get_payload(e.data)
        if is_shallow_param(ident).or(is_stack_local(ident)).or(is_value_global(ident)) {
            emit_expr(f, e, depth)
        } else {
            f.write_str("DEREF(")
            emit_expr(f, e, depth)
            f.write_str(")")
        }
    } else if is_variant(e.data, NodeType.LiteralStr) {
        ref s : Str = get_payload(e.data)
        f.write_str("(Str){.c_str=(U8*)\"")
        f.write_str(s)
        f.write_str("\", .count=")
        emit_u64(f, s.len().to_i64().to_u64())
        f.write_str("ULL, .cap=TIL_CAP_LIT}")
    } else if is_variant(e.data, NodeType.FieldAccess) {
        if builder_fa_is_ns(e).and(e.til_type.eq(TilType.Enum)) {
            f.write_str("(*")
            emit_expr(f, e, depth)
            f.write_str(")")
        } else {
            emit_expr(f, e, depth)
        }
    } else {
        emit_expr(f, e, depth)
    }
}

emit_as_ptr := proc(f: File, e: Expr, shallow depth: I32) {
    if is_variant(e.data, NodeType.Ident) {
        ref ident : Str = get_payload(e.data)
        if is_shallow_param(ident).or(is_stack_local(ident)).or(is_value_global(ident)) {
            if e.is_own_arg {
                ref mut ctype : Str = get_stack_local_ctype(ident)
                if is_null(ctype) { ctype = c_type_name(e.til_type, e.struct_name) }
                f.write_str("({ ")
                f.write_str(ctype)
                f.write_str(" *_oa = malloc(sizeof(")
                f.write_str(ctype)
                f.write_str(")); *_oa = ")
                emit_expr(f, e, depth)
                f.write_str("; _oa; })")
            } else {
                f.write_str("&")
                f.write_str(ident)
            }
        } else if is_variant(e.data, NodeType.Ident) {
            emit_expr(f, e, depth)
        }
    } else if is_variant(e.data, NodeType.FCall) {
        if e.struct_name.len().gt(0).and(e.child_count().gt(0)) {
            if is_variant(e.child(0).data, NodeType.Ident) {
                ref callee_ident : Str = get_payload(e.child(0).data)
                if callee_ident.eq(e.struct_name) {
                    ctype := c_type_name(e.til_type, e.struct_name)
                    _ctor_seq = _ctor_seq.add(1.to_i32())
                    id := _ctor_seq
                    f.write_str("({ ")
                    f.write_str(ctype)
                    f.write_str(" *_sc")
                    emit_i32(f, id)
                    f.write_str(" = malloc(sizeof(")
                    f.write_str(ctype)
                    f.write_str(")); ")
                    tmp := "_sc".concat(id.to_i64().to_str())
                    emit_ctor_fields(f, tmp, e, depth)
                    f.write_str(" _sc")
                    emit_i32(f, id)
                    f.write_str("; })")
                    return
                }
            }
        }
        emit_expr(f, e, depth)
    } else if is_variant(e.data, NodeType.LiteralStr) {
        emit_expr(f, e, depth)
    } else if is_variant(e.data, NodeType.FieldAccess) {
        if e.field_own_type.eq(OwnType.Shallow).not() {
            emit_expr(f, e, depth)
        } else if builder_fa_is_ns(e).and(e.til_type.eq(TilType.Enum)) {
            emit_expr(f, e, depth)
        } else if e.til_type.eq(TilType.Dynamic) {
            emit_expr(f, e, depth)
        } else {
            f.write_str("&")
            emit_expr(f, e, depth)
        }
    } else if is_variant(e.data, NodeType.LiteralNull) {
        f.write_str("NULL")
    } else {
        ctype := c_type_name(e.til_type, e.struct_name)
        f.write_str("&(")
        f.write_str(ctype)
        f.write_str("){")
        emit_expr(f, e, depth)
        f.write_str("}")
    }
}

emit_usize_ref := proc(f: File, e: Expr, shallow depth: I32) {
    f.write_str("USIZE_REF(")
    emit_deref(f, e, depth)
    f.write_str(")")
}

emit_cli_parse_arg := proc(f: File, pname: Str, ptype: Str, shallow argi: I32) {
    if ptype.eq("Str") {
        f.write_str("    Str *"); f.write_str(pname); f.write_str(" = Str_clone(&(Str){.c_str = (U8 *)argv["); emit_i32(f, argi); f.write_str("], .count = strlen(argv["); emit_i32(f, argi); f.write_str("]), .cap = TIL_CAP_LIT});\n")
    } else if ptype.eq("I64") {
        f.write_str("    I64 *"); f.write_str(pname); f.write_str(" = cli_parse_i64(argv["); emit_i32(f, argi); f.write_str("]);\n")
    } else if ptype.eq("U8") {
        f.write_str("    U8 *"); f.write_str(pname); f.write_str(" = cli_parse_u8(argv["); emit_i32(f, argi); f.write_str("]);\n")
    } else if ptype.eq("I16") {
        f.write_str("    I16 *"); f.write_str(pname); f.write_str(" = cli_parse_i16(argv["); emit_i32(f, argi); f.write_str("]);\n")
    } else if ptype.eq("I32") {
        f.write_str("    I32 *"); f.write_str(pname); f.write_str(" = cli_parse_i32(argv["); emit_i32(f, argi); f.write_str("]);\n")
    } else if ptype.eq("U32") {
        f.write_str("    U32 *"); f.write_str(pname); f.write_str(" = cli_parse_u32(argv["); emit_i32(f, argi); f.write_str("]);\n")
    } else if ptype.eq("U64") {
        f.write_str("    U64 *"); f.write_str(pname); f.write_str(" = cli_parse_u64(argv["); emit_i32(f, argi); f.write_str("]);\n")
    } else if ptype.eq("USize") {
        f.write_str("    USize *"); f.write_str(pname); f.write_str(" = (USize *)cli_parse_u64(argv["); emit_i32(f, argi); f.write_str("]);\n")
    } else if ptype.eq("Bool") {
        f.write_str("    Bool *"); f.write_str(pname); f.write_str(" = cli_parse_bool(argv["); emit_i32(f, argi); f.write_str("]);\n")
    } else {
        f.write_str("    // unsupported CLI arg type: "); f.write_str(ptype); f.write_str("\n")
        f.write_str("    fprintf(stderr, \"error: unsupported CLI argument type '"); f.write_str(ptype); f.write_str("'\\n\"); return 1;\n")
    }
}

emit_func_def := proc(f: File, name: Str, func_def: Expr, mode: Mode, shallow is_static: Bool) {
    ref fd : FunctionDef = get_payload(func_def.data)
    ref body : Expr = func_def.child(0)
    mut is_main := false
    if is_null(mode).not() {
        if mode.needs_main { is_main = name.eq("main") }
    }

    if is_main {
        nparam := fd.nparam
        vi := fd.variadic_index
        if nparam.eq(0) {
            f.write_str("int main(int argc, char **argv) {\n")
            f.write_str("    (void)argv;\n")
            f.write_str("    if (argc > 1) { fprintf(stderr, \"error: main expects no arguments, got %d\\n\", argc - 1); return 1; }\n")
        } else {
            f.write_str("int main(int argc, char **argv) {\n")
            mut fixed := nparam.to_i64().to_i32()
            if vi.gte(0.to_i32()) { fixed = fixed.sub(1.to_i32()) }
            if vi.gte(0.to_i32()) {
                f.write_str("    if (argc - 1 < "); emit_i32(f, fixed); f.write_str(") { fprintf(stderr, \"error: main expects at least "); emit_i32(f, fixed); f.write_str(" argument(s), got %d\\n\", argc - 1); return 1; }\n")
            } else {
                f.write_str("    if (argc - 1 != "); emit_i32(f, nparam.to_i64().to_i32()); f.write_str(") { fprintf(stderr, \"error: main expects "); emit_i32(f, nparam.to_i64().to_i32()); f.write_str(" argument(s), got %d\\n\", argc - 1); return 1; }\n")
            }
        }
        emit_ns_inits(f, 1.to_i32())
        if has_script_globals {
            for prog_idx in 0..2 {
                ref mut prog : Expr = NULL
                if prog_idx.eq(0) { prog = codegen_core_program } else { prog = codegen_program }
                if is_null(prog) { continue }
                for i in 0..prog.child_count() {
                    ref gs : Expr = prog.child(i)
                    if is_variant(gs.data, NodeType.Decl) {
                        ref rhs : Expr = gs.child(0)
                        if is_variant(rhs.data, NodeType.FuncDef).or(is_variant(rhs.data, NodeType.StructDef)).or(is_variant(rhs.data, NodeType.EnumDef)) { continue }
                        if gs.til_type.eq(TilType.None).and(is_variant(rhs.data, NodeType.Ident)) { continue }
                    } else if is_variant(gs.data, NodeType.FCall).not() { continue }
                    emit_stmt(f, gs, 1.to_i32())
                }
            }
        }
        if nparam.gt(0) {
            mut argi := 1.to_i32()
            for i in 0..nparam {
                ref p : Param = fd.params.get(i)
                ii := i.to_i64().to_i32()
                if ii.eq(vi) {
                    // Variadic array
                    f.write_str("    int _va_argc = argc - "); emit_i32(f, argi); f.write_str(";\n")
                    f.write_str("    USize _va_esz = sizeof("); f.write_str(p.ptype); f.write_str(");\n")
                    f.write_str("    USize _va_cap = _va_argc;\n")
                    f.write_str("    Array *"); f.write_str(p.name); f.write_str(" = Array_new(&(Str){.c_str = (U8 *)\""); f.write_str(p.ptype); f.write_str("\", .count = "); emit_u64(f, p.ptype.len().to_i64().to_u64()); f.write_str("ULL, .cap = TIL_CAP_LIT}, &(USize){_va_esz}, &(USize){_va_cap});\n")
                    f.write_str("    for (int _i = 0; _i < _va_argc; _i++) {\n")
                    f.write_str("        USize _idx = _i;\n")
                    if p.ptype.eq("Str") {
                        f.write_str("        Str *_val = Str_clone(&(Str){.c_str = (U8 *)argv["); emit_i32(f, argi); f.write_str(" + _i], .count = strlen(argv["); emit_i32(f, argi); f.write_str(" + _i]), .cap = TIL_CAP_LIT});\n")
                    } else if p.ptype.eq("I64") {
                        f.write_str("        I64 *_val = cli_parse_i64(argv["); emit_i32(f, argi); f.write_str(" + _i]);\n")
                    } else if p.ptype.eq("U8") {
                        f.write_str("        U8 *_val = cli_parse_u8(argv["); emit_i32(f, argi); f.write_str(" + _i]);\n")
                    } else if p.ptype.eq("I16") {
                        f.write_str("        I16 *_val = cli_parse_i16(argv["); emit_i32(f, argi); f.write_str(" + _i]);\n")
                    } else if p.ptype.eq("I32") {
                        f.write_str("        I32 *_val = cli_parse_i32(argv["); emit_i32(f, argi); f.write_str(" + _i]);\n")
                    } else if p.ptype.eq("U32") {
                        f.write_str("        U32 *_val = cli_parse_u32(argv["); emit_i32(f, argi); f.write_str(" + _i]);\n")
                    } else if p.ptype.eq("U64") {
                        f.write_str("        U64 *_val = cli_parse_u64(argv["); emit_i32(f, argi); f.write_str(" + _i]);\n")
                    } else if p.ptype.eq("USize") {
                        f.write_str("        USize *_val = (USize *)cli_parse_u64(argv["); emit_i32(f, argi); f.write_str(" + _i]);\n")
                    } else if p.ptype.eq("Bool") {
                        f.write_str("        Bool *_val = cli_parse_bool(argv["); emit_i32(f, argi); f.write_str(" + _i]);\n")
                    }
                    f.write_str("        Array_set("); f.write_str(p.name); f.write_str(", &(USize){_idx}, _val);\n")
                    f.write_str("    }\n")
                } else {
                    emit_cli_parse_arg(f, p.name, p.ptype, argi)
                    argi = argi.add(1.to_i32())
                }
            }
        }
        saved_sl := stack_locals; saved_slt := stack_local_types; saved_uth := unsafe_to_hoist; saved_rl := ref_locals
        stack_locals = Set.new("Str", Str.size()); stack_local_types = Map.new("Str", Str.size(), "Str", Str.size())
        unsafe_to_hoist = Set.new("Str", Str.size()); ref_locals = Set.new("Str", Str.size())
        collect_unsafe_to_hoist(body)
        in_main_func = true
        emit_body(f, body, 1.to_i32())
        in_main_func = false
        own stack_locals.delete(); own stack_local_types.delete(); own unsafe_to_hoist.delete(); own ref_locals.delete()
        stack_locals = saved_sl; stack_local_types = saved_slt; unsafe_to_hoist = saved_uth; ref_locals = saved_rl
        f.write_str("    return 0;\n")
        f.write_str("}\n")
    } else {
        // Return type
        mut ret := ""
        if fd.return_type.len().gt(0) {
            if is_variant(fd.return_own_type, OwnType.Shallow) { ret = type_name_to_c_value(fd.return_type) }
            else { ret = type_name_to_c(fd.return_type) }
        }
        if ret.len().eq(0) { ret = "void" }
        // Signature
        if is_static { f.write_str("static __attribute__((unused)) ") }
        f.write_str(ret); f.write_str(" "); fc := func_to_c(name); f.write_str(fc); f.write_str("(")
        emit_param_list(f, func_def, true)
        f.write_str(") {\n")
        for i in 0..fd.nparam {
            ref p : Param = fd.params.get(i)
            f.write_str("    (void)"); f.write_str(p.name); f.write_str(";\n")
        }
        // NULL guard for delete methods
        if name.len().gt(7) {
            if name.substr(name.len().sub(7), 7).eq("_delete") {
                if fd.nparam.gt(0) {
                    ref p0 : Param = fd.params.get(0)
                    if p0.name.eq("self") { f.write_str("    if (!self) return;\n") }
                }
            }
        }
        in_func_def = true
        current_fdef = func_def
        saved_sl := stack_locals; saved_slt := stack_local_types; saved_uth := unsafe_to_hoist; saved_rl := ref_locals
        stack_locals = Set.new("Str", Str.size()); stack_local_types = Map.new("Str", Str.size(), "Str", Str.size())
        unsafe_to_hoist = Set.new("Str", Str.size()); ref_locals = Set.new("Str", Str.size())
        collect_unsafe_to_hoist(body)
        emit_body(f, body, 1.to_i32())
        own stack_locals.delete(); own stack_local_types.delete(); own unsafe_to_hoist.delete(); own ref_locals.delete()
        stack_locals = saved_sl; stack_local_types = saved_slt; unsafe_to_hoist = saved_uth; ref_locals = saved_rl
        in_func_def = false
        f.write_str("}\n")
    }
}

emit_struct_typedef := proc(f: File, name: Str, struct_def: Expr) {
    ref body : Expr = struct_def.child(0)
    if is_ext_h_type(name) { return }
    mut has_instance_fields := false
    for i in 0..body.child_count() {
        ref fld : Expr = body.child(i)
        ref dd : Declaration = get_payload(fld.data)
        if dd.is_namespace.not() { has_instance_fields = true }
    }
    f.write_str("typedef struct "); f.write_str(name); f.write_str(" {\n")
    if has_instance_fields.not() { f.write_str("    char _;\n") }
    for i in 0..body.child_count() {
        ref field : Expr = body.child(i)
        ref dd : Declaration = get_payload(field.data)
        if dd.is_namespace { continue }
        if dd.own_type.eq(OwnType.Shallow).not() {
            if field.til_type.eq(TilType.Struct).or(field.til_type.eq(TilType.Enum)) {
                if field.child(0).struct_name.len().gt(0) {
                    f.write_str("    "); f.write_str(field.child(0).struct_name); f.write_str(" *"); f.write_str(dd.name); f.write_str(";\n")
                } else {
                    tc := til_type_to_c(field.til_type); f.write_str("    "); f.write_str(tc); f.write_str(" *"); f.write_str(dd.name); f.write_str(";\n")
                }
            } else {
                tc := til_type_to_c(field.til_type); f.write_str("    "); f.write_str(tc); f.write_str(" *"); f.write_str(dd.name); f.write_str(";\n")
            }
        } else if field.til_type.eq(TilType.Struct).or(field.til_type.eq(TilType.Enum)) {
            if field.child(0).struct_name.len().gt(0) {
                f.write_str("    "); f.write_str(field.child(0).struct_name); f.write_str(" "); f.write_str(dd.name); f.write_str(";\n")
            } else {
                tc := til_type_to_c(field.til_type); f.write_str("    "); f.write_str(tc); f.write_str(" "); f.write_str(dd.name); f.write_str(";\n")
            }
        } else {
            tc := til_type_to_c(field.til_type); f.write_str("    "); f.write_str(tc); f.write_str(" "); f.write_str(dd.name); f.write_str(";\n")
        }
    }
    f.write_str("} "); f.write_str(name); f.write_str(";\n\n")
    // Namespace fields as globals
    for i in 0..body.child_count() {
        ref field : Expr = body.child(i)
        ref dd : Declaration = get_payload(field.data)
        if dd.is_namespace.not() { continue }
        if field.child_count().eq(0) { continue }
                        if is_variant(field.child(0).data, NodeType.FuncDef) { continue }
        if field.til_type.eq(TilType.Struct).or(field.til_type.eq(TilType.Enum)) {
            if field.child(0).struct_name.len().gt(0) {
                f.write_str(field.child(0).struct_name); f.write_str(" "); f.write_str(name); f.write_str("_"); f.write_str(dd.name); f.write_str(";\n")
            } else {
                tc := til_type_to_c(field.til_type); f.write_str(tc); f.write_str(" "); f.write_str(name); f.write_str("_"); f.write_str(dd.name); f.write_str(";\n")
            }
        } else {
            tc := til_type_to_c(field.til_type); f.write_str(tc); f.write_str(" "); f.write_str(name); f.write_str("_"); f.write_str(dd.name); f.write_str(";\n")
        }
    }
}

emit_struct_funcs := proc(f: File, name: Str, struct_def: Expr, shallow is_lib: Bool) {
    ref body : Expr = struct_def.child(0)
    for i in 0..body.child_count() {
        ref field : Expr = body.child(i)
        ref dd : Declaration = get_payload(field.data)
        if dd.is_namespace.not() { continue }
        if field.child_count().eq(0) { continue }
        if is_variant(field.child(0).data, NodeType.FuncDef).not() { continue }
        ref fdef : Expr = field.child(0)
        ref fd : FunctionDef = get_payload(fdef.data)
        if is_variant(fd.func_type, FuncType.ExtFunc).or(is_variant(fd.func_type, FuncType.ExtProc)) { continue }
        // Emit size() as sizeof
        if dd.name.eq("size").and(fd.nparam.eq(0)).and(fd.return_type.len().gt(0)) {
            if fd.return_type.eq("USize").or(fd.return_type.eq("U32")).or(fd.return_type.eq("U64")) {
                ret_ctype := type_name_to_c_value(fd.return_type)
                if is_variant(fd.return_own_type, OwnType.Shallow) {
                    f.write_str(ret_ctype); f.write_str(" "); f.write_str(name); f.write_str("_size(void) {\n")
                    f.write_str("    return ("); f.write_str(ret_ctype); f.write_str(")sizeof("); f.write_str(name); f.write_str(");\n")
                } else {
                    f.write_str(ret_ctype); f.write_str(" *"); f.write_str(name); f.write_str("_size(void) {\n")
                    f.write_str("    "); f.write_str(ret_ctype); f.write_str(" *r = malloc(sizeof("); f.write_str(ret_ctype); f.write_str("));\n")
                    f.write_str("    *r = ("); f.write_str(ret_ctype); f.write_str(")sizeof("); f.write_str(name); f.write_str(");\n")
                    f.write_str("    return r;\n")
                }
                f.write_str("}\n\n")
                continue
            }
        }
        full_name := name.concat("_").concat(dd.name)
        emit_func_def(f, full_name, fdef, NULL, false)
        f.write_str("\n")
    }
}

emit_enum_def := proc(f: File, name: Str, enum_def: Expr) {
    ref body : Expr = enum_def.child(0)
    hp := enum_has_payloads(enum_def)
    if hp.not() {
        // Simple enum
        mut vnames := Vec.new("Str", Str.size())
        for i in 0..body.child_count() {
            ref v : Expr = body.child(i)
            ref dd : Declaration = get_payload(v.data)
            if dd.is_namespace { continue }
            vnames.push(own dd.name.clone())
        }
        for i in 0..vnames.len() {
            ref vn : Str = vnames.get(i)
            f.write_str(name); f.write_str(" *"); f.write_str(name); f.write_str("_"); f.write_str(vn); f.write_str("() {\n")
            f.write_str("    "); f.write_str(name); f.write_str(" *r = malloc(sizeof("); f.write_str(name); f.write_str("));\n")
            f.write_str("    *r = ("); f.write_str(name); f.write_str("){ .tag = "); f.write_str(name); f.write_str("_TAG_"); f.write_str(vn); f.write_str(" };\n")
            f.write_str("    return r;\n"); f.write_str("}\n")
        }
        own vnames.delete()
    } else {
        // Payload enum
        mut vnames := Vec.new("Str", Str.size())
        mut vtypes := Vec.new("Str", Str.size())
        for i in 0..body.child_count() {
            ref v : Expr = body.child(i)
            ref dd : Declaration = get_payload(v.data)
            if dd.is_namespace { continue }
            vnames.push(own dd.name.clone())
            vtypes.push(own dd.explicit_type.clone())
        }
        for i in 0..vnames.len() {
            ref vn : Str = vnames.get(i)
            ref vt : Str = vtypes.get(i)
            if vt.len().eq(0) {
                f.write_str(name); f.write_str(" *"); f.write_str(name); f.write_str("_"); f.write_str(vn); f.write_str("() {\n")
                f.write_str("    "); f.write_str(name); f.write_str(" *r = malloc(sizeof("); f.write_str(name); f.write_str("));\n")
                f.write_str("    r->tag = "); f.write_str(name); f.write_str("_TAG_"); f.write_str(vn); f.write_str(";\n")
                f.write_str("    return r;\n"); f.write_str("}\n")
                continue
            }
            ptype := type_name_to_c(vt)
            f.write_str(name); f.write_str(" *"); f.write_str(name); f.write_str("_"); f.write_str(vn); f.write_str("("); f.write_str(ptype); f.write_str(" val) {\n")
            f.write_str("    "); f.write_str(name); f.write_str(" *r = malloc(sizeof("); f.write_str(name); f.write_str("));\n")
            f.write_str("    r->tag = "); f.write_str(name); f.write_str("_TAG_"); f.write_str(vn); f.write_str(";\n")
            if is_primitive_type(vt) {
                f.write_str("    r->data."); f.write_str(vn); f.write_str(" = *val;\n")
            } else if is_funcsig_type(vt).or(vt.eq("Dynamic")) {
                f.write_str("    r->data."); f.write_str(vn); f.write_str(" = val;\n")
            } else {
                tnc := type_name_to_c(vt)
                f.write_str("    { "); f.write_str(tnc); f.write_str(" _tmp = "); f.write_str(vt); f.write_str("_clone(val); r->data."); f.write_str(vn); f.write_str(" = *_tmp; free(_tmp); }\n")
            }
            f.write_str("    return r;\n"); f.write_str("}\n")
        }
        own vnames.delete()
        own vtypes.delete()
    }
    // Namespace methods
    for i in 0..body.child_count() {
        ref field : Expr = body.child(i)
        ref dd : Declaration = get_payload(field.data)
        if dd.is_namespace.not() { continue }
        if field.child_count().eq(0) { continue }
        if is_variant(field.child(0).data, NodeType.FuncDef).not() { continue }
        ref fdef : Expr = field.child(0)
        ref fd : FunctionDef = get_payload(fdef.data)
        if is_variant(fd.func_type, FuncType.ExtFunc).or(is_variant(fd.func_type, FuncType.ExtProc)) { continue }
        if dd.name.eq("size").and(fd.nparam.eq(0)).and(fd.return_type.len().gt(0)) {
            if fd.return_type.eq("USize").or(fd.return_type.eq("U32")).or(fd.return_type.eq("U64")) {
                ret_ctype := type_name_to_c_value(fd.return_type)
                if is_variant(fd.return_own_type, OwnType.Shallow) {
                    f.write_str(ret_ctype); f.write_str(" "); f.write_str(name); f.write_str("_size(void) {\n")
                    f.write_str("    return ("); f.write_str(ret_ctype); f.write_str(")sizeof("); f.write_str(name); f.write_str(");\n")
                } else {
                    f.write_str(ret_ctype); f.write_str(" *"); f.write_str(name); f.write_str("_size(void) {\n")
                    f.write_str("    "); f.write_str(ret_ctype); f.write_str(" *r = malloc(sizeof("); f.write_str(ret_ctype); f.write_str("));\n")
                    f.write_str("    *r = ("); f.write_str(ret_ctype); f.write_str(")sizeof("); f.write_str(name); f.write_str(");\n")
                    f.write_str("    return r;\n")
                }
                f.write_str("}\n\n")
                continue
            }
        }
        full_name := name.concat("_").concat(dd.name)
        emit_func_def(f, full_name, fdef, NULL, false)
        f.write_str("\n")
    }
}

emit_enum_struct_body := proc(f: File, ename: Str, enum_def: Expr) {
    ref ebody : Expr = enum_def.child(0)
    hp := enum_has_payloads(enum_def)
    f.write_str("struct "); f.write_str(ename); f.write_str(" {\n")
    f.write_str("    "); f.write_str(ename); f.write_str("_tag tag;\n")
    if hp {
        f.write_str("    union {\n")
        for j in 0..ebody.child_count() {
            ref v : Expr = ebody.child(j)
            ref dd : Declaration = get_payload(v.data)
            if dd.is_namespace { continue }
            if dd.explicit_type.len().gt(0) {
                tnv := type_name_to_c_value(dd.explicit_type)
                f.write_str("        "); f.write_str(tnv); f.write_str(" "); f.write_str(dd.name); f.write_str(";\n")
            }
        }
        f.write_str("    } data;\n")
    }
    f.write_str("};\n\n")
}

topo_emit_struct_enum_defs := proc(f: File, prog: Expr, mut emitted: Set) {
    mut indices := Vec.new("U32", U32.size())
    for i in 0..prog.child_count() {
        ref stmt : Expr = prog.child(i)
        if is_variant(stmt.data, NodeType.Decl) {
            if stmt.child_count().gt(0) {
                if is_variant(stmt.child(0).data, NodeType.StructDef).or(is_variant(stmt.child(0).data, NodeType.EnumDef)) {
                    mut idx := i
                    indices.push(own idx)
                }
            }
        }
    }
    mut remaining := indices.len()
    mut done := Array.new("Bool", Bool.size(), indices.len())
    for di in 0..indices.len() {
        mut f_val := false
        done.set(di, own f_val)
    }
    while remaining.gt(0) {
        mut progress := false
        for ei in 0..indices.len() {
            ref d : Bool = done.get(ei)
            if d { continue }
            ref idx : U32 = indices.get(ei)
            ref stmt : Expr = prog.child(idx)
            ref sname : Str = get_payload(stmt.data)
            ref def : Expr = stmt.child(0)
            mut deps_ok := true
            if is_variant(def.data, NodeType.StructDef) {
                ref sbody : Expr = def.child(0)
                for fi in 0..sbody.child_count() {
                    ref field : Expr = sbody.child(fi)
                    ref dd : Declaration = get_payload(field.data)
                    if dd.is_namespace { continue }
                    if dd.own_type.eq(OwnType.Shallow) {
                        if field.til_type.eq(TilType.Struct).or(field.til_type.eq(TilType.Enum)) {
                            if field.child(0).struct_name.len().gt(0) {
                                if emitted.has(field.child(0).struct_name).not() { deps_ok = false }
                            }
                        }
                    }
                }
            } else if is_variant(def.data, NodeType.EnumDef) {
                ref ebody : Expr = def.child(0)
                for fi in 0..ebody.child_count() {
                    ref v : Expr = ebody.child(fi)
                    ref dd : Declaration = get_payload(v.data)
                    if dd.is_namespace { continue }
                    if dd.explicit_type.len().gt(0) {
                        if is_primitive_type(dd.explicit_type).not().and(is_funcsig_type(dd.explicit_type).not()) {
                            if emitted.has(dd.explicit_type).not() { deps_ok = false }
                        }
                    }
                }
            }
            if deps_ok.not() { continue }
            if is_variant(def.data, NodeType.StructDef) {
                emit_struct_typedef(f, sname, def)
                f.write_str("\n")
            } else {
                emit_enum_struct_body(f, sname, def)
            }
            emitted.add(own sname.clone())
            mut t_val := true
            done.set(ei, own t_val)
            remaining = remaining.sub(1)
            progress = true
        }
        if progress.not() {
            for ei in 0..indices.len() {
                ref d : Bool = done.get(ei)
                if d { continue }
                ref idx : U32 = indices.get(ei)
                ref stmt : Expr = prog.child(idx)
                ref sname : Str = get_payload(stmt.data)
                ref def : Expr = stmt.child(0)
                if is_variant(def.data, NodeType.StructDef) {
                    emit_struct_typedef(f, sname, def)
                    f.write_str("\n")
                } else {
                    emit_enum_struct_body(f, sname, def)
                }
            }
            break
        }
    }
    own done.delete()
    own indices.delete()
}

emit_func_forward_decl := proc(f: File, name: Str, fdef: Expr) {
    ref fd : FunctionDef = get_payload(fdef.data)
    mut ret := "void"
    if fd.return_type.len().gt(0) {
        if is_variant(fd.return_own_type, OwnType.Shallow) { ret = type_name_to_c_value(fd.return_type) }
        else { ret = type_name_to_c(fd.return_type) }
    }
    f.write_str(ret); f.write_str(" "); f.write_str(name); f.write_str("(")
    emit_param_list(f, fdef, true)
    f.write_str(");\n")
}

emit_header_forward_decls := proc(f: File, core_program: Expr, program: Expr) {
    for prog_idx in 0..2 {
        ref mut prog : Expr = NULL
        if prog_idx.eq(0) { prog = core_program } else { prog = program }
        if is_null(prog) { continue }
        for i in 0..prog.child_count() {
            ref stmt : Expr = prog.child(i)
            if is_variant(stmt.data, NodeType.Decl) {
                ref dd : Declaration = get_payload(stmt.data)
                if stmt.child_count().eq(0) { continue }
                ref rhs : Expr = stmt.child(0)
                if is_variant(rhs.data, NodeType.StructDef) {
                    if is_ext_h_type(dd.name) { continue }
                    f.write_str("typedef struct "); f.write_str(dd.name); f.write_str(" "); f.write_str(dd.name); f.write_str(";\n")
                }
                if is_variant(rhs.data, NodeType.EnumDef) {
                    ref ebody : Expr = rhs.child(0)
                    f.write_str("typedef enum {\n")
                    mut tag := 0.to_i32()
                    for j in 0..ebody.child_count() {
                        ref v : Expr = ebody.child(j)
                        ref vdd : Declaration = get_payload(v.data)
                        if vdd.is_namespace { continue }
                        if tag.gt(0.to_i32()) { f.write_str(",\n") }
                        f.write_str("    "); f.write_str(dd.name); f.write_str("_TAG_"); f.write_str(vdd.name)
                        tag = tag.add(1.to_i32())
                    }
                    f.write_str("\n} "); f.write_str(dd.name); f.write_str("_tag;\n")
                    f.write_str("typedef struct "); f.write_str(dd.name); f.write_str(" "); f.write_str(dd.name); f.write_str(";\n")
                }
            }
        }
    }
    f.write_str("\n")
}

emit_header_defs_and_funcs := proc(f: File, core_program: Expr, program: Expr) {
    mut emitted_h := Set.new("Str", Str.size())
    emitted_h.add(own "U8".clone()); emitted_h.add(own "I16".clone()); emitted_h.add(own "I32".clone())
    emitted_h.add(own "U32".clone()); emitted_h.add(own "U64".clone()); emitted_h.add(own "I64".clone())
    emitted_h.add(own "F32".clone()); emitted_h.add(own "Bool".clone())
    if is_null(core_program).not() { topo_emit_struct_enum_defs(f, core_program, emitted_h) }
    topo_emit_struct_enum_defs(f, program, emitted_h)
    own emitted_h.delete()

    // Function forward declarations
    for prog_idx in 0..2 {
        ref mut prog : Expr = NULL
        if prog_idx.eq(0) { prog = core_program } else { prog = program }
        if is_null(prog) { continue }
        is_core_pass := prog_idx.eq(0).and(is_null(core_program).not())
        for i in 0..prog.child_count() {
            ref stmt : Expr = prog.child(i)
            if is_variant(stmt.data, NodeType.Decl).not() { continue }
            ref dd : Declaration = get_payload(stmt.data)
            if stmt.child_count().eq(0) { continue }
            ref rhs : Expr = stmt.child(0)
            if is_variant(rhs.data, NodeType.StructDef).or(is_variant(rhs.data, NodeType.EnumDef)) {
                if is_scalar_method_type(dd.name) { continue }
                ref body : Expr = rhs.child(0)
                for j in 0..body.child_count() {
                    ref field : Expr = body.child(j)
                    ref fdd : Declaration = get_payload(field.data)
                    if fdd.is_namespace.not() { continue }
                    if field.child_count().eq(0) { continue }
                    if field.child_count().eq(0) { continue }
        if is_variant(field.child(0).data, NodeType.FuncDef).not() { continue }
                    ref fdef : Expr = field.child(0)
                    ref fd : FunctionDef = get_payload(fdef.data)
                    if is_core_pass.and(is_variant(fd.func_type, FuncType.ExtFunc).or(is_variant(fd.func_type, FuncType.ExtProc))) { continue }
                    full_name := dd.name.concat("_").concat(fdd.name)
                    emit_func_forward_decl(f, full_name, fdef)
                }
            } else if is_variant(rhs.data, NodeType.FuncDef) {
                if rhs.child_count().eq(0) { continue }
                ref fd : FunctionDef = get_payload(rhs.data)
                if is_core_pass.and(is_variant(fd.func_type, FuncType.ExtFunc).or(is_variant(fd.func_type, FuncType.ExtProc))) { continue }
                fc := func_to_c(dd.name)
                emit_func_forward_decl(f, fc, rhs)
            }
        }
    }

    // Enum auto-helper forward declarations
    for i in 0..program.child_count() {
        ref stmt : Expr = program.child(i)
        if is_variant(stmt.data, NodeType.Decl).not() { continue }
        ref dd : Declaration = get_payload(stmt.data)
        if stmt.child_count().eq(0) { continue }
        if is_variant(stmt.child(0).data, NodeType.EnumDef).not() { continue }
        ref ebody : Expr = stmt.child(0).child(0)
        // Find eq fdef
        mut eq_fdef := Expr.new(NodeType.Body, stmt.line, stmt.col, stmt.path)
        mut has_eq_fdef := false
        for j in 0..ebody.child_count() {
            ref field : Expr = ebody.child(j)
            ref fdd : Declaration = get_payload(field.data)
            if fdd.is_namespace {
                if fdd.name.eq("eq") {
                    if field.child_count().gt(0) {
                        if is_variant(field.child(0).data, NodeType.FuncDef) {
                            eq_fdef = field.child(0).clone()
                            has_eq_fdef = true
                        }
                    }
                }
            }
        }
        mut eq_ret := "Bool *"
        if has_eq_fdef {
            ref eqfd : FunctionDef = get_payload(eq_fdef.data)
            if is_variant(eqfd.return_own_type, OwnType.Shallow) { eq_ret = "Bool" }
        }
        f.write_str(eq_ret); f.write_str(" "); f.write_str(dd.name); f.write_str("_eq("); f.write_str(dd.name); f.write_str(" *, "); f.write_str(dd.name); f.write_str(" *);\n")
        for j in 0..ebody.child_count() {
            ref v : Expr = ebody.child(j)
            ref vdd : Declaration = get_payload(v.data)
            if vdd.is_namespace { continue }
            if vdd.explicit_type.len().gt(0) {
                tnc := type_name_to_c(vdd.explicit_type)
                f.write_str(dd.name); f.write_str(" *"); f.write_str(dd.name); f.write_str("_"); f.write_str(vdd.name); f.write_str("("); f.write_str(tnc); f.write_str(");\n")
            } else {
                f.write_str(dd.name); f.write_str(" *"); f.write_str(dd.name); f.write_str("_"); f.write_str(vdd.name); f.write_str("();\n")
            }
        }
    }
    f.write_str("\n")
}

emit_header_global_decls := proc(f: File, core_program: Expr, program: Expr) {
    for prog_idx in 0..2 {
        ref mut prog : Expr = NULL
        if prog_idx.eq(0) { prog = core_program } else { prog = program }
        if is_null(prog) { continue }
        for i in 0..prog.child_count() {
            ref stmt : Expr = prog.child(i)
            if is_exported_top_level_global(stmt).not() { continue }
            ref rhs : Expr = stmt.child(0)
            ref dd : Declaration = get_payload(stmt.data)
            mut ctype := ""
            if stmt.til_type.eq(TilType.Dynamic) { ctype = til_type_to_c(stmt.til_type) }
            else { ctype = c_type_name(stmt.til_type, rhs.struct_name) }
            if dd.own_type.eq(OwnType.Ref) {
                f.write_str("extern "); f.write_str(ctype); f.write_str(" *"); f.write_str(dd.name); f.write_str(";\n")
            } else {
                f.write_str("extern "); f.write_str(ctype); f.write_str(" "); f.write_str(dd.name); f.write_str(";\n")
            }
        }
    }
    f.write_str("\n")
}

build_forward_header := proc(core_program: Expr, program: Expr, fwd_path: Str) returns shallow I32 {
    f := File.new(fwd_path, true)
    f.write_str("#pragma once\n#include \"ext.h\"\n\n")
    emit_header_forward_decls(f, core_program, program)
    emit_header_defs_and_funcs(f, core_program, program)
    emit_header_global_decls(f, core_program, program)
    f.close()
    return 0.to_i32()
}

build_header := proc(core_program: Expr, program: Expr, h_path: Str) returns shallow I32 {
    if has_funcsig_names.not() {
        own funcsig_names.delete()
        funcsig_names = Set.new("Str", Str.size())
        has_funcsig_names = true
        for i in 0..program.child_count() {
            ref stmt : Expr = program.child(i)
            if is_variant(stmt.data, NodeType.Decl) {
                if stmt.child_count().gt(0) {
                    if is_variant(stmt.child(0).data, NodeType.FuncDef) {
                        if stmt.child(0).child_count().eq(0) {
                            ref dd : Declaration = get_payload(stmt.data)
                            funcsig_names.add(own dd.name.clone())
                        }
                    }
                }
            }
        }
    }
    f := File.new(h_path, true)
    f.write_str("#pragma once\n#include \"ext.h\"\n\n")
    emit_header_forward_decls(f, core_program, program)
    emit_header_defs_and_funcs(f, core_program, program)
    emit_header_global_decls(f, core_program, program)
    f.write_str("#include \"ext.h\"\n\n")
    f.close()
    return 0.to_i32()
}

emit_binding_ns_methods := proc(f: File, body: Expr) {
    mut has_ns := false
    for j in 0..body.child_count() {
        ref field : Expr = body.child(j)
        ref fdd : Declaration = get_payload(field.data)
        if fdd.is_namespace.not() { continue }
        if field.child_count().eq(0) { continue }
        if is_variant(field.child(0).data, NodeType.FuncDef).not() { continue }
        ref fdef : Expr = field.child(0)
        ref fd : FunctionDef = get_payload(fdef.data)
        if is_variant(fd.func_type, FuncType.ExtFunc).or(is_variant(fd.func_type, FuncType.ExtProc)) { continue }
        if has_ns.not() { f.write_str("    namespace:\n"); has_ns = true }
        mut kw := "ext_func"
        if is_variant(fd.func_type, FuncType.Proc).or(is_variant(fd.func_type, FuncType.Test)) { kw = "ext_proc" }
        f.write_str("    "); f.write_str(fdd.name); f.write_str(" := "); f.write_str(kw); f.write_str("(")
        for p in 0..fd.nparam {
            if p.gt(0) { f.write_str(", ") }
            ref param : Param = fd.params.get(p)
            if is_variant(param.own_type, OwnType.Own) { f.write_str("own ") }
            f.write_str(param.name); f.write_str(": "); f.write_str(param.ptype)
        }
        f.write_str(")")
        if fd.return_type.len().gt(0) {
            f.write_str(" returns ")
            if is_variant(fd.return_own_type, OwnType.Ref) { f.write_str("ref ") }
            if is_variant(fd.return_own_type, OwnType.Shallow) { f.write_str("shallow ") }
            f.write_str(fd.return_type)
        }
        f.write_str(" {}\n")
    }
}

build_til_binding := proc(core_program: Expr, program: Expr, til_path: Str, lib_name: Str) returns shallow I32 {
    f := File.new(til_path, true)
    f.write_str("// Auto-generated FFI binding for "); f.write_str(lib_name); f.write_str("\n")
    f.write_str("link(\""); f.write_str(lib_name); f.write_str("\")\n\n")
    for i in 0..program.child_count() {
        ref stmt : Expr = program.child(i)
        if is_variant(stmt.data, NodeType.Decl).not() { continue }
        ref dd : Declaration = get_payload(stmt.data)
        if stmt.child_count().eq(0) { continue }
        ref rhs : Expr = stmt.child(0)
        if is_variant(rhs.data, NodeType.StructDef) {
            ref body : Expr = rhs.child(0)
            f.write_str(dd.name); f.write_str(" := struct {\n")
            for j in 0..body.child_count() {
                ref field : Expr = body.child(j)
                ref fdd : Declaration = get_payload(field.data)
                if fdd.is_namespace { continue }
                f.write_str("    ")
                if fdd.is_mut { f.write_str("mut ") }
                if is_variant(fdd.own_type, OwnType.Own) { f.write_str("own ") }
                f.write_str(fdd.name)
                if fdd.explicit_type.len().gt(0) { f.write_str(" : "); f.write_str(fdd.explicit_type) }
                f.write_str(" := ")
                if field.child_count().gt(0) { emit_til_default(f, field.til_type, field.child(0).struct_name) }
                else { f.write_str("0") }
                f.write_str("\n")
            }
            emit_binding_ns_methods(f, body)
            f.write_str("}\n\n")
        } else if is_variant(rhs.data, NodeType.EnumDef) {
            ref body : Expr = rhs.child(0)
            f.write_str(dd.name); f.write_str(" := enum {\n")
            for j in 0..body.child_count() {
                ref v : Expr = body.child(j)
                ref vdd : Declaration = get_payload(v.data)
                if vdd.is_namespace { continue }
                f.write_str("    "); f.write_str(vdd.name)
                if vdd.explicit_type.len().gt(0) { f.write_str(": "); f.write_str(vdd.explicit_type) }
                f.write_str(",\n")
            }
            emit_binding_ns_methods(f, body)
            f.write_str("}\n\n")
        } else if is_variant(rhs.data, NodeType.FuncDef) {
            ref fd : FunctionDef = get_payload(rhs.data)
            if is_variant(fd.func_type, FuncType.ExtFunc).or(is_variant(fd.func_type, FuncType.ExtProc)) { continue }
            if is_variant(fd.func_type, FuncType.Test) { continue }
            mut kw := "ext_func"
            if is_variant(fd.func_type, FuncType.Proc) { kw = "ext_proc" }
            f.write_str(dd.name); f.write_str(" := "); f.write_str(kw); f.write_str("(")
            for p in 0..fd.nparam {
                if p.gt(0) { f.write_str(", ") }
                ref param : Param = fd.params.get(p)
                if is_variant(param.own_type, OwnType.Own) { f.write_str("own ") }
                pi := p.to_i64().to_i32()
                if pi.eq(fd.variadic_index) { f.write_str("..") }
                if pi.eq(fd.kwargs_index) {
                    f.write_str(param.name); f.write_str(": ...")
                } else {
                    f.write_str(param.name); f.write_str(": "); f.write_str(param.ptype)
                }
            }
            f.write_str(")")
            if fd.return_type.len().gt(0) {
                f.write_str(" returns ")
                if is_variant(fd.return_own_type, OwnType.Ref) { f.write_str("ref ") }
                if is_variant(fd.return_own_type, OwnType.Shallow) { f.write_str("shallow ") }
                f.write_str(fd.return_type)
            }
            f.write_str(" {}\n\n")
        }
    }
    f.close()
    return 0.to_i32()
}

compile_lib := proc(c_path: Str, lib_name: Str, ext_c_path: Str, user_c_path: Str, link_flags: Str, include_flags: Str) returns shallow I32 {
    mut uc := user_c_path
    mut lf := link_flags
    mut ifl := include_flags
    if uc.len().eq(0) { uc = "" }
    if lf.len().eq(0) { lf = "" }
    if ifl.len().eq(0) { ifl = "" }

    // Extract directory from ext_c_path for -I flag
    mut ext_dir := "."
    slash := ext_c_path.rfind("/")
    if slash.gte(0) { ext_dir = ext_c_path.substr(0, slash.to_usize()).clone() }

    // Compile library .c to object
    obj_path := "gen/lib/".concat(lib_name).concat(".o")
    mut cmd := "cc -Wall -Wextra -Werror -fPIC -I".concat(ext_dir)
        .concat(" -c ").concat(c_path).concat(" -o ").concat(obj_path)
    mut result := system_cmd(cmd)
    if result.neq(0) {
        println("error: library compilation failed")
        return 1.to_i32()
    }

    // Compile ext.c to object
    ext_obj := "gen/lib/ext.o"
    cmd = "cc -Wall -Wextra -Werror -fPIC -I".concat(ext_dir)
        .concat(" -c ").concat(ext_c_path).concat(" -o ").concat(ext_obj)
    result = system_cmd(cmd)
    if result.neq(0) {
        println("error: ext.c compilation failed")
        return 1.to_i32()
    }

    // Compile user .c to object if present
    mut user_obj := ""
    if uc.len().gt(0) {
        user_obj = "gen/lib/user.o"
        cmd = "cc -Wall -Wextra -Werror -fPIC -I".concat(ext_dir).concat(ifl)
            .concat(" -c ").concat(uc).concat(" -o ").concat(user_obj)
        result = system_cmd(cmd)
        if result.neq(0) {
            println("error: user .c compilation failed")
            return 1.to_i32()
        }
    }

    // Create shared library
    so_path := "gen/lib/lib".concat(lib_name).concat(".so")
    cmd = "cc -shared -Wl,--allow-multiple-definition -o ".concat(so_path)
        .concat(" ").concat(obj_path).concat(" ").concat(ext_obj)
        .concat(" ").concat(user_obj).concat(lf)
    result = system_cmd(cmd)
    if result.neq(0) {
        println("error: shared library creation failed")
        return 1.to_i32()
    }

    // Create static library
    a_path := "gen/lib/lib".concat(lib_name).concat(".a")
    cmd = "ar rcs ".concat(a_path)
        .concat(" ").concat(obj_path).concat(" ").concat(ext_obj)
        .concat(" ").concat(user_obj)
    result = system_cmd(cmd)
    if result.neq(0) {
        println("error: static library creation failed")
        return 1.to_i32()
    }

    return 0.to_i32()
}

compile_c := proc(c_path: Str, bin_path: Str, ext_c_path: Str, user_c_path: Str, link_flags: Str, include_flags: Str) returns shallow I32 {
    mut uc := user_c_path
    mut lf := link_flags
    mut ifl := include_flags
    if uc.len().eq(0) { uc = "" }
    if lf.len().eq(0) { lf = "" }
    if ifl.len().eq(0) { ifl = "" }

    // Extract directory from ext_c_path for -I flag
    mut ext_dir := "."
    slash := ext_c_path.rfind("/")
    if slash.gte(0) { ext_dir = ext_c_path.substr(0, slash.to_usize()).clone() }

    // If link_c files present, compile each to .o separately with -include forward.h
    mut user_part := ""
    if uc.len().gt(0) {
        c_slash := c_path.rfind("/")
        mut c_dir := "."
        if c_slash.gte(0) { c_dir = c_path.substr(0, c_slash.to_usize()).clone() }
        c_dot := c_path.rfind(".")
        mut c_base := c_path
        if c_dot.gt(c_slash) { c_base = c_path.substr(0, c_dot.to_usize()) }
        fwd_path := c_base.concat("_forward.h")

        // Split space-separated link_c files and compile each individually
        files := uc.split(" ")
        mut all_objs := ""
        for fi in 0..files.len() {
            ref file : Str = files.get(fi)
            if file.len().eq(0) { continue }
            user_obj := c_dir.concat("/user_").concat(fi.to_i64().to_str()).concat(".o")

            // Skip -include forward.h for src/c/ files
            mut fwd_flag := " -include ".concat(fwd_path)
            if file.starts_with("src/c/") { fwd_flag = " -Isrc/c -Iboot" }
            obj_cmd := "cc -Wall -Wextra -Werror -I".concat(ext_dir)
                .concat(fwd_flag).concat(ifl).concat(" -c ").concat(file)
                .concat(" -o ").concat(user_obj)

            obj_result := system_cmd(obj_cmd)
            if obj_result.neq(0) {
                println("error: link_c compilation failed for ".concat(file))
                return 1.to_i32()
            }
            all_objs = all_objs.concat(" ").concat(user_obj)
        }
        user_part = all_objs
    }

    cmd := "cc -Wall -Wextra -Werror -g -rdynamic -Wl,--allow-multiple-definition -I".concat(ext_dir)
        .concat(" -o ").concat(bin_path).concat(" ").concat(c_path)
        .concat(" ").concat(ext_c_path).concat(user_part).concat(lf)

    result := system_cmd(cmd)
    if result.neq(0) {
        println("error: C compilation failed")
        return 1.to_i32()
    }
    return 0.to_i32()
}

register_funcsig_prog := proc(prog: Expr) {
    for i in 0..prog.child_count() {
        ref stmt : Expr = prog.child(i)
        if is_variant(stmt.data, NodeType.Decl) {
            ref rhs : Expr = stmt.child(0)
            if is_variant(rhs.data, NodeType.FuncDef) {
                if rhs.child_count().eq(0) {
                    ref dd : Declaration = get_payload(stmt.data)
                    funcsig_names.add(own dd.name.clone())
                }
            }
            if stmt.til_type.eq(TilType.None) {
                if is_variant(rhs.data, NodeType.Ident) {
                    ref rhs_name : Str = get_payload(rhs.data)
                    if funcsig_names.has(rhs_name) {
                        ref dd : Declaration = get_payload(stmt.data)
                        funcsig_names.add(own dd.name.clone())
                    }
                }
            }
        }
    }
}

emit_global_inits_prog := proc(f: File, prog: Expr) {
    for i in 0..prog.child_count() {
        ref gs : Expr = prog.child(i)
        if is_variant(gs.data, NodeType.Decl) {
            ref rhs : Expr = gs.child(0)
            if is_variant(rhs.data, NodeType.FuncDef).or(is_variant(rhs.data, NodeType.StructDef))
                .or(is_variant(rhs.data, NodeType.EnumDef)) { continue }
            if gs.til_type.eq(TilType.None) {
                if is_variant(rhs.data, NodeType.Ident) { continue }
            }
        } else {
            if is_variant(gs.data, NodeType.FCall).not() { continue }
        }
        emit_stmt(f, gs, 1)
    }
}

emit_global_inits := proc(f: File) {
    if has_script_globals.not() { return }
    if is_null(codegen_core_program).not() { emit_global_inits_prog(f, codegen_core_program) }
    if is_null(codegen_program).not() { emit_global_inits_prog(f, codegen_program) }
}

build_register_funcsig_names := proc(core_program: Expr, program: Expr) {
    funcsig_names = Set.new("Str", Str.size())
    has_funcsig_names = true
    for prog_idx in 0..2 {
        ref mut prog : Expr = NULL
        if prog_idx.eq(0) { prog = core_program } else { prog = program }
        if is_null(prog) { continue }
        for i in 0..prog.child_count() {
            ref stmt : Expr = prog.child(i)
            if is_variant(stmt.data, NodeType.Decl) {
                ref rhs : Expr = stmt.child(0)
                if is_variant(rhs.data, NodeType.FuncDef) {
                    if rhs.child_count().eq(0) {
                        ref dd : Declaration = get_payload(stmt.data)
                        funcsig_names.add(own dd.name.clone())
                    }
                }
                if stmt.til_type.eq(TilType.None) {
                    if is_variant(rhs.data, NodeType.Ident) {
                        ref rhs_name : Str = get_payload(rhs.data)
                        if funcsig_names.has(rhs_name) {
                            ref dd : Declaration = get_payload(stmt.data)
                            funcsig_names.add(own dd.name.clone())
                        }
                    }
                }
            }
        }
    }
}

register_lookups_prog := proc(prog: Expr) {
    for i in 0..prog.child_count() {
        ref stmt : Expr = prog.child(i)
        if is_variant(stmt.data, NodeType.Decl) {
            ref rhs : Expr = stmt.child(0)
            if is_variant(rhs.data, NodeType.StructDef).or(is_variant(rhs.data, NodeType.EnumDef)) {
                ref dd : Declaration = get_payload(stmt.data)
                ref body : Expr = rhs.child(0)
                v : Dynamic = malloc(I64.size())
                write_ptr(v, body)
                struct_bodies.set(own dd.name.clone(), own v)
                for j in 0..body.child_count() {
                    ref field : Expr = body.child(j)
                    ref fd : Declaration = get_payload(field.data)
                    if fd.is_namespace.not() { continue }
                    if field.child_count().eq(0) { continue }
                    if is_variant(field.child(0).data, NodeType.FuncDef).not() { continue }
                    ref fdef : Expr = field.child(0)
                    key := dd.name.concat("_").concat(fd.name)
                    fv : Dynamic = malloc(I64.size())
                    write_ptr(fv, fdef)
                    func_defs.set(own key, own fv)
                    if fdef.child_count().gt(0) {
                        ref fbody : Expr = fdef.child(0)
                        for k in 0..fbody.child_count() {
                            ref nested : Expr = fbody.child(k)
                            if is_variant(nested.data, NodeType.Decl).not() { continue }
                            if nested.child_count().eq(0) { continue }
                            if is_variant(nested.child(0).data, NodeType.FuncDef).not() { continue }
                            ref nfdef : Expr = nested.child(0)
                            ref nd : Declaration = get_payload(nested.data)
                            nv : Dynamic = malloc(I64.size())
                            write_ptr(nv, nfdef)
                            func_defs.set(own nd.name.clone(), own nv)
                        }
                    }
                }
            }
            if is_variant(rhs.data, NodeType.FuncDef) {
                ref dd2 : Declaration = get_payload(stmt.data)
                fv2 : Dynamic = malloc(I64.size())
                write_ptr(fv2, rhs)
                func_defs.set(own dd2.name.clone(), own fv2)
            }
        }
    }
}

// #135: can't use for prog_idx in 0..2 with ref mut prog here because
// the clone bug makes stored pointers point to cloned nodes
build_register_lookups := proc(core_program: Expr, program: Expr) {
    struct_bodies = Map.new("Str", Str.size(), "Dynamic", I64.size())
    func_defs = Map.new("Str", Str.size(), "Dynamic", I64.size())
    stack_locals = Set.new("Str", Str.size())
    stack_local_types = Map.new("Str", Str.size(), "Str", Str.size())
    unsafe_to_hoist = Set.new("Str", Str.size())
    ref_locals = Set.new("Str", Str.size())
    if is_null(core_program).not() { register_lookups_prog(core_program) }
    register_lookups_prog(program)
}

emit_dyn_call_bodies := proc(f: File, core_program: Expr, program: Expr) {
    mut dyn_methods := Vec.new("DynCallInfo", DynCallInfo.size())
    if is_null(core_program).not() { collect_dyn_methods(core_program, dyn_methods) }
    collect_dyn_methods(program, dyn_methods)
    for m in 0..dyn_methods.len() {
        ref info : DynCallInfo = dyn_methods.get(m)
        ref method : Str = info.method
        mut ret_type := "void "
        if info.has_return { ret_type = "void *" }
        if info.nargs.eq(1) {
            f.write_str(ret_type); f.write_str("dyn_call_"); f.write_str(method); f.write_str("(Str *type_name, void *val) {\n")
        } else {
            f.write_str(ret_type); f.write_str("dyn_call_"); f.write_str(method); f.write_str("(Str *type_name, void *val, void *arg2) {\n")
        }
        for prog_idx in 0..2 {
            ref mut prog : Expr = NULL
            if prog_idx.eq(0) { prog = core_program } else { prog = program }
            if is_null(prog) { continue }
            for i in 0..prog.child_count() {
                ref stmt : Expr = prog.child(i)
                if is_variant(stmt.data, NodeType.Decl).not() { continue }
                ref def : Expr = stmt.child(0)
                if is_variant(def.data, NodeType.StructDef).not().and(is_variant(def.data, NodeType.EnumDef).not()) { continue }
                ref dd : Declaration = get_payload(stmt.data)
                ref body : Expr = def.child(0)
                ref mut method_fdef : Expr = NULL
                for j in 0..body.child_count() {
                    ref field : Expr = body.child(j)
                    ref fdd : Declaration = get_payload(field.data)
                    if fdd.is_namespace {
                        if fdd.name.eq(method) {
                            if field.child_count().gt(0) {
                                if is_variant(field.child(0).data, NodeType.FuncDef) {
                                    method_fdef = field.child(0)
                                    break
                                }
                            }
                        }
                    }
                }
                if is_null(method_fdef) { continue }
                ref mfd : FunctionDef = get_payload(method_fdef.data)
                mut arg1 := "val"
                if mfd.params.len().gt(0) {
                    ref p0 : Param = mfd.params.get(0)
                    if is_variant(p0.own_type, OwnType.Shallow) { arg1 = "*(".concat(dd.name).concat(" *)val") }
                }
                mut arg2_s := "arg2"
                if info.nargs.eq(2) {
                    if mfd.params.len().gt(1) {
                        if mfd.nparam.gt(1) {
                            ref p1 : Param = mfd.params.get(1)
                            if is_variant(p1.own_type, OwnType.Shallow) { arg2_s = "*(".concat(dd.name).concat(" *)arg2") }
                        }
                    }
                }
                ret_sh := is_variant(mfd.return_own_type, OwnType.Shallow)
                mut ret_ct := ""
                if info.has_return {
                    if ret_sh {
                        if mfd.return_type.len().gt(0) { ret_ct = type_name_to_c_value(mfd.return_type) }
                    }
                }
                tlen := dd.name.len().to_i64().to_u64()
                if info.nargs.eq(2) {
                    if info.has_return {
                        if ret_sh {
                            f.write_str("    if (type_name->count == "); emit_u64(f, tlen); f.write_str("ULL && memcmp(type_name->c_str, \""); f.write_str(dd.name); f.write_str("\", "); emit_u64(f, tlen); f.write_str("ULL) == 0) { "); f.write_str(ret_ct); f.write_str(" *_r = malloc(sizeof("); f.write_str(ret_ct); f.write_str(")); *_r = "); f.write_str(dd.name); f.write_str("_"); f.write_str(method); f.write_str("("); f.write_str(arg1); f.write_str(", "); f.write_str(arg2_s); f.write_str("); return _r; }\n")
                        } else {
                            f.write_str("    if (type_name->count == "); emit_u64(f, tlen); f.write_str("ULL && memcmp(type_name->c_str, \""); f.write_str(dd.name); f.write_str("\", "); emit_u64(f, tlen); f.write_str("ULL) == 0) return (void *)"); f.write_str(dd.name); f.write_str("_"); f.write_str(method); f.write_str("("); f.write_str(arg1); f.write_str(", "); f.write_str(arg2_s); f.write_str(");\n")
                        }
                    } else {
                        f.write_str("    if (type_name->count == "); emit_u64(f, tlen); f.write_str("ULL && memcmp(type_name->c_str, \""); f.write_str(dd.name); f.write_str("\", "); emit_u64(f, tlen); f.write_str("ULL) == 0) { "); f.write_str(dd.name); f.write_str("_"); f.write_str(method); f.write_str("("); f.write_str(arg1); f.write_str(", "); f.write_str(arg2_s); f.write_str("); return; }\n")
                    }
                } else {
                    if info.has_return {
                        if ret_sh {
                            f.write_str("    if (type_name->count == "); emit_u64(f, tlen); f.write_str("ULL && memcmp(type_name->c_str, \""); f.write_str(dd.name); f.write_str("\", "); emit_u64(f, tlen); f.write_str("ULL) == 0) { "); f.write_str(ret_ct); f.write_str(" *_r = malloc(sizeof("); f.write_str(ret_ct); f.write_str(")); *_r = "); f.write_str(dd.name); f.write_str("_"); f.write_str(method); f.write_str("("); f.write_str(arg1); f.write_str("); return _r; }\n")
                        } else {
                            f.write_str("    if (type_name->count == "); emit_u64(f, tlen); f.write_str("ULL && memcmp(type_name->c_str, \""); f.write_str(dd.name); f.write_str("\", "); emit_u64(f, tlen); f.write_str("ULL) == 0) return (void *)"); f.write_str(dd.name); f.write_str("_"); f.write_str(method); f.write_str("("); f.write_str(arg1); f.write_str(");\n")
                        }
                    } else {
                        f.write_str("    if (type_name->count == "); emit_u64(f, tlen); f.write_str("ULL && memcmp(type_name->c_str, \""); f.write_str(dd.name); f.write_str("\", "); emit_u64(f, tlen); f.write_str("ULL) == 0) { "); f.write_str(dd.name); f.write_str("_"); f.write_str(method); f.write_str("("); f.write_str(arg1); f.write_str("); return; }\n")
                    }
                }
            }
        }
        f.write_str("    fprintf(stderr, \"dyn_call: unknown type for "); f.write_str(method); f.write_str("\\n\");\n")
        f.write_str("    exit(1);\n")
        f.write_str("}\n\n")
    }
    own dyn_methods.delete()
}

emit_dyn_has_bodies := proc(f: File, core_program: Expr, program: Expr) {
    // Find dyn_has_method to check return_is_shallow
    mut dyn_has_shallow := false
    for prog_idx in 0..2 {
        if dyn_has_shallow { break }
        ref mut prog : Expr = NULL
        if prog_idx.eq(0) { prog = core_program } else { prog = program }
        if is_null(prog) { continue }
        for i in 0..prog.child_count() {
            ref stmt : Expr = prog.child(i)
            if is_variant(stmt.data, NodeType.Decl) {
                if stmt.child_count().gt(0) {
                    if is_variant(stmt.child(0).data, NodeType.FuncDef) {
                        ref dd : Declaration = get_payload(stmt.data)
                        if dd.name.eq("dyn_has_method") {
                            ref fd : FunctionDef = get_payload(stmt.child(0).data)
                            dyn_has_shallow = is_variant(fd.return_own_type, OwnType.Shallow)
                            break
                        }
                    }
                }
            }
        }
    }
    mut dyn_has_ret := "Bool *"
    if dyn_has_shallow { dyn_has_ret = "Bool" }
    mut has_methods := Vec.new("Str", Str.size())
    if is_null(core_program).not() { collect_dyn_has_methods(core_program, has_methods) }
    collect_dyn_has_methods(program, has_methods)
    for m in 0..has_methods.len() {
        ref method : Str = has_methods.get(m)
        f.write_str(dyn_has_ret); f.write_str(" dyn_has_"); f.write_str(method); f.write_str("(Str *type_name) {\n    (void)type_name;\n")
        for prog_idx in 0..2 {
            ref mut prog : Expr = NULL
            if prog_idx.eq(0) { prog = core_program } else { prog = program }
            if is_null(prog) { continue }
            for i in 0..prog.child_count() {
                ref stmt : Expr = prog.child(i)
                if is_variant(stmt.data, NodeType.Decl).not() { continue }
                ref rhs : Expr = stmt.child(0)
                if is_variant(rhs.data, NodeType.StructDef).not().and(is_variant(rhs.data, NodeType.EnumDef).not()) { continue }
                ref dd : Declaration = get_payload(stmt.data)
                ref body : Expr = rhs.child(0)
                mut found := false
                for j in 0..body.child_count() {
                    ref field : Expr = body.child(j)
                    ref fdd : Declaration = get_payload(field.data)
                    if fdd.is_namespace {
                        if fdd.name.eq(method) { found = true; break }
                    }
                }
                if found.not() { continue }
                if dyn_has_shallow {
                    f.write_str("    if (type_name->count == "); emit_u64(f, dd.name.len().to_i64().to_u64()); f.write_str("ULL && memcmp(type_name->c_str, \""); f.write_str(dd.name); f.write_str("\", "); emit_u64(f, dd.name.len().to_i64().to_u64()); f.write_str("ULL) == 0) return 1;\n")
                } else {
                    f.write_str("    if (type_name->count == "); emit_u64(f, dd.name.len().to_i64().to_u64()); f.write_str("ULL && memcmp(type_name->c_str, \""); f.write_str(dd.name); f.write_str("\", "); emit_u64(f, dd.name.len().to_i64().to_u64()); f.write_str("ULL) == 0) { Bool *r = malloc(sizeof(Bool)); *r = 1; return r; }\n")
                }
            }
        }
        if dyn_has_shallow { f.write_str("    return 0;\n") }
        else { f.write_str("    Bool *r = malloc(sizeof(Bool)); *r = 0; return r;\n") }
        f.write_str("}\n\n")
    }
    own has_methods.delete()
}

emit_collection_helpers := proc(f: File, core_program: Expr, program: Expr) {
    mut coll_infos := Vec.new("CollectionInfo", CollectionInfo.size())
    if is_null(core_program).not() { collect_collection_builtins(core_program, coll_infos) }
    collect_collection_builtins(program, coll_infos)
    for i in 0..coll_infos.len() {
        ref ci : CollectionInfo = coll_infos.get(i)
        et := ci.type_name
        et_len := et.len().to_i64().to_u64()
        if ci.is_vec.neq(0) {
            f.write_str("Vec *vec_of_"); f.write_str(et); f.write_str("(int count, ...) {\n")
            f.write_str("    USize _esz = sizeof("); f.write_str(et); f.write_str(");\n")
            f.write_str("    Vec *_v = Vec_new(&(Str){.c_str = (U8 *)\""); f.write_str(et); f.write_str("\", .count = "); emit_u64(f, et_len); f.write_str("ULL, .cap = TIL_CAP_LIT}, &(USize){_esz});\n")
            f.write_str("    va_list ap; va_start(ap, count);\n")
            f.write_str("    for (int _i = 0; _i < count; _i++) {\n")
            cn := et.concat("_clone")
            is_shallow := callee_returns_shallow(cn)
            if is_shallow {
                f.write_str("        "); f.write_str(et); f.write_str(" *_val = malloc(sizeof("); f.write_str(et); f.write_str(")); *_val = "); f.write_str(et); f.write_str("_clone(va_arg(ap, "); f.write_str(et); f.write_str(" *));\n")
            } else {
                f.write_str("        "); f.write_str(et); f.write_str(" *_val = "); f.write_str(et); f.write_str("_clone(va_arg(ap, "); f.write_str(et); f.write_str(" *));\n")
            }
            f.write_str("        Vec_push(_v, _val);\n")
            f.write_str("    }\n")
            f.write_str("    va_end(ap);\n")
            f.write_str("    return _v;\n")
            f.write_str("}\n\n")
        } else {
            f.write_str("Array *array_of_"); f.write_str(et); f.write_str("(int count, ...) {\n")
            f.write_str("    USize _esz = sizeof("); f.write_str(et); f.write_str(");\n")
            f.write_str("    USize _cap = count;\n")
            f.write_str("    Array *_a = Array_new(&(Str){.c_str = (U8 *)\""); f.write_str(et); f.write_str("\", .count = "); emit_u64(f, et_len); f.write_str("ULL, .cap = TIL_CAP_LIT}, &(USize){_esz}, &(USize){_cap});\n")
            f.write_str("    va_list ap; va_start(ap, count);\n")
            f.write_str("    for (int _i = 0; _i < count; _i++) {\n")
            f.write_str("        USize _idx = _i;\n")
            cn := et.concat("_clone")
            is_shallow := callee_returns_shallow(cn)
            if is_shallow {
                f.write_str("        "); f.write_str(et); f.write_str(" *_val = malloc(sizeof("); f.write_str(et); f.write_str(")); *_val = "); f.write_str(et); f.write_str("_clone(va_arg(ap, "); f.write_str(et); f.write_str(" *));\n")
            } else {
                f.write_str("        "); f.write_str(et); f.write_str(" *_val = "); f.write_str(et); f.write_str("_clone(va_arg(ap, "); f.write_str(et); f.write_str(" *));\n")
            }
            f.write_str("        Array_set(_a, &(USize){_idx}, _val);\n")
            f.write_str("    }\n")
            f.write_str("    va_end(ap);\n")
            f.write_str("    return _a;\n")
            f.write_str("}\n\n")
        }
    }
    own coll_infos.delete()
}

emit_global_declarations := proc(f: File, core_program: Expr, program: Expr) {
    script_globals = Set.new("Str", Str.size())
    has_script_globals = true
    ref_globals = Set.new("Str", Str.size())
    has_ref_globals = true
    for prog_idx in 0..2 {
        ref mut prog : Expr = NULL
        if prog_idx.eq(0) { prog = core_program } else { prog = program }
        if is_null(prog) { continue }
        for i in 0..prog.child_count() {
            ref stmt : Expr = prog.child(i)
            if is_exported_top_level_global(stmt).not() { continue }
            ref rhs : Expr = stmt.child(0)
            mut ctype := ""
            if stmt.til_type.eq(TilType.Dynamic) { ctype = til_type_to_c(stmt.til_type) }
            else { ctype = c_type_name(stmt.til_type, rhs.struct_name) }
            ref dd : Declaration = get_payload(stmt.data)
            if dd.own_type.eq(OwnType.Ref) {
                f.write_str(ctype); f.write_str(" *"); f.write_str(dd.name); f.write_str(";\n")
                ref_globals.add(own dd.name.clone())
            } else {
                f.write_str(ctype); f.write_str(" "); f.write_str(dd.name); f.write_str(";\n")
                script_globals.add(own dd.name.clone())
            }
        }
    }
    f.write_str("\n")
}

emit_test_main := proc(f: File, program: Expr) {
    f.write_str("int main(void) {\n")
    emit_ns_inits(f, 1)
    emit_global_inits(f)
    mut test_count : I32 = 0
    for i in 0..program.child_count() {
        ref stmt : Expr = program.child(i)
        if is_variant(stmt.data, NodeType.Decl).not() { continue }
        ref rhs : Expr = stmt.child(0)
        if is_variant(rhs.data, NodeType.FuncDef).not() { continue }
        ref fd : FunctionDef = get_payload(rhs.data)
        if is_variant(fd.func_type, FuncType.Test).not() { continue }
        ref dd : Declaration = get_payload(stmt.data)
        f.write_str("    "); f.write_str(dd.name); f.write_str("();\n")
        f.write_str("    fprintf(stderr, \"  pass: %s\\n\", \""); f.write_str(dd.name); f.write_str("\");\n")
        test_count = test_count.add(1.to_i32())
    }
    if test_count.eq(0.to_i32()) {
        f.write_str("    fprintf(stderr, \"no tests found\\n\");\n")
    } else {
        f.write_str("    fprintf(stderr, \""); emit_i32(f, test_count); f.write_str("/"); emit_i32(f, test_count); f.write_str(" tests passed\\n\");\n")
    }
    f.write_str("    return 0;\n")
    f.write_str("}\n")
}

emit_script_main := proc(f: File, program: Expr) {
    f.write_str("int main(void) {\n")
    emit_ns_inits(f, 1)
    unsafe_to_hoist = Set.new("Str", Str.size())
    collect_unsafe_to_hoist(program)
    for i in 0..program.child_count() {
        ref stmt : Expr = program.child(i)
        if is_variant(stmt.data, NodeType.Decl) {
            ref rhs : Expr = stmt.child(0)
            if is_variant(rhs.data, NodeType.FuncDef).or(is_variant(rhs.data, NodeType.StructDef)).or(is_variant(rhs.data, NodeType.EnumDef)) { continue }
        }
        emit_stmt(f, stmt, 1)
    }
    f.write_str("    return 0;\n")
    f.write_str("}\n")
    own script_globals.delete()
    has_script_globals = false
}

emit_function_bodies := proc(f: File, core_program: Expr, program: Expr, mode: Mode, shallow is_lib: Bool) {
    for prog_idx in 0..2 {
        ref mut prog : Expr = NULL
        if prog_idx.eq(0) { prog = core_program } else { prog = program }
        if is_null(prog) { continue }
        for i in 0..prog.child_count() {
            ref stmt : Expr = prog.child(i)
            if is_variant(stmt.data, NodeType.Decl) {
                ref dd : Declaration = get_payload(stmt.data)
                ref rhs : Expr = stmt.child(0)
                if is_variant(rhs.data, NodeType.StructDef) {
                    emit_struct_funcs(f, dd.name, rhs, is_lib)
                } else if is_variant(rhs.data, NodeType.EnumDef) {
                    emit_enum_def(f, dd.name, rhs)
                    f.write_str("\n")
                } else if is_variant(rhs.data, NodeType.FuncDef) {
                    ref fd : FunctionDef = get_payload(rhs.data)
                    if is_variant(fd.func_type, FuncType.ExtFunc).or(is_variant(fd.func_type, FuncType.ExtProc)) { continue }
                    if rhs.child_count().eq(0) { continue }
                    emit_func_def(f, dd.name, rhs, mode, false)
                    f.write_str("\n")
                }
            }
        }
    }
}

emit_ext_func_declarations := proc(f: File, program: Expr) {
    for i in 0..program.child_count() {
        ref stmt : Expr = program.child(i)
        if is_variant(stmt.data, NodeType.Decl).not() { continue }
        if stmt.child_count().eq(0) { continue }
        if is_variant(stmt.child(0).data, NodeType.FuncDef).not() { continue }
        ref fdef : Expr = stmt.child(0)
        ref fd : FunctionDef = get_payload(fdef.data)
        if is_variant(fd.func_type, FuncType.ExtFunc).not().and(is_variant(fd.func_type, FuncType.ExtProc).not()) { continue }
        ref dd : Declaration = get_payload(stmt.data)
        if is_skip_ext_decl(dd.name) { continue }
        if fd.return_type.len().gt(0) {
            mut rt := ""
            if is_variant(fd.return_own_type, OwnType.Shallow) { rt = type_name_to_c_value(fd.return_type) }
            else { rt = type_name_to_c(fd.return_type) }
            f.write_str(rt); f.write_str(" "); fc := func_to_c(dd.name); f.write_str(fc); f.write_str("(")
        } else {
            f.write_str("void "); fc := func_to_c(dd.name); f.write_str(fc); f.write_str("(")
        }
        emit_param_list(f, fdef, false)
        f.write_str(");\n")
    }
    f.write_str("\n")
}

emit_lib_init := proc(f: File) {
    f.write_str("__attribute__((constructor))\nstatic void _til_lib_init(void) {\n")
    emit_ns_inits(f, 1)
    emit_global_inits(f)
    f.write_str("}\n\n")
}

build := ext_func(core_program: Expr, program: Expr, mode: Mode, shallow run_tests: Bool, path: Str, c_output_path: Str) returns shallow I32 {}

