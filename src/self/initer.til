mode lib

import("parser.til")

TypeBinding := struct {
    mut name := ""
    mut type := TilType.Unknown
    mut func_type := FuncType.None
    mut is_mut := false
    mut path := ""
    mut line : U32 = 0
    mut col : U32 = 0
    mut is_param := false
    mut own_type := OwnType.Shallow
    mut is_alias := false
    mut is_type_alias := false
    mut alias_target := ""
    ref mut struct_def : Expr = NULL
    ref mut func_def : Expr = NULL
    mut is_builtin := false
    mut used := false
namespace:
    eq := func(a: TypeBinding, b: TypeBinding) returns shallow Bool {
        return a.name.eq(b.name)
    }
    to_str := func(self: TypeBinding) returns Str {
        if is_null(self.name) { return "TypeBinding" }
        return self.name.clone()
    }
}

// Active file path for diagnostics / bindings.
mut initer_path := ""

ScopeFind := enum { NotFound, Found: TypeBinding }

TypeScope := struct {
    mut bindings := Map.new("Str", Str.size(), "TypeBinding", TypeBinding.size())
    ref mut parent : TypeScope = NULL
namespace:
    get_binding := func(self: TypeScope, name: Str) returns ref TypeBinding {
        if self.bindings.has(name) {
            ref b : TypeBinding = self.bindings.get(name)
            return b
        }
        if is_null(self.parent).not() {
            ref pb : TypeBinding = self.parent.get_binding(name)
            return pb
        }
        return NULL
    }
    find := func(self: TypeScope, name: Str) returns ScopeFind {
        ref b : TypeBinding = self.get_binding(name)
        if is_null(b).not() {
            return ScopeFind.Found(b)
        }
        return ScopeFind.NotFound
    }
    get_type := func(self: TypeScope, name: Str) returns TilType {
        ref b : TypeBinding = self.get_binding(name)
        if is_null(b).not() { return b.type.clone() }
        return TilType.Unknown
    }
    get_func_type := func(self: TypeScope, name: Str) returns shallow FuncType {
        ref b : TypeBinding = self.get_binding(name)
        if is_null(b).not() { return b.func_type }
        return FuncType.None
    }
    get_struct := func(self: TypeScope, name: Str) returns ref Expr {
        if self.bindings.has(name) {
            ref b : TypeBinding = self.bindings.get(name)
            if is_null(b.struct_def).not() { return b.struct_def }
        }
        if is_null(self.parent).not() {
            return self.parent.get_struct(name)
        }
        return NULL
    }
    is_mut := func(self: TypeScope, name: Str) returns shallow Bool {
        ref b : TypeBinding = self.get_binding(name)
        if is_null(b).not() { return b.is_mut }
        return false
    }
    set := func(mut self: TypeScope, name: Str, type: TilType,
        shallow func_type: FuncType, shallow is_mut: Bool,
        path: Str,
        shallow line: U32, shallow col: U32,
        shallow is_param: Bool, shallow own_type: OwnType) {
            if self.bindings.has(name) {
                ref mut b : TypeBinding = self.bindings.get(name)
                b.type = type
                b.func_type = func_type
                b.is_mut = is_mut
                b.path = path.clone()
                b.line = line
                b.col = col
                b.is_param = is_param
                b.own_type = own_type
                return
            }
            nb := TypeBinding(name = name.clone(), type = type.clone(),
                func_type = func_type, is_mut = is_mut,
                path = path.clone(),
                line = line, col = col,
                is_param = is_param, own_type = own_type)
            self.bindings.set(own name.clone(), own nb)
        }
}

ImportUnit := struct {
    mut mode := Mode()
    own mut ast := Expr.new(NodeType.Body, 0, 0)
    mut imports := Vec.new("Str", Str.size())
}

Context := struct {
    mut mode := Mode()
    mut path := ""
    mut path_modes := Map.new("Str", Str.size(), "Mode", Mode.size())

    // Import tracking (rstil-style). Map path -> (mode, ast).
    mut imported := Map.new("Str", Str.size(), "ImportUnit", ImportUnit.size())
    mut imports_init_done := Set.new("Str", Str.size())
    mut imports_typer_done := Set.new("Str", Str.size())
    mut imports_precomp_done := Set.new("Str", Str.size())
    mut imports_eval_done := Set.new("Str", Str.size())

    mut scope := TypeScope()
    mut is_repl := false
}

align_up := func(shallow offset: I32, shallow align: I32) returns shallow I32 {
    return offset.add(align).sub(1).and(align.sub(1).xor(-1.to_i32()))
}

type_from_name_init := func(name: Str, scope: TypeScope) returns TilType {
    if name.eq("I64")  { return TilType.I64 }
    if name.eq("U8")   { return TilType.U8 }
    if name.eq("I16")  { return TilType.I16 }
    if name.eq("I32")  { return TilType.I32 }
    if name.eq("U32")  { return TilType.U32 }
    if name.eq("U64")  { return TilType.U64 }
    if name.eq("USize") { return TilType.U32 }
    if name.eq("Str")  { return TilType.Struct("Str".clone()) }
    if name.eq("Bool") { return TilType.Bool }
    if name.eq("StructDef") { return TilType.Struct("StructDef".clone()) }
    if name.eq("EnumDef") { return TilType.Struct("EnumDef".clone()) }
    if name.eq("Dynamic")   { return TilType.Dynamic }
    if is_null(scope).not() {
        ref b : TypeBinding = scope.get_binding(name)
        if is_null(b).not() {
            if b.is_builtin {
                if is_null(b.struct_def).not() { return b.type }
            }
            if is_null(b.func_def).not() {
                if b.func_def.children.len().eq(0) {
                    return TilType.FuncPtr
                }
            }
        }
        ref sdef : Expr = scope.get_struct(name)
        if is_null(sdef).not() {
            if sdef.node_type.is(NodeType.EnumDef) {
                return TilType.Enum(name.clone())
            }
            return TilType.Struct(name.clone())
        }
    }
    return TilType.Unknown
}

register_struct_def_for_stmt := proc(stmt: Expr, scope: TypeScope) returns shallow I32 {
    if stmt.node_type.is(NodeType.Decl).not() { return 0.to_i32() }
    if stmt.child(0).node_type.is(NodeType.StructDef).not() { return 0.to_i32() }

    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        sname := sdecl.name

        existing_find := scope.find(sname)
        switch existing_find {
        case ScopeFind.Found(existing):
            if is_null(existing.struct_def).not() {
                println(
                    initer_path, ":", stmt.line.to_str(), ":", stmt.col.to_str(),
                    ": error: struct '", sname, "' already declared at ",
                    existing.path, ":", existing.line.to_str(), ":", existing.col.to_str(),
                )
                return 1.to_i32()
            }
        case:
        }

        mut builtin_type := TilType.Struct(sname.clone())
        mut is_builtin := false
        if sname.eq("I64") { builtin_type = TilType.I64; is_builtin = true }
        else if sname.eq("U8") { builtin_type = TilType.U8; is_builtin = true }
        else if sname.eq("I16") { builtin_type = TilType.I16; is_builtin = true }
        else if sname.eq("I32") { builtin_type = TilType.I32; is_builtin = true }
        else if sname.eq("U32") { builtin_type = TilType.U32; is_builtin = true }
        else if sname.eq("U64") { builtin_type = TilType.U64; is_builtin = true }
        else if sname.eq("USize") { builtin_type = TilType.U32; is_builtin = true }
        else if sname.eq("Str") { is_builtin = false }
        else if sname.eq("Bool") { builtin_type = TilType.Bool; is_builtin = true }
        else if sname.eq("StructDef") { is_builtin = false }
        else if sname.eq("FunctionDef") { is_builtin = false }
        else if sname.eq("Dynamic") { builtin_type = TilType.Dynamic; is_builtin = true }

        scope.set(sname, builtin_type, FuncType.None, false, initer_path, stmt.line, stmt.col, false, OwnType.Shallow)
        ref mut b : TypeBinding = scope.get_binding(sname)
        b.struct_def = stmt.child(0)
        b.is_builtin = is_builtin
        return 0.to_i32()
    case:
        UNREACHABLE(__LOC__)
        return 0.to_i32()
    }
}

register_struct_definitions := proc(program: Expr, scope: TypeScope) returns shallow I32 {
    mut errors : I32 = 0
    for stmt : Expr in program.children {
        errors = errors.add(register_struct_def_for_stmt(stmt, scope))
    }
    return errors
}

gen_struct_clone_delete_for_stmt := func(stmt: Expr, scope: TypeScope) {
    if stmt.node_type.is(NodeType.Decl).not() { return }
    if stmt.child(0).node_type.is(NodeType.StructDef).not() { return }

    mut sname := ""
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        sname = sdecl.name
    case:
        UNREACHABLE(__LOC__)
        return
    }
    if sname.eq("Dynamic") { return }

    ref sdef : Expr = stmt.child(0)
    switch sdef.node_type {
    case NodeType.StructDef(sdd):
        mut has_clone := false
        mut has_delete := false
        for d_j : Declaration in sdd.ns_decls {
            ref fd : Declaration = d_j
            if fd.name.eq("clone") { has_clone = true }
            if fd.name.eq("delete") { has_delete = true }
        }

        if has_clone.not() {
            field_names := Vec.new("Str", Str.size())
            field_refs := Vec.new("I32", I32.size())
            for d_j : Declaration in sdd.fields {
                ref fd : Declaration = d_j
                field_names.push(own fd.name.clone())
                mut ref_flag : I32 = 0
                if fd.own_type.eq(OwnType.Ref) {
                    ref_flag = 1
                } else if fd.explicit_type.len().gt(0).and(type_from_name_init(fd.explicit_type, scope).eq(TilType.FuncPtr)) {
                    ref_flag = 1
                }
                field_refs.push(own ref_flag)
            }

            mut func_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
            if field_names.len().eq(0) {
                mut ctor := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col)
                mut ctor_name := Expr.new(NodeType.Ident(sname.clone()), stmt.line, stmt.col)
                ctor.add_child(own ctor_name)

                mut ret := Expr.new(NodeType.Return, stmt.line, stmt.col)
                ret.add_child(own ctor)
                func_body.add_child(own ret)
            } else {
                mut ctor := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col)
                mut ctor_name := Expr.new(NodeType.Ident(sname.clone()), stmt.line, stmt.col)
                ctor.add_child(own ctor_name)

                for j in 0..field_names.len() {
                    ref fname : Str = field_names.get(j)
                    ref fref : I32 = field_refs.get(j)

                    mut self_id := Expr.new(NodeType.Ident("self"), stmt.line, stmt.col)
                    mut field_acc := Expr.new(NodeType.FieldAccess(fname.clone()), stmt.line, stmt.col)
                    field_acc.add_child(own self_id)

                    mut named := Expr.new(NodeType.NamedArg(fname.clone()), stmt.line, stmt.col)
                    if fref.eq(1) {
                        named.add_child(own field_acc)
                    } else {
                        mut clone_acc := Expr.new(NodeType.FieldAccess("clone"), stmt.line, stmt.col)
                        clone_acc.add_child(own field_acc)
                        mut clone_call := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col)
                        clone_call.add_child(own clone_acc)
                        named.add_child(own clone_call)
                    }
                    ctor.add_child(own named)
                }

                mut ret := Expr.new(NodeType.Return, stmt.line, stmt.col)
                ret.add_child(own ctor)
                func_body.add_child(own ret)
            }

            mut func_decl := FunctionDef()
            func_decl.func_type = FuncType.Func
            mut self_pname := "self"
            if field_names.len().eq(0) { self_pname = "_self" }
            func_decl.params.push(own Declaration(name = self_pname, explicit_type = sname.clone(), til_type = til_type_from_explicit_type(sname), own_type = OwnType.Ref))
            func_decl.return_type = sname.clone()
            func_decl.variadic_index = -1.to_i32()
            func_decl.kwargs_index = -1.to_i32()

            mut func_def := Expr.new(NodeType.FuncDef(func_decl), stmt.line, stmt.col)
            func_def.add_child(own func_body)

            sdd.ns_decls.push(own Declaration(name = "clone", default_value = func_def))
        }

        if has_delete.not() {
            del_field_names := Vec.new("Str", Str.size())
            del_field_owns := Vec.new("Bool", Bool.size())
            for d_j : Declaration in sdd.fields {
                ref fd : Declaration = d_j
                if fd.own_type.eq(OwnType.Ref) { continue }
                if fd.explicit_type.len().gt(0).and(type_from_name_init(fd.explicit_type, scope).eq(TilType.FuncPtr)) {
                    continue
                }
                del_field_names.push(own fd.name.clone())
                if fd.own_type.eq(OwnType.Own) {
                    del_field_owns.push(own true)
                } else {
                    del_field_owns.push(own false)
                }
            }

            mut proc_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
            for j in 0..del_field_names.len() {
                ref fname : Str = del_field_names.get(j)
                ref fown : Bool = del_field_owns.get(j)
                mut self_id := Expr.new(NodeType.Ident("self"), stmt.line, stmt.col)
                mut field_acc := Expr.new(NodeType.FieldAccess(fname.clone()), stmt.line, stmt.col)
                field_acc.add_child(own self_id)

                mut del_acc := Expr.new(NodeType.FieldAccess("delete"), stmt.line, stmt.col)
                del_acc.add_child(own field_acc)
                mut del_call := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col)
                set_own_arg(del_call, 0) // signal UFCS own for self arg
                del_call.add_child(own del_acc)

                mut cf_lit := Expr.new(NodeType.LiteralBool(fown), stmt.line, stmt.col)
                del_call.add_child(own cf_lit)
                proc_body.add_child(own del_call)
            }

            mut cond := Expr.new(NodeType.Ident("call_free"), stmt.line, stmt.col)
            mut then_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
            mut free_call := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col)
            mut free_id := Expr.new(NodeType.Ident("free"), stmt.line, stmt.col)
            free_call.add_child(own free_id)
            mut self_arg := Expr.new(NodeType.Ident("self"), stmt.line, stmt.col)
            set_own_arg(free_call, free_call.children.len())
            free_call.add_child(own self_arg)
            then_body.add_child(own free_call)
            mut if_node := Expr.new(NodeType.If, stmt.line, stmt.col)
            if_node.add_child(own cond)
            if_node.add_child(own then_body)
            proc_body.add_child(own if_node)

            mut default_true := Expr.new(NodeType.LiteralBool(true), stmt.line, stmt.col)

            mut proc_decl := FunctionDef()
            proc_decl.func_type = FuncType.Func
            proc_decl.params.push(own Declaration(name = "self", explicit_type = sname.clone(), til_type = til_type_from_explicit_type(sname), own_type = OwnType.Own))
            proc_decl.params.push(own Declaration(name = "call_free", explicit_type = "Bool", til_type = TilType.Bool, own_type = OwnType.Ref, default_value = default_true.clone()))
            proc_decl.variadic_index = -1.to_i32()
            proc_decl.kwargs_index = -1.to_i32()

            mut proc_def := Expr.new(NodeType.FuncDef(proc_decl), stmt.line, stmt.col)
            proc_def.add_child(own proc_body)

            sdd.ns_decls.push(own Declaration(name = "delete", default_value = proc_def))
        }
    case:
        UNREACHABLE(__LOC__)
    }
}

generate_missing_struct_clones_and_deletes := func(program: Expr, scope: TypeScope) {
    for stmt : Expr in program.children {
        gen_struct_clone_delete_for_stmt(stmt, scope)
    }
}

register_enum_definition := proc(stmt: Expr, scope: TypeScope) returns shallow I32 {
    switch stmt.node_type {
    case NodeType.Decl(edecl):
        ename := edecl.name

        existing_find := scope.find(ename)
        switch existing_find {
        case ScopeFind.Found(existing):
            if is_null(existing.struct_def).not() {
                println(
                    initer_path, ":", stmt.line.to_str(), ":", stmt.col.to_str(),
                    ": error: enum '", ename, "' already declared at ",
                    existing.path, ":", existing.line.to_str(), ":", existing.col.to_str(),
                )
                return 1
            }
        case:
        }

        scope.set(ename, TilType.Enum(ename.clone()), FuncType.None, false, initer_path, stmt.line, stmt.col, false, OwnType.Shallow)
        ref mut b : TypeBinding = scope.get_binding(ename)
        b.struct_def = stmt.child(0)
        return 0
    case:
        UNREACHABLE(__LOC__)
        return 0
    }
}

collect_enum_variants := func(enum_def: Expr, mut variant_names: Vec, mut variant_types: Vec, mut has_payloads: Bool) {
    switch enum_def.node_type {
    case NodeType.EnumDef(edd):
        has_payloads = edd.payload_types.len().gt(0)
        for j in 0..edd.variants.len() {
            ref vn : Str = edd.variants.get(j)
            variant_names.push(own vn.clone())
            idx := j.to_i64()
            if edd.payload_types.has(idx) {
                ref pt : Str = edd.payload_types.get(idx)
                variant_types.push(own pt.clone())
            } else {
                variant_types.push(own "".clone())
            }
        }
    case:
        UNREACHABLE(__LOC__)
    }
}

generate_enum_variant_constructors := func(enum_def: Expr, ename: Str, shallow line: U32, shallow col: U32, variant_names: Vec, variant_types: Vec, shallow has_payloads: Bool) {
    switch enum_def.node_type {
    case NodeType.EnumDef(evc_edd):
        if has_payloads.not() {
            for j in 0..variant_names.len() {
                ref vname : Str = variant_names.get(j)
                mut lit := Expr.new(NodeType.LiteralNum(j.to_str()), line, col)
                evc_edd.ns_decls.push(own Declaration(name = vname.clone(), default_value = lit))
            }
            return
        }

        for j in 0..variant_names.len() {
            mut func_decl := FunctionDef()
            func_decl.func_type = FuncType.ExtFunc
            ref vtype : Str = variant_types.get(j)
            if vtype.len().gt(0) {
                param := Declaration(name = "val", explicit_type = vtype.clone(), til_type = til_type_from_explicit_type(vtype), own_type = OwnType.Ref)
                func_decl.params.push(own param)
            }
            func_decl.return_type = ename.clone()
            func_decl.variadic_index = -1.to_i32()
            func_decl.kwargs_index = -1.to_i32()

            mut func_def := Expr.new(NodeType.FuncDef(func_decl), line, col)
            mut func_body := Expr.new(NodeType.Body, line, col)
            func_def.add_child(own func_body)

            ref vname : Str = variant_names.get(j)
            evc_edd.ns_decls.push(own Declaration(name = vname.clone(), default_value = func_def))
        }
    case:
        UNREACHABLE(__LOC__)
    }
}

generate_enum_is_method := func(enum_def: Expr, ename: Str, shallow line: U32, shallow col: U32) {
    mut func_body := Expr.new(NodeType.Body, line, col)
    mut is_id := Expr.new(NodeType.Ident("is"), line, col)
    mut self_id := Expr.new(NodeType.Ident("self"), line, col)
    mut other_id := Expr.new(NodeType.Ident("other"), line, col)
    mut is_call := Expr.new(NodeType.FCall(FCallData()), line, col)
    is_call.add_child(own is_id)
    is_call.add_child(own self_id)
    is_call.add_child(own other_id)
    mut ret := Expr.new(NodeType.Return, line, col)
    ret.add_child(own is_call)
    func_body.add_child(own ret)

    mut func_decl := FunctionDef()
    func_decl.func_type = FuncType.Func
    self_param := Declaration(name = "self", explicit_type = ename.clone(), til_type = til_type_from_explicit_type(ename), own_type = OwnType.Ref)
    other_param := Declaration(name = "other", explicit_type = ename.clone(), til_type = til_type_from_explicit_type(ename), own_type = OwnType.Ref)
    func_decl.params.push(own self_param)
    func_decl.params.push(own other_param)
    func_decl.return_type = "Bool"
    func_decl.return_own_type = OwnType.Shallow
    func_decl.variadic_index = -1.to_i32()
    func_decl.kwargs_index = -1.to_i32()

    mut func_def := Expr.new(NodeType.FuncDef(func_decl), line, col)
    func_def.add_child(own func_body)

    switch enum_def.node_type {
    case NodeType.EnumDef(eis_edd):
        eis_edd.ns_decls.push(own Declaration(name = "is", default_value = func_def))
    case:
        UNREACHABLE(__LOC__)
    }
}

generate_enum_eq_method := func(enum_def: Expr, ename: Str, shallow line: U32, shallow col: U32, variant_names: Vec, variant_types: Vec, scope: TypeScope) {
    mut func_body := Expr.new(NodeType.Body, line, col)
    for j in 0..variant_names.len() {
        ref vn : Str = variant_names.get(j)
        mut iv1 := Expr.new(NodeType.Ident("is"), line, col)
        mut self_id := Expr.new(NodeType.Ident("self"), line, col)
        mut et1 := Expr.new(NodeType.Ident(ename.clone()), line, col)
        mut vr1 := Expr.new(NodeType.FieldAccess(vn.clone()), line, col)
        vr1.add_child(own et1)
        mut is_call := Expr.new(NodeType.FCall(FCallData()), line, col)
        is_call.add_child(own iv1)
        is_call.add_child(own self_id)
        is_call.add_child(own vr1)

        mut then_body := Expr.new(NodeType.Body, line, col)

        ref vtype : Str = variant_types.get(j)
        if vtype.len().gt(0) {
            is_funcsig := type_from_name_init(vtype, scope).eq(TilType.FuncPtr)

            mut iv2 := Expr.new(NodeType.Ident("is"), line, col)
            mut other_id := Expr.new(NodeType.Ident("other"), line, col)
            mut et2 := Expr.new(NodeType.Ident(ename.clone()), line, col)
            mut vr2 := Expr.new(NodeType.FieldAccess(vn.clone()), line, col)
            vr2.add_child(own et2)
            mut is_call2 := Expr.new(NodeType.FCall(FCallData()), line, col)
            is_call2.add_child(own iv2)
            is_call2.add_child(own other_id)
            is_call2.add_child(own vr2)
            mut not_acc := Expr.new(NodeType.FieldAccess("not"), line, col)
            not_acc.add_child(own is_call2)
            mut not_call := Expr.new(NodeType.FCall(FCallData()), line, col)
            not_call.add_child(own not_acc)

            mut ret_false := Expr.new(NodeType.Return, line, col)
            mut false_lit := Expr.new(NodeType.LiteralBool(false), line, col)
            ret_false.add_child(own false_lit)
            mut guard_body := Expr.new(NodeType.Body, line, col)
            guard_body.add_child(own ret_false)
            mut guard_if := Expr.new(NodeType.If, line, col)
            guard_if.add_child(own not_call)
            guard_if.add_child(own guard_body)
            then_body.add_child(own guard_if)

            if is_funcsig {
                mut ret_true := Expr.new(NodeType.Return, line, col)
                mut true_lit := Expr.new(NodeType.LiteralBool(true), line, col)
                ret_true.add_child(own true_lit)
                then_body.add_child(own ret_true)
            } else {
                mut gp1 := Expr.new(NodeType.Ident("get_payload"), line, col)
                mut self2 := Expr.new(NodeType.Ident("self"), line, col)
                mut gc1 := Expr.new(NodeType.FCall(FCallData()), line, col)
                gc1.add_child(own gp1)
                gc1.add_child(own self2)
                mut sd1 := Expr.new(NodeType.Decl(Declaration(name = "_sp", explicit_type = vtype.clone(), til_type = til_type_from_explicit_type(vtype), own_type = OwnType.Ref)), line, col)
                sd1.add_child(own gc1)
                then_body.add_child(own sd1)

                mut gp2 := Expr.new(NodeType.Ident("get_payload"), line, col)
                mut other2 := Expr.new(NodeType.Ident("other"), line, col)
                mut gc2 := Expr.new(NodeType.FCall(FCallData()), line, col)
                gc2.add_child(own gp2)
                gc2.add_child(own other2)
                mut sd2 := Expr.new(NodeType.Decl(Declaration(name = "_op", explicit_type = vtype.clone(), til_type = til_type_from_explicit_type(vtype), own_type = OwnType.Ref)), line, col)
                sd2.add_child(own gc2)
                then_body.add_child(own sd2)

                mut sp_id := Expr.new(NodeType.Ident("_sp"), line, col)
                mut eq_acc := Expr.new(NodeType.FieldAccess("eq"), line, col)
                eq_acc.add_child(own sp_id)
                mut op_id := Expr.new(NodeType.Ident("_op"), line, col)
                mut eq_call := Expr.new(NodeType.FCall(FCallData()), line, col)
                eq_call.add_child(own eq_acc)
                eq_call.add_child(own op_id)

                mut ret_eq := Expr.new(NodeType.Return, line, col)
                ret_eq.add_child(own eq_call)
                then_body.add_child(own ret_eq)
            }
        } else {
            mut iv3 := Expr.new(NodeType.Ident("is"), line, col)
            mut other_id := Expr.new(NodeType.Ident("other"), line, col)
            mut et3 := Expr.new(NodeType.Ident(ename.clone()), line, col)
            mut vr3 := Expr.new(NodeType.FieldAccess(vn.clone()), line, col)
            vr3.add_child(own et3)
            mut is_call3 := Expr.new(NodeType.FCall(FCallData()), line, col)
            is_call3.add_child(own iv3)
            is_call3.add_child(own other_id)
            is_call3.add_child(own vr3)
            mut ret := Expr.new(NodeType.Return, line, col)
            ret.add_child(own is_call3)
            then_body.add_child(own ret)
        }

        mut if_node := Expr.new(NodeType.If, line, col)
        if_node.add_child(own is_call)
        if_node.add_child(own then_body)
        func_body.add_child(own if_node)
    }

    mut ret_false := Expr.new(NodeType.Return, line, col)
    mut false_lit := Expr.new(NodeType.LiteralBool(false), line, col)
    ret_false.add_child(own false_lit)
    func_body.add_child(own ret_false)

    mut fdecl := FunctionDef()
    fdecl.func_type = FuncType.Func
    fdecl.params.push(own Declaration(name = "self", explicit_type = ename.clone(), til_type = til_type_from_explicit_type(ename), own_type = OwnType.Ref))
    fdecl.params.push(own Declaration(name = "other", explicit_type = ename.clone(), til_type = til_type_from_explicit_type(ename), own_type = OwnType.Ref))
    fdecl.return_type = "Bool"
    fdecl.return_own_type = OwnType.Shallow
    fdecl.variadic_index = -1.to_i32()
    fdecl.kwargs_index = -1.to_i32()

    mut fdef := Expr.new(NodeType.FuncDef(fdecl), line, col)
    fdef.add_child(own func_body)

    switch enum_def.node_type {
    case NodeType.EnumDef(eeq_edd):
        eeq_edd.ns_decls.push(own Declaration(name = "eq", default_value = fdef))
    case:
        UNREACHABLE(__LOC__)
    }
}

generate_enum_delete_method := func(enum_def: Expr, ename: Str, shallow line: U32, shallow col: U32, variant_names: Vec, variant_types: Vec, shallow has_payloads: Bool, scope: TypeScope) {
    mut proc_body := Expr.new(NodeType.Body, line, col)
    if has_payloads {
        for j in 0..variant_names.len() {
            ref vn : Str = variant_names.get(j)
            ref vtype : Str = variant_types.get(j)
            if vtype.len().eq(0) { continue }
            if vtype.eq("Dynamic") { continue }
            if type_from_name_init(vtype, scope).eq(TilType.FuncPtr) { continue }

            mut tiv := Expr.new(NodeType.Ident("is"), line, col)
            mut self_id := Expr.new(NodeType.Ident("self"), line, col)
            mut tet := Expr.new(NodeType.Ident(ename.clone()), line, col)
            mut tvr := Expr.new(NodeType.FieldAccess(vn.clone()), line, col)
            tvr.add_child(own tet)
            mut is_call := Expr.new(NodeType.FCall(FCallData()), line, col)
            is_call.add_child(own tiv)
            is_call.add_child(own self_id)
            is_call.add_child(own tvr)

            mut then_body := Expr.new(NodeType.Body, line, col)

            mut type_id := Expr.new(NodeType.Ident(vtype.clone()), line, col)
            type_id.til_type = type_from_name_init(vtype, scope)
            mut del_acc := Expr.new(NodeType.FieldAccess("delete"), line, col)
            del_acc.add_child(own type_id)
            mut del_call := Expr.new(NodeType.FCall(FCallData()), line, col)
            del_call.add_child(own del_acc)

            mut gp := Expr.new(NodeType.Ident("get_payload"), line, col)
            mut self2 := Expr.new(NodeType.Ident("self"), line, col)
            mut gc := Expr.new(NodeType.FCall(FCallData()), line, col)
            gc.add_child(own gp)
            gc.add_child(own self2)
            gc.til_type = type_from_name_init(vtype, scope)
            set_own_arg(del_call, del_call.children.len())
            del_call.add_child(own gc)

            mut false_lit := Expr.new(NodeType.LiteralBool(false), line, col)
            del_call.add_child(own false_lit)
            then_body.add_child(own del_call)

            mut if_node2 := Expr.new(NodeType.If, line, col)
            if_node2.add_child(own is_call)
            if_node2.add_child(own then_body)
            proc_body.add_child(own if_node2)
        }
    }

    mut cond := Expr.new(NodeType.Ident("call_free"), line, col)
    mut then_body := Expr.new(NodeType.Body, line, col)
    mut free_call := Expr.new(NodeType.FCall(FCallData()), line, col)
    mut free_id := Expr.new(NodeType.Ident("free"), line, col)
    free_call.add_child(own free_id)
    mut self_arg := Expr.new(NodeType.Ident("self"), line, col)
    set_own_arg(free_call, free_call.children.len())
    free_call.add_child(own self_arg)
    then_body.add_child(own free_call)
    mut if_node := Expr.new(NodeType.If, line, col)
    if_node.add_child(own cond)
    if_node.add_child(own then_body)
    proc_body.add_child(own if_node)

    mut default_true := Expr.new(NodeType.LiteralBool(true), line, col)

    mut fdecl := FunctionDef()
    fdecl.func_type = FuncType.Func
    fdecl.params.push(own Declaration(name = "self", explicit_type = ename.clone(), til_type = til_type_from_explicit_type(ename), own_type = OwnType.Own))
    fdecl.params.push(own Declaration(name = "call_free", explicit_type = "Bool", til_type = TilType.Bool, own_type = OwnType.Ref, default_value = default_true.clone()))
    fdecl.variadic_index = -1.to_i32()
    fdecl.kwargs_index = -1.to_i32()

    mut fdef := Expr.new(NodeType.FuncDef(fdecl), line, col)
    fdef.add_child(own proc_body)

    switch enum_def.node_type {
    case NodeType.EnumDef(edel_edd):
        edel_edd.ns_decls.push(own Declaration(name = "delete", default_value = fdef))
    case:
        UNREACHABLE(__LOC__)
    }
}

generate_enum_to_str_method := func(enum_def: Expr, ename: Str, shallow line: U32, shallow col: U32, variant_names: Vec, variant_types: Vec, shallow has_payloads: Bool, scope: TypeScope) {
    mut func_body := Expr.new(NodeType.Body, line, col)
    for j in 0..variant_names.len() {
        ref vn : Str = variant_names.get(j)
        ref vtype : Str = variant_types.get(j)

        if has_payloads {
            mut tiv := Expr.new(NodeType.Ident("is"), line, col)
            mut self_id := Expr.new(NodeType.Ident("self"), line, col)
            mut tet := Expr.new(NodeType.Ident(ename.clone()), line, col)
            mut tvr := Expr.new(NodeType.FieldAccess(vn.clone()), line, col)
            tvr.add_child(own tet)
            mut is_call := Expr.new(NodeType.FCall(FCallData()), line, col)
            is_call.add_child(own tiv)
            is_call.add_child(own self_id)
            is_call.add_child(own tvr)

            mut then_body := Expr.new(NodeType.Body, line, col)
            if vtype.len().gt(0).and(type_from_name_init(vtype, scope).eq(TilType.FuncPtr)) {
                ret_text := format(vn, "(func)")
                mut ret_str := Expr.new(NodeType.LiteralStr(ret_text), line, col)
                mut ret := Expr.new(NodeType.Return, line, col)
                ret.add_child(own ret_str)
                then_body.add_child(own ret)
            } else if vtype.len().gt(0) {
                pn := format("_p_", vtype, "_", j.to_str())
                mut gp := Expr.new(NodeType.Ident("get_payload"), line, col)
                mut self2 := Expr.new(NodeType.Ident("self"), line, col)
                mut gc := Expr.new(NodeType.FCall(FCallData()), line, col)
                gc.add_child(own gp)
                gc.add_child(own self2)
                mut pd := Expr.new(NodeType.Decl(Declaration(name = pn.clone(), explicit_type = vtype.clone(), til_type = til_type_from_explicit_type(vtype), own_type = OwnType.Ref)), line, col)
                pd.add_child(own gc)
                then_body.add_child(own pd)

                mut fmt_call := Expr.new(NodeType.FCall(FCallData()), line, col)
                mut fmt_id := Expr.new(NodeType.Ident("format"), line, col)
                fmt_call.add_child(own fmt_id)

                prefix_text := format(vn, "(")
                mut prefix := Expr.new(NodeType.LiteralStr(prefix_text), line, col)
                fmt_call.add_child(own prefix)

                mut p_id := Expr.new(NodeType.Ident(pn), line, col)
                mut tostr_acc := Expr.new(NodeType.FieldAccess("to_str"), line, col)
                tostr_acc.add_child(own p_id)
                mut tostr_call := Expr.new(NodeType.FCall(FCallData()), line, col)
                tostr_call.add_child(own tostr_acc)
                fmt_call.add_child(own tostr_call)

                mut suffix := Expr.new(NodeType.LiteralStr(")"), line, col)
                fmt_call.add_child(own suffix)

                mut ret := Expr.new(NodeType.Return, line, col)
                ret.add_child(own fmt_call)
                then_body.add_child(own ret)
            } else {
                mut ret_str := Expr.new(NodeType.LiteralStr(vn.clone()), line, col)
                mut ret := Expr.new(NodeType.Return, line, col)
                ret.add_child(own ret_str)
                then_body.add_child(own ret)
            }

            mut if_node := Expr.new(NodeType.If, line, col)
            if_node.add_child(own is_call)
            if_node.add_child(own then_body)
            func_body.add_child(own if_node)
        } else {
            mut self_id := Expr.new(NodeType.Ident("self"), line, col)
            mut eq_acc := Expr.new(NodeType.FieldAccess("eq"), line, col)
            eq_acc.add_child(own self_id)

            mut ename_id := Expr.new(NodeType.Ident(ename.clone()), line, col)
            mut var_acc := Expr.new(NodeType.FieldAccess(vn.clone()), line, col)
            var_acc.add_child(own ename_id)

            mut eq_call := Expr.new(NodeType.FCall(FCallData()), line, col)
            eq_call.add_child(own eq_acc)
            eq_call.add_child(own var_acc)

            mut ret_str := Expr.new(NodeType.LiteralStr(vn.clone()), line, col)
            mut ret := Expr.new(NodeType.Return, line, col)
            ret.add_child(own ret_str)
            mut then_body := Expr.new(NodeType.Body, line, col)
            then_body.add_child(own ret)

            mut if_node := Expr.new(NodeType.If, line, col)
            if_node.add_child(own eq_call)
            if_node.add_child(own then_body)
            func_body.add_child(own if_node)
        }
    }

    mut unk := Expr.new(NodeType.LiteralStr("unknown"), line, col)
    mut ret_unk := Expr.new(NodeType.Return, line, col)
    ret_unk.add_child(own unk)
    func_body.add_child(own ret_unk)

    mut fdecl := FunctionDef()
    fdecl.func_type = FuncType.Func
    fdecl.params.push(own Declaration(name = "self", explicit_type = ename.clone(), til_type = til_type_from_explicit_type(ename), own_type = OwnType.Ref))
    fdecl.return_type = "Str"
    fdecl.variadic_index = -1.to_i32()
    fdecl.kwargs_index = -1.to_i32()

    mut fdef := Expr.new(NodeType.FuncDef(fdecl), line, col)
    fdef.add_child(own func_body)

    switch enum_def.node_type {
    case NodeType.EnumDef(ets_edd):
        ets_edd.ns_decls.push(own Declaration(name = "to_str", default_value = fdef))
    case:
        UNREACHABLE(__LOC__)
    }
}

generate_enum_clone_method := func(enum_def: Expr, ename: Str, shallow line: I32, shallow col: I32, variant_names: Vec, variant_types: Vec, shallow has_payloads: Bool) {
    mut func_body := Expr.new(NodeType.Body, line.to_i64().to_u32(), col.to_i64().to_u32())
    for j in 0..variant_names.len() {
        ref vname : Str = variant_names.get(j)

        mut ename_id := Expr.new(NodeType.Ident(ename.clone()), line.to_i64().to_u32(), col.to_i64().to_u32())
        mut ctor_acc := Expr.new(NodeType.FieldAccess(vname.clone()), line.to_i64().to_u32(), col.to_i64().to_u32())
        ctor_acc.add_child(own ename_id)

        mut ctor_expr := Expr.new(NodeType.LiteralNull, line.to_i64().to_u32(), col.to_i64().to_u32())
        mut pd := Expr.new(NodeType.Body, line.to_i64().to_u32(), col.to_i64().to_u32())
        mut has_pd := false
        ref vtype : Str = variant_types.get(j)
        if vtype.len().gt(0) {
            pn := format("_clone_payload_", vname, "_", j.to_str())

            mut gp := Expr.new(NodeType.Ident("get_payload"), line.to_i64().to_u32(), col.to_i64().to_u32())
            mut self_g := Expr.new(NodeType.Ident("self"), line.to_i64().to_u32(), col.to_i64().to_u32())
            mut gc := Expr.new(NodeType.FCall(FCallData()), line.to_i64().to_u32(), col.to_i64().to_u32())
            gc.add_child(own gp)
            gc.add_child(own self_g)

            mut decl_expr := Expr.new(NodeType.Decl(Declaration(name = pn.clone(), explicit_type = vtype.clone(), til_type = til_type_from_explicit_type(vtype), own_type = OwnType.Ref)), line.to_i64().to_u32(), col.to_i64().to_u32())
            decl_expr.add_child(own gc)
            pd = decl_expr
            has_pd = true

            mut ctor_call := Expr.new(NodeType.FCall(FCallData()), line.to_i64().to_u32(), col.to_i64().to_u32())
            ctor_call.add_child(own ctor_acc)
            mut p_id := Expr.new(NodeType.Ident(pn), line.to_i64().to_u32(), col.to_i64().to_u32())
            ctor_call.add_child(own p_id)
            ctor_expr = ctor_call
        } else {
            ctor_expr = ctor_acc
        }

        mut ret := Expr.new(NodeType.Return, line.to_i64().to_u32(), col.to_i64().to_u32())
        ret.add_child(own ctor_expr)

        if j.lt(variant_names.len().sub(1)) {
            mut cond := Expr.new(NodeType.LiteralNull, line.to_i64().to_u32(), col.to_i64().to_u32())
            if has_payloads {
                mut civ := Expr.new(NodeType.Ident("is"), line.to_i64().to_u32(), col.to_i64().to_u32())
                mut self_id := Expr.new(NodeType.Ident("self"), line.to_i64().to_u32(), col.to_i64().to_u32())
                mut cet := Expr.new(NodeType.Ident(ename.clone()), line.to_i64().to_u32(), col.to_i64().to_u32())
                mut cvr := Expr.new(NodeType.FieldAccess(vname.clone()), line.to_i64().to_u32(), col.to_i64().to_u32())
                cvr.add_child(own cet)
                mut cond_call := Expr.new(NodeType.FCall(FCallData()), line.to_i64().to_u32(), col.to_i64().to_u32())
                cond_call.add_child(own civ)
                cond_call.add_child(own self_id)
                cond_call.add_child(own cvr)
                cond = cond_call
            } else {
                mut self_id := Expr.new(NodeType.Ident("self"), line.to_i64().to_u32(), col.to_i64().to_u32())
                mut eq_acc := Expr.new(NodeType.FieldAccess("eq"), line.to_i64().to_u32(), col.to_i64().to_u32())
                eq_acc.add_child(own self_id)

                mut en2 := Expr.new(NodeType.Ident(ename.clone()), line.to_i64().to_u32(), col.to_i64().to_u32())
                mut va2 := Expr.new(NodeType.FieldAccess(vname.clone()), line.to_i64().to_u32(), col.to_i64().to_u32())
                va2.add_child(own en2)

                mut cond_call := Expr.new(NodeType.FCall(FCallData()), line.to_i64().to_u32(), col.to_i64().to_u32())
                cond_call.add_child(own eq_acc)
                cond_call.add_child(own va2)
                cond = cond_call
            }

            mut then_body := Expr.new(NodeType.Body, line.to_i64().to_u32(), col.to_i64().to_u32())
            if has_pd {
                then_body.add_child(own pd.clone())
            }
            then_body.add_child(own ret)

            mut if_node := Expr.new(NodeType.If, line.to_i64().to_u32(), col.to_i64().to_u32())
            if_node.add_child(own cond)
            if_node.add_child(own then_body)
            func_body.add_child(own if_node)
        } else {
            if has_pd {
                func_body.add_child(own pd.clone())
            }
            func_body.add_child(own ret)
        }
    }

    mut fdecl := FunctionDef()
    fdecl.func_type = FuncType.Func
    fdecl.params.push(own Declaration(name = "self", explicit_type = ename.clone(), til_type = til_type_from_explicit_type(ename), own_type = OwnType.Ref))
    fdecl.return_type = ename.clone()
    fdecl.variadic_index = -1.to_i32()
    fdecl.kwargs_index = -1.to_i32()

    mut fdef := Expr.new(NodeType.FuncDef(fdecl), line.to_i64().to_u32(), col.to_i64().to_u32())
    fdef.add_child(own func_body)

    switch enum_def.node_type {
    case NodeType.EnumDef(ecl_edd2):
        ecl_edd2.ns_decls.push(own Declaration(name = "clone", default_value = fdef))
    case:
        UNREACHABLE(__LOC__)
    }
}

register_enum_def_for_stmt := proc(stmt: Expr, scope: TypeScope) returns shallow I32 {
    if stmt.node_type.is(NodeType.Decl).not() { return 0.to_i32() }
    if stmt.child(0).node_type.is(NodeType.EnumDef).not() { return 0.to_i32() }
    return register_enum_definition(stmt, scope)
}

gen_enum_nonclone_methods_for_stmt := func(stmt: Expr, scope: TypeScope) {
    if stmt.node_type.is(NodeType.Decl).not() { return }
    if stmt.child(0).node_type.is(NodeType.EnumDef).not() { return }

    mut ename := ""
    switch stmt.node_type {
    case NodeType.Decl(edecl):
        ename = edecl.name
    case:
        UNREACHABLE(__LOC__)
        return
    }
    line := stmt.line
    col := stmt.col

    variant_names := Vec.new("Str", Str.size())
    variant_types := Vec.new("Str", Str.size())
    mut has_payloads := false
    collect_enum_variants(stmt.child(0), variant_names, variant_types, has_payloads)
    generate_enum_variant_constructors(stmt.child(0), ename, line, col, variant_names, variant_types, has_payloads)

    mut has_is := false
    mut has_eq := false
    mut has_delete := false
    mut has_to_str := false
    switch stmt.child(0).node_type {
    case NodeType.EnumDef(ens_edd):
        for d_j : Declaration in ens_edd.ns_decls {
            ref fdecl : Declaration = d_j
            if fdecl.name.eq("is") { has_is = true }
            if fdecl.name.eq("eq") { has_eq = true }
            if fdecl.name.eq("delete") { has_delete = true }
            if fdecl.name.eq("to_str") { has_to_str = true }
        }
    case:
        UNREACHABLE(__LOC__)
    }

    if has_is.not() {
        generate_enum_is_method(stmt.child(0), ename, line, col)
    }
    if has_eq.not() {
        generate_enum_eq_method(stmt.child(0), ename, line, col, variant_names, variant_types, scope)
    }
    if has_delete.not() {
        generate_enum_delete_method(stmt.child(0), ename, line, col, variant_names, variant_types, has_payloads, scope)
    }
    if has_to_str.not() {
        generate_enum_to_str_method(stmt.child(0), ename, line, col, variant_names, variant_types, has_payloads, scope)
    }

    Vec.delete(own variant_names, false)
    Vec.delete(own variant_types, false)
}

register_enum_and_gen_nonclone_methods_for_stmt := proc(stmt: Expr, scope: TypeScope) returns shallow I32 {
    reg_errors := register_enum_def_for_stmt(stmt, scope)
    if reg_errors.gt(0) { return reg_errors }
    gen_enum_nonclone_methods_for_stmt(stmt, scope)
    return 0.to_i32()
}

register_enums_and_generate_nonclone_methods := proc(program: Expr, scope: TypeScope) returns shallow I32 {
    mut errors : I32 = 0
    for stmt : Expr in program.children {
        errors = errors.add(register_enum_and_gen_nonclone_methods_for_stmt(stmt, scope))
    }
    return errors
}

gen_missing_enum_clone_for_stmt := func(stmt: Expr) {
    if stmt.node_type.is(NodeType.Decl).not() { return }
    if stmt.child(0).node_type.is(NodeType.EnumDef).not() { return }

    mut ename := ""
    switch stmt.node_type {
    case NodeType.Decl(edecl):
        ename = edecl.name
    case:
        UNREACHABLE(__LOC__)
        return
    }
    line := stmt.line
    col := stmt.col
    mut has_clone := false
    switch stmt.child(0).node_type {
    case NodeType.EnumDef(ecl_edd):
        for d_j : Declaration in ecl_edd.ns_decls {
            ref fdecl : Declaration = d_j
            if fdecl.name.eq("clone") {
                has_clone = true
                break
            }
        }
    case:
        UNREACHABLE(__LOC__)
    }
    if has_clone.not() {
        variant_names := Vec.new("Str", Str.size())
        variant_types := Vec.new("Str", Str.size())
        mut has_payloads := false
        collect_enum_variants(stmt.child(0), variant_names, variant_types, has_payloads)
        generate_enum_clone_method(stmt.child(0), ename, line.to_i64().to_i32(), col.to_i64().to_i32(), variant_names, variant_types, has_payloads)
        Vec.delete(own variant_names, false)
        Vec.delete(own variant_types, false)
    }
}

generate_missing_enum_clones := func(program: Expr) {
    for stmt : Expr in program.children {
        gen_missing_enum_clone_for_stmt(stmt)
    }
}

register_funcsig_alias_for_stmt := func(stmt: Expr, scope: TypeScope) {
    if is_func_decl(stmt).not() { return }
    if stmt.child(0).children.len().neq(0) { return }
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        scope.set(sdecl.name, TilType.FuncPtr, FuncType.None, false, initer_path, stmt.line, stmt.col, false, OwnType.Shallow)
        ref mut fb : TypeBinding = scope.get_binding(sdecl.name)
        fb.func_def = stmt.child(0)
    case:
        UNREACHABLE(__LOC__)
    }
}

register_funcsig_aliases := func(program: Expr, scope: TypeScope) {
    for stmt : Expr in program.children {
        register_funcsig_alias_for_stmt(stmt, scope)
    }
}

register_type_alias_for_stmt := func(stmt: Expr, scope: TypeScope) {
    if stmt.node_type.is(NodeType.Decl).not() { return }
    ref rhs : Expr = stmt.child(0)
    mut target_name := ""
    switch rhs.node_type {
    case NodeType.Ident(tn):
        target_name = tn
    case:
        return
    }
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        if scope.find(sdecl.name).is(ScopeFind.Found) { return }
        find := scope.find(target_name)
        switch find {
        case ScopeFind.Found(target):
            if is_null(target.struct_def).and(target.is_builtin.not()) {
                if is_null(target.func_def) {
                    return
                }
                if target.func_def.children.len().neq(0) {
                    return
                }
            }
            scope.set(sdecl.name, target.type, target.func_type, false, initer_path, stmt.line, stmt.col, false, OwnType.Shallow)
            ref mut ab : TypeBinding = scope.get_binding(sdecl.name)
            ab.struct_def = target.struct_def
            ab.func_def = target.func_def
            ab.is_builtin = target.is_builtin
            ab.is_type_alias = true
            if target.alias_target.is_empty() {
                ab.alias_target = target_name
            } else {
                ab.alias_target = target.alias_target
            }
        case:
            // Target not in scope yet. Only register when the target name
            // is a builtin primitive (e.g. `USize := U32` declared above
            // u32.til's import). Extending this to user-defined types
            // (Custom) is unsafe because we cannot tell at this point
            // whether the target is a type, a value, or an ALL_CAPS
            // constant (CamelCase heuristic doesn't work). The Found
            // arm above handles user-defined types when the target file
            // was already init'd. #165.
            til_type := til_type_from_explicit_type(target_name)
            if til_type.is(TilType.Unknown) { return }
            if til_type.is(TilType.Custom) { return }
            scope.set(sdecl.name, til_type, FuncType.None, false, initer_path, stmt.line, stmt.col, false, OwnType.Shallow)
            ref mut ab : TypeBinding = scope.get_binding(sdecl.name)
            ab.is_type_alias = true
            ab.alias_target = target_name
        }
    case:
        UNREACHABLE(__LOC__)
    }
}

register_type_aliases := func(program: Expr, scope: TypeScope) {
    for stmt : Expr in program.children {
        register_type_alias_for_stmt(stmt, scope)
    }
}

register_top_level_value_for_stmt := func(stmt: Expr, scope: TypeScope) {
    if stmt.node_type.is(NodeType.Decl).not() { return }
    ref rhs : Expr = stmt.child(0)
    if rhs.node_type.is(NodeType.FuncDef).or(rhs.node_type.is(NodeType.StructDef)).or(rhs.node_type.is(NodeType.EnumDef)) {
        return
    }
    if rhs.node_type.is(NodeType.Ident) {
        switch stmt.node_type {
        case NodeType.Decl(sdecl0):
            if sdecl0.explicit_type.len().eq(0) {
                switch rhs.node_type {
                case NodeType.Ident(rhs_name):
                    if type_from_name_init(rhs_name, scope).eq(TilType.Unknown).not() {
                        return
                    }
                case:
                }
            }
        case:
        }
    }

    mut t := TilType.Unknown
    if infer_top_level_decl_type(stmt, scope, t).not() { return }
    if t.eq(TilType.Unknown) { return }

    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        scope.set(sdecl.name, t, FuncType.None, sdecl.is_mut, initer_path, stmt.line, stmt.col, false, OwnType.Shallow)
    case:
        UNREACHABLE(__LOC__)
    }
}

register_top_level_values := func(program: Expr, scope: TypeScope) {
    for stmt : Expr in program.children {
        register_top_level_value_for_stmt(stmt, scope)
    }
}

register_function_def_for_stmt := func(stmt: Expr, scope: TypeScope) {
    if stmt.node_type.is(NodeType.Decl).not() { return }
    ref def : Expr = stmt.child(0)
    if def.node_type.is(NodeType.FuncDef).not() { return }

    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        if def.children.len().eq(0) {
            scope.set(sdecl.name, TilType.FuncPtr, FuncType.None, false, initer_path, stmt.line, stmt.col, false, OwnType.Shallow)
            ref mut fb : TypeBinding = scope.get_binding(sdecl.name)
            fb.func_def = stmt.child(0)
            return
        }

        if sdecl.explicit_type.len().gt(0) {
            fs_find := scope.find(sdecl.explicit_type)
            switch fs_find {
            case ScopeFind.Found(fsb):
                if is_null(fsb.func_def).not() {
                    if fsb.func_def.children.len().eq(0) {
                        ref sig : Expr = fsb.func_def
                        switch def.node_type {
                        case NodeType.FuncDef(fdef):
                            switch sig.node_type {
                            case NodeType.FuncDef(sigdef):
                                if fdef.params.len().neq(sigdef.params.len()) {
                                    panic(
                                        __LOC__,
                                        initer_path, ":", stmt.line.to_str(), ":", stmt.col.to_str(),
                                        ": error: '", sdecl.name, "' expects ", fdef.params.len().to_str(),
                                        " params but FuncSig '", sdecl.explicit_type, "' has ", sigdef.params.len().to_str(),
                                    )
                                }
                                fdef.func_type = sigdef.func_type
                                for j in 0..sigdef.params.len() {
                                    ref mut dp : Declaration = fdef.params.get(j)
                                    ref sp : Declaration = sigdef.params.get(j)
                                    dp.explicit_type = sp.explicit_type
                                    dp.til_type = sp.til_type.clone()
                                    dp.is_mut = sp.is_mut
                                    dp.own_type = sp.own_type
                                }
                                fdef.return_type = sigdef.return_type
                                fdef.return_own_type = sigdef.return_own_type
                                sdecl.explicit_type = ""
                                sdecl.til_type = TilType.Unknown
                            case:
                                UNREACHABLE(__LOC__)
                            }
                        case:
                            UNREACHABLE(__LOC__)
                        }
                    }
                }
            case:
            }
        }

        switch def.node_type {
        case NodeType.FuncDef(fdef):
            ft := fdef.func_type
            mut rt := TilType.None
            if fdef.return_type.len().gt(0) {
                // #165 step 1: scope-free. Custom(name) for user types;
                // normalize_scope_bindings (called after init) resolves
                // these to Struct/Enum once scope is populated.
                rt = til_type_from_explicit_type(fdef.return_type)
            }
            scope.set(sdecl.name, rt, ft, false, initer_path, stmt.line, stmt.col, false, OwnType.Shallow)
            ref mut fb : TypeBinding = scope.get_binding(sdecl.name)
            fb.func_def = stmt.child(0)
            if ft.is(FuncType.ExtFunc).or(ft.is(FuncType.ExtProc)) {
                fb.is_builtin = true
            }
        case:
            UNREACHABLE(__LOC__)
        }
    case:
        UNREACHABLE(__LOC__)
    }
}

register_function_definitions := func(program: Expr, scope: TypeScope) {
    for stmt : Expr in program.children {
        register_function_def_for_stmt(stmt, scope)
    }
}

gen_struct_size_method_for_stmt := func(stmt: Expr) {
    if stmt.node_type.is(NodeType.Decl).not() { return }
    ref def : Expr = stmt.child(0)
    if def.node_type.is(NodeType.StructDef).not() { return }

    mut sname := ""
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        sname = sdecl.name
    case:
        UNREACHABLE(__LOC__)
        return
    }
    if sname.eq("Dynamic") { return }
    switch def.node_type {
    case NodeType.StructDef(sz_sdd):
        mut has_size := false
        for d_j : Declaration in sz_sdd.ns_decls {
            ref fd : Declaration = d_j
            if fd.name.eq("size") {
                has_size = true
                break
            }
        }
        if has_size { return }

        sz_text := sz_sdd.total_struct_size.to_str()

        mut func_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
        mut size_expr := Expr.new(NodeType.LiteralNum(sz_text.clone()), stmt.line, stmt.col)
        mut ret := Expr.new(NodeType.Return, stmt.line, stmt.col)
        ret.add_child(own size_expr)
        func_body.add_child(own ret)

        mut func_decl := FunctionDef()
        func_decl.func_type = FuncType.Func
        func_decl.return_type = "USize"
        func_decl.return_own_type = OwnType.Shallow
        func_decl.variadic_index = -1.to_i32()
        func_decl.kwargs_index = -1.to_i32()

        mut func_def := Expr.new(NodeType.FuncDef(func_decl), stmt.line, stmt.col)
        func_def.add_child(own func_body)

        sz_sdd.ns_decls.push(own Declaration(name = "size", default_value = func_def))
    case:
        UNREACHABLE(__LOC__)
    }
}

generate_struct_size_methods := func(program: Expr) {
    for stmt : Expr in program.children {
        gen_struct_size_method_for_stmt(stmt)
    }
}

gen_enum_size_method_for_stmt := proc(stmt: Expr, scope: TypeScope) {
    if stmt.node_type.is(NodeType.Decl).not() { return }
    ref def : Expr = stmt.child(0)
    if def.node_type.is(NodeType.EnumDef).not() { return }

    mut sname := ""
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        sname = sdecl.name
    case:
        UNREACHABLE(__LOC__)
        return
    }
    if sname.eq("Dynamic") { return }
    mut has_size := false
    ref size_ns : Vec = def_ns_decls(def)
    for d_j : Declaration in size_ns {
        ref fd : Declaration = d_j
        if fd.name.eq("size") {
            has_size = true
            break
        }
    }
    if has_size { return }

    sz_text := compute_enum_layout(def, scope).to_str()

    mut func_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
    mut size_expr := Expr.new(NodeType.LiteralNum(sz_text.clone()), stmt.line, stmt.col)
    mut ret := Expr.new(NodeType.Return, stmt.line, stmt.col)
    ret.add_child(own size_expr)
    func_body.add_child(own ret)

    mut func_decl := FunctionDef()
    func_decl.func_type = FuncType.Func
    func_decl.return_type = "USize"
    func_decl.return_own_type = OwnType.Shallow
    func_decl.variadic_index = -1.to_i32()
    func_decl.kwargs_index = -1.to_i32()

    mut func_def := Expr.new(NodeType.FuncDef(func_decl), stmt.line, stmt.col)
    func_def.add_child(own func_body)

    switch def.node_type {
    case NodeType.EnumDef(esz_edd):
        esz_edd.ns_decls.push(own Declaration(name = "size", default_value = func_def))
    case:
        UNREACHABLE(__LOC__)
    }
}

generate_enum_size_methods := proc(program: Expr, scope: TypeScope) {
    for stmt : Expr in program.children {
        gen_enum_size_method_for_stmt(stmt, scope)
    }
}

gen_unity_derived_for_stmt := func(stmt: Expr) {
    if is_struct_or_enum(stmt).not() { return }
    ref def : Expr = stmt.child(0)

    mut sname := ""
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        sname = sdecl.name
    case:
        UNREACHABLE(__LOC__)
        return
    }
    if sname.eq("Dynamic") { return }

    mut has_add := false
    mut has_sub := false
    mut has_unity := false
    mut has_inc := false
    mut has_dec := false
    ref unity_ns : Vec = def_ns_decls(def)
    for d_j : Declaration in unity_ns {
        ref fd : Declaration = d_j
        if fd.name.eq("add") { has_add = true }
        if fd.name.eq("sub") { has_sub = true }
        if fd.name.eq("unity") { has_unity = true }
        if fd.name.eq("inc") { has_inc = true }
        if fd.name.eq("dec") { has_dec = true }
    }
    if has_unity.not() { return }

    for pass in 0..2 {
        mut method := "inc"
        mut op := "add"
        mut already_has := has_inc
        mut has_op := has_add
        if pass.eq(1) {
            method = "dec"
            op = "sub"
            already_has = has_dec
            has_op = has_sub
        }
        if already_has { continue }
        if has_op.not() { continue }

        mut self1 := Expr.new(NodeType.Ident("self"), stmt.line, stmt.col)
        mut self2 := Expr.new(NodeType.Ident("self"), stmt.line, stmt.col)

        mut unity_acc := Expr.new(NodeType.FieldAccess("unity"), stmt.line, stmt.col)
        unity_acc.add_child(own self2)
        mut unity_call := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col)
        unity_call.add_child(own unity_acc)

        mut op_acc := Expr.new(NodeType.FieldAccess(op.clone()), stmt.line, stmt.col)
        op_acc.add_child(own self1)
        mut op_call := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col)
        op_call.add_child(own op_acc)
        op_call.add_child(own unity_call)

        mut assign := Expr.new(NodeType.Assign(AssignData(name = "self")), stmt.line, stmt.col)
        assign.add_child(own op_call)

        mut proc_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
        proc_body.add_child(own assign)

        mut func_decl := FunctionDef()
        func_decl.func_type = FuncType.Func
        param := Declaration(name = "self", explicit_type = sname.clone(), til_type = til_type_from_explicit_type(sname), is_mut = true, own_type = OwnType.Ref)
        func_decl.params.push(own param)
        func_decl.variadic_index = -1.to_i32()
        func_decl.kwargs_index = -1.to_i32()

        mut func_def := Expr.new(NodeType.FuncDef(func_decl), stmt.line, stmt.col)
        func_def.add_child(own proc_body)

        switch def.node_type {
        case NodeType.StructDef(un_sdd):
            un_sdd.ns_decls.push(own Declaration(name = method.clone(), default_value = func_def))
        case NodeType.EnumDef(eu_edd):
            eu_edd.ns_decls.push(own Declaration(name = method.clone(), default_value = func_def))
        case:
            UNREACHABLE(__LOC__)
        }
    }
}

generate_size_methods := proc(program: Expr, scope: TypeScope) {
    generate_struct_size_methods(program)
    generate_enum_size_methods(program, scope)
}

gen_cmp_derived_for_stmt := func(stmt: Expr) {
    if is_struct_or_enum(stmt).not() { return }
    ref def : Expr = stmt.child(0)

    mut sname := ""
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        sname = sdecl.name
    case:
        UNREACHABLE(__LOC__)
        return
    }
    if sname.eq("Dynamic") { return }

    mut has_cmp := false
    mut has_eq := false
    mut has_neq := false
    mut has_lt := false
    mut has_gt := false
    mut has_lte := false
    mut has_gte := false
    ref cmp_ns : Vec = def_ns_decls(def)
    for d_j : Declaration in cmp_ns {
        ref fd : Declaration = d_j
        if fd.name.eq("cmp") { has_cmp = true }
        if fd.name.eq("eq") { has_eq = true }
        if fd.name.eq("neq") { has_neq = true }
        if fd.name.eq("lt") { has_lt = true }
        if fd.name.eq("gt") { has_gt = true }
        if fd.name.eq("lte") { has_lte = true }
        if fd.name.eq("gte") { has_gte = true }
    }
    if has_cmp.not() { return }

    if has_eq.not() {
        mut a_id := Expr.new(NodeType.Ident("a"), stmt.line, stmt.col)
        mut b_id := Expr.new(NodeType.Ident("b"), stmt.line, stmt.col)
        mut cmp_acc := Expr.new(NodeType.FieldAccess("cmp"), stmt.line, stmt.col)
        cmp_acc.add_child(own a_id)
        mut cmp_call := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col)
        cmp_call.add_child(own cmp_acc)
        cmp_call.add_child(own b_id)
        mut eq_acc := Expr.new(NodeType.FieldAccess("eq"), stmt.line, stmt.col)
        eq_acc.add_child(own cmp_call)
        mut eq_call := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col)
        eq_call.add_child(own eq_acc)
        mut zero := Expr.new(NodeType.LiteralNum("0"), stmt.line, stmt.col)
        eq_call.add_child(own zero)
        mut ret := Expr.new(NodeType.Return, stmt.line, stmt.col)
        ret.add_child(own eq_call)
        mut func_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
        func_body.add_child(own ret)
        mut func_decl := FunctionDef()
        func_decl.func_type = FuncType.Func
        a_param := Declaration(name = "a", explicit_type = sname.clone(), til_type = til_type_from_explicit_type(sname), own_type = OwnType.Ref)
        b_param := Declaration(name = "b", explicit_type = sname.clone(), til_type = til_type_from_explicit_type(sname), own_type = OwnType.Ref)
        func_decl.params.push(own a_param)
        func_decl.params.push(own b_param)
        func_decl.return_type = "Bool"
        func_decl.return_own_type = OwnType.Shallow
        func_decl.variadic_index = -1.to_i32()
        func_decl.kwargs_index = -1.to_i32()
        mut func_def := Expr.new(NodeType.FuncDef(func_decl), stmt.line, stmt.col)
        func_def.add_child(own func_body)
        switch def.node_type {
        case NodeType.StructDef(cmp_sdd):
            cmp_sdd.ns_decls.push(own Declaration(name = "eq", default_value = func_def))
        case NodeType.EnumDef(ec_edd):
            ec_edd.ns_decls.push(own Declaration(name = "eq", default_value = func_def))
        case:
            UNREACHABLE(__LOC__)
        }
    }

    if has_lt.not() {
        mut a_id := Expr.new(NodeType.Ident("a"), stmt.line, stmt.col)
        mut b_id := Expr.new(NodeType.Ident("b"), stmt.line, stmt.col)
        mut cmp_acc := Expr.new(NodeType.FieldAccess("cmp"), stmt.line, stmt.col)
        cmp_acc.add_child(own a_id)
        mut cmp_call := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col)
        cmp_call.add_child(own cmp_acc)
        cmp_call.add_child(own b_id)
        mut eq_acc := Expr.new(NodeType.FieldAccess("eq"), stmt.line, stmt.col)
        eq_acc.add_child(own cmp_call)
        mut eq_call := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col)
        eq_call.add_child(own eq_acc)
        mut zero := Expr.new(NodeType.LiteralNum("0"), stmt.line, stmt.col)
        mut sub_acc := Expr.new(NodeType.FieldAccess("sub"), stmt.line, stmt.col)
        sub_acc.add_child(own zero)
        mut neg1_call := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col)
        neg1_call.add_child(own sub_acc)
        mut one := Expr.new(NodeType.LiteralNum("1"), stmt.line, stmt.col)
        neg1_call.add_child(own one)
        eq_call.add_child(own neg1_call)
        mut ret := Expr.new(NodeType.Return, stmt.line, stmt.col)
        ret.add_child(own eq_call)
        mut func_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
        func_body.add_child(own ret)
        mut func_decl := FunctionDef()
        func_decl.func_type = FuncType.Func
        a_param := Declaration(name = "a", explicit_type = sname.clone(), til_type = til_type_from_explicit_type(sname), own_type = OwnType.Ref)
        b_param := Declaration(name = "b", explicit_type = sname.clone(), til_type = til_type_from_explicit_type(sname), own_type = OwnType.Ref)
        func_decl.params.push(own a_param)
        func_decl.params.push(own b_param)
        func_decl.return_type = "Bool"
        func_decl.return_own_type = OwnType.Shallow
        func_decl.variadic_index = -1.to_i32()
        func_decl.kwargs_index = -1.to_i32()
        mut func_def := Expr.new(NodeType.FuncDef(func_decl), stmt.line, stmt.col)
        func_def.add_child(own func_body)
        switch def.node_type {
        case NodeType.StructDef(cmp_sdd):
            cmp_sdd.ns_decls.push(own Declaration(name = "lt", default_value = func_def))
        case NodeType.EnumDef(ec_edd):
            ec_edd.ns_decls.push(own Declaration(name = "lt", default_value = func_def))
        case:
            UNREACHABLE(__LOC__)
        }
    }

    if has_gt.not() {
        mut a_id := Expr.new(NodeType.Ident("a"), stmt.line, stmt.col)
        mut b_id := Expr.new(NodeType.Ident("b"), stmt.line, stmt.col)
        mut cmp_acc := Expr.new(NodeType.FieldAccess("cmp"), stmt.line, stmt.col)
        cmp_acc.add_child(own a_id)
        mut cmp_call := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col)
        cmp_call.add_child(own cmp_acc)
        cmp_call.add_child(own b_id)
        mut eq_acc := Expr.new(NodeType.FieldAccess("eq"), stmt.line, stmt.col)
        eq_acc.add_child(own cmp_call)
        mut eq_call := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col)
        eq_call.add_child(own eq_acc)
        mut one := Expr.new(NodeType.LiteralNum("1"), stmt.line, stmt.col)
        eq_call.add_child(own one)
        mut ret := Expr.new(NodeType.Return, stmt.line, stmt.col)
        ret.add_child(own eq_call)
        mut func_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
        func_body.add_child(own ret)
        mut func_decl := FunctionDef()
        func_decl.func_type = FuncType.Func
        a_param := Declaration(name = "a", explicit_type = sname.clone(), til_type = til_type_from_explicit_type(sname), own_type = OwnType.Ref)
        b_param := Declaration(name = "b", explicit_type = sname.clone(), til_type = til_type_from_explicit_type(sname), own_type = OwnType.Ref)
        func_decl.params.push(own a_param)
        func_decl.params.push(own b_param)
        func_decl.return_type = "Bool"
        func_decl.return_own_type = OwnType.Shallow
        func_decl.variadic_index = -1.to_i32()
        func_decl.kwargs_index = -1.to_i32()
        mut func_def := Expr.new(NodeType.FuncDef(func_decl), stmt.line, stmt.col)
        func_def.add_child(own func_body)
        switch def.node_type {
        case NodeType.StructDef(cmp_sdd):
            cmp_sdd.ns_decls.push(own Declaration(name = "gt", default_value = func_def))
        case NodeType.EnumDef(ec_edd):
            ec_edd.ns_decls.push(own Declaration(name = "gt", default_value = func_def))
        case:
            UNREACHABLE(__LOC__)
        }
    }

    if has_neq.not() {
        mut a_id := Expr.new(NodeType.Ident("a"), stmt.line, stmt.col)
        mut b_id := Expr.new(NodeType.Ident("b"), stmt.line, stmt.col)
        mut eq_acc := Expr.new(NodeType.FieldAccess("eq"), stmt.line, stmt.col)
        eq_acc.add_child(own a_id)
        mut eq_call := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col)
        eq_call.add_child(own eq_acc)
        eq_call.add_child(own b_id)
        mut not_acc := Expr.new(NodeType.FieldAccess("not"), stmt.line, stmt.col)
        not_acc.add_child(own eq_call)
        mut not_call := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col)
        not_call.add_child(own not_acc)
        mut ret := Expr.new(NodeType.Return, stmt.line, stmt.col)
        ret.add_child(own not_call)
        mut func_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
        func_body.add_child(own ret)
        mut func_decl := FunctionDef()
        func_decl.func_type = FuncType.Func
        a_param := Declaration(name = "a", explicit_type = sname.clone(), til_type = til_type_from_explicit_type(sname), own_type = OwnType.Ref)
        b_param := Declaration(name = "b", explicit_type = sname.clone(), til_type = til_type_from_explicit_type(sname), own_type = OwnType.Ref)
        func_decl.params.push(own a_param)
        func_decl.params.push(own b_param)
        func_decl.return_type = "Bool"
        func_decl.return_own_type = OwnType.Shallow
        func_decl.variadic_index = -1.to_i32()
        func_decl.kwargs_index = -1.to_i32()
        mut func_def := Expr.new(NodeType.FuncDef(func_decl), stmt.line, stmt.col)
        func_def.add_child(own func_body)
        switch def.node_type {
        case NodeType.StructDef(cmp_sdd):
            cmp_sdd.ns_decls.push(own Declaration(name = "neq", default_value = func_def))
        case NodeType.EnumDef(ec_edd):
            ec_edd.ns_decls.push(own Declaration(name = "neq", default_value = func_def))
        case:
            UNREACHABLE(__LOC__)
        }
    }

    if has_lte.not() {
        mut a_id := Expr.new(NodeType.Ident("a"), stmt.line, stmt.col)
        mut b_id := Expr.new(NodeType.Ident("b"), stmt.line, stmt.col)
        mut gt_acc := Expr.new(NodeType.FieldAccess("gt"), stmt.line, stmt.col)
        gt_acc.add_child(own a_id)
        mut gt_call := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col)
        gt_call.add_child(own gt_acc)
        gt_call.add_child(own b_id)
        mut not_acc := Expr.new(NodeType.FieldAccess("not"), stmt.line, stmt.col)
        not_acc.add_child(own gt_call)
        mut not_call := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col)
        not_call.add_child(own not_acc)
        mut ret := Expr.new(NodeType.Return, stmt.line, stmt.col)
        ret.add_child(own not_call)
        mut func_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
        func_body.add_child(own ret)
        mut func_decl := FunctionDef()
        func_decl.func_type = FuncType.Func
        a_param := Declaration(name = "a", explicit_type = sname.clone(), til_type = til_type_from_explicit_type(sname), own_type = OwnType.Ref)
        b_param := Declaration(name = "b", explicit_type = sname.clone(), til_type = til_type_from_explicit_type(sname), own_type = OwnType.Ref)
        func_decl.params.push(own a_param)
        func_decl.params.push(own b_param)
        func_decl.return_type = "Bool"
        func_decl.return_own_type = OwnType.Shallow
        func_decl.variadic_index = -1.to_i32()
        func_decl.kwargs_index = -1.to_i32()
        mut func_def := Expr.new(NodeType.FuncDef(func_decl), stmt.line, stmt.col)
        func_def.add_child(own func_body)
        switch def.node_type {
        case NodeType.StructDef(cmp_sdd):
            cmp_sdd.ns_decls.push(own Declaration(name = "lte", default_value = func_def))
        case NodeType.EnumDef(ec_edd):
            ec_edd.ns_decls.push(own Declaration(name = "lte", default_value = func_def))
        case:
            UNREACHABLE(__LOC__)
        }
    }

    if has_gte.not() {
        mut a_id := Expr.new(NodeType.Ident("a"), stmt.line, stmt.col)
        mut b_id := Expr.new(NodeType.Ident("b"), stmt.line, stmt.col)
        mut lt_acc := Expr.new(NodeType.FieldAccess("lt"), stmt.line, stmt.col)
        lt_acc.add_child(own a_id)
        mut lt_call := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col)
        lt_call.add_child(own lt_acc)
        lt_call.add_child(own b_id)
        mut not_acc := Expr.new(NodeType.FieldAccess("not"), stmt.line, stmt.col)
        not_acc.add_child(own lt_call)
        mut not_call := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col)
        not_call.add_child(own not_acc)
        mut ret := Expr.new(NodeType.Return, stmt.line, stmt.col)
        ret.add_child(own not_call)
        mut func_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
        func_body.add_child(own ret)
        mut func_decl := FunctionDef()
        func_decl.func_type = FuncType.Func
        a_param := Declaration(name = "a", explicit_type = sname.clone(), til_type = til_type_from_explicit_type(sname), own_type = OwnType.Ref)
        b_param := Declaration(name = "b", explicit_type = sname.clone(), til_type = til_type_from_explicit_type(sname), own_type = OwnType.Ref)
        func_decl.params.push(own a_param)
        func_decl.params.push(own b_param)
        func_decl.return_type = "Bool"
        func_decl.return_own_type = OwnType.Shallow
        func_decl.variadic_index = -1.to_i32()
        func_decl.kwargs_index = -1.to_i32()
        mut func_def := Expr.new(NodeType.FuncDef(func_decl), stmt.line, stmt.col)
        func_def.add_child(own func_body)
        switch def.node_type {
        case NodeType.StructDef(cmp_sdd):
            cmp_sdd.ns_decls.push(own Declaration(name = "gte", default_value = func_def))
        case NodeType.EnumDef(ec_edd):
            ec_edd.ns_decls.push(own Declaration(name = "gte", default_value = func_def))
        case:
            UNREACHABLE(__LOC__)
        }
    }
}

compute_struct_layout := proc(mut struct_def: Expr, scope: TypeScope) {
    switch struct_def.node_type {
    case NodeType.StructDef(struct_meta):
        if struct_meta.total_struct_size.gt(0) { return }

        mut offset : I32 = 0
        mut max_align : I32 = 1

        for mut fd : Declaration in struct_meta.fields {
            mut fsz : I32 = 0
            mut falign : I32 = 0

            if fd.own_type.eq(OwnType.Shallow).not() {
                fsz = 8
                falign = 8

                mut ftype := fd.explicit_type
                if ftype.len().eq(0) {
                    if is_null(fd.default_value).not() {
                        ref def_val : Expr = fd.default_value
                        if def_val.node_type.is(NodeType.FCall) {
                            if def_val.children.len().gt(0) {
                                ref callee : Expr = def_val.child(0)
                                switch callee.node_type {
                                case NodeType.Ident(_ft):
                                    ftype = _ft
                                case:
                                }
                            }
                        }
                        if ftype.len().gt(0) {
                            fd.explicit_type = ftype
                            fd.til_type = til_type_from_explicit_type(fd.explicit_type)
                        }
                    }
                }

                if ftype.len().gt(0) {
                    if ftype.eq("I64").not().and(ftype.eq("U8").not()).and(ftype.eq("I16").not()).and(ftype.eq("I32").not()).and(ftype.eq("U32").not()).and(ftype.eq("Bool").not()) {
                        ref nested_def : Expr = scope.get_struct(ftype)
                        if is_null(nested_def).not() {
                            fd.field_struct_def = nested_def
                        }
                    }
                }
            } else {
                mut ftype := fd.explicit_type
                if ftype.len().eq(0) {
                    if is_null(fd.default_value).not() {
                        ref def_val : Expr = fd.default_value
                        if def_val.node_type.is(NodeType.LiteralNum) { ftype = "I64" }
                        else if def_val.node_type.is(NodeType.LiteralStr) { ftype = "Str" }
                        else if def_val.node_type.is(NodeType.LiteralBool) { ftype = "Bool" }
                        else if til_type_name(def_val.til_type).len().gt(0) { ftype = til_type_name(def_val.til_type) }
                        else if def_val.node_type.is(NodeType.FCall) {
                            if def_val.children.len().gt(0) {
                                ref callee : Expr = def_val.child(0)
                                switch callee.node_type {
                                case NodeType.Ident(_ft):
                                    ftype = _ft
                                case NodeType.FieldAccess:
                                    if callee.children.len().gt(0) {
                                        ref type_node : Expr = callee.child(0)
                                        switch type_node.node_type {
                                        case NodeType.Ident(_ft):
                                            ftype = _ft
                                        case:
                                        }
                                    }
                                case:
                                }
                            }
                        } else if def_val.node_type.is(NodeType.FieldAccess) {
                            if def_val.children.len().gt(0) {
                                ref type_node : Expr = def_val.child(0)
                                switch type_node.node_type {
                                case NodeType.Ident(_ft):
                                    ftype = _ft
                                case:
                                }
                            }
                        }
                        if ftype.len().gt(0) {
                            fd.explicit_type = ftype
                            fd.til_type = til_type_from_explicit_type(fd.explicit_type)
                        }
                    }
                }

                ref ab : TypeBinding = scope.get_binding(ftype)
                if is_null(ab).not() {
                    if ab.is_type_alias {
                        if ab.alias_target.is_empty().not() {
                            ftype = ab.alias_target
                            fd.explicit_type = ftype
                            fd.til_type = til_type_from_explicit_type(fd.explicit_type)
                        }
                    }
                }

                if ftype.len().eq(0) { fsz = 8; falign = 8 }
                else if ftype.eq("I64") { fsz = 8; falign = 8 }
                else if ftype.eq("U8") { fsz = 1; falign = 1 }
                else if ftype.eq("I16") { fsz = 2; falign = 2 }
                else if ftype.eq("I32") { fsz = 4; falign = 4 }
                else if ftype.eq("U32") { fsz = 4; falign = 4 }
                else if ftype.eq("Bool") { fsz = 1; falign = 1 }
                else if type_from_name_init(ftype, scope).is(TilType.FuncPtr) { fsz = 8; falign = 8 }
                else {
                    ref nested_def : Expr = scope.get_struct(ftype)
                    if is_null(nested_def).not().and(nested_def.node_type.is(NodeType.EnumDef)) {
                        fsz = compute_enum_layout(nested_def, scope)
                        if enum_has_payloads(nested_def) { falign = 8 } else { falign = 4 }
                        fd.field_struct_def = nested_def
                    } else if is_null(nested_def).not() {
                        compute_struct_layout(nested_def, scope)
                        switch nested_def.node_type {
                        case NodeType.StructDef(nested_meta):
                            fsz = nested_meta.total_struct_size
                        case:
                            UNREACHABLE(__LOC__)
                        }
                        falign = 8
                        fd.field_struct_def = nested_def
                    } else {
                        fsz = 8
                        falign = 8
                    }
                }
            }

            offset = align_up(offset, falign)
            fd.field_offset = offset
            fd.field_size = fsz
            if falign.gt(max_align) { max_align = falign }
            offset = offset.add(fsz)
        }

        struct_meta.total_struct_size = align_up(offset, max_align)
        if struct_meta.total_struct_size.eq(0) {
            struct_meta.total_struct_size = 1
        }
    case:
        UNREACHABLE(__LOC__)
    }
}

// Compute size and alignment for a TIL type name.
// For struct/enum payloads, recurses into compute_struct_layout / compute_enum_layout.
type_size_align := proc(ftype: Str, scope: TypeScope, mut sz: I32, mut al: I32) {
    if ftype.eq("I64") { sz = 8; al = 8; return }
    if ftype.eq("U64") { sz = 8; al = 8; return }
    if ftype.eq("F32") { sz = 4; al = 4; return }
    if ftype.eq("U8") { sz = 1; al = 1; return }
    if ftype.eq("I8") { sz = 1; al = 1; return }
    if ftype.eq("I16") { sz = 2; al = 2; return }
    if ftype.eq("I32") { sz = 4; al = 4; return }
    if ftype.eq("U32") { sz = 4; al = 4; return }
    if ftype.eq("Bool") { sz = 1; al = 1; return }
    if ftype.eq("Dynamic") { sz = 8; al = 8; return }
    if type_from_name_init(ftype, scope).is(TilType.FuncPtr) { sz = 8; al = 8; return }
    ref nested : Expr = scope.get_struct(ftype)
    if is_null(nested) { sz = 8; al = 8; return }
    switch nested.node_type {
    case NodeType.StructDef(_nm):
        compute_struct_layout(nested, scope)
        sz = _nm.total_struct_size
        al = 8
    case NodeType.EnumDef:
        sz = compute_enum_layout(nested, scope)
        al = 8
    case:
        sz = 8
        al = 8
    }
}

compute_enum_layout := proc(enum_def: Expr, scope: TypeScope) returns shallow I32 {
    switch enum_def.node_type {
    case NodeType.EnumDef(edd):
        if edd.total_enum_size.gt(0) { return edd.total_enum_size }
        // Set sentinel before recursing to break self-referential cycles.
        edd.total_enum_size = 4

        mut max_payload_size : I32 = 0
        mut max_payload_align : I32 = 4
        for vi in 0..edd.variants.len() {
            vt := enum_variant_type(enum_def, vi.to_i64().to_i32())
            if vt.len().eq(0) { continue }
            mut psz : I32 = 0
            mut palign : I32 = 0
            type_size_align(vt, scope, psz, palign)
            if psz.gt(max_payload_size) { max_payload_size = psz }
            if palign.gt(max_payload_align) { max_payload_align = palign }
        }
        mut total : I32 = 4
        if max_payload_size.gt(0) {
            total = align_up(4, max_payload_align)
            total = total.add(max_payload_size)
        }
        total = align_up(total, max_payload_align)
        edd.total_enum_size = total
        return total
    case:
        UNREACHABLE(__LOC__)
        return 0.to_i32()
    }
}

compute_all_struct_layouts := proc(program: Expr, scope: TypeScope) {
    for stmt : Expr in program.children {
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        if stmt.child(0).node_type.is(NodeType.StructDef).not() { continue }
        mut sname := ""
        switch stmt.node_type {
        case NodeType.Decl(_sd):
            sname = _sd.name
        case:
            UNREACHABLE(__LOC__)
            continue
        }
        if sname.eq("Dynamic") { continue }
        compute_struct_layout(stmt.child(0), scope)
    }
    for stmt : Expr in program.children {
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        if stmt.child(0).node_type.is(NodeType.EnumDef).not() { continue }
        compute_enum_layout(stmt.child(0), scope)
    }
}

// Re-resolve field_struct_def pointers after hoisting (cloning) invalidates them.
resolve_field_struct_defs := func(program: Expr, scope: TypeScope) {
    for stmt : Expr in program.children {
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        if stmt.child(0).node_type.is(NodeType.StructDef).not() { continue }
        switch stmt.child(0).node_type {
        case NodeType.StructDef(sdd):
            for mut fd : Declaration in sdd.fields {
                if fd.explicit_type.len().gt(0) {
                    ftype := fd.explicit_type
                    if ftype.eq("I64").not().and(ftype.eq("U8").not()).and(ftype.eq("I16").not())
                    .and(ftype.eq("I32").not()).and(ftype.eq("U32").not()).and(ftype.eq("Bool").not()) {
                        ref nested_def : Expr = scope.get_struct(ftype)
                        if is_null(nested_def).not() {
                            fd.field_struct_def = nested_def
                        }
                    }
                }
            }
        case:
            UNREACHABLE(__LOC__)
        }
    }
}

infer_top_level_decl_type := func(stmt: Expr, scope: TypeScope, mut out_type: TilType) returns shallow Bool {
    ref rhs : Expr = stmt.child(0)
    out_type = TilType.Unknown

    switch stmt.node_type {
    case NodeType.Decl(dd):
        if dd.explicit_type.len().gt(0) {
            // #165 step 1: scope-free. normalize_scope_bindings resolves
            // any Custom(name) it produces after init has finished.
            out_type = til_type_from_explicit_type(dd.explicit_type)
            return out_type.is(TilType.Unknown).not()
        }
    case:
    }

    switch rhs.node_type {
    case NodeType.LiteralNum:
        out_type = TilType.I64
        return true
    case NodeType.LiteralBool:
        out_type = TilType.Bool
        return true
    case NodeType.LiteralStr:
        out_type = TilType.Struct("Str".clone())
        return true
    case NodeType.LiteralNull:
        out_type = TilType.Dynamic
        return true
    case NodeType.Ident(id):
        ref b : TypeBinding = scope.get_binding(id)
        if is_null(b) { return false }
        out_type = b.type
        return out_type.is(TilType.Unknown).not()
    case NodeType.FieldAccess:
        mut init_ns1 := false
        if rhs.children.len().gt(0) {
            ref _io1 : Expr = rhs.child(0)
            if _io1.node_type.is(NodeType.Ident) {
                if til_type_name(_io1.til_type).eq("StructDef").or(til_type_name(_io1.til_type).eq("EnumDef")) {
                    init_ns1 = true
                }
            }
        }
        if init_ns1.and(rhs.til_type.is(TilType.Enum)) {
            mut enum_name := ""
            if rhs.children.len().gt(0) {
                enum_name = til_type_name(rhs.child(0).til_type)
            }
            out_type = TilType.Enum(enum_name.clone())
            return true
        }
        return false
    case NodeType.FCall:
        ref callee : Expr = rhs.child(0)
        switch callee.node_type {
        case NodeType.Ident(cn):
            if til_type_name(rhs.til_type).len().gt(0).and(cn.eq(til_type_name(rhs.til_type))) {
                out_type = TilType.Struct(til_type_name(rhs.til_type))
                return true
            }
            ref fb : TypeBinding = scope.get_binding(cn)
            if is_null(fb) { return false }
            out_type = fb.type
            return out_type.is(TilType.Unknown).not()
        case NodeType.FieldAccess:
            mut init_ns2 := false
            if callee.children.len().gt(0) {
                ref _io2 : Expr = callee.child(0)
                if _io2.node_type.is(NodeType.Ident) {
                    if til_type_name(_io2.til_type).eq("StructDef").or(til_type_name(_io2.til_type).eq("EnumDef")) {
                        init_ns2 = true
                    }
                }
            }
            if init_ns2.and(til_type_name(rhs.til_type).len().gt(0)).and(rhs.til_type.is(TilType.Enum)) {
                out_type = TilType.Enum(til_type_name(rhs.til_type))
                return true
            }
            return false
        case:
            return false
        }
    case:
        return false
    }
}

init_declarations := proc(program: Expr, scope: TypeScope) returns shallow I32 {
    mut errors : I32 = 0
    // Legacy merged init runs with per-statement modes; keep empty path.
    initer_path = ""

    // Single AST walk: register every type name in scope and bucket each Decl
    // into the list it needs. All cross-decl work (alias resolution, struct
    // layouts, size/derived/method generation, function-def and top-level
    // value registration) runs after the walk over the collected lists --
    // not over program.children -- so we never re-traverse the AST. We
    // store indices into program.children rather than the Expr nodes
    // themselves so the lists don't need to own the AST.
    struct_idxs := Vec.new("U32", U32.size())
    enum_idxs := Vec.new("U32", U32.size())
    alias_idxs := Vec.new("U32", U32.size())
    func_idxs := Vec.new("U32", U32.size())
    value_idxs := Vec.new("U32", U32.size())
    for i in 0..program.children.len() {
        ref stmt : Expr = program.child(i)
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        ref rhs : Expr = stmt.child(0)
        if rhs.node_type.is(NodeType.StructDef) {
            errors = errors.add(register_struct_def_for_stmt(stmt, scope))
            struct_idxs.push(own i)
        } else if rhs.node_type.is(NodeType.EnumDef) {
            errors = errors.add(register_enum_def_for_stmt(stmt, scope))
            enum_idxs.push(own i)
        } else if rhs.node_type.is(NodeType.FuncDef) {
            if rhs.children.len().eq(0) {
                register_funcsig_alias_for_stmt(stmt, scope)
            } else {
                func_idxs.push(own i)
            }
        } else if rhs.node_type.is(NodeType.Ident) {
            alias_idxs.push(own i)
        } else {
            value_idxs.push(own i)
        }
    }

    // All type names are now in scope. Process the collected lists.
    for ei : U32 in enum_idxs {
        ref stmt : Expr = program.child(ei)
        gen_enum_nonclone_methods_for_stmt(stmt, scope)
        gen_missing_enum_clone_for_stmt(stmt)
    }
    for si : U32 in struct_idxs {
        ref stmt : Expr = program.child(si)
        gen_struct_clone_delete_for_stmt(stmt, scope)
    }
    for ai : U32 in alias_idxs {
        ref stmt : Expr = program.child(ai)
        register_type_alias_for_stmt(stmt, scope)
    }
    for si : U32 in struct_idxs {
        ref stmt : Expr = program.child(si)
        compute_struct_layout(stmt.child(0), scope)
    }
    for ei : U32 in enum_idxs {
        ref stmt : Expr = program.child(ei)
        compute_enum_layout(stmt.child(0), scope)
    }
    for si : U32 in struct_idxs {
        ref stmt : Expr = program.child(si)
        gen_struct_size_method_for_stmt(stmt)
        gen_cmp_derived_for_stmt(stmt)
        gen_unity_derived_for_stmt(stmt)
    }
    for ei : U32 in enum_idxs {
        ref stmt : Expr = program.child(ei)
        gen_enum_size_method_for_stmt(stmt, scope)
        gen_cmp_derived_for_stmt(stmt)
        gen_unity_derived_for_stmt(stmt)
    }
    for fi : U32 in func_idxs {
        ref stmt : Expr = program.child(fi)
        register_function_def_for_stmt(stmt, scope)
    }
    for vi : U32 in value_idxs {
        ref stmt : Expr = program.child(vi)
        register_top_level_value_for_stmt(stmt, scope)
    }

    Vec.delete(own struct_idxs, false)
    Vec.delete(own enum_idxs, false)
    Vec.delete(own alias_idxs, false)
    Vec.delete(own func_idxs, false)
    Vec.delete(own value_idxs, false)
    return errors
}

// rstil-style unit initializer: index declarations for one file, but do not
// run global layout/method generation that must see the whole program.
init_declarations_unit := proc(path: Str, program: Expr, scope: TypeScope, ctx: Context) returns shallow I32 {
    context_enter_file(ctx, path)
    initer_path = ctx.path.clone()
    mut errors : I32 = 0

    // Single AST walk: register every type name in scope (struct, enum,
    // funcsig) and bucket each remaining Decl's index for post-walk work.
    // Enum non-clone methods need scope to be populated before they can
    // generate eq/delete/to_str, so we delay them until after the walk.
    enum_idxs := Vec.new("U32", U32.size())
    alias_idxs := Vec.new("U32", U32.size())
    func_idxs := Vec.new("U32", U32.size())
    value_idxs := Vec.new("U32", U32.size())
    for i in 0..program.children.len() {
        ref stmt : Expr = program.child(i)
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        ref rhs : Expr = stmt.child(0)
        if rhs.node_type.is(NodeType.StructDef) {
            errors = errors.add(register_struct_def_for_stmt(stmt, scope))
        } else if rhs.node_type.is(NodeType.EnumDef) {
            errors = errors.add(register_enum_def_for_stmt(stmt, scope))
            enum_idxs.push(own i)
        } else if rhs.node_type.is(NodeType.FuncDef) {
            if rhs.children.len().eq(0) {
                register_funcsig_alias_for_stmt(stmt, scope)
            } else {
                func_idxs.push(own i)
            }
        } else if rhs.node_type.is(NodeType.Ident) {
            alias_idxs.push(own i)
        } else {
            value_idxs.push(own i)
        }
    }

    // All type names are now in scope. Process the collected lists.
    for ei : U32 in enum_idxs {
        gen_enum_nonclone_methods_for_stmt(program.child(ei), scope)
    }
    for ai : U32 in alias_idxs {
        register_type_alias_for_stmt(program.child(ai), scope)
    }
    for fi : U32 in func_idxs {
        register_function_def_for_stmt(program.child(fi), scope)
    }
    for vi : U32 in value_idxs {
        register_top_level_value_for_stmt(program.child(vi), scope)
    }

    Vec.delete(own enum_idxs, false)
    Vec.delete(own alias_idxs, false)
    Vec.delete(own func_idxs, false)
    Vec.delete(own value_idxs, false)
    return errors
}

// Run the global init steps that require a full program view.
init_declarations_global := proc(program: Expr, scope: TypeScope) returns shallow I32 {
    mut errors : I32 = 0

    // Single AST walk: bucket struct and enum decls for post-walk work,
    // and bucket func/value decls in case global generation steps added
    // new ones (size/derived methods) that need to be registered.
    struct_idxs := Vec.new("U32", U32.size())
    enum_idxs := Vec.new("U32", U32.size())
    func_idxs := Vec.new("U32", U32.size())
    value_idxs := Vec.new("U32", U32.size())
    for i in 0..program.children.len() {
        ref stmt : Expr = program.child(i)
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        ref rhs : Expr = stmt.child(0)
        if rhs.node_type.is(NodeType.StructDef) {
            struct_idxs.push(own i)
        } else if rhs.node_type.is(NodeType.EnumDef) {
            enum_idxs.push(own i)
        } else if rhs.node_type.is(NodeType.FuncDef) {
            if rhs.children.len().gt(0) {
                func_idxs.push(own i)
            }
        } else if rhs.node_type.is(NodeType.Ident).not() {
            value_idxs.push(own i)
        }
    }

    // Method generation: clone+delete for structs, clone for enums.
    // Enum non-clone methods already ran per-unit.
    for si : U32 in struct_idxs {
        gen_struct_clone_delete_for_stmt(program.child(si), scope)
    }
    for ei : U32 in enum_idxs {
        gen_missing_enum_clone_for_stmt(program.child(ei))
    }
    // Layouts.
    for si : U32 in struct_idxs {
        compute_struct_layout(program.child(si).child(0), scope)
    }
    for ei : U32 in enum_idxs {
        compute_enum_layout(program.child(ei).child(0), scope)
    }
    // Size + cmp/unity derived methods.
    for si : U32 in struct_idxs {
        ref stmt : Expr = program.child(si)
        gen_struct_size_method_for_stmt(stmt)
        gen_cmp_derived_for_stmt(stmt)
        gen_unity_derived_for_stmt(stmt)
    }
    for ei : U32 in enum_idxs {
        ref stmt : Expr = program.child(ei)
        gen_enum_size_method_for_stmt(stmt, scope)
        gen_cmp_derived_for_stmt(stmt)
        gen_unity_derived_for_stmt(stmt)
    }
    // Re-register function/value decls -- new ones may have been generated
    // above (size methods etc) but those go into ns_decls, not program.children.
    // Still re-register here to mirror the original ordering.
    for fi : U32 in func_idxs {
        register_function_def_for_stmt(program.child(fi), scope)
    }
    for vi : U32 in value_idxs {
        register_top_level_value_for_stmt(program.child(vi), scope)
    }

    Vec.delete(own struct_idxs, false)
    Vec.delete(own enum_idxs, false)
    Vec.delete(own func_idxs, false)
    Vec.delete(own value_idxs, false)
    return errors
}

// rstil-style init: recursively init imports then this file.
// Count ~import("...")~ FCalls at the top level of `body`. Used by step 5
// to distinguish mode auto-imports (prepended to iu.imports by the loader)
// from explicit imports that appear in the source AST.
count_ast_imports := func(body: Expr) returns shallow USize {
    mut n : USize = 0.to_u32()
    for stmt : Expr in body.children {
        if stmt.node_type.is(NodeType.FCall).not() { continue }
        if stmt.children.len().neq(2) { continue }
        if stmt.child(0).node_type.is(NodeType.Ident).not() { continue }
        if stmt.child(1).node_type.is(NodeType.LiteralStr).not() { continue }
        ref id : Str = get_payload(stmt.child(0).node_type)
        if id.eq("import") { n = n.add(1.to_u32()) }
    }
    return n
}

init_file := proc(path: Str, ctx: Context) returns shallow I32 {
    if ctx.imports_init_done.has(path) {
        return 0.to_i32()
    }
    ctx.imports_init_done.add(own path.clone())

    ref iu : ImportUnit = ctx.imported.get(path)

    // Walk the AST in source order and recurse on each ~import("...")~ FCall.
    // iu.imports is kept as a side table that maps the i-th import FCall to
    // its resolved disp path. The loader prepends mode auto-imports (e.g.
    // `mode gui` -> gui.til) ahead of the AST-extracted imports, so process
    // those leading entries first before walking. #165 step 5.
    ast_count : USize = count_ast_imports(iu.ast)
    auto_count : USize = iu.imports.len().sub(ast_count)
    for i in 0..auto_count {
        ref dep : Str = iu.imports.get(i)
        init_file(dep, ctx)
    }
    mut import_idx : USize = auto_count
    for stmt : Expr in iu.ast.children {
        if stmt.node_type.is(NodeType.FCall).not() { continue }
        if stmt.children.len().neq(2) { continue }
        if stmt.child(0).node_type.is(NodeType.Ident).not() { continue }
        if stmt.child(1).node_type.is(NodeType.LiteralStr).not() { continue }
        ref id : Str = get_payload(stmt.child(0).node_type)
        if id.eq("import").not() { continue }
        ref dep : Str = iu.imports.get(import_idx)
        init_file(dep, ctx)
        import_idx = import_idx.add(1.to_u32())
    }

    ctx.mode = iu.mode.clone()
    init_declarations_unit(path, iu.ast, ctx.scope, ctx)
    return 0.to_i32()
}

// sync_body_ns_to_payload: deleted -- all ns methods now go directly to ns_decls
