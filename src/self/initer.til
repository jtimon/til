compute_struct_layout := proc(name: Str, mut struct_def: Expr, scope: TypeScope, ctx: Context) {
    if ctx.struct_layouts.has(name) { return }
    // Set sentinel so nested recursion into self-referential types
    // (e.g. linked-list-style struct with a ref field of its own type)
    // sees a non-empty entry and short-circuits.
    ctx.struct_layouts.set(name, own StructLayout(total_size = 1))
    switch struct_def.node_type {
    case NodeType.StructDef(struct_meta):
        mut offset : USize = 0
        mut max_align : USize = 1
        mut sl := StructLayout()

        for mut fd : Declaration in struct_meta.fields {
            mut fsz : USize = 0
            mut falign : USize = 0
            mut field_struct_name := ""

            if fd.own_type.is(OwnType.Shallow).not() {
                fsz = 8
                falign = 8

                mut ftype := fd.explicit_type
                if ftype.len().eq(0) {
                    if fd.default_value.is_null().not() {
                        ref def_val : Expr = fd.default_value
                        if def_val.node_type.is(NodeType.FCall) {
                            if def_val.children.len().gt(0) {
                                ref callee : Expr = def_val.child(0)
                                switch callee.node_type {
                                case NodeType.Ident(ft):
                                    ftype = ft.ident_name()
                                case:
                                }
                            }
                        }
                        if ftype.len().gt(0) {
                            fd.explicit_type = ftype
                            fd.til_type = til_type_from_explicit_type(fd.explicit_type)
                        }
                    }
                }

            } else {
                mut ftype := fd.explicit_type
                if ftype.len().eq(0) {
                    if fd.default_value.is_null().not() {
                        ref def_val : Expr = fd.default_value
                        if def_val.node_type.is_literal_num() { ftype = "I64" }
                        else if def_val.node_type.is_literal_str() { ftype = "Str" }
                        else if def_val.node_type.is_literal_bool() { ftype = "Bool" }
                        else if til_type_name(def_val.expr_til_type()).len().gt(0) { ftype = til_type_name(def_val.expr_til_type()) }
                        else if def_val.node_type.is(NodeType.FCall) {
                            if def_val.children.len().gt(0) {
                                ref callee : Expr = def_val.child(0)
                                switch callee.node_type {
                                case NodeType.Ident(ft):
                                    ftype = ft.ident_name()
                                case NodeType.FieldAccess:
                                    if callee.children.len().gt(0) {
                                        ref type_node : Expr = callee.child(0)
                                        switch type_node.node_type {
                                        case NodeType.Ident(ft):
                                            ftype = ft.ident_name()
                                        case:
                                        }
                                    }
                                case:
                                }
                            }
                        } else if def_val.node_type.is(NodeType.FieldAccess) {
                            if def_val.children.len().gt(0) {
                                ref type_node : Expr = def_val.child(0)
                                switch type_node.node_type {
                                case NodeType.Ident(ft):
                                    ftype = ft.ident_name()
                                case:
                                }
                            }
                        }
                        if ftype.len().gt(0) {
                            fd.explicit_type = ftype
                            fd.til_type = til_type_from_explicit_type(fd.explicit_type)
                        }
                    }
                }

                ref ab : TypeBinding = scope.get_binding(ftype)
                if ab.is_null().not() {
                    if ab.is_type_alias {
                        if ab.alias_target.is_empty().not() {
                            ftype = ab.alias_target
                            fd.explicit_type = ftype
                            fd.til_type = til_type_from_explicit_type(fd.explicit_type)
                        }
                    }
                }

                if ftype.len().eq(0) { fsz = 8; falign = 8 }
                else {
                    mut prim : Primitive = Primitive.I64
                    mut psz : USize = 0
                    mut pal : USize = 0
                    mut pbuiltin : Bool = false
                    is_prim : Bool = primitive_type_info(ftype, prim, psz, pal, pbuiltin)
                    if is_prim {
                        fsz = psz
                        falign = pal
                    } else if type_from_name_init(ftype, scope).is_funcptr() {
                        fsz = 8
                        falign = 8
                    } else {
                        ref nested_def : Expr = scope.get_struct(ftype)
                        if nested_def.is_null().not() {
                            if nested_def.node_type.is(NodeType.EnumDef) {
                                fsz = compute_enum_layout(ftype, nested_def, scope, ctx)
                                if enum_has_payloads(nested_def) { falign = 8 } else { falign = 4 }
                                field_struct_name = ftype.clone()
                            } else {
                                compute_struct_layout(ftype, nested_def, scope, ctx)
                                ref nested_layout : StructLayout = ctx.struct_layouts[ftype]
                                fsz = nested_layout.total_size
                                falign = nested_layout.align
                                field_struct_name = ftype.clone()
                            }
                        } else {
                            fsz = 8
                            falign = 8
                        }
                    }
                }
            }

            offset = align_up(offset, falign)
            sl.fields.push(own FieldLayout(offset = offset, size = fsz, struct_name = field_struct_name))
            if falign.gt(max_align) { max_align = falign }
            offset = offset.add(fsz)
        }

        sl.total_size = align_up(offset, max_align)
        sl.align = max_align
        if sl.total_size.eq(0) { sl.total_size = 1 }
        ctx.struct_layouts.set(name, own sl)
    case:
        UNREACHABLE(__LOC__)
    }
}

// Compute size and alignment for a TIL type name.
// For struct/enum payloads, recurses into compute_struct_layout / compute_enum_layout.
priv type_size_align := proc(ftype: Str, scope: TypeScope, ctx: Context, mut sz: USize, mut al: USize) {
    mut prim : Primitive = Primitive.I64
    mut psz : USize = 0
    mut pal : USize = 0
    mut pbuiltin : Bool = false
    if primitive_type_info(ftype, prim, psz, pal, pbuiltin) {
        sz = psz
        al = pal
        return
    }
    if type_from_name_init(ftype, scope).is_funcptr() { sz = 8; al = 8; return }
    ref nested : Expr = scope.get_struct(ftype)
    if nested.is_null() { sz = 8; al = 8; return }
    switch nested.node_type {
    case NodeType.StructDef:
        compute_struct_layout(ftype, nested, scope, ctx)
        ref sl : StructLayout = ctx.struct_layouts[ftype]
        sz = sl.total_size
        al = sl.align
    case NodeType.EnumDef:
        sz = compute_enum_layout(ftype, nested, scope, ctx)
        al = 8
    case:
        sz = 8
        al = 8
    }
}

compute_enum_layout := proc(name: Str, enum_def: Expr, scope: TypeScope, ctx: Context) returns USize {
    if ctx.struct_layouts.has(name) { return ctx_total_size(name, ctx) }
    // Set sentinel before recursing to break self-referential cycles.
    ctx.struct_layouts.set(name, own StructLayout(total_size = 4, align = 4))
    switch enum_def.node_type {
    case NodeType.EnumDef(edd):
        mut max_payload_size : USize = 0
        mut max_payload_align : USize = 4
        for vi in 0..edd.variants.len() {
            vt := enum_variant_type(enum_def, vi.cast(I32))
            if vt.len().eq(0) { continue }
            mut psz : USize = 0
            mut palign : USize = 0
            type_size_align(vt, scope, ctx, psz, palign)
            if psz.gt(max_payload_size) { max_payload_size = psz }
            if palign.gt(max_payload_align) { max_payload_align = palign }
        }
        mut total : USize = 4
        if max_payload_size.gt(0) {
            total = align_up(4, max_payload_align)
            total = total.add(max_payload_size)
        }
        total = align_up(total, max_payload_align)
        ctx.struct_layouts.set(name, own StructLayout(total_size = total, align = max_payload_align))
        return total
    case:
        UNREACHABLE(__LOC__)
        return 0
    }
}

// Issue #147 step 4: lookup helper for the struct/enum total size out of
// ctx.struct_layouts. Returns 0 when the name is unregistered (which
// downstream code already handles as "unknown size / fall back").
ctx_total_size := func(name: Str, ctx: Context) returns USize {
    if name.len().eq(0) { return 0 }
    if ctx.struct_layouts.has(name).not() { return 0 }
    ref sl : StructLayout = ctx.struct_layouts[name]
    return sl.total_size
}

// Issue #147 step 4: per-field layout lookup. Walks the parent struct's
// definition to find ~field_name~'s index, then returns the FieldLayout
// (offset, size, struct_name) from ctx.struct_layouts. Returns the zero
// FieldLayout when the parent or field isn't registered, matching what
// the AST field_offset / field_size used to default to.
ctx_field_layout := func(sname: Str, field_name: Str, ctx: Context) returns FieldLayout {
    if sname.len().eq(0).or(field_name.len().eq(0)) { return FieldLayout() }
    if ctx.struct_layouts.has(sname).not() { return FieldLayout() }
    ref sl : StructLayout = ctx.struct_layouts[sname]
    ref tdef : Expr = lookup_interp_type_def(sname, ctx)
    if tdef.is_null() { return FieldLayout() }
    switch tdef.node_type {
    case NodeType.StructDef(sdd):
        for i in 0..sdd.fields.len() {
            ref fd : Declaration = sdd.fields[i]
            if fd.name.eq(field_name) {
                if i.lt(sl.fields.len()) {
                    ref fl : FieldLayout = sl.fields[i]
                    return FieldLayout(offset = fl.offset, size = fl.size, struct_name = fl.struct_name.clone())
                }
                return FieldLayout()
            }
        }
    case:
    }
    return FieldLayout()
}


priv infer_top_level_decl_type := func(stmt: Expr, scope: TypeScope, mut out_type: Type) returns Bool {
    ref rhs : Expr = stmt.child(0)
    out_type = Type.Unknown

    switch stmt.node_type {
    case NodeType.Decl(dd):
        if dd.explicit_type.len().gt(0) {
            out_type = init_type_from_explicit_type(dd.explicit_type, scope)
            return out_type.is(Type.Unknown).not()
        }
    case:
    }

    switch rhs.node_type {
    case NodeType.Literal(Literal.Num):
        out_type = Type.Primitive(Primitive.I64)
        return true
    case NodeType.Literal(Literal.Bool):
        out_type = Type.Primitive(Primitive.Bool)
        return true
    case NodeType.Literal(Literal.Str):
        out_type = Type.Struct("Str")
        return true
    case NodeType.Literal(Literal.Null):
        out_type = Type.Dynamic
        return true
    case NodeType.Ident(id):
        ref b : TypeBinding = scope.get_binding(id.ident_name())
        if b.is_null() { return false }
        out_type = b.type
        return out_type.is(Type.Unknown).not()
    case NodeType.FieldAccess:
        mut init_ns1 := false
        if rhs.children.len().gt(0) {
            ref io1 : Expr = rhs.child(0)
            if io1.node_type.is(NodeType.Ident) {
                if til_type_name(io1.expr_til_type()).eq("StructDef").or(til_type_name(io1.expr_til_type()).eq("EnumDef")) {
                    init_ns1 = true
                }
            }
        }
        if init_ns1.and(rhs.expr_til_type().is(Type.Enum)) {
            mut enum_name := ""
            if rhs.children.len().gt(0) {
                enum_name = til_type_name(rhs.child(0).expr_til_type())
            }
            out_type = Type.Enum(enum_name.clone())
            return true
        }
        return false
    case NodeType.FCall:
        ref callee : Expr = rhs.child(0)
        switch callee.node_type {
        case NodeType.Ident(cn):
            if til_type_name(rhs.expr_til_type()).len().gt(0).and(cn.ident_name().eq(til_type_name(rhs.expr_til_type()))) {
                out_type = Type.Struct(til_type_name(rhs.expr_til_type()))
                return true
            }
            ref fb : TypeBinding = scope.get_binding(cn.ident_name())
            if fb.is_null() { return false }
            out_type = fb.type
            return out_type.is(Type.Unknown).not()
        case NodeType.FieldAccess:
            mut init_ns2 := false
            if callee.children.len().gt(0) {
                ref io2 : Expr = callee.child(0)
                if io2.node_type.is(NodeType.Ident) {
                    if til_type_name(io2.expr_til_type()).eq("StructDef").or(til_type_name(io2.expr_til_type()).eq("EnumDef")) {
                        init_ns2 = true
                    }
                }
            }
            if init_ns2.and(til_type_name(rhs.expr_til_type()).len().gt(0)).and(rhs.expr_til_type().is(Type.Enum)) {
                out_type = Type.Enum(til_type_name(rhs.expr_til_type()))
                return true
            }
            return false
        case:
            return false
        }
    case:
        return false
    }
}

// Issue #93: lift nested struct/enum/func definitions out of function
// bodies up to the program top level.
//
// Folded into init_declarations_unit's existing single AST walk: when
// that walk visits a top-level FuncDef-with-body, it calls
// init_lift_in_body on the body. Inner Decls whose RHS is StructDef,
// EnumDef, or FuncDef-with-body are mangled to `<parent>_<orig>`,
// appended to program.children, and replaced in the original body slot
// with an empty inner Body (no-op `{}` in C). References to the
// original name within the parent body (Ident, FieldAccess base,
// FCall callee, Decl explicit_type, FuncDef return_type and param
// types, struct field types, enum variant payload types) are
// rewritten in-place through a single recursive walk in
// init_rewrite_refs.
//
// The main init walk's while loop re-checks program.children.len()
// each iteration, so the lifted decls get registered by the same walk
// in subsequent iterations -- one walk does both jobs.
//
// ext_func / ext_proc forward declarations stay in place (they refer
// to externally-linked C symbols).

priv init_is_lift_target := func(stmt: Expr) returns Bool {
    if stmt.node_type.is(NodeType.Decl).not() { return false }
    if stmt.children.len().eq(0) { return false }
    ref rhs : Expr = stmt.child(0)
    if rhs.node_type.is(NodeType.StructDef) { return true }
    if rhs.node_type.is(NodeType.EnumDef) { return true }
    if rhs.node_type.is(NodeType.FuncDef) {
        if rhs.children.len().eq(0) { return false }
        switch rhs.node_type {
        case NodeType.FuncDef(rhs_fd):
            if rhs_fd.func_type.is(FuncType.ExtFunc) { return false }
            if rhs_fd.func_type.is(FuncType.ExtProc) { return false }
            // Issue #54: a capturing nested function is a closure -- it
            // must stay nested so its body resolves the captured outer
            // locals (hoisting to file scope would strand them). The typer
            // enforces the explicit-capture restriction.
            if rhs_fd.captures.len().gt(0) { return false }
            return true
        case:
            return false
        }
    }
    return false
}

priv init_lookup_name := func(renamings: Map(Str, Str), name: Str) returns Str {
    if name.len().eq(0) { return "" }
    if renamings.has(name).not() { return "" }
    ref s : Str = renamings[name]
    return s.clone()
}

priv init_rename_ident_in_place := func(mut e: Expr, renamings: Map(Str, Str)) {
    switch e.node_type {
    case NodeType.Ident(name):
        new_name := init_lookup_name(renamings, name.ident_name())
        if new_name.len().gt(0) {
            e.node_type = ident_node(new_name)
        }
    case NodeType.Assign(ad):
        // Assignments to a renamed top-level priv: `local_counter = ...`
        // stores the LHS name on AssignData, not as a child Ident, so the
        // generic Ident rename above misses it.
        new_name := init_lookup_name(renamings, ad.name)
        if new_name.len().gt(0) {
            ad.name = new_name.clone()
        }
    case:
    }
}

priv init_rename_decl_in_place := func(mut dd: Declaration, renamings: Map(Str, Str)) {
    if dd.explicit_type.len().eq(0) { return }
    new_t := init_lookup_name(renamings, dd.explicit_type)
    if new_t.len().gt(0) {
        dd.explicit_type = new_t
    }
}

priv init_rewrite_refs := proc(mut e: Expr, renamings: Map(Str, Str)) {
    if e.is_null() { return }
    init_rename_ident_in_place(e, renamings)
    // `for x : LocalInfo in xs { ... }` stores the loop's explicit type
    // on the ForIn node's payload as Type.Custom("LocalInfo") (read back
    // via expr_til_type). No Declaration is involved (parser.til:1428),
    // so init_rename_decl_in_place misses it; patch the Type.Custom
    // payload here.
    custom_t := e.expr_til_type()
    switch custom_t {
    case Type.Custom(custom_name):
        new_custom := init_lookup_name(renamings, custom_name)
        if new_custom.len().gt(0) {
            e.set_expr_til_type(Type.Custom(new_custom.clone()))
        }
    case:
    }
    switch e.node_type {
    case NodeType.Decl(dd):
        init_rename_decl_in_place(dd, renamings)
    case NodeType.FuncDef(fd):
        if fd.return_type.len().gt(0) {
            new_rt := init_lookup_name(renamings, fd.return_type)
            if new_rt.len().gt(0) {
                fd.return_type = new_rt
            }
        }
        for mut pd : Declaration in fd.params {
            init_rename_decl_in_place(pd, renamings)
            if pd.default_value.is_null().not() {
                init_rewrite_refs(pd.default_value, renamings)
            }
        }
    case NodeType.StructDef(sdd):
        for mut sf : Declaration in sdd.fields {
            init_rename_decl_in_place(sf, renamings)
            if sf.default_value.is_null().not() {
                init_rewrite_refs(sf.default_value, renamings)
            }
        }
        for mut nd : Declaration in sdd.ns_decls {
            init_rename_decl_in_place(nd, renamings)
            if nd.default_value.is_null().not() {
                init_rewrite_refs(nd.default_value, renamings)
            }
        }
    case NodeType.EnumDef(edd):
        for vi in 0..edd.variants.len() {
            vidx := vi.to_i64()
            if edd.payload_types.has(vidx).not() { continue }
            ref pt_old : Str = edd.payload_types[vidx]
            new_pt := init_lookup_name(renamings, pt_old)
            if new_pt.len().gt(0) {
                edd.payload_types.set(vidx, own new_pt.clone())
            }
        }
        for mut nd : Declaration in edd.ns_decls {
            init_rename_decl_in_place(nd, renamings)
            if nd.default_value.is_null().not() {
                init_rewrite_refs(nd.default_value, renamings)
            }
        }
    case:
    }
    for i in 0..e.children.len() {
        ref mut c : Expr = e.child(i)
        init_rewrite_refs(c, renamings)
    }
}

priv init_lift_in_body := proc(mut body: Expr, parent_prefix: Str, mut top_level: Vec(Expr)) {
    if body.is_null() { return }
    if body.node_type.is(NodeType.Body).not() { return }

    mut renamings := Map(Str, Str).new()
    mut lifted_indices := Vec(USize).new()

    for i in 0..body.children.len() {
        ref child : Expr = body.child(i)
        if init_is_lift_target(child).not() { continue }
        switch child.node_type {
        case NodeType.Decl(child_dd):
            mangled := parent_prefix.concat("_").concat(child_dd.name)
            renamings.set(child_dd.name, own mangled.clone())
            child_dd.orig_name = child_dd.name.clone()
            child_dd.name = mangled.clone()
            child_dd.is_priv = true
            mut idx := i
            lifted_indices.push(own idx)
        case:
        }
    }

    if renamings.len().gt(0) {
        for i in 0..body.children.len() {
            ref mut c : Expr = body.child(i)
            init_rewrite_refs(c, renamings)
        }
    }

    for idx : USize in lifted_indices {
        ref mut slot : Expr = body.child(idx)
        switch slot.node_type {
        case NodeType.Decl(slot_dd):
            ref mut slot_rhs : Expr = slot.child(0)
            if slot_rhs.node_type.is(NodeType.FuncDef) {
                if slot_rhs.children.len().gt(0) {
                    ref mut fbody : Expr = slot_rhs.child(0)
                    init_lift_in_body(fbody, slot_dd.name, top_level)
                }
            } else if slot_rhs.node_type.is(NodeType.StructDef).or(slot_rhs.node_type.is(NodeType.EnumDef)) {
                init_lift_in_ns_decls(slot_rhs, slot_dd.name, top_level)
            }
            top_level.push(own slot.clone())
        case:
            UNREACHABLE(__LOC__)
        }
        mut empty_body := Expr.new(NodeType.Body, slot.line, slot.col)
        body.children.set(idx, own empty_body)
    }

    init_recurse_into_subbodies(body, parent_prefix, top_level)
}

priv init_lift_in_ns_decls := proc(mut def: Expr, parent_prefix: Str, mut top_level: Vec(Expr)) {
    if def.is_null() { return }
    switch def.node_type {
    case NodeType.StructDef(ld_sdd):
        for mut nd : Declaration in ld_sdd.ns_decls {
            if nd.default_value.is_null() { continue }
            if nd.default_value.node_type.is(NodeType.FuncDef).not() { continue }
            if nd.default_value.children.len().eq(0) { continue }
            ref mut nbody : Expr = nd.default_value.child(0)
            init_lift_in_body(nbody, parent_prefix, top_level)
        }
    case NodeType.EnumDef(ld_edd):
        for mut nd : Declaration in ld_edd.ns_decls {
            if nd.default_value.is_null() { continue }
            if nd.default_value.node_type.is(NodeType.FuncDef).not() { continue }
            if nd.default_value.children.len().eq(0) { continue }
            ref mut nbody : Expr = nd.default_value.child(0)
            init_lift_in_body(nbody, parent_prefix, top_level)
        }
    case:
    }
}

priv init_recurse_into_subbodies := proc(mut body: Expr, parent_prefix: Str, mut top_level: Vec(Expr)) {
    for i in 0..body.children.len() {
        ref mut c : Expr = body.child(i)
        init_recurse_into_expr(c, parent_prefix, top_level)
    }
}

priv init_recurse_into_expr := proc(mut e: Expr, parent_prefix: Str, mut top_level: Vec(Expr)) {
    if e.is_null() { return }
    if e.node_type.is(NodeType.Body) {
        init_lift_in_body(e, parent_prefix, top_level)
        return
    }
    if e.node_type.is(NodeType.FuncDef) {
        if e.children.len().gt(0) {
            ref mut fbody : Expr = e.child(0)
            init_lift_in_body(fbody, parent_prefix, top_level)
        }
        return
    }
    for i in 0..e.children.len() {
        ref mut c : Expr = e.child(i)
        init_recurse_into_expr(c, parent_prefix, top_level)
    }
}

// Issue #57: macros returning `StructDef` / `EnumDef` / `FuncDef` act
// as generators -- `Pair := make_pair(I64)` should be equivalent to
// `Pair := struct { first: I64 = 0, second: I64 = 0 }`, and
// `add5 := make_adder(5)` to
// `add5 := func(x: I64) returns I64 { return x.add(5) }`. Mirrors
// rstil's macro-returns-StructDef path (precomp.rs ~309): scan top-level
// decls whose RHS is a call to a top-level macro returning a type-def or
// func-def, inline the macro body's return literal with the macro's
// parameters substituted out for the call-site args, and replace the
// Decl's RHS with the resulting struct/enum/func literal. The rest of
// the registration walk then treats the Decl like any other named def.
//
// Macro bodies are required to be a single `return <struct|enum|func
// literal>` statement; anything more complex isn't expanded here (a
// diagnostic is emitted later by the normal typer).
//
// The substitution map is param-name -> arg-expression (whole Expr).
// For a `T: Type` param the arg is an Ident (e.g. `I64`); for value
// params like `N: I64` the arg can be any expression (literal, ident,
// fcall). `init_substitute_idents` replaces the whole Expr when an Ident
// matches a substituted name, so an `Ident(N)` becomes a clone of the
// arg expression (e.g. `LiteralNum 5`). Type-position substitutions use
// the ident name when possible, or the deterministic macro-inst arg name
// for nested template args like `Vec(Str)`.
priv init_subst_ident_name := func(subs: Map(Str, Expr), name: Str) returns Str {
    if subs.has(name) {
        ref repl : Expr = subs[name]
        switch repl.node_type {
        case NodeType.Ident(idn):
            return idn.ident_name().clone()
        case NodeType.FCall:
            return init_macro_inst_name(repl)
        case:
            return init_macro_inst_arg_name(repl)
        }
    }

    // Issue #267: type-position template self-references parse as a mangled
    // name before macro expansion (`TemplVec(T)` -> `TemplVec__T`). Substitute
    // any type-param segment inside that generated name so the expanded method
    // points at the current monomorphization (`TemplVec__I64`).
    marker := name.find("__")
    if marker.lt(0) { return "" }
    marker_u : USize = marker.to_usize()
    if marker_u.add(2).gte(name.len()) { return "" }
    prefix := name.substr(0, marker_u.add(2))
    args := name.substr(marker_u.add(2), name.len().sub(marker_u).sub(2)).split("_")
    mut changed := false
    mut out := prefix.clone()
    for i in 0..args.len() {
        if i.gt(0) { out = out.concat("_") }
        ref arg : Str = args[i]
        if subs.has(arg) {
            ref repl_arg : Expr = subs[arg]
            switch repl_arg.node_type {
            case NodeType.Ident(idn_arg):
                out = out.concat(idn_arg.ident_name())
                changed = true
            case:
                out = out.concat(init_macro_inst_arg_name(repl_arg))
                changed = true
            }
        } else {
            out = out.concat(arg)
        }
    }
    if changed { return out }
    return ""
}

priv init_substitute_idents := func(mut e: Expr, subs: Map(Str, Expr)) {
    if e.is_null() { return }
    switch e.node_type {
    case NodeType.Ident(idn):
        nm := idn.ident_name()
        if subs.has(nm) {
            ref repl_expr : Expr = subs[nm]
            cloned := repl_expr.clone()
            e.replace_with(own cloned)
            // The replacement now occupies `e`; children of the original
            // Ident were none, so no further recursion at this node.
            return
        }
    case NodeType.Decl(dd):
        // Issue #243: a body-local declaration (`ref x : T = ...`,
        // `mut y : T = ...`) carries its type as a Declaration.explicit_type
        // string, not an Ident expr, so substitute it here too -- otherwise
        // T stays unresolved inside macro-templated method bodies. Then fall
        // through to recurse into the RHS value child below.
        new_type := init_subst_ident_name(subs, dd.explicit_type)
        if new_type.len().gt(0) {
            dd.explicit_type = new_type.clone()
            dd.til_type = til_type_from_explicit_type(dd.explicit_type)
        }
    case:
    }
    for mut c : Expr in e.children {
        init_substitute_idents(c, subs)
    }
}

// Helpers that take the StructDef / EnumDef directly (not via the
// switch-case destructure binding) so the typer carries the Map<I64,Str>
// type info into the payload-types subscript without the
// throws-inference mixing OutOfBounds (Vec) into KeyNotFound (Map).
priv init_subst_struct_params := func(sdef: StructDef, subs: Map(Str, Expr)) {
    for mut fd : Declaration in sdef.fields {
        new_type := init_subst_ident_name(subs, fd.explicit_type)
        if new_type.len().gt(0) {
            fd.explicit_type = new_type.clone()
            fd.til_type = til_type_from_explicit_type(fd.explicit_type)
        }
        if fd.default_value.is_null().not() {
            init_substitute_idents(fd.default_value, subs)
        }
    }
    for mut nd : Declaration in sdef.ns_decls {
        new_type := init_subst_ident_name(subs, nd.explicit_type)
        if new_type.len().gt(0) {
            nd.explicit_type = new_type.clone()
            nd.til_type = til_type_from_explicit_type(nd.explicit_type)
        }
        if nd.default_value.is_null().not() {
            // Issue #243: a namespace method's value is a FuncDef. Recurse
            // with the full type-param substitution (param/return types AND
            // body) so `T` resolves inside methods, not just in struct fields.
            // Non-FuncDef ns defaults (constants) only need Ident substitution.
            if nd.default_value.node_type.is(NodeType.FuncDef) {
                init_substitute_type_params(nd.default_value, subs)
            } else {
                init_substitute_idents(nd.default_value, subs)
            }
        }
    }
}

priv init_subst_enum_params := func(mut edef: EnumDef, subs: Map(Str, Expr)) {
    for k in 0..edef.variants.len() {
        if edef.payload_types.has(k.to_i64()) {
            ref pt : Str = edef.payload_types[k.to_i64()]
            new_pt := init_subst_ident_name(subs, pt)
            if new_pt.len().gt(0) {
                edef.payload_types.set(k.to_i64(), own new_pt.clone())
            }
        }
    }
    for mut nd : Declaration in edef.ns_decls {
        new_type := init_subst_ident_name(subs, nd.explicit_type)
        if new_type.len().gt(0) {
            nd.explicit_type = new_type.clone()
            nd.til_type = til_type_from_explicit_type(nd.explicit_type)
        }
        if nd.default_value.is_null().not() {
            // Issue #243 follow-up: same FuncDef dispatch as
            // init_subst_struct_params -- a namespace method's param
            // types and return type live in the FunctionDef payload,
            // not Expr.children, so init_substitute_idents alone would
            // miss them. Non-FuncDef ns defaults (constants) only need
            // Ident substitution.
            if nd.default_value.node_type.is(NodeType.FuncDef) {
                init_substitute_type_params(nd.default_value, subs)
            } else {
                init_substitute_idents(nd.default_value, subs)
            }
        }
    }
}

priv init_subst_func_params := func(mut fdd: FunctionDef, subs: Map(Str, Expr)) {
    for mut pd : Declaration in fdd.params {
        new_type := init_subst_ident_name(subs, pd.explicit_type)
        if new_type.len().gt(0) {
            pd.explicit_type = new_type.clone()
            pd.til_type = til_type_from_explicit_type(pd.explicit_type)
        }
        if pd.default_value.is_null().not() {
            init_substitute_idents(pd.default_value, subs)
        }
    }
    new_ret := init_subst_ident_name(subs, fdd.return_type)
    if new_ret.len().gt(0) {
        fdd.return_type = new_ret.clone()
    }
    for i in 0..fdd.throw_types.len() {
        ref tt : Str = fdd.throw_types[i]
        new_throw := init_subst_ident_name(subs, tt)
        if new_throw.len().gt(0) {
            fdd.throw_types.set(i, own new_throw.clone())
        }
    }
}

priv init_substitute_type_params := func(mut def: Expr, subs: Map(Str, Expr)) {
    switch def.node_type {
    case NodeType.StructDef(sdd):
        init_subst_struct_params(sdd, subs)
    case NodeType.EnumDef(edd):
        init_subst_enum_params(edd, subs)
    case NodeType.FuncDef(fdd):
        init_subst_func_params(fdd, subs)
        // Walk the function body too, substituting Ident references to
        // type-params (e.g. T used inside expressions, struct/enum
        // literals nested in the body).
        if def.children.len().gt(0) {
            ref mut fnbody : Expr = def.child(0)
            init_substitute_idents(fnbody, subs)
        }
    case:
    }
}

// Issue #58: evaluate a macro-body condition at expand time. Today
// only the `<Ident>.is(Type.<Variant>)` shape is recognised -- enough
// to make `if T.is(Type.Primitive(Primitive.Bool)) { ... }` style template branching pick
// a branch deterministically once T's substitution is applied. Returns
// 1 (true), 0 (false), or -1 (shape not understood, caller falls back
// to leaving the macro un-expanded).
priv init_macro_cond_eval := func(cond: Expr) returns I32 {
    if cond.node_type.is(NodeType.FCall).not() { return -1 }
    if cond.children.len().neq(2) { return -1 }
    ref callee : Expr = cond.child(0)
    if callee.node_type.is(NodeType.FieldAccess).not() { return -1 }
    mut method_name := ""
    switch callee.node_type {
    case NodeType.FieldAccess(fan): method_name = fan.field_access_name()
    case: return -1
    }
    if method_name.eq("is").not() { return -1 }
    if callee.children.len().neq(1) { return -1 }
    ref lhs : Expr = callee.child(0)
    mut lhs_name := ""
    switch lhs.node_type {
    case NodeType.Ident(idn): lhs_name = idn.ident_name()
    case: return -1
    }
    ref arg : Expr = cond.child(1)
    // Nested form `Type.Primitive(Primitive.X)` (an FCall): a primitive that
    // lives under Type.Primitive rather than as a flat Type variant. Match
    // the inner primitive name against the substituted type-param Ident.
    if arg.node_type.is(NodeType.FCall) {
        if arg.children.len().neq(2) { return -1 }
        ref p_callee : Expr = arg.child(0)
        mut p_callee_name := ""
        switch p_callee.node_type {
        case NodeType.FieldAccess(p_fan): p_callee_name = p_fan.field_access_name()
        case: return -1
        }
        if p_callee_name.eq("Primitive").not() { return -1 }
        if p_callee.children.len().neq(1) { return -1 }
        switch p_callee.child(0).node_type {
        case NodeType.Ident(p_recv): if p_recv.ident_name().eq("Type").not() { return -1 }
        case: return -1
        }
        ref p_arg : Expr = arg.child(1)
        mut prim_name := ""
        switch p_arg.node_type {
        case NodeType.FieldAccess(p_arg_fan): prim_name = p_arg_fan.field_access_name()
        case: return -1
        }
        if p_arg.children.len().neq(1) { return -1 }
        switch p_arg.child(0).node_type {
        case NodeType.Ident(p_arg_recv): if p_arg_recv.ident_name().eq("Primitive").not() { return -1 }
        case: return -1
        }
        if lhs_name.eq(prim_name) { return 1 }
        return 0
    }
    if arg.node_type.is(NodeType.FieldAccess).not() { return -1 }
    mut variant_name := ""
    switch arg.node_type {
    case NodeType.FieldAccess(fan_arg): variant_name = fan_arg.field_access_name()
    case: return -1
    }
    if arg.children.len().neq(1) { return -1 }
    ref arg_recv : Expr = arg.child(0)
    mut recv_name := ""
    switch arg_recv.node_type {
    case NodeType.Ident(idr): recv_name = idr.ident_name()
    case: return -1
    }
    if recv_name.eq("Type").not() { return -1 }
    if lhs_name.eq(variant_name) { return 1 }
    return 0
}

// Pick the macro return literal from a possibly-if-shaped body. body
// must be a NodeType.Body. Returns NULL when the shape isn't a single
// Return or a recognised if-chain whose branches each terminate in a
// single Return; the caller falls back to leaving the macro un-expanded.
priv init_macro_pick_return := func(body: Expr, subs: Map(Str, Expr)) returns ref Expr {
    if body.is_null() { return NULL }
    if body.node_type.is(NodeType.Body).not() { return NULL }
    if body.children.len().neq(1) { return NULL }
    ref s : Expr = body.child(0)
    if s.node_type.is(NodeType.Return) {
        if s.children.len().eq(0) { return NULL }
        return s.child(0)
    }
    if s.node_type.is(NodeType.If).not() { return NULL }
    if s.children.len().lt(2) { return NULL }
    // Clone + substitute the condition before evaluating: subs maps the
    // type-param Ident (`T`) onto the call's arg Ident (`Bool`), turning
    // `T.is(Type.Primitive(Primitive.Bool))` into `Bool.is(Type.Primitive(Primitive.Bool))`.
    mut cond_clone := s.child(0).clone()
    init_substitute_idents(cond_clone, subs)
    res := init_macro_cond_eval(cond_clone)
    if res.lt(0) { return NULL }
    if res.eq(1) {
        return init_macro_pick_return(s.child(1), subs)
    }
    if s.children.len().lt(3) { return NULL }
    return init_macro_pick_return(s.child(2), subs)
}

priv init_is_type_gen_macro_def := func(fdef: Expr) returns Bool {
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        if fd.func_type.is(FuncType.Macro).not() { return false }
        return fd.return_type.eq("StructDef")
            .or(fd.return_type.eq("EnumDef"))
            .or(fd.return_type.eq("FuncDef"))
            .or(fd.return_type.eq("FunctionDef"))
    case:
    }
    return false
}

priv init_lookup_type_gen_macro := func(name: Str, macros: Map(Str, Expr), scope: TypeScope) returns ref Expr {
    if macros.has(name) {
        ref local_macro : Expr = macros[name]
        return local_macro
    }
    ref imported_macro : Expr = scope.lookup_func(name)
    if imported_macro.is_null() { return NULL }
    if init_is_type_gen_macro_def(imported_macro).not() { return NULL }
    return imported_macro
}

// Issue #267 (caveat 2): inline instantiation of a type-gen macro. `e` is a
// macro-instantiation call `MACRO(arg1, ...)` when its callee is an Ident
// naming a local or imported StructDef/EnumDef/FuncDef-returning macro.
priv init_is_macro_inst_call := func(e: Expr, macros: Map(Str, Expr), scope: TypeScope) returns Bool {
    if e.node_type.is(NodeType.FCall).not() { return false }
    if e.children.len().lt(1) { return false }
    ref callee : Expr = e.child(0)
    if callee.node_type.is(NodeType.Ident).not() { return false }
    mut nm := ""
    switch callee.node_type {
    case NodeType.Ident(cn): nm = cn.ident_name()
    case:
    }
    return init_lookup_type_gen_macro(nm, macros, scope).is_null().not()
}

// A top-level `Name := MACRO(args)` decl whose RHS is directly a macro
// instantiation -- handled by the main expansion loop, so the inline-hoist
// pass leaves it alone (its only nested calls are the type-arg idents).
priv init_is_direct_macro_inst_decl := func(stmt: Expr, macros: Map(Str, Expr), scope: TypeScope) returns Bool {
    if stmt.node_type.is(NodeType.Decl).not() { return false }
    if stmt.children.len().eq(0) { return false }
    return init_is_macro_inst_call(stmt.child(0), macros, scope)
}

priv init_macro_inst_uses_own_type_param := func(rhs: Expr, macro_fdef: Expr) returns Bool {
    if rhs.node_type.is(NodeType.FCall).not() { return false }
    if macro_fdef.node_type.is(NodeType.FuncDef).not() { return false }
    switch macro_fdef.node_type {
    case NodeType.FuncDef(mfd):
        for i in 1..rhs.children.len() {
            ref arg : Expr = rhs.child(i)
            if arg.node_type.is(NodeType.Ident).not() { continue }
            mut arg_name := ""
            switch arg.node_type {
            case NodeType.Ident(an): arg_name = an.ident_name()
            case:
            }
            for p : Declaration in mfd.params {
                if p.explicit_type.eq("Type").and(p.name.eq(arg_name)) { return true }
            }
        }
    case:
    }
    return false
}

priv init_macro_inst_name_byte := func(b: I8) returns Str {
    if b.gte('a').and(b.lte('z')) { return Str.from_byte(b.cast(U8)) }
    if b.gte('A').and(b.lte('Z')) { return Str.from_byte(b.cast(U8)) }
    if b.gte('0').and(b.lte('9')) { return Str.from_byte(b.cast(U8)) }
    if b.eq('_') { return Str.from_byte(b.cast(U8)) }
    return "x".concat(b.cast(I64).to_str()).concat("x")
}

priv init_macro_inst_text_name := func(prefix: Str, text: Str) returns Str {
    mut out := prefix.concat(text.len().to_str()).concat("_")
    for i in 0..text.len() {
        out = out.concat(init_macro_inst_name_byte(text.byte_at(i)))
    }
    return out
}

priv init_type_arg_name := func(scope: TypeScope, name: Str) returns Str {
    if scope.is_null().not() {
        ref b : TypeBinding = scope.get_binding(name)
        if b.is_null().not() {
            if b.is_type_alias.and(b.alias_target.is_empty().not()) {
                return b.alias_target.clone()
            }
        }
    }
    return name.clone()
}

priv init_macro_inst_type_arg_name := func(arg: Expr, scope: TypeScope) returns Str {
    switch arg.node_type {
    case NodeType.Ident(an): return init_type_arg_name(scope, an.ident_name())
    case:
    }
    return init_macro_inst_arg_name(arg)
}

priv init_macro_inst_arg_name := func(arg: Expr) returns Str {
    switch arg.node_type {
    case NodeType.Ident(an): return an.ident_name()
    case NodeType.Literal(Literal.Num(n)): return init_macro_inst_text_name("n", n.literal_num_text())
    case NodeType.Literal(Literal.Str(s)): return init_macro_inst_text_name("s", s)
    case NodeType.Literal(Literal.Bool(b)):
        if b { return "btrue" }
        return "bfalse"
    case NodeType.Literal(Literal.Null): return "null"
    case NodeType.FieldAccess(fa):
        mut out := "fa".concat(init_macro_inst_text_name("f", fa.field_access_name()))
        for c : Expr in arg.children {
            out = out.concat("_").concat(init_macro_inst_arg_name(c))
        }
        return out
    case NodeType.FCall:
        mut out := "call"
        for c : Expr in arg.children {
            out = out.concat("_").concat(init_macro_inst_arg_name(c))
        }
        return out
    case:
    }
    return init_macro_inst_text_name("e", arg.to_str())
}

// Deterministic, dedup-friendly name for a monomorphization: `MACRO__Arg1_Arg2`
// (the same macro + same compile-time args always yields the same name, so
// inline uses share one generated type without conflating value arguments).
priv init_macro_inst_name := func(e: Expr) returns Str {
    ref callee : Expr = e.child(0)
    mut out := ""
    switch callee.node_type {
    case NodeType.Ident(cn): out = cn.ident_name().concat("__")
    case:
    }
    for k in 1..e.children.len() {
        if k.gt(1) { out = out.concat("_") }
        ref arg : Expr = e.child(k)
        out = out.concat(init_macro_inst_arg_name(arg))
    }
    return out
}

priv init_macro_inst_name_for_macro := func(e: Expr, macro_fdef: Expr, scope: TypeScope) returns Str {
    ref callee : Expr = e.child(0)
    mut out := ""
    switch callee.node_type {
    case NodeType.Ident(cn): out = cn.ident_name().concat("__")
    case:
    }
    for k in 1..e.children.len() {
        if k.gt(1) { out = out.concat("_") }
        ref arg : Expr = e.child(k)
        mut is_type_arg := false
        switch macro_fdef.node_type {
        case NodeType.FuncDef(mfd):
            pidx := k.sub(1)
            if pidx.lt(mfd.params.len()) {
                ref param : Declaration = mfd.params[pidx]
                is_type_arg = param.explicit_type.eq("Type")
            }
        case:
        }
        if is_type_arg {
            out = out.concat(init_macro_inst_type_arg_name(arg, scope))
        } else {
            out = out.concat(init_macro_inst_arg_name(arg))
        }
    }
    return out
}

priv init_macro_inst_name_in_scope := func(e: Expr, macros: Map(Str, Expr), scope: TypeScope) returns Str {
    if e.children.len().eq(0) { return init_macro_inst_name(e) }
    ref callee : Expr = e.child(0)
    switch callee.node_type {
    case NodeType.Ident(cn):
        ref macro_fdef : Expr = init_lookup_type_gen_macro(cn.ident_name(), macros, scope)
        if macro_fdef.is_null().not() {
            return init_macro_inst_name_for_macro(e, macro_fdef, scope)
        }
    case:
    }
    return init_macro_inst_name(e)
}

// Recursively rewrite every inline macro-instantiation call in `e`'s subtree
// to an Ident referencing a synthesized monomorphization decl. Dedup via
// ctx.type_gen_synths across all initialized units; accumulate any new
// `genname := MACRO(args)` decls in `synthesized` for this unit only.
// Replacing through `children.replace` frees the old call subtree.
priv init_hoist_walk := func(mut e: Expr, macros: Map(Str, Expr), scope: TypeScope, ctx: Context, mut synthesized: Vec(Expr), mark_ctx: Bool) {
    if e.is_null() { return }
    switch e.node_type {
    case NodeType.StructDef(sdd):
        for mut fd : Declaration in sdd.fields {
            if fd.default_value.is_null().not() {
                init_hoist_walk(fd.default_value, macros, scope, ctx, synthesized, mark_ctx)
            }
        }
        for mut nd : Declaration in sdd.ns_decls {
            if nd.default_value.is_null().not() {
                init_hoist_walk(nd.default_value, macros, scope, ctx, synthesized, mark_ctx)
            }
        }
    case NodeType.EnumDef(edd):
        for mut nd : Declaration in edd.ns_decls {
            if nd.default_value.is_null().not() {
                init_hoist_walk(nd.default_value, macros, scope, ctx, synthesized, mark_ctx)
            }
        }
    case NodeType.FuncDef(fdd):
        for mut pd : Declaration in fdd.params {
            if pd.default_value.is_null().not() {
                init_hoist_walk(pd.default_value, macros, scope, ctx, synthesized, mark_ctx)
            }
        }
    case:
    }
    for i in 0..e.children.len() {
        ref mut c : Expr = e.child(i)
        if init_is_macro_inst_call(c, macros, scope) {
            genname := init_macro_inst_name_in_scope(c, macros, scope)
            if ctx.type_gen_synths.has(genname).not() {
                mut decl := Expr.new(NodeType.Decl(Declaration(name = genname.clone())), c.line, c.col)
                decl.add_child(own c.clone())
                synthesized.push(own decl)
                if mark_ctx { ctx.type_gen_synths.add(own genname.clone()) }
            }
            mut idn := Expr.new(ident_node(genname), c.line, c.col)
            e.children.set(i, own idn)
        } else {
            init_hoist_walk(c, macros, scope, ctx, synthesized, mark_ctx)
        }
    }
}

// Issue #267 (caveat 2): hoist inline type-gen macro instantiations (used as
// `.new()` receivers, call args, etc.) into synthesized top-level decls, so
// `mut v := TemplVec(Bool).new()` works without first binding the type to a
// name. Synthesized decls are appended to `program` and then expanded by the
// main loop below. Dedup keys on the generated name, so N inline uses of
// `TemplVec(Bool)` compile to ONE generated type.
priv init_hoist_inline_macros := func(mut program: Expr, macros: Map(Str, Expr), scope: TypeScope, ctx: Context) {
    mut synthesized := Vec(Expr).new()
    np := program.children.len()
    for i in 0..np {
        ref mut stmt : Expr = program.child(i)
        if stmt.node_type.is(NodeType.Decl) {
            if stmt.children.len().gt(0) {
                if init_is_type_gen_macro_def(stmt.child(0)) { continue }
            }
        }
        if init_is_direct_macro_inst_decl(stmt, macros, scope) { continue }
        init_hoist_walk(stmt, macros, scope, ctx, synthesized, false)
    }
    for d : Expr in synthesized {
        program.children.push(own d.clone())
    }
}

// A direct `Alias := Template(I64, 4)` should not expand a second type whose
// real name is `Alias`. Normalize it to an ordinary alias of the deterministic
// monomorphization, plus one canonical decl if this unit owns that instantiation.
priv init_normalize_direct_type_gen_aliases := func(mut program: Expr, macros: Map(Str, Expr), scope: TypeScope, ctx: Context) {
    mut synthesized := Vec(Expr).new()
    for i in 0..program.children.len() {
        ref mut stmt : Expr = program.child(i)
        if init_is_direct_macro_inst_decl(stmt, macros, scope).not() { continue }
        ref rhs : Expr = stmt.child(0)
        genname := init_macro_inst_name_in_scope(rhs, macros, scope)
        switch stmt.node_type {
        case NodeType.Decl(dd):
            if dd.name.eq(genname) { continue }
            ref callee : Expr = rhs.child(0)
            switch callee.node_type {
            case NodeType.Ident(cn):
                ref mf : Expr = init_lookup_type_gen_macro(cn.ident_name(), macros, scope)
                if mf.is_null() { continue }
                if ctx.type_gen_synths.has(genname).not() {
                    mut decl := Expr.new(NodeType.Decl(Declaration(name = genname.clone())), stmt.line, stmt.col)
                    decl.add_child(own rhs.clone())
                    synthesized.push(own decl)
                }
                mut alias_target := Expr.new(ident_node(genname), stmt.line, stmt.col)
                stmt.children.set(0.to_usize(), own alias_target)
            case:
            }
        case:
        }
    }
    for d : Expr in synthesized {
        program.children.push(own d.clone())
    }
}

priv init_synth_array_inst_decl := func(elem_type: Str, line: U32, col: U32) returns Expr {
    genname := "Array__".concat(elem_type)
    mut array_id := Expr.new(ident_node("Array"), line, col)
    mut elem_id := Expr.new(ident_node(elem_type), line, col)
    mut call := Expr.new(NodeType.FCall(FCallData()), line, col)
    call.add_child(own array_id)
    call.add_child(own elem_id)
    mut decl := Expr.new(NodeType.Decl(Declaration(name = genname)), line, col)
    decl.add_child(own call)
    return decl
}

priv init_synth_vec_inst_decl := func(elem_type: Str, line: U32, col: U32) returns Expr {
    genname := "Vec__".concat(elem_type)
    mut vec_id := Expr.new(ident_node("Vec"), line, col)
    mut elem_id := Expr.new(ident_node(elem_type), line, col)
    mut call := Expr.new(NodeType.FCall(FCallData()), line, col)
    call.add_child(own vec_id)
    call.add_child(own elem_id)
    mut decl := Expr.new(NodeType.Decl(Declaration(name = genname)), line, col)
    decl.add_child(own call)
    return decl
}

priv init_synth_set_inst_decl := func(elem_type: Str, line: U32, col: U32) returns Expr {
    genname := "Set__".concat(elem_type)
    mut set_id := Expr.new(ident_node("Set"), line, col)
    mut elem_id := Expr.new(ident_node(elem_type), line, col)
    mut call := Expr.new(NodeType.FCall(FCallData()), line, col)
    call.add_child(own set_id)
    call.add_child(own elem_id)
    mut decl := Expr.new(NodeType.Decl(Declaration(name = genname)), line, col)
    decl.add_child(own call)
    return decl
}

priv init_synth_map_inst_decl := func(key_type: Str, val_type: Str, line: U32, col: U32) returns Expr {
    genname := "Map__".concat(key_type).concat("_").concat(val_type)
    mut map_id := Expr.new(ident_node("Map"), line, col)
    mut key_id := Expr.new(ident_node(key_type), line, col)
    mut val_id := Expr.new(ident_node(val_type), line, col)
    mut call := Expr.new(NodeType.FCall(FCallData()), line, col)
    call.add_child(own map_id)
    call.add_child(own key_id)
    call.add_child(own val_id)
    mut decl := Expr.new(NodeType.Decl(Declaration(name = genname)), line, col)
    decl.add_child(own call)
    return decl
}

priv init_set_literal_elem_type := func(e: Expr) returns Str {
    if e.children.len().eq(0) { return "" }
    ref first : Expr = e.child(0)
    switch first.node_type {
    case NodeType.Literal(Literal.Str): return "Str"
    case NodeType.Literal(Literal.Bool): return "Bool"
    case NodeType.Literal(Literal.Num(nd)):
        tn := type_to_name(nd.til_type)
        if tn.len().gt(0) { return tn }
        return "I64"
    case:
    }
    return ""
}

priv init_literal_child_type := func(e: Expr) returns Str {
    switch e.node_type {
    case NodeType.Literal(Literal.Str): return "Str"
    case NodeType.Literal(Literal.Bool): return "Bool"
    case NodeType.Literal(Literal.Num(nd)):
        tn := type_to_name(nd.til_type)
        if tn.len().gt(0) { return tn }
        return "I64"
    case NodeType.FieldAccess:
        if e.children.len().gt(0) {
            switch e.child(0).node_type {
            case NodeType.Ident(type_name): return type_name.ident_name().clone()
            case:
            }
        }
    case:
    }
    return ""
}

priv init_collect_variadic_arrays := func(e: Expr, mut synthesized: Vec(Expr), mut seen: Map(Str, Str), synth_array: Bool, synth_vec: Bool, synth_set: Bool, synth_map: Bool) {
    if e.is_null() { return }
    switch e.node_type {
    case NodeType.FCall:
        if e.children.len().gte(2) {
            ref callee : Expr = e.child(0)
            switch callee.node_type {
            case NodeType.Ident(cn):
                if cn.ident_name().eq("array").or(cn.ident_name().eq("vec")) {
                    should_synth := cn.ident_name().eq("array").and(synth_array)
                        .or(cn.ident_name().eq("vec").and(synth_vec))
                    if should_synth {
                        ref type_arg : Expr = e.child(1)
                        switch type_arg.node_type {
                        case NodeType.Literal(Literal.Str(elem_type)):
                            mut genname := "Array__".concat(elem_type)
                            if cn.ident_name().eq("vec") { genname = "Vec__".concat(elem_type) }
                            if seen.has(genname).not() {
                                if cn.ident_name().eq("array") {
                                    synthesized.push(own init_synth_array_inst_decl(elem_type, e.line, e.col))
                                } else {
                                    synthesized.push(own init_synth_vec_inst_decl(elem_type, e.line, e.col))
                                }
                                seen.set(genname, own "")
                            }
                        case:
                        }
                    }
                }
            case:
            }
        }
    case NodeType.Literal(Literal.SetLit):
        if synth_set {
            elem_type := init_set_literal_elem_type(e)
            if elem_type.len().gt(0) {
                genname := "Set__".concat(elem_type)
                if seen.has(genname).not() {
                    synthesized.push(own init_synth_set_inst_decl(elem_type, e.line, e.col))
                    seen.set(genname, own "")
                }
            }
        }
    case NodeType.Literal(Literal.MapLit):
        if synth_map.and(e.children.len().gte(2)) {
            key_type := init_literal_child_type(e.child(0))
            val_type := init_literal_child_type(e.child(1))
            if key_type.len().gt(0).and(val_type.len().gt(0)) {
                genname := "Map__".concat(key_type).concat("_").concat(val_type)
                if seen.has(genname).not() {
                    synthesized.push(own init_synth_map_inst_decl(key_type, val_type, e.line, e.col))
                    seen.set(genname, own "")
                }
            }
        }
    case NodeType.FuncDef(fd):
        if fd.variadic_index.gte(0) {
            ref p : Declaration = fd.params[fd.variadic_index.to_usize()]
            genname := "Array__".concat(p.explicit_type)
            if seen.has(genname).not() {
                synthesized.push(own init_synth_array_inst_decl(p.explicit_type, e.line, e.col))
                seen.set(genname, own "")
            }
        }
    case NodeType.StructDef(sdd):
        for nd : Declaration in sdd.ns_decls {
            init_collect_variadic_arrays(nd.default_value, synthesized, seen, synth_array, synth_vec, synth_set, synth_map)
        }
    case NodeType.EnumDef(edd):
        for nd : Declaration in edd.ns_decls {
            init_collect_variadic_arrays(nd.default_value, synthesized, seen, synth_array, synth_vec, synth_set, synth_map)
        }
    case:
    }
    for i in 0..e.children.len() {
        init_collect_variadic_arrays(e.child(i), synthesized, seen, synth_array, synth_vec, synth_set, synth_map)
    }
}

priv init_synthesize_variadic_arrays := func(mut program: Expr, ctx: Context) {
    mut synthesized := Vec(Expr).new()
    mut seen := Map(Str, Str).new()
    synth_array := ctx.scope.get_struct("Array").is_null()
    synth_vec := ctx.scope.get_struct("Vec").is_null()
    synth_set := ctx.scope.get_struct("Set").is_null()
    synth_map := ctx.scope.get_struct("Map").is_null()
    if synth_array.not().and(synth_vec.not()).and(synth_set.not()).and(synth_map.not()) { return }
    for i in 0..program.children.len() {
        init_collect_variadic_arrays(program.child(i), synthesized, seen, synth_array, synth_vec, synth_set, synth_map)
    }
    for d : Expr in synthesized {
        switch d.node_type {
        case NodeType.Decl(dd):
            if ctx.type_gen_synths.has(dd.name).not() {
                program.children.push(own d.clone())
            }
        case:
        }
    }
}

// Parser-synthesized type-position instantiations are emitted as direct
// deterministic decls (`Name__Arg := Name(Arg)`). Keep only the first one
// across all initialized units, but leave user aliases (`Alias := Name(Arg)`)
// alone because their LHS is intentionally not the deterministic name.
priv init_dedup_direct_type_gen_decls := func(mut program: Expr, macros: Map(Str, Expr), scope: TypeScope, ctx: Context) {
    mut last_direct := Map(Str, I64).new()
    for i in 0..program.children.len() {
        ref stmt0 : Expr = program.child(i)
        if init_is_direct_macro_inst_decl(stmt0, macros, scope).not() { continue }
        ref rhs0 : Expr = stmt0.child(0)
        genname0 := init_macro_inst_name_in_scope(rhs0, macros, scope)
        switch stmt0.node_type {
        case NodeType.Decl(dd0):
            if dd0.name.eq(genname0) {
                last_direct.set(genname0, own i.to_i64())
            }
        case:
        }
    }

    mut kept_stmts := Vec(Expr).new()
    for i in 0..program.children.len() {
        ref stmt : Expr = program.child(i)
        mut keep := true
        if init_is_direct_macro_inst_decl(stmt, macros, scope) {
            ref rhs : Expr = stmt.child(0)
            genname := init_macro_inst_name_in_scope(rhs, macros, scope)
            switch stmt.node_type {
            case NodeType.Decl(dd):
                if dd.name.eq(genname) {
                    mut drop_placeholder := false
                    ref callee : Expr = rhs.child(0)
                    switch callee.node_type {
                    case NodeType.Ident(cn):
                        ref mf : Expr = init_lookup_type_gen_macro(cn.ident_name(), macros, scope)
                        if mf.is_null().not().and(init_macro_inst_uses_own_type_param(rhs, mf)) {
                            drop_placeholder = true
                        }
                    case:
                    }
                    mut is_last_local := true
                    if last_direct.has(genname) {
                        ref last_idx : I64 = last_direct[genname]
                        if last_idx.neq(i.to_i64()) { is_last_local = false }
                    }
                    if is_last_local.not() {
                        keep = false
                    } else if drop_placeholder {
                        keep = false
                    } else if ctx.type_gen_synths.has(genname) {
                        keep = false
                    } else {
                        ctx.type_gen_synths.add(own genname.clone())
                    }
                }
            case:
            }
        }
        if keep { kept_stmts.push(own stmt.clone()) }
    }
    program.children.clear()
    for ks : Expr in kept_stmts {
        program.children.push(own ks.clone())
    }
}

priv init_refresh_seeded_scope_defs := func(program: Expr, mut scope: TypeScope) {
    for stmt : Expr in program.children {
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        if stmt.children.len().eq(0) { continue }
        mut name := ""
        switch stmt.node_type {
        case NodeType.Decl(dd): name = dd.name
        case:
        }
        if scope.bindings.has(name).not() { continue }
        ref rhs : Expr = stmt.child(0)
        if rhs.node_type.is(NodeType.StructDef).or(rhs.node_type.is(NodeType.EnumDef)) {
            scope.set_struct_def(name, rhs)
        } else if rhs.node_type.is(NodeType.FuncDef) {
            scope.set_func_def(name, rhs)
        }
    }
}

// Issue #58 "Phase now": a top-level `name := func(T: Type, ...)` is a
// GENERIC function -- a func/proc whose param list has at least one
// `Type`-typed param. Unlike a macro it is CALLED DIRECTLY with the
// type-arg inline (`identity(I64, 42)`, `swap(I64, x, y)`); init
// monomorphizes it per distinct type-arg tuple, synthesizes the
// concrete copy, and rewrites each call to that copy with the type-args
// dropped. The generic decl itself is removed (its body can't type-check
// with T undefined).
priv init_func_is_generic := func(rhs: Expr) returns Bool {
    switch rhs.node_type {
    case NodeType.FuncDef(fd):
        gok := fd.func_type.is(FuncType.Func).or(fd.func_type.is(FuncType.Proc))
        if gok.not() { return false }
        // A `P: Type` param is a generic TYPE-PARAMETER only if its name
        // is actually USED as a type elsewhere in the signature -- as
        // another param's explicit_type, or as the return type. A plain
        // `func(t: Type) returns Str` (where `t` is a runtime Type VALUE
        // never used to type anything, e.g. til_type_name_c) is NOT a
        // generic and must be left untouched.
        for p : Declaration in fd.params {
            if p.explicit_type.eq("Type").not() { continue }
            tname := p.name
            if fd.return_type.eq(tname) { return true }
            for q : Declaration in fd.params {
                if q.explicit_type.eq(tname) { return true }
            }
        }
        return false
    case:
        return false
    }
}

// Expand a single generic-func call `call` = `gname(typearg, ..., valargs)`
// against the generic funcdef `gfd_expr`. Synthesizes the monomorphization
// (deduped via `seen`, accumulated in `synthesized`) and rewrites `call`
// in place to the concrete `gname__T1_T2(valargs)`.
priv init_generic_expand_call := func(mut call: Expr, gname: Str, gfd_expr: Expr, generics: Map(Str, Expr), mut seen: Map(Str, Str), mut synthesized: Vec(Expr)) {
    switch gfd_expr.node_type {
    case NodeType.FuncDef(gfd):
        // Build the type-param substitution map and the mono name from
        // the type-args at the Type-param positions.
        mut subs := Map(Str, Expr).new()
        mut mono := gname.concat("__")
        mut first := true
        mut ok := true
        for i in 0..gfd.params.len() {
            ref p : Declaration = gfd.params[i]
            argidx := i.add(1)
            if argidx.gte(call.children.len()) { ok = false; break }
            if p.explicit_type.eq("Type") {
                ref arg : Expr = call.child(argidx)
                switch arg.node_type {
                case NodeType.Ident(an):
                    tn := an.ident_name()
                    mut tid := Expr.new(ident_node(tn), arg.line, arg.col)
                    subs.set(p.name, own tid)
                    if first.not() { mono = mono.concat("_") }
                    mono = mono.concat(tn)
                    first = false
                case:
                    ok = false
                }
            }
        }
        if ok.not() { return }

        // Synthesize the concrete copy once per distinct mono name.
        if seen.has(mono).not() {
            mut cloned := gfd_expr.clone()
            switch cloned.node_type {
            case NodeType.FuncDef(cfd):
                mut kept := Vec(Declaration).new()
                for kp : Declaration in cfd.params {
                    if kp.explicit_type.eq("Type") { continue }
                    kept.push(own kp.clone())
                }
                cfd.params.clear()
                for kp2 : Declaration in kept {
                    cfd.params.push(own kp2.clone())
                }
            case:
            }
            init_substitute_type_params(cloned, subs)
            // Composition: the freshly-substituted body may now contain
            // calls to OTHER generic funcs (or to this one with different
            // type-args). Walk it with the same generics/seen/synthesized,
            // so those calls get rewritten and any new monomorphizations
            // get appended -- the program-level outer loop will then pick
            // them up alongside the rest.
            init_generic_walk(cloned, generics, seen, synthesized)
            mut decl := Expr.new(NodeType.Decl(Declaration(name = mono.clone())), call.line, call.col)
            decl.add_child(own cloned)
            synthesized.push(own decl)
            seen.set(mono, own mono.clone())
        }

        // Rewrite the call: callee -> Ident(mono); keep only the value
        // args (drop the type-args). own-arg markers from the source
        // call carry over to the matching new positions, so a generic
        // taking `own v: T` keeps its move semantics after the rewrite.
        mut newcall := Expr.new(NodeType.FCall(FCallData()), call.line, call.col)
        mut mono_id := Expr.new(ident_node(mono), call.line, call.col)
        newcall.add_child(own mono_id)
        mut new_arg_pos := 1
        for j in 0..gfd.params.len() {
            ref vp : Declaration = gfd.params[j]
            if vp.explicit_type.eq("Type") { continue }
            vargidx := j.add(1)
            if vargidx.lt(call.children.len()) {
                src_own := get_own_arg(call, vargidx)
                newcall.add_child(own call.child(vargidx).clone())
                if src_own { set_own_arg(newcall, new_arg_pos.to_usize()) }
                new_arg_pos = new_arg_pos.add(1)
            }
        }
        call.replace_with(own newcall)
    case:
    }
}

// Walk `e`'s subtree rewriting every generic-func call to its
// monomorphization. `generics` maps name -> generic funcdef Expr.
priv init_generic_walk := func(mut e: Expr, generics: Map(Str, Expr), mut seen: Map(Str, Str), mut synthesized: Vec(Expr)) {
    if e.is_null() { return }
    for i in 0..e.children.len() {
        ref mut c : Expr = e.child(i)
        mut handled := false
        if c.node_type.is(NodeType.FCall).and(c.children.len().gt(0)) {
            ref callee : Expr = c.child(0)
            switch callee.node_type {
            case NodeType.Ident(cn):
                gnm := cn.ident_name()
                if generics.has(gnm) {
                    // Recurse into the args first (nested generic calls),
                    // then expand this call.
                    init_generic_walk(c, generics, seen, synthesized)
                    ref gfd_expr : Expr = generics[gnm]
                    // generics threaded through so the expander can
                    // recursively walk the synthesized body for composed
                    // generic calls (init_generic_expand_call signature
                    // now takes generics).
                    init_generic_expand_call(c, gnm, gfd_expr, generics, seen, synthesized)
                    handled = true
                }
            case:
            }
        }
        if handled.not() {
            init_generic_walk(c, generics, seen, synthesized)
        }
    }
}

priv init_expand_generic_funcs := func(mut program: Expr) {
    // Collect top-level generic func/proc decls.
    mut generics := Map(Str, Expr).new()
    for stmt : Expr in program.children {
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        if stmt.children.len().eq(0) { continue }
        ref rhs : Expr = stmt.child(0)
        if init_func_is_generic(rhs).not() { continue }
        switch stmt.node_type {
        case NodeType.Decl(dd):
            generics.set(dd.name, own rhs.clone())
        case:
        }
    }
    if generics.len().eq(0) { return }

    // Rewrite all calls (skipping the generic decls themselves, whose
    // bodies reference the still-unbound type-param).
    mut seen := Map(Str, Str).new()
    mut synthesized := Vec(Expr).new()
    for i in 0..program.children.len() {
        ref mut stmt : Expr = program.child(i)
        is_generic_decl := stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0)).and(init_func_is_generic(stmt.child(0)))
        if is_generic_decl { continue }
        init_generic_walk(stmt, generics, seen, synthesized)
    }

    // Rebuild program.children: drop the generic decls, keep everything
    // else, then append the synthesized monomorphizations.
    mut kept_stmts := Vec(Expr).new()
    for stmt2 : Expr in program.children {
        drop := stmt2.node_type.is(NodeType.Decl).and(stmt2.children.len().gt(0)).and(init_func_is_generic(stmt2.child(0)))
        if drop { continue }
        kept_stmts.push(own stmt2.clone())
    }
    program.children.clear()
    for ks : Expr in kept_stmts {
        program.children.push(own ks.clone())
    }
    for d : Expr in synthesized {
        program.children.push(own d.clone())
    }
}

priv init_expand_type_gen_macros := func(mut program: Expr, scope: TypeScope, ctx: Context) {
    // Build map of top-level macro defs returning a type-def metatype
    // (StructDef / EnumDef) or a FuncDef / FunctionDef (function
    // generator: rstil's macro-returns-FuncDef equivalent).
    mut macros := Map(Str, Expr).new()
    for stmt : Expr in program.children {
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        if stmt.children.len().eq(0) { continue }
        ref rhs : Expr = stmt.child(0)
        if rhs.node_type.is(NodeType.FuncDef).not() { continue }
        if init_is_type_gen_macro_def(rhs).not() { continue }
        switch stmt.node_type {
        case NodeType.Decl(dd):
            macros.set(dd.name, own rhs.clone())
        case:
        }
    }

    // Normalize explicit aliases (`Alias := Template(I64)`) before dedup so
    // every instantiated template has one deterministic real type name.
    init_normalize_direct_type_gen_aliases(program, macros, scope, ctx)

    // Variadic params are stored as an element type plus variadic_index, not as
    // an explicit `Array(T)` annotation, so synthesize their concrete Array type.
    init_synthesize_variadic_arrays(program, ctx)

    // Issue #267 (caveat 2): first hoist inline instantiations (e.g.
    // `TemplVec(Bool).new()`) into synthesized top-level decls, deduped, so
    // the expansion loop below picks them up alongside the user's explicit
    // `Name := MACRO(args)` decls.
    init_hoist_inline_macros(program, macros, scope, ctx)

    // Issue #267: parser-synthesized type-position instantiations are already
    // direct deterministic decls. Dedup them after value-position hoisting:
    // if a value use already synthesized `Name__Arg`, drop the parser's
    // duplicate; if the type occurrence is truly type-only, keep it.
    init_dedup_direct_type_gen_decls(program, macros, scope, ctx)
    init_refresh_seeded_scope_defs(program, scope)

    // Walk top-level decls, expanding each `X := macroname(args)`. Expansion
    // can synthesize more deterministic decls from `Name(T)` self-references
    // after substitution, so iterate until no direct instantiations remain.
    mut expanded_any := true
    while expanded_any {
        expanded_any = false
        for i in 0..program.children.len() {
            ref mut stmt : Expr = program.child(i)
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            if stmt.children.len().eq(0) { continue }
            ref rhs : Expr = stmt.child(0)
            if rhs.node_type.is(NodeType.FCall).not() { continue }
            if rhs.children.len().lt(1) { continue }
            ref callee : Expr = rhs.child(0)
            if callee.node_type.is(NodeType.Ident).not() { continue }
            mut callee_name := ""
            switch callee.node_type {
            case NodeType.Ident(cn): callee_name = cn.ident_name()
            case:
            }
            ref macro_fdef : Expr = init_lookup_type_gen_macro(callee_name, macros, scope)
            if macro_fdef.is_null() { continue }
            if macro_fdef.children.len().eq(0) { continue }
            ref body : Expr = macro_fdef.child(0)
            if body.node_type.is(NodeType.Body).not() { continue }

            // Build param-name -> arg-expression substitution. Type-param args
            // are Idents (e.g. `I64`) and value-param args are arbitrary
            // expressions (literals, idents, fcalls); store the whole Expr so
            // init_substitute_idents can replace `Ident(N)` with the cloned
            // arg expression for value params, while
            // init_subst_ident_name still extracts the receiving type name for
            // explicit-type strings when the substitution is Ident-shaped.
            mut subs := Map(Str, Expr).new()
            switch macro_fdef.node_type {
            case NodeType.FuncDef(mfd):
                for j in 0..mfd.params.len() {
                    if j.add(1).gte(rhs.children.len()) { break }
                    ref param : Declaration = mfd.params[j]
                    ref arg : Expr = rhs.child(j.add(1))
                    if param.explicit_type.eq("Type").and(arg.node_type.is(NodeType.Ident)) {
                        switch arg.node_type {
                        case NodeType.Ident(an):
                            type_arg_name := init_type_arg_name(scope, an.ident_name())
                            mut type_arg := Expr.new(ident_node(type_arg_name), arg.line, arg.col)
                            subs.set(param.name, own type_arg)
                        case:
                        }
                    } else {
                        subs.set(param.name, own arg.clone())
                    }
                }
            case:
            }

            // Pick the return literal -- a direct `return <literal>` or an
            // if-chain whose recognised condition evaluates to a definite
            // arm under `subs` (issue #58).
            ref ret_val : Expr = init_macro_pick_return(body, subs)
            if ret_val.is_null() { continue }
            ret_val_ok := ret_val.node_type.is(NodeType.StructDef)
                .or(ret_val.node_type.is(NodeType.EnumDef))
                .or(ret_val.node_type.is(NodeType.FuncDef))
            if ret_val_ok.not() { continue }

            // Clone the return literal, substitute, then hoist any explicit
            // `Name(T)` self-references that became concrete value-position
            // instantiations after substitution (`Name(I64)(...)`).
            mut cloned := ret_val.clone()
            init_substitute_type_params(cloned, subs)
            mut nested_synthesized := Vec(Expr).new()
            init_hoist_walk(cloned, macros, scope, ctx, nested_synthesized, true)
            stmt.children.set(0.to_usize(), own cloned)
            for nd : Expr in nested_synthesized {
                program.children.push(own nd.clone())
            }
            expanded_any = true
        }
    }
}

// rstil-style unit initializer: index declarations for one file, but do not
// run global layout/method generation that must see the whole program.
priv init_seed_declarations_unit := proc(path: Str, program: Expr, scope: TypeScope, ctx: Context) returns I32 {
    if ctx.imports_init_seed_done.has(path) { return 0 }
    ctx.imports_init_seed_done.add(own path.clone())

    context_enter_file(ctx, path)
    mut errors : I32 = 0

    // Issue #271: make public file-level declarations visible before
    // recursive imports run. This generalizes same-file forward
    // declarations to import cycles without pretending the file is fully
    // initialized yet. Private names are skipped here because their full
    // init pass rewrites them to file-keyed C names before registration.
    for i in 0..program.children.len() {
        ref stmt : Expr = program.child(i)
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        if stmt.children.len().eq(0) { continue }
        mut is_priv := false
        switch stmt.node_type {
        case NodeType.Decl(dd): is_priv = dd.is_priv
        case:
        }
        if is_priv { continue }

        ref rhs : Expr = stmt.child(0)
        if rhs.node_type.is(NodeType.StructDef) {
            errors = errors.add(register_struct_def_for_stmt(ctx, stmt, scope))
        } else if rhs.node_type.is(NodeType.EnumDef) {
            errors = errors.add(register_enum_def_for_stmt(ctx, stmt, scope))
        } else if rhs.node_type.is(NodeType.FuncDef) {
            if rhs.children.len().eq(0) {
                register_funcsig_alias_for_stmt(ctx, stmt, scope)
            } else {
                register_function_def_for_stmt(ctx, stmt, scope)
            }
        }
    }
    return errors
}

priv init_declarations_unit := proc(path: Str, program: Expr, scope: TypeScope, ctx: Context) returns I32 {
    context_enter_file(ctx, path)
    mut errors : I32 = 0

    // Issue #57: expand `X := macroname(args)` where macroname is a
    // top-level macro returning StructDef/EnumDef -- inline the macro
    // body's return literal with type-params substituted, so X becomes a
    // normal named struct/enum decl for the registration walk below.
    init_expand_type_gen_macros(program, scope, ctx)

    // Issue #58 "Phase now": monomorphize direct generic functions
    // `name := func(T: Type, ...)` called as `name(I64, args)`. Runs
    // after macro expansion so a macro-generated generic func would also
    // be picked up. Rewrites each call to its concrete copy and removes
    // the generic decl.
    init_expand_generic_funcs(program)
    init_refresh_seeded_scope_defs(program, scope)

    // Single AST walk: register every type name in scope (struct, enum,
    // funcsig) and bucket each remaining Decl's index for post-walk work.
    // Enum non-clone methods need scope to be populated before they can
    // generate eq/delete/to_str, so we delay them until after the walk.
    enum_idxs := Vec(U32).new()
    alias_idxs := Vec(U32).new()
    func_idxs := Vec(U32).new()
    value_idxs := Vec(U32).new()
    // Issue #93: nested struct/enum/func definitions inside a FuncDef
    // body are lifted to the program top level (with names mangled
    // `<parent>_<orig>`) inline during this walk. The lifted decls are
    // appended to program.children; the while loop re-checks
    // program.children.len() each iteration so they get registered by
    // the same walk without an extra pass.
    // Issue #93: nested struct/enum/func definitions inside a FuncDef
    // body are lifted to the program top level (with names mangled
    // `<parent>_<orig>`) inline during this walk. The lifted decls are
    // appended to program.children; the while loop re-checks
    // program.children.len() each iteration so they get registered by
    // the same walk without an extra pass.
    // Issue #93: nested struct/enum/func definitions inside a FuncDef
    // body are lifted to the program top level (with names mangled
    // `<parent>_<orig>`) before the registration walk. Lifted decls
    // are appended to program.children; the same walk below registers
    // them along with the original top-level decls. Splitting the
    // lift from the walk avoids mutating program.children while we
    // hold refs into it (which previously corrupted memory).
    mut nested_lifted := Vec(Expr).new()
    for li in 0..program.children.len() {
        ref lstmt : Expr = program.child(li)
        if lstmt.node_type.is(NodeType.Decl).not() { continue }
        if lstmt.children.len().eq(0) { continue }
        ref lrhs : Expr = lstmt.child(0)
        if lrhs.node_type.is(NodeType.FuncDef).not() { continue }
        if lrhs.children.len().eq(0) { continue }
        switch lrhs.node_type {
        case NodeType.FuncDef(lift_fd):
            if lift_fd.func_type.is(FuncType.ExtFunc) { continue }
            if lift_fd.func_type.is(FuncType.ExtProc) { continue }
        case:
            continue
        }
        switch lstmt.node_type {
        case NodeType.Decl(lift_dd):
            ref mut lbody : Expr = lrhs.child(0)
            init_lift_in_body(lbody, lift_dd.name, nested_lifted)
        case:
            UNREACHABLE(__LOC__)
        }
    }
    for l : Expr in nested_lifted {
        program.children.push(own l.clone())
    }

    // Rewrite every top-level `priv` decl (and the lifted-nested ones,
    // which the lift step above just marked priv) to a file-keyed C
    // symbol. Same in-file Ident references get rewritten alongside via
    // init_rewrite_refs, so the rest of the pipeline emits and links
    // distinct C functions for two files that happen to share a priv
    // identifier. The original user-facing name lives on dd.orig_name
    // for diagnostics.
    mut priv_renamings := Map(Str, Str).new()
    for pi in 0..program.children.len() {
        ref pstmt : Expr = program.child(pi)
        if pstmt.node_type.is(NodeType.Decl).not() { continue }
        switch pstmt.node_type {
        case NodeType.Decl(pdd):
            if pdd.is_priv.not() { continue }
            if pdd.name.starts_with("priv__") { continue }
            // Skip lifted-nested decls (the lift step above already set
            // orig_name on them and mangled their name to `<parent>_<orig>`).
            // Their function-scope priv check downstream relies on the
            // parent being extractable from the mangled name -- stacking
            // a `priv__<path>__` prefix would break that contract and
            // also let sibling functions reach the lifted decl from
            // anywhere in the file. Cross-file collisions on a lifted
            // nested name (same parent + same nested) are rare and the
            // existing parent prefix already disambiguates within a
            // file; we accept the residual risk for now.
            if pdd.orig_name.len().gt(0) { continue }
            mangled := priv_c_name(path, pdd.name)
            pdd.orig_name = pdd.name.clone()
            priv_renamings.set(pdd.name, own mangled.clone())
            pdd.name = mangled.clone()
        case:
        }
    }
    if priv_renamings.len().gt(0) {
        for ri in 0..program.children.len() {
            ref mut rc : Expr = program.child(ri)
            init_rewrite_refs(rc, priv_renamings)
        }
    }

    for i in 0..program.children.len() {
        ref stmt : Expr = program.child(i)
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        ref rhs : Expr = stmt.child(0)
        if rhs.node_type.is(NodeType.StructDef) {
            errors = errors.add(register_struct_def_for_stmt(ctx, stmt, scope))
        } else if rhs.node_type.is(NodeType.EnumDef) {
            errors = errors.add(register_enum_def_for_stmt(ctx, stmt, scope))
            enum_idxs.push(own i)
        } else if rhs.node_type.is(NodeType.FuncDef) {
            if rhs.children.len().eq(0) {
                register_funcsig_alias_for_stmt(ctx, stmt, scope)
            } else {
                func_idxs.push(own i)
            }
        } else if rhs.node_type.is(NodeType.Ident) {
            alias_idxs.push(own i)
        } else {
            value_idxs.push(own i)
        }
    }

    // All type names are now in scope. Process the collected lists.
    for ei : U32 in enum_idxs {
        gen_enum_nonclone_methods_for_stmt(program.child(ei), scope)
    }
    for ai : U32 in alias_idxs {
        register_type_alias_for_stmt(ctx, program.child(ai), scope)
    }
    for fi : U32 in func_idxs {
        register_function_def_for_stmt(ctx, program.child(fi), scope)
    }
    for vi : U32 in value_idxs {
        register_top_level_value_for_stmt(ctx, program.child(vi), scope)
    }

    return errors
}

// Issue #268: `struct/enum implements Iface` copies each of the interface's
// CONCRETE default methods (a func/proc WITH a body) into the implementing
// type's own namespace, so the type can call them as its own. There is no
// inheritance chain -- every implementer gets its own copy. Abstract methods
// (ext_func/ext_proc, empty body) are NOT copied; the type must supply those
// itself, which the typer's conformance check already enforces. A method the
// type already defines OVERRIDES the default and is left untouched. The
// interface's own name acts as Self in the copied signature and is rewritten
// to the implementing type (so `self: Drawable` becomes `self: Circle`),
// which is why a default body that calls `self.draw()` resolves to the
// implementer's own method. Mirrors the other gen_* synthesis helpers.
priv gen_implements_defaults_for_stmt := func(stmt: Expr, scope: TypeScope) {
    if stmt.node_type.is(NodeType.Decl).not() { return }
    mut impl_name := ""
    switch stmt.node_type {
    case NodeType.Decl(idecl):
        impl_name = idecl.name.clone()
    case:
        return
    }
    ref tdef : Expr = stmt.child(0)
    mut iface_name := ""
    switch tdef.node_type {
    case NodeType.StructDef(sdd_n):
        iface_name = sdd_n.implements_name.clone()
    case NodeType.EnumDef(edd_n):
        iface_name = edd_n.implements_name.clone()
    case:
        return
    }
    if iface_name.len().eq(0) { return }
    ref iface_def : Expr = scope.get_struct(iface_name)
    if iface_def.is_null() { return }
    // Only copy from an actual interface; the typer reports the non-interface
    // / unknown-name cases as conformance errors.
    mut is_iface := false
    switch iface_def.node_type {
    case NodeType.StructDef(idd):
        if idd.is_interface { is_iface = true }
    case:
    }
    if is_iface.not() { return }

    ref iface_ns : Vec(Declaration) = def_ns_decls(iface_def)
    for am : Declaration in iface_ns {
        if am.default_value.is_null() { continue }
        // A concrete default is a func/proc WITH a body, not abstract and not
        // an auto-generated helper (clone/delete/...).
        mut is_default := false
        switch am.default_value.node_type {
        case NodeType.FuncDef(am_fd):
            if am_fd.auto_generated.not().and(am_fd.func_type.is(FuncType.Func).or(am_fd.func_type.is(FuncType.Proc))) {
                is_default = true
            }
        case:
        }
        if is_default.not() { continue }
        // Override: the implementing type already provides this method.
        if find_ns_decl(tdef, am.name).is_null().not() { continue }
        mut copy := am.default_value.clone()
        gen_substitute_self_type(copy, iface_name, impl_name)
        switch tdef.node_type {
        case NodeType.StructDef(sdd):
            sdd.ns_decls.push(own Declaration(name = am.name.clone(), default_value = copy))
        case NodeType.EnumDef(edd):
            edd.ns_decls.push(own Declaration(name = am.name.clone(), default_value = copy))
        case:
        }
    }
}

// Rewrite the interface Self type to the implementing type in a copied
// default method's signature: any param whose declared type is the interface
// name, and a return type equal to it, become the implementing type. Body
// references resolve through the (now-substituted) `self` param, so only the
// signature needs touching for the common cases.
priv gen_substitute_self_type := func(mut fexpr: Expr, from_name: Str, to_name: Str) {
    switch fexpr.node_type {
    case NodeType.FuncDef(fd):
        for mut pd : Declaration in fd.params {
            if pd.explicit_type.eq(from_name) { pd.explicit_type = to_name.clone() }
        }
        if fd.return_type.eq(from_name) { fd.return_type = to_name.clone() }
    case:
    }
}

// Run the global init steps that require a full program view.
init_declarations_global := func(ctx: Context, program: Expr, scope: TypeScope) returns I32 {
    errors : I32 = 0

    // Single AST walk: bucket struct and enum decls for post-walk work,
    // and bucket func/value decls in case global generation steps added
    // new ones (size/derived methods) that need to be registered.
    struct_idxs := Vec(U32).new()
    enum_idxs := Vec(U32).new()
    func_idxs := Vec(U32).new()
    value_idxs := Vec(U32).new()
    for i in 0..program.children.len() {
        ref stmt : Expr = program.child(i)
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        ref rhs : Expr = stmt.child(0)
        if rhs.node_type.is(NodeType.StructDef) {
            struct_idxs.push(own i)
        } else if rhs.node_type.is(NodeType.EnumDef) {
            enum_idxs.push(own i)
        } else if rhs.node_type.is(NodeType.FuncDef) {
            if rhs.children.len().gt(0) {
                func_idxs.push(own i)
            }
        } else if rhs.node_type.is(NodeType.Ident).not() {
            value_idxs.push(own i)
        }
    }

    // Scope-using method generation that still lives here pending
    // the #174 method-body cycle work: clone+delete for structs,
    // missing-clone for enums. Layout computation, size methodgen
    // and cmp/unity methodgen all moved to type_decls_file (the
    // typer's first sweep) as part of #147 step 3-4 / #174 work.
    for si : U32 in struct_idxs {
        gen_struct_clone_delete_for_stmt(program.child(si), scope, ctx)
        gen_implements_defaults_for_stmt(program.child(si), scope)
    }
    for ei : U32 in enum_idxs {
        gen_missing_enum_clone_for_stmt(program.child(ei), scope)
        gen_implements_defaults_for_stmt(program.child(ei), scope)
    }
    // Re-register function/value decls -- new ones may have been generated
    // above (size methods etc) but those go into ns_decls, not program.children.
    // Still re-register here to mirror the original ordering.
    for fi : U32 in func_idxs {
        register_function_def_for_stmt(ctx, program.child(fi), scope)
    }
    for vi : U32 in value_idxs {
        register_top_level_value_for_stmt(ctx, program.child(vi), scope)
    }

    return errors
}

// Count ~import("...")~ FCalls at the top level of `body`. Used by step 5
// to distinguish mode auto-imports (prepended to iu.imports by the loader)
// from explicit imports that appear in the source AST.
count_ast_imports := func(body: Expr) returns USize {
    mut n : USize = 0
    for i in 0..body.children.len() {
        ref stmt : Expr = body.children[i]
        mut is_imp := false
        if stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0)) {
            ref imp_stmt : Expr = stmt.child(0)
            if imp_stmt.node_type.is(NodeType.FCall).and(imp_stmt.children.len().gte(2)) {
                if imp_stmt.child(1).node_type.is_literal_str() {
                    switch imp_stmt.child(0).node_type {
                    case NodeType.Ident(id):
                        if id.ident_name().eq("import") { is_imp = true }
                    case:
                    }
                }
            }
        } else {
            if stmt.node_type.is(NodeType.FCall).and(stmt.children.len().gte(2)) {
                if stmt.child(1).node_type.is_literal_str() {
                    switch stmt.child(0).node_type {
                    case NodeType.Ident(id):
                        if id.ident_name().eq("import") { is_imp = true }
                    case:
                    }
                }
            }
        }
        if is_imp { n = n.add(1) }
    }
    return n
}

init_file := proc(path: Str, ctx: Context) returns I32 {
    if ctx.imports_init_done.has(path) {
        return 0
    }
    if ctx.imports_init_active.has(path) {
        return 0
    }
    ctx.imports_init_active.add(own path.clone())

    ref iu : ImportUnit = ctx.imported[path]

    ctx.mode = iu.mode.clone()
    init_seed_declarations_unit(path, iu.ast, ctx.scope, ctx)

    // Walk the AST in source order and recurse on each ~import("...")~ FCall.
    // iu.imports is kept as a side table that maps the i-th import FCall to
    // its resolved disp path. The loader prepends mode auto-imports (e.g.
    // `mode gui` -> gui.til) ahead of the AST-extracted imports, so process
    // those leading entries first before walking. #165 step 5.
    ast_count : USize = count_ast_imports(iu.ast)
    auto_count : USize = iu.imports.len().sub(ast_count)
    for i in 0..auto_count {
        ref dep : Str = iu.imports[i]
        init_file(dep, ctx)
    }
    mut import_idx : USize = auto_count
    for i in 0..iu.ast.children.len() {
        ref stmt : Expr = iu.ast.children[i]
        mut is_imp := false
        if stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0)) {
            ref imp_stmt : Expr = stmt.child(0)
            if imp_stmt.node_type.is(NodeType.FCall).and(imp_stmt.children.len().gte(2)) {
                if imp_stmt.child(1).node_type.is_literal_str() {
                    switch imp_stmt.child(0).node_type {
                    case NodeType.Ident(id):
                        if id.ident_name().eq("import") { is_imp = true }
                    case:
                    }
                }
            }
        } else {
            if stmt.node_type.is(NodeType.FCall).and(stmt.children.len().gte(2)) {
                if stmt.child(1).node_type.is_literal_str() {
                    switch stmt.child(0).node_type {
                    case NodeType.Ident(id):
                        if id.ident_name().eq("import") { is_imp = true }
                    case:
                    }
                }
            }
        }

        if is_imp {
            ref dep : Str = iu.imports[import_idx]
            init_file(dep, ctx)
            import_idx = import_idx.add(1)
        }
    }

    ctx.mode = iu.mode.clone()
    init_declarations_unit(path, iu.ast, ctx.scope, ctx)
    ctx.imports_init_done.add(own path.clone())
    return 0
}

// sync_body_ns_to_payload: deleted -- all ns methods now go directly to ns_decls

// True iff `variant_name` is a payload-less variant of `enum_def`.
priv enum_variant_is_payload_less := func(enum_def: Expr, variant_name: Str) returns Bool {
    if variant_name.len().eq(0) { return false }
    switch enum_def.node_type {
    case NodeType.EnumDef(edd):
        for j in 0..edd.variants.len() {
            ref vn : Str = edd.variants[j]
            if vn.eq(variant_name) {
                idx := j.to_i64()
                ref pts : Map(I64, Str) = edd.payload_types
                if pts.has(idx).not() { return true }
                ref pt : Str = pts[idx]
                return pt.len().eq(0)
            }
        }
    case:
    }
    return false
}

// Returns the receiver type name if `e` is `<Type>.clone(arg)`, else "".
clone_call_type_name := func(e: Expr) returns Str {
    if e.node_type.is(NodeType.FCall).not() { return "" }
    if e.children.len().lt(2) { return "" }
    ref callee : Expr = e.child(0)
    if callee.node_type.is(NodeType.FieldAccess).not() { return "" }
    mut is_clone := false
    switch callee.node_type {
    case NodeType.FieldAccess(m): is_clone = m.field_access_name().eq("clone")
    case:
    }
    if is_clone.not() { return "" }
    if callee.children.len().eq(0) { return "" }
    ref recv : Expr = callee.child(0)
    if recv.node_type.is(NodeType.Ident).not() { return "" }
    switch recv.node_type {
    case NodeType.Ident(n): return n.ident_name()
    case: return ""
    }
}

// AST-only half of is_pod_enum_clone_call / is_pod_enum_clone_wrap.
// Caller resolves the enum def their own way (builder via Context,
// garbager via TypeScope) and passes it here.
is_pod_enum_clone_of := func(e: Expr, edef: Expr) returns Bool {
    if edef.is_null() { return false }
    if edef.node_type.is(NodeType.EnumDef).not() { return false }
    if enum_has_payloads(edef).not() { return true }
    ref arg : Expr = e.child(1)
    if arg.node_type.is(NodeType.FieldAccess).not() { return false }
    if arg.expr_til_type().is(Type.Enum).not() { return false }
    mut vname := ""
    switch arg.node_type {
    case NodeType.FieldAccess(vn): vname = vn.field_access_name()
    case:
    }
    return enum_variant_is_payload_less(edef, vname)
}
