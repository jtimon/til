mode lib

import("parser")
import("context")

priv is_dynamic_type := func(name: Str) returns Bool {
    return name.eq("Dynamic")
}

priv primitive_type_info := func(name: Str, mut prim: Primitive, mut sz: USize, mut al: USize, mut is_builtin: Bool) returns Bool {
    if name.eq("I64") { prim = Primitive.I64; sz = 8; al = 8; is_builtin = true; return true }
    if name.eq("U8") { prim = Primitive.U8; sz = 1; al = 1; is_builtin = true; return true }
    if name.eq("I8") { prim = Primitive.I8; sz = 1; al = 1; is_builtin = true; return true }
    if name.eq("I16") { prim = Primitive.I16; sz = 2; al = 2; is_builtin = true; return true }
    if name.eq("U16") { prim = Primitive.U16; sz = 2; al = 2; is_builtin = true; return true }
    if name.eq("I32") { prim = Primitive.I32; sz = 4; al = 4; is_builtin = true; return true }
    if name.eq("U32") { prim = Primitive.U32; sz = 4; al = 4; is_builtin = true; return true }
    if name.eq("U64") { prim = Primitive.U64; sz = 8; al = 8; is_builtin = true; return true }
    if name.eq("USize") { prim = Primitive.U32; sz = 4; al = 4; is_builtin = true; return true }
    if name.eq("Bool") { prim = Primitive.Bool; sz = 1; al = 1; is_builtin = true; return true }
    if name.eq("F32") { prim = Primitive.F32; sz = 4; al = 4; is_builtin = true; return true }
    if name.eq("Dynamic") { sz = 8; al = 8; is_builtin = true; return true }
    return false
}

priv register_struct_def_for_stmt := proc(ctx: Context, stmt: Expr, scope: TypeScope) returns I32 {
    if stmt.node_type.is(NodeType.Decl).not() { return 0 }
    if stmt.child(0).node_type.is(NodeType.StructDef).not() { return 0 }

    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        sname := sdecl.name

        existing_find := scope.find(sname)
        switch existing_find {
        case ScopeFind.Found(existing):
            if scope.struct_def_of(existing.name).is_null().not() {
                if existing.path.eq(ctx.path).and(existing.line.eq(stmt.line)).and(existing.col.eq(stmt.col)).not() {
                    println(
                        ctx.path, ":", stmt.line.to_str(), ":", stmt.col.to_str(),
                        ": error: struct '", sname, "' already declared at ",
                        existing.path, ":", existing.line.to_str(), ":", existing.col.to_str(),
                    )
                    return 1
                }
            }
        case:
        }

        mut builtin_type := Type.Struct(sname.clone())
        mut is_builtin := false
        mut prim : Primitive = Primitive.I64
        mut sz : USize = 0
        mut al : USize = 0
        mut prim_builtin : Bool = false
        if primitive_type_info(sname, prim, sz, al, prim_builtin) {
            builtin_type = Type.Primitive(prim)
            is_builtin = prim_builtin
        } else if sname.eq("Str") {
            is_builtin = false
        } else if sname.eq("StructDef") {
            is_builtin = false
        } else if sname.eq("FunctionDef") {
            is_builtin = false
        }

        scope.set(sname, builtin_type, false, ctx.path, stmt.line, stmt.col, false, OwnType.Shallow)
        scope.set_struct_def(sname, stmt.child(0))
        ref mut b : TypeBinding = scope.get_binding(sname)
        b.is_builtin = is_builtin
        b.is_priv = sdecl.is_priv
        b.orig_name = sdecl.orig_name.clone()
        // Issue #147 step 4: pre-populate ctx.interp_type_defs at init so
        // precomp eval (which clones Values and looks up nested struct/enum
        // defs by name) sees a populated registry; interpret_units later
        // re-registers with the same value, which is idempotent.
        tdv : Dynamic = malloc(I64.size().cast(U64))
        write_ptr(tdv, stmt.child(0))
        ctx.interp_type_defs.set(sname, own tdv)
        return 0
    case:
        UNREACHABLE(__LOC__)
        return 0
    }
}

priv gen_struct_clone_delete_for_stmt := func(stmt: Expr, scope: TypeScope, ctx: Context) {
    if stmt.node_type.is(NodeType.Decl).not() { return }
    if stmt.child(0).node_type.is(NodeType.StructDef).not() { return }

    mut sname := ""
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        sname = sdecl.name
    case:
        UNREACHABLE(__LOC__)
        return
    }
    if is_dynamic_type(sname) { return }

    ref sdef : Expr = stmt.child(0)
    switch sdef.node_type {
    case NodeType.StructDef(sdd):
        mut has_clone := false
        mut has_delete := false
        mut has_hash := false
        for d_j : Declaration in sdd.ns_decls {
            ref fd : Declaration = d_j
            if fd.name.eq("clone") { has_clone = true }
            if fd.name.eq("delete") { has_delete = true }
            if fd.name.eq("hash") { has_hash = true }
        }

        if has_clone.not() {
            field_names := Vec(Str).new()
            field_refs := Vec(I32).new()
            for d_j : Declaration in sdd.fields {
                ref fd : Declaration = d_j
                field_names.push(own fd.name.clone())
                mut ref_flag : I32 = 0
                if fd.own_type.is(OwnType.Ref) {
                    ref_flag = 1
                } else if fd.own_type.is(OwnType.Own).not().and(is_pod_type_for_clone(field_inferred_type_name(fd), scope)) {
                    // POD field: value-copy is the clone, so pass
                    // directly and skip the wasteful `.clone()` wrap.
                    // Uses field_inferred_type_name so that
                    // `mut x := 0` (no explicit annotation) also
                    // benefits -- inference picks I64 from the
                    // LiteralNum default value.  Own-typed fields are
                    // excluded: their value-copy aliases the heap
                    // payload.  FuncPtr fields fall under is_pod
                    // (a function pointer is just a pointer value).
                    ref_flag = 1
                }
                field_refs.push(own ref_flag)
            }

            mut func_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
            if field_names.len().eq(0) {
                mut ctor := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col)
                mut ctor_name := Expr.new(ident_node(sname), stmt.line, stmt.col)
                ctor.add_child(own ctor_name)

                mut ret := Expr.new(NodeType.Return, stmt.line, stmt.col)
                ret.add_child(own ctor)
                func_body.add_child(own ret)
            } else {
                mut ctor := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col)
                mut ctor_name := Expr.new(ident_node(sname), stmt.line, stmt.col)
                ctor.add_child(own ctor_name)

                for j in 0..field_names.len() {
                    ref fname : Str = field_names[j]
                    ref fref : I32 = field_refs[j]

                    mut self_id := Expr.new(ident_node("self"), stmt.line, stmt.col)
                    // NodeType.FieldAccess/NamedArg's constructors Str_clone their
                    // payload internally, so an outer fname.clone() at the call
                    // site is a redundant alloc whose wrapper Str leaks if the
                    // asap delete misses it. Pass the borrowed `fname` directly.
                    mut field_acc := Expr.new(field_access_node(fname), stmt.line, stmt.col)
                    field_acc.add_child(own self_id)

                    mut named := Expr.new(NodeType.NamedArg(fname.clone()), stmt.line, stmt.col)
                    if fref.eq(1) {
                        named.add_child(own field_acc)
                    } else {
                        mut clone_call := make_method_call_fcall(own field_acc, "clone", stmt.line, stmt.col)
                        named.add_child(own clone_call)
                    }
                    ctor.add_child(own named)
                }

                mut ret := Expr.new(NodeType.Return, stmt.line, stmt.col)
                ret.add_child(own ctor)
                func_body.add_child(own ret)
            }

            mut func_decl := FunctionDef(auto_generated = true)
            func_decl.func_type = FuncType.Func
            mut self_pname := "self"
            if field_names.len().eq(0) { self_pname = "_self" }
            func_decl.params.push(own decl_typed(name = self_pname, explicit_type = sname, own_type = OwnType.Ref))
            func_decl.return_type = sname.clone()
            func_decl.variadic_index = -1
            func_decl.kwargs_index = -1

            mut func_def := Expr.new(NodeType.FuncDef(func_decl), stmt.line, stmt.col)
            func_def.add_child(own func_body)

            sdd.ns_decls.push(own Declaration(name = "clone", default_value = func_def))
        }

        if has_delete.not() {
            // POD shortcut: when every field is value-copy-safe per
            // is_pod_type_for_clone, no field needs deep cleanup --
            // the per-field `.delete(false)` calls would all bottom
            // out in no-ops -- so emit just the `if call_free: free`
            // tail and skip the field loop entirely.  Saves both
            // compile-time codegen and runtime call frames per POD
            // struct destruction.
            pod_no_field_deletes := is_pod_type_for_clone(sname, scope)
            del_field_names := Vec(Str).new()
            del_field_owns := Vec(Bool).new()
            if pod_no_field_deletes.not() {
                for d_j : Declaration in sdd.fields {
                    ref fd : Declaration = d_j
                    if fd.own_type.is(OwnType.Ref) { continue }
                    if fd.explicit_type.len().gt(0).and(type_from_name_init(fd.explicit_type, scope).is_funcptr()) {
                        continue
                    }
                    del_field_names.push(own fd.name.clone())
                    if fd.own_type.is(OwnType.Own) {
                        del_field_owns.push(own true)
                    } else {
                        del_field_owns.push(own false)
                    }
                }
            }

            mut proc_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
            for j in 0..del_field_names.len() {
                ref fname : Str = del_field_names[j]
                ref fown : Bool = del_field_owns[j]
                mut self_id := Expr.new(ident_node("self"), stmt.line, stmt.col)
                mut field_acc := Expr.new(field_access_node(fname), stmt.line, stmt.col)
                field_acc.add_child(own self_id)

                mut del_acc := Expr.new(field_access_node("delete"), stmt.line, stmt.col)
                del_acc.add_child(own field_acc)
                mut del_call := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col)
                set_own_arg(del_call, 0) // signal UFCS own for self arg
                del_call.add_child(own del_acc)

                mut cf_lit := Expr.new(NodeType.Literal(Literal.Bool(fown)), stmt.line, stmt.col)
                del_call.add_child(own cf_lit)
                proc_body.add_child(own del_call)
            }

            mut cond := Expr.new(ident_node("call_free"), stmt.line, stmt.col)
            mut then_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
            mut free_call := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col)
            mut free_id := Expr.new(ident_node("free"), stmt.line, stmt.col)
            free_call.add_child(own free_id)
            mut self_arg := Expr.new(ident_node("self"), stmt.line, stmt.col)
            set_own_arg(free_call, free_call.children.len())
            free_call.add_child(own self_arg)
            then_body.add_child(own free_call)
            mut if_node := Expr.new(NodeType.If, stmt.line, stmt.col)
            if_node.add_child(own cond)
            if_node.add_child(own then_body)
            proc_body.add_child(own if_node)

            mut proc_decl := FunctionDef(auto_generated = true)
            proc_decl.func_type = FuncType.Func
            proc_decl.params.push(own decl_typed(name = "self", explicit_type = sname, own_type = OwnType.Own))
            // Issue #223: call_free is a primitive (Bool), so emit it as a
            // plain borrowed param (Ref) and let step-1 auto-shallow normalize
            // it to value -- same as a hand-written delete. (An explicit Shallow
            // here would trip the step-2 redundant-shallow check.)
            proc_decl.params.push(own Declaration(name = "call_free", explicit_type = "Bool", til_type = Type.Primitive(Primitive.Bool), own_type = OwnType.Ref, default_value = Expr.new(NodeType.Literal(Literal.Bool(true)), stmt.line, stmt.col)))
            proc_decl.variadic_index = -1
            proc_decl.kwargs_index = -1

            mut proc_def := Expr.new(NodeType.FuncDef(proc_decl), stmt.line, stmt.col)
            proc_def.add_child(own proc_body)

            sdd.ns_decls.push(own Declaration(name = "delete", default_value = proc_def))
        }

        // Issue #214 follow-up: auto-generate `hash(self, hasher)` ONLY
        // when every field is shallow (no own / no ref). Any field that
        // owns or borrows heap data means the in-struct bytes lie about
        // identity -- a bytewise hash of the struct would key on
        // pointer addresses rather than content -- so we leave the
        // method out and let the type's author write a content-aware
        // one (Str.hash is the canonical example). HashMap.new will
        // then panic on dyn_has_method when the type is used as a key.
        if has_hash.not() {
            mut autogen_hash := true
            for d_j : Declaration in sdd.fields {
                if d_j.own_type.is(OwnType.Own).or(d_j.own_type.is(OwnType.Ref)) {
                    autogen_hash = false
                }
            }
            if autogen_hash {
                // Body: return hasher(self, <total_struct_size>)
                // Emit the size as a literal because <sname>.size()
                // would resolve through the namespace and the call's
                // return type can come back as U64 instead of USize
                // when the size method isn't visible yet at this
                // initer pass; and self.size() trips UFCS into trying
                // to pass self where the no-arg size() expects none.
                // sdd.total_struct_size is already set by the earlier
                // layout-computation pass.
                sz_text := ctx_total_size(sname, ctx).to_str()

                mut hash_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
                mut size_lit := Expr.new(literal_num_node(sz_text), stmt.line, stmt.col)

                mut hasher_id := Expr.new(ident_node("hasher"), stmt.line, stmt.col)
                mut self_arg := Expr.new(ident_node("self"), stmt.line, stmt.col)
                mut hasher_call := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col)
                hasher_call.add_child(own hasher_id)
                hasher_call.add_child(own self_arg)
                hasher_call.add_child(own size_lit)

                mut ret := Expr.new(NodeType.Return, stmt.line, stmt.col)
                ret.add_child(own hasher_call)
                hash_body.add_child(own ret)

                mut hash_decl := FunctionDef(auto_generated = true)
                hash_decl.func_type = FuncType.Func
                hash_decl.params.push(own decl_typed(name = "self", explicit_type = sname, own_type = OwnType.Ref))
                hash_decl.params.push(own Declaration(name = "hasher", explicit_type = "HashFn", til_type = Type.FuncPtrSig("HashFn"), own_type = OwnType.Ref))
                hash_decl.return_type = "U64"
                hash_decl.variadic_index = -1
                hash_decl.kwargs_index = -1

                mut hash_def := Expr.new(NodeType.FuncDef(hash_decl), stmt.line, stmt.col)
                hash_def.add_child(own hash_body)

                sdd.ns_decls.push(own Declaration(name = "hash", default_value = hash_def))
            }
        }
    case:
        UNREACHABLE(__LOC__)
    }
}

priv register_enum_definition := proc(ctx: Context, stmt: Expr, scope: TypeScope) returns I32 {
    switch stmt.node_type {
    case NodeType.Decl(edecl):
        ename := edecl.name

        existing_find := scope.find(ename)
        switch existing_find {
        case ScopeFind.Found(existing):
            if scope.struct_def_of(existing.name).is_null().not() {
                if existing.path.eq(ctx.path).and(existing.line.eq(stmt.line)).and(existing.col.eq(stmt.col)).not() {
                    println(
                        ctx.path, ":", stmt.line.to_str(), ":", stmt.col.to_str(),
                        ": error: enum '", ename, "' already declared at ",
                        existing.path, ":", existing.line.to_str(), ":", existing.col.to_str(),
                    )
                    return 1
                }
            }
        case:
        }

        scope.set(ename, Type.Enum(ename.clone()), false, ctx.path, stmt.line, stmt.col, false, OwnType.Shallow)
        scope.set_struct_def(ename, stmt.child(0))
        ref mut b : TypeBinding = scope.get_binding(ename)
        b.is_priv = edecl.is_priv
        b.orig_name = edecl.orig_name.clone()
        // Issue #147 step 4: pre-populate ctx.interp_type_defs (see
        // register_struct_def_for_stmt for rationale).
        tdv : Dynamic = malloc(I64.size().cast(U64))
        write_ptr(tdv, stmt.child(0))
        ctx.interp_type_defs.set(ename, own tdv)
        return 0
    case:
        UNREACHABLE(__LOC__)
        return 0
    }
}

collect_enum_variants := func(enum_def: Expr, mut variant_names: Vec(Str), mut variant_types: Vec(Str), mut has_payloads: Bool) {
    switch enum_def.node_type {
    case NodeType.EnumDef(edd):
        has_payloads = edd.payload_types.len().gt(0)
        for j in 0..edd.variants.len() {
            ref vn : Str = edd.variants[j]
            variant_names.push(own vn.clone())
            idx := j.to_i64()
            if edd.payload_types.has(idx) {
                ref pt : Str = edd.payload_types[idx]
                variant_types.push(own pt.clone())
            } else {
                variant_types.push(own "")
            }
        }
    case:
        UNREACHABLE(__LOC__)
    }
}

priv generate_enum_variant_constructors := func(enum_def: Expr, ename: Str, line: U32, col: U32, variant_names: Vec(Str), variant_types: Vec(Str), has_payloads: Bool, scope: TypeScope) {
    switch enum_def.node_type {
    case NodeType.EnumDef(evc_edd):
        if has_payloads.not() {
            for j in 0..variant_names.len() {
                ref vname : Str = variant_names[j]
                lit := Expr.new(literal_num_node(j.to_str()), line, col)
                evc_edd.ns_decls.push(own Declaration(name = vname.clone(), default_value = lit))
            }
            return
        }

        for j in 0..variant_names.len() {
            mut func_decl := FunctionDef(auto_generated = true, is_enum_variant_ctor = true)
            func_decl.func_type = FuncType.ExtFunc
            ref vtype : Str = variant_types[j]
            if vtype.len().gt(0) {
                mut payload_own_type := OwnType.Own
                resolved := type_from_name_init(vtype, scope)
                if is_primitive(resolved) { payload_own_type = OwnType.Ref }
                if vtype.eq("Dynamic") { payload_own_type = OwnType.Ref }
                if resolved.is_funcptr() { payload_own_type = OwnType.Ref }
                if vtype.starts_with("_Fn_") { payload_own_type = OwnType.Ref }
                param := decl_typed(name = "val", explicit_type = vtype, own_type = payload_own_type)
                func_decl.params.push(own param)
            }
            func_decl.return_type = ename.clone()
            func_decl.variadic_index = -1
            func_decl.kwargs_index = -1

            mut func_def := Expr.new(NodeType.FuncDef(func_decl), line, col)
            mut func_body := Expr.new(NodeType.Body, line, col)
            func_def.add_child(own func_body)

            ref vname : Str = variant_names[j]
            evc_edd.ns_decls.push(own Declaration(name = vname.clone(), default_value = func_def))
        }
    case:
        UNREACHABLE(__LOC__)
    }
}

priv generate_enum_is_method := func(enum_def: Expr, ename: Str, line: U32, col: U32) {
    mut func_body := Expr.new(NodeType.Body, line, col)
    mut is_id := Expr.new(ident_node("is"), line, col)
    mut self_id := Expr.new(ident_node("self"), line, col)
    mut other_id := Expr.new(ident_node("other"), line, col)
    mut is_call := Expr.new(NodeType.FCall(FCallData()), line, col)
    is_call.add_child(own is_id)
    is_call.add_child(own self_id)
    is_call.add_child(own other_id)
    mut ret := Expr.new(NodeType.Return, line, col)
    ret.add_child(own is_call)
    func_body.add_child(own ret)

    mut func_decl := FunctionDef(auto_generated = true)
    func_decl.func_type = FuncType.Func
    self_param := decl_typed(name = "self", explicit_type = ename, own_type = OwnType.Ref)
    other_param := decl_typed(name = "other", explicit_type = ename, own_type = OwnType.Ref)
    func_decl.params.push(own self_param)
    func_decl.params.push(own other_param)
    func_decl.return_type = "Bool"
    func_decl.variadic_index = -1
    func_decl.kwargs_index = -1

    mut func_def := Expr.new(NodeType.FuncDef(func_decl), line, col)
    func_def.add_child(own func_body)

    switch enum_def.node_type {
    case NodeType.EnumDef(eis_edd):
        eis_edd.ns_decls.push(own Declaration(name = "is", default_value = func_def))
    case:
        UNREACHABLE(__LOC__)
    }
}

priv generate_enum_eq_method := func(enum_def: Expr, ename: Str, line: U32, col: U32, variant_names: Vec(Str), variant_types: Vec(Str), scope: TypeScope) {
    mut func_body := Expr.new(NodeType.Body, line, col)
    for j in 0..variant_names.len() {
        ref vn : Str = variant_names[j]
        mut is_call := make_is_tag_check_fcall("self", ename, vn, line, col)

        mut then_body := Expr.new(NodeType.Body, line, col)

        ref vtype : Str = variant_types[j]
        if vtype.len().gt(0) {
            is_funcsig := type_from_name_init(vtype, scope).is_funcptr()

            mut is_call2 := make_is_tag_check_fcall("other", ename, vn, line, col)
            mut not_call := make_method_call_fcall(own is_call2, "not", line, col)

            mut ret_false := Expr.new(NodeType.Return, line, col)
            mut false_lit := Expr.new(NodeType.Literal(Literal.Bool(false)), line, col)
            ret_false.add_child(own false_lit)
            mut guard_body := Expr.new(NodeType.Body, line, col)
            guard_body.add_child(own ret_false)
            mut guard_if := Expr.new(NodeType.If, line, col)
            guard_if.add_child(own not_call)
            guard_if.add_child(own guard_body)
            then_body.add_child(own guard_if)

            if is_funcsig {
                mut ret_true := Expr.new(NodeType.Return, line, col)
                mut true_lit := Expr.new(NodeType.Literal(Literal.Bool(true)), line, col)
                ret_true.add_child(own true_lit)
                then_body.add_child(own ret_true)
            } else {
                mut self_arg := Expr.new(ident_node("self"), line, col)
                then_body.add_child(own make_payload_ref_decl(own self_arg, "_sp", vtype, line, col, false))
                mut other_arg := Expr.new(ident_node("other"), line, col)
                then_body.add_child(own make_payload_ref_decl(own other_arg, "_op", vtype, line, col, false))

                mut sp_id := Expr.new(ident_node("_sp"), line, col)
                mut eq_call := make_method_call_fcall(own sp_id, "eq", line, col)
                mut op_id := Expr.new(ident_node("_op"), line, col)
                eq_call.add_child(own op_id)

                mut ret_eq := Expr.new(NodeType.Return, line, col)
                ret_eq.add_child(own eq_call)
                then_body.add_child(own ret_eq)
            }
        } else {
            mut is_call3 := make_is_tag_check_fcall("other", ename, vn, line, col)
            mut ret := Expr.new(NodeType.Return, line, col)
            ret.add_child(own is_call3)
            then_body.add_child(own ret)
        }

        mut if_node := Expr.new(NodeType.If, line, col)
        if_node.add_child(own is_call)
        if_node.add_child(own then_body)
        func_body.add_child(own if_node)
    }

    mut ret_false := Expr.new(NodeType.Return, line, col)
    mut false_lit := Expr.new(NodeType.Literal(Literal.Bool(false)), line, col)
    ret_false.add_child(own false_lit)
    func_body.add_child(own ret_false)

    mut fdecl := FunctionDef(auto_generated = true)
    fdecl.func_type = FuncType.Func
    fdecl.params.push(own decl_typed(name = "self", explicit_type = ename, own_type = OwnType.Ref))
    fdecl.params.push(own decl_typed(name = "other", explicit_type = ename, own_type = OwnType.Ref))
    fdecl.return_type = "Bool"
    fdecl.variadic_index = -1
    fdecl.kwargs_index = -1

    mut fdef := Expr.new(NodeType.FuncDef(fdecl), line, col)
    fdef.add_child(own func_body)

    switch enum_def.node_type {
    case NodeType.EnumDef(eeq_edd):
        eeq_edd.ns_decls.push(own Declaration(name = "eq", default_value = fdef))
    case:
        UNREACHABLE(__LOC__)
    }
}

priv generate_enum_delete_method := func(enum_def: Expr, ename: Str, line: U32, col: U32, variant_names: Vec(Str), variant_types: Vec(Str), has_payloads: Bool, scope: TypeScope) {
    mut proc_body := Expr.new(NodeType.Body, line, col)
    if has_payloads {
        for j in 0..variant_names.len() {
            ref vn : Str = variant_names[j]
            ref vtype : Str = variant_types[j]
            if vtype.len().eq(0) { continue }
            if vtype.eq("Dynamic") { continue }
            if type_from_name_init(vtype, scope).is_funcptr() { continue }

            mut is_call := make_is_tag_check_fcall("self", ename, vn, line, col)

            mut then_body := Expr.new(NodeType.Body, line, col)

            mut type_id := Expr.new(ident_node(vtype), line, col)
            type_id.set_expr_til_type(type_from_name_init(vtype, scope))
            mut del_acc := Expr.new(field_access_node("delete"), line, col)
            del_acc.add_child(own type_id)
            mut del_call := Expr.new(NodeType.FCall(FCallData()), line, col)
            del_call.add_child(own del_acc)

            mut self_arg := Expr.new(ident_node("self"), line, col)
            mut gc := make_get_payload_fcall(own self_arg, type_from_name_init(vtype, scope), line, col)
            set_own_arg(del_call, del_call.children.len())
            del_call.add_child(own gc)

            mut false_lit := Expr.new(NodeType.Literal(Literal.Bool(false)), line, col)
            del_call.add_child(own false_lit)
            then_body.add_child(own del_call)

            mut if_node2 := Expr.new(NodeType.If, line, col)
            if_node2.add_child(own is_call)
            if_node2.add_child(own then_body)
            proc_body.add_child(own if_node2)
        }
    }

    mut cond := Expr.new(ident_node("call_free"), line, col)
    mut then_body := Expr.new(NodeType.Body, line, col)
    mut free_call := Expr.new(NodeType.FCall(FCallData()), line, col)
    mut free_id := Expr.new(ident_node("free"), line, col)
    free_call.add_child(own free_id)
    mut self_arg := Expr.new(ident_node("self"), line, col)
    set_own_arg(free_call, free_call.children.len())
    free_call.add_child(own self_arg)
    then_body.add_child(own free_call)
    mut if_node := Expr.new(NodeType.If, line, col)
    if_node.add_child(own cond)
    if_node.add_child(own then_body)
    proc_body.add_child(own if_node)

    mut default_true := Expr.new(NodeType.Literal(Literal.Bool(true)), line, col)

    mut fdecl := FunctionDef(auto_generated = true)
    fdecl.func_type = FuncType.Func
    fdecl.params.push(own decl_typed(name = "self", explicit_type = ename, own_type = OwnType.Own))
    // Issue #223: call_free is a primitive (Bool) -> emit a plain borrowed
    // param (Ref) and let step-1 auto-shallow normalize it to value, matching
    // a hand-written delete. (An explicit Shallow trips the step-2 check.)
    fdecl.params.push(own Declaration(name = "call_free", explicit_type = "Bool", til_type = Type.Primitive(Primitive.Bool), own_type = OwnType.Ref, default_value = default_true.clone()))
    fdecl.variadic_index = -1
    fdecl.kwargs_index = -1

    mut fdef := Expr.new(NodeType.FuncDef(fdecl), line, col)
    fdef.add_child(own proc_body)

    switch enum_def.node_type {
    case NodeType.EnumDef(edel_edd):
        edel_edd.ns_decls.push(own Declaration(name = "delete", default_value = fdef))
    case:
        UNREACHABLE(__LOC__)
    }
}

priv generate_enum_to_str_method := func(enum_def: Expr, ename: Str, line: U32, col: U32, variant_names: Vec(Str), variant_types: Vec(Str), has_payloads: Bool, scope: TypeScope) {
    mut func_body := Expr.new(NodeType.Body, line, col)
    for j in 0..variant_names.len() {
        ref vn : Str = variant_names[j]
        ref vtype : Str = variant_types[j]

        if has_payloads {
            mut is_call := make_is_tag_check_fcall("self", ename, vn, line, col)

            mut then_body := Expr.new(NodeType.Body, line, col)
            if vtype.len().gt(0).and(type_from_name_init(vtype, scope).is_funcptr()) {
                ret_text := format(vn, "(func)")
                mut ret_str := Expr.new(NodeType.Literal(Literal.Str(ret_text)), line, col)
                mut ret := Expr.new(NodeType.Return, line, col)
                ret.add_child(own ret_str)
                then_body.add_child(own ret)
            } else if vtype.len().gt(0) {
                pn := format("_p_", vtype, "_", j.to_str())
                mut self_arg := Expr.new(ident_node("self"), line, col)
                then_body.add_child(own make_payload_ref_decl(own self_arg, pn, vtype, line, col, false))

                mut fmt_call := Expr.new(NodeType.FCall(FCallData()), line, col)
                mut fmt_id := Expr.new(ident_node("format"), line, col)
                fmt_call.add_child(own fmt_id)

                prefix_text := format(vn, "(")
                mut prefix := Expr.new(NodeType.Literal(Literal.Str(prefix_text)), line, col)
                fmt_call.add_child(own prefix)

                mut p_id := Expr.new(ident_node(pn), line, col)
                if vtype.eq("Str") {
                    // Payload is already Str -- format() takes Str
                    // variadics, so an extra .to_str() round-trip would
                    // just trip typer's redundant-conversion check.
                    fmt_call.add_child(own p_id)
                } else {
                    mut tostr_call := make_method_call_fcall(own p_id, "to_str", line, col)
                    fmt_call.add_child(own tostr_call)
                }

                mut suffix := Expr.new(NodeType.Literal(Literal.Str(")")), line, col)
                fmt_call.add_child(own suffix)

                mut ret := Expr.new(NodeType.Return, line, col)
                ret.add_child(own fmt_call)
                then_body.add_child(own ret)
            } else {
                mut ret_str := Expr.new(NodeType.Literal(Literal.Str(vn.clone())), line, col)
                mut ret := Expr.new(NodeType.Return, line, col)
                ret.add_child(own ret_str)
                then_body.add_child(own ret)
            }

            mut if_node := Expr.new(NodeType.If, line, col)
            if_node.add_child(own is_call)
            if_node.add_child(own then_body)
            func_body.add_child(own if_node)
        } else {
            mut self_id := Expr.new(ident_node("self"), line, col)
            mut eq_call := make_method_call_fcall(own self_id, "eq", line, col)

            mut ename_id := Expr.new(ident_node(ename), line, col)
            mut var_acc := Expr.new(field_access_node(vn), line, col)
            var_acc.add_child(own ename_id)
            eq_call.add_child(own var_acc)

            mut ret_str := Expr.new(NodeType.Literal(Literal.Str(vn.clone())), line, col)
            mut ret := Expr.new(NodeType.Return, line, col)
            ret.add_child(own ret_str)
            mut then_body := Expr.new(NodeType.Body, line, col)
            then_body.add_child(own ret)

            mut if_node := Expr.new(NodeType.If, line, col)
            if_node.add_child(own eq_call)
            if_node.add_child(own then_body)
            func_body.add_child(own if_node)
        }
    }

    mut unk := Expr.new(NodeType.Literal(Literal.Str("unknown")), line, col)
    mut ret_unk := Expr.new(NodeType.Return, line, col)
    ret_unk.add_child(own unk)
    func_body.add_child(own ret_unk)

    mut fdecl := FunctionDef(auto_generated = true)
    fdecl.func_type = FuncType.Func
    fdecl.params.push(own decl_typed(name = "self", explicit_type = ename, own_type = OwnType.Ref))
    fdecl.return_type = "Str"
    fdecl.variadic_index = -1
    fdecl.kwargs_index = -1

    mut fdef := Expr.new(NodeType.FuncDef(fdecl), line, col)
    fdef.add_child(own func_body)

    switch enum_def.node_type {
    case NodeType.EnumDef(ets_edd):
        ets_edd.ns_decls.push(own Declaration(name = "to_str", default_value = fdef))
    case:
        UNREACHABLE(__LOC__)
    }
}

priv init_ns_has_func := func(def: Expr, method: Str) returns Bool {
    if def.is_null() { return false }
    ref ns : Vec(Declaration) = def_ns_decls(def)
    for d_j : Declaration in ns {
        if d_j.name.eq(method).and(d_j.default_value.is_null().not()) {
            if d_j.default_value.node_type.is(NodeType.FuncDef) { return true }
        }
    }
    return false
}

priv init_type_supports_generated_method := func(type_name: Str, method: Str, scope: TypeScope) returns Bool {
    if type_name.len().eq(0) { return true }
    resolved := type_from_name_init(type_name, scope)
    if is_primitive(resolved) { return true }
    if resolved.is_funcptr() { return true }
    if type_name.eq("Str").and(method.eq("to_str")) { return true }
    if type_name.eq("Dynamic") { return false }

    ref def : Expr = scope.get_struct(type_name)
    if def.is_null() { return false }
    if init_ns_has_func(def, method) { return true }
    if method.eq("eq").and(init_ns_has_func(def, "cmp")) { return true }

    // Enum helpers may be generated in declaration order, so an enum payload
    // can be supportable even before its own generated method has been pushed.
    switch def.node_type {
    case NodeType.EnumDef(ed):
        for j in 0..ed.variants.len() {
            idx := j.to_i64()
            if ed.payload_types.has(idx).not() { continue }
            ref payload_type : Str = ed.payload_types[idx]
            if init_type_supports_generated_method(payload_type, method, scope).not() { return false }
        }
        return true
    case:
    }
    return false
}

priv enum_payloads_support_generated_method := func(variant_types: Vec(Str), method: Str, scope: TypeScope) returns Bool {
    for vt_j : Str in variant_types {
        if vt_j.len().eq(0) { continue }
        if init_type_supports_generated_method(vt_j, method, scope).not() { return false }
    }
    return true
}

priv generate_enum_clone_method := func(enum_def: Expr, ename: Str, line: U32, col: U32, variant_names: Vec(Str), variant_types: Vec(Str), has_payloads: Bool, scope: TypeScope) {
    mut func_body := Expr.new(NodeType.Body, line, col)
    // Tag-only enums (no variant carries a payload) need an if-guard
    // for every variant so the auto-gen body always reads ~self~ at
    // least once -- otherwise check_unused_params rejects the
    // generated clone for a single-variant enum, where the existing
    // "last variant" branch below would otherwise emit just an
    // unconditional return. The trailing UNREACHABLE/return after
    // the loop satisfies C's -Wreturn-type without changing
    // observable behaviour (the enum is exhaustive).
    guard_every := has_payloads.not()
    for j in 0..variant_names.len() {
        ref vname : Str = variant_names[j]

        mut ename_id := Expr.new(ident_node(ename), line, col)
        mut ctor_acc := Expr.new(field_access_node(vname), line, col)
        ctor_acc.add_child(own ename_id)

        mut ctor_expr := Expr.new(NodeType.Literal(Literal.Null), line, col)
        mut pd := Expr.new(NodeType.Body, line, col)
        mut has_pd := false
        ref vtype : Str = variant_types[j]
        if vtype.len().gt(0) {
            pn := format("_clone_payload_", vname, "_", j.to_str())

            mut self_arg := Expr.new(ident_node("self"), line, col)
            pd = make_payload_ref_decl(own self_arg, pn, vtype, line, col, false)
            has_pd = true

            mut ctor_call := Expr.new(NodeType.FCall(FCallData()), line, col)
            ctor_call.add_child(own ctor_acc)
            mut p_id := Expr.new(ident_node(pn), line, col)
            // Issue #109: variant ctor payload param is Own for compound
            // types -- a clone() body produces a fresh enum with its own
            // owned payload, so deep-clone the extracted payload before
            // the ctor call. Primitives / Dynamic / FuncSig stay plain.
            resolved_pc := type_from_name_init(vtype, scope)
            payload_needs_clone := is_primitive(resolved_pc).not()
                .and(vtype.eq("Dynamic").not())
                .and(resolved_pc.is_funcptr().not())
                .and(vtype.starts_with("_Fn_").not())
            if payload_needs_clone {
                mut clone_call := make_method_call_fcall(own p_id, "clone", line, col)
                ctor_call.add_child(own clone_call)
            } else {
                ctor_call.add_child(own p_id)
            }
            ctor_expr = ctor_call
        } else {
            ctor_expr = ctor_acc
        }

        mut ret := Expr.new(NodeType.Return, line, col)
        ret.add_child(own ctor_expr)

        emit_guard := guard_every.or(j.lt(variant_names.len().sub(1)))
        if emit_guard {
            mut cond := Expr.new(NodeType.Literal(Literal.Null), line, col)
            if has_payloads {
                cond = make_is_tag_check_fcall("self", ename, vname, line, col)
            } else {
                mut self_id := Expr.new(ident_node("self"), line, col)
                mut cond_call := make_method_call_fcall(own self_id, "eq", line, col)

                mut en2 := Expr.new(ident_node(ename), line, col)
                mut va2 := Expr.new(field_access_node(vname), line, col)
                va2.add_child(own en2)
                cond_call.add_child(own va2)
                cond = cond_call
            }

            mut then_body := Expr.new(NodeType.Body, line, col)
            if has_pd {
                then_body.add_child(own pd.clone())
            }
            then_body.add_child(own ret)

            mut if_node := Expr.new(NodeType.If, line, col)
            if_node.add_child(own cond)
            if_node.add_child(own then_body)
            func_body.add_child(own if_node)
        } else {
            if has_pd {
                func_body.add_child(own pd.clone())
            }
            func_body.add_child(own ret)
        }
    }
    if guard_every {
        ref first_vname : Str = variant_names[0]
        // ~__LOC__~ is a parser-time directive; we're past parse, so
        // emit a synthetic loc string directly.
        loc_text := format(ename, ".clone:", line.to_str(), ":", col.to_str())
        mut unr_id := Expr.new(ident_node("UNREACHABLE"), line, col)
        mut loc_lit := Expr.new(NodeType.Literal(Literal.Str(loc_text)), line, col)
        mut unr_call := Expr.new(NodeType.FCall(FCallData()), line, col)
        unr_call.add_child(own unr_id)
        unr_call.add_child(own loc_lit)
        func_body.add_child(own unr_call)

        mut tail_ename_id := Expr.new(ident_node(ename), line, col)
        mut tail_ctor := Expr.new(field_access_node(first_vname), line, col)
        tail_ctor.add_child(own tail_ename_id)
        mut tail_ret := Expr.new(NodeType.Return, line, col)
        tail_ret.add_child(own tail_ctor)
        func_body.add_child(own tail_ret)
    }

    mut fdecl := FunctionDef(auto_generated = true)
    fdecl.func_type = FuncType.Func
    fdecl.params.push(own decl_typed(name = "self", explicit_type = ename, own_type = OwnType.Ref))
    fdecl.return_type = ename.clone()
    fdecl.variadic_index = -1
    fdecl.kwargs_index = -1

    mut fdef := Expr.new(NodeType.FuncDef(fdecl), line, col)
    fdef.add_child(own func_body)

    switch enum_def.node_type {
    case NodeType.EnumDef(ecl_edd2):
        ecl_edd2.ns_decls.push(own Declaration(name = "clone", default_value = fdef))
    case:
        UNREACHABLE(__LOC__)
    }
}

priv register_enum_def_for_stmt := proc(ctx: Context, stmt: Expr, scope: TypeScope) returns I32 {
    if stmt.node_type.is(NodeType.Decl).not() { return 0 }
    if stmt.child(0).node_type.is(NodeType.EnumDef).not() { return 0 }
    return register_enum_definition(ctx, stmt, scope)
}

priv gen_enum_nonclone_methods_for_stmt := func(stmt: Expr, scope: TypeScope) {
    if stmt.node_type.is(NodeType.Decl).not() { return }
    if stmt.child(0).node_type.is(NodeType.EnumDef).not() { return }

    mut ename := ""
    switch stmt.node_type {
    case NodeType.Decl(edecl):
        ename = edecl.name
    case:
        UNREACHABLE(__LOC__)
        return
    }
    line := stmt.line
    col := stmt.col

    variant_names := Vec(Str).new()
    variant_types := Vec(Str).new()
    mut has_payloads := false
    collect_enum_variants(stmt.child(0), variant_names, variant_types, has_payloads)
    generate_enum_variant_constructors(stmt.child(0), ename, line, col, variant_names, variant_types, has_payloads, scope)

    mut has_is := false
    mut has_eq := false
    mut has_delete := false
    mut has_to_str := false
    switch stmt.child(0).node_type {
    case NodeType.EnumDef(ens_edd):
        for d_j : Declaration in ens_edd.ns_decls {
            ref fdecl : Declaration = d_j
            if fdecl.name.eq("is") { has_is = true }
            if fdecl.name.eq("eq") { has_eq = true }
            if fdecl.name.eq("delete") { has_delete = true }
            if fdecl.name.eq("to_str") { has_to_str = true }
        }
    case:
        UNREACHABLE(__LOC__)
    }

    if has_is.not() {
        generate_enum_is_method(stmt.child(0), ename, line, col)
    }
    if has_eq.not().and(enum_payloads_support_generated_method(variant_types, "eq", scope)) {
        generate_enum_eq_method(stmt.child(0), ename, line, col, variant_names, variant_types, scope)
    }
    if has_delete.not() {
        generate_enum_delete_method(stmt.child(0), ename, line, col, variant_names, variant_types, has_payloads, scope)
    }
    if has_to_str.not().and(enum_payloads_support_generated_method(variant_types, "to_str", scope)) {
        generate_enum_to_str_method(stmt.child(0), ename, line, col, variant_names, variant_types, has_payloads, scope)
    }

}

priv gen_missing_enum_clone_for_stmt := func(stmt: Expr, scope: TypeScope) {
    if stmt.node_type.is(NodeType.Decl).not() { return }
    if stmt.child(0).node_type.is(NodeType.EnumDef).not() { return }

    mut ename := ""
    switch stmt.node_type {
    case NodeType.Decl(edecl):
        ename = edecl.name
    case:
        UNREACHABLE(__LOC__)
        return
    }
    line := stmt.line
    col := stmt.col
    mut has_clone := false
    switch stmt.child(0).node_type {
    case NodeType.EnumDef(ecl_edd):
        for d_j : Declaration in ecl_edd.ns_decls {
            ref fdecl : Declaration = d_j
            if fdecl.name.eq("clone") {
                has_clone = true
                break
            }
        }
    case:
        UNREACHABLE(__LOC__)
    }
    if has_clone.not() {
        variant_names := Vec(Str).new()
        variant_types := Vec(Str).new()
        mut has_payloads := false
        collect_enum_variants(stmt.child(0), variant_names, variant_types, has_payloads)
        generate_enum_clone_method(stmt.child(0), ename, line, col, variant_names, variant_types, has_payloads, scope)
    }
}

priv register_funcsig_alias_for_stmt := func(ctx: Context, stmt: Expr, scope: TypeScope) {
    if is_func_decl(stmt).not() { return }
    if stmt.child(0).children.len().neq(0) { return }
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        scope.set(sdecl.name, Type.FuncPtr, false, ctx.path, stmt.line, stmt.col, false, OwnType.Shallow)
        scope.set_func_def(sdecl.name, stmt.child(0))
        ref mut fb : TypeBinding = scope.get_binding(sdecl.name)
        fb.is_func_decl = true
    case:
        UNREACHABLE(__LOC__)
    }
}

priv register_type_alias_for_stmt := func(ctx: Context, stmt: Expr, scope: TypeScope) {
    if stmt.node_type.is(NodeType.Decl).not() { return }
    ref rhs : Expr = stmt.child(0)
    mut target_name := ""
    switch rhs.node_type {
    case NodeType.Ident(tn):
        target_name = tn.ident_name()
    case:
        return
    }
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        if scope.find(sdecl.name).is(ScopeFind.Found) { return }
        find := scope.find(target_name)
        switch find {
        case ScopeFind.Found(target):
            ref tgt_fd : Expr = scope.lookup_func(target.name)
            ref tgt_sd : Expr = scope.struct_def_of(target.name)
            if tgt_sd.is_null().and(target.is_builtin.not()) {
                if tgt_fd.is_null() {
                    return
                }
                if tgt_fd.children.len().neq(0) {
                    return
                }
            }
            scope.set(sdecl.name, target.type, false, ctx.path, stmt.line, stmt.col, false, OwnType.Shallow)
            if tgt_fd.is_null().not() { scope.set_func_def(sdecl.name, tgt_fd) }
            ref mut ab : TypeBinding = scope.get_binding(sdecl.name)
            if tgt_sd.is_null().not() { scope.set_struct_def(sdecl.name, tgt_sd) }
            ab.is_func_decl = target.is_func_decl
            ab.is_builtin = target.is_builtin
            ab.is_type_alias = true
            if target.alias_target.is_empty() {
                ab.alias_target = target_name
            } else {
                ab.alias_target = target.alias_target
            }
        case:
            // Target not in scope yet. Only register when the target name
            // is a builtin primitive (e.g. `USize := U32` declared above
            // u32.til's import). Extending this to user-defined types
            // (Custom) is unsafe because we cannot tell at this point
            // whether the target is a type, a value, or an ALL_CAPS
            // constant (CamelCase heuristic doesn't work). The Found
            // arm above handles user-defined types when the target file
            // was already init'd. #165.
            til_type := til_type_from_explicit_type(target_name)
            if til_type.is(Type.Unknown) { return }
            if til_type.is(Type.Custom) { return }
            scope.set(sdecl.name, til_type, false, ctx.path, stmt.line, stmt.col, false, OwnType.Shallow)
            ref mut ab : TypeBinding = scope.get_binding(sdecl.name)
            ab.is_type_alias = true
            ab.alias_target = target_name
        }
    case:
        UNREACHABLE(__LOC__)
    }
}

priv register_top_level_value_for_stmt := func(ctx: Context, stmt: Expr, scope: TypeScope) {
    if stmt.node_type.is(NodeType.Decl).not() { return }
    ref rhs : Expr = stmt.child(0)
    if rhs.node_type.is(NodeType.FuncDef).or(rhs.node_type.is(NodeType.StructDef)).or(rhs.node_type.is(NodeType.EnumDef)) {
        return
    }
    if rhs.node_type.is(NodeType.Ident) {
        switch stmt.node_type {
        case NodeType.Decl(sdecl0):
            if sdecl0.explicit_type.len().eq(0) {
                switch rhs.node_type {
                case NodeType.Ident(rhs_name):
                    if type_from_name_init(rhs_name.ident_name(), scope).is(Type.Unknown).not() {
                        return
                    }
                case:
                }
            }
        case:
        }
    }

    mut t := Type.Unknown
    if infer_top_level_decl_type(stmt, scope, t).not() { return }
    if t.is(Type.Unknown) { return }

    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        scope.set(sdecl.name, t, sdecl.is_mut, ctx.path, stmt.line, stmt.col, false, OwnType.Shallow)
        ref mut tlv_b : TypeBinding = scope.get_binding(sdecl.name)
        tlv_b.is_priv = sdecl.is_priv
        tlv_b.orig_name = sdecl.orig_name.clone()
    case:
        UNREACHABLE(__LOC__)
    }
}

priv register_function_def_for_stmt := func(ctx: Context, stmt: Expr, scope: TypeScope) {
    if stmt.node_type.is(NodeType.Decl).not() { return }
    ref def : Expr = stmt.child(0)
    if def.node_type.is(NodeType.FuncDef).not() { return }

    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        if def.children.len().eq(0) {
            scope.set(sdecl.name, Type.FuncPtr, false, ctx.path, stmt.line, stmt.col, false, OwnType.Shallow)
            scope.set_func_def(sdecl.name, stmt.child(0))
            ref mut fb : TypeBinding = scope.get_binding(sdecl.name)
            fb.is_func_decl = true
            fb.is_priv = sdecl.is_priv
            fb.orig_name = sdecl.orig_name.clone()
            return
        }

        if sdecl.explicit_type.len().gt(0) {
            fs_find := scope.find(sdecl.explicit_type)
            switch fs_find {
            case ScopeFind.Found(fsb):
                ref fsb_fd : Expr = scope.lookup_func(fsb.name)
                if fsb_fd.is_null().not() {
                    if fsb_fd.children.len().eq(0) {
                        ref sig : Expr = fsb_fd
                        switch def.node_type {
                        case NodeType.FuncDef(fdef):
                            switch sig.node_type {
                            case NodeType.FuncDef(sigdef):
                                if fdef.params.len().neq(sigdef.params.len()) {
                                    panic(
                                        __LOC__,
                                        ctx.path, ":", stmt.line.to_str(), ":", stmt.col.to_str(),
                                        ": error: '", sdecl.name, "' expects ", fdef.params.len().to_str(),
                                        " params but FuncSig '", sdecl.explicit_type, "' has ", sigdef.params.len().to_str(),
                                    )
                                }
                                fdef.func_type = sigdef.func_type
                                for j in 0..sigdef.params.len() {
                                    ref mut dp : Declaration = fdef.params[j]
                                    ref sp : Declaration = sigdef.params[j]
                                    dp.explicit_type = sp.explicit_type
                                    dp.til_type = sp.til_type.clone()
                                    dp.is_mut = sp.is_mut
                                    dp.own_type = sp.own_type
                                }
                                fdef.return_type = sigdef.return_type
                                fdef.return_own_type = sigdef.return_own_type
                                sdecl.explicit_type = ""
                                sdecl.til_type = Type.Unknown
                            case:
                                UNREACHABLE(__LOC__)
                            }
                        case:
                            UNREACHABLE(__LOC__)
                        }
                    }
                }
            case:
            }
        }

        switch def.node_type {
        case NodeType.FuncDef(fdef):
            ft := fdef.func_type
            mut rt := Type.None
            if fdef.return_type.len().gt(0) {
                rt = init_type_from_explicit_type(fdef.return_type, scope)
            }
            scope.set(sdecl.name, rt, false, ctx.path, stmt.line, stmt.col, false, OwnType.Shallow)
            scope.set_func_def(sdecl.name, stmt.child(0))
            ref mut fb : TypeBinding = scope.get_binding(sdecl.name)
            fb.is_func_decl = true
            fb.is_priv = sdecl.is_priv
            fb.orig_name = sdecl.orig_name.clone()
            if ft.is(FuncType.ExtFunc).or(ft.is(FuncType.ExtProc)) {
                fb.is_builtin = true
            }
        case:
            UNREACHABLE(__LOC__)
        }
    case:
        UNREACHABLE(__LOC__)
    }
}

gen_struct_size_method_for_stmt := func(stmt: Expr, ctx: Context) {    if stmt.node_type.is(NodeType.Decl).not() { return }
    ref def : Expr = stmt.child(0)
    if def.node_type.is(NodeType.StructDef).not() { return }

    mut sname := ""
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        sname = sdecl.name
    case:
        UNREACHABLE(__LOC__)
        return
    }
    if is_dynamic_type(sname) { return }
    switch def.node_type {
    case NodeType.StructDef(sz_sdd):
        mut has_size := false
        for d_j : Declaration in sz_sdd.ns_decls {
            ref fd : Declaration = d_j
            if fd.name.eq("size") {
                has_size = true
                break
            }
        }
        if has_size { return }

        sz_text := ctx_total_size(sname, ctx).to_str()

        mut func_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
        mut size_expr := Expr.new(literal_num_node(sz_text), stmt.line, stmt.col)
        mut ret := Expr.new(NodeType.Return, stmt.line, stmt.col)
        ret.add_child(own size_expr)
        func_body.add_child(own ret)

        mut func_decl := FunctionDef(auto_generated = true)
        func_decl.func_type = FuncType.Func
        func_decl.return_type = "USize"
        func_decl.variadic_index = -1
        func_decl.kwargs_index = -1

        mut func_def := Expr.new(NodeType.FuncDef(func_decl), stmt.line, stmt.col)
        func_def.add_child(own func_body)

        sz_sdd.ns_decls.push(own Declaration(name = "size", default_value = func_def))
    case:
        UNREACHABLE(__LOC__)
    }
}

