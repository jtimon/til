            not_call.add_child(own not_acc)
            mut ret := Expr.new(NodeType.Return, stmt.line, stmt.col, stmt.path)
            ret.add_child(own not_call)
            mut func_body := Expr.new(NodeType.Body, stmt.line, stmt.col, stmt.path)
            func_body.add_child(own ret)
            mut func_decl := FunctionDef()
            func_decl.func_type = FuncType.Func
            a_param := Declaration(name = "a", explicit_type = sname.clone(), own_type = OwnType.Ref)
            b_param := Declaration(name = "b", explicit_type = sname.clone(), own_type = OwnType.Ref)
            func_decl.params.push(own a_param)
            func_decl.params.push(own b_param)
            func_decl.return_type = "Bool"
            func_decl.return_own_type = OwnType.Shallow
            func_decl.variadic_index = -1.to_i32()
            func_decl.kwargs_index = -1.to_i32()
            mut func_def := Expr.new(NodeType.FuncDef(func_decl), stmt.line, stmt.col, stmt.path)
            func_def.add_child(own func_body)
            if def.data.is(NodeType.StructDef) {
                ref mut _cmp_sdd : StructDef = get_payload(def.data)
                _cmp_sdd.ns_decls.push(own Declaration(name = "neq", is_namespace = true, default_value = func_def))
            } else {
                ref mut _ec_edd : EnumDef = get_payload(def.data)
                _ec_edd.ns_decls.push(own Declaration(name = "neq", is_namespace = true, default_value = func_def))
            }
        }

        if has_lte.not() {
            mut a_id := Expr.new(NodeType.Ident("a"), stmt.line, stmt.col, stmt.path)
            mut b_id := Expr.new(NodeType.Ident("b"), stmt.line, stmt.col, stmt.path)
            mut gt_acc := Expr.new(NodeType.FieldAccess("gt"), stmt.line, stmt.col, stmt.path)
            gt_acc.add_child(own a_id)
            mut gt_call := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col, stmt.path)
            gt_call.add_child(own gt_acc)
            gt_call.add_child(own b_id)
            mut not_acc := Expr.new(NodeType.FieldAccess("not"), stmt.line, stmt.col, stmt.path)
            not_acc.add_child(own gt_call)
            mut not_call := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col, stmt.path)
            not_call.add_child(own not_acc)
            mut ret := Expr.new(NodeType.Return, stmt.line, stmt.col, stmt.path)
            ret.add_child(own not_call)
            mut func_body := Expr.new(NodeType.Body, stmt.line, stmt.col, stmt.path)
            func_body.add_child(own ret)
            mut func_decl := FunctionDef()
            func_decl.func_type = FuncType.Func
            a_param := Declaration(name = "a", explicit_type = sname.clone(), own_type = OwnType.Ref)
            b_param := Declaration(name = "b", explicit_type = sname.clone(), own_type = OwnType.Ref)
            func_decl.params.push(own a_param)
            func_decl.params.push(own b_param)
            func_decl.return_type = "Bool"
            func_decl.return_own_type = OwnType.Shallow
            func_decl.variadic_index = -1.to_i32()
            func_decl.kwargs_index = -1.to_i32()
            mut func_def := Expr.new(NodeType.FuncDef(func_decl), stmt.line, stmt.col, stmt.path)
            func_def.add_child(own func_body)
            if def.data.is(NodeType.StructDef) {
                ref mut _cmp_sdd : StructDef = get_payload(def.data)
                _cmp_sdd.ns_decls.push(own Declaration(name = "lte", is_namespace = true, default_value = func_def))
            } else {
                ref mut _ec_edd : EnumDef = get_payload(def.data)
                _ec_edd.ns_decls.push(own Declaration(name = "lte", is_namespace = true, default_value = func_def))
            }
        }

        if has_gte.not() {
            mut a_id := Expr.new(NodeType.Ident("a"), stmt.line, stmt.col, stmt.path)
            mut b_id := Expr.new(NodeType.Ident("b"), stmt.line, stmt.col, stmt.path)
            mut lt_acc := Expr.new(NodeType.FieldAccess("lt"), stmt.line, stmt.col, stmt.path)
            lt_acc.add_child(own a_id)
            mut lt_call := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col, stmt.path)
            lt_call.add_child(own lt_acc)
            lt_call.add_child(own b_id)
            mut not_acc := Expr.new(NodeType.FieldAccess("not"), stmt.line, stmt.col, stmt.path)
            not_acc.add_child(own lt_call)
            mut not_call := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col, stmt.path)
            not_call.add_child(own not_acc)
            mut ret := Expr.new(NodeType.Return, stmt.line, stmt.col, stmt.path)
            ret.add_child(own not_call)
            mut func_body := Expr.new(NodeType.Body, stmt.line, stmt.col, stmt.path)
            func_body.add_child(own ret)
            mut func_decl := FunctionDef()
            func_decl.func_type = FuncType.Func
            a_param := Declaration(name = "a", explicit_type = sname.clone(), own_type = OwnType.Ref)
            b_param := Declaration(name = "b", explicit_type = sname.clone(), own_type = OwnType.Ref)
            func_decl.params.push(own a_param)
            func_decl.params.push(own b_param)
            func_decl.return_type = "Bool"
            func_decl.return_own_type = OwnType.Shallow
            func_decl.variadic_index = -1.to_i32()
            func_decl.kwargs_index = -1.to_i32()
            mut func_def := Expr.new(NodeType.FuncDef(func_decl), stmt.line, stmt.col, stmt.path)
            func_def.add_child(own func_body)
            if def.data.is(NodeType.StructDef) {
                ref mut _cmp_sdd : StructDef = get_payload(def.data)
                _cmp_sdd.ns_decls.push(own Declaration(name = "gte", is_namespace = true, default_value = func_def))
            } else {
                ref mut _ec_edd : EnumDef = get_payload(def.data)
                _ec_edd.ns_decls.push(own Declaration(name = "gte", is_namespace = true, default_value = func_def))
            }
        }
    }
}

generate_derived_methods := proc(program: Expr) {
    generate_cmp_derived_methods(program)
    generate_unity_derived_methods(program)
}

compute_struct_layout := proc(mut struct_def: Expr, scope: TypeScope) {
    ref mut struct_meta : StructDef = get_payload(struct_def.data)
    if struct_meta.total_struct_size.gt(0) { return }

    ref body : Expr = struct_def.child(0)
    mut offset : I32 = 0
    mut max_align : I32 = 1

    for i in 0..body.children.len() {
        ref mut field : Expr = body.child(i)
        if field.data.is(NodeType.Decl).not() { continue }

        ref mut fd : Declaration = get_payload(field.data)
        if fd.is_namespace { continue }

        mut fsz : I32 = 0
        mut falign : I32 = 0

        if fd.own_type.eq(OwnType.Shallow).not() {
            fsz = 8
            falign = 8

            mut ftype := fd.explicit_type
            if ftype.len().eq(0) {
                if field.children.len().gt(0) {
                    ref def_val : Expr = field.child(0)
                    if def_val.data.is(NodeType.FCall) {
                        if def_val.children.len().gt(0) {
                            ref callee : Expr = def_val.child(0)
                            if callee.data.is(NodeType.Ident) {
                                ref _ft : Str = get_payload(callee.data)
                                ftype = _ft
                            }
                        }
                    }
                    if ftype.len().gt(0) { fd.explicit_type = ftype }
                }
            }

            if ftype.len().gt(0) {
                if ftype.eq("I64").not().and(ftype.eq("U8").not()).and(ftype.eq("I16").not()).and(ftype.eq("I32").not()).and(ftype.eq("U32").not()).and(ftype.eq("Bool").not()) {
                    ref nested_def : Expr = scope.get_struct(ftype)
                    if is_null(nested_def).not() {
                        fd.field_struct_def = nested_def
                    }
                }
            }
        } else {
            mut ftype := fd.explicit_type
            if ftype.len().eq(0) {
                if field.children.len().gt(0) {
                    ref def_val : Expr = field.child(0)
                    if def_val.data.is(NodeType.LiteralNum) { ftype = "I64" }
                    else if def_val.data.is(NodeType.LiteralStr) { ftype = "Str" }
                    else if def_val.data.is(NodeType.LiteralBool) { ftype = "Bool" }
                    else if til_type_name(def_val.til_type).len().gt(0) { ftype = til_type_name(def_val.til_type) }
                    else if def_val.data.is(NodeType.FCall) {
                        if def_val.children.len().gt(0) {
                            ref callee : Expr = def_val.child(0)
                            if callee.data.is(NodeType.Ident) {
                                ref _ft : Str = get_payload(callee.data)
                                ftype = _ft
                            } else if callee.data.is(NodeType.FieldAccess) {
                                if callee.children.len().gt(0) {
                                    ref type_node : Expr = callee.child(0)
                                    if type_node.data.is(NodeType.Ident) {
                                        ref _ft : Str = get_payload(type_node.data)
                                        ftype = _ft
                                    }
                                }
                            }
                        }
                    } else if def_val.data.is(NodeType.FieldAccess) {
                        if def_val.children.len().gt(0) {
                            ref type_node : Expr = def_val.child(0)
                            if type_node.data.is(NodeType.Ident) {
                                ref _ft : Str = get_payload(type_node.data)
                                ftype = _ft
                            }
                        }
                    }
                    if ftype.len().gt(0) { fd.explicit_type = ftype }
                }
            }

            ref ab : TypeBinding = scope.get_binding(ftype)
            if is_null(ab).not() {
                if ab.is_type_alias {
                    if is_null(ab.alias_target).not() {
                        ftype = ab.alias_target
                        fd.explicit_type = ftype
                    }
                }
            }

            if ftype.len().eq(0) { fsz = 8; falign = 8 }
            else if ftype.eq("I64") { fsz = 8; falign = 8 }
            else if ftype.eq("U8") { fsz = 1; falign = 1 }
            else if ftype.eq("I16") { fsz = 2; falign = 2 }
            else if ftype.eq("I32") { fsz = 4; falign = 4 }
            else if ftype.eq("U32") { fsz = 4; falign = 4 }
            else if ftype.eq("Bool") { fsz = 1; falign = 1 }
            else if type_from_name_init(ftype, scope).eq(TilType.FuncPtr) { fsz = 8; falign = 8 }
            else {
                ref nested_def : Expr = scope.get_struct(ftype)
                if is_null(nested_def).not().and(nested_def.data.is(NodeType.EnumDef)) {
                    if enum_has_payloads(nested_def) {
                        fsz = 8
                        falign = 8
                    } else {
                        fsz = 4
                        falign = 4
                    }
                    fd.field_struct_def = nested_def
                } else if is_null(nested_def).not() {
                    compute_struct_layout(nested_def, scope)
                    ref nested_meta : StructDef = get_payload(nested_def.data)
                    fsz = nested_meta.total_struct_size
                    falign = 8
                    fd.field_struct_def = nested_def
                } else {
                    fsz = 8
                    falign = 8
                }
            }
        }

        offset = align_up(offset, falign)
        fd.field_offset = offset
        fd.field_size = fsz
        if falign.gt(max_align) { max_align = falign }
        offset = offset.add(fsz)
    }

    struct_meta.total_struct_size = align_up(offset, max_align)
    if struct_meta.total_struct_size.eq(0) {
        struct_meta.total_struct_size = 1
    }
}

compute_all_struct_layouts := proc(program: Expr, scope: TypeScope) {
    for i in 0..program.children.len() {
        ref stmt : Expr = program.child(i)
        if stmt.data.is(NodeType.Decl).not() { continue }
        if stmt.child(0).data.is(NodeType.StructDef).not() { continue }
        ref _sd : Declaration = get_payload(stmt.data)
        sname := _sd.name
        if sname.eq("Dynamic") { continue }
        compute_struct_layout(stmt.child(0), scope)
    }
}

infer_top_level_decl_type := func(stmt: Expr, scope: TypeScope, mut out_type: TilType) returns shallow Bool {
    ref rhs : Expr = stmt.child(0)
    out_type = TilType.Unknown

    if stmt.data.is(NodeType.Decl) {
        ref dd : Declaration = get_payload(stmt.data)
        if dd.explicit_type.len().gt(0) {
            out_type = type_from_name_init(dd.explicit_type, scope)
            return out_type.is(TilType.Unknown).not()
        }
    }

    switch rhs.data {
    case NodeType.LiteralNum:
        out_type = TilType.I64
        return true
    case NodeType.LiteralBool:
        out_type = TilType.Bool
        return true
    case NodeType.LiteralStr:
        out_type = TilType.Struct("Str".clone())
        return true
    case NodeType.LiteralNull:
        out_type = TilType.Dynamic
        return true
    case NodeType.Ident(id):
        ref b : TypeBinding = scope.get_binding(id)
        if is_null(b) { return false }
        out_type = b.type
        return out_type.is(TilType.Unknown).not()
    case NodeType.FieldAccess:
        mut _init_ns1 := false
        if rhs.children.len().gt(0) {
            ref _io1 : Expr = rhs.child(0)
            if _io1.data.is(NodeType.Ident) {
                if til_type_name(_io1.til_type).eq("StructDef").or(til_type_name(_io1.til_type).eq("EnumDef")) {
                    _init_ns1 = true
                }
            }
        }
        if _init_ns1.and(rhs.til_type.is(TilType.Enum)) {
            mut _enum_name := ""
            if rhs.children.len().gt(0) {
                _enum_name = til_type_name(rhs.child(0).til_type)
            }
            out_type = TilType.Enum(_enum_name.clone())
            return true
        }
        return false
    case NodeType.FCall:
        ref callee : Expr = rhs.child(0)
        if til_type_name(rhs.til_type).len().gt(0).and(callee.data.is(NodeType.Ident)) {
            ref cn : Str = get_payload(callee.data)
            if cn.eq(til_type_name(rhs.til_type)) {
                out_type = TilType.Struct(til_type_name(rhs.til_type))
                return true
            }
        }
        mut _init_ns2 := false
        if callee.data.is(NodeType.FieldAccess).and(callee.children.len().gt(0)) {
            ref _io2 : Expr = callee.child(0)
            if _io2.data.is(NodeType.Ident) {
                if til_type_name(_io2.til_type).eq("StructDef").or(til_type_name(_io2.til_type).eq("EnumDef")) {
                    _init_ns2 = true
                }
            }
        }
        if callee.data.is(NodeType.FieldAccess).and(_init_ns2)
        .and(til_type_name(rhs.til_type).len().gt(0)).and(rhs.til_type.is(TilType.Enum)) {
            out_type = TilType.Enum(til_type_name(rhs.til_type))
            return true
        }
        if callee.data.is(NodeType.Ident) {
            ref fn_name : Str = get_payload(callee.data)
            ref fb : TypeBinding = scope.get_binding(fn_name)
            if is_null(fb) { return false }
            out_type = fb.type
            return out_type.is(TilType.Unknown).not()
        }
        return false
    case:
        return false
    }
}

init_declarations := proc(program: Expr, scope: TypeScope) returns shallow I32 {
    mut errors : I32 = 0

    errors = errors.add(register_struct_definitions(program, scope))
    register_funcsig_aliases(program, scope)
    generate_missing_struct_clones(program, scope)
    generate_missing_struct_deletes(program, scope)
    errors = errors.add(register_enums_and_generate_nonclone_methods(program, scope))
    generate_missing_enum_clones(program)
    register_type_aliases(program, scope)
    compute_all_struct_layouts(program, scope)
    generate_size_methods(program)
    generate_derived_methods(program)
    register_function_definitions(program, scope)
    register_top_level_values(program, scope)

    return errors
}

