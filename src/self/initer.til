mode lib

import("parser")

TypeBinding := struct {
    name := ""
    type := Type.Unknown
    func_type := FuncType.None
    is_mut := false
    is_priv := false
    path := ""
    line : U32 = 0
    col : U32 = 0
    is_param := false
    own_type := OwnType.Shallow
    is_alias := false
    is_type_alias := false
    alias_target := ""
    ref struct_def : Expr = NULL
    ref func_def : Expr = NULL
    is_builtin := false
    used := false
    // Issue #93: mirror of Declaration.orig_name -- non-empty means
    // init_declarations_unit hoisted this decl from a function body and
    // the unused-priv check should report it in source terms (original
    // name + enclosing parent) rather than as a synthetic mangled name.
    orig_name := ""
namespace:
    eq := func(a: TypeBinding, b: TypeBinding) returns Bool {
        return a.name.eq(b.name)
    }
    to_str := func(self: TypeBinding) returns Str {
        if is_null(self.name) { return "TypeBinding" }
        return self.name.clone()
    }
}

// initer_path previously lived here as a module-level mut copy of
// ctx.path. The register_*_for_stmt helpers and the dispatchers
// (init_declarations_unit / init_declarations_global) now thread
// ctx through and read ctx.path directly, so the mirror is gone.

// Mangled C symbol prefix for `priv` top-level decls. Two `priv X` in
// different files used to clobber each other at the C symbol level
// (the C emitter writes `void X()` once per priv, both lands in the
// generated translation unit and one silently wins). Rewriting each
// priv decl plus its in-file references to `priv__<path>__<name>` at
// init time keeps every priv binding distinct without the rest of the
// pipeline (precomp, scavenger, builder, interpreter) needing to know
// anything about priv-by-file. The user-visible identifier survives on
// Declaration.orig_name for diagnostics.
priv_c_name := func(path: Str, name: Str) returns Str {
    mut buf := Str.with_capacity(path.len().add(name.len()).add(16))
    buf.push_str("priv__")
    // Path bytes that aren't C-identifier-safe become a single `_`, and
    // runs of consecutive non-ident bytes collapse so we get
    // `priv__test_priv_helper_til__Mood` rather than
    // `priv____test_priv_helper_til__Mood` from `./test/priv_helper.til`.
    mut last_was_underscore := false
    mut i : USize = 0
    while i.lt(path.len()) {
        ref c : I8 = path.byte_at(i)
        is_alnum := c.gte('a').and(c.lte('z'))
            .or(c.gte('A').and(c.lte('Z')))
            .or(c.gte('0').and(c.lte('9')))
        if is_alnum {
            buf.push_str(path.substr(i, 1))
            last_was_underscore = false
        } else {
            if last_was_underscore.not() {
                buf.push_str("_")
                last_was_underscore = true
            }
        }
        i = i.add(1)
    }
    buf.push_str("__")
    buf.push_str(name)
    return buf
}

ScopeFind := enum { NotFound, Found: TypeBinding }

TypeScope := struct {
    bindings := Map.new(Str, TypeBinding)
    ref parent : TypeScope = NULL
namespace:
    get_binding := func(self: TypeScope, name: Str) returns ref TypeBinding {
        if self.bindings.has(name) {
            ref b : TypeBinding = self.bindings[name]
            return b
        }
        if is_null(self.parent).not() {
            ref pb : TypeBinding = self.parent.get_binding(name)
            return pb
        }
        return NULL
    }
    find := func(self: TypeScope, name: Str) returns ScopeFind {
        ref b : TypeBinding = self.get_binding(name)
        if is_null(b).not() {
            return ScopeFind.Found(b.clone())
        }
        return ScopeFind.NotFound
    }
    get_type := func(self: TypeScope, name: Str) returns Type {
        ref b : TypeBinding = self.get_binding(name)
        if is_null(b).not() { return b.type.clone() }
        return Type.Unknown
    }
    get_func_type := func(self: TypeScope, name: Str) returns shallow FuncType {
        ref b : TypeBinding = self.get_binding(name)
        if is_null(b).not() { return b.func_type }
        return FuncType.None
    }
    get_struct := func(self: TypeScope, name: Str) returns ref Expr {
        if self.bindings.has(name) {
            ref b : TypeBinding = self.bindings[name]
            if is_null(b.struct_def).not() { return b.struct_def }
        }
        if is_null(self.parent).not() {
            return self.parent.get_struct(name)
        }
        return NULL
    }
    is_mut := func(self: TypeScope, name: Str) returns Bool {
        ref b : TypeBinding = self.get_binding(name)
        if is_null(b).not() { return b.is_mut }
        return false
    }
    set := func(mut self: TypeScope, name: Str, type: Type,
        shallow func_type: FuncType, is_mut: Bool,
        path: Str,
        line: U32, col: U32,
        is_param: Bool, shallow own_type: OwnType) {
            if self.bindings.has(name) {
                ref mut b : TypeBinding = self.bindings[name]
                b.type = type
                b.func_type = func_type
                b.is_mut = is_mut
                // path/line/col are declaration-site identity. Don't
                // overwrite them on re-registration: init_declarations_global
                // re-runs across all units with a stale initer_path and
                // would otherwise relocate priv bindings to the wrong file
                // (issue #179 step 1 cross-file check needs the original).
                b.is_param = is_param
                b.own_type = own_type
                return
            }
            nb := TypeBinding(name = name.clone(), type = type.clone(),
                func_type = func_type, is_mut = is_mut,
                path = path.clone(),
                line = line, col = col,
                is_param = is_param, own_type = own_type)
            self.bindings.set(own name.clone(), own nb)
        }
}

ImportUnit := struct {
    mode_str := ""
    mode := Mode()
    own ast := Expr.new(NodeType.Body, 0, 0)
    imports := Vec.new(Str)
}

Context := struct {
    mode := Mode()
    path := ""
    path_modes := Map.new(Str, Mode)

    // Import tracking (rstil-style). Map path -> (mode, ast).
    imported := Map.new(Str, ImportUnit)
    imports_init_done := Set.new(Str)
    // Two-sweep typer (issue #174 / #147 step 3-4 prep). The typer
    // recursion is split into a decls-first sweep (struct/enum decls,
    // methodgen, layout) and a bodies sweep (function body
    // type-checking). The decls sweep produces all method-name
    // bindings before any body type-checks, so the Vec/Str/I64 method
    // cycle that #174 catalogues is broken: bodies in either
    // direction always see the other's methods. Each sweep has its
    // own per-file memo Set.
    imports_typer_decls_done := Set.new(Str)
    imports_typer_bodies_done := Set.new(Str)
    imports_precomp_done := Set.new(Str)
    imports_eval_done := Set.new(Str)

    scope := TypeScope()
    is_repl := false

    // Issue #147 step 3: struct/enum layouts keyed by type name. Populated
    // by record_struct_layout / record_enum_layout after compute_*_layout
    // fills the AST fields. Readers still use the AST fields for now; they
    // migrate to this map in step 4.
    struct_layouts := Map.new(Str, StructLayout)

    // Precomp state moved off module globals. The same Context crosses
    // imported files and later phases, so these three tables live here
    // directly rather than as a separate module-global side store.
    precomp_macros := Set.new(Str)
    precomp_funcs := Set.new(Str)
    precomp_known := Map.new(Str, Value)

    // Interpreter runtime state, moved off module globals (same
    // direct-on-Context approach as the precomp tables above). The
    // control-flow flags and return slot drive eval_body /
    // eval_user_func; ns_fields/ns_keys hold static struct fields keyed
    // `<Type>.<field>`; ns_inited guards their one-time (re)creation.
    has_return := false
    has_break := false
    has_continue := false
    return_value := Value.None
    ns_fields := Map.new(Str, Value)
    ns_keys := Vec.new(Dynamic)
    ns_inited := false

    // True while the typer is inferring a struct/enum namespace member
    // (set in infer_type_def_expr).  Lets infer_func_def_expr accept
    // test() decls at the namespace level even though scope.parent is
    // the type's inner scope, while still rejecting test() decls
    // inside arbitrary nested function bodies.
    typing_namespace_member := false

    // #178 first table: per-function-emission cache of FuncPtr local
    // signatures, populated by the builder when it emits a FuncPtr-typed
    // decl, read back when fcall_fn_sig needs to resolve a FuncPtr local
    // call. Currently swapped at emit_func_def boundaries to scope it
    // per emission. The eventual rstil-style direction is to populate
    // this from the typer (keyed by function name) so the builder reads
    // without a per-emit reset; this commit only moves the storage.
    local_fn_sigs := Map.new(Str, Dynamic)

    // #178 builder lookup tables migrated from module-globals. Populated
    // at build registration time, read throughout codegen.
    func_defs := Map.new(Str, Dynamic)
    struct_def_exprs := Map.new(Str, Dynamic)
    funcsig_names := Set.new(Str)
    script_globals := Set.new(Str)
    ref_globals := Set.new(Str)

    // Issue #198: typer-owned error-type registries, moved off
    // module-level globals so they live on the same Context that
    // crosses unit boundaries. throw_type_registry is the integer-tag
    // table used by tag_for_type; throws_names/throws_per is the
    // Decl-name -> throws-types map used by inject_throw_args_in_body.
    throw_type_registry := Vec.new(Str)
    throws_names_global := Vec.new(Str)
    throws_per_global := Vec.new(Vec)

    // Issue #202: monotonically-increasing counter for `_bang_ret_<N>`
    // temps emitted when hoisting nested `f()!` calls. Lives on
    // ctx so the same Context that already threads the throws
    // registries also owns the matching temp counter.
    bang_counter : I64 = 0

    // Type-qualified throws lookup: throws_names_global stores method
    // throws under "Type.method" keys (free functions stay bare). To
    // resolve the receiver type of a `recv.method(...)` call site at
    // lowering time (before infer_body runs), the throw/catch walk
    // seeds this map with the current function's param-name -> type-name
    // bindings. Local receivers are resolved by scanning the body's
    // Decls (guess_local_type); the global scope handles the static
    // `Type.method(...)` form.
    lowering_param_types := Map.new(Str, Str)

    // Two typer-scope flags shared with garbager: typer_in_main_func is
    // set while infer_func_def_expr is checking main(), so the garbager
    // helpers can give main()'s non-Own params a scope-end delete (no
    // caller frees them); typer_in_shallow_return is set when the
    // current function returns `shallow T`, so the garbager keeps a
    // would-be-moved struct local Shallow for the codegen.
    typer_in_shallow_return : Bool = false
    typer_in_main_func : Bool = false

    // Resolved declared return type name of the function currently being
    // type-checked (empty when none / not in a func). infer_return_stmt
    // reads it to narrow a bare numeric literal return value to the
    // declared numeric type, mirroring the call-argument narrowing in
    // validate_fcall_arg. Saved+restored around each func body.
    typer_return_type_name : Str = ""

    // Monotonically-increasing builder counter for synthesised
    // constructor temp names (`_ctor_<N>`). The codegen never
    // resets this -- it just needs unique names across the whole
    // emission, so a single ctx-owned counter is sufficient.
    ctor_seq : I32 = 0

    // Builder emission-state flags. in_func_def is true while
    // emit_func_def is emitting a function body, so emit_stmt_decl
    // knows a Decl is a local (not a header global); in_main_func is
    // true while emitting main()'s body so emit_stmt_return can
    // append `return 0;` after the user code.
    in_func_def : Bool = false
    in_main_func : Bool = false

    // Typer proc/func validation: proc_def_depth counts the nesting
    // depth of `proc` definitions currently being typed (>0 means we
    // are inside one), and proc_calls_count tallies proc/ext_proc
    // call sites seen in the active proc body. infer_func_def_expr
    // saves+restores both around each body so a proc that contains
    // no proc-calls trips the "should be a func" diagnostic.
    proc_calls_count : I32 = 0
    proc_def_depth : I32 = 0

    // Typer unique-name generators. Each counter mints a fresh
    // suffix for a different family of synthesised temps that the
    // typer emits during desugar/hoist passes: hoist_counter for
    // generic hoists (`hoisted__<T>_<N>`, `_wcond_Bool_<N>`,
    // `_sw_<T>_<N>`, ...), va_counter for variadic-Array packs
    // (`_va_Array_<N>`), kw_counter for keyword-arg DynMaps
    // (`_kw<N>`), coll_counter for vec/array literal hoists
    // (`_vec_<N>`, `_array_<N>`). They never reset -- they only
    // need to mint unique-across-program names.
    hoist_counter : I32 = 0
    va_counter : I32 = 0
    kw_counter : I32 = 0
    coll_counter : I32 = 0

    // Remaining typer-phase scratch, moved off module globals. errors is
    // the per-unit type-error counter (reset and returned by
    // type_check_unit / type_check); current_type_name / current_top_func_name
    // track the type/function whose body is being typed (for the priv
    // access checks); auto_gen_depth counts nesting of auto-generated
    // FuncDef bodies so the unused-priv-member check ignores boilerplate
    // reads; throw_used_local_names tracks err-slot locals referenced
    // while lowering throw/catch. (typer_path is not duplicated here --
    // it was always a copy of ctx.path.)
    errors : I32 = 0
    current_type_name := ""
    current_top_func_name := ""
    auto_gen_depth : I32 = 0
    throw_used_local_names := Set.new(Str)

    // #178 builder per-function transients. The builder resets these on
    // entering each function body and reads them throughout that body's
    // emission. emit_func_def is not actually recursive (the typer lifts
    // nested funcs to top level), so a per-emit reset is sufficient.
    stack_locals := Set.new(Str)
    stack_local_types := Map.new(Str, Str)
    unsafe_to_hoist := Set.new(Str)
    ref_locals := Set.new(Str)
    // #220: names of decls made inside the current function body. Inside a
    // function every `:=` decl is a local (is_global/is_rg are gated on
    // in_func_def.not()), but stack_locals/ref_locals only capture a subset
    // of emit paths -- own-heap pointer locals (`Type *m = malloc(...)`) and
    // Dynamic locals (`void *tmp = ...`) were untracked. A local that shadows
    // a script global of the same name then inherited the global's value
    // classification and codegen emitted `.`/`&`/value-return against a
    // pointer. Recorded for every in-function decl; consulted only by
    // is_value_global/is_ref_global so the effect is limited to the
    // global-vs-local decision.
    ptr_locals := Set.new(Str)
    // #185: ref-locals declared as `ref X : Dynamic = ...`. Tracked
    // separately so emit_deref can typed-cast a Dynamic-declared
    // local when the typer's narrow_dynamic has retyped a use of it
    // to a concrete primitive (`not(x)`, `y.add(x)`, etc.). Without
    // the cast the codegen would emit `DEREF(x)` on a `void *`,
    // which is invalid C.
    ref_dyn_locals := Set.new(Str)
    ref current_fdef : Expr = NULL

    // #177 interpreter caches for well-known core types, populated during
    // interpret_register_defs by interpret_register_struct_defs and read
    // back by make_str_value / build_array_from_argv. These were the
    // remaining six module-scope ref-mut + NULL globals after #178.
    ref cached_str_def : Expr = NULL
    ref cached_str_name : Str = NULL
    ref cached_array_def : Expr = NULL
    ref cached_array_name : Str = NULL
    ref cached_vec_def : Expr = NULL
    ref cached_vec_name : Str = NULL

    // Interpreter type-def registry: maps every struct/enum name to its
    // AST def Expr. Populated by interpreter_init_ns, read via
    // lookup_interp_type_def. This is the rstil-style "external type
    // map" that lets struct/enum values carry only a heap pointer +
    // type name and recover their layout by name lookup. Stored as
    // Map(Str, Dynamic) of malloc'd cells holding the Expr pointer
    // (same encoding as struct_def_exprs / func_defs) so the field type
    // stays in scope at the Context definition in this file.
    interp_type_defs := Map.new(Str, Dynamic)

    // Dispatch / FFI runtime state (previously module-level globals in
    // dispatch.til). FFIEntry / FFITypePtrBox are defined in dispatch.til
    // but resolve here via whole-program merge (same as ns_fields' Value).
    // ffi_cleanup frees the inner C-heap pointers (cifs etc.) and resets
    // these maps to fresh, so Context's auto-delete only ever frees empty
    // containers -- no double free of the libffi allocations.
    dispatch_map := Map.new(Str, Dynamic)
    dispatch_inited := false
    ffi_map := Map.new(Str, FFIEntry)
    ffi_map_inited := false
    ffi_loaded := false
    ffi_struct_defs := Map.new(Str, Dynamic)
    ffi_type_cache := Vec.new(FFITypePtrBox)
    ffi_type_cache_inited := false
}

priv align_up := func(offset: I32, align: I32) returns I32 {
    return offset.add(align).sub(1).and(align.sub(1).xor(-1))
}

// Issue #158: classify one top-level statement's foldable macro/func names
// into ctx (precomp_macros / precomp_funcs). The typer already walks every
// final top-level decl (in infer_body_unit, after lambda-lifting), so this
// runs there as a side effect of that walk -- precomp then reuses the sets
// from Context instead of re-deriving them. Method calls fold under the
// qualified `<Type>_<method>` name that the precomp dispatch looks up.
precomp_classify_stmt := func(stmt: Expr, ctx: Context) {
    if stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0)).not() { return }
    switch stmt.child(0).node_type {
    case NodeType.FuncDef(fd):
        switch stmt.node_type {
        case NodeType.Decl(dd):
            if fd.func_type.is(FuncType.Macro) {
                ctx.precomp_macros.add(own dd.name.clone())
            } else if fd.func_type.is(FuncType.Func)
                .or(fd.func_type.is(FuncType.ExtFunc)) {
                ctx.precomp_funcs.add(own dd.name.clone())
            }
        case:
        }
    case NodeType.StructDef(sdd_data):
        switch stmt.node_type {
        case NodeType.Decl(sdd):
            for d_j : Declaration in sdd_data.ns_decls {
                ref fdd : Declaration = d_j
                ref fdef : Expr = fdd.default_value
                switch fdef.node_type {
                case NodeType.FuncDef(ffd):
                    qname := sdd.name.format("_", fdd.name)
                    if ffd.func_type.is(FuncType.Macro) {
                        ctx.precomp_macros.add(own qname)
                    } else if ffd.func_type.is(FuncType.Func)
                        .or(ffd.func_type.is(FuncType.ExtFunc)) {
                        ctx.precomp_funcs.add(own qname)
                    }
                case:
                }
            }
        case:
        }
    case NodeType.EnumDef(pc_edd):
        switch stmt.node_type {
        case NodeType.Decl(sdd):
            for d_j : Declaration in pc_edd.ns_decls {
                ref nsd : Declaration = d_j
                if is_null(nsd.default_value) { continue }
                switch nsd.default_value.node_type {
                case NodeType.FuncDef(ffd):
                    qname := sdd.name.format("_", nsd.name)
                    if ffd.func_type.is(FuncType.Macro) {
                        ctx.precomp_macros.add(own qname)
                    } else if ffd.func_type.is(FuncType.Func)
                        .or(ffd.func_type.is(FuncType.ExtFunc)) {
                        ctx.precomp_funcs.add(own qname)
                    }
                case:
                }
            }
        case:
        }
    case:
    }
}

// Build a UFCS-style method call FCall ~recv.method(args...)~. Returns
// the FCall with the FieldAccess(method) callee installed; the caller
// pushes any argument children with ~call.add_child(own arg)~.
make_method_call_fcall := func(own recv: Expr, method: Str, line: U32, col: U32) returns Expr {
    mut acc := Expr.new(field_access_node(method), line, col)
    acc.add_child(own recv)
    mut call := Expr.new(NodeType.FCall(FCallData()), line, col)
    call.add_child(own acc)
    return call
}

// Build the typer/initer-internal ~get_payload(arg)~ FCall used to
// destructure enum payloads in generated method bodies and switch
// case desugar. The til_type is set so infer_fcall_expr's
// user-code rejection in typer.til recognises this as
// typer-emitted rather than user-written.
make_get_payload_fcall := func(own arg: Expr, shallow payload_type: Type, line: U32, col: U32) returns Expr {
    mut gp := Expr.new(ident_node("get_payload"), line, col)
    mut gc := Expr.new(NodeType.FCall(FCallData()), line, col)
    gc.add_child(own gp)
    gc.add_child(own arg)
    set_expr_til_type(gc, payload_type)
    return gc
}

// Build the tag-check FCall ~is(arg, EnumName.Variant)~ used to gate
// each per-variant arm in the auto-generated enum eq, delete, to_str
// and clone method bodies.
make_is_tag_check_fcall := func(arg_name: Str, ename: Str, vname: Str, line: U32, col: U32) returns Expr {
    mut iv := Expr.new(ident_node("is"), line, col)
    mut arg_id := Expr.new(ident_node(arg_name), line, col)
    mut et := Expr.new(ident_node(ename), line, col)
    mut vr := Expr.new(field_access_node(vname), line, col)
    vr.add_child(own et)
    mut is_call := Expr.new(NodeType.FCall(FCallData()), line, col)
    is_call.add_child(own iv)
    is_call.add_child(own arg_id)
    is_call.add_child(own vr)
    return is_call
}

// Wrap make_get_payload_fcall in a ~ref bind_name : vtype = get_payload(arg)~
// Decl. This is the payload-destructure shape used by every auto-generated
// enum method body (eq/to_str/clone) and by typer.til's switch case desugar.
// The delete-generator threads the FCall into a different parent and so
// stays on the lower-level helper.
// Both the FCall and the Decl need an owned Type for til_type; resolve
// vtype twice so each consumer gets a fresh Type.Custom("Name") payload
// instead of an aliased one (which would double-free at scope exit).
make_payload_ref_decl := func(own arg: Expr, bind_name: Str, vtype: Str, line: U32, col: U32, is_mut: Bool) returns Expr {
    mut gc := make_get_payload_fcall(own arg, til_type_from_explicit_type(vtype), line, col)
    mut decl := Expr.new(NodeType.Decl(Declaration(name = bind_name.clone(), explicit_type = vtype.clone(), til_type = til_type_from_explicit_type(vtype), own_type = OwnType.Ref, is_mut = is_mut)), line, col)
    decl.add_child(own gc)
    return decl
}

type_from_name_init := func(name: Str, scope: TypeScope) returns Type {
    if name.eq("I64")  { return Type.I64 }
    if name.eq("U8")   { return Type.Struct("U8") }
    if name.eq("I8")   { return Type.Struct("I8") }
    if name.eq("I16")  { return Type.Primitive(Primitive.I16) }
    if name.eq("U16")  { return Type.Primitive(Primitive.U16) }
    if name.eq("I32")  { return Type.Struct("I32") }
    if name.eq("U32")  { return Type.U32 }
    if name.eq("U64")  { return Type.U64 }
    if name.eq("USize") { return Type.U32 }
    if name.eq("Str")  { return Type.Struct("Str") }
    if name.eq("Bool") { return Type.Bool }
    if name.eq("StructDef") { return Type.Struct("StructDef") }
    if name.eq("EnumDef") { return Type.Struct("EnumDef") }
    if name.eq("Dynamic")   { return Type.Dynamic }
    if is_null(scope).not() {
        ref b : TypeBinding = scope.get_binding(name)
        if is_null(b).not() {
            if b.is_type_alias {
                if b.alias_target.is_empty().not() {
                    return type_from_name_init(b.alias_target, scope)
                }
            }
            if b.is_builtin {
                if is_null(b.struct_def).not() { return b.type }
            }
            if is_null(b.func_def).not() {
                if b.func_def.children.len().eq(0) {
                    return Type.FuncPtr
                }
            }
        }
        ref sdef : Expr = scope.get_struct(name)
        if is_null(sdef).not() {
            if sdef.node_type.is(NodeType.EnumDef) {
                return Type.Enum(name.clone())
            }
            return Type.Struct(name.clone())
        }
    }
    return Type.Unknown
}

init_type_from_explicit_type := func(name: Str, scope: TypeScope) returns Type {
    mut resolved := name.clone()
    ref b : TypeBinding = scope.get_binding(name)
    if is_null(b).not() {
        if b.is_type_alias {
            if b.alias_target.is_empty().not() {
                resolved = b.alias_target.clone()
            }
        }
    }
    resolved_type := type_from_name_init(resolved, scope)
    if resolved_type.is(Type.Unknown).not() {
        return resolved_type
    }
    return til_type_from_explicit_type(resolved)
}

register_struct_def_for_stmt := proc(ctx: Context, stmt: Expr, scope: TypeScope) returns I32 {
    if stmt.node_type.is(NodeType.Decl).not() { return 0 }
    if stmt.child(0).node_type.is(NodeType.StructDef).not() { return 0 }

    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        sname := sdecl.name

        existing_find := scope.find(sname)
        switch existing_find {
        case ScopeFind.Found(existing):
            if is_null(existing.struct_def).not() {
                println(
                    ctx.path, ":", stmt.line.to_str(), ":", stmt.col.to_str(),
                    ": error: struct '", sname, "' already declared at ",
                    existing.path, ":", existing.line.to_str(), ":", existing.col.to_str(),
                )
                return 1
            }
        case:
        }

        mut builtin_type := Type.Struct(sname.clone())
        mut is_builtin := false
        if sname.eq("I64") { builtin_type = Type.I64; is_builtin = true }
        else if sname.eq("U8") { builtin_type = Type.Struct("U8"); is_builtin = true }
        else if sname.eq("I8") { builtin_type = Type.Struct("I8"); is_builtin = true }
        else if sname.eq("I16") { builtin_type = Type.Primitive(Primitive.I16); is_builtin = true }
        else if sname.eq("U16") { builtin_type = Type.Primitive(Primitive.U16); is_builtin = true }
        else if sname.eq("I32") { builtin_type = Type.Struct("I32"); is_builtin = true }
        else if sname.eq("U32") { builtin_type = Type.U32; is_builtin = true }
        else if sname.eq("U64") { builtin_type = Type.U64; is_builtin = true }
        else if sname.eq("USize") { builtin_type = Type.U32; is_builtin = true }
        else if sname.eq("Str") { is_builtin = false }
        else if sname.eq("Bool") { builtin_type = Type.Bool; is_builtin = true }
        else if sname.eq("StructDef") { is_builtin = false }
        else if sname.eq("FunctionDef") { is_builtin = false }
        else if sname.eq("Dynamic") { builtin_type = Type.Dynamic; is_builtin = true }

        scope.set(sname, builtin_type, FuncType.None, false, ctx.path, stmt.line, stmt.col, false, OwnType.Shallow)
        ref mut b : TypeBinding = scope.get_binding(sname)
        b.struct_def = stmt.child(0)
        b.is_builtin = is_builtin
        b.is_priv = sdecl.is_priv
        b.orig_name = sdecl.orig_name.clone()
        // Issue #147 step 4: pre-populate ctx.interp_type_defs at init so
        // precomp eval (which clones Values and looks up nested struct/enum
        // defs by name) sees a populated registry; interpret_units later
        // re-registers with the same value, which is idempotent.
        _tdv : Dynamic = malloc(I64.size())
        write_ptr(_tdv, stmt.child(0))
        ctx.interp_type_defs.set(own sname.clone(), own _tdv)
        return 0
    case:
        UNREACHABLE(__LOC__)
        return 0
    }
}

// Best-effort field type name at initer time.  Fields with an
// explicit annotation use it directly; otherwise infer from the
// default value (literal -> primitive, `T()` ctor -> T).  Returns
// "" when nothing usable is available.
priv field_inferred_type_name := func(fd: Declaration) returns Str {
    if fd.explicit_type.len().gt(0) { return fd.explicit_type.clone() }
    if is_null(fd.default_value) { return "" }
    ref def_val : Expr = fd.default_value
    switch def_val.node_type {
    case NodeType.Literal(Literal.Num):  return "I64"
    case NodeType.Literal(Literal.Bool): return "Bool"
    case NodeType.Literal(Literal.Str):  return "Str"
    case NodeType.FCall:
        if def_val.children.len().eq(0) { return "" }
        ref callee : Expr = def_val.child(0)
        switch callee.node_type {
        case NodeType.Ident(cn): return ident_name(cn)
        case:
        }
    case:
    }
    return ""
}

// A type is "value-copy safe" -- i.e. a shallow byte-copy is
// semantically equivalent to its `.clone()` method -- when its
// underlying Type is a primitive (including aliases), a function
// pointer, a struct whose non-ref fields are all value-copy-safe, or
// an enum whose payload variants (if any) are all value-copy-safe.
// The auto-gen struct clone uses this to skip the `.clone()` wrap
// around POD fields: passing `self.x` directly works because the
// containing ctor's NamedArg slot will value-copy.  Ref fields are
// non-owning pointer bytes -- value-copying them is correct (the
// auto-gen clone's Ref branch already does exactly that), so they
// don't disqualify the containing struct.
priv is_pod_type_for_clone := func(type_name: Str, scope: TypeScope) returns Bool {
    if type_name.len().eq(0) { return false }
    t := type_from_name_init(type_name, scope)
    if is_primitive(t) { return true }
    if t.is(Type.FuncPtr) { return true }
    if is_null(scope) { return false }
    ref sdef : Expr = scope.get_struct(type_name)
    if is_null(sdef) { return false }
    switch sdef.node_type {
    case NodeType.StructDef(sdd):
        if sdd.fields.len().eq(0) { return false }
        for fd : Declaration in sdd.fields {
            if fd.own_type.is(OwnType.Own) { return false }
            if fd.own_type.is(OwnType.Ref) { continue }
            ftn := field_inferred_type_name(fd)
            if is_pod_type_for_clone(ftn, scope).not() { return false }
        }
        return true
    case NodeType.EnumDef(edd):
        for j in 0..edd.variants.len() {
            idx := j.to_i64()
            if edd.payload_types.has(idx) {
                ref pt : Str = edd.payload_types[idx]
                if pt.len().gt(0).and(is_pod_type_for_clone(pt, scope).not()) { return false }
            }
        }
        return true
    case:
    }
    return false
}

gen_struct_clone_delete_for_stmt := func(stmt: Expr, scope: TypeScope) {
    if stmt.node_type.is(NodeType.Decl).not() { return }
    if stmt.child(0).node_type.is(NodeType.StructDef).not() { return }

    mut sname := ""
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        sname = sdecl.name
    case:
        UNREACHABLE(__LOC__)
        return
    }
    if sname.eq("Dynamic") { return }

    ref sdef : Expr = stmt.child(0)
    switch sdef.node_type {
    case NodeType.StructDef(sdd):
        mut has_clone := false
        mut has_delete := false
        mut has_hash := false
        for d_j : Declaration in sdd.ns_decls {
            ref fd : Declaration = d_j
            if fd.name.eq("clone") { has_clone = true }
            if fd.name.eq("delete") { has_delete = true }
            if fd.name.eq("hash") { has_hash = true }
        }

        if has_clone.not() {
            field_names := Vec.new(Str)
            field_refs := Vec.new(I32)
            for d_j : Declaration in sdd.fields {
                ref fd : Declaration = d_j
                field_names.push(own fd.name.clone())
                mut ref_flag : I32 = 0
                if fd.own_type.is(OwnType.Ref) {
                    ref_flag = 1
                } else if fd.own_type.is(OwnType.Own).not().and(is_pod_type_for_clone(field_inferred_type_name(fd), scope)) {
                    // POD field: value-copy is the clone, so pass
                    // directly and skip the wasteful `.clone()` wrap.
                    // Uses field_inferred_type_name so that
                    // `mut x := 0` (no explicit annotation) also
                    // benefits -- inference picks I64 from the
                    // LiteralNum default value.  Own-typed fields are
                    // excluded: their value-copy aliases the heap
                    // payload.  FuncPtr fields fall under is_pod
                    // (a function pointer is just a pointer value).
                    ref_flag = 1
                }
                field_refs.push(own ref_flag)
            }

            mut func_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
            if field_names.len().eq(0) {
                mut ctor := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col)
                mut ctor_name := Expr.new(ident_node(sname), stmt.line, stmt.col)
                ctor.add_child(own ctor_name)

                mut ret := Expr.new(NodeType.Return, stmt.line, stmt.col)
                ret.add_child(own ctor)
                func_body.add_child(own ret)
            } else {
                mut ctor := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col)
                mut ctor_name := Expr.new(ident_node(sname), stmt.line, stmt.col)
                ctor.add_child(own ctor_name)

                for j in 0..field_names.len() {
                    ref fname : Str = field_names[j]
                    ref fref : I32 = field_refs[j]

                    mut self_id := Expr.new(ident_node("self"), stmt.line, stmt.col)
                    // NodeType.FieldAccess/NamedArg's constructors Str_clone their
                    // payload internally, so an outer fname.clone() at the call
                    // site is a redundant alloc whose wrapper Str leaks if the
                    // asap delete misses it. Pass the borrowed `fname` directly.
                    mut field_acc := Expr.new(field_access_node(fname), stmt.line, stmt.col)
                    field_acc.add_child(own self_id)

                    mut named := Expr.new(NodeType.NamedArg(fname.clone()), stmt.line, stmt.col)
                    if fref.eq(1) {
                        named.add_child(own field_acc)
                    } else {
                        mut clone_call := make_method_call_fcall(own field_acc, "clone", stmt.line, stmt.col)
                        named.add_child(own clone_call)
                    }
                    ctor.add_child(own named)
                }

                mut ret := Expr.new(NodeType.Return, stmt.line, stmt.col)
                ret.add_child(own ctor)
                func_body.add_child(own ret)
            }

            mut func_decl := FunctionDef(auto_generated = true)
            func_decl.func_type = FuncType.Func
            mut self_pname := "self"
            if field_names.len().eq(0) { self_pname = "_self" }
            func_decl.params.push(own Declaration(name = self_pname, explicit_type = sname.clone(), til_type = til_type_from_explicit_type(sname), own_type = OwnType.Ref))
            func_decl.return_type = sname.clone()
            func_decl.variadic_index = -1
            func_decl.kwargs_index = -1

            mut func_def := Expr.new(NodeType.FuncDef(func_decl), stmt.line, stmt.col)
            func_def.add_child(own func_body)

            sdd.ns_decls.push(own Declaration(name = "clone", default_value = func_def))
        }

        if has_delete.not() {
            // POD shortcut: when every field is value-copy-safe per
            // is_pod_type_for_clone, no field needs deep cleanup --
            // the per-field `.delete(false)` calls would all bottom
            // out in no-ops -- so emit just the `if call_free: free`
            // tail and skip the field loop entirely.  Saves both
            // compile-time codegen and runtime call frames per POD
            // struct destruction.
            pod_no_field_deletes := is_pod_type_for_clone(sname, scope)
            del_field_names := Vec.new(Str)
            del_field_owns := Vec.new(Bool)
            if pod_no_field_deletes.not() {
                for d_j : Declaration in sdd.fields {
                    ref fd : Declaration = d_j
                    if fd.own_type.is(OwnType.Ref) { continue }
                    if fd.explicit_type.len().gt(0).and(type_from_name_init(fd.explicit_type, scope).is(Type.FuncPtr)) {
                        continue
                    }
                    del_field_names.push(own fd.name.clone())
                    if fd.own_type.is(OwnType.Own) {
                        del_field_owns.push(own true)
                    } else {
                        del_field_owns.push(own false)
                    }
                }
            }

            mut proc_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
            for j in 0..del_field_names.len() {
                ref fname : Str = del_field_names[j]
                ref fown : Bool = del_field_owns[j]
                mut self_id := Expr.new(ident_node("self"), stmt.line, stmt.col)
                mut field_acc := Expr.new(field_access_node(fname), stmt.line, stmt.col)
                field_acc.add_child(own self_id)

                mut del_acc := Expr.new(field_access_node("delete"), stmt.line, stmt.col)
                del_acc.add_child(own field_acc)
                mut del_call := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col)
                set_own_arg(del_call, 0) // signal UFCS own for self arg
                del_call.add_child(own del_acc)

                mut cf_lit := Expr.new(NodeType.Literal(Literal.Bool(fown)), stmt.line, stmt.col)
                del_call.add_child(own cf_lit)
                proc_body.add_child(own del_call)
            }

            mut cond := Expr.new(ident_node("call_free"), stmt.line, stmt.col)
            mut then_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
            mut free_call := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col)
            mut free_id := Expr.new(ident_node("free"), stmt.line, stmt.col)
            free_call.add_child(own free_id)
            mut self_arg := Expr.new(ident_node("self"), stmt.line, stmt.col)
            set_own_arg(free_call, free_call.children.len())
            free_call.add_child(own self_arg)
            then_body.add_child(own free_call)
            mut if_node := Expr.new(NodeType.If, stmt.line, stmt.col)
            if_node.add_child(own cond)
            if_node.add_child(own then_body)
            proc_body.add_child(own if_node)

            mut proc_decl := FunctionDef(auto_generated = true)
            proc_decl.func_type = FuncType.Func
            proc_decl.params.push(own Declaration(name = "self", explicit_type = sname.clone(), til_type = til_type_from_explicit_type(sname), own_type = OwnType.Own))
            // Issue #223: call_free is a primitive (Bool), so emit it as a
            // plain borrowed param (Ref) and let step-1 auto-shallow normalize
            // it to value -- same as a hand-written delete. (An explicit Shallow
            // here would trip the step-2 redundant-shallow check.)
            proc_decl.params.push(own Declaration(name = "call_free", explicit_type = "Bool", til_type = Type.Bool, own_type = OwnType.Ref, default_value = Expr.new(NodeType.Literal(Literal.Bool(true)), stmt.line, stmt.col)))
            proc_decl.variadic_index = -1
            proc_decl.kwargs_index = -1

            mut proc_def := Expr.new(NodeType.FuncDef(proc_decl), stmt.line, stmt.col)
            proc_def.add_child(own proc_body)

            sdd.ns_decls.push(own Declaration(name = "delete", default_value = proc_def))
        }

        // Issue #214 follow-up: auto-generate `hash(self, hasher)` ONLY
        // when every field is shallow (no own / no ref). Any field that
        // owns or borrows heap data means the in-struct bytes lie about
        // identity -- a bytewise hash of the struct would key on
        // pointer addresses rather than content -- so we leave the
        // method out and let the type's author write a content-aware
        // one (Str.hash is the canonical example). HashMap.new will
        // then panic on dyn_has_method when the type is used as a key.
        if has_hash.not() {
            mut autogen_hash := true
            for d_j : Declaration in sdd.fields {
                if d_j.own_type.is(OwnType.Own).or(d_j.own_type.is(OwnType.Ref)) {
                    autogen_hash = false
                }
            }
            if autogen_hash {
                // Body: return hasher(self, <total_struct_size>)
                // Emit the size as a literal because <sname>.size()
                // would resolve through the namespace and the call's
                // return type can come back as U64 instead of USize
                // when the size method isn't visible yet at this
                // initer pass; and self.size() trips UFCS into trying
                // to pass self where the no-arg size() expects none.
                // sdd.total_struct_size is already set by the earlier
                // layout-computation pass.
                sz_text := sdd.total_struct_size.to_str()

                mut hash_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
                mut size_lit := Expr.new(literal_num_node(sz_text), stmt.line, stmt.col)

                mut hasher_id := Expr.new(ident_node("hasher"), stmt.line, stmt.col)
                mut self_arg := Expr.new(ident_node("self"), stmt.line, stmt.col)
                mut hasher_call := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col)
                hasher_call.add_child(own hasher_id)
                hasher_call.add_child(own self_arg)
                hasher_call.add_child(own size_lit)

                mut ret := Expr.new(NodeType.Return, stmt.line, stmt.col)
                ret.add_child(own hasher_call)
                hash_body.add_child(own ret)

                mut hash_decl := FunctionDef(auto_generated = true)
                hash_decl.func_type = FuncType.Func
                hash_decl.params.push(own Declaration(name = "self", explicit_type = sname.clone(), til_type = til_type_from_explicit_type(sname), own_type = OwnType.Ref))
                hash_decl.params.push(own Declaration(name = "hasher", explicit_type = "HashFn", til_type = Type.FuncPtr, own_type = OwnType.Ref))
                hash_decl.return_type = "U64"
                hash_decl.variadic_index = -1
                hash_decl.kwargs_index = -1

                mut hash_def := Expr.new(NodeType.FuncDef(hash_decl), stmt.line, stmt.col)
                hash_def.add_child(own hash_body)

                sdd.ns_decls.push(own Declaration(name = "hash", default_value = hash_def))
            }
        }
    case:
        UNREACHABLE(__LOC__)
    }
}

generate_missing_struct_clones_and_deletes := func(program: Expr, scope: TypeScope) {
    for stmt : Expr in program.children {
        gen_struct_clone_delete_for_stmt(stmt, scope)
    }
}

register_enum_definition := proc(ctx: Context, stmt: Expr, scope: TypeScope) returns I32 {
    switch stmt.node_type {
    case NodeType.Decl(edecl):
        ename := edecl.name

        existing_find := scope.find(ename)
        switch existing_find {
        case ScopeFind.Found(existing):
            if is_null(existing.struct_def).not() {
                println(
                    ctx.path, ":", stmt.line.to_str(), ":", stmt.col.to_str(),
                    ": error: enum '", ename, "' already declared at ",
                    existing.path, ":", existing.line.to_str(), ":", existing.col.to_str(),
                )
                return 1
            }
        case:
        }

        scope.set(ename, Type.Enum(ename.clone()), FuncType.None, false, ctx.path, stmt.line, stmt.col, false, OwnType.Shallow)
        ref mut b : TypeBinding = scope.get_binding(ename)
        b.struct_def = stmt.child(0)
        b.is_priv = edecl.is_priv
        b.orig_name = edecl.orig_name.clone()
        // Issue #147 step 4: pre-populate ctx.interp_type_defs (see
        // register_struct_def_for_stmt for rationale).
        _tdv : Dynamic = malloc(I64.size())
        write_ptr(_tdv, stmt.child(0))
        ctx.interp_type_defs.set(own ename.clone(), own _tdv)
        return 0
    case:
        UNREACHABLE(__LOC__)
        return 0
    }
}

collect_enum_variants := func(enum_def: Expr, mut variant_names: Vec, mut variant_types: Vec, mut has_payloads: Bool) {
    switch enum_def.node_type {
    case NodeType.EnumDef(edd):
        has_payloads = edd.payload_types.len().gt(0)
        for j in 0..edd.variants.len() {
            ref vn : Str = edd.variants[j]
            variant_names.push(own vn.clone())
            idx := j.to_i64()
            if edd.payload_types.has(idx) {
                ref pt : Str = edd.payload_types[idx]
                variant_types.push(own pt.clone())
            } else {
                variant_types.push(own "")
            }
        }
    case:
        UNREACHABLE(__LOC__)
    }
}

priv generate_enum_variant_constructors := func(enum_def: Expr, ename: Str, line: U32, col: U32, variant_names: Vec, variant_types: Vec, has_payloads: Bool, scope: TypeScope) {
    switch enum_def.node_type {
    case NodeType.EnumDef(evc_edd):
        if has_payloads.not() {
            for j in 0..variant_names.len() {
                ref vname : Str = variant_names[j]
                mut lit := Expr.new(literal_num_node(j.to_str()), line, col)
                evc_edd.ns_decls.push(own Declaration(name = vname.clone(), default_value = lit))
            }
            return
        }

        for j in 0..variant_names.len() {
            mut func_decl := FunctionDef(auto_generated = true, is_enum_variant_ctor = true)
            func_decl.func_type = FuncType.ExtFunc
            ref vtype : Str = variant_types[j]
            if vtype.len().gt(0) {
                mut payload_own_type := OwnType.Own
                resolved := type_from_name_init(vtype, scope)
                if is_primitive(resolved) { payload_own_type = OwnType.Ref }
                if vtype.eq("Dynamic") { payload_own_type = OwnType.Ref }
                if resolved.is(Type.FuncPtr) { payload_own_type = OwnType.Ref }
                if vtype.starts_with("_Fn_") { payload_own_type = OwnType.Ref }
                param := Declaration(name = "val", explicit_type = vtype.clone(), til_type = til_type_from_explicit_type(vtype), own_type = payload_own_type)
                func_decl.params.push(own param)
            }
            func_decl.return_type = ename.clone()
            func_decl.variadic_index = -1
            func_decl.kwargs_index = -1

            mut func_def := Expr.new(NodeType.FuncDef(func_decl), line, col)
            mut func_body := Expr.new(NodeType.Body, line, col)
            func_def.add_child(own func_body)

            ref vname : Str = variant_names[j]
            evc_edd.ns_decls.push(own Declaration(name = vname.clone(), default_value = func_def))
        }
    case:
        UNREACHABLE(__LOC__)
    }
}

priv generate_enum_is_method := func(enum_def: Expr, ename: Str, line: U32, col: U32) {
    mut func_body := Expr.new(NodeType.Body, line, col)
    mut is_id := Expr.new(ident_node("is"), line, col)
    mut self_id := Expr.new(ident_node("self"), line, col)
    mut other_id := Expr.new(ident_node("other"), line, col)
    mut is_call := Expr.new(NodeType.FCall(FCallData()), line, col)
    is_call.add_child(own is_id)
    is_call.add_child(own self_id)
    is_call.add_child(own other_id)
    mut ret := Expr.new(NodeType.Return, line, col)
    ret.add_child(own is_call)
    func_body.add_child(own ret)

    mut func_decl := FunctionDef(auto_generated = true)
    func_decl.func_type = FuncType.Func
    self_param := Declaration(name = "self", explicit_type = ename.clone(), til_type = til_type_from_explicit_type(ename), own_type = OwnType.Ref)
    other_param := Declaration(name = "other", explicit_type = ename.clone(), til_type = til_type_from_explicit_type(ename), own_type = OwnType.Ref)
    func_decl.params.push(own self_param)
    func_decl.params.push(own other_param)
    func_decl.return_type = "Bool"
    func_decl.variadic_index = -1
    func_decl.kwargs_index = -1

    mut func_def := Expr.new(NodeType.FuncDef(func_decl), line, col)
    func_def.add_child(own func_body)

    switch enum_def.node_type {
    case NodeType.EnumDef(eis_edd):
        eis_edd.ns_decls.push(own Declaration(name = "is", default_value = func_def))
    case:
        UNREACHABLE(__LOC__)
    }
}

generate_enum_eq_method := func(enum_def: Expr, ename: Str, line: U32, col: U32, variant_names: Vec, variant_types: Vec, scope: TypeScope) {
    mut func_body := Expr.new(NodeType.Body, line, col)
    for j in 0..variant_names.len() {
        ref vn : Str = variant_names[j]
        mut is_call := make_is_tag_check_fcall("self", ename, vn, line, col)

        mut then_body := Expr.new(NodeType.Body, line, col)

        ref vtype : Str = variant_types[j]
        if vtype.len().gt(0) {
            is_funcsig := type_from_name_init(vtype, scope).is(Type.FuncPtr)

            mut is_call2 := make_is_tag_check_fcall("other", ename, vn, line, col)
            mut not_call := make_method_call_fcall(own is_call2, "not", line, col)

            mut ret_false := Expr.new(NodeType.Return, line, col)
            mut false_lit := Expr.new(NodeType.Literal(Literal.Bool(false)), line, col)
            ret_false.add_child(own false_lit)
            mut guard_body := Expr.new(NodeType.Body, line, col)
            guard_body.add_child(own ret_false)
            mut guard_if := Expr.new(NodeType.If, line, col)
            guard_if.add_child(own not_call)
            guard_if.add_child(own guard_body)
            then_body.add_child(own guard_if)

            if is_funcsig {
                mut ret_true := Expr.new(NodeType.Return, line, col)
                mut true_lit := Expr.new(NodeType.Literal(Literal.Bool(true)), line, col)
                ret_true.add_child(own true_lit)
                then_body.add_child(own ret_true)
            } else {
                mut self_arg := Expr.new(ident_node("self"), line, col)
                then_body.add_child(own make_payload_ref_decl(own self_arg, "_sp", vtype, line, col, false))
                mut other_arg := Expr.new(ident_node("other"), line, col)
                then_body.add_child(own make_payload_ref_decl(own other_arg, "_op", vtype, line, col, false))

                mut sp_id := Expr.new(ident_node("_sp"), line, col)
                mut eq_call := make_method_call_fcall(own sp_id, "eq", line, col)
                mut op_id := Expr.new(ident_node("_op"), line, col)
                eq_call.add_child(own op_id)

                mut ret_eq := Expr.new(NodeType.Return, line, col)
                ret_eq.add_child(own eq_call)
                then_body.add_child(own ret_eq)
            }
        } else {
            mut is_call3 := make_is_tag_check_fcall("other", ename, vn, line, col)
            mut ret := Expr.new(NodeType.Return, line, col)
            ret.add_child(own is_call3)
            then_body.add_child(own ret)
        }

        mut if_node := Expr.new(NodeType.If, line, col)
        if_node.add_child(own is_call)
        if_node.add_child(own then_body)
        func_body.add_child(own if_node)
    }

    mut ret_false := Expr.new(NodeType.Return, line, col)
    mut false_lit := Expr.new(NodeType.Literal(Literal.Bool(false)), line, col)
    ret_false.add_child(own false_lit)
    func_body.add_child(own ret_false)

    mut fdecl := FunctionDef(auto_generated = true)
    fdecl.func_type = FuncType.Func
    fdecl.params.push(own Declaration(name = "self", explicit_type = ename.clone(), til_type = til_type_from_explicit_type(ename), own_type = OwnType.Ref))
    fdecl.params.push(own Declaration(name = "other", explicit_type = ename.clone(), til_type = til_type_from_explicit_type(ename), own_type = OwnType.Ref))
    fdecl.return_type = "Bool"
    fdecl.variadic_index = -1
    fdecl.kwargs_index = -1

    mut fdef := Expr.new(NodeType.FuncDef(fdecl), line, col)
    fdef.add_child(own func_body)

    switch enum_def.node_type {
    case NodeType.EnumDef(eeq_edd):
        eeq_edd.ns_decls.push(own Declaration(name = "eq", default_value = fdef))
    case:
        UNREACHABLE(__LOC__)
    }
}

generate_enum_delete_method := func(enum_def: Expr, ename: Str, line: U32, col: U32, variant_names: Vec, variant_types: Vec, has_payloads: Bool, scope: TypeScope) {
    mut proc_body := Expr.new(NodeType.Body, line, col)
    if has_payloads {
        for j in 0..variant_names.len() {
            ref vn : Str = variant_names[j]
            ref vtype : Str = variant_types[j]
            if vtype.len().eq(0) { continue }
            if vtype.eq("Dynamic") { continue }
            if type_from_name_init(vtype, scope).is(Type.FuncPtr) { continue }

            mut is_call := make_is_tag_check_fcall("self", ename, vn, line, col)

            mut then_body := Expr.new(NodeType.Body, line, col)

            mut type_id := Expr.new(ident_node(vtype), line, col)
            set_expr_til_type(type_id, type_from_name_init(vtype, scope))
            mut del_acc := Expr.new(field_access_node("delete"), line, col)
            del_acc.add_child(own type_id)
            mut del_call := Expr.new(NodeType.FCall(FCallData()), line, col)
            del_call.add_child(own del_acc)

            mut self_arg := Expr.new(ident_node("self"), line, col)
            mut gc := make_get_payload_fcall(own self_arg, type_from_name_init(vtype, scope), line, col)
            set_own_arg(del_call, del_call.children.len())
            del_call.add_child(own gc)

            mut false_lit := Expr.new(NodeType.Literal(Literal.Bool(false)), line, col)
            del_call.add_child(own false_lit)
            then_body.add_child(own del_call)

            mut if_node2 := Expr.new(NodeType.If, line, col)
            if_node2.add_child(own is_call)
            if_node2.add_child(own then_body)
            proc_body.add_child(own if_node2)
        }
    }

    mut cond := Expr.new(ident_node("call_free"), line, col)
    mut then_body := Expr.new(NodeType.Body, line, col)
    mut free_call := Expr.new(NodeType.FCall(FCallData()), line, col)
    mut free_id := Expr.new(ident_node("free"), line, col)
    free_call.add_child(own free_id)
    mut self_arg := Expr.new(ident_node("self"), line, col)
    set_own_arg(free_call, free_call.children.len())
    free_call.add_child(own self_arg)
    then_body.add_child(own free_call)
    mut if_node := Expr.new(NodeType.If, line, col)
    if_node.add_child(own cond)
    if_node.add_child(own then_body)
    proc_body.add_child(own if_node)

    mut default_true := Expr.new(NodeType.Literal(Literal.Bool(true)), line, col)

    mut fdecl := FunctionDef(auto_generated = true)
    fdecl.func_type = FuncType.Func
    fdecl.params.push(own Declaration(name = "self", explicit_type = ename.clone(), til_type = til_type_from_explicit_type(ename), own_type = OwnType.Own))
    // Issue #223: call_free is a primitive (Bool) -> emit a plain borrowed
    // param (Ref) and let step-1 auto-shallow normalize it to value, matching
    // a hand-written delete. (An explicit Shallow trips the step-2 check.)
    fdecl.params.push(own Declaration(name = "call_free", explicit_type = "Bool", til_type = Type.Bool, own_type = OwnType.Ref, default_value = default_true.clone()))
    fdecl.variadic_index = -1
    fdecl.kwargs_index = -1

    mut fdef := Expr.new(NodeType.FuncDef(fdecl), line, col)
    fdef.add_child(own proc_body)

    switch enum_def.node_type {
    case NodeType.EnumDef(edel_edd):
        edel_edd.ns_decls.push(own Declaration(name = "delete", default_value = fdef))
    case:
        UNREACHABLE(__LOC__)
    }
}

generate_enum_to_str_method := func(enum_def: Expr, ename: Str, line: U32, col: U32, variant_names: Vec, variant_types: Vec, has_payloads: Bool, scope: TypeScope) {
    mut func_body := Expr.new(NodeType.Body, line, col)
    for j in 0..variant_names.len() {
        ref vn : Str = variant_names[j]
        ref vtype : Str = variant_types[j]

        if has_payloads {
            mut is_call := make_is_tag_check_fcall("self", ename, vn, line, col)

            mut then_body := Expr.new(NodeType.Body, line, col)
            if vtype.len().gt(0).and(type_from_name_init(vtype, scope).is(Type.FuncPtr)) {
                ret_text := format(vn, "(func)")
                mut ret_str := Expr.new(NodeType.Literal(Literal.Str(ret_text)), line, col)
                mut ret := Expr.new(NodeType.Return, line, col)
                ret.add_child(own ret_str)
                then_body.add_child(own ret)
            } else if vtype.len().gt(0) {
                pn := format("_p_", vtype, "_", j.to_str())
                mut self_arg := Expr.new(ident_node("self"), line, col)
                then_body.add_child(own make_payload_ref_decl(own self_arg, pn, vtype, line, col, false))

                mut fmt_call := Expr.new(NodeType.FCall(FCallData()), line, col)
                mut fmt_id := Expr.new(ident_node("format"), line, col)
                fmt_call.add_child(own fmt_id)

                prefix_text := format(vn, "(")
                mut prefix := Expr.new(NodeType.Literal(Literal.Str(prefix_text)), line, col)
                fmt_call.add_child(own prefix)

                mut p_id := Expr.new(ident_node(pn), line, col)
                if vtype.eq("Str") {
                    // Payload is already Str -- format() takes Str
                    // variadics, so an extra .to_str() round-trip would
                    // just trip typer's redundant-conversion check.
                    fmt_call.add_child(own p_id)
                } else {
                    mut tostr_call := make_method_call_fcall(own p_id, "to_str", line, col)
                    fmt_call.add_child(own tostr_call)
                }

                mut suffix := Expr.new(NodeType.Literal(Literal.Str(")")), line, col)
                fmt_call.add_child(own suffix)

                mut ret := Expr.new(NodeType.Return, line, col)
                ret.add_child(own fmt_call)
                then_body.add_child(own ret)
            } else {
                mut ret_str := Expr.new(NodeType.Literal(Literal.Str(vn.clone())), line, col)
                mut ret := Expr.new(NodeType.Return, line, col)
                ret.add_child(own ret_str)
                then_body.add_child(own ret)
            }

            mut if_node := Expr.new(NodeType.If, line, col)
            if_node.add_child(own is_call)
            if_node.add_child(own then_body)
            func_body.add_child(own if_node)
        } else {
            mut self_id := Expr.new(ident_node("self"), line, col)
            mut eq_call := make_method_call_fcall(own self_id, "eq", line, col)

            mut ename_id := Expr.new(ident_node(ename), line, col)
            mut var_acc := Expr.new(field_access_node(vn), line, col)
            var_acc.add_child(own ename_id)
            eq_call.add_child(own var_acc)

            mut ret_str := Expr.new(NodeType.Literal(Literal.Str(vn.clone())), line, col)
            mut ret := Expr.new(NodeType.Return, line, col)
            ret.add_child(own ret_str)
            mut then_body := Expr.new(NodeType.Body, line, col)
            then_body.add_child(own ret)

            mut if_node := Expr.new(NodeType.If, line, col)
            if_node.add_child(own eq_call)
            if_node.add_child(own then_body)
            func_body.add_child(own if_node)
        }
    }

    mut unk := Expr.new(NodeType.Literal(Literal.Str("unknown")), line, col)
    mut ret_unk := Expr.new(NodeType.Return, line, col)
    ret_unk.add_child(own unk)
    func_body.add_child(own ret_unk)

    mut fdecl := FunctionDef(auto_generated = true)
    fdecl.func_type = FuncType.Func
    fdecl.params.push(own Declaration(name = "self", explicit_type = ename.clone(), til_type = til_type_from_explicit_type(ename), own_type = OwnType.Ref))
    fdecl.return_type = "Str"
    fdecl.variadic_index = -1
    fdecl.kwargs_index = -1

    mut fdef := Expr.new(NodeType.FuncDef(fdecl), line, col)
    fdef.add_child(own func_body)

    switch enum_def.node_type {
    case NodeType.EnumDef(ets_edd):
        ets_edd.ns_decls.push(own Declaration(name = "to_str", default_value = fdef))
    case:
        UNREACHABLE(__LOC__)
    }
}

generate_enum_clone_method := func(enum_def: Expr, ename: Str, line: U32, col: U32, variant_names: Vec, variant_types: Vec, has_payloads: Bool, scope: TypeScope) {
    mut func_body := Expr.new(NodeType.Body, line, col)
    // Tag-only enums (no variant carries a payload) need an if-guard
    // for every variant so the auto-gen body always reads ~self~ at
    // least once -- otherwise check_unused_params rejects the
    // generated clone for a single-variant enum, where the existing
    // "last variant" branch below would otherwise emit just an
    // unconditional return. The trailing UNREACHABLE/return after
    // the loop satisfies C's -Wreturn-type without changing
    // observable behaviour (the enum is exhaustive).
    guard_every := has_payloads.not()
    for j in 0..variant_names.len() {
        ref vname : Str = variant_names[j]

        mut ename_id := Expr.new(ident_node(ename), line, col)
        mut ctor_acc := Expr.new(field_access_node(vname), line, col)
        ctor_acc.add_child(own ename_id)

        mut ctor_expr := Expr.new(NodeType.Literal(Literal.Null), line, col)
        mut pd := Expr.new(NodeType.Body, line, col)
        mut has_pd := false
        ref vtype : Str = variant_types[j]
        if vtype.len().gt(0) {
            pn := format("_clone_payload_", vname, "_", j.to_str())

            mut self_arg := Expr.new(ident_node("self"), line, col)
            pd = make_payload_ref_decl(own self_arg, pn, vtype, line, col, false)
            has_pd = true

            mut ctor_call := Expr.new(NodeType.FCall(FCallData()), line, col)
            ctor_call.add_child(own ctor_acc)
            mut p_id := Expr.new(ident_node(pn), line, col)
            // Issue #109: variant ctor payload param is Own for compound
            // types -- a clone() body produces a fresh enum with its own
            // owned payload, so deep-clone the extracted payload before
            // the ctor call. Primitives / Dynamic / FuncSig stay plain.
            resolved_pc := type_from_name_init(vtype, scope)
            payload_needs_clone := is_primitive(resolved_pc).not()
                .and(vtype.eq("Dynamic").not())
                .and(resolved_pc.is(Type.FuncPtr).not())
                .and(vtype.starts_with("_Fn_").not())
            if payload_needs_clone {
                mut clone_call := make_method_call_fcall(own p_id, "clone", line, col)
                ctor_call.add_child(own clone_call)
            } else {
                ctor_call.add_child(own p_id)
            }
            ctor_expr = ctor_call
        } else {
            ctor_expr = ctor_acc
        }

        mut ret := Expr.new(NodeType.Return, line, col)
        ret.add_child(own ctor_expr)

        emit_guard := guard_every.or(j.lt(variant_names.len().sub(1)))
        if emit_guard {
            mut cond := Expr.new(NodeType.Literal(Literal.Null), line, col)
            if has_payloads {
                cond = make_is_tag_check_fcall("self", ename, vname, line, col)
            } else {
                mut self_id := Expr.new(ident_node("self"), line, col)
                mut cond_call := make_method_call_fcall(own self_id, "eq", line, col)

                mut en2 := Expr.new(ident_node(ename), line, col)
                mut va2 := Expr.new(field_access_node(vname), line, col)
                va2.add_child(own en2)
                cond_call.add_child(own va2)
                cond = cond_call
            }

            mut then_body := Expr.new(NodeType.Body, line, col)
            if has_pd {
                then_body.add_child(own pd.clone())
            }
            then_body.add_child(own ret)

            mut if_node := Expr.new(NodeType.If, line, col)
            if_node.add_child(own cond)
            if_node.add_child(own then_body)
            func_body.add_child(own if_node)
        } else {
            if has_pd {
                func_body.add_child(own pd.clone())
            }
            func_body.add_child(own ret)
        }
    }
    if guard_every {
        ref first_vname : Str = variant_names[0]
        // ~__LOC__~ is a parser-time directive; we're past parse, so
        // emit a synthetic loc string directly.
        loc_text := format(ename, ".clone:", line.to_str(), ":", col.to_str())
        mut unr_id := Expr.new(ident_node("UNREACHABLE"), line, col)
        mut loc_lit := Expr.new(NodeType.Literal(Literal.Str(loc_text)), line, col)
        mut unr_call := Expr.new(NodeType.FCall(FCallData()), line, col)
        unr_call.add_child(own unr_id)
        unr_call.add_child(own loc_lit)
        func_body.add_child(own unr_call)

        mut tail_ename_id := Expr.new(ident_node(ename), line, col)
        mut tail_ctor := Expr.new(field_access_node(first_vname), line, col)
        tail_ctor.add_child(own tail_ename_id)
        mut tail_ret := Expr.new(NodeType.Return, line, col)
        tail_ret.add_child(own tail_ctor)
        func_body.add_child(own tail_ret)
    }

    mut fdecl := FunctionDef(auto_generated = true)
    fdecl.func_type = FuncType.Func
    fdecl.params.push(own Declaration(name = "self", explicit_type = ename.clone(), til_type = til_type_from_explicit_type(ename), own_type = OwnType.Ref))
    fdecl.return_type = ename.clone()
    fdecl.variadic_index = -1
    fdecl.kwargs_index = -1

    mut fdef := Expr.new(NodeType.FuncDef(fdecl), line, col)
    fdef.add_child(own func_body)

    switch enum_def.node_type {
    case NodeType.EnumDef(ecl_edd2):
        ecl_edd2.ns_decls.push(own Declaration(name = "clone", default_value = fdef))
    case:
        UNREACHABLE(__LOC__)
    }
}

register_enum_def_for_stmt := proc(ctx: Context, stmt: Expr, scope: TypeScope) returns I32 {
    if stmt.node_type.is(NodeType.Decl).not() { return 0 }
    if stmt.child(0).node_type.is(NodeType.EnumDef).not() { return 0 }
    return register_enum_definition(ctx, stmt, scope)
}

gen_enum_nonclone_methods_for_stmt := func(stmt: Expr, scope: TypeScope) {
    if stmt.node_type.is(NodeType.Decl).not() { return }
    if stmt.child(0).node_type.is(NodeType.EnumDef).not() { return }

    mut ename := ""
    switch stmt.node_type {
    case NodeType.Decl(edecl):
        ename = edecl.name
    case:
        UNREACHABLE(__LOC__)
        return
    }
    line := stmt.line
    col := stmt.col

    variant_names := Vec.new(Str)
    variant_types := Vec.new(Str)
    mut has_payloads := false
    collect_enum_variants(stmt.child(0), variant_names, variant_types, has_payloads)
    generate_enum_variant_constructors(stmt.child(0), ename, line, col, variant_names, variant_types, has_payloads, scope)

    mut has_is := false
    mut has_eq := false
    mut has_delete := false
    mut has_to_str := false
    switch stmt.child(0).node_type {
    case NodeType.EnumDef(ens_edd):
        for d_j : Declaration in ens_edd.ns_decls {
            ref fdecl : Declaration = d_j
            if fdecl.name.eq("is") { has_is = true }
            if fdecl.name.eq("eq") { has_eq = true }
            if fdecl.name.eq("delete") { has_delete = true }
            if fdecl.name.eq("to_str") { has_to_str = true }
        }
    case:
        UNREACHABLE(__LOC__)
    }

    if has_is.not() {
        generate_enum_is_method(stmt.child(0), ename, line, col)
    }
    if has_eq.not() {
        generate_enum_eq_method(stmt.child(0), ename, line, col, variant_names, variant_types, scope)
    }
    if has_delete.not() {
        generate_enum_delete_method(stmt.child(0), ename, line, col, variant_names, variant_types, has_payloads, scope)
    }
    if has_to_str.not() {
        generate_enum_to_str_method(stmt.child(0), ename, line, col, variant_names, variant_types, has_payloads, scope)
    }

    Vec.delete(own variant_names, true)
    Vec.delete(own variant_types, true)
}

register_enum_and_gen_nonclone_methods_for_stmt := proc(ctx: Context, stmt: Expr, scope: TypeScope) returns I32 {
    reg_errors := register_enum_def_for_stmt(ctx, stmt, scope)
    if reg_errors.gt(0) { return reg_errors }
    gen_enum_nonclone_methods_for_stmt(stmt, scope)
    return 0
}

register_enums_and_generate_nonclone_methods := proc(ctx: Context, program: Expr, scope: TypeScope) returns I32 {
    mut errors : I32 = 0
    for stmt : Expr in program.children {
        errors = errors.add(register_enum_and_gen_nonclone_methods_for_stmt(ctx, stmt, scope))
    }
    return errors
}

gen_missing_enum_clone_for_stmt := func(stmt: Expr, scope: TypeScope) {
    if stmt.node_type.is(NodeType.Decl).not() { return }
    if stmt.child(0).node_type.is(NodeType.EnumDef).not() { return }

    mut ename := ""
    switch stmt.node_type {
    case NodeType.Decl(edecl):
        ename = edecl.name
    case:
        UNREACHABLE(__LOC__)
        return
    }
    line := stmt.line
    col := stmt.col
    mut has_clone := false
    switch stmt.child(0).node_type {
    case NodeType.EnumDef(ecl_edd):
        for d_j : Declaration in ecl_edd.ns_decls {
            ref fdecl : Declaration = d_j
            if fdecl.name.eq("clone") {
                has_clone = true
                break
            }
        }
    case:
        UNREACHABLE(__LOC__)
    }
    if has_clone.not() {
        variant_names := Vec.new(Str)
        variant_types := Vec.new(Str)
        mut has_payloads := false
        collect_enum_variants(stmt.child(0), variant_names, variant_types, has_payloads)
        generate_enum_clone_method(stmt.child(0), ename, line, col, variant_names, variant_types, has_payloads, scope)
        Vec.delete(own variant_names, true)
        Vec.delete(own variant_types, true)
    }
}

generate_missing_enum_clones := func(program: Expr, scope: TypeScope) {
    for stmt : Expr in program.children {
        gen_missing_enum_clone_for_stmt(stmt, scope)
    }
}

register_funcsig_alias_for_stmt := func(ctx: Context, stmt: Expr, scope: TypeScope) {
    if is_func_decl(stmt).not() { return }
    if stmt.child(0).children.len().neq(0) { return }
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        scope.set(sdecl.name, Type.FuncPtr, FuncType.None, false, ctx.path, stmt.line, stmt.col, false, OwnType.Shallow)
        ref mut fb : TypeBinding = scope.get_binding(sdecl.name)
        fb.func_def = stmt.child(0)
    case:
        UNREACHABLE(__LOC__)
    }
}

register_funcsig_aliases := func(ctx: Context, program: Expr, scope: TypeScope) {
    for stmt : Expr in program.children {
        register_funcsig_alias_for_stmt(ctx, stmt, scope)
    }
}

register_type_alias_for_stmt := func(ctx: Context, stmt: Expr, scope: TypeScope) {
    if stmt.node_type.is(NodeType.Decl).not() { return }
    ref rhs : Expr = stmt.child(0)
    mut target_name := ""
    switch rhs.node_type {
    case NodeType.Ident(tn):
        target_name = ident_name(tn)
    case:
        return
    }
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        if scope.find(sdecl.name).is(ScopeFind.Found) { return }
        find := scope.find(target_name)
        switch find {
        case ScopeFind.Found(target):
            if is_null(target.struct_def).and(target.is_builtin.not()) {
                if is_null(target.func_def) {
                    return
                }
                if target.func_def.children.len().neq(0) {
                    return
                }
            }
            scope.set(sdecl.name, target.type, target.func_type, false, ctx.path, stmt.line, stmt.col, false, OwnType.Shallow)
            ref mut ab : TypeBinding = scope.get_binding(sdecl.name)
            ab.struct_def = target.struct_def
            ab.func_def = target.func_def
            ab.is_builtin = target.is_builtin
            ab.is_type_alias = true
            if target.alias_target.is_empty() {
                ab.alias_target = target_name
            } else {
                ab.alias_target = target.alias_target
            }
        case:
            // Target not in scope yet. Only register when the target name
            // is a builtin primitive (e.g. `USize := U32` declared above
            // u32.til's import). Extending this to user-defined types
            // (Custom) is unsafe because we cannot tell at this point
            // whether the target is a type, a value, or an ALL_CAPS
            // constant (CamelCase heuristic doesn't work). The Found
            // arm above handles user-defined types when the target file
            // was already init'd. #165.
            til_type := til_type_from_explicit_type(target_name)
            if til_type.is(Type.Unknown) { return }
            if til_type.is(Type.Custom) { return }
            scope.set(sdecl.name, til_type, FuncType.None, false, ctx.path, stmt.line, stmt.col, false, OwnType.Shallow)
            ref mut ab : TypeBinding = scope.get_binding(sdecl.name)
            ab.is_type_alias = true
            ab.alias_target = target_name
        }
    case:
        UNREACHABLE(__LOC__)
    }
}

register_type_aliases := func(ctx: Context, program: Expr, scope: TypeScope) {
    for stmt : Expr in program.children {
        register_type_alias_for_stmt(ctx, stmt, scope)
    }
}

register_top_level_value_for_stmt := func(ctx: Context, stmt: Expr, scope: TypeScope) {
    if stmt.node_type.is(NodeType.Decl).not() { return }
    ref rhs : Expr = stmt.child(0)
    if rhs.node_type.is(NodeType.FuncDef).or(rhs.node_type.is(NodeType.StructDef)).or(rhs.node_type.is(NodeType.EnumDef)) {
        return
    }
    if rhs.node_type.is(NodeType.Ident) {
        switch stmt.node_type {
        case NodeType.Decl(sdecl0):
            if sdecl0.explicit_type.len().eq(0) {
                switch rhs.node_type {
                case NodeType.Ident(rhs_name):
                    if type_from_name_init(ident_name(rhs_name), scope).is(Type.Unknown).not() {
                        return
                    }
                case:
                }
            }
        case:
        }
    }

    mut t := Type.Unknown
    if infer_top_level_decl_type(stmt, scope, t).not() { return }
    if t.is(Type.Unknown) { return }

    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        scope.set(sdecl.name, t, FuncType.None, sdecl.is_mut, ctx.path, stmt.line, stmt.col, false, OwnType.Shallow)
        ref mut tlv_b : TypeBinding = scope.get_binding(sdecl.name)
        tlv_b.is_priv = sdecl.is_priv
        tlv_b.orig_name = sdecl.orig_name.clone()
    case:
        UNREACHABLE(__LOC__)
    }
}

register_top_level_values := func(ctx: Context, program: Expr, scope: TypeScope) {
    for stmt : Expr in program.children {
        register_top_level_value_for_stmt(ctx, stmt, scope)
    }
}

register_function_def_for_stmt := func(ctx: Context, stmt: Expr, scope: TypeScope) {
    if stmt.node_type.is(NodeType.Decl).not() { return }
    ref def : Expr = stmt.child(0)
    if def.node_type.is(NodeType.FuncDef).not() { return }

    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        if def.children.len().eq(0) {
            scope.set(sdecl.name, Type.FuncPtr, FuncType.None, false, ctx.path, stmt.line, stmt.col, false, OwnType.Shallow)
            ref mut fb : TypeBinding = scope.get_binding(sdecl.name)
            fb.func_def = stmt.child(0)
            fb.is_priv = sdecl.is_priv
            fb.orig_name = sdecl.orig_name.clone()
            return
        }

        if sdecl.explicit_type.len().gt(0) {
            fs_find := scope.find(sdecl.explicit_type)
            switch fs_find {
            case ScopeFind.Found(fsb):
                if is_null(fsb.func_def).not() {
                    if fsb.func_def.children.len().eq(0) {
                        ref sig : Expr = fsb.func_def
                        switch def.node_type {
                        case NodeType.FuncDef(fdef):
                            switch sig.node_type {
                            case NodeType.FuncDef(sigdef):
                                if fdef.params.len().neq(sigdef.params.len()) {
                                    panic(
                                        __LOC__,
                                        ctx.path, ":", stmt.line.to_str(), ":", stmt.col.to_str(),
                                        ": error: '", sdecl.name, "' expects ", fdef.params.len().to_str(),
                                        " params but FuncSig '", sdecl.explicit_type, "' has ", sigdef.params.len().to_str(),
                                    )
                                }
                                fdef.func_type = sigdef.func_type
                                for j in 0..sigdef.params.len() {
                                    ref mut dp : Declaration = fdef.params[j]
                                    ref sp : Declaration = sigdef.params[j]
                                    dp.explicit_type = sp.explicit_type
                                    dp.til_type = sp.til_type.clone()
                                    dp.is_mut = sp.is_mut
                                    dp.own_type = sp.own_type
                                }
                                fdef.return_type = sigdef.return_type
                                fdef.return_own_type = sigdef.return_own_type
                                sdecl.explicit_type = ""
                                sdecl.til_type = Type.Unknown
                            case:
                                UNREACHABLE(__LOC__)
                            }
                        case:
                            UNREACHABLE(__LOC__)
                        }
                    }
                }
            case:
            }
        }

        switch def.node_type {
        case NodeType.FuncDef(fdef):
            ft := fdef.func_type
            mut rt := Type.None
            if fdef.return_type.len().gt(0) {
                rt = init_type_from_explicit_type(fdef.return_type, scope)
            }
            scope.set(sdecl.name, rt, ft, false, ctx.path, stmt.line, stmt.col, false, OwnType.Shallow)
            ref mut fb : TypeBinding = scope.get_binding(sdecl.name)
            fb.func_def = stmt.child(0)
            fb.is_priv = sdecl.is_priv
            fb.orig_name = sdecl.orig_name.clone()
            if ft.is(FuncType.ExtFunc).or(ft.is(FuncType.ExtProc)) {
                fb.is_builtin = true
            }
        case:
            UNREACHABLE(__LOC__)
        }
    case:
        UNREACHABLE(__LOC__)
    }
}

register_function_definitions := func(ctx: Context, program: Expr, scope: TypeScope) {
    for stmt : Expr in program.children {
        register_function_def_for_stmt(ctx, stmt, scope)
    }
}

gen_struct_size_method_for_stmt := func(stmt: Expr) {
    if stmt.node_type.is(NodeType.Decl).not() { return }
    ref def : Expr = stmt.child(0)
    if def.node_type.is(NodeType.StructDef).not() { return }

    mut sname := ""
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        sname = sdecl.name
    case:
        UNREACHABLE(__LOC__)
        return
    }
    if sname.eq("Dynamic") { return }
    switch def.node_type {
    case NodeType.StructDef(sz_sdd):
        mut has_size := false
        for d_j : Declaration in sz_sdd.ns_decls {
            ref fd : Declaration = d_j
            if fd.name.eq("size") {
                has_size = true
                break
            }
        }
        if has_size { return }

        sz_text := sz_sdd.total_struct_size.to_str()

        mut func_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
        mut size_expr := Expr.new(literal_num_node(sz_text), stmt.line, stmt.col)
        mut ret := Expr.new(NodeType.Return, stmt.line, stmt.col)
        ret.add_child(own size_expr)
        func_body.add_child(own ret)

        mut func_decl := FunctionDef(auto_generated = true)
        func_decl.func_type = FuncType.Func
        func_decl.return_type = "USize"
        func_decl.variadic_index = -1
        func_decl.kwargs_index = -1

        mut func_def := Expr.new(NodeType.FuncDef(func_decl), stmt.line, stmt.col)
        func_def.add_child(own func_body)

        sz_sdd.ns_decls.push(own Declaration(name = "size", default_value = func_def))
    case:
        UNREACHABLE(__LOC__)
    }
}

generate_struct_size_methods := func(program: Expr) {
    for stmt : Expr in program.children {
        gen_struct_size_method_for_stmt(stmt)
    }
}

gen_enum_size_method_for_stmt := proc(stmt: Expr, scope: TypeScope) {
    if stmt.node_type.is(NodeType.Decl).not() { return }
    ref def : Expr = stmt.child(0)
    if def.node_type.is(NodeType.EnumDef).not() { return }

    mut sname := ""
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        sname = sdecl.name
    case:
        UNREACHABLE(__LOC__)
        return
    }
    if sname.eq("Dynamic") { return }
    mut has_size := false
    ref size_ns : Vec = def_ns_decls(def)
    for d_j : Declaration in size_ns {
        ref fd : Declaration = d_j
        if fd.name.eq("size") {
            has_size = true
            break
        }
    }
    if has_size { return }

    sz_text := compute_enum_layout(def, scope).to_str()

    mut func_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
    mut size_expr := Expr.new(literal_num_node(sz_text), stmt.line, stmt.col)
    mut ret := Expr.new(NodeType.Return, stmt.line, stmt.col)
    ret.add_child(own size_expr)
    func_body.add_child(own ret)

    mut func_decl := FunctionDef(auto_generated = true)
    func_decl.func_type = FuncType.Func
    func_decl.return_type = "USize"
    func_decl.variadic_index = -1
    func_decl.kwargs_index = -1

    mut func_def := Expr.new(NodeType.FuncDef(func_decl), stmt.line, stmt.col)
    func_def.add_child(own func_body)

    switch def.node_type {
    case NodeType.EnumDef(esz_edd):
        esz_edd.ns_decls.push(own Declaration(name = "size", default_value = func_def))
    case:
        UNREACHABLE(__LOC__)
    }
}

generate_enum_size_methods := proc(program: Expr, scope: TypeScope) {
    for stmt : Expr in program.children {
        gen_enum_size_method_for_stmt(stmt, scope)
    }
}

gen_unity_derived_for_stmt := func(stmt: Expr) {
    if is_struct_or_enum(stmt).not() { return }
    ref def : Expr = stmt.child(0)

    mut sname := ""
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        sname = sdecl.name
    case:
        UNREACHABLE(__LOC__)
        return
    }
    if sname.eq("Dynamic") { return }

    mut has_add := false
    mut has_sub := false
    mut has_unity := false
    mut has_inc := false
    mut has_dec := false
    ref unity_ns : Vec = def_ns_decls(def)
    for d_j : Declaration in unity_ns {
        ref fd : Declaration = d_j
        if fd.name.eq("add") { has_add = true }
        if fd.name.eq("sub") { has_sub = true }
        if fd.name.eq("unity") { has_unity = true }
        if fd.name.eq("inc") { has_inc = true }
        if fd.name.eq("dec") { has_dec = true }
    }
    if has_unity.not() { return }

    for pass in 0..2 {
        mut method := "inc"
        mut op := "add"
        mut already_has := has_inc
        mut has_op := has_add
        if pass.eq(1) {
            method = "dec"
            op = "sub"
            already_has = has_dec
            has_op = has_sub
        }
        if already_has { continue }
        if has_op.not() { continue }

        mut self1 := Expr.new(ident_node("self"), stmt.line, stmt.col)
        mut self2 := Expr.new(ident_node("self"), stmt.line, stmt.col)

        mut unity_call := make_method_call_fcall(own self2, "unity", stmt.line, stmt.col)

        mut op_call := make_method_call_fcall(own self1, op, stmt.line, stmt.col)
        op_call.add_child(own unity_call)

        mut assign := Expr.new(NodeType.Assign(AssignData(name = "self")), stmt.line, stmt.col)
        assign.add_child(own op_call)

        mut proc_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
        proc_body.add_child(own assign)

        mut func_decl := FunctionDef(auto_generated = true)
        func_decl.func_type = FuncType.Func
        param := Declaration(name = "self", explicit_type = sname.clone(), til_type = til_type_from_explicit_type(sname), is_mut = true, own_type = OwnType.Ref)
        func_decl.params.push(own param)
        func_decl.variadic_index = -1
        func_decl.kwargs_index = -1

        mut func_def := Expr.new(NodeType.FuncDef(func_decl), stmt.line, stmt.col)
        func_def.add_child(own proc_body)

        switch def.node_type {
        case NodeType.StructDef(un_sdd):
            un_sdd.ns_decls.push(own Declaration(name = method.clone(), default_value = func_def))
        case NodeType.EnumDef(eu_edd):
            eu_edd.ns_decls.push(own Declaration(name = method.clone(), default_value = func_def))
        case:
            UNREACHABLE(__LOC__)
        }
    }
}

generate_size_methods := proc(program: Expr, scope: TypeScope) {
    generate_struct_size_methods(program)
    generate_enum_size_methods(program, scope)
}

gen_cmp_derived_for_stmt := func(stmt: Expr) {
    if is_struct_or_enum(stmt).not() { return }
    ref def : Expr = stmt.child(0)

    mut sname := ""
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        sname = sdecl.name
    case:
        UNREACHABLE(__LOC__)
        return
    }
    if sname.eq("Dynamic") { return }

    mut has_cmp := false
    mut has_eq := false
    mut has_neq := false
    mut has_lt := false
    mut has_gt := false
    mut has_lte := false
    mut has_gte := false
    ref cmp_ns : Vec = def_ns_decls(def)
    for d_j : Declaration in cmp_ns {
        ref fd : Declaration = d_j
        if fd.name.eq("cmp") { has_cmp = true }
        if fd.name.eq("eq") { has_eq = true }
        if fd.name.eq("neq") { has_neq = true }
        if fd.name.eq("lt") { has_lt = true }
        if fd.name.eq("gt") { has_gt = true }
        if fd.name.eq("lte") { has_lte = true }
        if fd.name.eq("gte") { has_gte = true }
    }
    if has_cmp.not() { return }

    if has_eq.not() {
        mut a_id := Expr.new(ident_node("a"), stmt.line, stmt.col)
        mut cmp_call := make_method_call_fcall(own a_id, "cmp", stmt.line, stmt.col)
        mut b_id := Expr.new(ident_node("b"), stmt.line, stmt.col)
        cmp_call.add_child(own b_id)
        mut eq_call := make_method_call_fcall(own cmp_call, "eq", stmt.line, stmt.col)
        mut zero := Expr.new(literal_num_node("0"), stmt.line, stmt.col)
        eq_call.add_child(own zero)
        mut ret := Expr.new(NodeType.Return, stmt.line, stmt.col)
        ret.add_child(own eq_call)
        mut func_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
        func_body.add_child(own ret)
        mut func_decl := FunctionDef(auto_generated = true)
        func_decl.func_type = FuncType.Func
        a_param := Declaration(name = "a", explicit_type = sname.clone(), til_type = til_type_from_explicit_type(sname), own_type = OwnType.Ref)
        b_param := Declaration(name = "b", explicit_type = sname.clone(), til_type = til_type_from_explicit_type(sname), own_type = OwnType.Ref)
        func_decl.params.push(own a_param)
        func_decl.params.push(own b_param)
        func_decl.return_type = "Bool"
        func_decl.variadic_index = -1
        func_decl.kwargs_index = -1
        mut func_def := Expr.new(NodeType.FuncDef(func_decl), stmt.line, stmt.col)
        func_def.add_child(own func_body)
        switch def.node_type {
        case NodeType.StructDef(cmp_sdd):
            cmp_sdd.ns_decls.push(own Declaration(name = "eq", default_value = func_def))
        case NodeType.EnumDef(ec_edd):
            ec_edd.ns_decls.push(own Declaration(name = "eq", default_value = func_def))
        case:
            UNREACHABLE(__LOC__)
        }
    }

    if has_lt.not() {
        mut a_id := Expr.new(ident_node("a"), stmt.line, stmt.col)
        mut cmp_call := make_method_call_fcall(own a_id, "cmp", stmt.line, stmt.col)
        mut b_id := Expr.new(ident_node("b"), stmt.line, stmt.col)
        cmp_call.add_child(own b_id)
        mut eq_call := make_method_call_fcall(own cmp_call, "eq", stmt.line, stmt.col)
        mut zero := Expr.new(literal_num_node("0"), stmt.line, stmt.col)
        mut neg1_call := make_method_call_fcall(own zero, "sub", stmt.line, stmt.col)
        mut one := Expr.new(literal_num_node("1"), stmt.line, stmt.col)
        neg1_call.add_child(own one)
        eq_call.add_child(own neg1_call)
        mut ret := Expr.new(NodeType.Return, stmt.line, stmt.col)
        ret.add_child(own eq_call)
        mut func_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
        func_body.add_child(own ret)
        mut func_decl := FunctionDef(auto_generated = true)
        func_decl.func_type = FuncType.Func
        a_param := Declaration(name = "a", explicit_type = sname.clone(), til_type = til_type_from_explicit_type(sname), own_type = OwnType.Ref)
        b_param := Declaration(name = "b", explicit_type = sname.clone(), til_type = til_type_from_explicit_type(sname), own_type = OwnType.Ref)
        func_decl.params.push(own a_param)
        func_decl.params.push(own b_param)
        func_decl.return_type = "Bool"
        func_decl.variadic_index = -1
        func_decl.kwargs_index = -1
        mut func_def := Expr.new(NodeType.FuncDef(func_decl), stmt.line, stmt.col)
        func_def.add_child(own func_body)
        switch def.node_type {
        case NodeType.StructDef(cmp_sdd):
            cmp_sdd.ns_decls.push(own Declaration(name = "lt", default_value = func_def))
        case NodeType.EnumDef(ec_edd):
            ec_edd.ns_decls.push(own Declaration(name = "lt", default_value = func_def))
        case:
            UNREACHABLE(__LOC__)
        }
    }

    if has_gt.not() {
        mut a_id := Expr.new(ident_node("a"), stmt.line, stmt.col)
        mut cmp_call := make_method_call_fcall(own a_id, "cmp", stmt.line, stmt.col)
        mut b_id := Expr.new(ident_node("b"), stmt.line, stmt.col)
        cmp_call.add_child(own b_id)
        mut eq_call := make_method_call_fcall(own cmp_call, "eq", stmt.line, stmt.col)
        mut one := Expr.new(literal_num_node("1"), stmt.line, stmt.col)
        eq_call.add_child(own one)
        mut ret := Expr.new(NodeType.Return, stmt.line, stmt.col)
        ret.add_child(own eq_call)
        mut func_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
        func_body.add_child(own ret)
        mut func_decl := FunctionDef(auto_generated = true)
        func_decl.func_type = FuncType.Func
        a_param := Declaration(name = "a", explicit_type = sname.clone(), til_type = til_type_from_explicit_type(sname), own_type = OwnType.Ref)
        b_param := Declaration(name = "b", explicit_type = sname.clone(), til_type = til_type_from_explicit_type(sname), own_type = OwnType.Ref)
        func_decl.params.push(own a_param)
        func_decl.params.push(own b_param)
        func_decl.return_type = "Bool"
        func_decl.variadic_index = -1
        func_decl.kwargs_index = -1
        mut func_def := Expr.new(NodeType.FuncDef(func_decl), stmt.line, stmt.col)
        func_def.add_child(own func_body)
        switch def.node_type {
        case NodeType.StructDef(cmp_sdd):
            cmp_sdd.ns_decls.push(own Declaration(name = "gt", default_value = func_def))
        case NodeType.EnumDef(ec_edd):
            ec_edd.ns_decls.push(own Declaration(name = "gt", default_value = func_def))
        case:
            UNREACHABLE(__LOC__)
        }
    }

    if has_neq.not() {
        mut a_id := Expr.new(ident_node("a"), stmt.line, stmt.col)
        mut eq_call := make_method_call_fcall(own a_id, "eq", stmt.line, stmt.col)
        mut b_id := Expr.new(ident_node("b"), stmt.line, stmt.col)
        eq_call.add_child(own b_id)
        mut not_call := make_method_call_fcall(own eq_call, "not", stmt.line, stmt.col)
        mut ret := Expr.new(NodeType.Return, stmt.line, stmt.col)
        ret.add_child(own not_call)
        mut func_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
        func_body.add_child(own ret)
        mut func_decl := FunctionDef(auto_generated = true)
        func_decl.func_type = FuncType.Func
        a_param := Declaration(name = "a", explicit_type = sname.clone(), til_type = til_type_from_explicit_type(sname), own_type = OwnType.Ref)
        b_param := Declaration(name = "b", explicit_type = sname.clone(), til_type = til_type_from_explicit_type(sname), own_type = OwnType.Ref)
        func_decl.params.push(own a_param)
        func_decl.params.push(own b_param)
        func_decl.return_type = "Bool"
        func_decl.variadic_index = -1
        func_decl.kwargs_index = -1
        mut func_def := Expr.new(NodeType.FuncDef(func_decl), stmt.line, stmt.col)
        func_def.add_child(own func_body)
        switch def.node_type {
        case NodeType.StructDef(cmp_sdd):
            cmp_sdd.ns_decls.push(own Declaration(name = "neq", default_value = func_def))
        case NodeType.EnumDef(ec_edd):
            ec_edd.ns_decls.push(own Declaration(name = "neq", default_value = func_def))
        case:
            UNREACHABLE(__LOC__)
        }
    }

    if has_lte.not() {
        mut a_id := Expr.new(ident_node("a"), stmt.line, stmt.col)
        mut gt_call := make_method_call_fcall(own a_id, "gt", stmt.line, stmt.col)
        mut b_id := Expr.new(ident_node("b"), stmt.line, stmt.col)
        gt_call.add_child(own b_id)
        mut not_call := make_method_call_fcall(own gt_call, "not", stmt.line, stmt.col)
        mut ret := Expr.new(NodeType.Return, stmt.line, stmt.col)
        ret.add_child(own not_call)
        mut func_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
        func_body.add_child(own ret)
        mut func_decl := FunctionDef(auto_generated = true)
        func_decl.func_type = FuncType.Func
        a_param := Declaration(name = "a", explicit_type = sname.clone(), til_type = til_type_from_explicit_type(sname), own_type = OwnType.Ref)
        b_param := Declaration(name = "b", explicit_type = sname.clone(), til_type = til_type_from_explicit_type(sname), own_type = OwnType.Ref)
        func_decl.params.push(own a_param)
        func_decl.params.push(own b_param)
        func_decl.return_type = "Bool"
        func_decl.variadic_index = -1
        func_decl.kwargs_index = -1
        mut func_def := Expr.new(NodeType.FuncDef(func_decl), stmt.line, stmt.col)
        func_def.add_child(own func_body)
        switch def.node_type {
        case NodeType.StructDef(cmp_sdd):
            cmp_sdd.ns_decls.push(own Declaration(name = "lte", default_value = func_def))
        case NodeType.EnumDef(ec_edd):
            ec_edd.ns_decls.push(own Declaration(name = "lte", default_value = func_def))
        case:
            UNREACHABLE(__LOC__)
        }
    }

    if has_gte.not() {
        mut a_id := Expr.new(ident_node("a"), stmt.line, stmt.col)
        mut lt_call := make_method_call_fcall(own a_id, "lt", stmt.line, stmt.col)
        mut b_id := Expr.new(ident_node("b"), stmt.line, stmt.col)
        lt_call.add_child(own b_id)
        mut not_call := make_method_call_fcall(own lt_call, "not", stmt.line, stmt.col)
        mut ret := Expr.new(NodeType.Return, stmt.line, stmt.col)
        ret.add_child(own not_call)
        mut func_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
        func_body.add_child(own ret)
        mut func_decl := FunctionDef(auto_generated = true)
        func_decl.func_type = FuncType.Func
        a_param := Declaration(name = "a", explicit_type = sname.clone(), til_type = til_type_from_explicit_type(sname), own_type = OwnType.Ref)
        b_param := Declaration(name = "b", explicit_type = sname.clone(), til_type = til_type_from_explicit_type(sname), own_type = OwnType.Ref)
        func_decl.params.push(own a_param)
        func_decl.params.push(own b_param)
        func_decl.return_type = "Bool"
        func_decl.variadic_index = -1
        func_decl.kwargs_index = -1
        mut func_def := Expr.new(NodeType.FuncDef(func_decl), stmt.line, stmt.col)
        func_def.add_child(own func_body)
        switch def.node_type {
        case NodeType.StructDef(cmp_sdd):
            cmp_sdd.ns_decls.push(own Declaration(name = "gte", default_value = func_def))
        case NodeType.EnumDef(ec_edd):
            ec_edd.ns_decls.push(own Declaration(name = "gte", default_value = func_def))
        case:
            UNREACHABLE(__LOC__)
        }
    }
}

compute_struct_layout := proc(mut struct_def: Expr, scope: TypeScope) {
    switch struct_def.node_type {
    case NodeType.StructDef(struct_meta):
        if struct_meta.total_struct_size.gt(0) { return }

        mut offset : I32 = 0
        mut max_align : I32 = 1

        for mut fd : Declaration in struct_meta.fields {
            mut fsz : I32 = 0
            mut falign : I32 = 0

            if fd.own_type.is(OwnType.Shallow).not() {
                fsz = 8
                falign = 8

                mut ftype := fd.explicit_type
                if ftype.len().eq(0) {
                    if is_null(fd.default_value).not() {
                        ref def_val : Expr = fd.default_value
                        if def_val.node_type.is(NodeType.FCall) {
                            if def_val.children.len().gt(0) {
                                ref callee : Expr = def_val.child(0)
                                switch callee.node_type {
                                case NodeType.Ident(_ft):
                                    ftype = ident_name(_ft)
                                case:
                                }
                            }
                        }
                        if ftype.len().gt(0) {
                            fd.explicit_type = ftype
                            fd.til_type = til_type_from_explicit_type(fd.explicit_type)
                        }
                    }
                }

            } else {
                mut ftype := fd.explicit_type
                if ftype.len().eq(0) {
                    if is_null(fd.default_value).not() {
                        ref def_val : Expr = fd.default_value
                        if def_val.node_type.is_literal_num() { ftype = "I64" }
                        else if def_val.node_type.is_literal_str() { ftype = "Str" }
                        else if def_val.node_type.is_literal_bool() { ftype = "Bool" }
                        else if til_type_name(expr_til_type(def_val)).len().gt(0) { ftype = til_type_name(expr_til_type(def_val)) }
                        else if def_val.node_type.is(NodeType.FCall) {
                            if def_val.children.len().gt(0) {
                                ref callee : Expr = def_val.child(0)
                                switch callee.node_type {
                                case NodeType.Ident(_ft):
                                    ftype = ident_name(_ft)
                                case NodeType.FieldAccess:
                                    if callee.children.len().gt(0) {
                                        ref type_node : Expr = callee.child(0)
                                        switch type_node.node_type {
                                        case NodeType.Ident(_ft):
                                            ftype = ident_name(_ft)
                                        case:
                                        }
                                    }
                                case:
                                }
                            }
                        } else if def_val.node_type.is(NodeType.FieldAccess) {
                            if def_val.children.len().gt(0) {
                                ref type_node : Expr = def_val.child(0)
                                switch type_node.node_type {
                                case NodeType.Ident(_ft):
                                    ftype = ident_name(_ft)
                                case:
                                }
                            }
                        }
                        if ftype.len().gt(0) {
                            fd.explicit_type = ftype
                            fd.til_type = til_type_from_explicit_type(fd.explicit_type)
                        }
                    }
                }

                ref ab : TypeBinding = scope.get_binding(ftype)
                if is_null(ab).not() {
                    if ab.is_type_alias {
                        if ab.alias_target.is_empty().not() {
                            ftype = ab.alias_target
                            fd.explicit_type = ftype
                            fd.til_type = til_type_from_explicit_type(fd.explicit_type)
                        }
                    }
                }

                if ftype.len().eq(0) { fsz = 8; falign = 8 }
                else if ftype.eq("I64") { fsz = 8; falign = 8 }
                else if ftype.eq("U8") { fsz = 1; falign = 1 }
                else if ftype.eq("I8") { fsz = 1; falign = 1 }
                else if ftype.eq("I16") { fsz = 2; falign = 2 }
                else if ftype.eq("U16") { fsz = 2; falign = 2 }
                else if ftype.eq("I32") { fsz = 4; falign = 4 }
                else if ftype.eq("U32") { fsz = 4; falign = 4 }
                else if ftype.eq("Bool") { fsz = 1; falign = 1 }
                else if type_from_name_init(ftype, scope).is(Type.FuncPtr) { fsz = 8; falign = 8 }
                else {
                    ref nested_def : Expr = scope.get_struct(ftype)
                    if is_null(nested_def).not().and(nested_def.node_type.is(NodeType.EnumDef)) {
                        fsz = compute_enum_layout(nested_def, scope)
                        if enum_has_payloads(nested_def) { falign = 8 } else { falign = 4 }
                    } else if is_null(nested_def).not() {
                        compute_struct_layout(nested_def, scope)
                        switch nested_def.node_type {
                        case NodeType.StructDef(nested_meta):
                            fsz = nested_meta.total_struct_size
                        case:
                            UNREACHABLE(__LOC__)
                        }
                        falign = 8
                    } else {
                        fsz = 8
                        falign = 8
                    }
                }
            }

            offset = align_up(offset, falign)
            fd.field_offset = offset
            fd.field_size = fsz
            if falign.gt(max_align) { max_align = falign }
            offset = offset.add(fsz)
        }

        struct_meta.total_struct_size = align_up(offset, max_align)
        if struct_meta.total_struct_size.eq(0) {
            struct_meta.total_struct_size = 1
        }
    case:
        UNREACHABLE(__LOC__)
    }
}

// Compute size and alignment for a TIL type name.
// For struct/enum payloads, recurses into compute_struct_layout / compute_enum_layout.
type_size_align := proc(ftype: Str, scope: TypeScope, mut sz: I32, mut al: I32) {
    if ftype.eq("I64") { sz = 8; al = 8; return }
    if ftype.eq("U64") { sz = 8; al = 8; return }
    if ftype.eq("F32") { sz = 4; al = 4; return }
    if ftype.eq("U8") { sz = 1; al = 1; return }
    if ftype.eq("I8") { sz = 1; al = 1; return }
    if ftype.eq("I16") { sz = 2; al = 2; return }
    if ftype.eq("U16") { sz = 2; al = 2; return }
    if ftype.eq("I32") { sz = 4; al = 4; return }
    if ftype.eq("U32") { sz = 4; al = 4; return }
    if ftype.eq("Bool") { sz = 1; al = 1; return }
    if ftype.eq("Dynamic") { sz = 8; al = 8; return }
    if type_from_name_init(ftype, scope).is(Type.FuncPtr) { sz = 8; al = 8; return }
    ref nested : Expr = scope.get_struct(ftype)
    if is_null(nested) { sz = 8; al = 8; return }
    switch nested.node_type {
    case NodeType.StructDef(_nm):
        compute_struct_layout(nested, scope)
        sz = _nm.total_struct_size
        al = 8
    case NodeType.EnumDef:
        sz = compute_enum_layout(nested, scope)
        al = 8
    case:
        sz = 8
        al = 8
    }
}

compute_enum_layout := proc(enum_def: Expr, scope: TypeScope) returns I32 {
    switch enum_def.node_type {
    case NodeType.EnumDef(edd):
        if edd.total_enum_size.gt(0) { return edd.total_enum_size }
        // Set sentinel before recursing to break self-referential cycles.
        edd.total_enum_size = 4

        mut max_payload_size : I32 = 0
        mut max_payload_align : I32 = 4
        for vi in 0..edd.variants.len() {
            vt := enum_variant_type(enum_def, vi.cast(I32))
            if vt.len().eq(0) { continue }
            mut psz : I32 = 0
            mut palign : I32 = 0
            type_size_align(vt, scope, psz, palign)
            if psz.gt(max_payload_size) { max_payload_size = psz }
            if palign.gt(max_payload_align) { max_payload_align = palign }
        }
        mut total : I32 = 4
        if max_payload_size.gt(0) {
            total = align_up(4, max_payload_align)
            total = total.add(max_payload_size)
        }
        total = align_up(total, max_payload_align)
        edd.total_enum_size = total
        return total
    case:
        UNREACHABLE(__LOC__)
        return 0
    }
}

// Issue #147 step 3: snapshot a struct's just-computed layout (AST fields
// already filled by compute_struct_layout) into ctx.struct_layouts.
// struct_name is set for fields whose type resolves to a non-primitive
// struct/enum via ctx.interp_type_defs, matching the population rule the
// removed Declaration.field_struct_def used.
// Issue #147 step 4: lookup helper for the struct/enum total size out of
// ctx.struct_layouts. Returns 0 when the name is unregistered (which
// downstream code already handles as "unknown size / fall back").
ctx_total_size := func(name: Str, ctx: Context) returns I32 {
    if name.len().eq(0) { return 0 }
    if ctx.struct_layouts.has(name).not() { return 0 }
    ref sl : StructLayout = ctx.struct_layouts[name]
    return sl.total_size
}

record_struct_layout := func(ctx: Context, name: Str, sdef: Expr) {
    switch sdef.node_type {
    case NodeType.StructDef(sm):
        mut sl := StructLayout(total_size = sm.total_struct_size)
        for fd : Declaration in sm.fields {
            mut flx := FieldLayout(offset = fd.field_offset, size = fd.field_size)
            if is_primitive(fd.til_type).not() {
                if is_null(lookup_interp_type_def(fd.explicit_type, ctx)).not() {
                    flx.struct_name = fd.explicit_type.clone()
                }
            }
            sl.fields.push(own flx)
        }
        ctx.struct_layouts.set(own name.clone(), own sl)
    case:
    }
}

record_enum_layout := func(ctx: Context, name: Str, edef: Expr) {
    switch edef.node_type {
    case NodeType.EnumDef(em):
        ctx.struct_layouts.set(own name.clone(), own StructLayout(total_size = em.total_enum_size))
    case:
    }
}

compute_all_struct_layouts := proc(program: Expr, scope: TypeScope) {
    for stmt : Expr in program.children {
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        if stmt.child(0).node_type.is(NodeType.StructDef).not() { continue }
        mut sname := ""
        switch stmt.node_type {
        case NodeType.Decl(_sd):
            sname = _sd.name
        case:
            UNREACHABLE(__LOC__)
            continue
        }
        if sname.eq("Dynamic") { continue }
        compute_struct_layout(stmt.child(0), scope)
    }
    for stmt : Expr in program.children {
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        if stmt.child(0).node_type.is(NodeType.EnumDef).not() { continue }
        compute_enum_layout(stmt.child(0), scope)
    }
}

infer_top_level_decl_type := func(stmt: Expr, scope: TypeScope, mut out_type: Type) returns Bool {
    ref rhs : Expr = stmt.child(0)
    out_type = Type.Unknown

    switch stmt.node_type {
    case NodeType.Decl(dd):
        if dd.explicit_type.len().gt(0) {
            out_type = init_type_from_explicit_type(dd.explicit_type, scope)
            return out_type.is(Type.Unknown).not()
        }
    case:
    }

    switch rhs.node_type {
    case NodeType.Literal(Literal.Num):
        out_type = Type.I64
        return true
    case NodeType.Literal(Literal.Bool):
        out_type = Type.Bool
        return true
    case NodeType.Literal(Literal.Str):
        out_type = Type.Struct("Str")
        return true
    case NodeType.Literal(Literal.Null):
        out_type = Type.Dynamic
        return true
    case NodeType.Ident(id):
        ref b : TypeBinding = scope.get_binding(ident_name(id))
        if is_null(b) { return false }
        out_type = b.type
        return out_type.is(Type.Unknown).not()
    case NodeType.FieldAccess:
        mut init_ns1 := false
        if rhs.children.len().gt(0) {
            ref _io1 : Expr = rhs.child(0)
            if _io1.node_type.is(NodeType.Ident) {
                if til_type_name(expr_til_type(_io1)).eq("StructDef").or(til_type_name(expr_til_type(_io1)).eq("EnumDef")) {
                    init_ns1 = true
                }
            }
        }
        if init_ns1.and(expr_til_type(rhs).is(Type.Enum)) {
            mut enum_name := ""
            if rhs.children.len().gt(0) {
                enum_name = til_type_name(expr_til_type(rhs.child(0)))
            }
            out_type = Type.Enum(enum_name.clone())
            return true
        }
        return false
    case NodeType.FCall:
        ref callee : Expr = rhs.child(0)
        switch callee.node_type {
        case NodeType.Ident(cn):
            if til_type_name(expr_til_type(rhs)).len().gt(0).and(ident_name(cn).eq(til_type_name(expr_til_type(rhs)))) {
                out_type = Type.Struct(til_type_name(expr_til_type(rhs)))
                return true
            }
            ref fb : TypeBinding = scope.get_binding(ident_name(cn))
            if is_null(fb) { return false }
            out_type = fb.type
            return out_type.is(Type.Unknown).not()
        case NodeType.FieldAccess:
            mut init_ns2 := false
            if callee.children.len().gt(0) {
                ref _io2 : Expr = callee.child(0)
                if _io2.node_type.is(NodeType.Ident) {
                    if til_type_name(expr_til_type(_io2)).eq("StructDef").or(til_type_name(expr_til_type(_io2)).eq("EnumDef")) {
                        init_ns2 = true
                    }
                }
            }
            if init_ns2.and(til_type_name(expr_til_type(rhs)).len().gt(0)).and(expr_til_type(rhs).is(Type.Enum)) {
                out_type = Type.Enum(til_type_name(expr_til_type(rhs)))
                return true
            }
            return false
        case:
            return false
        }
    case:
        return false
    }
}

init_declarations := proc(ctx: Context, program: Expr, scope: TypeScope) returns I32 {
    mut errors : I32 = 0

    // Single AST walk: register every type name in scope and bucket each Decl
    // into the list it needs. All cross-decl work (alias resolution, struct
    // layouts, size/derived/method generation, function-def and top-level
    // value registration) runs after the walk over the collected lists --
    // not over program.children -- so we never re-traverse the AST. We
    // store indices into program.children rather than the Expr nodes
    // themselves so the lists don't need to own the AST.
    struct_idxs := Vec.new(U32)
    enum_idxs := Vec.new(U32)
    alias_idxs := Vec.new(U32)
    func_idxs := Vec.new(U32)
    value_idxs := Vec.new(U32)
    for i in 0..program.children.len() {
        ref stmt : Expr = program.child(i)
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        ref rhs : Expr = stmt.child(0)
        if rhs.node_type.is(NodeType.StructDef) {
            errors = errors.add(register_struct_def_for_stmt(ctx, stmt, scope))
            struct_idxs.push(own i)
        } else if rhs.node_type.is(NodeType.EnumDef) {
            errors = errors.add(register_enum_def_for_stmt(ctx, stmt, scope))
            enum_idxs.push(own i)
        } else if rhs.node_type.is(NodeType.FuncDef) {
            if rhs.children.len().eq(0) {
                register_funcsig_alias_for_stmt(ctx, stmt, scope)
            } else {
                func_idxs.push(own i)
            }
        } else if rhs.node_type.is(NodeType.Ident) {
            alias_idxs.push(own i)
        } else {
            value_idxs.push(own i)
        }
    }

    // All type names are now in scope. Process the collected lists.
    for ei : U32 in enum_idxs {
        ref stmt : Expr = program.child(ei)
        gen_enum_nonclone_methods_for_stmt(stmt, scope)
        gen_missing_enum_clone_for_stmt(stmt, scope)
    }
    for si : U32 in struct_idxs {
        ref stmt : Expr = program.child(si)
        gen_struct_clone_delete_for_stmt(stmt, scope)
    }
    for ai : U32 in alias_idxs {
        ref stmt : Expr = program.child(ai)
        register_type_alias_for_stmt(ctx, stmt, scope)
    }
    // compute_struct_layout / compute_enum_layout and the layout-
    // dependent gen_*_size_method_for_stmt helpers moved into
    // type_decls_file (the typer's first sweep) as part of #147 step
    // 3-4 / #174 work.
    for fi : U32 in func_idxs {
        ref stmt : Expr = program.child(fi)
        register_function_def_for_stmt(ctx, stmt, scope)
    }
    for vi : U32 in value_idxs {
        ref stmt : Expr = program.child(vi)
        register_top_level_value_for_stmt(ctx, stmt, scope)
    }

    Vec.delete(own struct_idxs, true)
    Vec.delete(own enum_idxs, true)
    Vec.delete(own alias_idxs, true)
    Vec.delete(own func_idxs, true)
    Vec.delete(own value_idxs, true)
    return errors
}

// Issue #93: lift nested struct/enum/func definitions out of function
// bodies up to the program top level.
//
// Folded into init_declarations_unit's existing single AST walk: when
// that walk visits a top-level FuncDef-with-body, it calls
// init_lift_in_body on the body. Inner Decls whose RHS is StructDef,
// EnumDef, or FuncDef-with-body are mangled to `<parent>_<orig>`,
// appended to program.children, and replaced in the original body slot
// with an empty inner Body (no-op `{}` in C). References to the
// original name within the parent body (Ident, FieldAccess base,
// FCall callee, Decl explicit_type, FuncDef return_type and param
// types, struct field types, enum variant payload types) are
// rewritten in-place through a single recursive walk in
// init_rewrite_refs.
//
// The main init walk's while loop re-checks program.children.len()
// each iteration, so the lifted decls get registered by the same walk
// in subsequent iterations -- one walk does both jobs.
//
// ext_func / ext_proc forward declarations stay in place (they refer
// to externally-linked C symbols).

priv init_is_lift_target := func(stmt: Expr) returns Bool {
    if stmt.node_type.is(NodeType.Decl).not() { return false }
    if stmt.children.len().eq(0) { return false }
    ref rhs : Expr = stmt.child(0)
    if rhs.node_type.is(NodeType.StructDef) { return true }
    if rhs.node_type.is(NodeType.EnumDef) { return true }
    if rhs.node_type.is(NodeType.FuncDef) {
        if rhs.children.len().eq(0) { return false }
        switch rhs.node_type {
        case NodeType.FuncDef(rhs_fd):
            if rhs_fd.func_type.is(FuncType.ExtFunc) { return false }
            if rhs_fd.func_type.is(FuncType.ExtProc) { return false }
            return true
        case:
            return false
        }
    }
    return false
}

priv init_lookup_name := func(renamings: Map, name: Str) returns Str {
    if name.len().eq(0) { return "" }
    if renamings.has(name).not() { return "" }
    ref s : Str = renamings[name]
    return s.clone()
}

priv init_rename_ident_in_place := func(mut e: Expr, renamings: Map) {
    switch e.node_type {
    case NodeType.Ident(name):
        new_name := init_lookup_name(renamings, ident_name(name))
        if new_name.len().gt(0) {
            e.node_type = ident_node(new_name)
        }
    case NodeType.Assign(ad):
        // Assignments to a renamed top-level priv: `local_counter = ...`
        // stores the LHS name on AssignData, not as a child Ident, so the
        // generic Ident rename above misses it.
        new_name := init_lookup_name(renamings, ad.name)
        if new_name.len().gt(0) {
            ad.name = new_name.clone()
        }
    case:
    }
}

priv init_rename_decl_in_place := func(mut dd: Declaration, renamings: Map) {
    if dd.explicit_type.len().eq(0) { return }
    new_t := init_lookup_name(renamings, dd.explicit_type)
    if new_t.len().gt(0) {
        dd.explicit_type = new_t
    }
}

priv init_rewrite_refs := proc(mut e: Expr, renamings: Map) {
    if is_null(e) { return }
    init_rename_ident_in_place(e, renamings)
    // `for x : LocalInfo in xs { ... }` stores the loop's explicit type
    // on the ForIn node's payload as Type.Custom("LocalInfo") (read back
    // via expr_til_type). No Declaration is involved (parser.til:1428),
    // so init_rename_decl_in_place misses it; patch the Type.Custom
    // payload here.
    custom_t := expr_til_type(e)
    switch custom_t {
    case Type.Custom(custom_name):
        new_custom := init_lookup_name(renamings, custom_name)
        if new_custom.len().gt(0) {
            set_expr_til_type(e, Type.Custom(new_custom.clone()))
        }
    case:
    }
    switch e.node_type {
    case NodeType.Decl(dd):
        init_rename_decl_in_place(dd, renamings)
    case NodeType.FuncDef(fd):
        if fd.return_type.len().gt(0) {
            new_rt := init_lookup_name(renamings, fd.return_type)
            if new_rt.len().gt(0) {
                fd.return_type = new_rt
            }
        }
        for mut pd : Declaration in fd.params {
            init_rename_decl_in_place(pd, renamings)
            if is_null(pd.default_value).not() {
                init_rewrite_refs(pd.default_value, renamings)
            }
        }
    case NodeType.StructDef(sdd):
        for mut sf : Declaration in sdd.fields {
            init_rename_decl_in_place(sf, renamings)
            if is_null(sf.default_value).not() {
                init_rewrite_refs(sf.default_value, renamings)
            }
        }
        for mut nd : Declaration in sdd.ns_decls {
            init_rename_decl_in_place(nd, renamings)
            if is_null(nd.default_value).not() {
                init_rewrite_refs(nd.default_value, renamings)
            }
        }
    case NodeType.EnumDef(edd):
        for vi in 0..edd.variants.len() {
            vidx := vi.to_i64()
            if edd.payload_types.has(vidx).not() { continue }
            ref pt_old : Str = edd.payload_types[vidx]
            new_pt := init_lookup_name(renamings, pt_old)
            if new_pt.len().gt(0) {
                edd.payload_types.set(own vidx.clone(), own new_pt.clone())
            }
        }
        for mut nd : Declaration in edd.ns_decls {
            init_rename_decl_in_place(nd, renamings)
            if is_null(nd.default_value).not() {
                init_rewrite_refs(nd.default_value, renamings)
            }
        }
    case:
    }
    for i in 0..e.children.len() {
        ref mut c : Expr = e.child(i)
        init_rewrite_refs(c, renamings)
    }
}

priv init_lift_in_body := proc(mut body: Expr, parent_prefix: Str, mut top_level: Vec) {
    if is_null(body) { return }
    if body.node_type.is(NodeType.Body).not() { return }

    mut renamings := Map.new(Str, Str)
    mut lifted_indices := Vec.new(USize)

    for i in 0..body.children.len() {
        ref child : Expr = body.child(i)
        if init_is_lift_target(child).not() { continue }
        switch child.node_type {
        case NodeType.Decl(child_dd):
            mangled := parent_prefix.concat("_").concat(child_dd.name)
            renamings.set(own child_dd.name.clone(), own mangled.clone())
            child_dd.orig_name = child_dd.name.clone()
            child_dd.name = mangled.clone()
            child_dd.is_priv = true
            mut idx := i
            lifted_indices.push(own idx)
        case:
        }
    }

    if renamings.len().gt(0) {
        for i in 0..body.children.len() {
            ref mut c : Expr = body.child(i)
            init_rewrite_refs(c, renamings)
        }
    }

    for idx : USize in lifted_indices {
        ref mut slot : Expr = body.child(idx)
        switch slot.node_type {
        case NodeType.Decl(slot_dd):
            ref mut slot_rhs : Expr = slot.child(0)
            if slot_rhs.node_type.is(NodeType.FuncDef) {
                if slot_rhs.children.len().gt(0) {
                    ref mut fbody : Expr = slot_rhs.child(0)
                    init_lift_in_body(fbody, slot_dd.name, top_level)
                }
            } else if slot_rhs.node_type.is(NodeType.StructDef).or(slot_rhs.node_type.is(NodeType.EnumDef)) {
                init_lift_in_ns_decls(slot_rhs, slot_dd.name, top_level)
            }
            top_level.push(own slot.clone())
        case:
            UNREACHABLE(__LOC__)
        }
        mut empty_body := Expr.new(NodeType.Body, slot.line, slot.col)
        body.children.set(idx, own empty_body)
    }

    init_recurse_into_subbodies(body, parent_prefix, top_level)
}

priv init_lift_in_ns_decls := proc(mut def: Expr, parent_prefix: Str, mut top_level: Vec) {
    if is_null(def) { return }
    switch def.node_type {
    case NodeType.StructDef(ld_sdd):
        for mut nd : Declaration in ld_sdd.ns_decls {
            if is_null(nd.default_value) { continue }
            if nd.default_value.node_type.is(NodeType.FuncDef).not() { continue }
            if nd.default_value.children.len().eq(0) { continue }
            ref mut nbody : Expr = nd.default_value.child(0)
            init_lift_in_body(nbody, parent_prefix, top_level)
        }
    case NodeType.EnumDef(ld_edd):
        for mut nd : Declaration in ld_edd.ns_decls {
            if is_null(nd.default_value) { continue }
            if nd.default_value.node_type.is(NodeType.FuncDef).not() { continue }
            if nd.default_value.children.len().eq(0) { continue }
            ref mut nbody : Expr = nd.default_value.child(0)
            init_lift_in_body(nbody, parent_prefix, top_level)
        }
    case:
    }
}

priv init_recurse_into_subbodies := proc(mut body: Expr, parent_prefix: Str, mut top_level: Vec) {
    for i in 0..body.children.len() {
        ref mut c : Expr = body.child(i)
        init_recurse_into_expr(c, parent_prefix, top_level)
    }
}

priv init_recurse_into_expr := proc(mut e: Expr, parent_prefix: Str, mut top_level: Vec) {
    if is_null(e) { return }
    if e.node_type.is(NodeType.Body) {
        init_lift_in_body(e, parent_prefix, top_level)
        return
    }
    if e.node_type.is(NodeType.FuncDef) {
        if e.children.len().gt(0) {
            ref mut fbody : Expr = e.child(0)
            init_lift_in_body(fbody, parent_prefix, top_level)
        }
        return
    }
    for i in 0..e.children.len() {
        ref mut c : Expr = e.child(i)
        init_recurse_into_expr(c, parent_prefix, top_level)
    }
}

// Issue #57: macros returning `StructDef` / `EnumDef` / `FuncDef` act
// as generators -- `Pair := make_pair(I64)` should be equivalent to
// `Pair := struct { first: I64 = 0, second: I64 = 0 }`, and
// `add5 := make_adder(5)` to
// `add5 := func(x: I64) returns I64 { return x.add(5) }`. Mirrors
// rstil's macro-returns-StructDef path (precomp.rs ~309): scan top-level
// decls whose RHS is a call to a top-level macro returning a type-def or
// func-def, inline the macro body's return literal with the macro's
// parameters substituted out for the call-site args, and replace the
// Decl's RHS with the resulting struct/enum/func literal. The rest of
// the registration walk then treats the Decl like any other named def.
//
// Macro bodies are required to be a single `return <struct|enum|func
// literal>` statement; anything more complex isn't expanded here (a
// diagnostic is emitted later by the normal typer).
//
// The substitution map is param-name -> arg-expression (whole Expr).
// For a `T: Type` param the arg is an Ident (e.g. `I64`); for value
// params like `N: I64` the arg can be any expression (literal, ident,
// fcall). `init_substitute_idents` replaces the whole Expr when an Ident
// matches a substituted name, so an `Ident(N)` becomes a clone of the
// arg expression (e.g. `LiteralNum 5`). The explicit-type helpers only
// fire when the substitution is Ident-shaped (i.e. a type-param) -- a
// value-param substitution leaves explicit_type strings unchanged.
priv init_subst_ident_name := func(subs: Map, name: Str) returns Str {
    if subs.has(name).not() { return "" }
    ref repl : Expr = subs[name]
    switch repl.node_type {
    case NodeType.Ident(idn):
        return ident_name(idn).clone()
    case:
        return ""
    }
}

priv init_substitute_idents := func(mut e: Expr, subs: Map) {
    if is_null(e) { return }
    switch e.node_type {
    case NodeType.Ident(idn):
        nm := ident_name(idn)
        if subs.has(nm) {
            ref repl_expr : Expr = subs[nm]
            mut cloned := repl_expr.clone()
            move(e, cloned, Expr.size())
            // The replacement now occupies `e`; children of the original
            // Ident were none, so no further recursion at this node.
            return
        }
    case:
    }
    for mut c : Expr in e.children {
        init_substitute_idents(c, subs)
    }
}

// Helpers that take the StructDef / EnumDef directly (not via the
// switch-case destructure binding) so the typer carries the Map<I64,Str>
// type info into the payload-types subscript without the
// throws-inference mixing OutOfBounds (Vec) into KeyNotFound (Map).
priv init_subst_struct_params := func(mut sdef: StructDef, subs: Map) {
    for mut fd : Declaration in sdef.fields {
        new_type := init_subst_ident_name(subs, fd.explicit_type)
        if new_type.len().gt(0) {
            fd.explicit_type = new_type.clone()
            fd.til_type = til_type_from_explicit_type(fd.explicit_type)
        }
        if is_null(fd.default_value).not() {
            init_substitute_idents(fd.default_value, subs)
        }
    }
    for mut nd : Declaration in sdef.ns_decls {
        new_type := init_subst_ident_name(subs, nd.explicit_type)
        if new_type.len().gt(0) {
            nd.explicit_type = new_type.clone()
            nd.til_type = til_type_from_explicit_type(nd.explicit_type)
        }
        if is_null(nd.default_value).not() {
            init_substitute_idents(nd.default_value, subs)
        }
    }
}

priv init_subst_enum_params := func(mut edef: EnumDef, subs: Map) {
    for k in 0..edef.variants.len() {
        if edef.payload_types.has(k.to_i64()) {
            ref pt : Str = edef.payload_types[k.to_i64()]
            new_pt := init_subst_ident_name(subs, pt)
            if new_pt.len().gt(0) {
                edef.payload_types.set(own k.to_i64(), own new_pt.clone())
            }
        }
    }
    for mut nd : Declaration in edef.ns_decls {
        new_type := init_subst_ident_name(subs, nd.explicit_type)
        if new_type.len().gt(0) {
            nd.explicit_type = new_type.clone()
            nd.til_type = til_type_from_explicit_type(nd.explicit_type)
        }
        if is_null(nd.default_value).not() {
            init_substitute_idents(nd.default_value, subs)
        }
    }
}

priv init_subst_func_params := func(mut fdd: FunctionDef, subs: Map) {
    for mut pd : Declaration in fdd.params {
        new_type := init_subst_ident_name(subs, pd.explicit_type)
        if new_type.len().gt(0) {
            pd.explicit_type = new_type.clone()
            pd.til_type = til_type_from_explicit_type(pd.explicit_type)
        }
        if is_null(pd.default_value).not() {
            init_substitute_idents(pd.default_value, subs)
        }
    }
    new_ret := init_subst_ident_name(subs, fdd.return_type)
    if new_ret.len().gt(0) {
        fdd.return_type = new_ret.clone()
    }
}

priv init_substitute_type_params := func(mut def: Expr, subs: Map) {
    switch def.node_type {
    case NodeType.StructDef(sdd):
        init_subst_struct_params(sdd, subs)
    case NodeType.EnumDef(edd):
        init_subst_enum_params(edd, subs)
    case NodeType.FuncDef(fdd):
        init_subst_func_params(fdd, subs)
        // Walk the function body too, substituting Ident references to
        // type-params (e.g. T used inside expressions, struct/enum
        // literals nested in the body).
        if def.children.len().gt(0) {
            ref mut fnbody : Expr = def.child(0)
            init_substitute_idents(fnbody, subs)
        }
    case:
    }
}

priv init_expand_type_gen_macros := func(mut program: Expr) {
    // Build map of top-level macro defs returning a type-def metatype
    // (StructDef / EnumDef) or a FuncDef / FunctionDef (function
    // generator: rstil's macro-returns-FuncDef equivalent).
    mut macros := Map.new(Str, Expr)
    for stmt : Expr in program.children {
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        if stmt.children.len().eq(0) { continue }
        ref rhs : Expr = stmt.child(0)
        if rhs.node_type.is(NodeType.FuncDef).not() { continue }
        switch rhs.node_type {
        case NodeType.FuncDef(fd):
            if fd.func_type.is(FuncType.Macro).not() { continue }
            ret_ok := fd.return_type.eq("StructDef")
                .or(fd.return_type.eq("EnumDef"))
                .or(fd.return_type.eq("FuncDef"))
                .or(fd.return_type.eq("FunctionDef"))
            if ret_ok.not() { continue }
            switch stmt.node_type {
            case NodeType.Decl(dd):
                macros.set(own dd.name.clone(), own rhs.clone())
            case:
            }
        case:
        }
    }
    if macros.len().eq(0) { return }

    // Walk top-level decls, expand each `X := macroname(args)`.
    for i in 0..program.children.len() {
        ref mut stmt : Expr = program.child(i)
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        if stmt.children.len().eq(0) { continue }
        ref rhs : Expr = stmt.child(0)
        if rhs.node_type.is(NodeType.FCall).not() { continue }
        if rhs.children.len().lt(1.to_usize()) { continue }
        ref callee : Expr = rhs.child(0)
        if callee.node_type.is(NodeType.Ident).not() { continue }
        mut callee_name := ""
        switch callee.node_type {
        case NodeType.Ident(cn): callee_name = ident_name(cn)
        case:
        }
        if macros.has(callee_name).not() { continue }
        ref macro_fdef : Expr = macros[callee_name]
        if macro_fdef.children.len().eq(0) { continue }
        ref body : Expr = macro_fdef.child(0)
        if body.node_type.is(NodeType.Body).not() { continue }
        if body.children.len().neq(1.to_usize()) { continue }
        ref ret_stmt : Expr = body.child(0)
        if ret_stmt.node_type.is(NodeType.Return).not() { continue }
        if ret_stmt.children.len().eq(0) { continue }
        ref ret_val : Expr = ret_stmt.child(0)
        ret_val_ok := ret_val.node_type.is(NodeType.StructDef)
            .or(ret_val.node_type.is(NodeType.EnumDef))
            .or(ret_val.node_type.is(NodeType.FuncDef))
        if ret_val_ok.not() { continue }

        // Build param-name -> arg-expression substitution. Type-param args
        // are Idents (e.g. `I64`) and value-param args are arbitrary
        // expressions (literals, idents, fcalls); store the whole Expr so
        // init_substitute_idents can replace `Ident(N)` with the cloned
        // arg expression for value params, while
        // init_subst_ident_name still extracts the receiving type name for
        // explicit-type strings when the substitution is Ident-shaped.
        mut subs := Map.new(Str, Expr)
        switch macro_fdef.node_type {
        case NodeType.FuncDef(mfd):
            for j in 0..mfd.params.len() {
                if j.add(1.to_usize()).gte(rhs.children.len()) { break }
                ref param : Declaration = mfd.params[j]
                ref arg : Expr = rhs.child(j.add(1.to_usize()))
                subs.set(own param.name.clone(), own arg.clone())
            }
        case:
        }

        // Clone the return literal, substitute, replace Decl's RHS.
        mut cloned := ret_val.clone()
        init_substitute_type_params(cloned, subs)
        stmt.children.set(0.to_usize(), own cloned)
    }
}

// rstil-style unit initializer: index declarations for one file, but do not
// run global layout/method generation that must see the whole program.
init_declarations_unit := proc(path: Str, program: Expr, scope: TypeScope, ctx: Context) returns I32 {
    context_enter_file(ctx, path)
    mut errors : I32 = 0

    // Issue #57: expand `X := macroname(args)` where macroname is a
    // top-level macro returning StructDef/EnumDef -- inline the macro
    // body's return literal with type-params substituted, so X becomes a
    // normal named struct/enum decl for the registration walk below.
    init_expand_type_gen_macros(program)

    // Single AST walk: register every type name in scope (struct, enum,
    // funcsig) and bucket each remaining Decl's index for post-walk work.
    // Enum non-clone methods need scope to be populated before they can
    // generate eq/delete/to_str, so we delay them until after the walk.
    enum_idxs := Vec.new(U32)
    alias_idxs := Vec.new(U32)
    func_idxs := Vec.new(U32)
    value_idxs := Vec.new(U32)
    // Issue #93: nested struct/enum/func definitions inside a FuncDef
    // body are lifted to the program top level (with names mangled
    // `<parent>_<orig>`) inline during this walk. The lifted decls are
    // appended to program.children; the while loop re-checks
    // program.children.len() each iteration so they get registered by
    // the same walk without an extra pass.
    // Issue #93: nested struct/enum/func definitions inside a FuncDef
    // body are lifted to the program top level (with names mangled
    // `<parent>_<orig>`) inline during this walk. The lifted decls are
    // appended to program.children; the while loop re-checks
    // program.children.len() each iteration so they get registered by
    // the same walk without an extra pass.
    // Issue #93: nested struct/enum/func definitions inside a FuncDef
    // body are lifted to the program top level (with names mangled
    // `<parent>_<orig>`) before the registration walk. Lifted decls
    // are appended to program.children; the same walk below registers
    // them along with the original top-level decls. Splitting the
    // lift from the walk avoids mutating program.children while we
    // hold refs into it (which previously corrupted memory).
    mut nested_lifted := Vec.new(Expr)
    for li in 0..program.children.len() {
        ref lstmt : Expr = program.child(li)
        if lstmt.node_type.is(NodeType.Decl).not() { continue }
        if lstmt.children.len().eq(0) { continue }
        ref lrhs : Expr = lstmt.child(0)
        if lrhs.node_type.is(NodeType.FuncDef).not() { continue }
        if lrhs.children.len().eq(0) { continue }
        switch lrhs.node_type {
        case NodeType.FuncDef(lift_fd):
            if lift_fd.func_type.is(FuncType.ExtFunc) { continue }
            if lift_fd.func_type.is(FuncType.ExtProc) { continue }
        case:
            continue
        }
        switch lstmt.node_type {
        case NodeType.Decl(lift_dd):
            ref mut lbody : Expr = lrhs.child(0)
            init_lift_in_body(lbody, lift_dd.name, nested_lifted)
        case:
            UNREACHABLE(__LOC__)
        }
    }
    for l : Expr in nested_lifted {
        program.children.push(own l.clone())
    }

    // Rewrite every top-level `priv` decl (and the lifted-nested ones,
    // which the lift step above just marked priv) to a file-keyed C
    // symbol. Same in-file Ident references get rewritten alongside via
    // init_rewrite_refs, so the rest of the pipeline emits and links
    // distinct C functions for two files that happen to share a priv
    // identifier. The original user-facing name lives on dd.orig_name
    // for diagnostics.
    mut priv_renamings := Map.new(Str, Str)
    for pi in 0..program.children.len() {
        ref pstmt : Expr = program.child(pi)
        if pstmt.node_type.is(NodeType.Decl).not() { continue }
        switch pstmt.node_type {
        case NodeType.Decl(pdd):
            if pdd.is_priv.not() { continue }
            if pdd.name.starts_with("priv__") { continue }
            // Skip lifted-nested decls (the lift step above already set
            // orig_name on them and mangled their name to `<parent>_<orig>`).
            // Their function-scope priv check downstream relies on the
            // parent being extractable from the mangled name -- stacking
            // a `priv__<path>__` prefix would break that contract and
            // also let sibling functions reach the lifted decl from
            // anywhere in the file. Cross-file collisions on a lifted
            // nested name (same parent + same nested) are rare and the
            // existing parent prefix already disambiguates within a
            // file; we accept the residual risk for now.
            if pdd.orig_name.len().gt(0) { continue }
            mangled := priv_c_name(path, pdd.name)
            pdd.orig_name = pdd.name.clone()
            priv_renamings.set(own pdd.name.clone(), own mangled.clone())
            pdd.name = mangled.clone()
        case:
        }
    }
    if priv_renamings.len().gt(0) {
        for ri in 0..program.children.len() {
            ref mut rc : Expr = program.child(ri)
            init_rewrite_refs(rc, priv_renamings)
        }
    }

    for i in 0..program.children.len() {
        ref stmt : Expr = program.child(i)
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        ref rhs : Expr = stmt.child(0)
        if rhs.node_type.is(NodeType.StructDef) {
            errors = errors.add(register_struct_def_for_stmt(ctx, stmt, scope))
        } else if rhs.node_type.is(NodeType.EnumDef) {
            errors = errors.add(register_enum_def_for_stmt(ctx, stmt, scope))
            enum_idxs.push(own i)
        } else if rhs.node_type.is(NodeType.FuncDef) {
            if rhs.children.len().eq(0) {
                register_funcsig_alias_for_stmt(ctx, stmt, scope)
            } else {
                func_idxs.push(own i)
            }
        } else if rhs.node_type.is(NodeType.Ident) {
            alias_idxs.push(own i)
        } else {
            value_idxs.push(own i)
        }
    }

    // All type names are now in scope. Process the collected lists.
    for ei : U32 in enum_idxs {
        gen_enum_nonclone_methods_for_stmt(program.child(ei), scope)
    }
    for ai : U32 in alias_idxs {
        register_type_alias_for_stmt(ctx, program.child(ai), scope)
    }
    for fi : U32 in func_idxs {
        register_function_def_for_stmt(ctx, program.child(fi), scope)
    }
    for vi : U32 in value_idxs {
        register_top_level_value_for_stmt(ctx, program.child(vi), scope)
    }

    Vec.delete(own enum_idxs, true)
    Vec.delete(own alias_idxs, true)
    Vec.delete(own func_idxs, true)
    Vec.delete(own value_idxs, true)
    return errors
}

// Run the global init steps that require a full program view.
init_declarations_global := func(ctx: Context, program: Expr, scope: TypeScope) returns I32 {
    mut errors : I32 = 0

    // Single AST walk: bucket struct and enum decls for post-walk work,
    // and bucket func/value decls in case global generation steps added
    // new ones (size/derived methods) that need to be registered.
    struct_idxs := Vec.new(U32)
    enum_idxs := Vec.new(U32)
    func_idxs := Vec.new(U32)
    value_idxs := Vec.new(U32)
    for i in 0..program.children.len() {
        ref stmt : Expr = program.child(i)
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        ref rhs : Expr = stmt.child(0)
        if rhs.node_type.is(NodeType.StructDef) {
            struct_idxs.push(own i)
        } else if rhs.node_type.is(NodeType.EnumDef) {
            enum_idxs.push(own i)
        } else if rhs.node_type.is(NodeType.FuncDef) {
            if rhs.children.len().gt(0) {
                func_idxs.push(own i)
            }
        } else if rhs.node_type.is(NodeType.Ident).not() {
            value_idxs.push(own i)
        }
    }

    // Scope-using method generation that still lives here pending
    // the #174 method-body cycle work: clone+delete for structs,
    // missing-clone for enums. Layout computation, size methodgen
    // and cmp/unity methodgen all moved to type_decls_file (the
    // typer's first sweep) as part of #147 step 3-4 / #174 work.
    for si : U32 in struct_idxs {
        gen_struct_clone_delete_for_stmt(program.child(si), scope)
    }
    for ei : U32 in enum_idxs {
        gen_missing_enum_clone_for_stmt(program.child(ei), scope)
    }
    // Re-register function/value decls -- new ones may have been generated
    // above (size methods etc) but those go into ns_decls, not program.children.
    // Still re-register here to mirror the original ordering.
    for fi : U32 in func_idxs {
        register_function_def_for_stmt(ctx, program.child(fi), scope)
    }
    for vi : U32 in value_idxs {
        register_top_level_value_for_stmt(ctx, program.child(vi), scope)
    }

    Vec.delete(own struct_idxs, true)
    Vec.delete(own enum_idxs, true)
    Vec.delete(own func_idxs, true)
    Vec.delete(own value_idxs, true)
    return errors
}

// Count ~import("...")~ FCalls at the top level of `body`. Used by step 5
// to distinguish mode auto-imports (prepended to iu.imports by the loader)
// from explicit imports that appear in the source AST.
count_ast_imports := func(body: Expr) returns USize {
    mut n : USize = 0
    for i in 0..body.children.len() {
        ref stmt : Expr = body.children[i]
        mut is_imp := false
        if stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0)) {
            ref imp_stmt : Expr = stmt.child(0)
            if imp_stmt.node_type.is(NodeType.FCall).and(imp_stmt.children.len().gte(2)) {
                if imp_stmt.child(1).node_type.is_literal_str() {
                    switch imp_stmt.child(0).node_type {
                    case NodeType.Ident(id):
                        if ident_name(id).eq("import") { is_imp = true }
                    case:
                    }
                }
            }
        } else {
            if stmt.node_type.is(NodeType.FCall).and(stmt.children.len().gte(2)) {
                if stmt.child(1).node_type.is_literal_str() {
                    switch stmt.child(0).node_type {
                    case NodeType.Ident(id):
                        if ident_name(id).eq("import") { is_imp = true }
                    case:
                    }
                }
            }
        }
        if is_imp { n = n.add(1) }
    }
    return n
}

init_file := proc(path: Str, ctx: Context) returns I32 {
    if ctx.imports_init_done.has(path) {
        return 0
    }
    ctx.imports_init_done.add(own path.clone())

    ref iu : ImportUnit = ctx.imported[path]

    // Walk the AST in source order and recurse on each ~import("...")~ FCall.
    // iu.imports is kept as a side table that maps the i-th import FCall to
    // its resolved disp path. The loader prepends mode auto-imports (e.g.
    // `mode gui` -> gui.til) ahead of the AST-extracted imports, so process
    // those leading entries first before walking. #165 step 5.
    ast_count : USize = count_ast_imports(iu.ast)
    auto_count : USize = iu.imports.len().sub(ast_count)
    for i in 0..auto_count {
        ref dep : Str = iu.imports[i]
        init_file(dep, ctx)
    }
    mut import_idx : USize = auto_count
    for i in 0..iu.ast.children.len() {
        ref stmt : Expr = iu.ast.children[i]
        mut is_imp := false
        if stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0)) {
            ref imp_stmt : Expr = stmt.child(0)
            if imp_stmt.node_type.is(NodeType.FCall).and(imp_stmt.children.len().gte(2)) {
                if imp_stmt.child(1).node_type.is_literal_str() {
                    switch imp_stmt.child(0).node_type {
                    case NodeType.Ident(id):
                        if ident_name(id).eq("import") { is_imp = true }
                    case:
                    }
                }
            }
        } else {
            if stmt.node_type.is(NodeType.FCall).and(stmt.children.len().gte(2)) {
                if stmt.child(1).node_type.is_literal_str() {
                    switch stmt.child(0).node_type {
                    case NodeType.Ident(id):
                        if ident_name(id).eq("import") { is_imp = true }
                    case:
                    }
                }
            }
        }

        if is_imp {
            ref dep : Str = iu.imports[import_idx]
            init_file(dep, ctx)
            import_idx = import_idx.add(1)
        }
    }

    ctx.mode = iu.mode.clone()
    init_declarations_unit(path, iu.ast, ctx.scope, ctx)
    return 0
}

// sync_body_ns_to_payload: deleted -- all ns methods now go directly to ns_decls
