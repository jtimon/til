mode lib
import("context")

import("parser")
import("modes")
import("initer")
import("targets")
import("typer")
import("desugarer")
import("garbager")
import("constfolder")
import("scavenger")

// --- External C bridges used by the loader ---

// realpath_str resolves a path against the live filesystem/CWD, so its result
// is not a pure function of its argument -- folding it would bake a
// CWD-dependent path at build time. It is ext_proc (not ext_func) so the
// const-folder never folds it; see #283. Its func callers below are procs too.
realpath_str := ext_proc(path: Str) returns Str {}

// --- Leaf helpers ---

REPL_CORE_INFO_CACHE := "doc/repl_core_info.esc"
REPL_CORE_DOCS_CACHE := "doc/repl_core_docs.esc"

priv normalize_mode_name := func(mode_name: Str) returns Str {
    if mode_name.len() > 0 {
        return mode_name
    }
    return "script"
}

// Strip CWD prefix so embedded file:line:col strings are repo-relative,
// not absolute. Prepend "./" so emacs recognizes the path as relative.
priv display_path := func(p: Str, cwd: Str) returns Str {
    prefix := format(cwd, "/")
    rel := p.strip_prefix(prefix)
    if rel.starts_with("/") {
        return rel
    }
    if rel.starts_with("./") {
        return rel
    }
    return format("./", rel)
}

priv require_mode := func(ctx: Context, path: Str, mode_name: Str) returns ref Mode {
    ref resolved : Mode = mode_resolve(ctx, mode_name)
    if resolved.is_null() {
        panic(": unknown mode '", mode_name, "'", loc = path)
    }
    return resolved
}

forward_header_path := func(path: Str) returns Str {
    slash := path.rfind("/")
    dot := path.rfind(".")
    if dot > slash {
        return format(path.substr(0, dot.to_usize()), "_forward.h")
    }
    return format(path, "_forward.h")
}

// Directory part of an absolute path (no trailing slash).
priv dir_of := func(abs: Str) returns Str {
    if abs.len() == 0 { return "." }
    mut last_slash := abs.len() - 1
    while last_slash.gt(0).and(abs.get(last_slash).neq('/')) {
        last_slash--
    }
    return abs.substr(0, last_slash).clone()
}

priv resolve_link_path := proc(base_dir: Str, root_dir: Str, path: Str) returns Str {
    if path.starts_with("/") {
        return path
    }
    rel_candidate := base_dir.format("/", path)
    if realpath_str(rel_candidate).len() > 0 {
        return rel_candidate
    }
    if root_dir.len() > 0 {
        root_candidate := root_dir.format("/", path)
        if realpath_str(root_candidate).len() > 0 {
            return root_candidate
        }
    }
    return rel_candidate
}

// --- Import resolution ---

ProgramUnit := struct {
    path := ""
    mode := Mode()
    imports := Vec(Str).new()
}

// Resolve a file's direct import paths to display paths.
priv resolve_import_disps := proc(import_paths: Vec(Str), base_dir: Str, lib_dir: Str, cwd: Str) returns Vec(Str) {
    mut out := Vec(Str).new()
    for import_path : Str in import_paths {
        mut try_path := base_dir.format("/", import_path)
        mut abs := realpath_str(try_path)
        if abs.eq("").and(lib_dir.len().gt(0)) {
            try_path = lib_dir.format("/", import_path)
            abs = realpath_str(try_path)
        }
        if abs == "" { continue }
        out.push(own display_path(abs, cwd))
    }
    return out
}

// Extract import("path") calls from AST body, returning paths as Vec of Str*.
// The .til suffix is appended internally; paths already ending in ".til" are
// rejected with a helpful error suggesting the bare-name form.
priv extract_one_import := func(mut imp_stmt: Expr, path: Str, mut paths: Vec(Str)) {
    if imp_stmt.children.len() >= 2 {
        switch imp_stmt.children[0].node_type {
        case NodeType.Ident(c0id):
            if c0id.ident_name() == "import" {
                switch imp_stmt.children[1].node_type {
                case NodeType.Literal(Literal.Str(p)):
                    if p.ends_with(".til") {
                        bare := p.strip_suffix(".til")
                        loc := path.format(":", imp_stmt.line.to_str(), ":", imp_stmt.col.to_str())
                        panic("import path must not end in '.til' (got \"", p,
                            "\"); use import(\"", bare, "\") instead", loc = loc)
                    }
                    paths.push(own format(p, ".til"))
                case:
                }
            }
        case:
        }
    }
}

priv extract_imports := func(body: Expr, path: Str) returns Vec(Str) {
    mut paths := Vec(Str).new()
    for stmt : Expr in body.children {
        mut is_imp := false
        mut is_decl_rhs := false
        if stmt.node_type.is(NodeType.FCall) {
            is_imp = true
        } else if stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0)) {
            if stmt.children[0].node_type.is(NodeType.FCall) {
                is_imp = true
                is_decl_rhs = true
            }
        }

        if is_imp {
            if is_decl_rhs {
                extract_one_import(stmt.children[0], path, paths)
            } else {
                extract_one_import(stmt, path, paths)
            }
        }
    }
    return paths
}

// Recursively resolve imports.
priv resolve_imports := proc(import_paths: Vec(Str), base_dir: Str,
    mut resolved_set: Set(Str), mut stack: Vec(Expr),
    mut units: Vec(ProgramUnit), lib_dir: Str,
    mut ctx: Context, default_mode: Str, cwd: Str) returns I32 {
        for import_path : Str in import_paths {
            // Try relative to importing file's directory, then lib_dir
            mut try_path := base_dir.format("/", import_path)
            mut abs := realpath_str(try_path)
            if abs.eq("").and(lib_dir.len().gt(0)) {
                try_path = lib_dir.format("/", import_path)
                abs = realpath_str(try_path)
            }
            if abs == "" {
                println(format("error: could not find import '", import_path, "' (from ", base_dir, "/)"))
                return 1
            }

            // Dedup (also handles circular imports -- files are added to
            // resolved_set when they start processing)
            if resolved_set.has(abs) {
                continue
            }
            resolved_set.add(own abs.clone())

            // Load, lex, parse the imported file. Use display_path for the
            // path strings that get embedded in the AST / generated C, so the
            // boot/ files don't carry absolute paths.
            disp := display_path(abs, cwd)
            source := File.readfile(abs)
            tokens := tokenize(source, disp)
            mut sub_mode := ""
            sub_ast := parse(tokens, source, disp, sub_mode, ctx.anon_type_counter)
            sub_mode = normalize_mode_name(sub_mode)
            ref sub_mode_def : Mode = require_mode(ctx, disp, sub_mode)
            context_register_path_mode(ctx, disp, sub_mode_def)
            sub_imports := extract_imports(sub_ast, disp)

            // Get imported file's directory for recursive resolution
            sub_dir := dir_of(abs)

            sub_import_disps := resolve_import_disps(sub_imports, sub_dir, lib_dir, cwd)

            // Recurse for sub-imports
            if sub_imports.len() > 0 {
                err := resolve_imports(sub_imports, sub_dir, resolved_set, stack, units, lib_dir,
                    ctx, default_mode, cwd)
                if err > 0 {
                    return err
                }
            }

            // Store canonical import unit in ctx (rstil-style).
            mut iu := ImportUnit(mode = sub_mode_def.clone())
            iu.ast.take_children(sub_ast)
            iu.imports = sub_import_disps.clone()
            ctx.imported.set(disp, own iu)

            // Record ordering metadata as a ProgramUnit.
            mut unit := ProgramUnit(path = disp.clone(), mode = sub_mode_def.clone())
            unit.imports = sub_import_disps
            units.push(own unit)

        }
        return 0
    }

// --- LoadedProgram ---

LoadedProgram := struct {
    own core_units := Vec(ProgramUnit).new()
    own units := Vec(ProgramUnit).new()
    mode_files := Vec(Str).new()

    target := Target.LinuxX64
    cur_mode := Mode()
    ctx := Context()
    skip_core := false
    mode_str := ""
    path := ""
    ext_c_path := ""
    link_flags := ""
    include_flags := ""
    link_c_paths := ""
    run_tests := false
namespace:
    delete := func(own self: LoadedProgram, call_free: Bool = true) {
        if self.is_null() { return }
        if self.core_units.is_null().not() { own self.core_units.delete(true) }
        if self.units.is_null().not() { own self.units.delete(true) }
        own self.mode_files.delete(false)
        Target.delete(own self.target, false)
        Mode.delete(own self.cur_mode, false)
        Context.delete(own self.ctx, false)
        Str.delete(own self.mode_str, false)
        Str.delete(own self.path, false)
        Str.delete(own self.ext_c_path, false)
        Str.delete(own self.link_flags, false)
        Str.delete(own self.include_flags, false)
        Str.delete(own self.link_c_paths, false)
        if call_free { free(own self) }
    }
}

// #192: find the RHS type name of a top-level `alias_name := <Ident>` decl in
// a parsed file body. Used to make USize/UPtr resolution SOURCE-DRIVEN: the
// width comes from src/core/usize.til (read fresh from the parsed AST every
// build) rather than a value baked into target_usize_name and thus into
// boot/til.c. Without this, flipping the source alias and the boot-baked width
// can never happen in one commit (a one-build lag), because the C ABI in
// ext.h has no such lag and the two would disagree at pass 1.
priv find_alias_rhs_in_ast := func(ast: Expr, name: Str) returns Str {
    if ast.is_null() { return "" }
    for i in 0..ast.children.len() {
        ref stmt : Expr = ast.children[i]
        mut is_match := false
        switch stmt.node_type {
        case NodeType.Decl(d):
            if d.name == name { is_match = true }
        case:
        }
        if is_match {
            if stmt.children.len() > 0 {
                switch stmt.children[0].node_type {
                // #192: clone -- ident_name() borrows the parsed AST node's name
                // Str (its bytes live in the Expr tree). Returning it as-is hands
                // the caller a view it then frees, freeing into the AST buffer
                // (ASAN: "free on address which was not malloc()-ed"). The clone
                // is an owned heap Str the caller can free safely.
                case NodeType.Ident(tn): return tn.ident_name().clone()
                case:
                }
            }
        }
    }
    return ""
}

// Resolve the target-width primitive name for a source-level int alias
// (USize/UPtr). 32-bit targets are always U32. On 64-bit, read the width
// from the source alias decl (lag-free); fall back to the baked
// target_*_name only if the source decl can't be found.
priv target_int_alias_name := func(lp: LoadedProgram, alias_name: Str, target_fallback: Str) returns Str {
    if target_uptr_name(lp.target) == "U32" { return "U32" }
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            rhs := find_alias_rhs_in_ast(iu.ast, alias_name)
            if rhs.len() > 0 { return rhs }
        }
    }
    return target_fallback
}

repl_clone_loaded_program := func(src: LoadedProgram) returns LoadedProgram {
    cloned := src.clone()
    repl_reregister_scope_defs_loaded(cloned)
    return cloned
}

priv retarget_alias_binding := func(mut scope: TypeScope, alias_name: Str, target_name: Str) {
    ref mut alias_binding : TypeBinding = scope.get_binding(alias_name)
    if alias_binding.is_null() { return }
    ref target_binding : TypeBinding = scope.get_binding(target_name)
    if target_binding.is_null() { return }
    alias_binding.type = target_binding.type.clone()
    ref target_sd : Expr = scope.struct_def_of(target_name)
    if target_sd.is_null().not() { scope.set_struct_def(alias_name, target_sd) }
    ref target_fd : Expr = scope.lookup_func(target_name)
    if target_fd.is_null().not() {
        scope.set_func_def(alias_name, target_fd)
    }
    alias_binding.is_func_decl = target_binding.is_func_decl
    alias_binding.is_builtin = target_binding.is_builtin
    alias_binding.is_type_alias = true
    alias_binding.alias_target = target_name.clone()
}

retarget_loaded_aliases := func(lp: LoadedProgram) {
    retarget_alias_binding(lp.ctx.scope, "UPtr", target_int_alias_name(lp, "UPtr", target_uptr_name(lp.target)))
    retarget_alias_binding(lp.ctx.scope, "USize", target_int_alias_name(lp, "USize", target_usize_name(lp.target)))
}

// Constfolder across per-file units (rstil-style): fold macros/pure funcs in the
// canonical ASTs stored in lp.ctx.imported.
priv constfolder_imported := proc(mut lp: LoadedProgram) {
    // Make codegen_lp() available so dispatch helpers like make_str_value can
    // read shared Context fields
    // (cached_str/array/vec_def) populated by interpreter_init_ns below.
    // Only clear the fold-results map here; the foldable-name table
    // (constfolder_foldables) was populated upstream by the typer
    // (constfolder_classify_stmt) and must survive into this phase.
    constfolder_clear_known(lp.ctx)
    // Issue #109: populate ctx.cached_str/array/vec_def BEFORE
    // constfolder_register_fold_scope, so the is_known -> expr_to_value
    // -> make_str_value(_view) path inside the fold-scope walk
    // produces Value.Struct values with struct_name = "Str" instead
    // of "". With NULL/empty struct_name, cleanup_value_payload's
    // si.struct_name.eq("Str") check fails and the inner Str
    // c_str buffer leaks at scope_free(own global) below.
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            populate_cached_aggregate_defs(lp.ctx, lp.ctx.imported[u.path].ast)
        }
    }
    for u : ProgramUnit in lp.units {
        populate_cached_aggregate_defs(lp.ctx, lp.ctx.imported[u.path].ast)
    }
    // Issue #158: one walk per unit builds the runtime fold scope
    // (struct/enum/func defs + literal global constants). Name
    // classification is no longer done here -- it was shared from the
    // typer's walk and lives on Context.
    global := scope_new(NULL)
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            constfolder_register_fold_scope(global, iu.ast, lp.ctx)
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        constfolder_register_fold_scope(global, iu.ast, lp.ctx)
    }
    // Nothing to fold? Skip the FFI/fold setup, but still free the
    // (near-empty) scope built above via the single cleanup at the end.
    // til's ownership checker is flow-insensitive, so we keep exactly one
    // scope_free(own global) rather than an early-return that moves it.
    has_fold := lp.ctx.constfolder_foldables.len() > 0
    if has_fold {
        // Issue #191: core constants registered after the defs walk so they
        // win over any like-named definition (e.g. CAP_VIEW for Str ops).
        constfolder_register_core_constants(global, lp.ctx.target_usize_pname)

        if lp.skip_core.not() {
            for u : ProgramUnit in lp.core_units {
                interpreter_init_ns(lp.ctx, global, lp.ctx.imported[u.path].ast)
            }
        }
        for u : ProgramUnit in lp.units {
            interpreter_init_ns(lp.ctx, global, lp.ctx.imported[u.path].ast)
        }

        // 2b) Init FFI for the interpreter used by constfolder.
        // Scan per-file ASTs directly to avoid merged-AST cloning.
        ffi_reset(lp.ctx)
        if lp.skip_core.not() {
            for u : ProgramUnit in lp.core_units {
                ref iu : ImportUnit = lp.ctx.imported[u.path]
                ffi_init_struct_defs_append(iu.ast, lp.ctx)
                ffi_init_scan_program(iu.ast, lp.ctx)
            }
        }
        for u : ProgramUnit in lp.units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            ffi_init_struct_defs_append(iu.ast, lp.ctx)
            ffi_init_scan_program(iu.ast, lp.ctx)
        }
        // Mark FFI loaded so ext_dispatch_ffi will dispatch the entries we
        // just registered. Built-in ext_funcs (I64_add etc.) are statically
        // linked, so no .so needs dlopen'ing for constfolder's eval-based fold
        // to call them.
        lp.ctx.ffi_loaded = true

        // 3) Fold calls in every file. The known-fold map lives on ctx
        // (ctx.constfolder_known); constfolder_reset_state below clears it.
        if lp.skip_core.not() {
            for u : ProgramUnit in lp.core_units {
                context_enter_file(lp.ctx, u.path)
                process_body(global, lp.ctx.imported[u.path].ast, lp.ctx, true)
            }
        }
        for u : ProgramUnit in lp.units {
            context_enter_file(lp.ctx, u.path)
            process_body(global, lp.ctx.imported[u.path].ast, lp.ctx, true)
        }
    }

    scope_free(own global)
    constfolder_reset_state(lp.ctx)
}

priv repl_classify_foldables_program := func(ctx: Context, program: Expr) {
    for stmt : Expr in program.children {
        constfolder_classify_stmt(stmt, ctx)
    }
}

priv repl_classify_foldables_loaded := func(mut lp: LoadedProgram) {
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            repl_classify_foldables_program(lp.ctx, lp.ctx.imported[u.path].ast)
        }
    }
    for u : ProgramUnit in lp.units {
        repl_classify_foldables_program(lp.ctx, lp.ctx.imported[u.path].ast)
    }
    for mf : Str in lp.mode_files {
        repl_classify_foldables_program(lp.ctx, lp.ctx.imported[mf].ast)
    }
}

priv repl_reregister_scope_defs_loaded := func(lp: LoadedProgram) {
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            reregister_repl_scope_defs(lp.ctx.imported[u.path].ast, lp.ctx.scope)
        }
    }
    for u2 : ProgramUnit in lp.units {
        reregister_repl_scope_defs(lp.ctx.imported[u2.path].ast, lp.ctx.scope)
    }
    for mf : Str in lp.mode_files {
        reregister_repl_scope_defs(lp.ctx.imported[mf].ast, lp.ctx.scope)
    }
}

priv constfolder_repl_delta := proc(mut lp: LoadedProgram, delta: Expr) {
    constfolder_clear_known(lp.ctx)
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            populate_cached_aggregate_defs(lp.ctx, lp.ctx.imported[u.path].ast)
        }
    }
    for u : ProgramUnit in lp.units {
        populate_cached_aggregate_defs(lp.ctx, lp.ctx.imported[u.path].ast)
    }
    populate_cached_aggregate_defs(lp.ctx, delta)

    global := scope_new(NULL)
    if lp.skip_core.not() {
        for u2 : ProgramUnit in lp.core_units {
            ref iu2 : ImportUnit = lp.ctx.imported[u2.path]
            constfolder_register_fold_scope(global, iu2.ast, lp.ctx)
        }
    }
    for u3 : ProgramUnit in lp.units {
        ref iu3 : ImportUnit = lp.ctx.imported[u3.path]
        constfolder_register_fold_scope(global, iu3.ast, lp.ctx)
    }
    constfolder_register_fold_scope(global, delta, lp.ctx)

    has_fold := lp.ctx.constfolder_foldables.len() > 0
    if has_fold {
        constfolder_register_core_constants(global, lp.ctx.target_usize_pname)

        if lp.skip_core.not() {
            for u4 : ProgramUnit in lp.core_units {
                interpreter_init_ns(lp.ctx, global, lp.ctx.imported[u4.path].ast)
            }
        }
        for u5 : ProgramUnit in lp.units {
            interpreter_init_ns(lp.ctx, global, lp.ctx.imported[u5.path].ast)
        }
        interpreter_init_ns(lp.ctx, global, delta)

        ffi_reset(lp.ctx)
        if lp.skip_core.not() {
            for u6 : ProgramUnit in lp.core_units {
                ref iu6 : ImportUnit = lp.ctx.imported[u6.path]
                ffi_init_struct_defs_append(iu6.ast, lp.ctx)
                ffi_init_scan_program(iu6.ast, lp.ctx)
            }
        }
        for u7 : ProgramUnit in lp.units {
            ref iu7 : ImportUnit = lp.ctx.imported[u7.path]
            ffi_init_struct_defs_append(iu7.ast, lp.ctx)
            ffi_init_scan_program(iu7.ast, lp.ctx)
        }
        ffi_init_struct_defs_append(delta, lp.ctx)
        ffi_init_scan_program(delta, lp.ctx)
        lp.ctx.ffi_loaded = true

        ref root : ProgramUnit = lp.units[lp.units.len() - 1]
        context_enter_file(lp.ctx, root.path)
        process_body(global, delta, lp.ctx, true)
    }

    scope_free(own global)
    constfolder_clear_known(lp.ctx)
}

// Scavenge across per-file units (rstil-style): compute a single visited set
// from merged views, then filter each file's canonical AST in ctx.imported.
priv DeclRef := struct {
    path := ""
    idx : USize = 0
}

priv find_ns_decl_fdef_imported := func(ctx: Context, top: Map(Str, DeclRef), name: Str) returns ref Expr {
    dot := name.find(".")
    if dot < 0 { return NULL }
    type_part := name.substr(0, dot.to_usize())
    if top.has(type_part).not() { return NULL }
    ref dr : DeclRef = top[type_part]
    ref iu : ImportUnit = ctx.imported[dr.path]
    ref tdecl : Expr = iu.ast.children[dr.idx]
    if tdecl.node_type.is(NodeType.Decl).not() { return NULL }
    if is_struct_or_enum(tdecl).not() { return NULL }
    dot_u := dot.to_usize()
    method_part := name.substr(dot_u + 1, name.len().sub(dot_u) - 1)
    ref ns : Vec(Declaration) = def_ns_decls(tdecl.children[0])
    for nsd : Declaration in ns {
        if nsd.name == method_part {
            if nsd.default_value.is_null().not() {
                return nsd.default_value
            }
        }
    }
    return NULL
}

priv scavenge_visited_imported := func(lp: LoadedProgram) returns Set(Str) {
    mut is_cli := false
    if lp.cur_mode.is_null().not() {
        if lp.cur_mode.needs_main {
            if lp.run_tests.not() {
                is_cli = true
            }
        }
    }

    // 1) Build top-level decl maps: name -> (path, idx)
    mut core_top := Map(Str, DeclRef).new()
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            for i in 0..iu.ast.children.len() {
                ref stmt : Expr = iu.ast.children[i]
                switch stmt.node_type {
                case NodeType.Decl(decl):
                    core_top.set(decl.name, own DeclRef(path = u.path.clone(), idx = i.clone()))
                case:
                }
            }
        }
    }
    mut top := Map(Str, DeclRef).new()
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for i in 0..iu.ast.children.len() {
            ref stmt : Expr = iu.ast.children[i]
            switch stmt.node_type {
            case NodeType.Decl(decl):
                top.set(decl.name, own DeclRef(path = u.path.clone(), idx = i.clone()))
            case:
            }
        }
    }

    // 2) Seed worklist from the concatenated user-unit stream
    mut worklist := Vec(Str).new()
    vec_push_str(worklist, "Str")
    if is_cli {
        vec_push_str(worklist, "main")
        // The generated CLI entry wrapper (emit_cli_parse_arg in
        // builder.til) parses typed argv into main()'s params inline,
        // by raw-C name: Str.from_c_str wraps each argv c-string and the
        // Str.to_* / I64.to_* family converts it. Those calls are emitted
        // after this reachability prune, so the names never appear in the
        // user stream -- seed them as roots here, or DCE drops the til
        // definitions and the wrapper fails to link. (Str.from_c_str
        // pulls in c_str_len transitively; Str.cmp/Str.delete come in via
        // the "Str" root above but are listed for clarity.)
        push_qn(worklist, "Str", "from_c_str")
        push_qn(worklist, "Str", "to_i64")
        push_qn(worklist, "Str", "to_u8")
        push_qn(worklist, "Str", "to_i32")
        push_qn(worklist, "Str", "to_u32")
        push_qn(worklist, "Str", "to_u64")
        push_qn(worklist, "Str", "to_f32")
        push_qn(worklist, "Str", "cmp")
        push_qn(worklist, "Str", "delete")
        push_qn(worklist, "I64", "to_i8")
        push_qn(worklist, "I64", "to_i16")
        push_qn(worklist, "I64", "to_u16")
        for u : ProgramUnit in lp.units {
            for stmt : Expr in lp.ctx.imported[u.path].ast.children {
                if stmt.node_type.is(NodeType.Decl) {
                    if is_def(stmt) { continue }
                }
                collect_refs(stmt, worklist)
            }
        }
    } else if lp.run_tests {
        for u : ProgramUnit in lp.units {
            for stmt : Expr in lp.ctx.imported[u.path].ast.children {
                if stmt.node_type.is(NodeType.Decl) {
                    if stmt.children.len() > 0 {
                        switch stmt.children[0].node_type {
                        case NodeType.FuncDef(fdef):
                            if fdef.func_type.is(FuncType.Test) {
                                switch stmt.node_type {
                                case NodeType.Decl(d):
                                    vec_push_str(worklist, d.name)
                                case:
                                }
                            }
                        case:
                        }
                    }
                    // Seed namespace test() decls so emit_test_main's
                    // Type_test_name() calls don't get scavenged out.
                    mut is_type_decl := false
                    if stmt.children.len() > 0 {
                        ref decl_value : Expr = stmt.children[0]
                        is_type_decl = decl_value.node_type.is(NodeType.StructDef)
                            .or(decl_value.node_type.is(NodeType.EnumDef))
                    }
                    if is_type_decl {
                        switch stmt.node_type {
                        case NodeType.Decl(sdecl):
                            ref nstv : Vec(Declaration) = def_ns_decls(stmt.children[0])
                            for nsd : Declaration in nstv {
                                ref nsfdef : Expr = nsd.default_value
                                if nsfdef.is_null() { continue }
                                if nsfdef.node_type.is(NodeType.FuncDef).not() { continue }
                                switch nsfdef.node_type {
                                case NodeType.FuncDef(nsfd):
                                    if nsfd.func_type.is(FuncType.Test) {
                                        push_qn(worklist, sdecl.name, nsd.name)
                                    }
                                case:
                                    UNREACHABLE()
                                }
                            }
                        case:
                            UNREACHABLE()
                        }
                    }
                    if is_def(stmt) { continue }
                }
                collect_refs(stmt, worklist)
            }
        }
    } else {
        for u : ProgramUnit in lp.units {
            for stmt : Expr in lp.ctx.imported[u.path].ast.children {
                if stmt.node_type.is(NodeType.Decl) {
                    if is_def(stmt) { continue }
                }
                collect_refs(stmt, worklist)
            }
        }
    }

    // 3) BFS
    mut visited := Set(Str).new()
    mut cursor : USize = 0
    while cursor < worklist.len() {
        name := Str.clone(worklist[cursor])
        cursor++
        if visited.has(name) { continue }
        visited.add(own name.clone())

        // #269: "*.m" wildcard from collect_refs -- a dyn_call whose type
        // name is a runtime expression (interface dispatch). The target
        // type is only known at runtime, so keep method m alive on every
        // top-level type by expanding to concrete Type.m names; the BFS
        // then walks each kept method's body normally.
        if name.starts_with("*.") {
            wc_method := name.substr(2, name.len() - 2)
            for wk in top.keys {
                push_qn(worklist, wk, wc_method)
            }
            for wk2 in core_top.keys {
                push_qn(worklist, wk2, wc_method)
            }
            continue
        }

        if top.has(name) {
            ref dr : DeclRef = top[name]
            ref iu : ImportUnit = lp.ctx.imported[dr.path]
            ref decl : Expr = iu.ast.children[dr.idx]
            if is_struct_or_enum(decl) {
                switch decl.children[0].node_type {
                case NodeType.StructDef(bfs_sdd):
                    for bfs_fd : Declaration in bfs_sdd.fields {
                        if bfs_fd.default_value.is_null().not() {
                            collect_refs(bfs_fd.default_value, worklist)
                        }
                        if bfs_fd.explicit_type.len() > 0 {
                            vec_push_str(worklist, bfs_fd.explicit_type)
                        }
                    }
                case NodeType.EnumDef(bfs_edd):
                    for j in 0..bfs_edd.variants.len() {
                        idx_e := j.to_i64()
                        if bfs_edd.payload_types.has(idx_e) {
                            vec_push_str(worklist, bfs_edd.payload_types[idx_e])
                        }
                    }
                case:
                    UNREACHABLE()
                }
                push_qn(worklist, name, "delete")
                push_qn(worklist, name, "clone")
                push_qn(worklist, name, "size")
                push_qn(worklist, name, "cmp")
                push_qn(worklist, name, "hash")
            } else {
                collect_refs(decl.children[0], worklist)
            }
        }
        if core_top.has(name) {
            ref dr : DeclRef = core_top[name]
            ref iu : ImportUnit = lp.ctx.imported[dr.path]
            ref decl : Expr = iu.ast.children[dr.idx]
            if is_struct_or_enum(decl) {
                switch decl.children[0].node_type {
                case NodeType.StructDef(bfs_sdd2):
                    for bfs_fd2 : Declaration in bfs_sdd2.fields {
                        if bfs_fd2.default_value.is_null().not() {
                            collect_refs(bfs_fd2.default_value, worklist)
                        }
                        if bfs_fd2.explicit_type.len() > 0 {
                            vec_push_str(worklist, bfs_fd2.explicit_type)
                        }
                    }
                case NodeType.EnumDef(bfs_edd2):
                    for j in 0..bfs_edd2.variants.len() {
                        idx_e2 := j.to_i64()
                        if bfs_edd2.payload_types.has(idx_e2) {
                            vec_push_str(worklist, bfs_edd2.payload_types[idx_e2])
                        }
                    }
                case:
                    UNREACHABLE()
                }
                push_qn(worklist, name, "delete")
                push_qn(worklist, name, "clone")
                push_qn(worklist, name, "size")
                push_qn(worklist, name, "cmp")
                push_qn(worklist, name, "hash")
            } else {
                collect_refs(decl.children[0], worklist)
            }
        }

        // A "Type.member" qualified name on the worklist can resolve to
        // a FuncDef (namespace method) or to a plain Ident / FCall /
        // other Expr (namespace data decl like `HashMap.hasher : HashFn
        // = fnv1a`). Walk whatever the default_value is so the free
        // identifiers it references stay reachable -- otherwise
        // `fnv1a` gets pruned and the init `HashMap_hasher = (void
        // *)fnv1a` in main() references an undeclared symbol.
        ref ns_fdef : Expr = find_ns_decl_fdef_imported(lp.ctx, top, name)
        if ns_fdef.is_null().not() {
            collect_refs(ns_fdef, worklist)
        }
        ref core_ns_fdef : Expr = find_ns_decl_fdef_imported(lp.ctx, core_top, name)
        if core_ns_fdef.is_null().not() {
            collect_refs(core_ns_fdef, worklist)
        }
    }
    return visited
}

// Types that a CLI argument can be parsed into. Must match the builder's
// cli_box_expr (codegen) and the interpreter's parse_cli_arg -- keep the
// three in sync when adding a type.
// Reject a main() whose parameters can't be parsed from CLI arguments, with a
// clear up-front error. Without this the builder emits C that references an
// undeclared param (a cryptic -Werror=unused-parameter failure) instead of a
// usable message. The variadic param is checked by its element type, which is
// what the builder parses. Runs on the compile path (scavenge_imported); the
// interpreter additionally guards at runtime in parse_cli_arg.
priv validate_cli_main := func(lp: LoadedProgram) {
    if lp.cur_mode.is_null() { return }
    if lp.cur_mode.needs_main.not() { return }
    if lp.run_tests { return }
    for u : ProgramUnit in lp.units {
        for stmt : Expr in lp.ctx.imported[u.path].ast.children {
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            if stmt.children.len() == 0 { continue }
            mut is_main_decl := false
            switch stmt.node_type {
            case NodeType.Decl(d):
                if d.name == "main" { is_main_decl = true }
            case:
            }
            if is_main_decl.not() { continue }
            switch stmt.children[0].node_type {
            case NodeType.FuncDef(fdef):
                for p : Declaration in fdef.params {
                    if p.explicit_type.eq("Str").or(p.explicit_type.eq("I64")).or(p.explicit_type.eq("U8")).or(p.explicit_type.eq("I8"))
                        .or(p.explicit_type.eq("I16")).or(p.explicit_type.eq("U16")).or(p.explicit_type.eq("I32")).or(p.explicit_type.eq("U32"))
                        .or(p.explicit_type.eq("U64")).or(p.explicit_type.eq("USize")).or(p.explicit_type.eq("UPtr")).or(p.explicit_type.eq("Bool"))
                        .or(p.explicit_type.eq("F32")).not() {
                        loc := format(u.path, ":", stmt.line.to_str(), ":", stmt.col.to_str())
                        panic("main parameter '", p.name, "': type '", p.explicit_type,
                            "' cannot be parsed from a CLI argument (supported: Str, Bool, F32, I8/U8/I16/U16/I32/U32/I64/U64/USize/UPtr)", loc = loc)
                    }
                }
            case:
            }
        }
    }
}

priv scavenge_imported := proc(mut lp: LoadedProgram) {
    validate_cli_main(lp)
    visited := scavenge_visited_imported(lp)

    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            scavenge_filter(lp.ctx.imported[u.path].ast, visited)
        }
    }
    for u : ProgramUnit in lp.units {
        scavenge_filter(lp.ctx.imported[u.path].ast, visited)
    }

    // Body-level DCE: drop unreferenced hoisted temps left behind by
    // constfolder's constant folding. Runs over every imported unit (cores
    // included) so the codegen no longer needs `(void)<name>;` guards.
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            dce_program_bodies(lp.ctx.imported[u.path].ast)
        }
    }
    for u : ProgramUnit in lp.units {
        dce_program_bodies(lp.ctx.imported[u.path].ast)
    }
}

// Scan program AST for link()/link_c() directives; fill link_flags,
// include_flags, link_c_paths on the given LoadedProgram.
priv extract_link_info := proc(mut lp: LoadedProgram) {
    root_dir := lp.ext_c_path.strip_suffix("/src/c/ext.c")
    // Remove link()/link_c() directives in-place from every user file so the
    // interpreter never evaluates them. Move iu.ast.children into a local Vec
    // and push_take kept stmts (no clone); old_children's garbager-inserted
    // delete after the loop drops the dropped link directives (#302).
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        base_dir := dir_of(u.path)
        mut old_children := Vec(Expr).new()
        old_children.move_from(iu.ast.children)
        mut new_children := Vec(Expr).new()
        for idx in 0..old_children.count {
            ref stmt : Expr = old_children[idx]
            mut keep := true
            if stmt.node_type.is(NodeType.FCall).and(stmt.children.len().eq(2)) {
                switch stmt.children[0].node_type {
                case NodeType.Ident(fname):
                    switch stmt.children[1].node_type {
                    case NodeType.Literal(Literal.Str(arg)):
                        if fname.ident_name() == "link" {
                            keep = false
                            if arg.find("/") >= 0 {
                                resolved := resolve_link_path(base_dir, root_dir, arg)
                                lp.link_flags = lp.link_flags.format(" ", resolved)
                                last_slash := resolved.rfind("/")
                                if last_slash >= 0 {
                                    parent_dir := resolved.substr(0, last_slash.to_usize())
                                    parent_slash := parent_dir.rfind("/")
                                    if parent_slash >= 0 {
                                        inc_dir := parent_dir.substr(0, parent_slash.to_usize()).format("/include")
                                        lp.include_flags = lp.include_flags.format(" -I", inc_dir)
                                    }
                                }
                            } else {
                                lp.link_flags = lp.link_flags.format(" -l", arg)
                            }
                        } else if fname.ident_name() == "link_c" {
                            keep = false
                            if lp.link_c_paths.len() > 0 {
                                lp.link_c_paths = format(lp.link_c_paths, " ")
                            }
                            lp.link_c_paths = format(lp.link_c_paths, resolve_link_path(base_dir, root_dir, arg))
                        }
                    case:
                    }
                case:
                }
            }
            if keep { new_children.push_take(old_children, idx) }
        }
        iu.ast.children = new_children
    }
}

priv load_mode_file := proc(mut lp: LoadedProgram, path: Str, cwd: Str) {
    abs_path := realpath_str(path)
    if abs_path == "" { return }
    disp := display_path(abs_path, cwd)
    source := File.readfile(abs_path)
    tokens := tokenize(source, disp)
    mut mode_str := ""
    ast := parse(tokens, source, disp, mode_str, lp.ctx.anon_type_counter)
    mode_str = normalize_mode_name(mode_str)
    if mode_str.eq("mode").not() {
        panic("file '", disp, "' is not a 'mode mode' file")
    }
    for stmt : Expr in ast.children {
        mut is_valid := false
        if stmt.node_type.is(NodeType.Decl) {
            switch stmt.node_type {
            case NodeType.Decl(decl):
                if stmt.children.len() > 0 {
                    ref val : Expr = stmt.children[0]
                    if val.node_type.is(NodeType.FCall).and(val.children.len().gt(0)) {
                        ref callee : Expr = val.children[0]
                        switch callee.node_type {
                        case NodeType.Ident(id):
                            if id.ident_name() == "Mode" {
                                is_valid = true
                                mut m := Mode()
                                for i in 1..val.children.len() {
                                    ref arg : Expr = val.children[i]
                                    switch arg.node_type {
                                    case NodeType.NamedArg(arg_name):
                                        switch arg.children[0].node_type {
                                        case NodeType.Literal(Literal.Bool(b)):
                                            if arg_name == "needs_main" { m.needs_main = b }
                                            else if arg_name == "decls_only" { m.decls_only = b }
                                            else if arg_name == "is_library" { m.is_library = b }
                                            else if arg_name == "is_pure" { m.is_pure = b }
                                            else if arg_name == "run_tests" { m.run_tests = b }
                                            else if arg_name == "debug_prints" { m.debug_prints = b }
                                            else { panic(": unknown bool argument '", arg_name, "'", loc = disp) }
                                        case NodeType.Literal(Literal.Str(s)):
                                            if arg_name == "auto_import" { m.auto_import = s.clone() }
                                            else { panic(": unknown string argument '", arg_name, "'", loc = disp) }
                                        case:
                                            panic(": argument '", arg_name, "' must be a literal", loc = disp)
                                        }
                                    case:
                                        panic(": Mode arguments must be named (e.g. needs_main = true)", loc = disp)
                                    }
                                }
                                lp.ctx.mode_registry.set(decl.name, own m.clone())
                            }
                        case:
                        }
                    }
                }
            case:
            }
        }
        if is_valid.not() {
            loc := disp.format(":", stmt.line.to_str(), ":", stmt.col.to_str())
            panic(": only Mode(...) declarations are allowed in 'mode mode' files", loc = loc)
        }
    }

    // Store in lp.ctx.imported so it can be typechecked.
    ref mode_mode_def : Mode = mode_resolve(lp.ctx, mode_str)
    if mode_mode_def.is_null() {
        panic("unknown mode '", mode_str, "' for mode file")
    }
    mut iu := ImportUnit(mode_str = mode_str.clone())
    iu.mode = mode_mode_def.clone()
    iu.ast.take_children(ast)
    context_register_path_mode(lp.ctx, disp, iu.mode)
    lp.ctx.imported.set(disp, own iu)
    lp.mode_files.push(own disp.clone())
}

// Load core.til + user file + imports + mode auto_import. Returns a
// LoadedProgram with the merged ASTs and link info populated.
load_program := proc(path: Str, bin_dir: Str, cwd: Str, ext_c_path: Str, extra_modes: Vec(Str)) returns LoadedProgram {
    mut lp := LoadedProgram()
    context_init_mode_registry(lp.ctx)
    lp.path = path.clone()
    lp.ext_c_path = ext_c_path.clone()
    lp.target = detect_current_target()

    core_path := format(bin_dir, "/src/core/core.til")
    core_disp := display_path(core_path, cwd)

    load_mode_file(lp, format(bin_dir, "/src/core/modes.til"), cwd)
    for extra_mode : Str in extra_modes {
        load_mode_file(lp, extra_mode, cwd)
    }


    // Single resolved set for all imports (core + user), so no file is loaded twice
    resolved := Set(Str).new()
    resolve_stack := Vec(Expr).new()

    // Resolve mode files' imports
    core_units := Vec(ProgramUnit).new()
    for mode_file : Str in lp.mode_files {
        ref miu_temp : ImportUnit = lp.ctx.imported[mode_file]
        mut mode_imports := extract_imports(miu_temp.ast, mode_file)
        mut auto_disp := ""
        if miu_temp.mode.auto_import.len() > 0 {
            mut auto_path := bin_dir.format("/", miu_temp.mode.auto_import, ".til")
            if realpath_str(auto_path) == "" {
                // If it fails relative to bin_dir, maybe it's relative to the CWD (for custom modes in other projects)
                auto_path = cwd.format("/", miu_temp.mode.auto_import, ".til")
            }
            abs_auto := realpath_str(auto_path)
            if abs_auto.len() > 0 {
                if resolved.has(abs_auto).not() {
                    resolved.add(own abs_auto.clone())
                    disp_auto := display_path(abs_auto, cwd)
                    source_auto := File.readfile(abs_auto)
                    tokens_auto := tokenize(source_auto, disp_auto)
                    mut mode_auto := ""
                    ast_auto := parse(tokens_auto, source_auto, disp_auto, mode_auto, lp.ctx.anon_type_counter)
                    mode_auto = normalize_mode_name(mode_auto)
                    ref mode_auto_def : Mode = require_mode(lp.ctx, disp_auto, mode_auto)
                    context_register_path_mode(lp.ctx, disp_auto, mode_auto_def)

                    mut iu_auto := ImportUnit(mode_str = mode_auto.clone())
                    iu_auto.mode = mode_auto_def.clone()
                    iu_auto.ast.take_children(ast_auto)
                    lp.ctx.imported.set(disp_auto, own iu_auto)

                    mut unit_auto := ProgramUnit(path = disp_auto.clone(), mode = mode_auto_def.clone())
                    core_units.push(own unit_auto)
                }
                auto_disp = display_path(abs_auto, cwd)
            }
        }
        if mode_imports.len() > 0 {
            mode_dir := dir_of(realpath_str(mode_file))
            err := resolve_imports(mode_imports, mode_dir, resolved, resolve_stack,
                core_units, "", lp.ctx, "lib", cwd)
            if err > 0 {
                panic("failed to resolve imports for mode file ", mode_file)
            }
            ref miu : ImportUnit = lp.ctx.imported[mode_file]
            miu.imports = resolve_import_disps(mode_imports, mode_dir, "", cwd)
        }
        if auto_disp.len() > 0 {
            lp.ctx.imported[mode_file].imports.push(own auto_disp)
        }
    }

    // Add user file to resolved set early (so core imports skip it if it overlaps)
    abs_path := realpath_str(path)
    mut user_dir := "."
    if abs_path.len() > 0 {
        user_dir = dir_of(abs_path)
        resolved.add(own abs_path.clone())
    }

    // Load core.til
    core_source := File.readfile(core_path)
    core_tokens := tokenize(core_source, core_disp)
    mut core_mode_str := ""
    core_ast := parse(core_tokens, core_source, core_disp, core_mode_str, lp.ctx.anon_type_counter)
    ref core_mode : Mode = require_mode(lp.ctx, core_disp, core_mode_str)
    context_register_path_mode(lp.ctx, core_disp, core_mode)

    // Add core.til to resolved set; skip prepending if user file IS core.til
    mut skip_core := false
    core_abs := realpath_str(core_path)
    if core_abs.len() > 0 {
        if resolved.has(core_abs) {
            skip_core = true
        }
        resolved.add(own core_abs.clone())
    }

    // Resolve core imports
    core_imports := extract_imports(core_ast, core_disp)
    if core_imports.len().gt(0).and(skip_core.not()) {
        core_dir := format(bin_dir, "/src/core")
        err := resolve_imports(core_imports, core_dir, resolved, resolve_stack,
            core_units, "", lp.ctx, "lib", cwd)
        if err > 0 {
            panic("failed to resolve core imports")
        }
    }


    // Load user file
    source := File.readfile(path)
    tokens := tokenize(source, path)
    mut mode_str := ""
    user_ast := parse(tokens, source, path, mode_str, lp.ctx.anon_type_counter)
    imports := extract_imports(user_ast, path)
    mode_str = normalize_mode_name(mode_str)
    ref mut cur_mode : Mode = require_mode(lp.ctx, path, mode_str)
    context_register_path_mode(lp.ctx, path, cur_mode)
    lp.ctx.mode = cur_mode.clone()

    // If mode has auto_import, load its .til declarations
    auto_import := cur_mode.auto_import

    // Resolve user imports (using same resolved set -- skips files already loaded by core)
    units := Vec(ProgramUnit).new()
    lib_dir := format(bin_dir, "/lib")
    user_import_disps := resolve_import_disps(imports, user_dir, lib_dir, cwd)
    if imports.len() > 0 {
        err := resolve_imports(imports, user_dir, resolved, resolve_stack,
            units, lib_dir, lp.ctx, "", cwd)
        if err > 0 {
            panic("failed to resolve imports")
        }
    }

    // Core entrypoint import unit.
    mut core_iu := ImportUnit(mode = core_mode.clone())
    core_iu.ast.take_children(core_ast)
    core_iu.imports = resolve_import_disps(core_imports, format(bin_dir, "/src/core"), "", cwd)
    lp.ctx.imported.set(core_disp, own core_iu)

    // Core entrypoint unit (after its imports).
    mut core_unit := ProgramUnit(path = core_disp.clone(), mode = core_mode.clone())
    core_unit.imports = lp.ctx.imported[core_disp].imports.clone()
    core_units.push(own core_unit)

    // Mode auto-import is represented as the first unit (if present),
    // followed by imported files, with the user entrypoint unit last.
    mut mode_disp := ""
    if auto_import.len() > 0 {
        mut mode_til_path := bin_dir.format("/", auto_import, ".til")
        if realpath_str(mode_til_path) == "" {
            mode_til_path = user_dir.format("/", auto_import, ".til")
        }
        if realpath_str(mode_til_path) == "" {
            mode_til_path = bin_dir.format("/src/modes/", auto_import, ".til")
        }
        mode_disp = display_path(mode_til_path, cwd)
        mode_source := File.readfile(mode_til_path)
        mode_tokens := tokenize(mode_source, mode_disp)
        mut mode_mode := ""
        mode_ast := parse(mode_tokens, mode_source, mode_disp, mode_mode, lp.ctx.anon_type_counter)
        mode_mode = normalize_mode_name(mode_mode)
        ref mode_mode_def : Mode = require_mode(lp.ctx, mode_disp, mode_mode)
        context_register_path_mode(lp.ctx, mode_disp, mode_mode_def)

        // Resolve the auto-import file's own imports (mirrors core.til).
        mode_imports := extract_imports(mode_ast, mode_disp)
        mode_dir := dir_of(realpath_str(mode_til_path))
        if mode_imports.len() > 0 {
            err := resolve_imports(mode_imports, mode_dir, resolved, resolve_stack,
                units, lib_dir, lp.ctx, "", cwd)
            if err > 0 {
                panic("failed to resolve mode auto-import imports")
            }
        }

        // Mode auto-import import unit.
        mut mode_iu := ImportUnit(mode = mode_mode_def.clone())
        mode_iu.ast.take_children(mode_ast)
        mode_iu.imports = resolve_import_disps(mode_imports, mode_dir, lib_dir, cwd)
        lp.ctx.imported.set(mode_disp, own mode_iu)

        // Mode auto-import unit.
        mut mode_unit := ProgramUnit(path = mode_disp.clone(), mode = mode_mode_def.clone())
        mode_unit.imports = lp.ctx.imported[mode_disp].imports.clone()
        units.push(own mode_unit)

    }

    // User entrypoint import unit.
    mut user_iu := ImportUnit(mode = cur_mode.clone())
    user_iu.ast.take_children(user_ast)
    // Ensure mode auto-import runs before the file's explicit imports.
    // This matches the merged AST order and keeps per-file init/type in sync.
    if mode_disp.len() > 0 {
        mut all_imports := Vec(Str).new()
        all_imports.push(own mode_disp.clone())
        for dep : Str in user_import_disps { all_imports.push(own dep.clone()) }
        user_iu.imports = all_imports
    } else {
        user_iu.imports = user_import_disps.clone()
    }
    lp.ctx.imported.set(path, own user_iu)

    // User entrypoint unit.
    mut user_unit := ProgramUnit(path = path.clone(), mode = cur_mode.clone())
    if mode_disp.len() > 0 {
        mut all_imports2 := Vec(Str).new()
        all_imports2.push(own mode_disp)
        for dep : Str in user_import_disps { all_imports2.push(own dep.clone()) }
        user_unit.imports = all_imports2
    } else {
        user_unit.imports = user_import_disps
    }
    units.push(own user_unit)

    lp.core_units = core_units
    lp.units = units
    lp.cur_mode = cur_mode.clone()

    // lp.ctx.imported is populated during import resolution and for the
    // entrypoint files above.

    lp.skip_core = skip_core
    lp.mode_str = mode_str

    extract_link_info(lp)
    return lp
}

// --- Doc registry synthesis ---

// Escape raw bytes for use as a NodeType.Literal(Literal.Str) text. The interpreter
// (eval_expr in interpreter.til) and the C codegen (Str_lit in builder.til)
// both expect the source-level form: \\, \", \n, \t. Escaping here keeps
// both paths happy when synthesised doc text contains newlines or quotes.
priv escape_doc_for_literal_str := func(raw: Str) returns Str {
    mut out := ""
    for c : I8 in raw {
        if c == '\\' {
            out = format(out, "\\\\")
        } else if c == '"' {
            out = format(out, "\\\"")
        } else if c == 10 {
            out = format(out, "\\n")
        } else if c == 9 {
            out = format(out, "\\t")
        } else {
            out = format(out, Str.from_byte(c.cast(U8)))
        }
    }
    return out
}

// Classify a top-level Decl's FuncType into a kind string.
priv func_kind := func(ft: FuncType) returns Str {
    switch ft {
    case FuncType.Proc:    return "proc"
    case FuncType.Test:    return "test"
    case FuncType.Macro:   return "macro"
    case FuncType.ExtFunc: return "ext_func"
    case FuncType.ExtProc: return "ext_proc"
    case FuncType.CoreFunc: return "core_func"
    case FuncType.CoreProc: return "core_proc"
    case: return "func"
    }
}

// User-facing Type name for help() info strings. "" for Unknown/None.
priv til_type_user := func(t: Type) returns Str {
    switch t {
    case Type.Primitive(Primitive.I64):       return "I64"
    case Type.Primitive(Primitive.U8):        return "U8"
    case Type.Primitive(Primitive.I8):        return "I8"
    case Type.Primitive(Primitive.I16):       return "I16"
    case Type.Primitive(Primitive.U16):       return "U16"
    case Type.Primitive(Primitive.I32):       return "I32"
    case Type.Primitive(Primitive.U32):       return "U32"
    case Type.Primitive(Primitive.U64):       return "U64"
    case Type.Primitive(Primitive.F32):       return "F32"
    case Type.Primitive(Primitive.Bool):      return "Bool"
    case Type.Struct(name):    return name.clone()
    case Type.StructDef:       return "StructDef"
    case Type.Enum(name):      return name.clone()
    case Type.EnumDef:         return "EnumDef"
    case Type.FuncDef:         return "FunctionDef"
    case Type.FuncPtr:         return "Fn"
    case Type.Dynamic:         return "Dynamic"
    case Type.Custom(name):    return name.clone()
    case: return ""
    }
}

// Append "name<0x01>value<0x02>" to packed. 0x01/0x02 are control bytes
// that won't appear in identifiers or /// doc text, so they make safe
// field/record separators for __doc_lookup__ in core/doc.til.
priv append_packed_entry := func(mut packed: Str, name: Str, value: Str) {
    packed.push_str(name)
    packed.push_str(Str.from_byte(1))
    packed.push_str(value)
    packed.push_str(Str.from_byte(2))
}

// Append "[own |ref |shallow ][mut ]" prefix for d, omitting whichever
// ownership the surrounding context already implies.
priv append_qualifier_prefix := func(mut out: Str, d: Declaration, default_own: OwnType) {
    if d.own_type.is(default_own).not() {
        switch d.own_type {
        case OwnType.Own:     out.push_str("own ")
        case OwnType.Ref:     out.push_str("ref ")
        case OwnType.Shallow: out.push_str("shallow ")
        }
    }
    if d.is_mut { out.push_str("mut ") }
}

// Append "(p1: T1, name: ..TN)" plus optional " returns [shallow|ref ]T".
priv append_fn_signature := func(mut out: Str, fd: FunctionDef) {
    out.push_str("(")
    var_idx_i64 : I64 = fd.variadic_index.cast(I64)
    for i in 0..fd.params.len() {
        if i > 0 { out.push_str(", ") }
        ref p : Declaration = fd.params[i]
        is_variadic := i.to_i64() == var_idx_i64
        if is_variadic.not() { append_qualifier_prefix(out, p, OwnType.Ref) }
        out.push_str(p.name)
        if p.explicit_type.len() > 0 {
            out.push_str(": ")
            if is_variadic { out.push_str("..") }
            out.push_str(p.explicit_type)
        }
    }
    out.push_str(")")
    if fd.return_type.len() > 0 {
        out.push_str(" returns ")
        switch fd.return_own_type {
        case OwnType.Shallow: out.push_str("shallow ")
        case OwnType.Ref:     out.push_str("ref ")
        case OwnType.Own:
        }
        out.push_str(fd.return_type)
    }
}

// Append "<indent>/// <line>\n" for each line of doc.
priv append_doc_lines_indented := func(mut out: Str, doc: Str, indent: Str) {
    if doc.is_empty() { return }
    mut start : USize = 0
    for i in 0..doc.len() {
        ref c : I8 = doc.unsafe_get(i)
        if c == 10 {
            out.push_str(indent)
            out.push_str("/// ")
            if i > start { out.push_str(doc.substr(start, i - start)) }
            out.push_str("\n")
            start = i + 1
        }
    }
    out.push_str(indent)
    out.push_str("/// ")
    if start < doc.len() { out.push_str(doc.substr(start, doc.len() - start)) }
    out.push_str("\n")
}

DocMeta := struct {
    body := ""
    group := ""
    since := ""
    deprecated := ""
    hidden := false
}

doc_keyword_value := func(line: Str, key: Str) returns Str {
    trimmed := line.trim()
    if trimmed.starts_with(key).not() { return "" }
    return trimmed.substr(key.len(), trimmed.len() - key.len()).trim().clone()
}

doc_false_value := func(value: Str) returns Bool {
    trimmed := value.trim()
    return trimmed.eq("false").or(trimmed.eq("nil")).or(trimmed.eq("no"))
}

doc_meta_line := func(line: Str, mut meta: DocMeta) returns Bool {
    trimmed := line.trim()
    if trimmed.starts_with("#+doc:") {
        value := doc_keyword_value(trimmed, "#+doc:")
        if doc_false_value(value) { meta.hidden = true }
        return true
    }
    if trimmed.starts_with("#+group:") {
        meta.group = doc_keyword_value(trimmed, "#+group:")
        return true
    }
    if trimmed.starts_with("#+since:") {
        meta.since = doc_keyword_value(trimmed, "#+since:")
        return true
    }
    if trimmed.starts_with("#+deprecated:") {
        meta.deprecated = doc_keyword_value(trimmed, "#+deprecated:")
        return true
    }
    return false
}

parse_doc_meta := func(doc: Str) returns DocMeta {
    mut meta := DocMeta()
    mut body := Str.with_capacity(doc.len())
    mut start : USize = 0
    for i in 0..doc.len() {
        ref c : I8 = doc.unsafe_get(i)
        if c == 10 {
            line := doc.substr(start, i - start)
            if doc_meta_line(line, meta).not() {
                if body.is_empty().not() { body.push_str("\n") }
                body.push_str(line)
            }
            start = i + 1
        }
    }
    if start < doc.len() {
        line := doc.substr(start, doc.len() - start)
        if doc_meta_line(line, meta).not() {
            if body.is_empty().not() { body.push_str("\n") }
            body.push_str(line)
        }
    }
    meta.body = body
    return meta
}

format_doc_for_help := func(doc: Str) returns Str {
    meta := parse_doc_meta(doc)
    if meta.hidden { return "" }
    cap := meta.body.len().add(meta.group.len()).add(meta.since.len()).add(meta.deprecated.len()) + 64
    mut out := Str.with_capacity(cap)
    if meta.since.is_empty().not() { out.push_str("Since: "); out.push_str(meta.since); out.push_str("\n") }
    if meta.deprecated.is_empty().not() { out.push_str("Deprecated: "); out.push_str(meta.deprecated); out.push_str("\n") }
    if meta.group.is_empty().not() { out.push_str("Group: "); out.push_str(meta.group); out.push_str("\n") }
    if out.is_empty().not().and(meta.body.is_empty().not()) { out.push_str("\n") }
    out.push_str(meta.body)
    return out
}

// Append "    [own |ref |shallow ][mut ]name : Type" for a struct field.
priv append_field_indented := func(mut out: Str, d: Declaration) {
    append_doc_lines_indented(out, d.doc, "    ")
    out.push_str("    ")
    append_qualifier_prefix(out, d, OwnType.Shallow)
    out.push_str(d.name)
    if d.explicit_type.len() > 0 {
        out.push_str(" : ")
        out.push_str(d.explicit_type)
    }
}

// Append "    [kind ]name(sig) returns T" for a namespace method.
priv append_ns_method_indented := func(mut out: Str, d: Declaration) {
    append_doc_lines_indented(out, d.doc, "    ")
    out.push_str("    ")
    mut handled := false
    if d.default_value.is_null().not() {
        switch d.default_value.node_type {
        case NodeType.FuncDef(fd):
            out.push_str(func_kind(fd.func_type))
            out.push_str(" ")
            out.push_str(d.name)
            append_fn_signature(out, fd)
            handled = true
        case:
        }
    }
    if handled.not() {
        out.push_str(d.name)
        if d.explicit_type.len() > 0 {
            out.push_str(" : ")
            out.push_str(d.explicit_type)
        }
    }
}

priv format_var_info := func(name: Str, dd: Declaration, scope: TypeScope) returns Str {
    mut t := dd.til_type.clone()
    if t.is(Type.Unknown) { t = scope.get_type(name) }
    type_str := til_type_user(t)
    if type_str.is_empty().not() {
        return name.format(" is a ", type_str)
    }
    if dd.explicit_type.len() > 0 {
        return format(name, " is a ", dd.explicit_type)
    }
    return name
}

priv format_func_info := func(name: Str, fd: FunctionDef) returns Str {
    mut cap : USize = name.len().add(fd.return_type.len()) + 64
    for p : Declaration in fd.params {
        cap = cap.add(p.name.len()).add(p.explicit_type.len()) + 48
    }
    mut out := Str.with_capacity(cap)
    out.push_str(func_kind(fd.func_type))
    out.push_str(" ")
    out.push_str(name)
    append_fn_signature(out, fd)
    return out
}

priv format_struct_info := func(name: Str, sdef: StructDef) returns Str {
    mut cap : USize = name.len() + 128
    for f : Declaration in sdef.fields {
        cap = cap.add(f.name.len()).add(f.explicit_type.len()).add(f.doc.len() * 2) + 128
    }
    for d : Declaration in sdef.ns_decls {
        cap = cap.add(d.name.len()).add(d.doc.len() * 2) + 192
        if d.default_value.is_null().not() {
            switch d.default_value.node_type {
            case NodeType.FuncDef(fd):
                cap = cap.add(fd.return_type.len()) + 48
                for p : Declaration in fd.params {
                    cap = cap.add(p.name.len()).add(p.explicit_type.len()) + 48
                }
            case:
            }
        }
    }
    cap = cap * 2
    mut out := Str.with_capacity(cap)
    out.push_str("struct ")
    out.push_str(name)
    out.push_str(" {")
    for f : Declaration in sdef.fields {
        out.push_str("\n")
        append_field_indented(out, f)
    }
    if sdef.ns_decls.len() > 0 {
        out.push_str("\nnamespace:")
        for d : Declaration in sdef.ns_decls {
            out.push_str("\n")
            append_ns_method_indented(out, d)
        }
    }
    out.push_str("\n}")
    return out
}

priv format_enum_info := func(name: Str, edef: EnumDef) returns Str {
    mut cap : USize = name.len() + 128
    for v : Str in edef.variants {
        cap = cap.add(v.len()) + 96
    }
    for d : Declaration in edef.ns_decls {
        cap = cap.add(d.name.len()).add(d.doc.len() * 2) + 192
        if d.default_value.is_null().not() {
            switch d.default_value.node_type {
            case NodeType.FuncDef(fd):
                cap = cap.add(fd.return_type.len()) + 48
                for p : Declaration in fd.params {
                    cap = cap.add(p.name.len()).add(p.explicit_type.len()) + 48
                }
            case:
            }
        }
    }
    cap = cap * 2
    mut out := Str.with_capacity(cap)
    out.push_str("enum ")
    out.push_str(name)
    out.push_str(" {")
    for i in 0..edef.variants.len() {
        out.push_str("\n    ")
        out.push_str(edef.variants[i])
        if edef.payload_types.has(i.to_i64()) {
            out.push_str(": ")
            out.push_str(edef.payload_types[i.to_i64()])
        }
    }
    if edef.ns_decls.len() > 0 {
        out.push_str("\nnamespace:")
        for d : Declaration in edef.ns_decls {
            out.push_str("\n")
            append_ns_method_indented(out, d)
        }
    }
    out.push_str("\n}")
    return out
}

// Build the rich info string for a top-level Decl.
format_decl_info := func(stmt: Expr, scope: TypeScope) returns Str {
    switch stmt.node_type {
    case NodeType.Decl(dd):
        if stmt.children.len() == 0 {
            return format_var_info(dd.name, dd, scope)
        }
        ref rhs : Expr = stmt.children[0]
        switch rhs.node_type {
        case NodeType.StructDef(sdef): return format_struct_info(dd.name, sdef)
        case NodeType.EnumDef(edef):   return format_enum_info(dd.name, edef)
        case NodeType.FuncDef(fd):     return format_func_info(dd.name, fd)
        case:                          return format_var_info(dd.name, dd, scope)
        }
    case:
        return ""
    }
}

// Append "Type.method" qualified entry for a single namespace method.
priv collect_member_method_packed := func(type_name: Str, d: Declaration, mut info: Str, mut docs: Str) {
    qual := type_name.format(".", d.name)
    mut info_cap : USize = qual.len() + 64
    mut is_func := false
    if d.default_value.is_null().not() {
        switch d.default_value.node_type {
        case NodeType.FuncDef(fd):
            is_func = true
            info_cap = info_cap.add(fd.return_type.len()) + 48
            for p : Declaration in fd.params {
                info_cap = info_cap.add(p.name.len()).add(p.explicit_type.len()) + 48
            }
        case:
        }
    }
    if is_func.not() {
        info_cap = info_cap.add(d.explicit_type.len()) + 8
    }
    mut method_info := Str.with_capacity(info_cap)
    if is_func {
        switch d.default_value.node_type {
        case NodeType.FuncDef(fd):
            method_info.push_str(func_kind(fd.func_type))
            method_info.push_str(" ")
            method_info.push_str(qual)
            append_fn_signature(method_info, fd)
        case:
        }
    } else {
        method_info.push_str("member ")
        method_info.push_str(qual)
        if d.explicit_type.len() > 0 {
            method_info.push_str(" : ")
            method_info.push_str(d.explicit_type)
        }
    }
    append_packed_entry(info, qual, method_info)
    if d.doc.is_empty().not() {
        help_doc := format_doc_for_help(d.doc)
        if help_doc.is_empty().not() {
            append_packed_entry(docs, qual, help_doc)
        }
    }
}

// Register "Type.field" entries for each struct field, plus "Type.method"
// entries for each namespace method.
priv collect_struct_members_packed := func(type_name: Str, sdef: StructDef, mut info: Str, mut docs: Str) {
    for f : Declaration in sdef.fields {
        qual := type_name.format(".", f.name)
        mut field_info := Str.with_capacity(qual.len().add(f.explicit_type.len()) + 64)
        field_info.push_str("field ")
        append_qualifier_prefix(field_info, f, OwnType.Shallow)
        field_info.push_str(qual)
        if f.explicit_type.len() > 0 {
            field_info.push_str(" : ")
            field_info.push_str(f.explicit_type)
        }
        append_packed_entry(info, qual, field_info)
        if f.doc.is_empty().not() {
            help_doc := format_doc_for_help(f.doc)
            if help_doc.is_empty().not() {
                append_packed_entry(docs, qual, help_doc)
            }
        }
    }
    for d : Declaration in sdef.ns_decls {
        collect_member_method_packed(type_name, d, info, docs)
    }
}

// Register "Type.Variant" entries for each enum variant, plus
// "Type.method" entries for each namespace method.
priv collect_enum_members_packed := func(type_name: Str, edef: EnumDef, mut info: Str, mut docs: Str) {
    for i in 0..edef.variants.len() {
        qual := type_name.format(".", edef.variants[i])
        mut variant_info := Str.with_capacity(qual.len() + 64)
        variant_info.push_str("variant ")
        variant_info.push_str(qual)
        if edef.payload_types.has(i.to_i64()) {
            variant_info.push_str(": ")
            variant_info.push_str(edef.payload_types[i.to_i64()])
        }
        append_packed_entry(info, qual, variant_info)
    }
    for d : Declaration in edef.ns_decls {
        collect_member_method_packed(type_name, d, info, docs)
    }
}

// Walk a Body's top-level Decls. For each Decl append (name, info) into
// `info` and (name, doc) into `docs` if Declaration.doc is non-empty.
// Struct/enum members are also registered under qualified names.
collect_decl_packed := func(body: Expr, scope: TypeScope, mut info: Str, mut docs: Str) {
    for stmt : Expr in body.children {
        switch stmt.node_type {
        case NodeType.Decl(dd):
            entry_info := format_decl_info(stmt, scope)
            if entry_info.is_empty().not() {
                append_packed_entry(info, dd.name, entry_info)
            }
            if dd.doc.is_empty().not() {
                help_doc := format_doc_for_help(dd.doc)
                if help_doc.is_empty().not() {
                    append_packed_entry(docs, dd.name, help_doc)
                }
            }
            if stmt.children.len() > 0 {
                switch stmt.children[0].node_type {
                case NodeType.StructDef(sdef):
                    collect_struct_members_packed(dd.name, sdef, info, docs)
                case NodeType.EnumDef(edef):
                    collect_enum_members_packed(dd.name, edef, info, docs)
                case:
                }
            }
        case:
        }
    }
}

// Wrap pre-built packed info/docs blobs into a __doc_init__("...","...")
// source line. Returns "" if both blobs are empty.
build_doc_init_line := func(packed_info: Str, packed_docs: Str) returns Str {
    if packed_info.is_empty().and(packed_docs.is_empty()) { return "" }
    esc_info := escape_doc_for_literal_str(packed_info)
    esc_docs := escape_doc_for_literal_str(packed_docs)
    return format("__doc_init__(\"", esc_info, "\", \"", esc_docs, "\")\n")
}

// Same as build_doc_init_line, but the core blobs are already escaped by the
// generated REPL doc cache. Only user blobs are escaped on each REPL turn.
build_doc_init_line_cached := func(escaped_core_info: Str, escaped_core_docs: Str, packed_user_info: Str, packed_user_docs: Str) returns Str {
    if escaped_core_info.is_empty().and(escaped_core_docs.is_empty()).and(packed_user_info.is_empty()).and(packed_user_docs.is_empty()) { return "" }
    esc_user_info := escape_doc_for_literal_str(packed_user_info)
    esc_user_docs := escape_doc_for_literal_str(packed_user_docs)
    return format("__doc_init__(\"", escaped_core_info, esc_user_info, "\", \"", escaped_core_docs, esc_user_docs, "\")\n")
}

build_doc_init_line_cache_files := func(core_info_path: Str, core_docs_path: Str, packed_user_info: Str, packed_user_docs: Str) returns Str {
    esc_info_path := escape_doc_for_literal_str(core_info_path)
    esc_docs_path := escape_doc_for_literal_str(core_docs_path)
    esc_user_info := escape_doc_for_literal_str(packed_user_info)
    esc_user_docs := escape_doc_for_literal_str(packed_user_docs)
    return format("doc_init_cache_files(\"", esc_info_path, "\", \"", esc_docs_path, "\", \"", esc_user_info, "\", \"", esc_user_docs, "\")\n")
}

ReplCoreDocCache := struct {
    escaped_info := ""
    escaped_docs := ""
}

build_repl_core_doc_cache := func(lp: LoadedProgram) returns ReplCoreDocCache {
    mut core_merged := Expr.new(NodeType.Body, 0, 0)
    for u : ProgramUnit in lp.core_units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        for stmt : Expr in iu.ast.children { core_merged.add_child(own stmt.clone()) }
    }
    mut packed_info := Str.with_capacity(262144)
    mut packed_docs := Str.with_capacity(262144)
    collect_decl_packed(core_merged, lp.ctx.scope, packed_info, packed_docs)
    return ReplCoreDocCache(
        escaped_info = escape_doc_for_literal_str(packed_info),
        escaped_docs = escape_doc_for_literal_str(packed_docs))
}

// Run init/typecheck/constfolder/scavenge on the loaded program. Sets
// lp.run_tests and exits with code 1 if the typer reports any errors.
// Run init + typer + field-struct resolution. Stops short of constfolder and
// scavenge so callers that only need a typed AST (e.g. `til doc`) don't pay
// the codegen-prep cost.
// Namespace import decl form: `name := import("x")` makes `name` a
// QUALIFIED ALIAS for x's public top-level decls -- every `name.sym`
// use in the importing unit is rewritten (rewrite_ns_alias_uses) into a
// direct reference to the original `sym`, and the decl itself is
// dropped. The previous implementation instead synthesized a local ns
// struct holding CLONES of every pub decl; the clones were typed in the
// IMPORTING file, so a pub decl whose body referenced a priv sibling of
// its own file broke (priv names are file-keyed), and every alias
// duplicated the imported bodies in the binary. With an explicit symbol
// list (`name := import("x", a, b)`) only the listed symbols are
// rewritable; each listed symbol is validated to exist in x.
priv desugar_one_import := func(mut imp_stmt: Expr, decl_name: Str, ctx: Context, resolved_path: Str, mut ns_alias_names: Set(Str), mut ns_alias_members: Set(Str), mut ns_alias_paths: Map(Str, Str)) returns Bool {
    mut handled := false
    if imp_stmt.children.len() >= 1 {
        switch imp_stmt.children[0].node_type {
        case NodeType.Ident(id):
            if id.ident_name() == "import" {
                if imp_stmt.children.len() > 1 {
                    mut path := ""
                    switch imp_stmt.children[1].node_type {
                    case NodeType.Literal(Literal.Str(p)):
                        path = format(p, ".til")
                    case:
                    }

                    if path.len() > 0 {
                        mut exp_symbols := Vec(Str).new()
                        if imp_stmt.children.len() > 2 {
                            for arg_i in 2..imp_stmt.children.len() {
                                switch imp_stmt.children[arg_i].node_type {
                                case NodeType.Ident(sym_id):
                                    exp_symbols.push(own Str.clone(sym_id.ident_name()))
                                case:
                                }
                            }
                        } else {
                            if ctx.imported.has(resolved_path) {
                                ref iu : ImportUnit = ctx.imported[resolved_path]
                                if iu.is_null().not() {
                                    for child : Expr in iu.ast.children {
                                        if child.node_type.is(NodeType.Decl) {
                                            switch child.node_type {
                                            case NodeType.Decl(dd):
                                                if dd.is_priv.not() {
                                                    exp_symbols.push(own dd.name.clone())
                                                }
                                            case:
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        handled = true
                        if ctx.imported.has(resolved_path) {
                            ref iu : ImportUnit = ctx.imported[resolved_path]
                            if iu.is_null().not() {
                                for sym : Str in exp_symbols {
                                    mut found := false
                                    for dd : Expr in iu.ast.children {
                                        switch dd.node_type {
                                        case NodeType.Decl(cd):
                                            if cd.name == sym { found = true }
                                        case:
                                        }
                                        if found { break }
                                    }
                                    if found.not() {
                                        imp_stmt.error(resolved_path, format("symbol '", sym, "' not found in '", resolved_path, "'"))
                                        return false
                                    }
                                    // Members keyed "alias|member" (til's
                                    // parser rejects nested generics like
                                    // Map(Str, Set(Str)) in param types).
                                    ns_alias_members.add(own format(decl_name, "|", sym))
                                }
                            }
                        }
                        ns_alias_names.add(own decl_name.clone())
                        ns_alias_paths.set(decl_name, own resolved_path.clone())
                    }
                }
            }
        case:
        }
    }
    return handled
}

// Collect the binder names a switch-case pattern introduces for its
// body: the plain-Ident payload args of (possibly nested) FCall
// patterns, e.g. `p` in `case NodeType.Literal(Literal.Str(p)):`.
priv collect_case_pattern_binders := func(pat: Expr, mut out: Set(Str)) {
    if pat.node_type.is(NodeType.FCall).not() { return }
    for ai in 1..pat.children.len() {
        ref a : Expr = pat.children[ai]
        switch a.node_type {
        case NodeType.Ident(bid):
            out.add(own Str.clone(bid.ident_name()))
        case NodeType.FCall:
            collect_case_pattern_binders(a, out)
        case:
        }
    }
}

// Rewrite-or-recurse for one child slot: if it is an `alias.sym`
// FieldAccess whose base names a (non-shadowed) namespace-import alias,
// replace it with a direct `sym` Ident; a member outside the alias's
// public set is a load-time error (same stage as the selective-import
// symbol-not-found error). Anything else recurses.
priv ns_alias_rewrite_child := func(mut e: Expr, i: USize, alias_names: Set(Str), alias_members: Set(Str), alias_paths: Map(Str, Str), path: Str, shadowed: Set(Str)) {
    ref mut c : Expr = e.children[i]
    mut alias_name := ""
    mut member := ""
    switch c.node_type {
    case NodeType.FieldAccess(fan):
        if c.children.len() > 0 {
            switch c.children[0].node_type {
            case NodeType.Ident(base_id):
                if alias_names.has(base_id.ident_name()).and(shadowed.has(base_id.ident_name()).not()) {
                    alias_name = Str.clone(base_id.ident_name())
                    member = Str.clone(fan.field_access_name())
                }
            case:
            }
        }
    case:
    }
    if alias_name.len() > 0 {
        if alias_members.has(format(alias_name, "|", member)).not() {
            loc := format(path, ":", c.line.to_str(), ":", c.col.to_str())
            panic("no public symbol '", member, "' in namespace import '",
                alias_name, "' of '", alias_paths[alias_name], "'", loc = loc)
        }
        mut idn := Expr.new(ident_node(member), c.line, c.col)
        // Vec.set deep-deletes the replaced FieldAccess subtree.
        e.children[i] = idn
    } else {
        rewrite_ns_alias_uses(c, alias_names, alias_members, alias_paths, path, shadowed)
    }
}

// Rewrite every `alias.sym` FieldAccess whose base is a namespace-import
// alias into a direct `sym` reference. Walks ns_decls / field defaults /
// param defaults explicitly since those Exprs live outside e.children.
// `shadowed` tracks names rebound by an enclosing binder -- function
// params/captures, body locals (from their decl point onward), for-in
// loop vars, switch-case payload binders, and catch vars -- so a local
// that shadows the alias name is left alone.
priv rewrite_ns_alias_uses := func(mut e: Expr, alias_names: Set(Str), alias_members: Set(Str), alias_paths: Map(Str, Str), path: Str, shadowed: Set(Str)) {
    switch e.node_type {
    case NodeType.StructDef(sdd):
        for mut fd : Declaration in sdd.fields {
            if fd.default_value.is_null().not() {
                rewrite_ns_alias_uses(fd.default_value, alias_names, alias_members, alias_paths, path, shadowed)
            }
        }
        for mut nd : Declaration in sdd.ns_decls {
            if nd.default_value.is_null().not() {
                rewrite_ns_alias_uses(nd.default_value, alias_names, alias_members, alias_paths, path, shadowed)
            }
        }
        return
    case NodeType.EnumDef(edd):
        for mut nd2 : Declaration in edd.ns_decls {
            if nd2.default_value.is_null().not() {
                rewrite_ns_alias_uses(nd2.default_value, alias_names, alias_members, alias_paths, path, shadowed)
            }
        }
        return
    case NodeType.FuncDef(fdd):
        for mut pd : Declaration in fdd.params {
            if pd.default_value.is_null().not() {
                rewrite_ns_alias_uses(pd.default_value, alias_names, alias_members, alias_paths, path, shadowed)
            }
        }
        mut fn_shadow := shadowed.clone()
        for pd2 : Declaration in fdd.params {
            fn_shadow.add(own pd2.name.clone())
        }
        for cap : Declaration in fdd.captures {
            fn_shadow.add(own cap.name.clone())
        }
        for fi in 0..e.children.len() {
            ns_alias_rewrite_child(e, fi, alias_names, alias_members, alias_paths, path, fn_shadow)
        }
        return
    case NodeType.Body:
        // Locals shadow from their decl point onward, so extend the set
        // AFTER each Decl child is walked (its RHS still sees the alias).
        mut body_shadow := shadowed.clone()
        for bi in 0..e.children.len() {
            ns_alias_rewrite_child(e, bi, alias_names, alias_members, alias_paths, path, body_shadow)
            switch e.children[bi].node_type {
            case NodeType.Decl(bd):
                body_shadow.add(own bd.name.clone())
            case:
            }
        }
        return
    case NodeType.ForIn(fid):
        if e.children.len() >= 2 {
            ns_alias_rewrite_child(e, 0, alias_names, alias_members, alias_paths, path, shadowed)
            mut loop_shadow := shadowed.clone()
            loop_shadow.add(own fid.name.clone())
            if fid.name2.len() > 0 { loop_shadow.add(own fid.name2.clone()) }
            ns_alias_rewrite_child(e, 1, alias_names, alias_members, alias_paths, path, loop_shadow)
            return
        }
    case NodeType.Case:
        // [pattern, body]: payload binders in the pattern shadow the body.
        if e.children.len() == 2 {
            ns_alias_rewrite_child(e, 0, alias_names, alias_members, alias_paths, path, shadowed)
            mut case_shadow := shadowed.clone()
            collect_case_pattern_binders(e.children[0], case_shadow)
            ns_alias_rewrite_child(e, 1, alias_names, alias_members, alias_paths, path, case_shadow)
            return
        }
    case NodeType.Catch:
        // [var Ident, type Ident, body]: the err var shadows the body.
        if e.children.len() >= 3 {
            mut catch_shadow := shadowed.clone()
            switch e.children[0].node_type {
            case NodeType.Ident(cvid):
                catch_shadow.add(own Str.clone(cvid.ident_name()))
            case:
            }
            ns_alias_rewrite_child(e, 2, alias_names, alias_members, alias_paths, path, catch_shadow)
            return
        }
    case:
    }
    for i in 0..e.children.len() {
        ns_alias_rewrite_child(e, i, alias_names, alias_members, alias_paths, path, shadowed)
    }
}

priv desugar_namespace_imports := func(path: Str, mut iu: ImportUnit, ctx: Context) {
    mut old := Vec(Expr).new()
    old.move_from(iu.ast.children)
    mut new_ch := Vec(Expr).new()
    mut imp_idx : USize = 0
    mut ns_alias_names := Set(Str).new()
    mut ns_alias_members := Set(Str).new()
    mut ns_alias_paths := Map(Str, Str).new()

    for i in 0..old.len() {
        ref stmt : Expr = old[i]

        mut is_imp := false
        mut is_decl_rhs := false
        mut decl_name := ""

        if stmt.node_type.is(NodeType.FCall) {
            is_imp = true
        } else if stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0)) {
            if stmt.children[0].node_type.is(NodeType.FCall) {
                is_imp = true
                is_decl_rhs = true
                switch stmt.node_type {
                case NodeType.Decl(dd):
                    decl_name = dd.name.clone()
                case:
                }
            }
        }

        mut handled := false
        if is_imp {
            mut is_valid_import := false
            if is_decl_rhs {
                ref imp_stmt_ref : Expr = stmt.children[0]
                if imp_stmt_ref.children.len() >= 2 {
                    switch imp_stmt_ref.children[0].node_type {
                    case NodeType.Ident(id):
                        if id.ident_name() == "import" {
                            switch imp_stmt_ref.children[1].node_type {
                            case NodeType.Literal(Literal.Str(_p)):
                                is_valid_import = true
                            case:
                            }
                        }
                    case:
                    }
                }
            } else {
                ref imp_stmt_ref : Expr = stmt
                if imp_stmt_ref.children.len() >= 2 {
                    switch imp_stmt_ref.children[0].node_type {
                    case NodeType.Ident(id):
                        if id.ident_name() == "import" {
                            switch imp_stmt_ref.children[1].node_type {
                            case NodeType.Literal(Literal.Str(_p)):
                                is_valid_import = true
                            case:
                            }
                        }
                    case:
                    }
                }
            }

            if is_valid_import {
                mut resolved := ""
                if imp_idx < iu.imports.len() {
                    resolved = iu.imports[imp_idx].clone()
                }
                imp_idx++
                if is_decl_rhs.and(decl_name.starts_with("_")) {
                    // #154: `_name := import(...)` is the unused-import
                    // opt-out. The alias is deliberately never read, so
                    // no rewrite map entry is needed. The file itself
                    // stays loaded (the loader resolved it already); only
                    // the decl is dropped.
                    handled = true
                } else if is_decl_rhs {
                    handled = desugar_one_import(stmt.children[0], decl_name, ctx, resolved, ns_alias_names, ns_alias_members, ns_alias_paths)
                }
                // Bare import stmts are kept as-is; the loader already
                // resolved them and the typer walks them for recursion.
            }
        }

        if handled.not() {
            new_ch.push_take(old, i)
        }
    }

    // Second pass: rewrite `alias.sym` uses in the kept statements into
    // direct references to the original decls.
    if ns_alias_names.len() > 0 {
        no_shadows := Set(Str).new()
        for j in 0..new_ch.len() {
            rewrite_ns_alias_uses(new_ch[j], ns_alias_names, ns_alias_members, ns_alias_paths, path, no_shadows)
        }
    }

    iu.ast.children.move_from(new_ch)
}

// Issue #262: lazy_func / lazy_proc inlining.
//
// A lazy callable's body is a single `return <expr>`. A call f(a1..an), or
// UFCS-style a1.f(a2..an), is rewritten here -- before type-checking -- by
// cloning <expr> and substituting each parameter Ident with the matching
// argument expression (call-by-name). When <expr> is a `match` (the
// short-circuit form), only the taken arm is evaluated at run time, so unused
// arguments never run.
// The lazy defs themselves are left in place: the typer checks them and
// (being uncalled after inlining) they emit as ordinary dead functions,
// exactly like macros.
//
// Scope: top-level lazy callables, called by bare name or UFCS method
// syntax, non-recursive. Fixed-arity calls inline directly; a binary lazy
// callable (and/or) called with more than two args right-folds into nested
// binary calls first (Lisp-style N-ary and/or). Declared-variadic, first-
// class, and recursive lazy callables are deferred (issue #262). A call that
// does not match a supported shape is left un-inlined and types as an
// ordinary (eager) call.

priv lazy_substitute_idents := func(mut e: Expr, subs: Map(Str, Expr)) {
    expect(e.is_null().not(), "e is null")
    for i in 0..e.children.len() {
        ref c : Expr = e.children[i]
        mut replaced := false
        switch c.node_type {
        case NodeType.Ident(idn):
            ref nm : Str = idn.ident_name()
            if subs.has(nm) {
                // Substitute through the parent slot: Vec.set deep-deletes
                // the old Ident (issue #272; replaces Expr.replace_with).
                ref repl : Expr = subs[nm]
                e.children[i] = repl.clone()
                replaced = true
            }
        case:
        }
        if replaced.not() { lazy_substitute_idents(c, subs) }
    }
}

// The value of a single-`return` body `{ return <expr> }`, else NULL.
priv lazy_single_return_value := func(body: Expr) returns Expr {
    if body.node_type.is(NodeType.Body).not() { return NULL }
    if body.children.len().eq(1).not() { return NULL }
    ref ret : Expr = body.children[0]
    if ret.node_type.is(NodeType.Return).not() { return NULL }
    if ret.children.len() < 1 { return NULL }
    return ret.children[0].clone()
}

// Build `match cond { case true: x case: y }`. Takes ownership of cond/x/y.
priv lazy_make_bool_match := func(own cond: Expr, own x: Expr, own y: Expr, line: U32, col: U32) returns Expr {
    mut m := Expr.new(NodeType.Match(MatchData()), line, col)
    m.add_child(own cond)                                    // subject
    // case true: x
    mut c1 := Expr.new(NodeType.Case, line, col)
    c1.add_child(own Expr.new(NodeType.Literal(Literal.Bool(true)), line, col))
    mut b1 := Expr.new(NodeType.Body, line, col)
    b1.add_child(own x)
    c1.add_child(own b1)
    m.add_child(own c1)
    // case: y  (default arm catches false)
    mut c2 := Expr.new(NodeType.Case, line, col)
    mut b2 := Expr.new(NodeType.Body, line, col)
    b2.add_child(own y)
    c2.add_child(own b2)
    m.add_child(own c2)
    return m
}

// Fold a guard chain `if c_i { return X_i } ... return Y` into nested matches,
// from guard i to the trailing return at n-1. Recursive so no loop-carried
// ownership transfer is needed.
priv lazy_build_guard_chain := func(body: Expr, i: USize, n: USize) returns Expr {
    if i.eq(n - 1) {
        // the trailing `return Y`
        return body.children[n - 1].children[0].clone()
    }
    ref g : Expr = body.children[i]               // `if cond { return X }`
    gx := lazy_single_return_value(g.children[1])
    inner := lazy_build_guard_chain(body, i + 1, n)
    return lazy_make_bool_match(own g.children[0].clone(), own gx, own inner, g.line, g.col)
}

// The expression a lazy body inlines to, freshly owned, or NULL when the body
// shape is not inlinable. Mirrors lazy_body_inlinable (src/core/ast.til):
//   { return <expr> }                          -> <expr>
//   { if cond { return X } else { return Y } }  -> match cond { true: X : Y }
//   { if c1 {return X1} ... if ck {return Xk} return Y }  -> nested match
// The if/else and guard-chain forms become `match` so they inline and
// short-circuit (til's `if` is a statement, not a value-expression). Other
// shapes (locals, loops, ...) return NULL; those need the thunk fallback.
priv lazy_body_as_expr := func(body: Expr) returns Expr {
    if lazy_body_inlinable(body).not() { return NULL }
    n := body.children.len()
    ref last : Expr = body.children[n - 1]
    if n.eq(1) {
        switch last.node_type {
        case NodeType.Return:
            return last.children[0].clone()
        case NodeType.If:
            x := lazy_single_return_value(last.children[1])
            y := lazy_single_return_value(last.children[2])
            return lazy_make_bool_match(own last.children[0].clone(), own x, own y, last.line, last.col)
        case:
            return NULL
        }
    }
    return lazy_build_guard_chain(body, 0, n)
}

// Returns true if the call was inlined. Leaves `call` untouched (and
// returns false) for any shape v1 does not handle, so the residual call
// types as an ordinary eager call.
priv inline_lazy_call := func(mut parent: Expr, call_idx: USize, fdef: Expr) returns Bool {
    ref call : Expr = parent.children[call_idx]
    if fdef.children.len() == 0 { return false }
    ref body : Expr = fdef.children[0]

    mut subs := Map(Str, Expr).new()
    mut ok := false
    mut is_method_call := false
    ref call_callee : Expr = call.children[0]
    switch call_callee.node_type {
    case NodeType.FieldAccess:
        is_method_call = call_callee.children.len() == 1
    case:
    }
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        if fd.variadic_index < 0 {
            mut nargs := call.children.len() - 1
            if is_method_call { nargs = call.children.len() }
            if nargs == fd.params.len() {
                for j in 0..fd.params.len() {
                    ref param : Declaration = fd.params[j]
                    if is_method_call.and(j.eq(0)) {
                        subs.set(param.name, own call_callee.children[0].clone())
                    } else {
                        mut arg_idx := j + 1
                        if is_method_call { arg_idx = j }
                        subs.set(param.name, own call.children[arg_idx].clone())
                    }
                }
                ok = true
            }
        }
    case:
    }
    if ok.not() { return false }

    mut cloned := lazy_body_as_expr(body)
    if cloned.is_null() { return false }
    // A bare-Ident body (`return x`) is the whole expression: the walk
    // below only substitutes CHILDREN, so swap the root here. Plain
    // assignment reclaims the first clone (save_old_delete).
    mut root_name := ""
    switch cloned.node_type {
    case NodeType.Ident(root_idn): root_name = Str.clone(root_idn.ident_name())
    case:
    }
    if root_name.len().gt(0).and(subs.has(root_name)) {
        cloned = subs[root_name].clone()
    } else {
        lazy_substitute_idents(cloned, subs)
    }
    parent.children[call_idx] = cloned
    return true
}

// Clone the k-th effective argument of a (possibly UFCS) call. For a method
// call the receiver is effective arg 0 and the explicit args follow; for a
// bare call the explicit args are the effective args.
priv lazy_eff_arg_clone := func(call: Expr, is_method: Bool, k: USize) returns Expr {
    if is_method {
        if k == 0 { return call.children[0].children[0].clone() }
        return call.children[k].clone()
    }
    return call.children[k + 1].clone()
}

// Substitution map for one unrolled statement of a variadic lazy call: the
// fixed params (before the variadic) map to their call-site argument
// expressions, and -- when `loop_var` is non-empty -- the loop variable maps
// to effective operand `k`. Built fresh per statement from the call, so each
// spliced expression is an independent clone and a single substitution pass
// suffices (no second walk that could capture names inside spliced operands).
priv lazy_variadic_subs := func(call: Expr, is_method: Bool, fdef: Expr,
        nfixed: USize, loop_var: Str, k: USize) returns Map(Str, Expr) {
    mut subs := Map(Str, Expr).new()
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        for j in 0..nfixed {
            ref param : Declaration = fd.params[j]
            subs.set(param.name, own lazy_eff_arg_clone(call, is_method, j))
        }
    case:
    }
    if loop_var.len() > 0 {
        subs.set(loop_var, own lazy_eff_arg_clone(call, is_method, k))
    }
    return subs
}

// Issue #262: genuinely-variadic lazy callables (vand/vor). A lazy def with a
// trailing variadic param whose body passes lazy_variadic_body_unrollable
// (src/core/ast.til: the param is consumed only by `for <v> in xs { <guards> }`
// loops) is unrolled at each call site over the compile-time-known operand
// list: every such loop becomes its guard statements repeated once per
// operand with <v> substituted by the operand expression (call-by-name), and
// the resulting guard chain is spliced as nested short-circuit matches via
// lazy_body_as_expr -- exactly like any other inlinable lazy body. A later
// operand is therefore evaluated only if every earlier guard fell through.
// Zero runtime cost: no thunks, and no operand collection is ever built.
// Returns true if the call was replaced; false leaves it untouched (e.g. too
// few fixed args), where the residual call fails arity checking in the typer.
priv inline_variadic_lazy_call := func(mut parent: Expr, call_idx: USize, fdef: Expr) returns Bool {
    ref call : Expr = parent.children[call_idx]
    if fdef.children.len() == 0 { return false }
    ref body : Expr = fdef.children[0]

    mut vidx : I32 = -1
    mut nparams : USize = 0
    mut vname := ""
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        if fd.kwargs_index >= 0 { return false }
        vidx = fd.variadic_index
        nparams = fd.params.len()
        if vidx >= 0 { vname = fd.params[vidx.to_usize()].name.clone() }
    case:
        return false
    }
    if vidx < 0 { return false }
    if vidx.to_usize() != nparams - 1 { return false }   // variadic must be last
    if lazy_variadic_body_unrollable(body, vname).not() { return false }

    mut is_method := false
    ref call_callee : Expr = call.children[0]
    switch call_callee.node_type {
    case NodeType.FieldAccess:
        is_method = call_callee.children.len() == 1
    case:
    }
    mut eff_count : USize = call.children.len() - 1
    if is_method { eff_count = call.children.len() }
    nfixed := nparams - 1
    if eff_count < nfixed { return false }

    // Unroll: each `for <v> in <vname>` loop becomes its guards once per
    // operand; other statements (guards, the final return) pass through.
    // All substitution happens here, per cloned statement, so lazy_body_as_expr
    // gets a fully-substituted guard chain and no further walk is needed.
    mut unrolled := Expr.new(NodeType.Body, call.line, call.col)
    for si in 0..body.children.len() {
        ref stmt : Expr = body.children[si]
        mut handled := false
        switch stmt.node_type {
        case NodeType.ForIn(fid):
            for k in nfixed..eff_count {
                opnd_subs := lazy_variadic_subs(call, is_method, fdef, nfixed, fid.name, k)
                for gj in 0..stmt.children[1].children.len() {
                    mut guard := stmt.children[1].children[gj].clone()
                    lazy_substitute_idents(guard, opnd_subs)
                    unrolled.add_child(own guard)
                }
            }
            handled = true
        case:
        }
        if handled.not() {
            fixed_subs := lazy_variadic_subs(call, is_method, fdef, nfixed, "", 0)
            mut cst := stmt.clone()
            lazy_substitute_idents(cst, fixed_subs)
            unrolled.add_child(own cst)
        }
    }

    cloned := lazy_body_as_expr(unrolled)
    expect(cloned.is_null().not(),
        "variadic lazy unroll produced a non-inlinable body despite lazy_variadic_body_unrollable")
    parent.children[call_idx] = cloned
    return true
}

// Issue #262: the RECURSIVE (Haskell-style) form of a variadic lazy callable.
// GHC's Prelude defines `and (x:xs) = x && and xs`; til's equivalent is
//   vand := lazy_func(xs: ..Bool) returns Bool {
//       return match xs {
//       case []:        true
//       case [x, ..tl]: match x { case true: vand(..tl) case: false }
//       }
//   }
// The body is a single `return match <xs> { ... }` with exactly two arms: an
// empty-list-pattern base case and a head/tail cons case whose value contains
// exactly one recursive tail call `self(..tl)` (an is_splat FCall of the tail
// ident). Each call site is unrolled bottom-up over its compile-time-known
// operands: expand(k) = base-arm value at k == N, else the cons-arm value with
// head -> operand k and the tail call replaced by expand(k+1). Call-by-name,
// zero runtime cost, and the author -- not the compiler -- defines the fold
// shape and base case, so nothing assumes associativity.

// Count value-uses of identifier `name` in `e` (Ident reads + Assign targets).
priv lazy_count_ident_uses := func(e: Expr, name: Str) returns USize {
    mut n : USize = 0
    switch e.node_type {
    case NodeType.Ident(idd):  if idd.ident_name() == name { n = n.add(1) }
    case NodeType.Assign(ad):  if ad.name == name { n = n.add(1) }
    case:
    }
    for c : Expr in e.children {
        n = n.add(lazy_count_ident_uses(c, name))
    }
    return n
}

// True if `e` is a recursive tail splat call `<callee>(..tail_name)`: an
// is_splat FCall with exactly one argument, the bare Ident `tail_name`.
priv lazy_is_tail_splat_call := func(e: Expr, tail_name: Str) returns Bool {
    switch e.node_type {
    case NodeType.FCall(fcd):
        if fcd.is_splat.not() { return false }
        if e.children.len() != 2 { return false }
        switch e.children[1].node_type {
        case NodeType.Ident(arg_id): return arg_id.ident_name() == tail_name
        case: return false
        }
    case: return false
    }
}

priv lazy_count_tail_splat_calls := func(e: Expr, tail_name: Str) returns USize {
    mut n : USize = 0
    if lazy_is_tail_splat_call(e, tail_name) { n = 1 }
    for c : Expr in e.children {
        n = n.add(lazy_count_tail_splat_calls(c, tail_name))
    }
    return n
}

// The Match node of a recursive variadic lazy body `{ return match <vname>
// { ... } }`, or NULL when the body does not have that outer shape.
priv lazy_recursive_body_match := func(body: Expr, vname: Str) returns ref Expr {
    if body.node_type.is(NodeType.Body).not() { return NULL }
    if body.children.len() != 1 { return NULL }
    ref ret : Expr = body.children[0]
    if ret.node_type.is(NodeType.Return).not().or(ret.children.len() != 1) { return NULL }
    ref m : Expr = ret.children[0]
    if m.node_type.is(NodeType.Match).not() { return NULL }
    if m.children.len() != 3 { return NULL }   // scrutinee + exactly 2 cases
    switch m.children[0].node_type {
    case NodeType.Ident(scrn):
        if scrn.ident_name().eq(vname).not() { return NULL }
    case: return NULL
    }
    return m
}

// The Case child of `m` whose pattern is a ListPattern with `arity` children
// (0 = the `[]` base case, 2 = the `[h, ..t]` cons case), or NULL. A guard
// (3-child Case) disqualifies the arm, as does an arm body that is not the
// parser's single-value Body wrapper (match arms parse as [pattern,
// Body(value)] -- see parse_case_head's caller in parse_primary).
priv lazy_recursive_arm := func(m: Expr, arity: USize) returns ref Expr {
    for i in 1..m.children.len() {
        ref cs : Expr = m.children[i]
        if cs.node_type.is(NodeType.Case).not() { continue }
        if cs.children.len() != 2 { continue }
        ref pat : Expr = cs.children[0]
        if pat.node_type.is(NodeType.ListPattern).and(pat.children.len().eq(arity)) {
            ref ab : Expr = cs.children[1]
            if ab.node_type.is(NodeType.Body).and(ab.children.len().eq(1)) {
                return cs
            }
        }
    }
    return NULL
}

// The value expression of a recursive arm: unwrap the parser's single-value
// Body wrapper (splicing the Body itself would put a statement list in
// expression position).
priv lazy_recursive_arm_value := func(arm: Expr) returns ref Expr {
    return arm.children[1].children[0]
}

// The Switch node of the STATEMENT (if/else) recursive form `{ switch <vname>
// { ... } }`, or NULL. Same []/[h, ..t] discrimination as the match form, but
// the arms are statement bodies (guards + returns) instead of single value
// expressions -- the til-native if/else spelling, since `if` is a statement:
//   switch xs {
//   case []: return true
//   case [x, ..tl]:
//       if x.not() { return false }
//       return vand(..tl)
//   }
priv lazy_recursive_body_switch := func(body: Expr, vname: Str) returns ref Expr {
    if body.node_type.is(NodeType.Body).not() { return NULL }
    if body.children.len() != 1 { return NULL }
    ref sw : Expr = body.children[0]
    if sw.node_type.is(NodeType.Switch).not() { return NULL }
    if sw.children.len() != 3 { return NULL }   // scrutinee + exactly 2 cases
    switch sw.children[0].node_type {
    case NodeType.Ident(scrn):
        if scrn.ident_name().eq(vname).not() { return NULL }
    case: return NULL
    }
    return sw
}

// The Case child of switch `sw` whose pattern is a ListPattern with `arity`
// children. Unlike the match form, the arm body is a statement list: the base
// arm must be a single `return <expr>` and the cons arm an inlinable guard
// chain -- both enforced by the callers.
priv lazy_recursive_switch_arm := func(sw: Expr, arity: USize) returns ref Expr {
    for i in 1..sw.children.len() {
        ref cs : Expr = sw.children[i]
        if cs.node_type.is(NodeType.Case).not() { continue }
        if cs.children.len() != 2 { continue }
        ref pat : Expr = cs.children[0]
        if pat.node_type.is(NodeType.ListPattern).and(pat.children.len().eq(arity)) {
            if cs.children[1].node_type.is(NodeType.Body) { return cs }
        }
    }
    return NULL
}

// The single `return <expr>` value of a switch-form base arm, else NULL.
priv lazy_recursive_switch_base_value := func(arm: Expr) returns ref Expr {
    ref b : Expr = arm.children[1]
    if b.children.len() != 1 { return NULL }
    ref ret : Expr = b.children[0]
    if ret.node_type.is(NodeType.Return).not().or(ret.children.len() != 1) { return NULL }
    return ret.children[0]
}

// Shared head/tail + hygiene rules for both recursive forms: distinct
// head/tail names (also distinct from the variadic and any fixed param), the
// base value mentions none of them, and the cons region never mentions the
// variadic and uses the tail EXACTLY once -- as the single recursive tail
// splat call `self(..tail)`.
priv lazy_recursive_hygiene_ok := func(cons_pat: Expr, vname: Str,
        fixed_names: Vec(Str), base_val: Expr, cons_region: Expr) returns Bool {
    mut head := ""
    mut tail := ""
    switch cons_pat.children[0].node_type {
    case NodeType.Ident(hn): head = Str.clone(hn.ident_name())
    case: return false
    }
    switch cons_pat.children[1].node_type {
    case NodeType.Ident(tn): tail = Str.clone(tn.ident_name())
    case: return false
    }
    if head.eq(tail).or(head.eq(vname)).or(tail.eq(vname)) { return false }
    for fx : Str in fixed_names {
        if fx.eq(head).or(fx.eq(tail)) { return false }
    }
    if lazy_count_ident_uses(base_val, vname).gt(0) { return false }
    if lazy_count_ident_uses(base_val, head).gt(0) { return false }
    if lazy_count_ident_uses(base_val, tail).gt(0) { return false }
    if lazy_count_ident_uses(cons_region, vname).gt(0) { return false }
    if lazy_count_ident_uses(cons_region, tail) != 1 { return false }
    if lazy_count_tail_splat_calls(cons_region, tail) != 1 { return false }
    return true
}

// Issue #262: shape check for the recursive variadic lazy form, shared by the
// typer (def-site acceptance + body-typing skip: the ListPattern arms cannot
// type as ordinary code), the builder (emission skip: the def is fully
// consumed at compile time), and the loader's unroll. Requirements beyond the
// outer shape: distinct head/tail names (both distinct from the variadic
// param and any fixed param), the base arm mentions neither the variadic nor
// head/tail, and the cons arm uses the tail EXACTLY once -- as the one
// recursive tail splat call `self(..tail)`.
lazy_recursive_variadic_def := func(fdef: Expr) returns Bool {
    if fdef.node_type.is(NodeType.FuncDef).not() { return false }
    if fdef.children.len() == 0 { return false }
    mut vname := ""
    mut fixed_names := Vec(Str).new()
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        if fd.func_type.is(FuncType.LazyFunc).or(fd.func_type.is(FuncType.LazyProc)).not() { return false }
        if fd.kwargs_index >= 0 { return false }
        if fd.variadic_index < 0 { return false }
        if fd.variadic_index.to_usize() != fd.params.len() - 1 { return false }
        vname = fd.params[fd.variadic_index.to_usize()].name.clone()
        for j in 0..fd.params.len() - 1 { fixed_names.push(own fd.params[j].name.clone()) }
    case: return false
    }
    ref m : Expr = lazy_recursive_body_match(fdef.children[0], vname)
    if m.is_null().not() {
        ref base_arm : Expr = lazy_recursive_arm(m, 0)
        ref cons_arm : Expr = lazy_recursive_arm(m, 2)
        if base_arm.is_null().or(cons_arm.is_null()) { return false }
        return lazy_recursive_hygiene_ok(cons_arm.children[0], vname, fixed_names,
            lazy_recursive_arm_value(base_arm), lazy_recursive_arm_value(cons_arm))
    }
    // The statement (if/else) form: `switch xs { case []: ... case [h, ..t]:
    // ... }` with a single-return base arm and an inlinable-guard-chain cons
    // arm (the guards splice as nested short-circuit matches at unroll time).
    ref sw : Expr = lazy_recursive_body_switch(fdef.children[0], vname)
    if sw.is_null() { return false }
    ref sbase : Expr = lazy_recursive_switch_arm(sw, 0)
    ref scons : Expr = lazy_recursive_switch_arm(sw, 2)
    if sbase.is_null().or(scons.is_null()) { return false }
    ref sbase_val : Expr = lazy_recursive_switch_base_value(sbase)
    if sbase_val.is_null() { return false }
    if lazy_body_inlinable(scons.children[1]).not() { return false }
    return lazy_recursive_hygiene_ok(scons.children[0], vname, fixed_names,
        sbase_val, scons.children[1])
}

// Clone `e`, replacing the (unique) recursive tail splat call `self(..tail)`
// with a clone of `repl`. The callee must name the def itself -- a tail splat
// call targeting anything else is a lie about the recursion and panics.
priv lazy_clone_replacing_tail := func(e: Expr, tail_name: Str, self_name: Str, repl: Expr) returns Expr {
    if lazy_is_tail_splat_call(e, tail_name) {
        mut cname := ""
        switch e.children[0].node_type {
        case NodeType.Ident(cn): cname = Str.clone(cn.ident_name())
        case:
        }
        expect(cname == self_name,
            "recursive variadic lazy: the tail splat call must target the def itself")
        return repl.clone()
    }
    mut out := Expr.new(e.node_type, e.line, e.col)
    for c : Expr in e.children {
        out.add_child(own lazy_clone_replacing_tail(c, tail_name, self_name, repl))
    }
    return out
}

// Substitute `subs` into a cloned arm value, handling the bare-Ident-root
// case (the walk only substitutes children; a root Ident swaps wholesale).
priv lazy_subst_arm_clone := func(own arm: Expr, subs: Map(Str, Expr)) returns Expr {
    mut root_name := ""
    switch arm.node_type {
    case NodeType.Ident(rn): root_name = Str.clone(rn.ident_name())
    case:
    }
    if root_name.len().gt(0).and(subs.has(root_name)) {
        return subs[root_name].clone()
    }
    lazy_substitute_idents(arm, subs)
    return arm
}

// expand(k): the expression for effective operands [k, eff_count). At
// k == eff_count the base arm; otherwise the cons arm with head -> operand k
// and the recursive tail call replaced by expand(k + 1). Fixed params
// substitute at every level. `cons_is_body` selects the form: false = the
// match form (cons_src is the arm's value expression), true = the switch
// (if/else) form (cons_src is the arm's statement Body -- an inlinable guard
// chain, spliced to a nested short-circuit match via lazy_body_as_expr).
priv lazy_expand_recursive := func(call: Expr, is_method: Bool, fdef: Expr,
        nfixed: USize, eff_count: USize, k: USize, base_val: Expr, cons_src: Expr,
        cons_is_body: Bool, head: Str, tail: Str, self_name: Str) returns Expr {
    if k == eff_count {
        base_subs := lazy_variadic_subs(call, is_method, fdef, nfixed, "", 0)
        return lazy_subst_arm_clone(own base_val.clone(), base_subs)
    }
    inner := lazy_expand_recursive(call, is_method, fdef, nfixed, eff_count,
        k + 1, base_val, cons_src, cons_is_body, head, tail, self_name)
    cons_subs := lazy_variadic_subs(call, is_method, fdef, nfixed, head, k)
    mut substituted := lazy_subst_arm_clone(own cons_src.clone(), cons_subs)
    if cons_is_body {
        substituted = lazy_body_as_expr(substituted)
        expect(substituted.is_null().not(),
            "switch-form recursive arm failed to splice despite lazy_body_inlinable")
    }
    return lazy_clone_replacing_tail(substituted, tail, self_name, inner)
}

// Extract head/tail from the cons pattern, run the expansion, and splice the
// result over the call node. Shared tail of inline_recursive_variadic_lazy_call
// for both recursive forms.
priv lazy_finish_recursive_inline := func(mut parent: Expr, call_idx: USize,
        fdef: Expr, self_name: Str, is_method: Bool, eff_count: USize,
        nfixed: USize, base_val: Expr, cons_src: Expr, cons_is_body: Bool,
        cons_pat: Expr) {
    mut head := ""
    mut tail := ""
    switch cons_pat.children[0].node_type {
    case NodeType.Ident(hn): head = Str.clone(hn.ident_name())
    case:
    }
    switch cons_pat.children[1].node_type {
    case NodeType.Ident(tn): tail = Str.clone(tn.ident_name())
    case:
    }
    expanded := lazy_expand_recursive(parent.children[call_idx], is_method, fdef,
        nfixed, eff_count, nfixed, base_val, cons_src, cons_is_body, head, tail, self_name)
    parent.children[call_idx] = expanded
}

// Inline one call to a recursive variadic lazy def (shape pre-checked by
// lazy_recursive_variadic_def). Returns false only on a fixed-arity shortfall,
// where the residual call fails arity checking in the typer.
priv inline_recursive_variadic_lazy_call := func(mut parent: Expr, call_idx: USize,
        fdef: Expr, self_name: Str) returns Bool {
    ref call : Expr = parent.children[call_idx]
    mut vname := ""
    mut nfixed : USize = 0
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        vname = fd.params[fd.variadic_index.to_usize()].name.clone()
        nfixed = fd.params.len() - 1
    case: return false
    }
    mut is_method := false
    switch call.children[0].node_type {
    case NodeType.FieldAccess:
        is_method = call.children[0].children.len() == 1
    case:
    }
    mut eff_count : USize = call.children.len() - 1
    if is_method { eff_count = call.children.len() }
    if eff_count < nfixed { return false }

    // Both forms share the expansion; they differ only in where the base
    // value and cons region live (match arm values vs switch arm bodies).
    ref m : Expr = lazy_recursive_body_match(fdef.children[0], vname)
    if m.is_null().not() {
        ref base_arm : Expr = lazy_recursive_arm(m, 0)
        ref cons_arm : Expr = lazy_recursive_arm(m, 2)
        lazy_finish_recursive_inline(parent, call_idx, fdef, self_name, is_method,
            eff_count, nfixed, lazy_recursive_arm_value(base_arm),
            lazy_recursive_arm_value(cons_arm), false, cons_arm.children[0])
        return true
    }
    ref sw : Expr = lazy_recursive_body_switch(fdef.children[0], vname)
    ref sbase : Expr = lazy_recursive_switch_arm(sw, 0)
    ref scons : Expr = lazy_recursive_switch_arm(sw, 2)
    lazy_finish_recursive_inline(parent, call_idx, fdef, self_name, is_method,
        eff_count, nfixed, lazy_recursive_switch_base_value(sbase),
        scons.children[1], true, scons.children[0])
    return true
}

// Issue #262: statement-inlining for non-inlinable-but-single-exit lazy
// bodies. A body `{ <safe prelude statements> <inlinable tail> }` (e.g.
// `x := f(a); return x.and(b)`) cannot become a single expression, so at a
// statement-position call (a Decl RHS or a Return operand) we splice the
// prelude into a fresh block and route the tail through a result temp:
//   r := lazyf(p, q)
// becomes
//   mut _lzr_N : R = <default>
//   { x := f(p); _lzr_N = <tail expr> }
//   r := _lzr_N
// The block scopes the body's locals (so repeated calls don't collide), the
// prelude runs unconditionally (matching the body), and the tail expr is
// short-circuited by the expression inliner below. Call-by-name, zero runtime
// cost. First-class / loop / early-return bodies are NOT handled here.
mut lazy_stmt_temp_counter := 0

// core_lazy_func inlining: a bodyless lazy core primitive has no body to
// splice -- its expansion is compiler-known, exactly like a core_func's
// backend lowering. `and` and `or` are the only core lazy ops; an unknown
// name is a hard error, the loader-side twin of the C backend's
// unknown-core-op panic. The spliced match keeps every argument in a
// statement context (an arm), so arbitrarily complex second operands
// lower with full ownership/cleanup machinery, same as lazy_func bodies.
// Calls the loader misses (the desugarer synthesizes .and()/.or() chains
// post-typer) reach the builder as residual calls and lower to C's
// natively short-circuiting && / || there.
priv inline_core_lazy_call := func(mut parent: Expr, call_idx: USize, fdef: Expr, name: Str) returns Bool {
    ref call : Expr = parent.children[call_idx]
    if lazy_call_arity_ok(call, fdef).not() { return false }
    mut is_method := false
    switch call.children[0].node_type {
    case NodeType.FieldAccess: is_method = call.children[0].children.len() == 1
    case:
    }
    if name == "and" {
        // and(a, b) == match a { case true: b case: false }
        a0 := lazy_eff_arg_clone(call, is_method, 0)
        a1 := lazy_eff_arg_clone(call, is_method, 1)
        parent.children[call_idx] = lazy_make_bool_match(own a0, own a1,
            own Expr.new(NodeType.Literal(Literal.Bool(false)), call.line, call.col), call.line, call.col)
        return true
    }
    if name == "or" {
        // or(a, b) == match a { case true: true case: b }
        a0 := lazy_eff_arg_clone(call, is_method, 0)
        a1 := lazy_eff_arg_clone(call, is_method, 1)
        parent.children[call_idx] = lazy_make_bool_match(own a0,
            own Expr.new(NodeType.Literal(Literal.Bool(true)), call.line, call.col), own a1, call.line, call.col)
        return true
    }
    panic(__LOC__, ": core_lazy_func loader expansion: unknown op '", name, "'")
    return false
}

priv lazy_call_arity_ok := func(call: Expr, fdef: Expr) returns Bool {
    mut is_method := false
    switch call.children[0].node_type {
    case NodeType.FieldAccess: is_method = call.children[0].children.len() == 1
    case:
    }
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        if fd.variadic_index >= 0 { return false }
        mut nargs := call.children.len().sub(1)
        if is_method { nargs = call.children.len() }
        return nargs == fd.params.len()
    case: return false
    }
}

priv lazy_build_subs := func(call: Expr, fdef: Expr) returns Map(Str, Expr) {
    mut subs := Map(Str, Expr).new()
    mut is_method := false
    ref callee : Expr = call.children[0]
    switch callee.node_type {
    case NodeType.FieldAccess: is_method = callee.children.len() == 1
    case:
    }
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        for j in 0..fd.params.len() {
            ref param : Declaration = fd.params[j]
            if is_method.and(j.eq(0)) {
                subs.set(param.name, own callee.children[0].clone())
            } else {
                mut arg_idx := j.add(1)
                if is_method { arg_idx = j }
                subs.set(param.name, own call.children[arg_idx].clone())
            }
        }
    case:
    }
    return subs
}

priv lazy_make_temp_decl := func(name: Str, type_name: Str, own init: Expr, line: U32, col: U32) returns Expr {
    mut dd := decl_typed(name = name, explicit_type = type_name, is_mut = true)
    mut decl := Expr.new(NodeType.Decl(dd), line, col)
    decl.add_child(own init)
    return decl
}

priv lazy_make_assign := func(name: Str, own rhs: Expr, line: U32, col: U32) returns Expr {
    mut a := Expr.new(NodeType.Assign(AssignData(name = name.clone())), line, col)
    a.add_child(own rhs)
    return a
}

// The fdef of a statement-inlinable lazy call at `call`, else NULL: a call to
// a lazy callable whose body is NOT expression-inlinable but IS statement-
// inlinable, with matching arity.
priv lazy_stmt_inlinable_call := func(call: Expr, scope: TypeScope, ctx: Context) returns ref Expr {
    if call.node_type.is(NodeType.FCall).not() { return NULL }
    if call.children.len() == 0 { return NULL }
    mut lname := ""
    switch call.children[0].node_type {
    case NodeType.Ident(idn): lname = Str.clone(idn.ident_name())
    case NodeType.FieldAccess(fa): lname = Str.clone(fa.field_access_name())
    case:
    }
    if lname.len() == 0 { return NULL }
    // A name in ctx.generic_funcs is a monomorphized-and-DROPPED top-level
    // generic: init_expand_generic_funcs freed its FuncDef, so
    // scope.lookup_func(name) hands back a dangling pointer -- the same
    // documented guard init_lookup_type_gen_macro carries. Reached here via
    // a METHOD call sharing a generic's name (p.swap() vs core swap, #302:
    // heap-use-after-free in func_def_type).
    if ctx.generic_funcs.has(lname) { return NULL }
    ref fdef : Expr = scope.lookup_func(lname)
    if fdef.is_null() { return NULL }
    ft := func_def_type(fdef)
    if ft.is(FuncType.LazyFunc).or(ft.is(FuncType.LazyProc)).not() { return NULL }
    if fdef.children.len() == 0 { return NULL }
    ref body : Expr = fdef.children[0]
    if lazy_body_inlinable(body) { return NULL }
    if lazy_body_stmt_inlinable(body).not() { return NULL }
    if lazy_call_arity_ok(call, fdef).not() { return NULL }
    return fdef
}

// Build `mut _lzr_N : R = default` + `{ <prelude>; _lzr_N = <tail> }`, push
// both into `new`, and return the result Ident `_lzr_N`. NULL on failure.
priv lazy_build_prelude := func(call: Expr, fdef: Expr, mut new: Vec(Expr)) returns Expr {
    ref body : Expr = fdef.children[0]
    split := lazy_body_split_point(body)
    if split < 0 { return NULL }
    sp : USize = split.to_usize()
    mut ret_type := ""
    switch fdef.node_type {
    case NodeType.FuncDef(fd): ret_type = fd.return_type.clone()
    case:
    }
    if ret_type.len() == 0 { return NULL }
    line := call.line
    col := call.col

    subs := lazy_build_subs(call, fdef)
    mut bclone := body.clone()
    lazy_substitute_idents(bclone, subs)
    nstmts := bclone.children.len()

    // Tail expression from the substituted suffix [sp, nstmts).
    mut tailb := Expr.new(NodeType.Body, line, col)
    for i in sp..nstmts { tailb.add_child(own bclone.children[i].clone()) }
    tail_expr := lazy_body_as_expr(tailb)
    if tail_expr.is_null() { return NULL }

    name := format("_lzr_", lazy_stmt_temp_counter.to_str())
    lazy_stmt_temp_counter++

    // The block: substituted prelude [0, sp) + `_lzr_N = tail`.
    mut blk := Expr.new(NodeType.Body, line, col)
    for i in 0..sp { blk.add_child(own bclone.children[i].clone()) }
    blk.add_child(own lazy_make_assign(name, own tail_expr, line, col))

    deflt := make_default_value_expr(ret_type, line, col)
    new.push(own lazy_make_temp_decl(name, ret_type, own deflt, line, col))
    new.push(own blk)
    return Expr.new(ident_node(name), line, col)
}

// The value-position child of a statement that could hold a lazy call (a
// Decl RHS or a Return operand), else NULL.
priv lazy_stmt_value_slot := func(s: Expr) returns ref Expr {
    switch s.node_type {
    case NodeType.Decl:   if s.children.len() > 0 { return s.children[0] }
    case NodeType.Return: if s.children.len() > 0 { return s.children[0] }
    case:
    }
    return NULL
}

priv lazy_stmt_inline_body := func(mut body: Expr, scope: TypeScope, ctx: Context) {
    mut old := Vec(Expr).new()
    old.move_from(body.children)
    mut new := Vec(Expr).new()
    for idx in 0..old.len() {
        ref s : Expr = old[idx]
        ref slot_call : Expr = lazy_stmt_value_slot(s)
        mut handled := false
        if slot_call.is_null().not() {
            ref fdef : Expr = lazy_stmt_inlinable_call(slot_call, scope, ctx)
            if fdef.is_null().not() {
                result := lazy_build_prelude(slot_call, fdef, new)
                if result.is_null().not() {
                    s.children[0] = result
                    new.push_take(old, idx)
                    handled = true
                }
            }
        }
        if handled.not() { new.push_take(old, idx) }
    }
    body.children = new
}

priv lazy_stmt_inline_walk := func(mut e: Expr, scope: TypeScope, depth: I32, ctx: Context) {
    if e.is_null() { return }
    if depth > 256 { return }
    if e.node_type.is(NodeType.Body) { lazy_stmt_inline_body(e, scope, ctx) }
    for i in 0..e.children.len() {
        lazy_stmt_inline_walk(e.children[i], scope, depth.add(1), ctx)
    }
}

priv expand_lazy_in_expr := func(mut e: Expr, scope: TypeScope, depth: I32, ctx: Context) {
    expect(e.is_null().not(), "e is null")
    if depth > 256 { return }
    for i in 0..e.children.len() {
        ref mut c : Expr = e.children[i]
        mut inlined := false
        if c.node_type.is(NodeType.FCall).and(c.children.len().gt(0)) {
            mut lname := ""
            switch c.children[0].node_type {
            case NodeType.Ident(idn): lname = Str.clone(idn.ident_name())
            case NodeType.FieldAccess(fa): lname = Str.clone(fa.field_access_name())
            case:
            }
            // Same dropped-generic guard as lazy_stmt_inlinable_call: a
            // name in ctx.generic_funcs points at a freed FuncDef.
            if lname.len().gt(0).and(ctx.generic_funcs.has(lname).not()) {
                ref fdef : Expr = scope.lookup_func(lname)
                if fdef.is_null().not() {
                    ft := func_def_type(fdef)
                    if ft.is(FuncType.LazyFunc).or(ft.is(FuncType.LazyProc)) {
                        // Variadic lazy defs unroll over the call's operands
                        // (the recursive Haskell-style form first, then the
                        // iterative for-in form); fixed-arity defs inline
                        // directly.
                        mut done := false
                        if lazy_recursive_variadic_def(fdef) {
                            done = inline_recursive_variadic_lazy_call(e, i, fdef, lname)
                        }
                        if done.not() { done = inline_variadic_lazy_call(e, i, fdef) }
                        if done.not() { done = inline_lazy_call(e, i, fdef) }
                        if done {
                            // The spliced body may contain further lazy
                            // calls (in the body or substituted args).
                            expand_lazy_in_expr(e.children[i], scope, depth + 1, ctx)
                            inlined = true
                        }
                    } else if ft.is(FuncType.CoreLazyFunc) {
                        // Bodyless lazy core primitive: splice the
                        // compiler-known match expansion.
                        if inline_core_lazy_call(e, i, fdef, lname) {
                            expand_lazy_in_expr(e.children[i], scope, depth + 1, ctx)
                            inlined = true
                        }
                    }
                }
            }
        }
        // A recursive variadic lazy def body is a compile-time TEMPLATE: its
        // self-call `self(..tl)` is the recursion point the per-call-site
        // unroll consumes, not a call to expand here -- expanding it in place
        // would destroy the template. Skip descending into such defs.
        mut recursive_template := false
        switch c.node_type {
        case NodeType.FuncDef: recursive_template = lazy_recursive_variadic_def(c)
        case:
        }
        if inlined.not().and(recursive_template.not()) { expand_lazy_in_expr(c, scope, depth + 1, ctx) }
    }
}

// Issue #262 thunk fallback. A top-level lazy_func / lazy_proc whose body is
// NEITHER expression-inlinable NOR statement-inlinable (loops, early returns
// inside control flow) is lowered to an ordinary closure-taking function: each
// param `p: T` becomes a zero-arg funcptr `p: func() returns T`, every
// value-use of `p` in the body is auto-forced to `p()`, and at each call site
// the argument expression `e` is wrapped in a synthesized capturing closure
// `func() returns T { return e }` (call-by-name). The synthetic funcptr type is
// named `_Fn_ret_<T>`, registered through register_funcsig_alias_for_stmt so the
// builder emits the typedef. Scope: top-level defs, bare-name calls, exact
// (non-variadic) arity, no shadowing of a param name inside the body.

// True if `body` (a FuncDef body) binds any name equal to a lazy param name --
// a Decl, an Assign target, or a for-loop variable. Walk stops at nested
// FuncDef boundaries (their params/locals are their own). When shadowing is
// present we do NOT thunk-lower the def at all (the existing typer hard error
// fires) rather than risk mis-rewriting a shadowed use.
priv lazy_param_shadowed := func(e: Expr, pnames: Set(Str), depth: I32) returns Bool {
    if depth > 256 { return false }
    for i in 0..e.children.len() {
        ref c : Expr = e.children[i]
        switch c.node_type {
        case NodeType.FuncDef: continue   // nested closure: its own scope
        case NodeType.Decl(dd):
            if pnames.has(dd.name) { return true }
        case NodeType.Assign(ad):
            if pnames.has(ad.name) { return true }
        case NodeType.ForIn(fd):
            if pnames.has(fd.name) { return true }
            if fd.name2.len().gt(0).and(pnames.has(fd.name2)) { return true }
        case:
        }
        if lazy_param_shadowed(c, pnames, depth + 1) { return true }
    }
    return false
}

// Rewrite every value-use of a lazy param name into a zero-arg force call
// `p()`. Each matching Ident child is replaced by `(FCall (Ident p))`. Walk
// stops at nested FuncDef boundaries. Shadowing is rejected earlier, so every
// Ident naming a param here is genuinely that param.
priv lazy_autoforce := func(mut e: Expr, pnames: Set(Str), depth: I32) {
    if depth > 256 { return }
    for i in 0..e.children.len() {
        ref c : Expr = e.children[i]
        switch c.node_type {
        case NodeType.FuncDef: continue   // nested closure: leave its body
        case NodeType.Ident(idn):
            ref nm : Str = idn.ident_name()
            if pnames.has(nm) {
                line := c.line
                col := c.col
                mut call := Expr.new(NodeType.FCall(FCallData()), line, col)
                call.add_child(own Expr.new(ident_node(nm), line, col))
                e.children[i] = call
                continue
            }
        case:
        }
        lazy_autoforce(c, pnames, depth + 1)
    }
}

// Build the bodyless `_Fn_ret_<T>` funcsig Decl (mirrors parser.til
// parse_fn_signature) and register it via the initer path, appending it to the
// unit AST so the C builder emits the typedef. Deduped per name through `seen`
// and the existing scope binding.
priv lazy_register_fn_ret_alias := func(mut lp: LoadedProgram, unit_path: Str,
        ret_type: Str, line: U32, col: U32, mut seen: Set(Str)) {
    name := format("_Fn_ret_", ret_type)
    if seen.has(name) { return }
    seen.add(own name.clone())
    // Reuse a hand-written `func() returns T` alias if one already exists.
    ref existing : TypeBinding = lp.ctx.scope.get_binding(name)
    if existing.is_null().not() { return }

    mut fd := FunctionDef()
    fd.func_type = FuncType.Func
    fd.return_type = ret_type.clone()
    fd.return_own_type = OwnType.Own
    fd.variadic_index = -1
    fd.kwargs_index = -1
    mut sig := Expr.new(NodeType.FuncDef(fd), line, col)
    mut decl := Expr.new(NodeType.Decl(Declaration(name = name.clone(), is_priv = true)), line, col)
    decl.add_child(own sig)
    register_funcsig_alias_for_stmt(lp.ctx, decl, lp.ctx.scope)
    lp.ctx.imported[unit_path].ast.add_child(own decl)
}

// Lower one non-inlinable top-level lazy def in place: LazyFunc->Func /
// LazyProc->Proc, retype each param `p: T` to `p: _Fn_ret_T`, auto-force the
// body, and register the funcptr aliases. Records the lowered name in `lowered`.
priv lazy_thunk_lower_def := func(mut lp: LoadedProgram, unit_path: Str,
        name: Str, mut fdef: Expr, mut lowered: Set(Str), mut seen: Set(Str)) {
    if fdef.children.len() == 0 { return }
    ref body : Expr = fdef.children[0]
    mut pnames := Set(Str).new()
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        if fd.variadic_index >= 0 { return }   // variadic: out of scope
        for p : Declaration in fd.params { pnames.add(own p.name.clone()) }
    case:
        return
    }
    // Shadowing: leave the def lazy so the existing typer hard error fires.
    if lazy_param_shadowed(body, pnames, 0) { return }

    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        if fd.func_type.is(FuncType.LazyFunc) { fd.func_type = FuncType.Func }
        else { fd.func_type = FuncType.Proc }
        for i in 0..fd.params.len() {
            ref mut param : Declaration = fd.params[i]
            ret_type := param.explicit_type.clone()
            lazy_register_fn_ret_alias(lp, unit_path, ret_type, fdef.line, fdef.col, seen)
            param.explicit_type = format("_Fn_ret_", ret_type)
            param.til_type = til_type_from_explicit_type(param.explicit_type)
        }
    case:
        return
    }
    lazy_autoforce(body, pnames, 0)
    lowered.add(own name.clone())
    lp.ctx.scope.set_func_def(name, fdef)
}

// Classify one name referenced inside a thunk arg expression against the
// program ROOT scope (lp.ctx.scope at this phase). A name is a CAPTURE iff it
// is not bound inside the thunk body and is not resolvable at root scope: at
// this phase only globals / top-level funcs / builtins are in scope, so any
// other name is an enclosing local the thunk must capture by reference (#54).
priv lazy_thunk_classify_capture := func(name: Str, scope: TypeScope,
        bound: Set(Str), mut caps: Vec(Declaration)) {
    if bound.has(name) { return }                  // bound inside the thunk body
    ref b : TypeBinding = scope.get_binding(name)
    if b.is_null().not() { return }                // global / top-level func / builtin
    for existing : Declaration in caps {
        if existing.name == name { return }
    }
    caps.push(own Declaration(name = name.clone(), own_type = OwnType.Ref))
}

// Free-variable analysis over a thunk arg expression: collect every Ident /
// Assign-target that resolves to an enclosing local into `caps`. Names bound
// inside the expression (a Decl, a for-loop variable) are tracked in `bound`
// so they are not mistaken for captures. Stops at nested FuncDef / CaptureBlock
// boundaries (those carry their own capture rules).
priv lazy_thunk_collect_captures := func(e: Expr, scope: TypeScope,
        mut bound: Set(Str), mut caps: Vec(Declaration)) {
    switch e.node_type {
    case NodeType.FuncDef: return
    case NodeType.CaptureBlock: return
    case NodeType.Decl(dd):
        if dd.name.len() > 0 { bound.add(own dd.name.clone()) }
    case NodeType.ForIn(fd):
        if fd.name.len() > 0 { bound.add(own fd.name.clone()) }
        if fd.name2.len() > 0 { bound.add(own fd.name2.clone()) }
    case NodeType.Ident(idd):
        lazy_thunk_classify_capture(idd.name, scope, bound, caps)
    case NodeType.Assign(ad):
        lazy_thunk_classify_capture(ad.name, scope, bound, caps)
    case:
    }
    for c : Expr in e.children {
        lazy_thunk_collect_captures(c, scope, bound, caps)
    }
}

// Wrap each argument of a call to a thunk-lowered def in a synthesized closure
// `func() returns T [caps] { return <arg> }` (call-by-name). `T` is the param's
// ORIGINAL return type, recovered from the param's `_Fn_ret_<T>` explicit_type;
// `caps` is the arg expression's enclosing-local free variables (by reference).
// A thunk with no captures is left non-capturing, so the lambda lifter hoists
// it to a plain top-level function -- exactly like any other non-capturing
// lambda. The typer's #54 closure-escape checks then gate any captured local
// that would escape its defining call (first-class / infinite uses await #54).
// Build a thunk closure `func() returns ret_type [caps] { return <eff> }` over
// the (owned) effective argument expression `eff`. `caps` is eff's enclosing-
// local free variables; a no-capture thunk is lifted to a plain top-level
// lambda, a capturing one reuses the #54 machinery.
priv lazy_make_thunk := func(own eff: Expr, ret_type: Str, scope: TypeScope) returns Expr {
    line := eff.line
    col := eff.col
    mut caps := Vec(Declaration).new()
    mut bound := Set(Str).new()
    lazy_thunk_collect_captures(eff, scope, bound, caps)
    mut cfd := FunctionDef()
    cfd.func_type = FuncType.Func
    cfd.return_type = ret_type.clone()
    cfd.variadic_index = -1
    cfd.kwargs_index = -1
    cfd.captures = caps
    mut ret := Expr.new(NodeType.Return, line, col)
    ret.add_child(own eff)
    mut cbody := Expr.new(NodeType.Body, line, col)
    cbody.add_child(own ret)
    mut clos := Expr.new(NodeType.FuncDef(cfd), line, col)
    clos.add_child(own cbody)
    return clos
}

// Build a fresh BARE call `name(thunk(eff_0), thunk(eff_1), ...)` to a thunk-
// lowered def, wrapping each effective argument in a thunk closure. Both bare
// `f(a, b)` and UFCS `a.f(b)` calls reduce to the same bare form (the receiver
// is effective arg 0), so a thunk -- which is not a UFCS receiver -- is never
// left in receiver position. `ret_type` per param is recovered from its
// `_Fn_ret_<T>` explicit_type. Mirrors lazy_build_fold's bare-normalization.
priv lazy_build_thunk_call := func(call: Expr, fdef: Expr, name: Str, is_method: Bool, scope: TypeScope) returns Expr {
    line := call.line
    col := call.col
    mut nc := Expr.new(NodeType.FCall(FCallData()), line, col)
    nc.add_child(own Expr.new(ident_node(name), line, col))
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        for j in 0..fd.params.len() {
            ref param : Declaration = fd.params[j]
            ret_type := param.explicit_type.strip_prefix("_Fn_ret_")
            nc.add_child(own lazy_make_thunk(own lazy_eff_arg_clone(call, is_method, j), ret_type, scope))
        }
    case:
    }
    return nc
}

// Walk all exprs; for every FCall (bare `f(a, b)` or UFCS `a.f(b)`) naming a
// thunk-lowered def with matching (non-variadic, exact) effective arity, rebuild
// it as a bare call with each effective argument wrapped in a thunk closure.
priv lazy_wrap_thunk_calls := func(mut e: Expr, scope: TypeScope, lowered: Set(Str), depth: I32) {
    if depth > 256 { return }
    for i in 0..e.children.len() {
        ref c : Expr = e.children[i]
        if c.node_type.is(NodeType.FCall).and(c.children.len().gt(0)) {
            mut lname := ""
            mut is_method := false
            switch c.children[0].node_type {
            case NodeType.Ident(idn): lname = Str.clone(idn.ident_name())
            case NodeType.FieldAccess(fa):
                lname = Str.clone(fa.field_access_name())
                is_method = true
            case:
            }
            if lname.len().gt(0).and(lowered.has(lname)) {
                ref fdef : Expr = scope.lookup_func(lname)
                if fdef.is_null().not() {
                    mut nparams : USize = 0
                    switch fdef.node_type {
                    case NodeType.FuncDef(fd): nparams = fd.params.len()
                    case:
                    }
                    // Effective args: bare `f(a, b)` has children.len()-1 args;
                    // UFCS `a.f(b)` adds the receiver, so children.len().
                    mut eff_count : USize = c.children.len().sub(1)
                    if is_method { eff_count = c.children.len() }
                    if eff_count.eq(nparams) {
                        e.children[i] = lazy_build_thunk_call(c, fdef, lname, is_method, scope)
                    }
                }
            }
        }
        lazy_wrap_thunk_calls(e.children[i], scope, lowered, depth + 1)
    }
}

// Find and lower every non-inlinable top-level lazy def in one unit AST, then
// collect the lowered names. Defs are the direct top-level Decl children.
priv lazy_thunk_lower_unit := func(mut lp: LoadedProgram, unit_path: Str,
        mut lowered: Set(Str), mut seen: Set(Str)) {
    ref unit_ast : Expr = lp.ctx.imported[unit_path].ast
    n := unit_ast.children.len()
    for i in 0..n {
        ref stmt : Expr = unit_ast.children[i]
        if is_func_decl(stmt).not() { continue }
        mut lname := ""
        switch stmt.node_type {
        case NodeType.Decl(dd): lname = dd.name.clone()
        case:
        }
        if lname.len() == 0 { continue }
        ref fdef : Expr = stmt.children[0]
        ft := func_def_type(fdef)
        if ft.is(FuncType.LazyFunc).or(ft.is(FuncType.LazyProc)).not() { continue }
        ref body : Expr = fdef.children[0]
        if lazy_body_inlinable(body).or(lazy_body_stmt_inlinable(body)) { continue }
        lazy_thunk_lower_def(lp, unit_path, lname, fdef, lowered, seen)
    }
}

// Issue #262: the thunk-fallback pass. Lower all non-inlinable top-level lazy
// defs, then wrap their bare-name call arguments in thunk closures. Runs BEFORE
// the inline passes; once a def's func_type flips to Func/Proc the inline
// passes skip its calls (they gate on LazyFunc/LazyProc), which is correct --
// the call-wrapping here already handled them.
priv expand_lazy_thunks_in_program := func(mut lp: LoadedProgram) {
    mut lowered := Set(Str).new()
    mut seen := Set(Str).new()
    if lp.skip_core.not() {
        for cu : ProgramUnit in lp.core_units {
            lazy_thunk_lower_unit(lp, cu.path, lowered, seen)
        }
    }
    for uu : ProgramUnit in lp.units {
        lazy_thunk_lower_unit(lp, uu.path, lowered, seen)
    }
    for mf : Str in lp.mode_files {
        lazy_thunk_lower_unit(lp, mf, lowered, seen)
    }
    if lowered.len() == 0 { return }
    if lp.skip_core.not() {
        for cu : ProgramUnit in lp.core_units {
            lazy_wrap_thunk_calls(lp.ctx.imported[cu.path].ast, lp.ctx.scope, lowered, 0)
        }
    }
    for uu : ProgramUnit in lp.units {
        lazy_wrap_thunk_calls(lp.ctx.imported[uu.path].ast, lp.ctx.scope, lowered, 0)
    }
    for mf : Str in lp.mode_files {
        lazy_wrap_thunk_calls(lp.ctx.imported[mf].ast, lp.ctx.scope, lowered, 0)
    }
}

priv expand_lazy_calls_in_program := func(mut lp: LoadedProgram) {
    // Issue #262: thunk-lower non-inlinable lazy defs + wrap their calls FIRST,
    // so the inline passes below only see the still-Lazy inlinable defs/calls.
    expand_lazy_thunks_in_program(lp)
    // Pass 1: statement-inline non-inlinable (local-binding) lazy bodies so
    // their inlinable tails are left for pass 2.
    if lp.skip_core.not() {
        for cu : ProgramUnit in lp.core_units {
            lazy_stmt_inline_walk(lp.ctx.imported[cu.path].ast, lp.ctx.scope, 0, lp.ctx)
        }
    }
    for uu : ProgramUnit in lp.units {
        lazy_stmt_inline_walk(lp.ctx.imported[uu.path].ast, lp.ctx.scope, 0, lp.ctx)
    }
    for mf : Str in lp.mode_files {
        lazy_stmt_inline_walk(lp.ctx.imported[mf].ast, lp.ctx.scope, 0, lp.ctx)
    }
    // Pass 2: expression inlining of (now exposed) inlinable lazy calls.
    if lp.skip_core.not() {
        for cu : ProgramUnit in lp.core_units {
            expand_lazy_in_expr(lp.ctx.imported[cu.path].ast, lp.ctx.scope, 0, lp.ctx)
        }
    }
    for uu : ProgramUnit in lp.units {
        expand_lazy_in_expr(lp.ctx.imported[uu.path].ast, lp.ctx.scope, 0, lp.ctx)
    }
    for mf : Str in lp.mode_files {
        expand_lazy_in_expr(lp.ctx.imported[mf].ast, lp.ctx.scope, 0, lp.ctx)
    }
}

// --- #154 prototype: unused-import check (--check-unused-imports) ---
//
// One entry per explicit import stmt in a user unit, snapshotted BEFORE
// desugar_namespace_imports rewrites `name := import(...)` decls into
// local ns structs -- the AST-position -> iu.imports mapping is only
// 1:1 while both forms are still in the AST.
priv ImportCheckEntry := struct {
    path := ""       // importing unit's display path
    line : U32 = 0
    col : U32 = 0
    label := ""      // import path literal as written, for the message
    dep := ""        // resolved display path of the imported file
    decl_name := ""  // non-empty for `name := import(...)` form
}

// True when imp_stmt is an import FCall of the exact shape that
// count_ast_imports counts (so the caller's import_idx stays in step
// with iu.imports); writes the path literal into label on success.
priv import_stmt_label := func(imp_stmt: Expr, mut label: Str) returns Bool {
    if imp_stmt.children.len() < 2 { return false }
    if imp_stmt.children[1].node_type.is_literal_str().not() { return false }
    mut is_imp := false
    switch imp_stmt.children[0].node_type {
    case NodeType.Ident(id):
        if id.ident_name() == "import" { is_imp = true }
    case:
    }
    if is_imp.not() { return false }
    switch imp_stmt.children[1].node_type {
    case NodeType.Literal(Literal.Str(p)):
        label = p.clone()
    case:
    }
    return true
}

priv collect_import_check_entries := func(unit_path: Str, iu: ImportUnit, mut entries: Vec(ImportCheckEntry)) {
    // Leading iu.imports entries with no matching AST stmt are
    // loader-injected (mode auto-imports); skip them, mirroring
    // type_bodies_file's auto_count logic.
    ast_count : USize = count_ast_imports(iu.ast)
    mut import_idx : USize = iu.imports.len() - ast_count
    for stmt : Expr in iu.ast.children {
        mut decl_name := ""
        mut label := ""
        mut is_imp := false
        if stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0)) {
            if stmt.children[0].node_type.is(NodeType.FCall) {
                is_imp = import_stmt_label(stmt.children[0], label)
                if is_imp {
                    switch stmt.node_type {
                    case NodeType.Decl(dd):
                        decl_name = dd.name.clone()
                    case:
                    }
                }
            }
        } else if stmt.node_type.is(NodeType.FCall) {
            is_imp = import_stmt_label(stmt, label)
        }
        if is_imp.not() { continue }
        ref dep : Str = iu.imports[import_idx]
        import_idx++
        entries.push(own ImportCheckEntry(path = unit_path.clone(),
            line = stmt.line, col = stmt.col, label = label.clone(),
            dep = dep.clone(), decl_name = decl_name.clone()))
    }
}

// An explicit import whose file contributed no symbol read from the
// importing file is flagged. `_name := import(...)` opts out -- the
// same _-prefix convention as unused params/locals (#86). A used
// `name := import(...)` alias needs no special case: its `name.sym`
// uses are rewritten to direct references at desugar time, so they
// produce ordinary cross-file use edges.
priv check_unused_imports_collected := proc(entries: Vec(ImportCheckEntry), ctx: Context) returns I32 {
    mut found : I32 = 0
    for ent : ImportCheckEntry in entries {
        if ent.decl_name.starts_with("_") { continue }
        is_used := ctx.import_use_edges.has(format(ent.path, "|", ent.dep))
        if is_used.not() {
            type_error_at(ent.path, ent.line, ent.col,
                format("unused import '", ent.label, "'"), ctx)
            found++
        }
    }
    return found
}

type_program_errors := proc(mut lp: LoadedProgram, run_tests: Bool) returns I32 {
    lp.run_tests = run_tests.or(lp.cur_mode.run_tests)

    // #192: register target-dependent USize/UPtr widths before any
    // init/typer resolution, so every position resolves them uniformly
    // to the per-target primitive. lp.target is final here (after any
    // --target override).
    context_register_target_int_alias_types(lp.ctx, target_int_alias_name(lp, "USize", target_usize_name(lp.target)), target_int_alias_name(lp, "UPtr", target_uptr_name(lp.target)))

    // #154 prototype: snapshot every explicit import stmt per user unit
    // before the namespace-import desugar below rewrites the decl form
    // away. Core units are exempt -- aggregators like core.til import
    // to re-export by design.
    mut import_check_entries := Vec(ImportCheckEntry).new()
    if lp.ctx.check_unused_imports {
        for icu : ProgramUnit in lp.units {
            collect_import_check_entries(icu.path, lp.ctx.imported[icu.path], import_check_entries)
        }
    }

    // Desugar namespace imports BEFORE init_file runs, so the initer
    // only ever sees direct references to the original decls.
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            desugar_namespace_imports(u.path, lp.ctx.imported[u.path], lp.ctx)
        }
    }
    for u : ProgramUnit in lp.units {
        desugar_namespace_imports(u.path, lp.ctx.imported[u.path], lp.ctx)
    }

    // Issue #158: the typer populates the foldable-name sets during its
    // walk (constfolder_classify_stmt); clear any stale state up front so a
    // fresh build (or REPL re-eval reusing this Context) starts clean.
    constfolder_reset_state(lp.ctx)

    // Init phase (rstil-style): recursive imports per file.
    context_reset_type_scope(lp.ctx)
    if lp.skip_core.not() {
        init_file(lp.core_units[lp.core_units.len() - 1].path, lp.ctx)
    }
    ref user_root : ProgramUnit = lp.units[lp.units.len() - 1]
    init_file(user_root.path, lp.ctx)
    for mode_file : Str in lp.mode_files {
        init_file(mode_file, lp.ctx)
    }


    // Global init steps: these generate methods/layouts that later phases
    // assume exist (e.g. comparison helpers on USize).
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            lp.ctx.mode = iu.mode.clone()
            context_enter_file(lp.ctx, u.path)
            init_declarations_global(lp.ctx, iu.ast, lp.ctx.scope)
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        lp.ctx.mode = iu.mode.clone()
        context_enter_file(lp.ctx, u.path)
        init_declarations_global(lp.ctx, iu.ast, lp.ctx.scope)
    }

    retarget_loaded_aliases(lp)

    // Ensure ctx.path is set to the user entrypoint by default.
    if lp.units.len() > 0 {
        context_enter_file(lp.ctx, lp.units[lp.units.len() - 1].path)
    }

    // #165 step 1: resolve any Type.Custom(name) bindings (written by
    // initer's scope-free registration helpers) to Struct/Enum now that
    // every name is in scope.
    normalize_scope_bindings(lp.ctx.scope)

    // Issue #262: inline lazy_func / lazy_proc calls before type-checking so
    // the spliced bodies (and the short-circuit `match` inside them) are
    // typed and lowered as ordinary code.
    expand_lazy_calls_in_program(lp)

    // Type checking (rstil-style): recursive imports per file.
    mut type_errors : I32 = 0
    if lp.skip_core.not() {
        type_errors = type_errors.add(type_file(lp.core_units[lp.core_units.len() - 1].path, lp.ctx))
    }
    type_errors = type_errors + type_file(user_root.path, lp.ctx)
    // Issue #187 step 1: priv top-level decls that nothing in the
    // file references are dead code -- no importer can reach them.
    type_errors = type_errors + check_unused_priv_top_level(lp.ctx.scope, lp.ctx)
    // Issue #187 steps 2-3: priv struct fields and namespace members
    // that no code in the struct's own namespace ever reads. Walk
    // every loaded unit's AST.
    if lp.skip_core.not() {
        for cu : ProgramUnit in lp.core_units {
            type_errors = type_errors + check_unused_priv_members_in_program(lp.ctx.imported[cu.path].ast, cu.path, lp.ctx)
        }
    }
    for uu : ProgramUnit in lp.units {
        type_errors = type_errors + check_unused_priv_members_in_program(lp.ctx.imported[uu.path].ast, uu.path, lp.ctx)
    }
    for mode_file : Str in lp.mode_files {
        type_errors = type_errors + type_file(mode_file, lp.ctx)
    }

    // #154 prototype: flag user-unit imports that contributed no used
    // symbol (opt-in via --check-unused-imports).
    if lp.ctx.check_unused_imports {
        type_errors = type_errors + check_unused_imports_collected(import_check_entries, lp.ctx)
    }

    if type_errors > 0 {
        return type_errors
    }

    return 0
}

finish_init_and_type_program := proc(mut lp: LoadedProgram) {
    // Asap-destruction phase. Walks every imported file's program
    // body and inserts the Type.delete() / free() calls for owned
    // globals. Sub-body asap (function bodies + nested if/while/
    // block/catch scopes) still runs inline from the typer's
    // scope-management sites because per-body scopes are stack
    // locals; issue #204 step 3b covers lifting those too.
    garbager_destroy(lp.ctx)
}

init_and_type_program_errors := proc(mut lp: LoadedProgram, run_tests: Bool) returns I32 {
    type_errors := type_program_errors(lp, run_tests)
    if type_errors > 0 { return type_errors }
    finish_init_and_type_program(lp)
    return 0
}

init_and_type_program := proc(mut lp: LoadedProgram, run_tests: Bool) {
    type_errors := init_and_type_program_errors(lp, run_tests)
    if type_errors > 0 {
        println(type_errors.to_str(), " type error(s) found")
        exit(1)
    }
}

finish_prepare_program := proc(mut lp: LoadedProgram) {
    constfolder_imported(lp)

    // Skip top-level scavenging for libraries only. link() and link_c()
    // directives are compile-time concerns and should not disable normal
    // AST scavenging.
    skip_scavenge := lp.cur_mode.is_library
    if skip_scavenge.not() {
        scavenge_imported(lp)
    } else {
        // Even libraries get body-level DCE so the dead arg-temps left
        // behind by constant folding don't bloat the emitted C.
        if lp.skip_core.not() {
            for u : ProgramUnit in lp.core_units {
                dce_program_bodies(lp.ctx.imported[u.path].ast)
            }
        }
        for u : ProgramUnit in lp.units {
            dce_program_bodies(lp.ctx.imported[u.path].ast)
        }
    }
}

repl_init_cached_program := proc(mut lp: LoadedProgram) returns I32 {
    type_errors := type_program_errors(lp, false)
    if type_errors > 0 { return type_errors }
    finish_init_and_type_program(lp)
    // The cached empty REPL base must keep core/user definitions alive for
    // later deltas; full prepare would scavenge them as unused in the empty
    // root and leave scope.func_defs pointing at deleted AST nodes.
    constfolder_imported(lp)
    repl_reregister_scope_defs_loaded(lp)
    repl_classify_foldables_loaded(lp)
    return 0
}

repl_type_delta_program := proc(mut lp: LoadedProgram, mut delta: Expr) returns I32 {
    lp.run_tests = lp.cur_mode.run_tests
    context_register_target_int_alias_types(lp.ctx, target_int_alias_name(lp, "USize", target_usize_name(lp.target)), target_int_alias_name(lp, "UPtr", target_uptr_name(lp.target)))
    ref root : ProgramUnit = lp.units[lp.units.len() - 1]
    ref iu : ImportUnit = lp.ctx.imported[root.path]
    lp.ctx.mode = iu.mode.clone()
    context_enter_file(lp.ctx, root.path)

    init_errors := init_repl_delta(root.path, delta, lp.ctx)
    if init_errors > 0 { return init_errors }

    retarget_loaded_aliases(lp)
    normalize_scope_bindings(lp.ctx.scope)
    lazy_stmt_inline_walk(delta, lp.ctx.scope, 0, lp.ctx)
    expand_lazy_in_expr(delta, lp.ctx.scope, 0, lp.ctx)

    type_errors := type_repl_delta(root.path, delta, lp.ctx)
    if type_errors > 0 { return type_errors }
    if body_pre_passes(lp.ctx, delta, lp.ctx.scope, 1) {
        type_errors2 := type_repl_delta(root.path, delta, lp.ctx)
        if type_errors2 > 0 { return type_errors2 }
    }
    garbager_destroy_body(lp.ctx, delta, lp.ctx.scope)
    return 0
}

repl_prepare_delta_program := proc(mut lp: LoadedProgram, mut delta: Expr) {
    constfolder_repl_delta(lp, delta)
    dce_program_bodies(delta)
}

prepare_program := proc(mut lp: LoadedProgram, run_tests: Bool) {
    init_and_type_program(lp, run_tests)
    finish_prepare_program(lp)
}

// --- Commands ---

cmd_ast := proc(lp: LoadedProgram) {
    println(format("mode: ", lp.mode_str))
    for u : ProgramUnit in lp.units {
        println(format("file: ", u.path))
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        println(iu.ast.to_str())
    }
}
