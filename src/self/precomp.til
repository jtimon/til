mode lib

// Precomp: constant folding for macros and pure functions
mut macros := Set.new("Str", Str.size())
mut funcs := Set.new("Str", Str.size())
mut known := Map.new("Str", Str.size(), "Value", Value.size())

precomp_has_macro := func(name: Str) returns shallow Bool {
    return macros.has(name)
}

precomp_has_func := func(name: Str) returns shallow Bool {
    return funcs.has(name)
}

value_to_expr := func(shallow val: Value, src: Expr) returns Expr {
    switch val {
    case Value.Int(x):
        mut e := Expr.new(NodeType.LiteralNum(x.to_str()), src.line, src.col, src.path)
        e.til_type = TilType.I64
        return e
    case Value.Byte(x):
        mut e := Expr.new(NodeType.LiteralNum(x.to_str()), src.line, src.col, src.path)
        e.til_type = TilType.U8
        return e
    case Value.Short(x):
        mut e := Expr.new(NodeType.LiteralNum(x.to_str()), src.line, src.col, src.path)
        e.til_type = TilType.I16
        return e
    case Value.Int32(x):
        mut e := Expr.new(NodeType.LiteralNum(x.to_str()), src.line, src.col, src.path)
        e.til_type = TilType.I32
        return e
    case Value.Uint32(x):
        mut e := Expr.new(NodeType.LiteralNum(x.to_str()), src.line, src.col, src.path)
        e.til_type = TilType.U32
        return e
    case Value.Uint64(x):
        mut e := Expr.new(NodeType.LiteralNum(x.to_str()), src.line, src.col, src.path)
        e.til_type = TilType.U64
        return e
    case Value.Float(x):
        mut e := Expr.new(NodeType.LiteralNum(x.to_str()), src.line, src.col, src.path)
        e.til_type = TilType.F32
        return e
    case Value.Struct(si):
        if si.to_str().eq("Str") {
            sv := str_view(val)
            mut e := Expr.new(NodeType.LiteralStr(sv.clone()), src.line, src.col, src.path)
            e.til_type = TilType.Struct("Str".clone())
            return e
        }
        return NULL
    case Value.Boolean(b):
        mut e := Expr.new(NodeType.LiteralBool(b.clone()), src.line, src.col, src.path)
        e.til_type = TilType.Bool
        return e
    case:
        return NULL
    }
}

expr_to_value := func(e: Expr) returns shallow Value {
    switch e.data {
    case NodeType.LiteralNum(num):
        switch e.til_type {
        case TilType.U8:  return val_u8(num.to_u8())
        case TilType.U32: return val_u32(num.to_i64())
        case TilType.U64: return val_u64(num.to_i64().to_u64())
        case TilType.I16: return val_i16(num.to_i64())
        case TilType.I32: return val_i32(num.to_i64())
        case TilType.F32: return val_f32(num.to_f32())
        case: return val_i64(num.to_i64())
        }
    case NodeType.LiteralStr(s):
        return make_str_value(s.c_str, s.count)
    case NodeType.LiteralBool(b):
        return val_bool(b)
    case:
        return val_none()
    }
}

is_known := func(e: Expr, mut out: Value) returns shallow Bool {
    switch e.data {
    case NodeType.LiteralNum:
        out = expr_to_value(e)
        return true
    case NodeType.LiteralStr:
        out = expr_to_value(e)
        return true
    case NodeType.LiteralBool:
        out = expr_to_value(e)
        return true
    case NodeType.Ident(id):
        if known.has(id) {
            ref v : Value = known.get(id)
            out = v
            return true
        }
        return false
    case:
        return false
    }
}

func_uses_unknown_globals := func(e: Expr, func_def: Expr, precomp_scope: Scope) returns shallow Bool {
    if e.data.is(NodeType.FuncDef) { return false }
    if e.data.is(NodeType.Ident) {
        ref name : Str = get_payload(e.data)
        ref fd : FunctionDef = get_payload(func_def.data)
        for p : Declaration in fd.params {
            if p.name.eq(name) { return false }
        }
        if known.has(name) { return false }
        if is_null(scope_get(precomp_scope, name)).not() { return false }
        return true
    }
    for ci in 0..e.children.len() {
        if func_uses_unknown_globals(e.child(ci), func_def, precomp_scope) { return true }
    }
    return false
}

try_eval_call := proc(scope: Scope, fcall: Expr, shallow require_known: Bool) returns ref Expr {
    // Check if the function body references unknown globals
    ref callee_ident : Str = get_payload(fcall.child(0).data)
    ref fn_cell : Cell = scope_get(scope, callee_ident)
    if is_null(fn_cell).not() {
        // TODO(#155): switch to fn_cell.val.is(Value.Func) once the
        // typer infers the Value enum type for Cell.val (currently
        // resolves to 'unknown', so UFCS has nothing to dispatch on).
        if is(fn_cell.val, Value.Func) {
            ref fptr : Dynamic = get_payload(fn_cell.val)
            ref fdef : Expr = deref(fptr)
            if fdef.data.is(NodeType.FuncDef) {
                if fdef.children.len().gt(0) {
                    if func_uses_unknown_globals(fdef.child(0), fdef, scope) {
                        return NULL
                    }
                }
            }
        }
    }

    // Build a call with literal args for the interpreter
    nargs := fcall.children.len().sub(1)
    mut ec := Expr.new(NodeType.FCall, fcall.line, fcall.col, fcall.path)
    ec.til_type = fcall.til_type
    ec.add_child(own fcall.child(0).clone())

    for i in 0..nargs {
        ref arg : Expr = fcall.child(i.add(1))
        mut arg_val := val_none()
        if is_known(arg, arg_val).not() {
            if require_known {
                arg.error("macro argument must be known at compile time")
            }
            return NULL
        }
        ec.add_child(own value_to_expr(arg_val, arg))
    }

    // Evaluate the call using the interpreter
    result := eval_expr(scope, ec)

    // Check if result is convertible to AST (value_to_expr returns NULL otherwise)
    mut can_convert := result.is(Value.Int)
    .or(result.is(Value.Byte))
    .or(result.is(Value.Short))
    .or(result.is(Value.Int32))
    .or(result.is(Value.Uint32))
    .or(result.is(Value.Uint64))
    .or(result.is(Value.Float))
    .or(result.is(Value.Boolean))
    if can_convert.not().and(result.is(Value.Struct)) {
        ref si : StructInstance = get_payload(result)
        if si.to_str().eq("Str") { can_convert = true }
    }
    if can_convert.not() {
        if require_known {
            fcall.error("macro returned non-primitive type")
        }
        return NULL
    }

    // Convert result to AST -- guaranteed non-NULL, safe to bind owned
    mut lit_local := value_to_expr(result, fcall)
    heap : Dynamic = malloc(Expr.size().to_u64())
    memcpy(heap, lit_local, Expr.size())
    memset(lit_local, 0, Expr.size())
    ref heap_lit : Expr = to_ptr(heap)
    return heap_lit
}

track_literal := proc(scope: Scope, name: Str, rhs: Expr) {
    mut v := val_none()
    if is_known(rhs, v) {
        mut vcopy := v
        known.set(own name.clone(), own vcopy)
        scope_set_owned(scope, name, v)
    }
}

is_macro_call := func(e: Expr) returns shallow Bool {
    if e.data.is(NodeType.FCall).not() { return false }
    if e.children.len().eq(0) { return false }
    ref callee : Expr = e.child(0)
    if callee.data.is(NodeType.Ident).not() { return false }
    return precomp_has_macro(get_payload(callee.data))
}

is_func_call := func(e: Expr) returns shallow Bool {
    if e.data.is(NodeType.FCall).not() { return false }
    if e.children.len().eq(0) { return false }
    ref callee : Expr = e.child(0)
    if callee.data.is(NodeType.Ident).not() { return false }
    return precomp_has_func(get_payload(callee.data))
}

process_body := proc(scope: Scope, body: Expr) {
    for i in 0..body.children.len() {
        ref stmt : Expr = body.child(i)
        if stmt.data.is(NodeType.Decl) {
            ref dd : Declaration = get_payload(stmt.data)
            if stmt.children.len().eq(0) { }
            else if stmt.child(0).data.is(NodeType.FuncDef)
            .or(stmt.child(0).data.is(NodeType.StructDef))
            .or(stmt.child(0).data.is(NodeType.EnumDef)) {
                if stmt.child(0).data.is(NodeType.FuncDef)
                .and(stmt.child(0).children.len().gt(0)) {
                    process_body(scope, decl_body(stmt))
                }
            } else if dd.own_type.eq(OwnType.Ref) { }
            else if dd.is_mut { }
            else if is_macro_call(stmt.child(0)) {
                ref lit : Expr = try_eval_call(scope, stmt.child(0), true)
                if is_null(lit).not() {
                    stmt.children.set(0, own lit.clone())
                    track_literal(scope, dd.name, lit)
                }
            } else if is_func_call(stmt.child(0)) {
                ref lit : Expr = try_eval_call(scope, stmt.child(0), false)
                if is_null(lit).not() {
                    stmt.children.set(0, own lit.clone())
                    track_literal(scope, dd.name, lit)
                } else {
                    track_literal(scope, dd.name, stmt.child(0))
                }
            } else {
                track_literal(scope, dd.name, stmt.child(0))
            }
        } else if stmt.data.is(NodeType.If) {
            if stmt.children.len().gt(1) {
                process_body(scope, stmt.child(1))
            }
            if stmt.children.len().gt(2) {
                process_body(scope, stmt.child(2))
            }
        } else if stmt.data.is(NodeType.While) {
            if stmt.children.len().gt(1) {
                process_body(scope, stmt.child(1))
            }
        } else if stmt.data.is(NodeType.FCall) {
            if is_macro_call(stmt) {
                ref lit : Expr = try_eval_call(scope, stmt, true)
                if is_null(lit).not() {
                    body.children.set(i, own lit.clone())
                }
            } else if is_func_call(stmt) {
                ref lit : Expr = try_eval_call(scope, stmt, false)
                if is_null(lit).not() {
                    body.children.set(i, own lit.clone())
                }
            }
        }
    }
}

precomp_scan_names := proc(prog: Expr) {
    for stmt : Expr in prog.children {
        if stmt.data.is(NodeType.Decl).and(stmt.children.len().gt(0)) {
            if stmt.child(0).data.is(NodeType.FuncDef) {
                ref fd : FunctionDef = get_payload(stmt.child(0).data)
                ref dd : Declaration = get_payload(stmt.data)
                if fd.func_type.is(FuncType.Macro) {
                    macros.add(own dd.name.clone())
                } else if fd.func_type.is(FuncType.Func) {
                    funcs.add(own dd.name.clone())
                }
            }
            if stmt.child(0).data.is(NodeType.StructDef) {
                ref sdd : Declaration = get_payload(stmt.data)
                ref sdd_data : StructDef = get_payload(stmt.child(0).data)
                for j in 0..sdd_data.ns_decls.len() {
                    ref fdd : Declaration = sdd_data.ns_decls.get(j)
                    ref fdef : Expr = fdd.default_value
                    if fdef.data.is(NodeType.FuncDef) {
                        ref ffd : FunctionDef = get_payload(fdef.data)
                        if ffd.func_type.is(FuncType.Func) {
                            qname := sdd.name.concat("_").concat(fdd.name)
                            funcs.add(own qname)
                        }
                    }
                }
            } else if stmt.child(0).data.is(NodeType.EnumDef) {
                ref sdd : Declaration = get_payload(stmt.data)
                ref _pc_edd : EnumDef = get_payload(stmt.child(0).data)
                for j in 0.._pc_edd.ns_decls.len() {
                    ref nsd : Declaration = _pc_edd.ns_decls.get(j)
                    if is_null(nsd.default_value) { continue }
                    if nsd.default_value.data.is(NodeType.FuncDef) {
                        ref ffd : FunctionDef = get_payload(nsd.default_value.data)
                        if ffd.func_type.is(FuncType.Func) {
                            qname := sdd.name.concat("_").concat(nsd.name)
                            funcs.add(own qname)
                        }
                    }
                }
            }
        }
    }
}

precomp_register_defs := proc(mut global: Scope, prog: Expr) {
    for stmt : Expr in prog.children {
        if stmt.data.is(NodeType.Decl).and(stmt.children.len().gt(0)) {
            if stmt.child(0).data.is(NodeType.FuncDef)
            .or(stmt.child(0).data.is(NodeType.StructDef))
            .or(stmt.child(0).data.is(NodeType.EnumDef)) {
                ref dd : Declaration = get_payload(stmt.data)
                mut val := val_none()
                // Build Value.Func manually: tag=9 (Func), data=pointer to child(0)
                memcpy(val, 9.to_i32(), 4)
                write_ptr(ptr_add(val, 8), stmt.child(0))
                scope_set_owned(global, dd.name, val)
                memset(val, 0, Value.size())
            }
        }
    }
}

precomp := proc(core_program: Expr, program: Expr) {
    // 1. Collect macro and pure func names
    macros = Set.new("Str", Str.size())
    funcs = Set.new("Str", Str.size())
    if is_null(core_program).not() { precomp_scan_names(core_program) }
    precomp_scan_names(program)

    // Nothing to fold?
    if macros.count.eq(0).and(funcs.count.eq(0)) {
        Set.delete(own macros, false)
        Set.delete(own funcs, false)
        return
    }

    // 2. Set up interpreter scope
    global := scope_new(NULL)
    if is_null(core_program).not() { precomp_register_defs(global, core_program) }
    precomp_register_defs(global, program)
    if is_null(core_program).not() { interpreter_init_ns(global, core_program) }
    interpreter_init_ns(global, program)

    // 2b. Init FFI
    ffi_init(program, NULL, NULL, NULL, NULL)
    if is_null(core_program).not() {
        ffi_init_struct_defs(core_program)
        ffi_init_scan_program(core_program)
    }

    // 3. Process the program body (user only)
    known = Map.new("Str", Str.size(), "Value", Value.size())
    process_body(global, program)

    // Cleanup
    Map.delete(own known, false)
    scope_free(own global)
    Set.delete(own macros, false)
    Set.delete(own funcs, false)
}
