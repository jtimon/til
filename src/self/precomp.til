mode lib

// Precomp: constant folding for macros and pure functions
mut macros := Set.new(Str)
mut funcs := Set.new(Str)
mut known := Map.new(Str, Value)

precomp_has_macro := func(name: Str) returns shallow Bool {
    return macros.has(name)
}

precomp_has_func := func(name: Str) returns shallow Bool {
    return funcs.has(name)
}

// Side-effecting names that mustn't be invoked at compile time.
// Mirrors rstil's hardcoded exit/malloc list, plus the I/O / FFI /
// environment-dependent ext_funcs that til core ships.
is_side_effecting_name := func(name: Str) returns shallow Bool {
    if name.eq("exit")        { return true }
    if name.eq("panic")       { return true }
    if name.eq("TODO")        { return true }
    if name.eq("UNREACHABLE") { return true }
    if name.eq("malloc") { return true }
    if name.eq("calloc") { return true }
    if name.eq("realloc") { return true }
    if name.eq("free")   { return true }
    if name.eq("memcpy") { return true }
    if name.eq("memmove") { return true }
    if name.eq("memset") { return true }
    if name.eq("read_ptr")  { return true }
    if name.eq("write_ptr") { return true }
    if name.eq("ptr_add")   { return true }
    if name.eq("ptr_eq")    { return true }
    if name.eq("to_ptr")    { return true }
    if name.eq("deref")     { return true }
    if name.eq("readfile")  { return true }
    if name.eq("writefile") { return true }
    if name.eq("print_single") { return true }
    if name.eq("eprint_single") { return true }
    if name.eq("print_flush") { return true }
    if name.eq("println") { return true }
    if name.eq("print")  { return true }
    if name.eq("in_read_line") { return true }
    if name.eq("cfile_open") { return true }
    if name.eq("cfile_close") { return true }
    if name.eq("cfile_read_all") { return true }
    if name.eq("cfile_write_str") { return true }
    if name.eq("file_mtime") { return true }
    if name.eq("unlink_path") { return true }
    if name.eq("spawn_cmd") { return true }
    if name.eq("wait_cmd")  { return true }
    if name.eq("run_cmd")   { return true }
    if name.eq("system_cmd") { return true }
    if name.eq("check_cmd_status") { return true }
    if name.eq("sleep_ms") { return true }
    if name.eq("clock_ms") { return true }
    if name.eq("get_thread_count") { return true }
    if name.eq("peak_rss_bytes") { return true }
    if name.eq("current_rss_bytes") { return true }
    if name.eq("process_id") { return true }
    if name.eq("get_bin_dir") { return true }
    if name.eq("get_cwd_str") { return true }
    if name.eq("ffi_global_symbol") { return true }
    if name.eq("ffi_user_symbol") { return true }
    if name.eq("ffi_load_global_lib") { return true }
    if name.eq("ffi_open_user_so") { return true }
    if name.eq("ffi_close_user_so") { return true }
    if name.eq("ffi_alloc_cif") { return true }
    if name.eq("ffi_prep_cif") { return true }
    if name.eq("ffi_call") { return true }
    if name.eq("dlopen") { return true }
    if name.eq("dlsym") { return true }
    if name.eq("dlclose") { return true }
    return false
}

value_to_expr := func(shallow val: Value, src: Expr) returns Expr {
    switch val {
    case Value.Int(x):
        mut e := Expr.new(NodeType.LiteralNum(x.to_str()), src.line, src.col)
        e.til_type = Type.I64
        return e
    case Value.Byte(x):
        mut e := Expr.new(NodeType.LiteralNum(x.to_str()), src.line, src.col)
        e.til_type = Type.U8
        return e
    case Value.Short(x):
        mut e := Expr.new(NodeType.LiteralNum(x.to_str()), src.line, src.col)
        e.til_type = Type.I16
        return e
    case Value.Int32(x):
        mut e := Expr.new(NodeType.LiteralNum(x.to_str()), src.line, src.col)
        e.til_type = Type.I32
        return e
    case Value.Uint32(x):
        mut e := Expr.new(NodeType.LiteralNum(x.to_str()), src.line, src.col)
        e.til_type = Type.U32
        return e
    case Value.Uint64(x):
        mut e := Expr.new(NodeType.LiteralNum(x.to_str()), src.line, src.col)
        e.til_type = Type.U64
        return e
    case Value.Float(_x):
        // F32 to_str uses %g and can emit scientific notation
        // ("6.28318e+06") that doesn't round-trip through Str.to_f32.
        // Don't fold F32-returning calls until we have a faithful F32
        // literal representation in the AST.
        return NULL
    case Value.Struct(si):
        if si.to_str().eq("Str") {
            sv := str_view(val)
            mut e := Expr.new(NodeType.LiteralStr(sv.clone()), src.line, src.col)
            e.til_type = Type.Struct("Str".clone())
            return e
        }
        return NULL
    case Value.Boolean(b):
        mut e := Expr.new(NodeType.LiteralBool(b.clone()), src.line, src.col)
        e.til_type = Type.Bool
        return e
    case:
        return NULL
    }
}

expr_to_value := func(e: Expr) returns shallow Value {
    switch e.node_type {
    case NodeType.LiteralNum(num):
        switch e.til_type {
        case Type.U8:  return val_u8(num.to_u8())
        case Type.U32: return val_u32(num.to_i64())
        case Type.U64: return val_u64(num.to_i64().to_u64())
        case Type.I16: return val_i16(num.to_i64())
        case Type.I32: return val_i32(num.to_i64())
        case Type.F32: return val_f32(num.to_f32())
        case: return val_i64(num.to_i64())
        }
    case NodeType.LiteralStr(s):
        return make_str_value(s.c_str, s.count)
    case NodeType.LiteralBool(b):
        return val_bool(b)
    case:
        return val_none()
    }
}

is_known := func(e: Expr, mut out: Value) returns shallow Bool {
    switch e.node_type {
    case NodeType.LiteralNum:
        out = expr_to_value(e)
        return true
    case NodeType.LiteralStr:
        out = expr_to_value(e)
        return true
    case NodeType.LiteralBool:
        out = expr_to_value(e)
        return true
    case NodeType.Ident(id):
        if known.has(id) {
            ref v : Value = known.get(id)
            out = v
            return true
        }
        return false
    case:
        return false
    }
}

// Walk `body` looking for a local Decl named `name`. Used to recognise
// typer-hoisted temps and other body-locals so func_uses_unknown_globals
// can skip flagging them as unknown globals.
body_has_local := proc(body: Expr, name: Str) returns shallow Bool {
    if body.node_type.is(NodeType.Decl) {
        ref dd : Declaration = get_payload(body.node_type)
        if dd.name.eq(name) { return true }
    }
    if body.node_type.is(NodeType.FuncDef) { return false }
    for c : Expr in body.children {
        if body_has_local(c, name) { return true }
    }
    return false
}

// `lenient`: when true, body-local Decl names (typer-hoisted temps,
// user-named locals) are NOT flagged as unknown -- the interpreter will
// see them when it walks the body. When false (master's behaviour),
// any Ident not in params/known/scope is unknown, which keeps macro
// fold from forcing eval into a body whose hoisted temps the eval
// scope can't see.
func_uses_unknown_globals := proc(e: Expr, func_def: Expr, precomp_scope: Scope, body_root: Expr, shallow lenient: Bool) returns shallow Bool {
    if e.node_type.is(NodeType.FuncDef) { return false }
    if e.node_type.is(NodeType.Ident) {
        ref name : Str = get_payload(e.node_type)
        // Side-effecting names are "unknown" for fold purposes: their
        // bodies aren't, but invoking them at compile time would kill
        // or corrupt the build.
        if is_side_effecting_name(name) { return true }
        // `clone`/`delete`/`concat`/`substr`/`format` allocate or free heap
        // memory and trigger destructor runs that read top-level constants
        // (e.g. Str.delete reads CAP_VIEW) precomp's scope doesn't have.
        if name.eq("clone") { return true }
        if name.eq("delete") { return true }
        if name.eq("concat") { return true }
        if name.eq("substr") { return true }
        if name.eq("format") { return true }
        ref fd : FunctionDef = get_payload(func_def.node_type)
        for p : Declaration in fd.params {
            if p.name.eq(name) { return false }
        }
        if known.has(name) { return false }
        if is_null(scope_get(precomp_scope, name)).not() { return false }
        if lenient.and(body_has_local(body_root, name)) { return false }
        return true
    }
    // Assign carries the LHS name as the node payload, not as an Ident
    // child. If the LHS isn't a body-local, the function mutates a
    // global -- never fold (eval would crash on missing bindings, or
    // worse, silently mutate precomp's interpreter scope).
    if e.node_type.is(NodeType.Assign) {
        ref aname : Str = get_payload(e.node_type)
        if body_has_local(body_root, aname).not() { return true }
    }
    // FieldAccess: detect `.clone()` / `.delete()` / etc on values where
    // the FA is the callee of an enclosing FCall. Same heap-cleanup risk.
    if e.node_type.is(NodeType.FieldAccess) {
        ref mname : Str = get_payload(e.node_type)
        if mname.eq("clone") { return true }
        if mname.eq("delete") { return true }
        if mname.eq("concat") { return true }
        if mname.eq("substr") { return true }
        if mname.eq("new").and(e.children.len().gt(0)) {
            if e.child(0).node_type.is(NodeType.Ident) {
                ref type_name : Str = get_payload(e.child(0).node_type)
                if type_name.eq("Vec") { return true }
            }
        }
    }
    for e_ci : Expr in e.children {
        if func_uses_unknown_globals(e_ci, func_def, precomp_scope, body_root, lenient) { return true }
    }
    return false
}

// If the function body is a trivially literal-returning shape, return a
// reference to that literal Expr. Handles both `return <lit>` and the
// typer-hoisted `_t := <lit>; return _t` form. Returns NULL otherwise.
priv extract_trivial_literal_return := func(fdef: Expr) returns ref Expr {
    if fdef.children.len().eq(0) { return NULL }
    ref body : Expr = fdef.child(0)
    n := body.children.len()
    if n.eq(1) {
        ref ret : Expr = body.child(0)
        if ret.node_type.is(NodeType.Return).not() { return NULL }
        if ret.children.len().eq(0) { return NULL }
        ref rv : Expr = ret.child(0)
        if rv.node_type.is(NodeType.LiteralNum)
            .or(rv.node_type.is(NodeType.LiteralStr))
            .or(rv.node_type.is(NodeType.LiteralBool)) {
            return rv
        }
        return NULL
    }
    if n.eq(2) {
        ref decl : Expr = body.child(0)
        ref ret : Expr = body.child(1)
        if decl.node_type.is(NodeType.Decl).not() { return NULL }
        if ret.node_type.is(NodeType.Return).not() { return NULL }
        if decl.children.len().eq(0) { return NULL }
        if ret.children.len().eq(0) { return NULL }
        ref dd : Declaration = get_payload(decl.node_type)
        ref ret_val : Expr = ret.child(0)
        if ret_val.node_type.is(NodeType.Ident).not() { return NULL }
        ref ident_name : Str = get_payload(ret_val.node_type)
        if ident_name.eq(dd.name).not() { return NULL }
        ref rhs : Expr = decl.child(0)
        if rhs.node_type.is(NodeType.LiteralNum)
            .or(rhs.node_type.is(NodeType.LiteralStr))
            .or(rhs.node_type.is(NodeType.LiteralBool)) {
            return rhs
        }
    }
    return NULL
}

// Try splitting `name` on every `_` and looking up each (left, right)
// pair via ns_get. Returns the first match's payload pointer or NULL.
// Lets the fast path resolve a typer/builder-flattened namespace
// callee like "Str_size" back to ns_get("Str", "size").
ns_lookup_flat := func(name: Str) returns shallow Dynamic {
    n := name.len()
    for i in 1..n {
        ref _b : U8 = name.byte_at(i)
        if _b.eq(95.to_u8()).not() { continue }
        sname := name.substr(0, i)
        rest_start := i.add(1)
        if rest_start.gte(n) { continue }
        mname := name.substr(rest_start, n.sub(rest_start))
        ref _nv : Value = ns_get(sname, mname)
        if is_null(_nv) { continue }
        if is(_nv, Value.Func).not() { continue }
        return get_payload(_nv)
    }
    return NULL
}

// For a FieldAccess callee like `recv.method`, derive the type name
// to dispatch on. If recv is an Ident that names a struct/enum (e.g.
// `Str.size`), use the Ident text. Otherwise fall back to recv.til_type
// so method calls on values (`x.add(y)` where x: I64) still resolve.
fa_recv_type_name := func(callee: Expr) returns Str {
    if callee.children.len().eq(0) { return "" }
    ref recv : Expr = callee.child(0)
    if recv.node_type.is(NodeType.Ident) {
        ref ident : Str = get_payload(recv.node_type)
        // If the Ident names a known type (`Str`/`I64`/...), use it.
        // Otherwise it's a value and we fall back to its til_type.
        ref _probe : Value = ns_get(ident, "size")
        if is_null(_probe).not() { return ident.clone() }
    }
    return til_type_name_c(recv.til_type)
}

// Fast path: if the callee is a nullary function whose body trivially
// returns a literal, return a heap-allocated clone of that literal.
try_fast_fold_call := func(scope: Scope, fcall: Expr) returns ref Expr {
    if fcall.children.len().eq(1).not() { return NULL }
    ref _fc_callee : Expr = fcall.child(0)
    mut _fc_fp : Dynamic = 0
    switch _fc_callee.node_type {
    case NodeType.Ident(_ci):
        ref _cell : Cell = scope_get(scope, _ci)
        if is_null(_cell).not() {
            if is(_cell.val, Value.Func) {
                _fc_fp = get_payload(_cell.val)
            }
        }
        // Fall back to namespace lookup for typer-flattened callees
        // (`Str_size()` instead of `Str.size()`).
        if is_null(_fc_fp) { _fc_fp = ns_lookup_flat(_ci) }
    case NodeType.FieldAccess(_mn):
        if _fc_callee.children.len().gt(0) {
            _sn := fa_recv_type_name(_fc_callee)
            if _sn.is_empty().not() {
                ref _nv : Value = ns_get(_sn, _mn)
                if is_null(_nv).not() {
                    if is(_nv, Value.Func) {
                        _fc_fp = get_payload(_nv)
                    }
                }
            }
        }
    case:
    }
    if is_null(_fc_fp) { return NULL }
    ref _fc_fdef : Expr = deref(_fc_fp)
    if _fc_fdef.node_type.is(NodeType.FuncDef).not() { return NULL }
    ref _lit : Expr = extract_trivial_literal_return(_fc_fdef)
    if is_null(_lit) { return NULL }
    mut _lit_clone := _lit.clone()
    _lit_clone.til_type = fcall.til_type
    _heap : Dynamic = malloc(Expr.size().to_u64())
    move(_heap, _lit_clone, Expr.size())
    ref _heap_ref : Expr = to_ptr(_heap)
    return _heap_ref
}

try_eval_call := proc(scope: Scope, fcall: Expr, shallow require_known: Bool, ctx: Context) returns ref Expr {
    ref _fast : Expr = try_fast_fold_call(scope, fcall)
    if is_null(_fast).not() { return _fast }

    ref callee : Expr = fcall.child(0)
    // Resolve fdef once so we can reject ref-returning funcs (results
    // are aliases not standalone values; for ext_funcs this also covers
    // env-dependent dlsym-style pointers that get truncated when
    // materialised back into a literal).
    mut fp : Dynamic = 0
    switch callee.node_type {
    case NodeType.Ident(callee_ident):
        // Block direct calls to side-effecting names (exit, malloc, panic,
        // clock_ms, ffi_global_symbol, ...).
        if is_side_effecting_name(callee_ident) { return NULL }
        ref fn_cell : Cell = scope_get(scope, callee_ident)
        if is_null(fn_cell).not() {
            if is(fn_cell.val, Value.Func) { fp = get_payload(fn_cell.val) }
        }
    case NodeType.FieldAccess(mname):
        // FieldAccess on an Ident value receiver: the interpreter needs
        // a binding to look up. If the Ident isn't a type name (Str/I64...)
        // and isn't a known constant, bail.
        if callee.children.len().gt(0) {
            ref recv : Expr = callee.child(0)
            if recv.node_type.is(NodeType.Ident) {
                ref _ri : Str = get_payload(recv.node_type)
                ref _probe : Value = ns_get(_ri, "size")
                if is_null(_probe) {
                    if known.has(_ri).not() { return NULL }
                }
            }
            sname := fa_recv_type_name(callee)
            if sname.is_empty().not() {
                ref ns_val : Value = ns_get(sname, mname)
                if is_null(ns_val).not() {
                    if is(ns_val, Value.Func) { fp = get_payload(ns_val) }
                }
            }
        }
    case:
    }
    if is_null(fp).not() {
        ref fdef : Expr = deref(fp)
        if fdef.node_type.is(NodeType.FuncDef) {
            ref _fd : FunctionDef = get_payload(fdef.node_type)
            // Folding a ref-returning func would bake the compile-time
            // alias into the AST. For ext_funcs it would also dlsym at
            // compile time and truncate the static address to scalar.
            if _fd.return_own_type.eq(OwnType.Ref) { return NULL }
            // Don't directly fold ext_funcs. Many user ext_funcs aren't
            // dispatchable at precomp time (their .so isn't dlopen'd) and
            // dispatching them would invoke runtime FFI with broken state.
            // Built-in arithmetic ops (I64_add etc.) are still invokable
            // when reached transitively through a user func body.
            if _fd.func_type.is(FuncType.ExtFunc) { return NULL }
            if fdef.children.len().gt(0) {
                // Macros use the strict body check (master's behaviour):
                // any unknown Ident bails before the args check, which
                // is what keeps `macro_add(N, 5)` from forcing eval.
                // Funcs use the lenient check that skips body-locals
                // (typer-hoisted temps), so non-trivial bodies can fold.
                if func_uses_unknown_globals(fdef.child(0), fdef, scope, fdef.child(0), require_known.not()) {
                    return NULL
                }
            }
        }
    }

    // Build a call with literal args for the interpreter
    nargs := fcall.children.len().sub(1)
    mut ec := Expr.new(NodeType.FCall(FCallData()), fcall.line, fcall.col)
    ec.til_type = fcall.til_type
    ec.add_child(own fcall.child(0).clone())

    for i in 0..nargs {
        ref arg : Expr = fcall.child(i.add(1))
        mut arg_val := val_none()
        if is_known(arg, arg_val).not() {
            if require_known {
                panic(
                    __LOC__,
                    ctx.path, ":", arg.line.to_str(), ":", arg.col.to_str(),
                    ": error: macro argument must be known at compile time",
                )
            }
            return NULL
        }
        ec.add_child(own value_to_expr(arg_val, arg))
    }

    // Evaluate the call using the interpreter
    result := eval_expr(scope, ec)

    // Value.Float intentionally excluded: F32_to_str -> %g can yield
    // scientific notation that doesn't round-trip through Str.to_f32.
    // Value.Struct(Str) intentionally excluded: folded strings can carry
    // NULs/non-ASCII that don't round-trip through a C source literal.
    mut can_convert := result.is(Value.Int)
    .or(result.is(Value.Byte))
    .or(result.is(Value.Short))
    .or(result.is(Value.Int32))
    .or(result.is(Value.Uint32))
    .or(result.is(Value.Uint64))
    .or(result.is(Value.Boolean))
    if can_convert.not() {
        if require_known {
            panic(
                __LOC__,
                ctx.path, ":", fcall.line.to_str(), ":", fcall.col.to_str(),
                ": error: macro returned non-primitive type",
            )
        }
        return NULL
    }

    // value_to_expr can still return NULL (e.g. Value.Struct non-Str).
    mut lit_local := value_to_expr(result, fcall)
    if is_null(lit_local) { return NULL }
    // Preserve fcall.til_type. value_to_expr derives til_type from the
    // runtime Value variant (Uint32 -> U32), but the original fcall might
    // have been typed as USize/U64/... at typer time. Surrounding code
    // (re-typing, codegen) expects the original til_type.
    lit_local.til_type = fcall.til_type
    heap : Dynamic = malloc(Expr.size().to_u64())
    move(heap, lit_local, Expr.size())
    ref heap_lit : Expr = to_ptr(heap)
    return heap_lit
}

track_literal := func(scope: Scope, name: Str, rhs: Expr) {
    mut v := val_none()
    if is_known(rhs, v) {
        mut vcopy := v
        known.set(own name.clone(), own vcopy)
        scope_set_owned(scope, name, v)
    }
}

is_macro_call := func(e: Expr) returns shallow Bool {
    if e.node_type.is(NodeType.FCall).not() { return false }
    if e.children.len().eq(0) { return false }
    ref callee : Expr = e.child(0)
    if callee.node_type.is(NodeType.Ident) {
        return precomp_has_macro(get_payload(callee.node_type))
    }
    if callee.node_type.is(NodeType.FieldAccess) {
        sname := fa_recv_type_name(callee)
        if sname.is_empty() { return false }
        ref mname : Str = get_payload(callee.node_type)
        qname := sname.format("_", mname)
        return precomp_has_macro(qname)
    }
    return false
}

is_func_call := func(e: Expr) returns shallow Bool {
    if e.node_type.is(NodeType.FCall).not() { return false }
    if e.children.len().eq(0) { return false }
    ref callee : Expr = e.child(0)
    if callee.node_type.is(NodeType.Ident) {
        return precomp_has_func(get_payload(callee.node_type))
    }
    if callee.node_type.is(NodeType.FieldAccess) {
        sname := fa_recv_type_name(callee)
        if sname.is_empty() { return false }
        ref mname : Str = get_payload(callee.node_type)
        qname := sname.format("_", mname)
        return precomp_has_func(qname)
    }
    return false
}

// Uniform fold: walk the subtree rooted at `e` and replace every FCall
// child whose callee is a known macro or pure func with its folded
// literal. Macros are forced (require_known); funcs try the fast path
// first, then the eval-based path for direct Ident callees (so
// `add(1, 2)` -> `3` works -- rstil-style).
fold_subtree := proc(scope: Scope, mut e: Expr, ctx: Context) {
    for i in 0..e.children.len() {
        ref child : Expr = e.child(i)
        fold_subtree(scope, child, ctx)
        if child.node_type.is(NodeType.FCall) {
            if is_macro_call(child) {
                ref lit : Expr = try_eval_call(scope, child, true, ctx)
                if is_null(lit).not() { e.children.set(i, own lit.clone()) }
            } else if is_func_call(child) {
                ref lit : Expr = try_fast_fold_call(scope, child)
                if is_null(lit).not() {
                    e.children.set(i, own lit.clone())
                } else if e.node_type.is(NodeType.Body).not() {
                    // Only fold FCalls inside expression contexts (parent
                    // isn't Body). Statement-level FCalls have meaningful
                    // side effects that fold would silently discard.
                    if child.children.len().gt(0) {
                        ref _cc : Expr = child.child(0)
                        // Only fold Ident-callee FCalls. FA-callee folds
                        // (method calls) require precomp-scope bindings
                        // for the receiver that we can't always provide.
                        if _cc.node_type.is(NodeType.Ident) {
                            ref lit2 : Expr = try_eval_call(scope, child, false, ctx)
                            if is_null(lit2).not() { e.children.set(i, own lit2.clone()) }
                        }
                    }
                }
            }
        }
        // Forward-track typer-hoisted temp Decls (`_t_*`) with literal
        // rhs so siblings can fold calls through them. The hoister
        // numbers temps program-globally, so `_t_*` names are unique
        // across sibling bodies. User-named locals are intentionally
        // NOT tracked: shared names (`x`, `result`, `i`) across sibling
        // bodies would let one body's value bleed into another's fold
        // via the global `known` Map. (rstil avoids this with a scope
        // stack; til doesn't have one.)
        if child.node_type.is(NodeType.Decl) {
            ref dd : Declaration = get_payload(child.node_type)
            if dd.is_mut.not()
            .and(dd.own_type.eq(OwnType.Ref).not())
            .and(dd.name.starts_with("_t_"))
            .and(child.children.len().gt(0)) {
                track_literal(scope, dd.name, child.child(0))
            }
        }
    }
}

process_body := proc(scope: Scope, body: Expr, ctx: Context, shallow at_global: Bool) {
    fold_subtree(scope, body, ctx)
    // Namespace method bodies live in StructDef/EnumDef ns_decls, not in
    // the body tree, so fold_subtree never reaches them. Walk them here.
    for stmt : Expr in body.children {
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        if stmt.children.len().eq(0) { continue }
        ref rhs : Expr = stmt.child(0)
        if rhs.node_type.is(NodeType.StructDef).or(rhs.node_type.is(NodeType.EnumDef)) {
            ref ns : Vec = def_ns_decls(rhs)
            for _nsd_e : Declaration in ns {
                ref nsd : Declaration = _nsd_e
                if is_null(nsd.default_value) { continue }
                if nsd.default_value.node_type.is(NodeType.FuncDef).not() { continue }
                if nsd.default_value.children.len().eq(0) { continue }
                fold_subtree(scope, nsd.default_value.child(0), ctx)
            }
        }
    }
    // Track Decl literals so future Idents see them as known. Recurse
    // into FuncDef bodies. Only track at top-level (at_global) -- inside
    // function bodies, user-named locals (`x`, `result`, `i`) collide
    // across siblings, and a global `known` Map would let one body's
    // value bleed into another's fold. fold_subtree handles `_t_*`
    // typer-hoisted temps directly during its walk (they're program-
    // unique by counter, so they don't collide).
    for stmt : Expr in body.children {
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        if stmt.children.len().eq(0) { continue }
        ref rhs : Expr = stmt.child(0)
        if rhs.node_type.is(NodeType.FuncDef) {
            if rhs.children.len().gt(0) { process_body(scope, stmt.child(0).child(0), ctx, false) }
            continue
        }
        if rhs.node_type.is(NodeType.StructDef) { continue }
        if rhs.node_type.is(NodeType.EnumDef) { continue }
        if at_global.not() { continue }
        ref dd : Declaration = get_payload(stmt.node_type)
        if dd.is_mut { continue }
        if dd.own_type.is(OwnType.Ref) { continue }
        track_literal(scope, dd.name, rhs)
    }
}

precomp_scan_names := func(prog: Expr) {
    for stmt : Expr in prog.children {
        if stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0)) {
            if stmt.child(0).node_type.is(NodeType.FuncDef) {
                ref fd : FunctionDef = get_payload(stmt.child(0).node_type)
                ref dd : Declaration = get_payload(stmt.node_type)
                if fd.func_type.is(FuncType.Macro) {
                    macros.add(own dd.name.clone())
                } else if fd.func_type.is(FuncType.Func)
                    .or(fd.func_type.is(FuncType.ExtFunc)) {
                    funcs.add(own dd.name.clone())
                }
            }
            switch stmt.child(0).node_type {
            case NodeType.StructDef(sdd_data):
                ref sdd : Declaration = get_payload(stmt.node_type)
                for d_j : Declaration in sdd_data.ns_decls {
                    ref fdd : Declaration = d_j
                    ref fdef : Expr = fdd.default_value
                    if fdef.node_type.is(NodeType.FuncDef) {
                        ref ffd : FunctionDef = get_payload(fdef.node_type)
                        qname := sdd.name.format("_", fdd.name)
                        if ffd.func_type.is(FuncType.Macro) {
                            macros.add(own qname)
                        } else if ffd.func_type.is(FuncType.Func)
                            .or(ffd.func_type.is(FuncType.ExtFunc)) {
                            funcs.add(own qname)
                        }
                    }
                }
            case NodeType.EnumDef(pc_edd):
                ref sdd : Declaration = get_payload(stmt.node_type)
                for d_j : Declaration in pc_edd.ns_decls {
                    ref nsd : Declaration = d_j
                    if is_null(nsd.default_value) { continue }
                    if nsd.default_value.node_type.is(NodeType.FuncDef) {
                        ref ffd : FunctionDef = get_payload(nsd.default_value.node_type)
                        qname := sdd.name.format("_", nsd.name)
                        if ffd.func_type.is(FuncType.Macro) {
                            macros.add(own qname)
                        } else if ffd.func_type.is(FuncType.Func)
                            .or(ffd.func_type.is(FuncType.ExtFunc)) {
                            funcs.add(own qname)
                        }
                    }
                }
            case:
            }
        }
    }
}

precomp_register_defs := func(mut global: Scope, prog: Expr) {
    for stmt : Expr in prog.children {
        if stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0)) {
            if stmt.child(0).node_type.is(NodeType.FuncDef)
            .or(stmt.child(0).node_type.is(NodeType.StructDef))
            .or(stmt.child(0).node_type.is(NodeType.EnumDef)) {
                ref dd : Declaration = get_payload(stmt.node_type)
                mut val := val_none()
                // Build Value.Func manually: tag=9 (Func), data=pointer to child(0)
                memcpy(val, 9.to_i32(), 4)
                write_ptr(ptr_add(val, 8), stmt.child(0))
                scope_set_owned(global, dd.name, val)
            }
        }
    }
}

precomp := proc(core_program: Expr, program: Expr, ctx: Context) {
    // 1. Collect macro and pure func names
    macros = Set.new(Str)
    funcs = Set.new(Str)
    if is_null(core_program).not() { precomp_scan_names(core_program) }
    precomp_scan_names(program)

    // Nothing to fold?
    if macros.count.eq(0).and(funcs.count.eq(0)) {
        Set.delete(own macros, false)
        Set.delete(own funcs, false)
        return
    }

    // 2. Set up interpreter scope
    global := scope_new(NULL)
    if is_null(core_program).not() { precomp_register_defs(global, core_program) }
    precomp_register_defs(global, program)
    if is_null(core_program).not() { interpreter_init_ns(ctx, global, core_program) }
    interpreter_init_ns(ctx, global, program)

    // 2b. Init FFI
    ffi_init(program, NULL, NULL, NULL, NULL)
    if is_null(core_program).not() {
        ffi_init_struct_defs(core_program)
        ffi_init_scan_program(core_program)
    }

    // 3. Fold calls in both core and user programs.
    known = Map.new(Str, Value)
    if is_null(core_program).not() { process_body(global, core_program, ctx, true) }
    process_body(global, program, ctx, true)

    // Cleanup
    Map.delete(own known, false)
    scope_free(own global)
    Set.delete(own macros, false)
    Set.delete(own funcs, false)
}
