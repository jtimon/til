mode lib
import("context")

// Check if a FieldAccess/FieldAssign Expr accesses a namespace field.
fa_is_ns := func(e: Expr, scope: TypeScope) returns Bool {
    if e.children.len() == 0 { return false }
    if e.node_type.is(NodeType.FieldAccess).not().and(e.node_type.is(NodeType.FieldAssign).not()) { return false }
    ref obj : Expr = e.children[0]
    mut sn := til_type_name(obj.til_type())
    if sn.len() == 0 {
        switch obj.node_type {
        case NodeType.Ident(id):
            sn = Str.clone(id.ident_name())
        case:
            return false
        }
    }
    ref sdef : Expr = scope.get_struct(sn)
    if sdef.is_null() { return false }
    mut fname := ""
    switch e.node_type {
    case NodeType.FieldAccess(fn):
        fname = Str.clone(fn.field_access_name())
    case NodeType.FieldAssign(fad):
        fname = fad.name
    case:
        UNREACHABLE()
        return false
    }
    ref ns : Vec(Declaration) = def_ns_decls(sdef)
    for dd : Declaration in ns {
        if dd.name == fname { return true }
    }
    return false
}

priv type_binding_is_type_token := func(scope: TypeScope, b: TypeBinding) returns Bool {
    if b.is_null() { return false }
    if b.is_type_alias { return true }
    if b.is_builtin { return true }
    if scope.struct_def_of(b.name).is_null().not() { return true }
    ref bfd : Expr = scope.lookup_func(b.name)
    if bfd.is_null().not() {
        if bfd.children.len() == 0 { return true }
    }
    return false
}

make_til_type_expr := func(src: Expr, t: Type) returns Expr {
    mut variant_name := ""
    mut payload_name := ""
    mut has_payload := false
    // Variants stored under Type.Primitive(Primitive.X) need a nested
    // construction `Type.Primitive(Primitive.X)`, not a bare
    // `Type.X` (Type has no such field). Built below after the switch.
    mut primitive_variant := ""
    switch t {
    case Type.Unknown:   variant_name = "Unknown"
    case Type.None:      variant_name = "None"
    case Type.Primitive(Primitive.I64):       primitive_variant = "I64"
    case Type.Primitive(Primitive.U8):        primitive_variant = "U8"
    case Type.Primitive(Primitive.I8):        primitive_variant = "I8"
    case Type.Primitive(Primitive.I16):       primitive_variant = "I16"
    case Type.Primitive(Primitive.U16):       primitive_variant = "U16"
    case Type.Primitive(Primitive.I32):       primitive_variant = "I32"
    case Type.Primitive(Primitive.U32):       primitive_variant = "U32"
    case Type.Primitive(Primitive.U64):       primitive_variant = "U64"
    case Type.Primitive(Primitive.F32):       primitive_variant = "F32"
    case Type.Primitive(Primitive.Bool):      primitive_variant = "Bool"
    case Type.Struct(s): variant_name = "Struct"; payload_name = s.clone(); has_payload = true
    case Type.StructDef: variant_name = "StructDef"
    case Type.Enum(s):   variant_name = "Enum"; payload_name = s.clone(); has_payload = true
    case Type.EnumDef:   variant_name = "EnumDef"
    case Type.FuncDef:   variant_name = "FuncDef"
    case Type.FuncPtr:   variant_name = "FuncPtr"
    // Issue #58: FuncPtrSig carries a FuncSig alias name. For
    // make_til_type_expr we emit it as the bare FuncPtr type token --
    // the name isn't part of til's type-token surface (no user-visible
    // `Type.FuncPtrSig("X")` constructor exists yet), and downstream
    // consumers that care about the name read it from the binding's
    // type via til_type_name. As migration progresses this can grow
    // its own variant_name path.
    case Type.FuncPtrSig: variant_name = "FuncPtr"
    case Type.Body:      variant_name = "Body"
    case Type.Dynamic:   variant_name = "Dynamic"
    case Type.Custom(s): variant_name = "Custom"; payload_name = s.clone(); has_payload = true
    }
    if primitive_variant.len() > 0 {
        // Build Type.Primitive(Primitive.<primitive_variant>).
        mut type_ident_p := Expr.new(ident_node("Type"), src.line, src.col)
        type_ident_p.set_til_type(Type.Enum("Type"))
        mut prim_ident := Expr.new(ident_node("Primitive"), src.line, src.col)
        prim_ident.set_til_type(Type.Enum("Primitive"))
        mut prim_fa := Expr.new(field_access_node(primitive_variant), src.line, src.col)
        prim_fa.add_child(own prim_ident)
        prim_fa.set_til_type(Type.Enum("Primitive"))
        mut type_prim_fa := Expr.new(field_access_node("Primitive"), src.line, src.col)
        type_prim_fa.add_child(own type_ident_p)
        type_prim_fa.set_til_type(Type.Unknown)
        mut call := Expr.new(NodeType.FCall(FCallData()), src.line, src.col)
        call.add_child(own type_prim_fa)
        call.add_child(own prim_fa)
        // The Type.Primitive(p) constructor takes ownership of its payload
        // (it frees the boxed Primitive), so the payload arg (child 1) must
        // be emitted as an owned heap box, not a stack compound literal.
        set_own_arg(call, 1)
        call.set_til_type(Type.Enum("Type"))
        return call
    }
    mut type_ident := Expr.new(ident_node("Type"), src.line, src.col)
    type_ident.set_til_type(Type.Enum("Type"))
    mut fa := Expr.new(field_access_node(variant_name), src.line, src.col)
    fa.add_child(own type_ident)
    if has_payload.not() {
        fa.set_til_type(Type.Enum("Type"))
        return fa
    }
    fa.set_til_type(Type.Unknown)
    mut call := Expr.new(NodeType.FCall(FCallData()), src.line, src.col)
    call.add_child(own fa)
    mut payload := Expr.new(NodeType.Literal(Literal.Str(payload_name)), src.line, src.col)
    call.add_child(own payload)
    call.set_til_type(Type.Enum("Type"))
    return call
}

priv rewrite_til_type_arg := proc(scope: TypeScope, mut parent: Expr, arg_idx: USize, ptype: Type, in_func: I32, ctx: Context) {
    if is_type_metatype(ptype).not() { return }
    ref arg : Expr = parent.children[arg_idx]
    switch arg.node_type {
    case NodeType.Ident(arg_name):
        ref b : TypeBinding = scope.get_binding(arg_name.ident_name())
        if type_binding_is_type_token(scope, b).not() { return }
        replacement := arg.make_til_type_expr(b.type)
        parent.children[arg_idx] = replacement
        infer_expr(scope, parent.children[arg_idx], in_func, ctx)
    case:
    }
}

// Look up the OwnType for the instance field of a FieldAccess/FieldAssign.
fa_own_type := func(e: Expr, scope: TypeScope) returns shallow OwnType {
    if e.children.len() == 0 { return OwnType.Shallow }
    if e.node_type.is(NodeType.FieldAccess).not().and(e.node_type.is(NodeType.FieldAssign).not()) { return OwnType.Shallow }
    ref obj : Expr = e.children[0]
    mut sn := til_type_name(obj.til_type())
    if sn.len() == 0 {
        switch obj.node_type {
        case NodeType.Ident(id):
            sn = Str.clone(id.ident_name())
        case:
            return OwnType.Shallow
        }
    }
    ref sdef : Expr = scope.get_struct(sn)
    if sdef.is_null() { return OwnType.Shallow }
    mut fname := ""
    switch e.node_type {
    case NodeType.FieldAccess(fn):
        fname = Str.clone(fn.field_access_name())
    case NodeType.FieldAssign(fad):
        fname = fad.name
    case:
        UNREACHABLE()
        return OwnType.Shallow
    }
    switch sdef.node_type {
    case NodeType.StructDef(ot_sdd):
        for dd : Declaration in ot_sdd.fields {
            if dd.name == fname { return dd.own_type }
        }
    case:
    }
    return OwnType.Shallow
}

// hoist_counter / va_counter / kw_counter / coll_counter previously
// lived here as module-level mut; they moved to Context (see
// initer.til). The hoist/desugar pre-pass chain (body_pre_passes ->
// apply_call_hoist_delete -> process_call_desugars +
// apply_hoist_to_stmt -> hoist_to_temp / hoist_expr / ...) threads
// `mut ctx: Context` so the same Context that already owns the rest
// of the typer scratch state also owns these unique-name counters.
// proc_calls_count / proc_def_depth previously lived here as
// module-level mut; they moved to Context (see initer.til). The
// typer reads/writes via ctx.proc_calls_count / ctx.proc_def_depth.
// errors / current_type_name / current_top_func_name / auto_gen_depth /
// throw_used_local_names likewise moved onto Context (see initer.til);
// helpers with ctx in scope use ctx.<field>, and the leaf diagnostics
// (type_error / type_error_at) reach it via ctx.
// Issue #93 follow-up: name of the top-level Decl whose body we are
// currently typing (function rhs or struct/enum that contains the
// active ns method body via current_type_name). Lifted nested defs
// carry their original parent in TypeBinding.orig_name; the function-
// scope priv check uses these two tracking globals to decide whether
// a reference at the current location is allowed to see the mangled
// name (only the original parent function and any of its other lifted
// descendants can). current_top_func_name now lives on Context.
// Issue #198: the throw_type_registry / throws_global tables
// previously declared here moved onto the
// `Context` struct (see initer.til) so cross-unit typer state lives
// on the same ctx everything else threads through. The accessors
// below take `ctx` and the body-walk helpers thread it down.
// #187 step 2: nesting depth of auto-generated FuncDef bodies
// (clone/delete/size/etc emitted by initer). The unused-priv-member
// check ignores reads inside these so genuinely-unused priv fields
// and ns methods are not masked by boilerplate references.
// auto_gen_depth / throw_used_local_names now live on Context.
// typer_in_shallow_return / typer_in_main_func previously lived as
// module-level mut here. They moved to Context (see initer.til) since
// garbager.til reads them and the garbager entry points already thread
// ctx. infer_func_def_expr writes ctx.typer_in_* while typing each
// body; collect_scope_locals / promote_own_transferred_locals read
// them through ctx.
I64Name := "I64"
U8Name := "U8"
I8Name := "I8"
I16Name := "I16"
U16Name := "U16"
I32Name := "I32"
U32Name := "U32"
U64Name := "U64"
F32Name := "F32"
BoolName := "Bool"

priv CtorArg := enum {
    Unfilled,
    Filled: Expr,
}

// Active file path and error counter for diagnostics live on Context
// (ctx.path / ctx.errors), threaded explicitly through type_error /
// type_error_at and every caller.
// Non-priv so the garbager module can report use-after-ownership-transfer
// against the same diagnostic counter.
type_error := proc(e: Expr, msg: Str, ctx: Context) {
    e.error(ctx.path, msg)
    ctx.errors++
}

type_error_at := proc(path: Str, line: U32, col: U32, msg: Str, ctx: Context) {
    println(path, ":", line.to_str(), ":", col.to_str(), ": error: ", msg)
    ctx.errors++
}

find_namespace_func := func(sdef: Expr, method: Str, scope: TypeScope) returns ref Expr {
    if sdef.is_null() { return NULL }
    ref ns : Vec(Declaration) = def_ns_decls(sdef)
    for fd : Declaration in ns {
        if fd.name == method {
            ref e : Expr = fd.default_value
            if scope.is_null().not() {
                if e.node_type.is(NodeType.Ident) {
                    switch e.node_type {
                    case NodeType.Ident(id):
                        sf := scope.find(id.ident_name())
                        switch sf {
                        case ScopeFind.Found(b):
                            ref bfd : Expr = scope.lookup_func(b.name)
                            if bfd.is_null().not() { return bfd }
                            ref bsd : Expr = scope.struct_def_of(b.name)
                            if bsd.is_null().not() { return bsd }
                        case:
                        }
                    case:
                    }
                }
            }
            return e
        }
    }
    return NULL
}

// Issue #191: check if an Expr is comptime-known. Used by typer to
// validate macro arguments and by constfolder to decide func folding.
// Conservative: only accepts shapes that are definitely known at
// compile time.
priv expr_is_comptime := func(e: Expr, scope: TypeScope) returns Bool {
    switch e.node_type {
    case NodeType.Literal(Literal.Num):    return true
    case NodeType.Literal(Literal.Str):    return true
    case NodeType.Literal(Literal.Bool):   return true
    case NodeType.Literal(Literal.Null):   return true
    case NodeType.Ident(id):
        ref b : TypeBinding = scope.get_binding(id.ident_name())
        if b.is_null() { return false }
        if b.is_mut { return false }
        if b.is_param { return false }
        return true
    case NodeType.FCall:
        if e.children.len() == 0 { return false }
        // Issue #57: a `Type.<Variant>(...)` constructor call returns a Type
        // metatype value -- pure and comptime when its arg(s) are. The typer
        // rewrites a Type-typed ident (e.g. `mymacro(NamedEnum)` or anon-lifted
        // `enum { ... }`) into this form via make_til_type_expr, so recognise
        // it before the binding lookup below (there is no `Type_Enum` binding
        // for the receiver-qualified method name).
        if is_type_metatype(e.til_type()) {
            for ai in 1..e.children.len() {
                if e.children[ai].expr_is_comptime(scope).not() { return false }
            }
            return true
        }
        ref callee : Expr = e.children[0]
        mut cb_ft := FuncType.Proc
        switch callee.node_type {
        case NodeType.Ident(cn):
            ref cb : TypeBinding = scope.get_binding(cn.ident_name())
            if cb.is_null() { return false }
            if cb.is_func_decl.not() { return false }
            cb_ft = binding_func_type(cb)
        case NodeType.FieldAccess(mn):
            // A namespace/UFCS method call (`recv.method(...)`) is lowered
            // by infer_field_access_fcall to `Type.method(recv, ...)`, with
            // the receiver's type as a leading arg. Those methods live in the
            // type's namespace -- they are NOT registered as flat `Type_method`
            // bindings, so a `scope.get_binding(...)` lookup always misses
            // (issue #285: that miss wrongly rejected `2.to_f32()`). Resolve
            // the FuncDef through the namespace and read its FuncType directly.
            if callee.children.len() == 0 { return false }
            ref recv : Expr = callee.children[0]
            mut sname := til_type_name(recv.til_type())
            if sname.len() == 0 {
                switch recv.node_type {
                case NodeType.Ident(rn):
                    sname = Str.clone(rn.ident_name())
                case:
                }
            }
            if sname.len() == 0 { return false }
            ref sdef : Expr = scope.get_struct(sname)
            ref ns_func : Expr = find_namespace_func(sdef, mn.field_access_name(), scope)
            if ns_func.is_null() { return false }
            switch ns_func.node_type {
            case NodeType.FuncDef(nfd):
                cb_ft = nfd.func_type
            case:
                return false
            }
        case:
            return false
        }
        if cb_ft.is(FuncType.Proc).or(cb_ft.is(FuncType.ExtProc)).or(cb_ft.is(FuncType.CoreProc)) {
            return false
        }
        if cb_ft.is(FuncType.Macro).or(cb_ft.is(FuncType.Func)).or(cb_ft.is(FuncType.ExtFunc)).or(cb_ft.is(FuncType.CoreFunc)).or(cb_ft.is(FuncType.CoreLazyFunc)) {
            for ai in 1..e.children.len() {
                if e.children[ai].expr_is_comptime(scope).not() { return false }
            }
            return true
        }
        return false
    case NodeType.FieldAccess:
        // Issue #57: `Type.<Variant>` (no payload, e.g. `Type.None` produced
        // by make_til_type_expr for primitive type-token args) is a Type
        // metatype value -- pure and comptime.
        if is_type_metatype(e.til_type()) {
            return true
        }
        return false
    case:
        return false
    }
}

// Issue #179 step 5: locate a namespace member's Declaration so the
// caller can read its is_priv flag (find_namespace_func only returns
// the default_value FuncDef Expr).
find_ns_decl := func(sdef: Expr, method: Str) returns ref Declaration {
    if sdef.is_null() { return NULL }
    ref ns : Vec(Declaration) = def_ns_decls(sdef)
    for fd : Declaration in ns {
        if fd.name == method { return fd }
    }
    return NULL
}

priv try_ufcs_rewrite := func(scope: TypeScope, mut e: Expr, fa: Expr, mut obj: Expr, method: Str, type_name: Str, ctx: Context) returns Bool {
    // Top-level `priv` free functions are file-mangled to
    // `priv__<path>__<name>`, and init_rewrite_refs only rewrites Ident
    // references -- not the method name on a UFCS FieldAccess. So
    // `x.priv_helper(...)` arrives here with the bare name while the
    // binding lives under the mangled name. Retry the lookup mangled so
    // priv free functions are UFCS-callable in their own file (the U in
    // UFCS is universal). cross-file priv access is still rejected later
    // by check_priv_access.
    mut lookup_name := method.clone()
    ref bare : TypeBinding = scope.get_binding(method)
    if bare.is_null() {
        mangled := priv_c_name(ctx.path, method)
        ref pm : TypeBinding = scope.get_binding(mangled)
        if pm.is_null().not() { lookup_name = mangled.clone() }
    }
    ref top : TypeBinding = scope.get_binding(lookup_name)
    mut ufcs_match : I32 = 0
    if top.is_null().not() {
        ref top_fd : Expr = scope.lookup_func(top.name)
        if top_fd.is_null().not() {
            switch top_fd.node_type {
            case NodeType.FuncDef(top_fdef):
                if top_fdef.params.len() > 0 {
                    ref first_param : Str = top_fdef.params[0].explicit_type
                    if first_param.len() > 0 {
                        // Only a genuine free-function *declaration* is
                        // UFCS-callable; a func-pointer value bound to the
                        // same sig (is_func_decl false) must not match, even
                        // though the sig's own FuncDef is a Func.
                        top_ft := binding_func_type(top)
                        is_free_func := top.is_func_decl.and(
                            top_ft.is(FuncType.Func)
                            .or(top_ft.is(FuncType.ExtFunc))
                            .or(top_ft.is(FuncType.Proc))
                            .or(top_ft.is(FuncType.ExtProc))
                            .or(top_ft.is(FuncType.CoreFunc))
                            .or(top_ft.is(FuncType.CoreProc))
                            .or(top_ft.is(FuncType.CoreLazyFunc)))
                        if type_name.len() > 0 {
                            if first_param == type_name {
                                ufcs_match = 1
                            } else if first_param.eq("Dynamic").and(is_free_func) {
                                ufcs_match = 1
                            }
                        } else if obj.til_type().is(Type.Dynamic) {
                            pt := type_from_name(first_param, scope, ctx)
                            narrow_dynamic(obj, pt)
                            ufcs_match = 1
                        }
                    }
                }
            case:
            }
        }
    }
    if ufcs_match == 0 { return false }
    mut fn_ident := Expr.new(ident_node(lookup_name), fa.line, fa.col)
    mut new_children := Vec(Expr).new()
    new_children.push(own fn_ident)
    // Move the receiver out of the old callee `fa` (slot 0) instead of
    // cloning it: push_take zeroes fa's slot so the trailing
    // `e.children = new_children` FieldAssign frees the old callee --
    // including its FieldAccess method-name Str -- without leaking and
    // without an extra clone of the receiver subtree. #109.
    new_children.push_take(e.children[0].children, 0)
    for i in 1..e.children.len() {
        new_children.push_take(e.children, i)
    }
    e.children = new_children
    return true
}

// Resolve the FunctionDef Expr that describes the callee signature for an
// FCall, by walking the AST + scope rather than reading a cached field.
// Mirrors the four FuncPtr-indirect cases the typer used to handle:
//   1/2. callee is FieldAccess on a struct whose field has a FuncSig type
//   3.   callee is an Ident bound to a FuncPtr local/param
//   4.   callee is an Ident for a regular func that returns a FuncSig
// Returns NULL when the binding is not in `scope` (e.g. param/local at
// builder time after func_scope was destroyed). Callers that need to
// resolve those cases must layer their own fallback on top.
resolve_fn_sig := func(fcall: Expr, scope: TypeScope) returns ref Expr {
    if fcall.is_null() { return NULL }
    if fcall.node_type.is(NodeType.FCall).not() { return NULL }
    if fcall.children.len() == 0 { return NULL }
    ref callee : Expr = fcall.children[0]
    switch callee.node_type {
    case NodeType.Ident(name):
        ref cb : TypeBinding = scope.get_binding(name.ident_name())
        if cb.is_null() { return NULL }
        if cb.type.is_funcptr().not() { return NULL }
        ref cb_fd : Expr = scope.lookup_func(cb.name)
        if cb_fd.is_null() { return NULL }
        // A func-pointer value (not a function declaration) carries a
        // signature func_def: hand it back directly.
        if cb.is_func_decl.not() {
            return cb_fd
        }
        switch cb_fd.node_type {
        case NodeType.FuncDef(cb_fdef):
            if cb_fdef.return_type.len() == 0 { return NULL }
            ref rsb : TypeBinding = scope.get_binding(cb_fdef.return_type)
            if rsb.is_null() { return NULL }
            ref rsb_fd : Expr = scope.lookup_func(rsb.name)
            if rsb_fd.is_null() { return NULL }
            if rsb_fd.children.len() != 0 { return NULL }
            return rsb_fd
        case:
        }
        return NULL
    case NodeType.FieldAccess(method):
        if callee.children.len() == 0 { return NULL }
        sname := til_type_name(callee.children[0].til_type())
        if sname.len() == 0 { return NULL }
        ref sdef : Expr = scope.get_struct(sname)
        if sdef.is_null() { return NULL }
        switch sdef.node_type {
        case NodeType.StructDef(sdd):
            for fd : Declaration in sdd.fields {
                if fd.name.eq(method.field_access_name()).not() { continue }
                // Issue #58 / #147 step 5: read the FuncSig alias name
                // from fd.til_type's FuncPtrSig payload (set by
                // type_from_name at field-typing time) instead of
                // fd.explicit_type + get_binding indirection.
                fsig_name := til_type_name(fd.til_type)
                if fsig_name.len() == 0 { continue }
                ref ftb_fd : Expr = scope.lookup_func(fsig_name)
                if ftb_fd.is_null() { continue }
                if ftb_fd.children.len() != 0 { continue }
                return ftb_fd
            }
        case:
        }
        return NULL
    case:
        return NULL
    }
}

// #168 step 2: true when an FCall yields a by-value result that a `ref`
// cannot borrow -- i.e. the callee returns Own (heap value the caller owns)
// OR Shallow (a stack value: a primitive, or an issue #223 auto-shallow
// struct). Only a `returns ref T` callee yields a borrowable pointer, so the
// predicate is "return_own_type is not Ref". A struct/enum constructor always
// produces a fresh owned value. Recognised callee shapes:
//   - Ident("foo")     -> scope binding's func_def.return_own_type
//   - Type.method(...) -> namespace lookup on the type's def
//   - obj.method(...)  -> namespace lookup on the receiver's type def
// A callee whose return is a fresh by-value result a `ref` cannot borrow:
// either an Own return, or (issue #223) a Shallow-returning callee whose
// return type is a STRUCT/ENUM. A Shallow primitive return (I64, ...) is
// left out: `ref x : I64 = f()` predates auto-shallow and other code relies
// on the existing classification; only the struct case is newly value-typed.
priv fdef_returns_unborrowable := func(fd: FunctionDef, scope: TypeScope) returns Bool {
    if fd.return_own_type.is(OwnType.Own) { return true }
    if fd.return_own_type.is(OwnType.Shallow) {
        rt := type_from_name_init(fd.return_type, scope)
        if rt.is(Type.Struct).or(rt.is(Type.Enum)) { return is_primitive(rt).not() }
    }
    return false
}

fcall_returns_own := func(fcall: Expr, scope: TypeScope) returns Bool {
    if fcall.node_type.is(NodeType.FCall).not() { return false }
    if fcall.children.len() == 0 { return false }
    ref callee : Expr = fcall.children[0]
    switch callee.node_type {
    case NodeType.Ident(cn):
        // Struct/enum constructor: `Foo(...)` where Foo is a registered
        // struct/enum type. The result is a freshly-constructed owned value.
        ref ctor_sdef : Expr = scope.get_struct(cn.ident_name())
        if ctor_sdef.is_null().not() { return true }
        ref cb : TypeBinding = scope.get_binding(cn.ident_name())
        if cb.is_null() { return false }
        ref cb_fd : Expr = scope.lookup_func(cb.name)
        if cb_fd.is_null() { return false }
        switch cb_fd.node_type {
        case NodeType.FuncDef(cfd):
            return fdef_returns_unborrowable(cfd, scope)
        case:
        }
        return false
    case NodeType.FieldAccess(cfa):
        // Type-name dispatch: Type.method(args). Receiver Ident is the type.
        if fa_is_ns(callee, scope) {
            switch callee.children[0].node_type {
            case NodeType.Ident(cti):
                ref sdef : Expr = scope.get_struct(cti.ident_name())
                ref method : Expr = find_namespace_func(sdef, cfa.field_access_name(), scope)
                if method.is_null() { return false }
                switch method.node_type {
                case NodeType.FuncDef(ffd):
                    return fdef_returns_unborrowable(ffd, scope)
                case:
                }
                return false
            case:
            }
        }
        // UFCS / instance method: obj.method(args). Resolve via receiver's type.
        if callee.children.len() > 0 {
            sname := til_type_name(callee.children[0].til_type())
            if sname.len() == 0 { return false }
            ref sdef : Expr = scope.get_struct(sname)
            ref method : Expr = find_namespace_func(sdef, cfa.field_access_name(), scope)
            if method.is_null() { return false }
            switch method.node_type {
            case NodeType.FuncDef(ffd):
                return fdef_returns_unborrowable(ffd, scope)
            case:
            }
        }
        return false
    case:
    }
    return false
}

// #168 step 1+2: ref bindings cannot be initialized from an owned value --
// the value would be heap-allocated with no owner. Step 1 caught literal
// `.clone()`; step 2 generalises to any FCall whose callee returns
// `OwnType.Own` (constructors, take_* helpers, factory funcs, etc.).
// Future steps broaden the surface (struct field defaults, assignments,
// ref-typed returns).
priv check_ref_decl_owned_init := proc(stmt: Expr, scope: TypeScope, ctx: Context) {
    if stmt.children.len() == 0 { return }
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        if sdecl.own_type.is(OwnType.Ref).not() { return }
        ref rhs : Expr = stmt.children[0]
        if rhs.node_type.is(NodeType.FCall).not() { return }
        if fcall_is_raw_alloc(rhs) { return }
        if fcall_returns_own(rhs, scope).not() { return }
        stmt.type_error(format("ref binding '", sdecl.name, "' cannot be initialized from an owned value (.clone() / constructor / function returning own) -- use 'own' to keep the value, or borrow the source directly"), ctx)
    case:
    }
}

// #168 step 3: struct field defaults follow the same predicate -- a
// `ref` field cannot have an owned-RHS default. NULL is still allowed
// (forced exception for ref fields, since the type doesn't yet have
// an instance to borrow from at default-value time).
priv check_ref_field_owned_default := proc(fd: Declaration, scope: TypeScope, ctx: Context) {
    if fd.own_type.is(OwnType.Ref).not() { return }
    if fd.default_value.is_null() { return }
    if fd.default_value.node_type.is(NodeType.NoDefaultArg) { return }
    if fd.default_value.node_type.is_literal_null() { return }
    if fd.default_value.node_type.is(NodeType.FCall).not() { return }
    if fcall_returns_own(fd.default_value, scope).not() { return }
    fd.default_value.type_error(format("ref field '", fd.name, "' default cannot be an owned value (.clone() / constructor / function returning own) -- use NULL or change the field to 'own'"), ctx)
}

// #168 step 4: assignments to ref-typed lvalues follow the same
// predicate. Catches the original FCallData.fn_sig motivating case
// (`fcd.fn_sig = src.clone()` where fn_sig was `ref mut Expr = NULL`).
// Caller passes the resolved target name (just for the diagnostic) and
// the rhs Expr; the predicate is the same as steps 1-3.
priv check_ref_assign_owned_rhs := proc(stmt: Expr, target_name: Str, rhs: Expr, scope: TypeScope, ctx: Context) {
    if rhs.node_type.is(NodeType.FCall).not() { return }
    if fcall_returns_own(rhs, scope).not() { return }
    stmt.type_error(format("ref target '", target_name, "' cannot be assigned an owned value (.clone() / constructor / function returning own) -- borrow the source directly, or change the target to 'own'/'mut'")
    , ctx)
}

// #168 step 1b / #177: ref bindings cannot be initialized to NULL. A
// `ref` slot initialized to NULL is structurally an uninitialized
// borrow; every legitimate use is rewritable as the borrow at the
// point you actually have it, as a sentinel value, or as a Context
// field on a longer-lived owner.
//
// Allowed exception: struct/namespace field defaults (where the
// parent type doesn't yet have an instance to point at).
//
// Module-scope globals were the original conservative carve-out; the
// 8 remaining sites flagged in #177 (interpreter cached_*_def/_name,
// builder current_fdef, typer current_struct_def) all migrated to
// Context fields. Module scope now enforces the same rule as locals.
priv check_ref_local_null_init := proc(stmt: Expr, ctx: Context) {
    if stmt.children.len() == 0 { return }
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        if sdecl.own_type.is(OwnType.Ref).not() { return }
        ref rhs : Expr = stmt.children[0]
        if rhs.node_type.is_literal_null().not() { return }
        stmt.type_error(format("ref binding '", sdecl.name, "' cannot be initialized to NULL -- borrow the source directly, or use a non-ref shape (own/mut + sentinel)"), ctx)
    case:
    }
}

priv infer_func_ptr_field_call := proc(scope: TypeScope, mut e: Expr, mut fa: Expr, obj: Expr, sdef: Expr, method: Str, in_func: I32, ctx: Context) returns Bool {
    if sdef.is_null().or(obj.til_type().is(Type.Struct).not().and(obj.til_type().is(Type.Enum).not())) { return false }
    switch sdef.node_type {
    case NodeType.StructDef(fpf_sdd):
        for fd : Declaration in fpf_sdd.fields {
            if fd.name.eq(method).not() { continue }
            if fd.til_type.is(Type.Body) {
                fa.set_til_type(Type.Body)
                nargs := e.children.len() - 1
                if nargs != 0 {
                    e.type_error(format("Body field '", method, "' expects 0 args, got ", nargs.to_str()), ctx)
                }
                if in_func != 0 {
                    e.type_error(format("func cannot call Body field '", method, "'"), ctx)
                } else if ctx.proc_def_depth > 0 {
                    ctx.proc_calls_count = ctx.proc_calls_count + 1
                }
                e.set_til_type(Type.None)
                return true
            }
            // Issue #58 / #147 step 5: read the FuncSig alias name from
            // fd.til_type's FuncPtrSig payload instead of fd.explicit_type
            // + scope.find indirection.
            fpf_sig_name := til_type_name(fd.til_type)
            if fpf_sig_name.len() == 0 { continue }
            ref ftb_fd : Expr = scope.lookup_func(fpf_sig_name)
            if ftb_fd.is_null().or(ftb_fd.children.len().neq(0)) { continue }
            fa.set_til_type(Type.FuncPtr)
            ref sig : Expr = ftb_fd
            mut nargs : USize = e.children.len()
            nargs--
            switch sig.node_type {
            case NodeType.FuncDef(sig_fdef):
                if nargs != sig_fdef.params.len() {
                    e.type_error(format("function pointer field '", method, "' expects ", sig_fdef.params.len().to_str(), " args, got ", nargs.to_str()), ctx)
                }
                mut ai : USize = 0
                while ai < nargs {
                    if ai >= sig_fdef.params.len() { break }
                    infer_expr(scope, e.children[ai + 1], in_func, ctx)
                    ai++
                }
                if sig_fdef.return_type.len() > 0 {
                    e.set_til_type(type_from_name(sig_fdef.return_type, scope, ctx))
                } else {
                    e.set_til_type(Type.None)
                }
            case:
                UNREACHABLE()
            }
            return true
        }
    case:
    }
    return false
}

// True when `e` is a `.clone()` method call (either UFCS form
// `x.clone()` or the desugared namespace form `Type.clone(x)`): an FCall
// whose callee is a FieldAccess named "clone".
is_clone_fcall := func(e: Expr) returns Bool {
    if e.node_type.is(NodeType.FCall).not() { return false }
    if e.children.len() == 0 { return false }
    switch e.children[0].node_type {
    case NodeType.FieldAccess(cfa):
        return cfa.field_access_name() == "clone"
    case:
        return false
    }
}

priv validate_fcall_own_args_for_fdef := proc(scope: TypeScope, e: Expr, fdef_data: FunctionDef, ctx: Context) {
        fvi := fdef_data.variadic_index
        fkwi := fdef_data.kwargs_index
        mut fvc : USize = 0
        if fvi >= 0 {
            fvc = fcall_variadic_count(e, fdef_data.params.len(), fkwi >= 0)
        }
        mut fkc : USize = 0
        if fkwi >= 0 {
            fkc = fcall_kwargs_count(e)
        }
        mut ci : USize = 1
        mut pi : USize = 0
        while pi < fdef_data.params.len() {
            if ci >= e.children.len() { break }
            if fvi >= 0 {
                if pi.to_i32() == fvi {
                    ci = ci + fvc
                    pi++
                    continue
                }
            }
            if fkwi >= 0 {
                if pi.to_i32() == fkwi {
                    ci = ci + fkc
                    pi++
                    continue
                }
            }
            ref pp2 : Declaration = fdef_data.params[pi]
            pown := pp2.own_type.is(OwnType.Own)
            ref arg : Expr = e.children[ci]
            // A `.clone()` passed to an immutable ref (borrow) parameter
            // is pure waste: the callee only borrows, so the fresh copy
            // is allocated and dropped without ever being retained or
            // mutated. Pass the value directly. (Own params legitimately
            // consume the clone; ref-mut params may mutate the copy.)
            if pp2.own_type.is(OwnType.Ref).and(pp2.is_mut.not()) {
                if arg.is_clone_fcall() {
                    arg.type_error(format("redundant '.clone()': parameter '", pp2.name, "' is a ref (borrow); pass the value directly"), ctx)
                }
            }
            if pown {
                if get_own_arg(e, ci).not() {
                    arg.type_error(format("argument for 'own' parameter '", pp2.name, "' must be marked 'own'"), ctx)
                }
                cap_name := closure_borrowed_capture_name(arg, scope)
                if cap_name.len() > 0 {
                    arg.type_error(format("own argument closure borrows captured local '", cap_name,
                        "'; capture it as 'own ", cap_name, "' or 'shallow ", cap_name,
                        "' if the closure escapes"), ctx)
                }
            } else if get_own_arg(e, ci) {
                arg.type_error(format("'own' on argument but parameter '", pp2.name, "' is not 'own'"), ctx)
            }
            if pown {
                switch arg.node_type {
                case NodeType.Ident(an):
                    sf_ab := scope.find(an.ident_name())
                    switch sf_ab {
                    case ScopeFind.Found(ab):
                        if ab.own_type.is(OwnType.Ref) {
                            arg.type_error("cannot pass ref variable to 'own' parameter; use .clone() to make an owned copy", ctx)
                        }
                    case:
                    }
                    // #164: passing an Ident as `own` consumes the binding
                    // (ownership transfer). The source's `mut` is what
                    // keeps the binding from auto-aliasing into a ref, so
                    // count this as a write-through.
                    ref mut own_arg_b : TypeBinding = scope.get_binding(an.ident_name())
                    if own_arg_b.is_null().not() { own_arg_b.written = true }
                case:
                }
            }
            if pown {
                if arg.node_type.is_literal_null() {
                    arg.type_error("cannot pass null to 'own' parameter", ctx)
                }
            }
            if pp2.own_type.is(OwnType.Shallow) {
                if arg.node_type.is_literal_null() {
                    arg.type_error("cannot pass null to 'shallow' parameter", ctx)
                }
            }
            ci++
            pi++
        }
}

priv validate_fcall_own_args := proc(scope: TypeScope, e: Expr, callee_bind: TypeBinding, ctx: Context) {
    if callee_bind.is_null() { return }
    ref fdef : Expr = scope.lookup_func(callee_bind.name)
    if fdef.is_null() { return }
    switch fdef.node_type {
    case NodeType.FuncDef(fdef_data):
        validate_fcall_own_args_for_fdef(scope, e, fdef_data, ctx)
    case:
        UNREACHABLE()
    }
}

priv set_fcall_own_args_for_own_params := func(mut e: Expr, fdef_data: FunctionDef) {
    fvi := fdef_data.variadic_index
    fkwi := fdef_data.kwargs_index
    mut fvc : USize = 0
    if fvi >= 0 {
        fvc = fcall_variadic_count(e, fdef_data.params.len(), fkwi >= 0)
    }
    mut fkc : USize = 0
    if fkwi >= 0 {
        fkc = fcall_kwargs_count(e)
    }
    mut ci : USize = 1
    mut pi : USize = 0
    while pi < fdef_data.params.len() {
        if ci >= e.children.len() { break }
        if fvi >= 0 {
            if pi.to_i32() == fvi {
                ci = ci + fvc
                pi++
                continue
            }
        }
        if fkwi >= 0 {
            if pi.to_i32() == fkwi {
                ci = ci + fkc
                pi++
                continue
            }
        }
        if fdef_data.params[pi].own_type.is(OwnType.Own) { set_own_arg(e, ci) }
        ci++
        pi++
    }
}

priv infer_struct_constructor_fcall := proc(scope: TypeScope, mut e: Expr, name: Str, in_func: I32, ctx: Context) returns Bool {
    ref sdef : Expr = scope.get_struct(name)
    if sdef.is_null() { return false }
    return infer_struct_constructor_fcall_impl(scope, sdef, e, name, in_func, ctx)
}

priv infer_struct_constructor_fcall_impl := proc(scope: TypeScope, sdef: Expr, mut e: Expr, name: Str, in_func: I32, ctx: Context) returns Bool {
    // #187 step 1: mark the struct binding as used so a priv struct
    // that is only ever instantiated (no namespace method calls) is
    // not misreported as dead. Skip when current_type_name matches
    // the struct itself: that's an internal constructor inside the
    // struct's own auto-generated or user-written ns methods, which
    // does not count as "used externally".
    if ctx.current_type_name.eq(name).not() {
        ref mut sb_used : TypeBinding = scope.get_binding(name)
        if sb_used.is_null().not() { sb_used.used = true }
    }
    // #154: constructing a cross-file type counts as a use of its import.
    note_cross_file_type_use(scope, ctx, name)
    sf_sb := scope.find(name)
    switch sf_sb {
    case ScopeFind.Found(sb):
        if sb.is_builtin {
            e.type_error(format("cannot instantiate builtin type '", name, "'"), ctx)
            e.set_til_type(Type.Unknown)
            return true
        }
        check_priv_access(e, name, sb, ctx)
    case:
    }

    // #99: if struct has new(), disallow literal outside its namespace
    if ctx.current_type_name.eq(name).not() {
        mut has_new := false
        ref new_ns : Vec(Declaration) = def_ns_decls(sdef)
        for nd : Declaration in new_ns {
            if nd.name == "new" {
                has_new = true
                break
            }
        }
        if has_new {
            e.type_error(format("struct '", name, "' has a new() constructor; use ", name, ".new(...) instead"), ctx)
            e.set_til_type(Type.Struct(name.clone()))
            return true
        }
    }

    switch sdef.node_type {
    case NodeType.StructDef(ctor_sdd):
        nfields := ctor_sdd.fields.len()
        mut field_vals := Vec(CtorArg).new()
        for _ in 0..nfields {
            field_vals.push(own CtorArg.Unfilled())
        }
        for i in 1..e.children.len() {
            ref arg : Expr = e.children[i]
            switch arg.node_type {
            case NodeType.NamedArg(aname):
                mut slot : I32 = -1
                for j in 0..nfields {
                    if ctor_sdd.fields[j].name == aname {
                        slot = j.to_i32()
                        break
                    }
                }
                if slot < 0 {
                    msg := format("struct '", name, "' has no field '", aname, "'")
                    arg.type_error(msg, ctx)
                }
                if slot >= 0 {
                    ref ctor_fld : Declaration = ctor_sdd.fields[slot.to_usize()]
                    check_member_priv(arg, name, aname, ctor_fld.is_priv, ctx)
                    if ctx.auto_gen_depth == 0 { ctor_fld.used = true }
                    ref slot_arg : CtorArg = field_vals[slot.to_usize()]
                    if slot_arg.is(CtorArg.Filled) {
                        msg := format("duplicate argument for field '", aname, "'")
                        arg.type_error(msg, ctx)
                    }
                    if slot_arg.is(CtorArg.Filled).not() {
                        // #251 follow-up: a conforming concrete given for an
                        // interface-typed field coerces to an OWNED box -- the
                        // field outlives the ctor call, so a borrow would
                        // dangle. Snapshot before inference desugars a struct
                        // ctor's named args (the box re-infers the snapshot);
                        // box if conforming, else store the value as usual.
                        ref fld_tn : Str = ctor_fld.explicit_type
                        if name_is_interface(fld_tn, scope) {
                            mut fld_snap := arg.children[0].clone()
                            infer_expr(scope, arg.children[0], in_func, ctx)
                            fld_cname := til_type_name(arg.children[0].til_type())
                            if fld_cname.len().gt(0).and(fld_cname.eq(fld_tn).not()).and(type_implements_iface(fld_cname, fld_tn, scope)) {
                                mut fld_box := make_owned_iface_box(fld_tn, fld_cname, own fld_snap, arg.children[0].line, arg.children[0].col)
                                infer_expr(scope, fld_box, in_func, ctx)
                                field_vals[slot.to_usize()] = CtorArg.Filled(fld_box)
                            } else {
                                field_vals[slot.to_usize()] = CtorArg.Filled(arg.children[0].clone())
                            }
                        } else {
                            field_vals[slot.to_usize()] = CtorArg.Filled(arg.children[0].clone())
                        }
                    }
                }
            case:
                arg.type_error("struct instantiation requires named arguments", ctx)
                continue
            }
        }
        mut missing_required := false
        for i in 0..nfields {
            if field_vals[i].is(CtorArg.Filled).not() {
                ref fld_d : Declaration = ctor_sdd.fields[i]
                if fld_d.default_value.node_type.is(NodeType.NoDefaultArg) {
                    // #242: a field with no default is required at
                    // instantiation; it must be supplied by name.
                    e.type_error(format("missing required field '", fld_d.name, "' in '", name, "(...)'"), ctx)
                    missing_required = true
                } else {
                    field_vals[i] = CtorArg.Filled(resolve_default_value(fld_d.default_value, e, ctx))
                }
            }
        }
        if missing_required {
            // Diagnostic(s) already emitted. Bail before the desugar so the
            // build loop below doesn't trip over the unfilled slot(s); set a
            // sensible type so the typer keeps reporting later errors.
            e.set_til_type(Type.Struct(resolve_type_alias(scope, name).clone()))
            return true
        }
        mut new_ch := Vec(Expr).new()
        new_ch.push_take(e.children, 0)
        for fv : CtorArg in field_vals {
            switch fv {
            case CtorArg.Filled(filled_arg):
                new_ch.push(own filled_arg.clone())
            case:
                UNREACHABLE()
            }
        }
        e.children = new_ch
        for i in 1..e.children.len() {
            // Issue #295: a FuncDef's til_type is FuncPtr (not Unknown),
            // so a capturing-closure arg would skip inference and its body
            // would never be typed against this (enclosing) scope -- losing the
            // captured variables' types in codegen. Infer capturing closures
            // here too so `n.add(1)` etc. resolve against the live scope.
            ref ci : Expr = e.children[i]
            mut needs_infer := ci.til_type().is(Type.Unknown)
            switch ci.node_type {
            case NodeType.FuncDef(ci_fd): if ci_fd.captures.len() > 0 { needs_infer = true }
            case NodeType.BodyValue: needs_infer = true
            case:
            }
            if needs_infer {
                infer_expr(scope, ci, in_func, ctx)
            }
        }
        for fi in 0..nfields {
            if fi >= e.children.len() - 1 { break }
            ref fld_decl : Declaration = ctor_sdd.fields[fi]
            ai := fi + 1
            if fld_decl.own_type.is(OwnType.Ref) { continue }
            if fld_decl.own_type.is(OwnType.Own).not() {
                if type_ctor_consumes(fld_decl.til_type).not() { continue }
            }
            set_own_arg(e, ai)
        }
        e.set_til_type(Type.Struct(resolve_type_alias(scope, name).clone()))
        return true
    case:
        UNREACHABLE()
        return false
    }
}

// Issue #281: materialize one parameter/field default value for a call/ctor
// fill site. If the default is the __LOC__ sentinel, resolve it to a Str
// literal holding the CALL SITE's location (the call/ctor Expr's coords + the
// file currently being typed, ctx.path -- the caller's file); otherwise clone
// the default as before. This is what makes a defaulted `loc: Str = __LOC__`
// report the caller. Keyed on the default VALUE, never on the callee's name,
// so any user func/proc/struct field gets the behavior.
resolve_default_value := func(default_value: Expr, call_expr: Expr, ctx: Context) returns Expr {
    if default_value.node_type.is(NodeType.Loc) {
        loc_str := format(ctx.path, ":", call_expr.line.to_str(), ":", call_expr.col.to_str())
        return Expr.new(NodeType.Literal(Literal.Str(loc_str)), call_expr.line, call_expr.col)
    }
    return default_value.clone()
}

// #269: is `name` an interface type (a StructDef flagged is_interface)?
priv name_is_interface := func(name: Str, scope: TypeScope) returns Bool {
    ref d : Expr = scope.get_struct(name)
    if d.is_null() { return false }
    switch d.node_type {
    case NodeType.StructDef(sdd):
        return sdd.is_interface
    case:
        return false
    }
}

// #269: does concrete type `cname` declare `implements iface`?
priv type_implements_iface := func(cname: Str, iface: Str, scope: TypeScope) returns Bool {
    ref d : Expr = scope.get_struct(cname)
    if d.is_null() { return false }
    switch d.node_type {
    case NodeType.StructDef(sdd):
        return sdd.implements_name == iface
    case NodeType.EnumDef(edd):
        return edd.implements_name == iface
    case:
        return false
    }
}

// Validate a single argument against its parameter's type. Narrows
// numeric literals to fit the param type, applies implicit widen /
// usize-coerce, and emits a type_error on mismatch. Skips Dynamic-typed
// args (the caller has already decided this arg is not constrained).
priv validate_fcall_arg := proc(mut arg: Expr, ptype: Type, ptype_name: Str, param_name: Str, ctx: Context) {
    // #269: accept a conforming concrete type where an interface is expected.
    // The #251 conformance check guarantees the methods exist; the runtime
    // dispatches the method call to the concrete type. (Interpreter path
    // first; compiled dispatch via a box is the follow-up.)
    if name_is_interface(ptype_name, ctx.scope) {
        arg_cname := til_type_name(arg.til_type())
        if arg_cname.len().gt(0).and(type_implements_iface(arg_cname, ptype_name, ctx.scope)) {
            return
        }
    }
    if arg.til_type().is(Type.Dynamic) { return }
    if arg.til_type().is(Type.Unknown) { return }
    switch arg.node_type {
    case NodeType.Literal(Literal.Num(lit_str)):
        if is_numeric_type(ptype) {
            if literal_in_range(lit_str.literal_num_text(), ptype).not() {
                arg.type_error(format("integer literal ", lit_str.literal_num_text(), " out of range for ", type_to_name(ptype)), ctx)
            }
            arg.set_til_type(ptype)
            return
        }
    case:
    }
    // Issue #224: implicit integer widening of non-literal arguments at
    // call sites is no longer allowed. A numeric literal still adopts the
    // param type via the Literal branch above; any runtime value that needs
    // a wider type must say so with an explicit `.cast(T)`. The USize/UPtr
    // coercion is intentionally kept (see can_implicit_usize_coerce).
    if can_implicit_usize_coerce(arg.til_type(), ptype, ptype_name) {
        arg.set_til_type(ptype)
        return
    }
    // Primitives all share the Type.Primitive tag, so the tag-only is()
    // can't tell them apart (e.g. Primitive(I64) vs Primitive(Bool)).
    // Compare precisely when both sides are primitives.
    mut type_matches := arg.til_type().is(ptype)
    if arg.til_type().is(Type.Primitive).and(ptype.is(Type.Primitive)) {
        type_matches = arg.til_type() == ptype
    }
    // Issue #58 / #147 step 5: FuncPtr / FuncPtrSig live on different
    // tags but are the same family. funcptr_eq applies the wildcard
    // semantic (bare FuncPtr matches any FuncPtrSig; named FuncPtrSig
    // must match exactly).
    if funcptr_eq(arg.til_type(), ptype) {
        type_matches = true
    }
    if type_matches.not().and(is_aggregate(ptype)) {
        arg_sname_for_match := til_type_name(arg.til_type())
        if arg_sname_for_match.len() > 0 {
            if ptype_name.eq(arg_sname_for_match) { type_matches = true }
        }
    }
    if type_matches.not() {
        arg.type_error(format("argument type mismatch for '", param_name, "': expected ", ptype_name, ", got ", type_to_name(arg.til_type())), ctx)
    } else if is_aggregate(ptype) {
        arg_sname := til_type_name(arg.til_type())
        if arg_sname.len() > 0 {
            if ptype_name.eq(arg_sname).not() {
                arg.type_error(format("argument type mismatch for '", param_name, "': expected ", ptype_name, ", got ", arg_sname), ctx)
            }
        }
}

}

priv infer_and_validate_fcall_args_for_fdef := proc(scope: TypeScope, mut e: Expr, fdef_data: FunctionDef, in_func: I32, ctx: Context) {
        fvi := fdef_data.variadic_index
        fkwi := fdef_data.kwargs_index
        mut fvc : USize = 0
        if fvi >= 0 {
            fvc = fcall_variadic_count(e, fdef_data.params.len(), fkwi >= 0)
        }
        mut fkc : USize = 0
        if fkwi >= 0 {
            fkc = fcall_kwargs_count(e)
        }
        mut ci : USize = 1
        mut pi : USize = 0
        while pi < fdef_data.params.len() {
            if ci >= e.children.len() { break }
            if fvi >= 0 {
                if pi.to_i32() == fvi {
                    ref vparam : Declaration = fdef_data.params[pi]
                    vptype := type_from_name(vparam.explicit_type, scope, ctx)
                    for vk in 0..fvc {
                        rewrite_til_type_arg(scope, e, ci + vk, vptype, in_func, ctx)
                        narrow_dynamic(e.children[ci + vk], vptype)
                    }
                    ci = ci + fvc
                    pi++
                    continue
                }
            }
            if fkwi >= 0 {
                if pi.to_i32() == fkwi {
                    ci = ci + fkc
                    pi++
                    continue
                }
            }
            ref param1 : Declaration = fdef_data.params[pi]
            ref ptype : Str = param1.explicit_type
            ptype_t := type_from_name(ptype, scope, ctx)
            rewrite_til_type_arg(scope, e, ci, ptype_t, in_func, ctx)
            narrow_dynamic(e.children[ci], ptype_t)
            // #164: arg passed to a `mut` param may be written through.
            // A `Dynamic` param is an untyped raw pointer the callee can
            // write through (move/memcpy/memset/write_ptr all take Dynamic
            // dests), so treat those conservatively as writes too.
            if param1.is_mut.or(ptype_t.is(Type.Dynamic)) {
                ref arg_e : Expr = e.children[ci]
                switch arg_e.node_type {
                case NodeType.Ident(arg_id):
                    ref mut arg_b : TypeBinding = scope.get_binding(arg_id.ident_name())
                    if arg_b.is_null().not() { arg_b.written = true }
                case NodeType.FieldAccess:
                    if arg_e.children.len() > 0 {
                        mark_field_assign_root_written(scope, arg_e.children[0])
                    }
                case:
                }
            }
            ci++
            pi++
        }
        ci = 1
        pi = 0
        while pi < fdef_data.params.len() {
            if ci >= e.children.len() { break }
            if fvi >= 0 {
                if pi.to_i32() == fvi {
                    ref vparam : Declaration = fdef_data.params[pi]
                    ref vptype_name : Str = vparam.explicit_type
                    mut is_splat := false
                    switch e.node_type {
                    case NodeType.FCall(fcd_v):
                        is_splat = fcd_v.is_splat
                    case:
                        UNREACHABLE()
                    }
                    if vptype_name.len().gt(0).and(is_splat.not()) {
                        vptype := type_from_name(vptype_name, scope, ctx)
                        if vptype.is(Type.Dynamic).not() {
                            is_str_va := vptype_name == "Str"
                            for vk in 0..fvc {
                                if is_str_va {
                                    ref vk_arg : Expr = e.children[ci + vk]
                                    if vk_arg.til_type().is(vptype).not() {
                                        if vk_arg.til_type().is(Type.Dynamic).not().and(vk_arg.til_type().is(Type.Unknown).not()) {
                                            arg_tname := type_to_name(vk_arg.til_type())
                                                if arg_tname.len().gt(0).and(arg_tname.eq("Str").not()) {
                                                    if type_has_to_str(scope, arg_tname) {
                                                        e.children[ci + vk] = make_to_str_call(arg_tname, vk_arg)
                                                        continue
                                                    }
                                            }
                                        }
                                    }
                                }
                                rewrite_til_type_arg(scope, e, ci + vk, vptype, in_func, ctx)
                                validate_fcall_arg(e.children[ci + vk], vptype, vptype_name, vparam.name, ctx)
                            }
                        }
                    }
                    ci = ci + fvc
                    pi++
                    continue
                }
            }
            if fkwi >= 0 {
                if pi.to_i32() == fkwi {
                    ci = ci + fkc
                    pi++
                    continue
                }
            }
            ref param2 : Declaration = fdef_data.params[pi]
            ref ptype_name : Str = param2.explicit_type
            if ptype_name.len() == 0 {
                ci++
                pi++
                continue
            }
            ptype := type_from_name(ptype_name, scope, ctx)
            if ptype.is(Type.Dynamic) {
                ci++
                pi++
                continue
            }
            // #269: a conforming concrete value where an interface is
            // expected coerces by BOXING: the arg is rewritten to
            // `Iface(iface_type_name = "<Concrete>", iface_val = <arg>)`.
            // The concrete type is statically known here, so the box carries
            // the runtime tag that interface method dispatch (dyn_call on
            // the box fields) needs. iface_val is a ref field: the box
            // borrows the value, it does not consume it.
            if name_is_interface(ptype_name, scope) {
                box_cname := til_type_name(e.children[ci].til_type())
                if box_cname.len().gt(0).and(box_cname.eq(ptype_name).not()).and(type_implements_iface(box_cname, ptype_name, scope)) {
                    box_line := e.children[ci].line
                    box_col := e.children[ci].col
                    mut iface_box := Expr.new(NodeType.FCall(FCallData()), box_line, box_col)
                    iface_box.add_child(own Expr.new(ident_node(ptype_name), box_line, box_col))
                    mut na_tag := Expr.new(NodeType.NamedArg("iface_type_name"), box_line, box_col)
                    na_tag.add_child(own Expr.new(NodeType.Literal(Literal.Str(box_cname.clone())), box_line, box_col))
                    iface_box.add_child(own na_tag)
                    mut na_val := Expr.new(NodeType.NamedArg("iface_val"), box_line, box_col)
                    // Wrap the value in to_ptr so the C backend passes its
                    // ADDRESS into the box's ref-Dynamic field (a struct
                    // local would otherwise be assigned by value).
                    mut val_ptr := Expr.new(NodeType.FCall(FCallData()), box_line, box_col)
                    val_ptr.add_child(own Expr.new(ident_node("to_ptr"), box_line, box_col))
                    val_ptr.add_child(own e.children[ci].clone())
                    na_val.add_child(own val_ptr)
                    iface_box.add_child(own na_val)
                    e.children[ci] = iface_box
                    infer_expr(scope, e.children[ci], in_func, ctx)
                }
            }
            rewrite_til_type_arg(scope, e, ci, ptype, in_func, ctx)
            validate_fcall_arg(e.children[ci], ptype, ptype_name, param2.name, ctx)
            ci++
            pi++
        }
}

priv infer_and_validate_fcall_args := proc(scope: TypeScope, mut e: Expr, callee_bind: TypeBinding, in_func: I32, ctx: Context) {
    for i in 1..e.children.len() {
        infer_expr(scope, e.children[i], in_func, ctx)
    }
    if callee_bind.is_null() { return }
    ref fdef : Expr = scope.lookup_func(callee_bind.name)
    if fdef.is_null() { return }
    switch fdef.node_type {
    case NodeType.FuncDef(fdef_data):
        infer_and_validate_fcall_args_for_fdef(scope, e, fdef_data, in_func, ctx)
    case:
        UNREACHABLE()
    }
}

priv resolve_fcall_return_type := proc(scope: TypeScope, mut e: Expr, name: Str, callee_bind: TypeBinding, in_func: I32, ctx: Context) {
    if name.eq("dyn_call").or(name.eq("dyn_call_ret")).or(name.eq("dyn_has_method")).or(name.eq("dyn_fn")) {
        if e.children.len() >= 3 {
            ref method_arg : Expr = e.children[2]
            if method_arg.node_type.is_literal_str().not() {
                method_arg.type_error("dyn_call method argument must be a string literal", ctx)
            }
        }
    }
    mut fn_type := scope.get_type(name)
    if fn_type.is(Type.Unknown) {
        e.type_error(format("undefined function '", name, "'"), ctx)
    }
    if fn_type.is(Type.Body) {
        e.children[0].set_til_type(Type.Body)
        nargs := e.children.len() - 1
        if nargs != 0 {
            e.type_error(format("Body '", name, "' expects 0 args, got ", nargs.to_str()), ctx)
        }
        if in_func != 0 {
            e.type_error(format("func cannot call Body '", name, "'"), ctx)
        } else if ctx.proc_def_depth > 0 {
            ctx.proc_calls_count = ctx.proc_calls_count + 1
        }
        e.set_til_type(Type.None)
        return
    }
    if fn_type.is_funcptr() {
        if callee_bind.is_null().not() {
            // A FuncPtr-typed binding that is a function-pointer value (not a
            // function/sig declaration) is called through its signature.
            if callee_bind.is_func_decl.not() {
                e.children[0].set_til_type(Type.FuncPtr)
                ref cb_func_def : Expr = scope.lookup_func(callee_bind.name)
                if cb_func_def.is_null().not() {
                    switch cb_func_def.node_type {
                    case NodeType.FuncDef(cb_fdef):
                        if cb_fdef.return_type.len() > 0 {
                            ref resolved_return_type : Str = resolve_type_alias(scope, cb_fdef.return_type)
                            rt := type_from_name(resolved_return_type, scope, ctx)
                            e.set_til_type(rt)
                        } else {
                            e.set_til_type(Type.None)
                        }
                    case:
                        UNREACHABLE()
                    }
                } else {
                    e.set_til_type(Type.Dynamic)
                }
                if cb_func_def.is_null().not() {
                    ref sig : Expr = cb_func_def
                    switch sig.node_type {
                    case NodeType.FuncDef(sig_fdef):
                        mut nargs : USize = e.children.len()
                        nargs--
                        if nargs != sig_fdef.params.len() {
                            e.type_error(format("function pointer '", name, "' expects ", sig_fdef.params.len().to_str(), " args, got ", nargs.to_str()), ctx)
                        }
                        mut ai : USize = 0
                        while ai < nargs {
                            if ai >= sig_fdef.params.len() { break }
                            ref arg : Expr = e.children[ai + 1]
                            ref expected_name : Str = sig_fdef.params[ai].explicit_type
                            if expected_name.len() == 0 {
                                ai++
                                continue
                            }
                            expected := type_from_name(expected_name, scope, ctx)
                            if expected.is(Type.Unknown).or(expected.is(Type.Dynamic)) {
                                ai++
                                continue
                            }
                            if arg.til_type().is(Type.Dynamic) {
                                ai++
                                continue
                            }
                            // #58 / #147: use the same wildcard-aware funcptr
                            // comparison validate_fcall_arg uses -- a bare
                            // FuncPtr (e.g. a thunk wrapping a first-class lazy
                            // arg, #262) matches any named FuncPtrSig param.
                            if arg.til_type().is(expected).not().and(funcptr_eq(arg.til_type(), expected).not()) {
                                e.type_error(format("function pointer '", name, "' param ", ai.add(1).to_str(), ": expected ", expected_name, ", got ", type_to_name(arg.til_type())), ctx)
                            }
                            ai++
                        }
                    case:
                        UNREACHABLE()
                    }
                }
                return
            }
        }
    }
    switch fn_type {
    case Type.Custom(ret_name):
        ref resolved_ret_name : Str = resolve_type_alias(scope, ret_name)
        resolved_ret := type_from_name(resolved_ret_name, scope, ctx)
        if resolved_ret.is(Type.Unknown).not() {
            fn_type = resolved_ret
        }
    case:
    }
    e.set_til_type(fn_type)
    // fn_type (from binding.type) already carries the name payload via
    // Type.Struct(name) or Type.Enum(name) when registered, so
    // no additional struct_name assignment is needed.
    mut debug_exempt := false
    if ctx.mode.debug_prints {
        if name.eq("print").or(name.eq("println")) {
            debug_exempt = true
        }
    }
    if fn_type.is_funcptr().not() {
        if in_func != 0 {
            callee_ft := scope.get_func_type(name)
            if callee_ft.is(FuncType.Proc).or(callee_ft.is(FuncType.ExtProc)).or(callee_ft.is(FuncType.CoreProc)) {
                ctx.proc_calls_count = ctx.proc_calls_count + 1
                if debug_exempt.not() {
                    e.type_error(format("func cannot call proc '", name, "'"), ctx)
                }
            }
        } else if ctx.proc_def_depth > 0 {
            callee_ft2 := scope.get_func_type(name)
            if callee_ft2.is(FuncType.Proc).or(callee_ft2.is(FuncType.ExtProc)).or(callee_ft2.is(FuncType.CoreProc)) {
                ctx.proc_calls_count = ctx.proc_calls_count + 1
            }
        }
    }
    if scope.get_func_type(name).is(FuncType.Test) {
        e.type_error(format("test functions cannot be called ('", name, "')"), ctx)
    }
}

// True when `method` is a `to_<X>` conversion whose suffix matches the
// receiver's `type_name` ASCII case-insensitively (e.g. `to_u32` on a
// U32, `to_aaa` on an Aaa). Converting a value to its own type is
// always redundant, so the typer emits a clearer diagnostic than the
// generic "no method 'to_u32' for type 'U32'". The check is purely on
// the call shape: core defines no identity converters (no `to_u32` on
// U32, no `to_str` on Str), so this only ever fires on a mistake.
priv is_self_conversion_method := func(method: Str, type_name: Str) returns Bool {
    if method.starts_with("to_").not() { return false }
    if type_name.len() == 0 { return false }
    suffix_len := method.len() - 3
    if suffix_len.eq(type_name.len()).not() { return false }
    for i in 0..suffix_len {
        ref mc : I8 = method.get(i + 3)
        ref tc : I8 = type_name.get(i)
        if mc == tc { continue }
        if tc.gte('A').and(tc.lte('Z')) {
            if tc + 32 == mc { continue }
        }
        return false
    }
    return true
}

// For methods like `obj.foo(...)`: returns the type-name lookup key
// (a primitive's c_name, a struct/enum payload name, or "" when no
// match). Used by infer_field_access_fcall to find the namespace.
// Avoids the `mut type_name := ""; type_name = ...` reassign pattern
// that leaked the empty Str default.
priv obj_method_type_name := func(obj: Expr) returns Str {
    if is_primitive(obj.til_type()) {
        return til_type_name_c(obj.til_type())
    }
    if is_aggregate(obj.til_type()) {
        return til_type_name(obj.til_type())
    }
    return ""
}

// Canonical type name that a numeric `to_<X>` conversion method
// converts TO, or "" when `method` is not such a conversion. `to_u32`
// -> "U32", `to_usize` -> "USize" (which type_from_name then resolves
// to the target's U32/U64). Drives the redundant-literal-conversion
// check: `5.to_u32()` is redundant because a bare `5` already narrows
// to U32 in any U32 context. Mirrors builtin_primitive_from_name's
// shape; Bool and to_str/to_ptr (non-numeric) deliberately fall through.
priv numeric_conv_target_name := func(method: Str) returns Str {
    if method.eq("to_i64")   { return "I64" }
    if method.eq("to_u8")    { return "U8" }
    if method.eq("to_i8")    { return "I8" }
    if method.eq("to_i16")   { return "I16" }
    if method.eq("to_u16")   { return "U16" }
    if method.eq("to_i32")   { return "I32" }
    if method.eq("to_u32")   { return "U32" }
    if method.eq("to_u64")   { return "U64" }
    if method.eq("to_f32")   { return "F32" }
    if method.eq("to_usize") { return "USize" }
    if method.eq("to_uptr")  { return "UPtr" }
    return ""
}

priv infer_field_access_fcall := proc(scope: TypeScope, mut e: Expr, in_func: I32, ctx: Context) returns Bool {
    ref mut fa : Expr = e.children[0]
    ref mut obj : Expr = fa.children[0]
    mut method := ""
    switch fa.node_type {
    case NodeType.FieldAccess(m):
        method = Str.clone(m.field_access_name())
    case:
        UNREACHABLE()
        return false
    }
    // `.clone()` on a literal receiver is always redundant: the literal
    // itself is a fresh value, so the clone allocates a copy that the
    // surrounding code would have produced anyway. Reject at the typer
    // level so callers fix the source instead of paying for the copy.
    if method == "clone" {
        if obj.node_type.is_nonnull_literal() {
            e.type_error("redundant '' on a literal", ctx)
            e.set_til_type( Type.Unknown)
            return true
        }
    }
    // #294: a numeric conversion on a numeric literal is redundant. A
    // bare literal already narrows to the target type through its
    // declaration type, an argument/field type, or any numeric context
    // (`x : U32 = 5`, `f(5)`, `b > 0`, `a / 2`), so `5.to_u32()` /
    // `5.cast(U32)` does no work the surrounding code would not do
    // anyway. Reject it: the fix is to drop the conversion, or -- where
    // the value was otherwise inferred -- give the binding an explicit
    // type (`x : U32 = 5`, not `x := 5.to_u32()`). Checked here, before
    // UFCS desugaring and constant folding, so it fires uniformly at
    // every literal receiver (arguments, operator operands, decls).
    // Out-of-range conversions stay legal -- they do real work
    // (300.to_u8() truncation, -1.to_usize() wraparound) -- gated by
    // literal_in_range against the resolved target type.
    if obj.node_type.is_literal_num() {
        mut conv_target := Type.Unknown
        if method.eq("cast") {
            if e.children.len().eq(2) {
                switch e.children[1].node_type {
                case NodeType.Ident(cast_tn):
                    conv_target = type_from_name(cast_tn.ident_name(), scope, ctx)
                case:
                }
            }
        } else {
            conv_tgt_name := numeric_conv_target_name(method)
            if conv_tgt_name.len() > 0 {
                conv_target = type_from_name(conv_tgt_name, scope, ctx)
            }
        }
        if is_numeric_type(conv_target) {
            switch obj.node_type {
            case NodeType.Literal(Literal.Num(conv_lit)):
                if literal_in_range(conv_lit.literal_num_text(), conv_target) {
                    e.type_error(format(
                        "redundant conversion '", method,
                        "' on a numeric literal: a bare literal already narrows to ",
                        type_to_name(conv_target),
                        " through its declaration or argument type; drop the conversion",
                        " (give the binding an explicit type if it was inferred)"), ctx)
                    // Keep the well-defined conversion result type (not
                    // Unknown) so the diagnostic does not cascade into
                    // spurious "got unknown" mismatches at the use site.
                    e.set_til_type(conv_target)
                    return true
                }
            case:
            }
        }
    }
    infer_expr(scope, obj, in_func, ctx)

    // A function pointer is a pointer-sized value, but a funcsig is not a
    // struct, so it has no `size` metatype method of its own. Route a funcptr
    // type-token's `.size()` through Dynamic (the universal 8-byte pointer,
    // src/core/dyn.til), which reports pointer size. (`clone`/`delete` need
    // funcptr-typed results / true no-op delete -- not Dynamic's, which frees
    // -- so they are handled separately as the Array-of-funcptr work lands.)
    if obj.til_type().is_funcptr().and(method.eq("size")) {
        switch obj.node_type {
        case NodeType.Ident:
            mut dyn_recv := Expr.new(ident_node("Dynamic"), obj.line, obj.col)
            dyn_recv.set_til_type(Type.Struct("Dynamic"))
            fa.children[0] = dyn_recv
        case:
        }
    }

    mut obj_is_type := false
    switch obj.node_type {
    case NodeType.Ident(oit_id):
        if scope.get_struct(oit_id.ident_name()).is_null().not() {
            obj_is_type = true
        }
    case:
    }

    mut ufcs_desugared := false
    if obj_is_type.not() {
        type_name := obj_method_type_name(obj)
        has_type_name := type_name.len() > 0

        // Calling `to_<self>` on a value that is already of that type is
        // a redundant self-conversion. Caught here -- before the
        // namespace lookup -- so the diagnostic names the mistake
        // directly instead of surfacing as a generic "no method". Skip
        // namespace calls like `Str.to_str(x)` (handled by the
        // obj_is_type branch), which dispatch on the explicit type.
        // #192: to_u64/to_u32 are the target-dependent widths -- a USize/UPtr
        // value needs `.to_u64()` on 64-bit and `.to_u32()` on 32-bit for the
        // same source to typecheck on both, so a self-conversion to either is
        // portable, not a mistake. Exempt them (mirrors the /.cast(U32)
        // exemption below). The lint still catches every other self-conversion.
        conv_w := method.eq("to_u64").or(method.eq("to_u32"))
        if has_type_name.and(is_self_conversion_method(method, type_name)).and(conv_w.not()) {
            e.type_error(format(
                "redundant self-conversion: '", method,
                "' would convert ", type_name, " to itself; ",
                "value is already of type '", type_name, "'",
            ), ctx)
            e.set_til_type(Type.Unknown)
            return true
        }
        // Same diagnostic for `x.cast(X)` where X matches the receiver's
        // type -- identity casts are accepted by infer_cast_fcall's
        // same-size rule, but they are always pointless and almost
        // always a copy-paste / migration mistake.
        if has_type_name.and(method.eq("cast")).and(e.children.len().eq(2)) {
            switch e.children[1].node_type {
            case NodeType.Ident(cast_id_data):
                // #192: USize/UPtr are target-dependent (U32 on 32-bit,
                // U64 on 64-bit). A ``/`.cast(U32)` on such a
                // value is redundant on one target but a needed widening on
                // the other, so it must stay for portability. Don't flag
                // self-casts to these widths; the lint still catches
                // pointless self-casts of every other type.
                cast_w := cast_id_data.ident_name().eq("U64").or(cast_id_data.ident_name().eq("U32"))
                if cast_id_data.ident_name().eq(type_name).and(cast_w.not()) {
                    e.type_error(format(
                        "redundant self-cast: 'cast(", type_name,
                        ")' would reinterpret ", type_name,
                        " as itself; drop the .cast(", type_name, ")",
                    ), ctx)
                    e.set_til_type(Type.Unknown)
                    return true
                }
            case:
            }
        }

        ref sdef1 : Expr = scope.get_struct(type_name)
        ref ns_func1 : Expr = find_namespace_func(sdef1, method, scope)
        if ns_func1.is_null() {
            if try_ufcs_rewrite(scope, e, fa, obj, method, type_name, ctx) {
                return false
            }
            if infer_func_ptr_field_call(scope, e, fa, obj, sdef1, method, in_func, ctx) {
                return true
            }
            if has_type_name.not() {
                if obj.til_type().is(Type.Dynamic) {
                    e.type_error(format(
                        "cannot call method '", method, "' on Dynamic value; ",
                        "use 'ref x : Type = ...' to declare with an explicit type first",
                    ), ctx)
                } else {
                    e.type_error(format("no method '", method, "' for type 'unknown'"), ctx)
                }
            } else {
                e.type_error(format("no method '", method, "' for type '", type_name, "'"), ctx)
            }
            e.set_til_type(Type.Unknown)
            return true
        }
        ufcs_desugared = true
        mut type_ident := Expr.new(ident_node(type_name), obj.line, obj.col)
        type_ident.set_til_type(Type.Struct(type_name.clone()))
        // Move the receiver `obj` out of fa.children[0] (no clone) into a
        // holder, then put the type ident in the vacated slot. push_take
        // zeroes the source slot, so the .set below is a plain bit-overwrite
        // of a dead slot. The moved receiver becomes the UFCS self-arg at
        // position 1 (pushed into new_children further down), so we reuse the
        // original subtree instead of cloning it and orphaning the original
        // -- the clone+orphan was a per-UFCS-call leak of the whole receiver.
        mut recv_holder := Vec(Expr).new()
        recv_holder.push_take(fa.children, 0)
        fa.children[0] = type_ident
        // Shift own_args bitmask: bits at position >=1 move to position+1
        // (UFCS inserts self at position 1)
        switch e.node_type {
        case NodeType.FCall(ufcs_fcd):
            old_own := ufcs_fcd.own_args
            mut new_own : U64 = 0
            mut bit : U64 = 1
            for bi in 0..e.children.len() {
                if old_own.band(bit) > 0 {
                    if bi == 0 {
                        new_own = new_own.bor(bit)
                    } else {
                        // Shift this bit left by 1 position
                        new_own = new_own.bor(bit * 2)
                    }
                }
                bit = bit * 2
            }
            ufcs_fcd.own_args = new_own
        case:
            UNREACHABLE()
        }
        mut new_children := Vec(Expr).new()
        new_children.push_take(e.children, 0)
        new_children.push_take(recv_holder, 0)
        for i in 1..e.children.len() {
            new_children.push_take(e.children, i)
        }
        e.children = new_children
        ref fa2 : Expr = e.children[0]
        switch fa2.node_type {
        case NodeType.FieldAccess(m2):
            method = Str.clone(m2.field_access_name())
        case:
            UNREACHABLE()
        }
    }

    ref mut fa3 : Expr = e.children[0]
    ref mut obj3 : Expr = fa3.children[0]
    if obj3.til_type().is(Type.Unknown) {
        infer_expr(scope, obj3, in_func, ctx)
    }
    mut obj3_sname := til_type_name(obj3.til_type())
    if obj3_sname.len() == 0 {
        switch obj3.node_type {
        case NodeType.Ident(obj3_id):
            obj3_sname = Str.clone(obj3_id.ident_name())
        case:
        }
    }
    ref sdef2 : Expr = scope.get_struct(obj3_sname)
    ref ns_func2 : Expr = find_namespace_func(sdef2, method, scope)
    if ns_func2.is_null() {
        e.type_error(format("no namespace function '", method, "'"), ctx)
        e.set_til_type(Type.Unknown)
        return true
    }
    ref fd : Declaration = find_ns_decl(sdef2, method)
    mut ns_member_priv := false
    if fd.is_null().not() { ns_member_priv = fd.is_priv }
    check_member_priv(e, obj3_sname, method, ns_member_priv, ctx)
    if ctx.auto_gen_depth.eq(0).and(fd.is_null().not()) { fd.used = true }
    // #154: calling a method of a cross-file type uses that type's import.
    note_cross_file_type_use(scope, ctx, obj3_sname)
    // #269: a call to an ABSTRACT method through an interface-typed receiver
    // cannot be resolved statically -- the receiver is a box carrying the
    // concrete implementer's type name (see gen_interface_box_fields_for_stmt
    // and the boxing rewrite in infer_and_validate_fcall_args). Lower the
    // call onto the existing dyn_call machinery, which dispatches on the
    // box's tag at runtime in BOTH backends:
    //   Iface.method(recv, extra...) ->
    //   dyn_call_ret(recv.iface_type_name, "method", arity, recv.iface_val, extra...)
    // Concrete default methods stay statically dispatched to the interface's
    // own implementation.
    if name_is_interface(obj3_sname, scope).and(e.children.len().gte(2)) {
        mut abs_method := false
        mut abs_returns := false
        mut abs_ret_type := ""
        switch ns_func2.node_type {
        case NodeType.FuncDef(abs_fd):
            if abs_fd.func_type.is(FuncType.ExtFunc).or(abs_fd.func_type.is(FuncType.ExtProc)) {
                abs_method = true
                abs_returns = abs_fd.return_type.len() > 0
                abs_ret_type = abs_fd.return_type.clone()
            }
        case:
        }
        recv_is_iface := til_type_name(e.children[1].til_type()) == obj3_sname
        if abs_method.and(recv_is_iface) {
            payload_args := e.children.len() - 1
            if payload_args > 2 {
                e.type_error(format("interface dispatch of '", obj3_sname, ".", method,
                    "': dyn_call supports at most one argument besides self"), ctx)
                e.set_til_type(Type.Unknown)
                return true
            }
            dl := e.line
            dc := e.col
            mut dyn_callee_name := "dyn_call"
            if abs_returns { dyn_callee_name = "dyn_call_ret" }
            mut dyn_children := Vec(Expr).new()
            dyn_children.push(own Expr.new(ident_node(dyn_callee_name), dl, dc))
            mut fa_tag := Expr.new(field_access_node("iface_type_name"), dl, dc)
            fa_tag.add_child(own e.children[1].clone())
            dyn_children.push(own fa_tag)
            dyn_children.push(own Expr.new(NodeType.Literal(Literal.Str(method.clone())), dl, dc))
            dyn_children.push(own Expr.new(NodeType.Literal(Literal.Num(LiteralNumData(text = payload_args.to_str()))), dl, dc))
            mut fa_val := Expr.new(field_access_node("iface_val"), dl, dc)
            fa_val.add_child(own e.children[1].clone())
            dyn_children.push(own fa_val)
            for xi in 2..e.children.len() {
                dyn_children.push_take(e.children, xi)
            }
            e.children = dyn_children
            switch e.node_type {
            case NodeType.FCall(dyn_fcd):
                dyn_fcd.own_args = 0
            case:
            }
            infer_expr(scope, e, in_func, ctx)
            if abs_ret_type.len() > 0 {
                e.set_til_type(type_from_name(abs_ret_type, scope, ctx))
            }
            return true
        }
    }
    if ctx.proc_def_depth.gt(0).or(in_func.neq(0)) {
        switch ns_func2.node_type {
        case NodeType.FuncDef(ns_fdef0):
            if ns_fdef0.func_type.is(FuncType.Proc).or(ns_fdef0.func_type.is(FuncType.ExtProc)).or(ns_fdef0.func_type.is(FuncType.CoreProc)) {
                ctx.proc_calls_count = ctx.proc_calls_count + 1
            }
        case:
        }
    }
    // Ensure obj3 carries the resolved struct type so the interpreter can
    // extract the parent type name via til_type_name for dispatch.
    if obj3_sname.len().gt(0).and(obj3.til_type().is(Type.Struct).not()) {
        obj3.set_til_type(Type.Struct(obj3_sname.clone()))
    }
    // is() compares only the outer enum tag (see ast.til), so a payload-carrying
    // variant like NodeType.Literal(Literal.SetLit) silently matches *any*
    // Literal -- the payload is dead. Reject it: use a bare variant
    // (NodeType.Literal) or a switch to discriminate the inner variant.
    if method == "is" {
        // is(self, other): the `other` argument is the last child (UFCS may
        // have inserted `self` ahead of it).
        if e.children.len() > 1 {
            ref is_other : Expr = e.children[e.children.len() - 1]
            if is_enum_variant_ctor_with_payload(is_other, scope) {
                is_other.type_error(format(
                    "is() compares only the enum tag, so the payload here is ignored; ",
                    "use a bare variant (e.g. 'NodeType.Literal') or a switch to ",
                    "discriminate the inner variant"), ctx)
            }
        }
    }
    switch ns_func2.node_type {
    case NodeType.FuncDef(ns_fdef):
        if desugar_fcall_args_for_fdef(e, "", ns_fdef, ctx).not() {
            // Missing-argument diagnostic was already emitted above.
            return true
        }
        // After UFCS rewriting, e.children[1] is the original receiver
        // Expr that was already inferred at the top of this proc. Skip
        // it (and any already-typed positional arg) to avoid firing
        // priv / member checks twice on the same node. Genuinely
        // unresolved args (Unknown til_type) still get inferred here.
        for i in 1..e.children.len() {
            if e.children[i].til_type().is(Type.Unknown) {
                infer_expr(scope, e.children[i], in_func, ctx)
            }
        }
        infer_and_validate_fcall_args_for_fdef(scope, e, ns_fdef, in_func, ctx)
        if ufcs_desugared {
            // If bit 0 (callee) was set by the parser's 'own expr' handler,
            // propagate it to bit 1 (the UFCS self arg) and clear bit 0.
            if get_own_arg(e, 0) {
                switch e.node_type {
                case NodeType.FCall(ufcs_fcd2):
                    ufcs_fcd2.own_args = ufcs_fcd2.own_args - 1
                case:
                    UNREACHABLE()
                }
                set_own_arg(e, 1)
            }
        }
        if ns_fdef.is_enum_variant_ctor {
            set_fcall_own_args_for_own_params(e, ns_fdef)
        }
        validate_fcall_own_args_for_fdef(scope, e, ns_fdef, ctx)
        mut rt := Type.None
        if ns_fdef.return_type.len() > 0 {
            rt = type_from_name(ns_fdef.return_type, scope, ctx)
        }
        e.set_til_type(rt)
        // Issue #191: namespace macro calls require all arguments to be comptime-known.
        if ns_fdef.func_type.is(FuncType.Macro) {
            for ai in 1..e.children.len() {
                if e.children[ai].expr_is_comptime(scope).not() {
                    e.children[ai].type_error("macro argument must be known at compile time", ctx)
                }
            }
        }
    case NodeType.StructDef(_ns_sdef):
        mut type_ident := Expr.new(ident_node(method), e.children[0].line, e.children[0].col)
        e.children[0] = type_ident
        return infer_struct_constructor_fcall_impl(scope, ns_func2, e, method, in_func, ctx)
    case:
        UNREACHABLE()
        return false
    }
    return true
}

// Issue #179 step 1: cross-file priv check for standalone funcs.
// The duplicate-fire problem this used to dedup against (FieldAccess
// receiver re-walk in infer_field_access_fcall) is now prevented at
// source: the post-UFCS re-walk skips already-typed children, so the
// receiver Expr is inferred exactly once.
priv check_priv_access := proc(mut e: Expr, name: Str, mut b: TypeBinding, ctx: Context) {
    if b.is_null() { return }
    if b.is_priv.not() { return }
    if b.path.eq(ctx.path).not() {
        // init_declarations_unit rewrote top-level priv decls to
        // `priv__<path>__<orig>`. Prefer the original identifier in the
        // diagnostic so users see the source form, not the mangle.
        mut display_name := name
        if b.orig_name.len().gt(0).and(b.name.starts_with("priv__")) {
            display_name = b.orig_name
        }
        e.type_error(format("'", display_name, "' is private to '", b.path, "'; remove 'priv' to expose it"), ctx)
        return
    }
    if b.orig_name.len() == 0 { return }
    // Top-level priv decls (mangled `priv__<path>__<orig>`) live at file
    // scope, so the same-file path check above is sufficient -- skip the
    // nested-parent check that follows, which assumes the
    // `<parent>_<orig>` lifted-nested layout.
    if b.name.starts_with("priv__") { return }
    // Issue #93 follow-up: lifted nested defs are function-scoped within
    // the original parent function. init_declarations_unit sets
    // b.orig_name to the user-facing identifier and mangles b.name as
    // `<parent>_<orig>`. Allow references from:
    //   - the parent function itself (current_top_func_name == parent), or
    //   - any other lifted descendant whose own mangled name starts with
    //     `<parent>_` (sibling helpers and inner ns methods), or
    //   - a ns-method body of a lifted struct/enum (tracked through
    //     current_type_name).
    parent_len := b.name.len().sub(b.orig_name.len()) - 1
    parent_name := b.name.substr(0, parent_len)
    parent_underscore := format(parent_name, "_")
    if ctx.current_top_func_name == parent_name { return }
    if ctx.current_top_func_name.starts_with(parent_underscore) { return }
    if ctx.current_type_name == parent_name { return }
    if ctx.current_type_name.starts_with(parent_underscore) { return }
    e.type_error(format("'", b.orig_name, "' is a local def of '", parent_name, "' and cannot be referenced from outside it"), ctx)
}

// Issue #179 + follow-up: cross-file priv check for type names that
// appear in declaration positions (parameter types, return types,
// ref/let decl explicit_type). The Ident-path check_priv_access only
// fires when a name is referenced as a value -- a user can otherwise
// write ~func(x: PrivStruct) returns PrivStruct~ in another file
// silently. Skip when inside the type's own namespace (auto-gen and
// hand-written ns methods both reference the parent type by name).
// Thin wrapper: looks up the binding, gates on current_type_name,
// then defers to check_priv_access for the actual emit.
priv check_priv_type_name := proc(mut e: Expr, name: Str, scope: TypeScope, ctx: Context) {
    if name.len() == 0 { return }
    if ctx.current_type_name == name { return }
    ref mut b : TypeBinding = scope.get_binding(name)
    check_priv_access(e, name, b, ctx)
}

// Issue #179 steps 4-5: priv check for struct fields and namespace
// methods. Stricter than top-level priv: priv members are only
// visible inside the struct's own namespace methods, not just the
// declaring file. current_type_name == owner_name iff we are
// type-checking a member body of that struct.
priv check_member_priv := proc(mut e: Expr, owner_name: Str, member_name: Str, member_is_priv: Bool, ctx: Context) {
    if member_is_priv.not() { return }
    if ctx.current_type_name == owner_name { return }
    e.type_error(format("'", owner_name, ".", member_name, "' is private to its struct; remove 'priv' to expose it"), ctx)
}

// Forbid `free(own X)` when X is an aggregate local whose type has a
// `delete` method. Such a shallow free releases only the struct box, and
// because passing `own X` makes the asap pass treat X as transferred (see
// expr_transfers_own), asap then skips the proper X.delete -- so X's owned
// fields leak. Demonstrated: `free(own vec_local)` leaks the element buffer.
// Exceptions fall out naturally: `self` is a param (not a local) so a
// delete method's own `free(own self)` box-release is allowed, and raw
// pointer types (U8/Dynamic) have no `delete` method so raw frees are fine.
priv check_free_managed_local := proc(scope: TypeScope, e: Expr, ctx: Context) {
    if e.children.len() < 2 { return }
    if get_own_arg(e, 1).not() { return }
    switch e.children[1].node_type {
    case NodeType.Ident(an):
        sf := scope.find(an.ident_name())
        switch sf {
        case ScopeFind.Found(b):
            if b.is_param { return }
            if b.own_type.is(OwnType.Ref) { return }
            tn := til_type_name(b.type)
            if tn.len() == 0 { return }
            ref sdef : Expr = scope.get_struct(tn)
            if sdef.is_null() { return }
            ref del : Expr = find_namespace_func(sdef, "delete", scope)
            if del.is_null() { return }
            e.type_error(format(
                "free(own ", Str.clone(an.ident_name()), ") shallow-frees managed type '", tn,
                "': passing 'own' makes the asap pass skip ", tn,
                ".delete, leaking its owned fields -- call ", tn, ".delete(own ",
                Str.clone(an.ident_name()), ", true) or let the asap pass free it",
            ), ctx)
        case:
        }
    case:
    }
}

// Issue #212: byte size of an integer primitive Type, or 0 for any
// non-integer-reinterpret-able type. F32 (4 bytes) and Bool are
// deliberately excluded -- `cast` is a bit reinterpret, not a value
// conversion. All four integer widths (1/2/4/8) carry a full same-size
// signed/unsigned pair in both the codegen and interpreter value model
// (Value.Sbyte/Byte, Value.Short/Ushort, Value.Int32/Uint32,
// Value.Int/Uint64).
priv cast_int_size := func(t: Type) returns USize {
    tn := til_type_name_c(t)
    if tn.eq("I8").or(tn.eq("U8"))   { return 1 }
    if tn.eq("I16").or(tn.eq("U16")) { return 2 }
    if tn.eq("I32").or(tn.eq("U32")) { return 4 }
    if tn.eq("I64").or(tn.eq("U64")) { return 8 }
    return 0
}

// True for the signed integer primitives the cast typer recognises.
// Used by cast_pair_ok to gate same-signedness widening; cross-
// signedness widening (e.g. I8 -> U16) is deferred for now because it
// changes the value's signed interpretation -- the operand and result
// no longer agree on what the bits mean.
priv cast_is_signed := func(t: Type) returns Bool {
    tn := til_type_name_c(t)
    if tn.eq("I8").or(tn.eq("I16")).or(tn.eq("I32")).or(tn.eq("I64")) {
        return true
    }
    return false
}

// True iff cast(src -> target) is legal for issue #212's current
// scope: same-size integer reinterpret (any signedness combination)
// OR same-signedness widening (src.size < target.size, both signed
// or both unsigned). Narrowing and cross-signedness widening are
// intentionally rejected.
priv cast_pair_ok := func(src: Type, target: Type) returns Bool {
    src_size := cast_int_size(src)
    target_size := cast_int_size(target)
    if src_size.gt(0).and(target_size.gt(0)) {
        if src_size == target_size { return true }
        if src_size < target_size {
            return cast_is_signed(src) == cast_is_signed(target)
        }
        return false
    }
    // Issue #58: Dynamic -> FuncPtr (named FuncSig) is the user's
    // assertion that the slot holds a function pointer of the target
    // signature -- used to pull a fn ptr out of a Dynamic-element Vec
    // (`Vec(BinaryOp).new()`) and call it. FuncPtr -> FuncPtr (same shape)
    // is accepted as an identity / nominal cast for completeness.
    if target.is_funcptr() {
        if src.is(Type.Dynamic).or(src.is_funcptr()) { return true }
    }
    if target.is(Type.Body) {
        if src.is(Type.Dynamic).or(src.is(Type.Body)) { return true }
    }
    return false
}

// Issue #212: type-check a `cast(e, T)` call. Validates that e and T are
// integer primitives of the same byte size, rewrites the T argument into
// a Type value (so downstream passes see a well-formed Type, as with
// Vec(I32).new()), and sets the call's result type to T -- the typer's
// stand-in for the not-yet-expressible `returns T`.
priv infer_cast_fcall := proc(scope: TypeScope, mut e: Expr, in_func: I32, ctx: Context) {
    if e.children.len() != 3 {
        e.type_error("cast expects (value, Type), e.g. x.cast(I32)", ctx)
        e.set_til_type(Type.Unknown)
        return
    }
    // Idempotency: if the typer has already processed this cast (e.g. a
    // for-range desugar re-infers an already-typed FCall), re-infer the
    // value arg for safety but skip re-deriving the target type. child(2)
    // stays the bare type-token Ident either way.
    if e.til_type().is(Type.Unknown).not() {
        infer_expr(scope, e.children[1], in_func, ctx)
        return
    }
    infer_expr(scope, e.children[1], in_func, ctx)
    src_type := e.children[1].til_type()
    mut tname := ""
    switch e.children[2].node_type {
    case NodeType.Ident(tn0): tname = Str.clone(tn0.ident_name())
    case:
        e.children[2].type_error("cast target must be a type name, e.g. cast(x, I32)", ctx)
        e.set_til_type(Type.Unknown)
        return
    }
    // Issue #58: a bare user FuncSig name (`cast(raw, BinaryOp)`)
    // resolves to Type.Custom through til_type_from_explicit_type;
    // walk scope to map it to Type.FuncPtr so cast_pair_ok's
    // Dynamic -> FuncPtr branch fires.
    mut target_type := til_type_from_explicit_type(tname)
    if target_type.is(Type.Custom) {
        target_type = type_from_name(tname, scope, ctx)
    }
    if cast_pair_ok(src_type, target_type).not() {
        e.type_error(format(
            "cast only supports same-size integer reinterpret ",
            "(any signedness) and same-signedness widening; ",
            "cannot cast ", til_type_name_c(src_type), " to ", tname,
        ), ctx)
        e.set_til_type(Type.Unknown)
        return
    }
    // Codegen never reads child(2), the type-token arg, so leave it as the
    // bare Ident it was parsed as and just tag it Type.Enum("Type"):
    //   * integer reinterpret / widening takes the target C type from the
    //     cast FCall's own til_type (til_type_name_c(e.til_type())) in
    //     the builder, never from child(2);
    //   * Issue #58's cast(value, FuncSig)(args) resolves the signature by
    //     NAME from this Ident (fcall_fn_sig / infer_funcptr_call_via_cast),
    //     which needs the bare Ident, not a rewritten Type value.
    // Materialising a runtime Type here (make_til_type_expr would build
    // Type.Primitive(Primitive.X) with an owned heap payload) only produced a
    // temp the hoister boxes with malloc and then deletes unused -- that dead
    // Type_Primitive box was the largest single allocation source in the
    // self-host --prof run.
    e.children[2].set_til_type(Type.Enum("Type"))
    e.set_til_type(target_type)
}

// Issue #58: type-check a postfix call where the callee is
// `cast(value, FuncSig)`. The cast has already been infer'd; this
// function reads the FuncSig name out of cast's child(2), looks up the
// FuncDef in scope, validates arg count + arg types against the sig,
// and sets the outer FCall's til_type to the sig's return type. Returns
// false when the callee isn't a cast-to-FuncSig shape so callers can
// fall back to other paths.
priv infer_funcptr_call_via_cast := proc(scope: TypeScope, mut e: Expr, in_func: I32, ctx: Context) returns Bool {
    ref callee : Expr = e.children[0]
    if callee.node_type.is(NodeType.FCall).not() { return false }
    if callee.til_type().is_funcptr().not() { return false }
    if callee.children.len() != 3 { return false }
    switch callee.children[0].node_type {
    case NodeType.Ident(cn):
        if cn.ident_name().eq("cast").not() { return false }
    case:
        return false
    }
    mut sig_name := ""
    switch callee.children[2].node_type {
    case NodeType.Ident(tn): sig_name = Str.clone(tn.ident_name())
    case:
        return false
    }
    ref sig_bind : TypeBinding = scope.get_binding(sig_name)
    if sig_bind.is_null() { return false }
    if sig_bind.type.is_funcptr().not() { return false }
    ref sig_def : Expr = scope.lookup_func(sig_bind.name)
    if sig_def.is_null() { return false }
    switch sig_def.node_type {
    case NodeType.FuncDef(sfd):
        nargs := e.children.len() - 1
        nparam := sfd.params.len()
        if nargs != nparam {
            type_error(e, format(
                "function pointer of type '", sig_name, "' expects ",
                nparam.to_str(), " arg(s), got ", nargs.to_str()
            ), ctx)
            e.set_til_type(Type.Unknown)
            return true
        }
        for ai in 1..e.children.len() {
            infer_expr(scope, e.children[ai], in_func, ctx)
        }
        if sfd.return_type.len() > 0 {
            e.set_til_type(type_from_name(sfd.return_type, scope, ctx))
        } else {
            e.set_til_type(Type.None)
        }
        return true
    case:
        return false
    }
}

// Issue #289: type an array(T, ...) / vec(T, ...) call. The element args are
// inferred normally; child(1) is the element TYPE token and is intentionally
// left un-inferred (its name -- a primitive like I64, a struct like Vector3,
// or a synthesized container name like Array__Str -- is all the later
// monomorphization passes need, and inferring a synthesized name as a value
// could spuriously fail symbol resolution). The token is NOT rewritten into a
// runtime Type expression, so the bare Ident survives for those passes.
priv infer_array_vec_fcall := proc(scope: TypeScope, mut e: Expr, name: Str, in_func: I32, ctx: Context) {
    for i in 2..e.children.len() {
        infer_expr(scope, e.children[i], in_func, ctx)
    }
    elem_type := array_vec_elem_type_name(e)
    if elem_type.len() == 0 {
        e.type_error("array/vec element type must be a type name, e.g. array(I64, 1, 2, 3)", ctx)
        e.set_til_type(Type.Unknown)
        return
    }
    if name == "array" {
        e.set_til_type(Type.Struct(variadic_array_type_name(scope, elem_type)))
    } else {
        e.set_til_type(Type.Struct(variadic_vec_type_name(scope, elem_type)))
    }
}

priv infer_fcall_expr := proc(scope: TypeScope, mut e: Expr, in_func: I32, ctx: Context) {
    // #164: a UFCS receiver `obj.method(args)` is conservatively treated
    // as "written" -- the namespace method may mutate it via `mut self`
    // (e.g. `Str.push_str(mut self: Str, s: Str)`), and the UFCS rewrite
    // turns into a callee_bind=NULL path that infer_and_validate_fcall_args
    // exits early on, so the precise pp2.is_mut check below won't fire
    // for namespace methods. Done before all dispatch.
    if e.children.len() > 0 {
        ref c0_w : Expr = e.children[0]
        if c0_w.node_type.is(NodeType.FieldAccess).and(c0_w.children.len().gt(0)) {
            mark_field_assign_root_written(scope, c0_w.children[0])
        }
    }
    if e.children[0].node_type.is(NodeType.FieldAccess) {
        if infer_field_access_fcall(scope, e, in_func, ctx) { return }
    }
    ref mut callee : Expr = e.children[0]
    // Issue #58: postfix call on a cast result: `cast(raw, BinaryOp)(3, 4)`.
    // Recognise the cast-to-FuncSig shape, type the cast (which sets the
    // cast expr's til_type to Type.FuncPtr and keeps child(2) as the
    // FuncSig Ident), and validate the outer call against the FuncSig.
    if callee.node_type.is(NodeType.FCall) {
        infer_expr(scope, callee, in_func, ctx)
        if callee.til_type().is(Type.Body) {
            nargs := e.children.len() - 1
            if nargs != 0 {
                e.type_error(format("Body value expects 0 args, got ", nargs.to_str()), ctx)
            }
            if in_func != 0 {
                e.type_error("func cannot call Body value", ctx)
            } else if ctx.proc_def_depth > 0 {
                ctx.proc_calls_count = ctx.proc_calls_count + 1
            }
            e.set_til_type(Type.None)
            return
        }
        if infer_funcptr_call_via_cast(scope, e, in_func, ctx) { return }
        // Other non-Ident callees (e.g. ops[0](args) without cast) are
        // not yet supported; the typer below will fall through to the
        // UNREACHABLE branch with a more diagnostic-able shape.
    }
    mut name := ""
    switch callee.node_type {
    case NodeType.Ident(name0):
        // Reject user-code calls to the internal ~get_payload~ builtin.
        // The typer's switch case desugar in make_switch_case_condition
        // and the initer's generated method bodies pre-set til_type on
        // their emitted FCalls; user-written FCalls arrive here with
        // til_type still Unknown.
        if name0.ident_name() == "get_payload" {
            if e.til_type().is(Type.Unknown) {
                e.type_error("bare get_payload(...) is not allowed; use a switch case binding instead", ctx)
                return
            }
            // typer-emitted: infer the receiver argument so downstream
            // checks see its type, but skip the normal callee-binding
            // resolution -- otherwise resolve_fcall_return_type would
            // overwrite our preset Struct/Enum til_type with the
            // declared `Dynamic` return of dyn.til's get_payload, and a
            // condition-side field access on this FCall (e.g.
            // ~case Shape.Dot(Point(x = 0)):~) would then fail with
            // "field access on non-struct value".
            if e.children.len() > 1 {
                infer_expr(scope, e.children[1], in_func, ctx)
            }
            return
        }
        name = Str.clone(name0.ident_name())
    case:
        UNREACHABLE()
        return
    }
    ref resolved_name : Str = resolve_type_alias(scope, name)
    if resolved_name.eq(name).not() {
        callee.node_type = ident_node(resolved_name)
        name = resolved_name.clone()
    }
    if name == "cast" {
        infer_cast_fcall(scope, e, in_func, ctx)
        return
    }
    if infer_struct_constructor_fcall(scope, e, name, in_func, ctx) { return }
    ref mut callee_bind : TypeBinding = scope.get_binding(name)
    if callee_bind.is_null().not() {
        callee_bind.used = true
        note_cross_file_use(ctx, callee_bind.path)
        check_priv_access(e, name, callee_bind, ctx)
        if scope.lookup_func(callee_bind.name).is_null().not() {
            desugar_user_func_fcall_args(scope, e, name, callee_bind, ctx)
        }
    }
    // Issue #289: array(T, ...) / vec(T, ...) carry the element type as a bare
    // type token in child(1) (like assert_eq's `T: Type`), not a Str. Handle
    // them before the generic arg machinery so the token is NOT rewritten into
    // a runtime Type expression by rewrite_til_type_arg -- array/vec are
    // monomorphized into Array__T / Vec__T at compile time, so the initer and
    // desugarer read the type NAME straight off this Ident.
    if name.eq("array").or(name.eq("vec")) {
        infer_array_vec_fcall(scope, e, name, in_func, ctx)
        return
    }
    // #288: a core_func / core_proc is an inline-only primitive intrinsic --
    // every backend lowers it natively, it emits NO symbol, and it must never
    // be indirected. dyn_fn is the one path that turns a (type, method) pair
    // into a callable funcptr (the FuncPtr fields CloneFn/CmpFn/HashFn/... are
    // all populated through it), so rejecting dyn_fn on a core_func also blocks
    // the FuncPtr-field and function-pointer vectors. dyn_fn takes the type
    // NAME as a Str (`dyn_fn("Type", "method")`); only that fully-literal shape
    // is statically checkable -- a Str-valued type argument
    // (`dyn_fn(elem_type, ...)`) is dynamic and skipped, and clone/cmp/hash
    // stay ext_func anyway.
    if name.eq("dyn_fn").and(e.children.len() >= 3) {
        switch e.children[1].node_type {
        case NodeType.Literal(Literal.Str(dyn_type_nm)):
            ref dyn_tdef : Expr = scope.get_struct(dyn_type_nm)
            if dyn_tdef.is_null().not() {
                switch e.children[2].node_type {
                case NodeType.Literal(Literal.Str(dyn_meth)):
                    ref dyn_md : Declaration = find_ns_decl(dyn_tdef, dyn_meth)
                    if dyn_md.is_null().not() {
                        switch dyn_md.default_value.node_type {
                        case NodeType.FuncDef(dyn_mfd):
                            if dyn_mfd.func_type.is(FuncType.CoreFunc).or(dyn_mfd.func_type.is(FuncType.CoreProc)).or(dyn_mfd.func_type.is(FuncType.CoreLazyFunc)) {
                                e.type_error(format("'", dyn_type_nm, ".", dyn_meth, "' is a ", func_type_name(dyn_mfd.func_type), " (an inline-only primitive intrinsic with no symbol) and cannot be indirected via dyn_fn"), ctx)
                            }
                        case:
                        }
                    }
                case:
                }
            }
        case:
        }
    }
    infer_and_validate_fcall_args(scope, e, callee_bind, in_func, ctx)
    if name == "free" { check_free_managed_local(scope, e, ctx) }
    // (check_move_managed_dest retired with the raw byte-move: `move` is
    // now the typed ownership primitive that destroys dest's old value
    // itself -- the guard's premise is gone, #302.)
    // Issue #191: macro calls require all arguments to be comptime-known.
    if callee_bind.is_null().not() {
        if binding_func_type(callee_bind).is(FuncType.Macro) {
            for ai in 1..e.children.len() {
                if e.children[ai].expr_is_comptime(scope).not() {
                    e.children[ai].type_error("macro argument must be known at compile time", ctx)
                }
            }
        }
    }
    validate_fcall_own_args(scope, e, callee_bind, ctx)
    resolve_fcall_return_type(scope, e, name, callee_bind, in_func, ctx)
    return
}

infer_expr := proc(scope: TypeScope, mut expr: Expr, in_func: I32, ctx: Context) {
    switch expr.node_type {
    case NodeType.Literal(Literal.Num):  infer_literal_expr(expr)
    case NodeType.Literal(Literal.Null): infer_literal_expr(expr)
    // Issue #281: a DIRECT __LOC__ use resolves to this token's own location
    // (the same string the old parse-time expansion produced). A __LOC__ that
    // is a parameter/field DEFAULT never reaches here -- it is left untouched
    // on the Declaration and resolved by the default-fill (resolve_default_value)
    // to the caller's location instead (infer_type_def_expr skips it for fields).
    case NodeType.Loc:
        expr.node_type = NodeType.Literal(Literal.Str(format(ctx.path, ":", expr.line.to_str(), ":", expr.col.to_str())))
    case NodeType.Ident:       infer_ident_expr(scope, expr, ctx)
    case NodeType.FuncDef:     infer_func_def_expr(scope, expr, ctx)
    case NodeType.BodyValue:   infer_body_value_expr(scope, expr, ctx)
    case NodeType.StructDef:   infer_type_def_expr(scope, expr, ctx)
    case NodeType.EnumDef:     infer_type_def_expr(scope, expr, ctx)
    case NodeType.FCall:       infer_fcall_expr(scope, expr, in_func, ctx)
    case NodeType.FieldAccess: infer_field_access_expr(scope, expr, in_func, ctx)
    case NodeType.Literal(Literal.MapLit):      infer_map_lit_expr(scope, expr, in_func, ctx)
    case NodeType.Literal(Literal.SetLit):      infer_set_lit_expr(scope, expr, in_func, ctx)
    case NodeType.NamedArg:    infer_named_arg_expr(scope, expr, in_func, ctx)
    case NodeType.Match:       infer_match_expr(scope, expr, in_func, ctx)
    case NodeType.Switch:
        // Issue #244: a switch reached expression position (e.g. `x := switch
        // ...`). switch is statement-only; point the user at match.
        expr.type_error("switch is a statement and yields no value; use 'match' to select a value", ctx)
        expr.set_til_type(Type.Unknown)
    case:
        expr.set_til_type(Type.Unknown)
    }
}

priv infer_ident_expr := proc(scope: TypeScope, mut expr: Expr, ctx: Context) {
    switch expr.node_type {
    case NodeType.Ident(id_name):
        type := scope.get_type(id_name.ident_name())
        if type.is(Type.Unknown) {
            expr.type_error(format("undefined symbol '", Str.clone(id_name.ident_name()), "'"), ctx)
        }
        expr.set_til_type(type)
        ref mut ib : TypeBinding = scope.get_binding(id_name.ident_name())
        if ib.is_null().not() {
            // #154: cross-file edge is recorded unconditionally -- the
            // current_type_name gate below only guards the priv-decl
            // `used` flag, and a type's own ns methods live in the
            // type's file so a self-reference is a no-op edge anyway.
            note_cross_file_use(ctx, ib.path)
            // #187 step 1: skip "used" marking when we're inside the
            // ident's own type namespace. Auto-generated clone/delete/
            // variant-constructor bodies reference the parent type by
            // name; counting those would mask a genuinely unused priv
            // type. External Ident references still mark it used.
            if ctx.current_type_name.eq(id_name.ident_name()).not() {
                ib.used = true
            }
            check_priv_access(expr, id_name.ident_name(), ib, ctx)
            if scope.lookup_func(ib.name).is_null().not() {
                expr.set_til_type(Type.FuncPtr)
            }
            if scope.struct_def_of(ib.name).is_null().not() {
                if til_type_name(expr.til_type()).len() == 0 {
                    ref resolved_name : Str = resolve_type_alias(scope, id_name.ident_name())
                    expr.set_til_type(Type.Custom(resolved_name.clone()))
                }
            }
        }
    case:
        UNREACHABLE()
    }
}

priv infer_named_arg_expr := proc(scope: TypeScope, mut expr: Expr, in_func: I32, ctx: Context) {
    if expr.children.len() > 0 {
        infer_expr(scope, expr.children[0], in_func, ctx)
    }
}

priv infer_map_lit_expr := proc(scope: TypeScope, expr: Expr, in_func: I32, ctx: Context) {
    for e_i : Expr in expr.children {
        infer_expr(scope, e_i, in_func, ctx)
    }
}

priv infer_set_lit_expr := proc(scope: TypeScope, expr: Expr, in_func: I32, ctx: Context) {
    for e_i : Expr in expr.children {
        infer_expr(scope, e_i, in_func, ctx)
    }
}

// Recursively scan `e` for any read or write of `self.<field_name>`
// (FieldAccess or FieldAssign whose receiver chain bottoms out in
// Ident("self")). Used to verify that user-written delete bodies
// reference each declared `own` field at least once -- if a field is
// never touched, the delete cannot possibly free it and any heap
// allocation the field's `own` qualifier announced is leaked at every
// destruction site (Map.delete, Vec.delete, scope_free, the
// auto-generated Value.delete chain, etc.).
priv expr_uses_self_field := proc(e: Expr, field_name: Str) returns Bool {
    expect(e.is_null().not(), "e is null")
    switch e.node_type {
    case NodeType.FieldAccess(fa_name):
        if fa_name.field_access_name() == field_name {
            if e.children.len() > 0 {
                switch e.children[0].node_type {
                case NodeType.Ident(id):
                    if id.ident_name() == "self" { return true }
                case:
                }
            }
        }
    case NodeType.FieldAssign(fad):
        if fad.name == field_name {
            if e.children.len() > 0 {
                switch e.children[0].node_type {
                case NodeType.Ident(id2):
                    if id2.ident_name() == "self" { return true }
                case:
                }
            }
        }
    case:
    }
    for ec : Expr in e.children {
        if expr_uses_self_field(ec, field_name) { return true }
    }
    return false
}

// Walk a struct's namespace decls; for the user-written `delete`
// (skip auto-generated ones), verify the body references each `own`
// field that the struct declares. A miss means the field's heap
// allocation has no path out -- the destructor silently leaks every
// time it runs. Issued at struct typing time so the error points at
// the struct declaration.
priv check_user_delete_frees_own_fields := proc(struct_name: Str, sdef: Expr, ctx: Context) {
    switch sdef.node_type {
    case NodeType.StructDef(cdsdd):
        ref cdns : Vec(Declaration) = def_ns_decls(sdef)
        for cdnd : Declaration in cdns {
            if cdnd.name.eq("delete").not() { continue }
            if cdnd.default_value.is_null() { continue }
            switch cdnd.default_value.node_type {
            case NodeType.FuncDef(cdfd):
                if cdfd.auto_generated { continue }
                if cdnd.default_value.children.len() == 0 { continue }
                ref cdbody : Expr = cdnd.default_value.children[0]
                for fd : Declaration in cdsdd.fields {
                    if fd.own_type.is(OwnType.Own).not() { continue }
                    if expr_uses_self_field(cdbody, fd.name).not() {
                        cdnd.default_value.type_error(
                            format("delete on '", struct_name, "' never references 'own' field 'self.", fd.name, "' -- declaring the field 'own' announces a heap allocation; the destructor must free it (e.g. `free(own self.", fd.name, ")`) or transfer its ownership."), ctx)
                    }
                }
            case:
            }
        }
    case:
    }
}

// Resolve enum payload type names against scope so e.g. a macro param `T`
// used as `Variant: T` payload is marked used, matching how StructDef
// field types do. Helper takes EnumDef directly (not via the switch-case
// destructure) so the typer carries Map<I64,Str> type info into the
// payload-types subscript without mixing the OutOfBounds (Vec) and
// KeyNotFound (Map) throws-inference paths.
priv typer_resolve_enum_payload_types := func(edef: EnumDef, scope: TypeScope, ctx: Context) {
    for k_e in 0..edef.variants.len() {
        if edef.payload_types.has(k_e.to_i64()) {
            ref pt_e : Str = edef.payload_types[k_e.to_i64()]
            if pt_e.len() > 0 {
                _ : Type = type_from_name(pt_e, scope, ctx)
            }
        }
    }
}

// Issue #251: does the implementing method `impl_fd` match the interface's
// abstract-method signature `iface_fd`? Same param count, same param types
// and return type -- but the interface's OWN name is "Self" and substitutes
// to the implementing type's name (so `self: Drawable` in the interface
// matches `self: Circle` in Circle). The func KIND differs by design
// (interface: ext_func/ext_proc; impl: func/proc), so it is not compared.
priv interface_method_conforms := func(iface_name: Str, impl_name: Str, iface_fd: Expr, impl_fd: Expr) returns Bool {
    switch iface_fd.node_type {
    case NodeType.FuncDef(ifd):
        switch impl_fd.node_type {
        case NodeType.FuncDef(mfd):
            if ifd.params.len() != mfd.params.len() { return false }
            for i in 0..ifd.params.len() {
                mut it := ifd.params[i].explicit_type.clone()
                if it == iface_name { it = impl_name.clone() }
                if it.eq(mfd.params[i].explicit_type).not() { return false }
            }
            mut ir := ifd.return_type.clone()
            if ir == iface_name { ir = impl_name.clone() }
            return ir == mfd.return_type
        case:
            return false
        }
    case:
        return false
    }
}

priv infer_type_def_expr := proc(scope: TypeScope, mut expr: Expr, ctx: Context) {
    expr.set_til_type(Type.None)
    inner := TypeScope(parent = scope)
    switch expr.node_type {
    case NodeType.StructDef(tc_sdd):
        for fd : Declaration in tc_sdd.fields {
            if fd.redundant_mut {
                fd.default_value.type_error(format("redundant 'mut' on struct field '", fd.name, "': fields are mutable by default; drop the 'mut' (use 'const' to make the field immutable)"), ctx)
            }
            // Issue #281: a `loc: Str = __LOC__` field default must stay the
            // Loc sentinel here -- inferring it now would resolve it to this
            // definition site. It is resolved per-constructor-call by the
            // default-fill (resolve_default_value) to the CALLER's location.
            if fd.default_value.is_null().not()
                .and(fd.default_value.node_type.is(NodeType.NoDefaultArg).not())
                .and(fd.default_value.node_type.is(NodeType.Loc).not()) {
                infer_expr(inner, fd.default_value, 0, ctx)
                check_ref_field_owned_default(fd, inner, ctx)
            }
            if fd.explicit_type.len() > 0 {
                fd.til_type =type_from_name(fd.explicit_type, inner, ctx)
                if fd.til_type.is(Type.Unknown).not() {
                    if fd.default_value.is_null().not().and(fd.default_value.node_type.is(NodeType.NoDefaultArg).not()) {
                        if fd.default_value.node_type.is_literal_num().and(is_numeric_type(fd.til_type)) {
                            fd.default_value.set_til_type(fd.til_type)
                        }
                        if fd.default_value.node_type.is_literal_null().not() {
                            narrow_dynamic(fd.default_value, fd.til_type)
                        }
                    }
                }
            } else {
                if fd.default_value.node_type.is(NodeType.NoDefaultArg) {
                    // #242: no default means there is no expression to infer
                    // the field type from, so an explicit `: Type` is required.
                    fd.default_value.type_error(format("field '", fd.name, "' has no default value, so it needs an explicit type: '", fd.name, " : Type'"), ctx)
                } else if fd.default_value.is_null().not() {
                    fd.til_type =fd.default_value.til_type()
                }
            }
            inner.set(fd.name, fd.til_type, fd.is_mut, ctx.path, expr.line, expr.col, false, fd.own_type)
            if fd.til_type.is_funcptr() {
                ref fb : TypeBinding = inner.get_binding(fd.name)
                if fd.default_value.is_null().not() {
                    switch fd.default_value.node_type {
                    case NodeType.Ident(dv_id):
                        ref src : TypeBinding = inner.get_binding(dv_id.ident_name())
                        if src.is_null().not() {
                            ref src_fd : Expr = inner.lookup_func(src.name)
                            if src_fd.is_null().not() { inner.set_func_def(fd.name, src_fd) }
                        }
                    case:
                    }
                }
                if inner.lookup_func(fb.name).is_null() {
                    // Issue #58 / #147 step 5: read the FuncSig alias
                    // name from fd.til_type (Type.FuncPtrSig payload)
                    // instead of from fd.explicit_type + get_binding
                    // round-trip. The FuncPtrSig predicate already gates
                    // "this is a FuncSig"; the bodyless-FuncDef check
                    // below is the same belt-and-braces it always was.
                    if fd.til_type.is(Type.FuncPtrSig) {
                        fsig_name := til_type_name(fd.til_type)
                        if fsig_name.len() > 0 {
                            ref fsb_fd : Expr = inner.lookup_func(fsig_name)
                            if fsb_fd.is_null().not() {
                                if fsb_fd.children.len() == 0 {
                                    inner.set_func_def(fd.name, fsb_fd)
                                }
                            }
                        }
                    }
                }
            }
        }
    case NodeType.EnumDef(tc_edd):
        // Issue #57: see typer_resolve_enum_payload_types.
        typer_resolve_enum_payload_types(tc_edd, inner, ctx)
    case:
    }
    // Issue #251: enforce the interface contract. `interface {...}`
    // desugars to a StructDef(is_interface) whose members the parser
    // accepts without checking. Each member must be ext_func/ext_proc
    // (an ABSTRACT method, implemented by conforming types) or func/proc
    // (a CONCRETE default with a body). A field, a test/macro/lazy member,
    // and a `namespace:` marker are all type errors. Reported here so they
    // aggregate in test/typer_errors.til.
    switch expr.node_type {
    case NodeType.StructDef(if_sdd):
        if if_sdd.is_interface {
            if if_sdd.interface_ns_marker {
                expr.type_error("interface has no 'namespace:' marker: it has no fields, so every declaration is already a method", ctx)
            }
            for if_nd : Declaration in if_sdd.ns_decls {
                if if_nd.default_value.is_null() { continue }
                switch if_nd.default_value.node_type {
                case NodeType.FuncDef(if_fd):
                    // Skip clone/delete/size/hash etc. that the initer
                    // auto-generates for the (empty) interface struct --
                    // only user-written members carry the contract.
                    if if_fd.auto_generated { continue }
                    ift := if_fd.func_type
                    ok_kind := ift.is(FuncType.Func).or(ift.is(FuncType.Proc))
                        .or(ift.is(FuncType.ExtFunc)).or(ift.is(FuncType.ExtProc))
                    if ok_kind.not() {
                        if_nd.default_value.type_error(format("interface member '", if_nd.name, "' must be a 'func'/'proc' (concrete default) or 'ext_func'/'ext_proc' (abstract method)"), ctx)
                    }
                case:
                    if_nd.default_value.type_error(format("interface member '", if_nd.name, "' must be a method: an interface cannot have fields"), ctx)
                }
            }
        }
    case:
    }
    // Issue #251: `struct implements Iface` / `enum implements Iface` --
    // verify the type provides every ABSTRACT (ext_func/ext_proc) method the
    // interface lists, with a matching signature. Concrete defaults are
    // inherited and not required. Structs and enums both carry methods in
    // their namespace, so the check is identical; only where the interface
    // name is recorded differs. Reported as aggregatable type errors.
    mut impl_iface_name := ""
    switch expr.node_type {
    case NodeType.StructDef(impl_sdd):
        impl_iface_name = impl_sdd.implements_name.clone()
    case NodeType.EnumDef(impl_edd):
        impl_iface_name = impl_edd.implements_name.clone()
    case:
    }
    if impl_iface_name.len() > 0 {
        impl_self_name := ctx.current_type_name
        ref iface_def : Expr = scope.get_struct(impl_iface_name)
        mut is_iface := false
        if iface_def.is_null().not() {
            switch iface_def.node_type {
            case NodeType.StructDef(iface_idd):
                if iface_idd.is_interface { is_iface = true }
            case:
            }
        }
        if is_iface.not() {
            expr.type_error(format("'", impl_self_name, "' implements '", impl_iface_name, "', which is not an interface"), ctx)
        } else {
            ref iface_members : Vec(Declaration) = def_ns_decls(iface_def)
            for am : Declaration in iface_members {
                if am.default_value.is_null() { continue }
                switch am.default_value.node_type {
                case NodeType.FuncDef(am_fd):
                    if am_fd.auto_generated { continue }
                    // Only abstract (ext_func/ext_proc) methods must be
                    // provided; func/proc defaults are inherited.
                    if am_fd.func_type.is(FuncType.ExtFunc).or(am_fd.func_type.is(FuncType.ExtProc)).not() { continue }
                    ref impl_m : Declaration = find_ns_decl(expr, am.name)
                    if impl_m.is_null() {
                        expr.type_error(format("'", impl_self_name, "' does not implement abstract method '", am.name, "' required by interface '", impl_iface_name, "'"), ctx)
                    } else if interface_method_conforms(impl_iface_name, impl_self_name, am.default_value, impl_m.default_value).not() {
                        impl_m.default_value.type_error(format("'", impl_self_name, ".", am.name, "' does not match the signature of '", impl_iface_name, ".", am.name, "' declared in the interface"), ctx)
                    }
                case:
                }
            }
        }
    }
    // Type-check ns_decls (stored directly by parser, not via body).
    // Flip ctx.typing_namespace_member so infer_func_def_expr accepts
    // test() decls at the namespace level (issue #51).
    saved_in_ns := ctx.typing_namespace_member
    ctx.typing_namespace_member = true
    ref tc_ns : Vec(Declaration) = def_ns_decls(expr)
    for tc_nd : Declaration in tc_ns {
        if tc_nd.default_value.is_null() { continue }
        if tc_nd.default_value.node_type.is(NodeType.NoDefaultArg) { continue }
        switch tc_nd.default_value.node_type {
        case NodeType.FuncDef(tc_fd):
            mut tc_rt := Type.None
            if tc_fd.return_type.len() > 0 {
                tc_rt = type_from_name(tc_fd.return_type, inner, ctx)
            }
            tc_nd.til_type =tc_rt.clone()
            inner.set(tc_nd.name, tc_rt, false, ctx.path, 0, 0, false, OwnType.Shallow)
            inner.set_func_def(tc_nd.name, tc_nd.default_value)
            ref mut tc_fb : TypeBinding = inner.get_binding(tc_nd.name)
            tc_fb.is_func_decl = true
            if tc_fd.func_type.is(FuncType.ExtFunc).or(tc_fd.func_type.is(FuncType.ExtProc)).or(tc_fd.func_type.is(FuncType.CoreFunc)).or(tc_fd.func_type.is(FuncType.CoreProc)).or(tc_fd.func_type.is(FuncType.CoreLazyFunc)) {
                tc_fb.is_builtin = true
            }
            infer_func_def_expr(inner, tc_nd.default_value, ctx)
        case:
            // A non-func namespace member is a constant (e.g. `MAX : F32 =
            // 3.4..e38`). Coerce its numeric literals to the declared type
            // before inference, exactly like top-level / local / field decls
            // (infer_decl_typed_value), so a typed float/int literal isn't
            // mis-parsed as I64 by the constfolder / interpreter.
            if tc_nd.explicit_type.len() > 0 {
                ns_declared := type_from_name(tc_nd.explicit_type, inner, ctx)
                if is_numeric_type(ns_declared) {
                    pre_coerce_decl_numeric_literals(tc_nd.default_value, ns_declared)
                }
            }
            infer_expr(inner, tc_nd.default_value, 0, ctx)
            tc_nd.til_type =tc_nd.default_value.til_type().clone()
        }
    }
    ctx.typing_namespace_member = saved_in_ns
    // Static check: a hand-written `delete` must free (or transfer) every
    // `own` field, otherwise the auto-generated destructor chain through
    // Value.delete / Map.delete / Vec.delete / scope_free leaks the
    // allocation the field's `own` qualifier declared.
    if expr.node_type.is(NodeType.StructDef) {
        check_user_delete_frees_own_fields(ctx.current_type_name, expr, ctx)
    }
}

// Issue #223 step 3: a struct is auto-shallow (safe to pass/return by a
// byte copy, like a primitive) when ALL of:
//   - its size fits in a machine word (total_struct_size <= 8 = UPtr.size()),
//   - it has no `own` fields (an owned heap pointer would be aliased /
//     double-freed by a byte copy -> the struct is "deep"),
//   - it has no `ref` fields (disqualified for now; revisitable later), AND
//   - every field's TYPE is itself auto-shallow (a primitive or another
//     auto-shallow struct). The transitive check closes the hole where a
//     size-8 struct embeds a deep struct inline.
// Enums are not covered here (revisit separately). Mirrors builder's
// is_pod_struct field rules, plus the size gate.
PTR_SIZE_BYTES : USize = 8
priv is_shallow_struct := func(type_name: Str, scope: TypeScope, ctx: Context) returns Bool {
    if type_name.len() == 0 { return false }
    expect(scope.is_null().not(), "scope is null")
    ref sdef : Expr = scope.get_struct(type_name)
    if sdef.is_null() { return false }
    switch sdef.node_type {
    case NodeType.StructDef(sdd):
        if ctx_total_size(type_name, ctx) > PTR_SIZE_BYTES { return false }
        if sdd.fields.len() == 0 { return false }
        for fd : Declaration in sdd.fields {
            if fd.own_type.is(OwnType.Own) { return false }
            if fd.own_type.is(OwnType.Ref) { return false }
            ref ftn : Str = fd.explicit_type
            if ftn.len() == 0 { return false }
            if is_primitive(til_type_from_explicit_type(ftn)) { continue }
            if is_shallow_struct(ftn, scope, ctx) { continue }
            return false
        }
        return true
    case:
    }
    return false
}

// A param/return type qualifies for auto-shallow if it is a primitive
// (step 1) or a small value-shaped struct (step 3).
priv is_auto_shallow_type := func(t: Type, type_name: Str, scope: TypeScope, ctx: Context) returns Bool {
    if is_primitive(t) { return true }
    if t.is(Type.Body) { return true }
    return is_shallow_struct(type_name, scope, ctx)
}

priv infer_func_sig_expr := func(scope: TypeScope, mut expr: Expr) {
    switch expr.node_type {
    case NodeType.FuncDef(fdef):
        // Issue #223 step 1: a function-pointer signature must match the
        // auto-shallow ABI of the ordinary func/proc it will hold, so
        // normalize primitive params/returns to Shallow here too. Otherwise
        // the call-through codegen would deref a value return as a pointer.
        sig_auto_shallow := fdef.func_type.is(FuncType.Func).or(fdef.func_type.is(FuncType.Proc))
        if fdef.return_type.len() > 0 {
            return_type_name := fdef.return_type.clone()
            ref resolved_return_type : Str = resolve_type_alias(scope, return_type_name)
            if is_usize_name(return_type_name).or(is_uptr_name(return_type_name)).and(resolve_type_alias(scope, "USize").eq(resolve_type_alias(scope, "UPtr")).not()).not() { fdef.return_type = resolved_return_type }
            // Issue #223 step 2: forbid redundant 'shallow' on a primitive
            // funcptr return. COMMENTED OUT during rollout (see infer_func_def_expr).
            // NOTE: infer_func_sig_expr is a func with no ctx, so enabling this
            // needs the diagnostic raised from a proc context.
            // if sig_auto_shallow.and(fdef.return_own_type.is(OwnType.Shallow)) {
            //     if is_primitive(til_type_from_explicit_type(resolved_return_type)) {
            //         <raise: redundant 'shallow' on primitive return type ... drop it>
            //     }
            // }
            if sig_auto_shallow.and(fdef.return_own_type.is(OwnType.Own)) {
                if is_primitive(til_type_from_explicit_type(resolved_return_type)) {
                    fdef.return_own_type = OwnType.Shallow
                }
            }
        }
        for param : Declaration in fdef.params {
            ptype_name := param.explicit_type.clone()
            ref resolved_ptype : Str = resolve_type_alias(scope, ptype_name)
            // Keep USize/UPtr as their alias name ONLY when the two widths
            // actually differ (a --usize=32 / 32-bit build): there the coercion
            // must recognize size vs pointer params. When they are equal (the
            // default), resolve to the primitive as before -- byte-identical.
            if is_usize_name(ptype_name).or(is_uptr_name(ptype_name)).and(resolve_type_alias(scope, "USize").eq(resolve_type_alias(scope, "UPtr")).not()).not() { param.explicit_type = resolved_ptype }
            param.til_type =til_type_from_explicit_type(resolved_ptype)
            // Issue #58 / #147 step 5: if the param's type resolves to a
            // FuncSig alias (a bodyless FuncDef in scope), upgrade
            // til_type from Type.Custom(name) to Type.FuncPtrSig(name)
            // so downstream consumers (builder's fcall_fn_sig fallback,
            // typer's func_def propagation) can read the FuncSig name
            // off the type instead of off `param.explicit_type`. This
            // is what makes the FuncPtrSig migration reach param-level
            // til_type, not just expr-level inferred types.
            ref sig_fd_param : Expr = scope.lookup_func(resolved_ptype)
            if sig_fd_param.is_null().not() {
                if sig_fd_param.children.len() == 0 {
                    param.til_type = Type.FuncPtrSig(resolved_ptype.clone())
                }
            }
            // Issue #223 step 2: forbid redundant 'shallow' on a primitive
            // funcptr parameter. COMMENTED OUT during rollout (see infer_func_def_expr).
            // if sig_auto_shallow.and(fdef.return_own_type.is(OwnType.Ref).not()).and(param.own_type.is(OwnType.Shallow)).and(param.is_mut.not()).and(is_primitive(param.til_type)) {
            //     <raise: redundant 'shallow' on primitive parameter ... drop it>
            // }
            if sig_auto_shallow.and(fdef.return_own_type.is(OwnType.Ref).not()).and(param.own_type.is(OwnType.Ref)).and(param.is_mut.not()).and(is_primitive(param.til_type)) {
                param.own_type = OwnType.Shallow
            }
            // A FuncPtr param is an 8-byte pointer; the C ABI passes it
            // by value just like a primitive, so the funcptr-sig has to
            // match auto-shallow too. Otherwise emit_fcall_funcptr_cast
            // generates `(void * *)` for the param and the arg emit
            // takes its address, both wrong for a callee that expects
            // the function pointer by value. param.til_type at this
            // point is Type.Custom(name) -- the FuncPtr-ness lives in
            // the scope binding for the alias name, not in the inline
            // Type, so look it up.
            if sig_auto_shallow.and(fdef.return_own_type.is(OwnType.Ref).not()).and(param.own_type.is(OwnType.Ref)).and(param.is_mut.not()) {
                ref pbind : TypeBinding = scope.get_binding(resolved_ptype)
                if param.til_type.is(Type.Body).or(pbind.is_null().not().and(pbind.type.is_funcptr())) {
                    param.own_type = OwnType.Shallow
                }
            }
        }
    case:
        UNREACHABLE()
    }
    expr.set_til_type(Type.FuncPtr)
}

priv check_ref_function_returns := proc(func_scope: TypeScope, expr: Expr, ctx: Context) {
    mut throws_count : USize = 0
    switch expr.node_type {
    case NodeType.FuncDef(fdef):
        if fdef.return_own_type.is(OwnType.Ref).not() { return }
        throws_count = fdef.throw_types.len()
    case:
        UNREACHABLE()
        return
    }
    for stmt : Expr in expr.children[0].children {
        if stmt.node_type.is(NodeType.Return).not() { continue }
        if stmt.children.len() == 0 { continue }
        ref rv : Expr = stmt.children[0]
        // A throwing ref-returning fn gets a synthetic `return null`
        // fallback from process_throw_catch_in_func_body. It is
        // unreachable on the success path and unused on the error path
        // (the err code flows out through the out-param), so allow it.
        if throws_count.gt(0).and(rv.node_type.is_literal_null()) { continue }
        if expr_is_borrow_source(rv, func_scope).not() {
            stmt.type_error("ref function must return a parameter or ref variable", ctx)
        }
    }
}

priv first_borrowed_capture_name := func(e: Expr) returns Str {
    switch e.node_type {
    case NodeType.FuncDef(fd):
        for cap : Declaration in fd.captures {
            if cap.own_type.is(OwnType.Ref) { return cap.name.clone() }
        }
    case:
    }
    return ""
}

priv closure_borrowed_capture_name := func(e: Expr, scope: TypeScope) returns Str {
    switch e.node_type {
    case NodeType.FuncDef:
        return first_borrowed_capture_name(e)
    case NodeType.Ident(id):
        ref fdef : Expr = scope.lookup_func(id.ident_name())
        if fdef.is_null() { return "" }
        return first_borrowed_capture_name(fdef)
    case:
    }
    return ""
}

priv check_returned_borrowed_closure_captures_in := proc(e: Expr, func_scope: TypeScope, ctx: Context) {
    switch e.node_type {
    case NodeType.Return:
        if e.children.len() == 0 { return }
        cap_name := closure_borrowed_capture_name(e.children[0], func_scope)
        if cap_name.len() > 0 {
            e.type_error(format("returned closure borrows captured local '", cap_name,
                "'; capture it as 'own ", cap_name, "' or 'shallow ", cap_name,
                "' if the closure escapes"), ctx)
        }
        return
    case NodeType.FuncDef:
        return
    case:
    }
    for c : Expr in e.children {
        check_returned_borrowed_closure_captures_in(c, func_scope, ctx)
    }
}

priv check_returned_borrowed_closure_captures := proc(func_scope: TypeScope, expr: Expr, ctx: Context) {
    switch expr.node_type {
    case NodeType.FuncDef:
        if expr.children.len() == 0 { return }
        check_returned_borrowed_closure_captures_in(expr.children[0], func_scope, ctx)
    case:
        UNREACHABLE()
    }
}

priv infer_func_def_expr := proc(scope: TypeScope, mut expr: Expr, mut ctx: Context) {
    if expr.children.len() == 0 {
        infer_func_sig_expr(scope, expr)
        return
    }
    expr.set_til_type(Type.None)
    // Snapshot + clear the namespace flag so nested funcs typed by
    // recursive infer_expr calls aren't treated as namespace members.
    ifd_in_ns := ctx.typing_namespace_member
    ctx.typing_namespace_member = false
    switch expr.node_type {
    case NodeType.FuncDef(fdef):
        // Issue #262: a lazy_func types like a func (cannot call proc,
        // tracks its return type); a lazy_proc types like neither func nor
        // proc here so its body may call procs without the "proc has no
        // proc calls" diagnostic. All lazy calls are inlined before this
        // pass runs, so these defs are dead -- they only need to type and
        // emit as ordinary functions.
        is_func := fdef.func_type.is(FuncType.Func).or(fdef.func_type.is(FuncType.LazyFunc)).or(fdef.func_type.is(FuncType.CoreLazyFunc))
        is_macro := fdef.func_type.is(FuncType.Macro)
        // Issue #262: a lazy callable's body must be handled by the loader's
        // lazy passes -- either expression-inlinable (lazy_body_inlinable:
        // single `return <expr>`, `if/else`, or guard chain) or statement-
        // inlinable (lazy_body_stmt_inlinable: a safe prelude + an inlinable
        // tail, e.g. `x := f(a); return x.and(b)`). Reject anything else
        // loudly (loops, early returns, first-class) -- those need the thunk
        // fallback and would otherwise silently degrade to an eager call.
        if fdef.func_type.is(FuncType.LazyFunc).or(fdef.func_type.is(FuncType.LazyProc)) {
            if expr.children.len() > 0 {
                // Issue #262: the RECURSIVE variadic form (vand/vor) is fully
                // consumed by the loader's recursion-unroll -- every call is
                // already expanded -- and its ListPattern arms cannot type as
                // ordinary code, so skip typing the def entirely (the same
                // way template macro bodies are skipped). The builder skips
                // its emission via the same predicate.
                if lazy_recursive_variadic_def(expr) {
                    expr.set_til_type(Type.None)
                    ctx.typing_namespace_member = ifd_in_ns
                    return
                }
                ref lbody : Expr = expr.children[0]
                if lazy_body_inlinable(lbody).or(lazy_body_stmt_inlinable(lbody)).not() {
                    // Issue #262: a variadic lazy def is accepted when its
                    // body is unrollable -- the loader unrolls every call
                    // over its known operands (inline_variadic_lazy_call),
                    // so the def itself is dead like any inlinable lazy def.
                    mut lazy_var_unrollable := false
                    if fdef.variadic_index >= 0 {
                        ref vparam : Declaration = fdef.params[fdef.variadic_index.to_usize()]
                        lazy_var_unrollable = lazy_variadic_body_unrollable(lbody, vparam.name)
                    }
                    if lazy_var_unrollable.not() {
                        expr.type_error("lazy_func/lazy_proc body must be inlinable for now (issue #262): a single 'return <expr>', an 'if/else' or guard chain, a prelude of local bindings followed by such a tail, or a variadic body consuming its variadic param only via 'for x in xs { if ... { return ... } }' loops or the recursive 'match xs { case []: ... case [x, ..tl]: ... }' form; other loops, early returns, and first-class use are not yet supported", ctx)
                    }
                }
            }
        }
        // Issue #57: macros that are pure templates (returning
        // StructDef / EnumDef / FuncDef, or with a `Type` parameter) are
        // expanded at each call site by initer's pre-pass. Detect the
        // condition up front so every subsequent body-walk and param-
        // resolution skip cleanly -- references to the type-params can't
        // be resolved until expansion. Mirrors rstil typer.rs:1090-1097.
        mut macro_is_template := false
        if is_macro {
            mtg_ret := fdef.return_type.eq("StructDef")
                .or(fdef.return_type.eq("EnumDef"))
                .or(fdef.return_type.eq("FuncDef"))
                .or(fdef.return_type.eq("FunctionDef"))
            if mtg_ret { macro_is_template = true }
            if macro_is_template.not() {
                for tmp_param : Declaration in fdef.params {
                    if tmp_param.explicit_type == "Type" {
                        macro_is_template = true
                    }
                }
            }
        }
        // Issue #223 step 1: auto-shallow applies to ordinary til
        // func/proc definitions only. ext_func/ext_proc qualifiers map
        // directly to a hand-written C signature (e.g. U64_clone takes a
        // 'const U64 *'), so their shallow-ness must be preserved exactly.
        auto_shallow_ok := fdef.func_type.is(FuncType.Func).or(fdef.func_type.is(FuncType.Proc))
            .or(fdef.func_type.is(FuncType.LazyFunc)).or(fdef.func_type.is(FuncType.LazyProc))
        if fdef.func_type.is(FuncType.Test) {
            // Allowed at root scope, or at the immediate namespace
            // level of a struct/enum (issue #51).  Tests in arbitrary
            // nested function bodies are still rejected.
            if scope.parent.is_null().not().and(ifd_in_ns.not()) {
                expr.type_error("test functions can only be declared at root scope or in a struct/enum namespace", ctx)
            }
            if fdef.return_type.len() > 0 {
                expr.type_error("test functions cannot have a return type", ctx)
            }
            if fdef.params.len() > 0 {
                expr.type_error("test functions cannot have parameters", ctx)
            }
        }
        if ctx.mode.is_pure {
            if fdef.func_type.is(FuncType.Proc) {
                expr.type_error("proc not allowed in pure mode", ctx)
            }
        }
        mut func_scope := TypeScope(parent = scope)
        if fdef.return_type.len() > 0 {
            return_type_name := fdef.return_type.clone()
            ref resolved_return_type : Str = resolve_type_alias(scope, return_type_name)
            if is_usize_name(return_type_name).or(is_uptr_name(return_type_name)).and(resolve_type_alias(scope, "USize").eq(resolve_type_alias(scope, "UPtr")).not()).not() { fdef.return_type = resolved_return_type }
            check_priv_type_name(expr, resolved_return_type, scope, ctx)
            // Issue #223 step 2: an explicit 'shallow' on a primitive return is
            // redundant (auto-shallow handles it). Reject it. Test the parser's
            // return_shallow_explicit flag, NOT return_own_type: the step-1
            // normalization below overwrites Own->Shallow for primitives, so
            // checking return_own_type would misfire on any RE-inference of the
            // def (e.g. a capturing closure re-typed as a UFCS-receiver-call
            // arg, which the auto-shallow pass had already normalized).
            if auto_shallow_ok.and(fdef.return_shallow_explicit) {
                if is_primitive(type_from_name_at(resolved_return_type, scope, expr, ctx)) {
                    expr.type_error("redundant 'shallow' on primitive return type: primitives are returned by value automatically (issue #223); drop it", ctx)
                }
            }
            // Issue #223 step 1/3: a primitive (step 1) or a small value-shaped
            // struct (step 3) is returned by value (shallow) even without the
            // qualifier. Normalize the default (Own) to Shallow for those types
            // so every downstream stage treats them as value types. Explicit
            // 'ref' returns are left alone (a borrowed pointer is intentional).
            if auto_shallow_ok.and(fdef.return_own_type.is(OwnType.Own)) {
                rt := type_from_name_at(resolved_return_type, scope, expr, ctx)
                if is_auto_shallow_type(rt, resolved_return_type, scope, ctx) { fdef.return_own_type = OwnType.Shallow }
            }
        }
        for i in 0..fdef.params.len() {
            ref mut param : Declaration = fdef.params[i]
            ptype_name := param.explicit_type.clone()
            ref resolved_ptype : Str = resolve_type_alias(scope, ptype_name)
            // Keep USize/UPtr as their alias name ONLY when the two widths
            // actually differ (a --usize=32 / 32-bit build): there the coercion
            // must recognize size vs pointer params. When they are equal (the
            // default), resolve to the primitive as before -- byte-identical.
            if is_usize_name(ptype_name).or(is_uptr_name(ptype_name)).and(resolve_type_alias(scope, "USize").eq(resolve_type_alias(scope, "UPtr")).not()).not() { param.explicit_type = resolved_ptype }
            param.til_type =til_type_from_explicit_type(resolved_ptype)
            ref ptn : Str = param.explicit_type
            pt := type_from_name_at(ptn, scope, expr, ctx)
            // Issue #58 / #147 step 5: same FuncPtrSig upgrade as in
            // infer_func_sig_expr -- if the param's type resolves to a
            // FuncSig (Type.FuncPtrSig(name)), store that on til_type so
            // downstream readers don't need to go through param.explicit_type.
            if pt.is(Type.FuncPtrSig) {
                param.til_type = pt.clone()
            }
            // Issue #57: skip the undefined-type diagnostic for template
            // macros -- a param like `T` is a stand-in resolved at
            // expansion time, not a real type.
            if pt.is(Type.Unknown).and(macro_is_template.not()) {
                expr.type_error(format("undefined type '", ptn, "'"), ctx)
            }
            pmut := param.is_mut
            pown := param.own_type.is(OwnType.Own)
            pshallow := param.own_type.is(OwnType.Shallow)
            if pshallow {
                is_scalar := is_primitive(pt)
                if is_scalar.not().and(pt.is(Type.Struct).not()).and(pt.is(Type.Enum).not()) {
                    expr.type_error(format("shallow parameter '", param.name, "' must be a scalar or struct type"), ctx)
                }
                if pown {
                    expr.type_error("parameter cannot be both 'shallow' and 'own'", ctx)
                }
                // Issue #223 step 2: an explicit 'shallow' on a primitive
                // parameter is redundant where auto-shallow applies (ordinary
                // func/proc not returning ref). Reject it.
                if is_scalar.and(auto_shallow_ok).and(fdef.return_own_type.is(OwnType.Ref).not()) {
                    expr.type_error(format("redundant 'shallow' on primitive parameter '", param.name, "': primitives are passed by value automatically (issue #223); drop it"), ctx)
                }
            }
            if i.to_i32() == fdef.variadic_index {
                // Regular til funcs get a callee-side auto-cleanup
                // (Array.delete at scope exit) so the caller can transfer
                // ownership cleanly. ext_func/ext_proc bodies are
                // user-written C with no auto-cleanup -- transferring
                // ownership leaks the synthesized Array. Keep the parser's
                // Ref setting for ext bindings; force Own elsewhere.
                // (Issue #109: ffi_run was 228B/9 from exactly this.)
                is_ext_va := fdef.func_type.is(FuncType.ExtFunc).or(fdef.func_type.is(FuncType.ExtProc)).or(fdef.func_type.is(FuncType.CoreFunc)).or(fdef.func_type.is(FuncType.CoreProc)).or(fdef.func_type.is(FuncType.CoreLazyFunc))
                if is_ext_va.not() { param.own_type = OwnType.Own }
                va_type := variadic_array_type_name(scope, param.explicit_type)
                func_scope.set(param.name, Type.Struct(va_type), false, ctx.path, expr.line, expr.col, true, param.own_type)
            } else if i.to_i32() == fdef.kwargs_index {
                // Same rationale as variadic above.
                is_ext_kw := fdef.func_type.is(FuncType.ExtFunc).or(fdef.func_type.is(FuncType.ExtProc)).or(fdef.func_type.is(FuncType.CoreFunc)).or(fdef.func_type.is(FuncType.CoreProc)).or(fdef.func_type.is(FuncType.CoreLazyFunc))
                if is_ext_kw.not() { param.own_type = OwnType.Own }
                func_scope.set(param.name, Type.Struct("KwargsMap"), false, ctx.path, expr.line, expr.col, true, param.own_type)
            } else {
                // Issue #223 step 1/3: a primitive (step 1) or small value-shaped
                // struct (step 3) param is passed by value (shallow) even without
                // the qualifier. Normalize the plain borrowed default (Ref,
                // non-mut) to Shallow for those types so every downstream stage
                // treats them as value types. 'mut', 'own', and 'shallow' params
                // are left as the user wrote them. A ref-returning function may
                // hand a param back by reference (e.g. min(a, b) returns ref I64),
                // so its params must stay borrowed pointers -- skip auto-shallow
                // there.
                if auto_shallow_ok.and(fdef.return_own_type.is(OwnType.Ref).not()).and(param.own_type.is(OwnType.Ref)).and(pmut.not()).and(is_auto_shallow_type(pt, ptn, scope, ctx)) {
                    param.own_type = OwnType.Shallow
                }
                func_scope.set(param.name, pt, pmut, ctx.path, expr.line, expr.col, true, param.own_type)
                if pt.is_funcptr() {
                    sf_fsb := scope.find(ptn)
                    switch sf_fsb {
                    case ScopeFind.Found(fsb):
                        ref fsb_fd : Expr = scope.lookup_func(fsb.name)
                        if fsb_fd.is_null().not() {
                            if fsb_fd.children.len() == 0 {
                                func_scope.set_func_def(param.name, fsb_fd)
                            }
                        }
                    case:
                    }
                }
            }
        }
        mut in_func_val : I32 = 0
        if is_func { in_func_val = 1 }
        mut returns_ref_val : I32 = 0
        if fdef.return_own_type.is(OwnType.Ref) { returns_ref_val = 1 }
        is_proc := fdef.func_type.is(FuncType.Proc)
        saved_proc_calls := ctx.proc_calls_count
        if is_proc {
            ctx.proc_calls_count = 0
            ctx.proc_def_depth = ctx.proc_def_depth + 1
        }
        if fdef.auto_generated {
            ctx.auto_gen_depth = ctx.auto_gen_depth + 1
        }
        saved_in_shallow_ret := ctx.typer_in_shallow_return
        ctx.typer_in_shallow_return = fdef.return_own_type.is(OwnType.Shallow)
        saved_in_main_func := ctx.typer_in_main_func
        ctx.typer_in_main_func = ctx.current_top_func_name.eq("main").and(scope.parent.is_null())
        saved_return_type_name := ctx.typer_return_type_name.clone()
        if is_func { ctx.typer_return_type_name = fdef.return_type.clone() } else { ctx.typer_return_type_name = "" }
        // Issue #198: lower throw/catch BEFORE infer_body so the
        // synthesised mut _err_kind / _err_<T> locals + if-guards
        // get type-checked normally and reach all downstream stages
        // (interpreter and builder) as plain til. Then inject the
        // extra err args at every does_throw call site so the
        // typer's arity check passes. UFCS calls keep their
        // FieldAccess(method) callee at this stage; the inject
        // matches by method name so the appended args end up at
        // the end of the eventual rewritten FCall.
        if fdef.auto_generated.not().and(macro_is_template.not()) {
            // Issue #158-aligned: single per-body walk for all
            // throw/catch processing (replaces the previous chain
            // of desugar_bang + validate + lower + inject + fallback
            // return). One walk does the work the five old passes
            // did, integrated per stmt.
            // Seed the receiver-type map so the walk's type-qualified
            // throws lookup can resolve `param.method(...)` receivers.
            ctx.lowering_param_types = Map(Str, Str).new()
            for lpi in 0..fdef.params.len() {
                ref lpp : Declaration = fdef.params[lpi]
                mut lptn := lpp.explicit_type.clone()
                if lpi.to_i32() == fdef.variadic_index { lptn = variadic_array_type_name(scope, lpp.explicit_type) }
                if lpi.to_i32() == fdef.kwargs_index { lptn = "KwargsMap" }
                if lptn.len() == 0 { continue }
                ctx.lowering_param_types.set(lpp.name, own lptn)
            }
            // Also seed switch-case payload bindings: `case E.V(x):` binds
            // `x` to the variant's payload type. The case-body Decls don't
            // exist yet at this stage (they are emitted inside infer_body
            // by make_switch_case_condition), so the throw/catch walk
            // can't see their explicit_type via the body-Decl scan.
            collect_switch_case_bindings(ctx, expr.children[0])
            process_throw_catch_in_func_body(ctx, expr.children[0], fdef.throw_types, fdef.return_type, fdef.return_own_type)
        }
        if macro_is_template.not() {
            infer_body(func_scope, expr.children[0], in_func_val, 1, 0, returns_ref_val, 0, ctx)
            garbager_destroy_body(ctx, expr.children[0], func_scope)
            // Issue #54: for a capturing function/lambda, validate the
            // captures against the enclosing scope and enforce that the
            // body only touches captured outer locals (plus params,
            // body-locals, globals, funcs/types) -- the same explicit-
            // capture restriction as a bare capture block.
            if fdef.captures.len() > 0 {
                validate_captures(scope, fdef.captures, expr, ctx)
                ref cap_root : TypeScope = scope_root_ref(scope)
                capture_block_check_refs(expr.children[0], scope, func_scope, cap_root, fdef.captures, ctx)
            }
        }
        ctx.typer_in_shallow_return = saved_in_shallow_ret
        ctx.typer_in_main_func = saved_in_main_func
        ctx.typer_return_type_name = saved_return_type_name
        if fdef.auto_generated {
            ctx.auto_gen_depth = ctx.auto_gen_depth - 1
        }
        if is_proc {
            if ctx.proc_calls_count == 0 {
                expr.type_error("proc has no proc/ext_proc calls; should be a func", ctx)
            }
            ctx.proc_calls_count = saved_proc_calls
            ctx.proc_def_depth = ctx.proc_def_depth - 1
        }
        if is_macro.and(fdef.return_type.len().eq(0)) {
            expr.type_error("macro must declare a return type", ctx)
        }
        if macro_is_template.not() {
            check_ref_function_returns(func_scope, expr, ctx)
            check_returned_borrowed_closure_captures(func_scope, expr, ctx)
            check_all_paths_return(expr, ctx)
            check_unused_params(func_scope, expr, ctx)
            check_unused_mut_params(func_scope, expr, ctx.path, ctx)
            check_unused_locals(func_scope, ctx.path, ctx)
            check_unused_mut_locals(func_scope, ctx.path, ctx)
        }
    case:
        UNREACHABLE()
    }
    ctx.typing_namespace_member = ifd_in_ns
}

// til's own all-paths-return check (option B). A non-void user function whose
// body can fall off the end without returning is reported here, with a til
// source location, instead of surfacing later as GCC's -Werror=return-type on
// the generated C (which the emitter's __builtin_unreachable terminator would
// otherwise quietly satisfy). The divergence predicate stmt_always_diverges
// lives in context.til, shared with the builder's emit-side terminator so the
// two can never drift. The C -Werror=return-type backstop stays on to catch
// anything the analysis still misses in the other direction.
priv check_all_paths_return := proc(expr: Expr, ctx: Context) {
    switch expr.node_type {
    case NodeType.FuncDef(fdef):
        // Only user Func/Proc bodies with a declared return type must return on
        // every path. A void function (no return type) may fall off the end;
        // ext/core have no til body; macros return AST; Test and auto-generated
        // functions are the compiler's own concern, not user-facing.
        if fdef.return_type.len() == 0 { return }
        if fdef.auto_generated { return }
        if fdef.func_type.is(FuncType.ExtFunc).or(fdef.func_type.is(FuncType.ExtProc))
            .or(fdef.func_type.is(FuncType.CoreFunc)).or(fdef.func_type.is(FuncType.CoreProc)).or(fdef.func_type.is(FuncType.CoreLazyFunc))
            .or(fdef.func_type.is(FuncType.Macro)).or(fdef.func_type.is(FuncType.Test)) { return }
        if stmt_always_diverges(expr.children[0]).not() {
            expr.type_error(format("non-void function can reach its end without returning; every path must return a value (declared 'returns ", fdef.return_type, "')"), ctx)
        }
    case:
    }
}

priv check_unused_params := proc(func_scope: TypeScope, expr: Expr, ctx: Context) {
    switch expr.node_type {
    case NodeType.FuncDef(fdef):
        if fdef.func_type.is(FuncType.ExtFunc) { return }
        if fdef.func_type.is(FuncType.ExtProc) { return }
        if fdef.func_type.is(FuncType.CoreFunc) { return }
        if fdef.func_type.is(FuncType.CoreProc) { return }
        if fdef.func_type.is(FuncType.CoreLazyFunc) { return }
        for param : Declaration in fdef.params {
            if param.name.len() == 0 { continue }
            if param.name.starts_with("_") { continue }
            ref pb : TypeBinding = func_scope.get_binding(param.name)
            if pb.is_null() { continue }
            if pb.used.not() {
                expr.type_error(format("unused parameter '", param.name, "'"), ctx)
            }
        }
    case:
        UNREACHABLE()
    }
}

// #164 step 2: a `mut` parameter that the body never writes through
// (no `param = ...`, no `param.f = ...`, never passed as the mut/own
// argument of another callee) is a redundant qualifier. Same `written`
// tracking as check_unused_mut_locals, but iterates the FuncDef's own
// params (locals are skipped via is_param in the step-1 check, so the
// two passes don't overlap). Called once per function -- params live on
// the func_scope only, not on the if/while/block inner scopes.
priv check_unused_mut_params := proc(func_scope: TypeScope, expr: Expr, path: Str, ctx: Context) {
    switch expr.node_type {
    case NodeType.FuncDef(fdef):
        if fdef.func_type.is(FuncType.ExtFunc) { return }
        if fdef.func_type.is(FuncType.ExtProc) { return }
        if fdef.func_type.is(FuncType.CoreFunc) { return }
        if fdef.func_type.is(FuncType.CoreProc) { return }
        if fdef.func_type.is(FuncType.CoreLazyFunc) { return }
        // Auto-generated bodies (clone/delete/size/enum eq/to_str/...) are
        // typer-emitted; the user cannot edit their signatures, so a
        // redundant `mut` there is not actionable.
        if fdef.auto_generated { return }
        for param : Declaration in fdef.params {
            if param.is_mut.not() { continue }
            if param.name.len() == 0 { continue }
            if param.name.starts_with("_") { continue }
            ref pb : TypeBinding = func_scope.get_binding(param.name)
            if pb.is_null() { continue }
            if pb.written { continue }
            type_error_at(path, pb.line, pb.col,
                format("redundant 'mut' on parameter '", param.name, "': never written through; drop the 'mut'"), ctx)
        }
    case:
        UNREACHABLE()
    }
}

check_unused_locals := proc(scope: TypeScope, path: Str, ctx: Context) {
    for b in scope.bindings.values {
        if b.is_param { continue }
        if b.is_builtin { continue }
        if b.is_type_alias { continue }
        if scope.struct_def_of(b.name).is_null().not() { continue }
        if scope.lookup_func(b.name).is_null().not() { continue }
        if b.name.len() == 0 { continue }
        if b.name.starts_with("_") { continue }
        // Hoist temps are compiler-internal and always have their use
        // substituted into the AST after typing, so `b.used` is never
        // flipped by the regular Ident-lookup path. Body DCE catches
        // any of these that go dead after constfolder; the typer's job
        // here is just to report user bugs.
        if b.name.starts_with("hoisted__") { continue }
        if ctx.throw_used_local_names.has(b.name) { continue }
        if b.used { continue }
        type_error_at(path, b.line, b.col, format("unused variable '", b.name, "'"), ctx)
    }
}

// #164: a `mut` local that is never written through (no `name = ...`,
// no `name.f = ...`) is a redundant qualifier -- the `mut` is a small
// lie about the local's effective shape. Flag it. Scoped to locals only
// for now (params are excluded: chain-walker cursors that take a `mut`
// param and only rebind it via `param = param.next` are still legal
// under the current language because `ref mut x : T = src` rejects
// immutable sources -- dropping the `mut` would require the language
// to distinguish "rebindable local pointer" from "write-through ref
// mut"; tracked separately on #164).
check_unused_mut_locals := proc(scope: TypeScope, path: Str, ctx: Context) {
    for b in scope.bindings.values {
        if b.is_param { continue }
        if b.is_builtin { continue }
        if b.is_type_alias { continue }
        if scope.struct_def_of(b.name).is_null().not() { continue }
        if scope.lookup_func(b.name).is_null().not() { continue }
        if b.name.len() == 0 { continue }
        if b.name.starts_with("_") { continue }
        if b.name.starts_with("hoisted__") { continue }
        // Payload-alias bindings (`case V(p):`) are typer-synthesized; the
        // user did not lexically write `mut` on `p`. Skip them so writes to
        // the source via `p = ...` (handled elsewhere) are the only signal.
        if b.is_alias { continue }
        if b.mut_explicit.not() { continue }
        if b.written { continue }
        type_error_at(path, b.line, b.col,
            format("redundant 'mut' on local '", b.name, "': never written through; drop the 'mut'"), ctx)
    }
}

// Issue #187 step 1: top-level priv items (funcs, structs, enums,
// globals) are file-local by construction. If nothing in the
// declaring file references one, it is dead code -- no importer can
// possibly reach it. Flag and suggest removing 'priv' to expose it.
// Returns the number of errors emitted so the loader can fold the
// count into its overall type_errors total.
check_unused_priv_top_level := proc(scope: TypeScope, ctx: Context) returns I32 {
    mut found : I32 = 0
    for b in scope.bindings.values {
        if b.is_priv.not() { continue }
        if b.is_builtin { continue }
        if b.used { continue }
        if b.name.len() == 0 { continue }
        if b.name.starts_with("_") { continue }
        mut kind := "value"
        if scope.lookup_func(b.name).is_null().not() { kind = "func" }
        ref b_sd : Expr = scope.struct_def_of(b.name)
        if b_sd.is_null().not() {
            if b_sd.node_type.is(NodeType.EnumDef) { kind = "enum" }
            else { kind = "struct" }
        }
        // Two flavors of mangled priv names land here:
        //   * top-level `priv X` rewritten by init_declarations_unit to
        //     `priv__<path>__<orig>` (b.name has the "priv__" prefix).
        //     Report it as a top-level priv with the original identifier.
        //   * Issue #93 nested defs hoisted out of a function body, named
        //     `<parent>_<orig>` (no "priv__" prefix). Report parent +
        //     local in source terms.
        if b.name.starts_with("priv__").and(b.orig_name.len().gt(0)) {
            type_error_at(b.path, b.line, b.col,
                format("unused priv ", kind, " '", b.orig_name, "'; remove 'priv' to expose it"), ctx)
            found++
            continue
        }
        if b.orig_name.len() > 0 {
            mangled_len := b.name.len()
            orig_len := b.orig_name.len()
            parent_len := mangled_len.sub(orig_len) - 1
            parent_name := b.name.substr(0, parent_len)
            type_error_at(b.path, b.line, b.col,
                format("unused local ", kind, " '", b.orig_name, "' in '", parent_name, "'; remove it or move it to file scope"), ctx)
            found++
            continue
        }
        type_error_at(b.path, b.line, b.col,
            format("unused priv ", kind, " '", b.name, "'; remove 'priv' to expose it"), ctx)
        found++
    }
    return found
}

// #187 steps 2-3: priv struct fields and namespace methods that no
// code in the struct's own namespace ever reads. The typer marks
// fields/ns_decls used on every successful access (gated on
// auto_gen_depth == 0 so boilerplate clone/delete don't mask
// unused decls). After type_check, walk every struct/enum decl in
// each ImportUnit and flag the leftovers.
check_unused_priv_members_in_program := proc(program: Expr, path: Str, ctx: Context) returns I32 {
    mut found : I32 = 0
    for stmt : Expr in program.children {
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        if stmt.children.len() == 0 { continue }
        ref tdef : Expr = stmt.children[0]
        if tdef.node_type.is(NodeType.StructDef).not()
            .and(tdef.node_type.is(NodeType.EnumDef).not()) { continue }
        mut owner_name := ""
        switch stmt.node_type {
        case NodeType.Decl(td_decl):
            owner_name = td_decl.name.clone()
        case:
            UNREACHABLE()
        }
        // Field walk (StructDef only). Report at the field's
        // default_value location (every field has one -- the parser
        // requires `name := value` or `name : Type = value`) so the
        // diagnostic points at the dead member, not the enclosing
        // struct. Fall back to tdef location for compiler-generated
        // decls that may carry the NoDefaultArg sentinel.
        switch tdef.node_type {
        case NodeType.StructDef(walk_sdd):
            for fld : Declaration in walk_sdd.fields {
                if fld.is_priv.not() { continue }
                if fld.used { continue }
                if fld.name.len() == 0 { continue }
                if fld.name.starts_with("_") { continue }
                mut fl_line : U32 = tdef.line
                mut fl_col : U32 = tdef.col
                if fld.default_value.is_null().not()
                    .and(fld.default_value.node_type.is(NodeType.NoDefaultArg).not()) {
                    fl_line = fld.default_value.line
                    fl_col = fld.default_value.col
                }
                type_error_at(path, fl_line, fl_col,
                    format("unused priv field '", owner_name, ".", fld.name, "'; remove 'priv' to expose it"), ctx)
                found++
            }
        case:
        }
        // Namespace walk (both StructDef and EnumDef). Same
        // default_value-location strategy as fields.
        ref ns : Vec(Declaration) = def_ns_decls(tdef)
        for nsd : Declaration in ns {
            if nsd.is_priv.not() { continue }
            if nsd.used { continue }
            if nsd.name.len() == 0 { continue }
            if nsd.name.starts_with("_") { continue }
            mut ns_line : U32 = tdef.line
            mut ns_col : U32 = tdef.col
            if nsd.default_value.is_null().not()
                .and(nsd.default_value.node_type.is(NodeType.NoDefaultArg).not()) {
                ns_line = nsd.default_value.line
                ns_col = nsd.default_value.col
            }
            type_error_at(path, ns_line, ns_col,
                format("unused priv ns member '", owner_name, ".", nsd.name, "'; remove 'priv' to expose it"), ctx)
            found++
        }
    }
    return found
}



// Narrow a bare numeric literal return value to the function's declared
// numeric return type, mirroring validate_fcall_arg for call arguments.
// Fires for a direct Literal.Num return expression (including negative
// literals like -1, which the parser now produces as a single literal);
// any other expression is left as-is.
priv narrow_return_literal := proc(scope: TypeScope, mut rv: Expr, ctx: Context) {
    if ctx.typer_return_type_name.len() == 0 { return }
    rt := type_from_name(ctx.typer_return_type_name, scope, ctx)
    if is_numeric_type(rt).not() { return }
    switch rv.node_type {
    case NodeType.Literal(Literal.Num(lit_str)):
        if literal_in_range(lit_str.literal_num_text(), rt).not() {
            rv.type_error(format("integer literal ", lit_str.literal_num_text(), " out of range for ", type_to_name(rt)), ctx)
        }
        rv.set_til_type(rt)
    case:
    }
}

// #251 follow-up: box a conforming concrete RETURNED where an interface is
// declared, with OWNED semantics. The box escapes the function, so a borrow
// (to_ptr, as args/locals use) would dangle once the concrete's frame is gone;
// instead iface_val holds a heap deep-copy via dyn_call_ret(.., "clone", ..)
// and iface_owned = true, so the box's delete frees that copy (see
// gen_interface_clone_delete_for_stmt). The raw return value is snapshotted
// BEFORE infer_expr desugars a struct ctor's named args to positional, since
// the box re-infers that snapshot and a desugared ctor would fail the
// named-arg requirement. The snapshot is moved into the box, or reclaimed by
// the garbager when the value is already the interface / not conforming.
// #251 follow-up: build an OWNED interface box wrapping `value` (a conforming
// concrete of type `concrete_name`) as interface `iface_name`:
//   <Iface>(iface_type_name = "<Concrete>",
//           iface_val = dyn_call_ret("<Concrete>", "clone", 1, value),
//           iface_owned = true)
// iface_val is a heap deep-copy (dyn_call_<method> mallocs shallow returns),
// so the box owns it and its delete frees it (gen_interface_clone_delete_for_stmt).
// Used at every ESCAPING coercion site (returns, fields, ...). `value` is
// passed to clone directly, NOT to_ptr(value): the C backend addresses it via
// emit_as_ptr and the interpreter binds a value to clone's ref self
// correctly, whereas a raw pointer yields a garbage self for enum receivers.
// The caller must pass a `value` snapshotted BEFORE inference desugared a
// struct ctor's named args, since the returned box gets re-inferred.
priv make_owned_iface_box := func(iface_name: Str, concrete_name: Str, own value: Expr, line: U32, col: U32) returns Expr {
    mut box := Expr.new(NodeType.FCall(FCallData()), line, col)
    box.add_child(own Expr.new(ident_node(iface_name), line, col))
    mut na_tag := Expr.new(NodeType.NamedArg("iface_type_name"), line, col)
    na_tag.add_child(own Expr.new(NodeType.Literal(Literal.Str(concrete_name.clone())), line, col))
    box.add_child(own na_tag)
    mut na_val := Expr.new(NodeType.NamedArg("iface_val"), line, col)
    mut clone_call := Expr.new(NodeType.FCall(FCallData()), line, col)
    clone_call.add_child(own Expr.new(ident_node("dyn_call_ret"), line, col))
    clone_call.add_child(own Expr.new(NodeType.Literal(Literal.Str(concrete_name.clone())), line, col))
    clone_call.add_child(own Expr.new(NodeType.Literal(Literal.Str("clone")), line, col))
    clone_call.add_child(own Expr.new(NodeType.Literal(Literal.Num(LiteralNumData(text = "1"))), line, col))
    clone_call.add_child(own value)
    na_val.add_child(own clone_call)
    box.add_child(own na_val)
    mut na_owned := Expr.new(NodeType.NamedArg("iface_owned"), line, col)
    na_owned.add_child(own Expr.new(NodeType.Literal(Literal.Bool(true)), line, col))
    box.add_child(own na_owned)
    return box
}

priv box_return_value := proc(scope: TypeScope, mut stmt: Expr, in_func: I32, ctx: Context) {
    iface_name := ctx.typer_return_type_name.clone()
    mut raw_val := stmt.children[0].clone()
    infer_expr(scope, stmt.children[0], in_func, ctx)
    narrow_return_literal(scope, stmt.children[0], ctx)
    rbox_cname := til_type_name(stmt.children[0].til_type())
    if rbox_cname.len().gt(0).and(rbox_cname.eq(iface_name).not()).and(type_implements_iface(rbox_cname, iface_name, scope)) {
        mut box := make_owned_iface_box(iface_name, rbox_cname, own raw_val, stmt.children[0].line, stmt.children[0].col)
        stmt.children[0] = box
        infer_expr(scope, stmt.children[0], in_func, ctx)
    }
}

// #282 follow-up: true when `e` is an FCall carrying an injected `_err_kind`
// out-arg -- i.e. the pre-infer throw pass lowered it as a throwing (`?`/`!`)
// call. Used to limit the ref-returning-return check to throwing calls (whose
// result is null on the throw path), so a plain non-throwing ref-returning
// call returned by value is left alone.
priv fcall_has_injected_err_arg := func(e: Expr) returns Bool {
    if e.node_type.is(NodeType.FCall).not() { return false }
    for c : Expr in e.children {
        switch c.node_type {
        case NodeType.Ident(idn):
            if idn.ident_name() == "_err_kind" { return true }
        case:
        }
    }
    return false
}

priv infer_return_stmt := proc(scope: TypeScope, mut stmt: Expr, in_func: I32, returns_ref: I32, ctx: Context) {    if stmt.children.len() > 0 {
        // #251 follow-up: a conforming concrete RETURNED where an interface is
        // declared coerces to an OWNED box (box_return_value). Done in a
        // helper because it must snapshot the raw value BEFORE inference
        // desugars a struct ctor's named args. Non-interface returns infer
        // normally and pay nothing.
        if ctx.typer_return_type_name.len().gt(0).and(name_is_interface(ctx.typer_return_type_name, scope)) {
            box_return_value(scope, stmt, in_func, ctx)
        } else {
            infer_expr(scope, stmt.children[0], in_func, ctx)
            narrow_return_literal(scope, stmt.children[0], ctx)
        }
        stmt.set_til_type(stmt.children[0].til_type())
        if returns_ref == 0 {
            // #282 follow-up: a by-value `return v.get(i)?` (ref-returning,
            // THROWING call) compiled, then DEREF'd a null ref on the throw
            // path ("panic: null deref"). The Decl form (`x := v.get(i)?`) and
            // the bang form (`return v.get(i)!`, via its hoisted temp Decl)
            // already reject this with "cannot own result of ref-returning
            // function"; the `?` return slipped past. Reject it the same way.
            // Gate on the injected `_err_kind` out-arg so this fires ONLY for a
            // lowered throwing call -- a plain non-throwing ref-returning call
            // (`return deref(p)`) always yields a valid ref and is fine to
            // return by value. Use `returns ref T` or `.clone()` instead.
            ref ret_val : Expr = stmt.children[0]
            if ret_val.node_type.is(NodeType.FCall)
                .and(fcall_returns_ref(ret_val, scope).neq(0))
                .and(fcall_has_injected_err_arg(ret_val)) {
                stmt.type_error("cannot own result of ref-returning function; use 'ref' or Type.clone()", ctx)
            }
            switch stmt.children[0].node_type {
            case NodeType.Ident(rn):
                sf := scope.find(rn.ident_name())
                switch sf {
                case ScopeFind.Found(b):
                    if b.own_type.is(OwnType.Ref).and(b.is_alias.not()).and(b.is_param.not()) {
                        stmt.type_error("cannot return ref variable from non-ref function; use .clone() or 'returns ref'", ctx)
                    }
                        if b.own_type.is(OwnType.Ref).and(b.is_alias).or(b.is_param.and(b.own_type.is(OwnType.Own).not())) {
                            tname := type_to_name(stmt.til_type())
                            // Issue #58 / #147 step 5: FuncPtr/FuncPtrSig has no T_clone.
                            if tname.len().gt(0).and(stmt.til_type().is_funcptr().not()).and(stmt.til_type().is(Type.Body).not()) {
                                mc := make_clone_call(tname, stmt.til_type(), stmt.children[0], stmt)
                                stmt.children[0] = mc
                            }
                        }
                case:
                }
            case:
            }
        } else {
            // #168 step 5: a ref-typed function cannot return an owned value
            // -- the heap allocation has nowhere to live in the caller.
            ref ret_expr : Expr = stmt.children[0]
            if ret_expr.node_type.is(NodeType.FCall).and(fcall_returns_own(ret_expr, scope)) {
                stmt.type_error("ref-typed function cannot return an owned value (.clone() / constructor / function returning own) -- return a borrow source directly, or change the signature to return owned", ctx)
            }
        }
    } else {
        stmt.set_til_type(Type.None)
    }
}

priv infer_if_stmt := proc(scope: TypeScope, mut stmt: Expr, in_func: I32, in_loop: I32, returns_ref: I32, ctx: Context) {
    infer_expr(scope, stmt.children[0], in_func, ctx)
    if_cond_t := stmt.children[0].til_type()
    if type_is_primitive(if_cond_t, Primitive.Bool).not().and(if_cond_t.is(Type.Unknown).not()) {
        stmt.type_error("if condition must be Bool", ctx)
    }
    then_scope := TypeScope(parent = scope)
    infer_body(then_scope, stmt.children[1], in_func, 1, in_loop, returns_ref, 0, ctx)
    garbager_destroy_body(ctx, stmt.children[1], then_scope)
    check_unused_locals(then_scope, ctx.path, ctx)
    check_unused_mut_locals(then_scope, ctx.path, ctx)
    if stmt.children.len() > 2 {
        else_scope := TypeScope(parent = scope)
        infer_body(else_scope, stmt.children[2], in_func, 1, in_loop, returns_ref, 0, ctx)
        garbager_destroy_body(ctx, stmt.children[2], else_scope)
        check_unused_locals(else_scope, ctx.path, ctx)
        check_unused_mut_locals(else_scope, ctx.path, ctx)
    }
    stmt.set_til_type(Type.None)
}

// Issue #297: a FieldAccess receiver that is a bare type alias (USize,
// UPtr, or a user `Foo := U8`) names a namespace through the alias. The
// alias has no struct def of its own, so resolve it to the target type and
// rewrite the receiver Ident to the target name (mirroring the method-call
// callee path, which is why `USize.size()` already resolves). Rewriting the
// name -- not just the til_type -- is what every downstream consumer needs:
// the scavenger's usage marking and the interpreter's ns lookup both key on
// the Ident name, while the builder reads the til_type; setting both keeps
// them in agreement so the `<Type>_<NAME>` global is emitted and not pruned.
priv resolve_fa_receiver_alias := func(scope: TypeScope, mut obj: Expr) {
    switch obj.node_type {
    case NodeType.Ident(rid):
        ref resolved : Str = resolve_type_alias(scope, rid.ident_name())
        if resolved.eq(rid.ident_name()).not() {
            if scope.get_struct(resolved).is_null().not() {
                obj.node_type = ident_node(resolved)
                obj.set_til_type(Type.Struct(resolved.clone()))
            }
        }
    case:
    }
}

priv infer_field_access_expr := proc(scope: TypeScope, mut expr: Expr, in_func: I32, ctx: Context) {
    infer_expr(scope, expr.children[0], in_func, ctx)
    resolve_fa_receiver_alias(scope, expr.children[0])
    mut obj_sname := til_type_name(expr.children[0].til_type())
    // #307: an Ident receiver whose binding is a non-type (e.g. a sibling
    // namespace member such as a variant ctor named like a global enum)
    // types nameless, but a field access needs a type. Apply get_struct's
    // fall-through rule (#147): a non-type binding does not block
    // resolving the same-named TYPE in receiver position.
    if obj_sname.len() == 0 {
        switch expr.children[0].node_type {
        case NodeType.Ident(fa_rid):
            ref fa_tdef : Expr = scope.get_struct(fa_rid.ident_name())
            if fa_tdef.is_null().not() {
                obj_sname = Str.clone(fa_rid.ident_name())
                if fa_tdef.node_type.is(NodeType.EnumDef) {
                    expr.children[0].set_til_type(Type.Enum(obj_sname.clone()))
                } else {
                    expr.children[0].set_til_type(Type.Struct(obj_sname.clone()))
                }
            }
        case:
        }
    }
    if obj_sname.len() > 0 {
        ref sdef : Expr = scope.get_struct(obj_sname)
        if sdef.is_null().not() {
            // #154: reading a member of a cross-file type uses its import.
            note_cross_file_type_use(scope, ctx, obj_sname)
            mut fname := ""
            switch expr.node_type {
            case NodeType.FieldAccess(fn):
                fname = Str.clone(fn.field_access_name())
            case:
                UNREACHABLE()
                return
            }
            mut found := false
            // Search struct fields from payload
            switch sdef.node_type {
            case NodeType.StructDef(fa_sdd):
                for fld : Declaration in fa_sdd.fields {
                    if fld.name == fname {
                        mut field_type := fld.til_type.clone()
                        if fld.explicit_type.len() > 0 {
                            resolved_field_type := type_from_name(fld.explicit_type, scope, ctx)
                            if resolved_field_type.is(Type.Unknown).not() {
                                field_type = resolved_field_type
                            }
                        }
                        expr.set_til_type(field_type)
                        check_member_priv(expr, obj_sname, fname, fld.is_priv, ctx)
                        if ctx.auto_gen_depth == 0 { fld.used = true }
                        found = true
                        break
                    }
                }
            case:
            }
            // Search namespace declarations from payload ns_decls
            if found.not() {
                ref fa_ns : Vec(Declaration) = def_ns_decls(sdef)
                for nsd : Declaration in fa_ns {
                    if nsd.name == fname {
                        expr.set_til_type(nsd.til_type.clone())
                        if sdef.node_type.is(NodeType.EnumDef).and(nsd.default_value.is_null().not()) {
                            switch nsd.default_value.node_type {
                            case NodeType.FuncDef(fd):
                                if fd.func_type.is(FuncType.ExtFunc).and(fd.return_type.len().gt(0)).and(fd.return_type.eq(obj_sname)) {
                                    expr.set_til_type(Type.Enum(obj_sname.clone()))
                                }
                            case:
                                expr.set_til_type(Type.Enum(obj_sname.clone()))
                            }
                        }
                        check_member_priv(expr, obj_sname, fname, nsd.is_priv, ctx)
                        if ctx.auto_gen_depth == 0 { nsd.used = true }
                        found = true
                        break
                    }
                }
            }
            if found.not() {
                mut kind := "struct"
                if sdef.node_type.is(NodeType.EnumDef) { kind = "enum" }
                expr.type_error(format(kind, " '", obj_sname, "' has no field '", fname, "'"), ctx)
                expr.set_til_type(Type.Unknown)
            }
        }
    } else {
        expr.type_error("field access on non-struct value", ctx)
        expr.set_til_type(Type.Unknown)
    }
}

// #164: walk a FieldAssign's LHS chain (`a.b.c = ...`) down to the root
// Ident and mark its binding as written, so the unused-mut check
// recognises that `a` was effectively mutated.
priv mark_field_assign_root_written := func(scope: TypeScope, obj: Expr) {
    switch obj.node_type {
    case NodeType.Ident(root_id):
        ref mut rb : TypeBinding = scope.get_binding(root_id.ident_name())
        if rb.is_null().not() { rb.written = true }
    case NodeType.FieldAccess:
        if obj.children.len() > 0 {
            mark_field_assign_root_written(scope, obj.children[0])
        }
    case:
    }
}

priv infer_field_assign_stmt := proc(scope: TypeScope, mut stmt: Expr, in_func: I32, ctx: Context) {
    infer_expr(scope, stmt.children[0], in_func, ctx)
    infer_expr(scope, stmt.children[1], in_func, ctx)
    ref obj : Expr = stmt.children[0]
    ref mut rhs : Expr = stmt.children[1]
    mut fname := ""
    switch stmt.node_type {
    case NodeType.FieldAssign(fad):
        fname = fad.name.clone()
    case:
        UNREACHABLE()
        return
    }
    // #164: walk to the root identifier of the obj chain and mark it
    // written. `a.b.c = ...` writes the root `a` (transitively).
    mark_field_assign_root_written(scope, obj)
    obj_sname := til_type_name(obj.til_type())
    if obj_sname.len() > 0 {
        ref sdef : Expr = scope.get_struct(obj_sname)
        if sdef.is_null().not() {
            // #154: writing a member of a cross-file type uses its import.
            note_cross_file_type_use(scope, ctx, obj_sname)
            mut found := false
            switch sdef.node_type {
            case NodeType.StructDef(fa_sdd):
                for fld : Declaration in fa_sdd.fields {
                    if fld.name == fname {
                        found = true
                        check_member_priv(stmt, obj_sname, fname, fld.is_priv, ctx)
                        if ctx.auto_gen_depth == 0 { fld.used = true }
                        if fld.is_mut.not() {
                            stmt.type_error(format("cannot assign to const field '", fname, "'; remove the 'const' keyword from its declaration to make it mutable"), ctx)
                        }
                        if fld.own_type.is(OwnType.Ref) {
                            check_ref_assign_owned_rhs(stmt, fname, rhs, scope, ctx)
                        }
                        // Resolve the declared type from explicit_type when
                        // set, like the field-ACCESS path does: a
                        // template-synthesized struct's cloned decls carry
                        // til_type Unknown, and comparing against that
                        // misreported every assign as a type mismatch.
                        mut fld_type := fld.til_type.clone()
                        if fld.explicit_type.len() > 0 {
                            resolved_fld_type := type_from_name(fld.explicit_type, scope, ctx)
                            if resolved_fld_type.is(Type.Unknown).not() {
                                fld_type = resolved_fld_type
                            }
                        }
                        mut handled_lit := false
                        switch rhs.node_type {
                        case NodeType.Literal(Literal.Num(lit_str)):
                            if is_numeric_type(fld_type) {
                                if literal_in_range(lit_str.literal_num_text(), fld_type).not() {
                                    rhs.type_error(format("integer literal out of range for field '", fname, "'"), ctx)
                                }
                                rhs.set_til_type(fld_type.clone())
                                handled_lit = true
                            }
                        case:
                        }
                        if handled_lit.not() {
                            rhs_type := rhs.til_type()
                            // Issue #58 / #147 step 5: FuncPtr/FuncPtrSig
                            // wildcard-aware family-equality.
                            if rhs_type.is(fld_type).not().and(funcptr_eq(rhs_type, fld_type).not()) {
                                if rhs_type.is(Type.Unknown).not() {
                                    if rhs_type.is(Type.Dynamic).not() {
                                        stmt.type_error(format("field '", fname, "' type mismatch"), ctx)
                                    }
                                }
                            }
                        }
                        break
                    }
                }
            case:
            }
            // Search namespace declarations from payload ns_decls
            if found.not() {
                ref fa_ns : Vec(Declaration) = def_ns_decls(sdef)
                for nsd : Declaration in fa_ns {
                    if nsd.name == fname {
                        found = true
                        if nsd.is_mut.not() {
                            stmt.type_error(format("cannot assign to immutable field '", fname, "'"), ctx)
                        }
                        // Same explicit_type fallback as the struct-field
                        // branch above (template-synthesized clones carry
                        // til_type Unknown).
                        mut nsd_type := nsd.til_type.clone()
                        if nsd.explicit_type.len() > 0 {
                            resolved_nsd_type := type_from_name(nsd.explicit_type, scope, ctx)
                            if resolved_nsd_type.is(Type.Unknown).not() {
                                nsd_type = resolved_nsd_type
                            }
                        }
                        mut handled_lit2 := false
                        switch rhs.node_type {
                        case NodeType.Literal(Literal.Num(lit_str)):
                            if is_numeric_type(nsd_type) {
                                if literal_in_range(lit_str.literal_num_text(), nsd_type).not() {
                                    rhs.type_error(format("integer literal out of range for field '", fname, "'"), ctx)
                                }
                                rhs.set_til_type(nsd_type.clone())
                                handled_lit2 = true
                            }
                        case:
                        }
                        if handled_lit2.not() {
                            rhs_type := rhs.til_type()
                            if rhs_type.is(nsd_type).not().and(funcptr_eq(rhs_type, nsd_type).not()) {
                                if rhs_type.is(Type.Unknown).not() {
                                    if rhs_type.is(Type.Dynamic).not() {
                                        stmt.type_error(format("field '", fname, "' type mismatch"), ctx)
                                    }
                                }
                            }
                        }
                        break
                    }
                }
            }
            if found.not() {
                stmt.type_error(format("struct '", obj_sname, "' has no field '", fname, "'"), ctx)
            }
        }
    } else {
        stmt.type_error("field assignment on non-struct value", ctx)
    }
    stmt.set_til_type(Type.None)
    if stmt.fa_own_type(scope).is(OwnType.Ref).not().and(
        rhs.node_type.is(NodeType.Ident).or(
            rhs.node_type.is(NodeType.FieldAccess).and(is_aggregate(rhs.til_type()))
        )
    ) {
        tname := type_to_name(rhs.til_type())
        // Issue #58 / #147 step 5: FuncPtr/FuncPtrSig has no T_clone.
        if tname.len().gt(0).and(rhs.til_type().is_funcptr().not()).and(rhs.til_type().is(Type.Body).not()) {
            mc := make_clone_call(tname, rhs.til_type(), rhs, rhs)
            stmt.children[1] = mc
        }
    }
}

priv infer_while_stmt := proc(scope: TypeScope, mut stmt: Expr, in_func: I32, returns_ref: I32, ctx: Context) {
    infer_expr(scope, stmt.children[0], in_func, ctx)
    while_cond_t := stmt.children[0].til_type()
    if type_is_primitive(while_cond_t, Primitive.Bool).not().and(while_cond_t.is(Type.Unknown).not()) {
        stmt.type_error(format("while condition must be Bool, got ", type_to_name(stmt.children[0].til_type())), ctx)
    }
    ref while_cond : Expr = stmt.children[0]
    if expr_contains_fcall(while_cond).or(stmt_contains_match(while_cond)) {
        ref cond : Expr = stmt.children[0]
        line := cond.line
        col := cond.col
        ref body : Expr = stmt.children[1]
        wname := format("_wcond_Bool_", ctx.hoist_counter.to_str())
        ctx.hoist_counter++

        mut decl := Expr.new(NodeType.Decl(Declaration(name = wname.clone())), line, col)
        decl.set_til_type(Type.Primitive(Primitive.Bool))
        decl.add_child(own cond.clone())
        decl.children[0].set_til_type(Type.Primitive(Primitive.Bool))

        mut ident := Expr.new(ident_node(wname), line, col)
        ident.set_til_type(Type.Primitive(Primitive.Bool))

        mut if_node := Expr.new(NodeType.If, line, col)
        if_node.set_til_type(Type.None)
        if_node.add_child(own ident)

        mut then_body := Expr.new(NodeType.Body, line, col)
        then_body.set_til_type(Type.None)
        if_node.add_child(own then_body)

        mut else_body := Expr.new(NodeType.Body, line, col)
        else_body.set_til_type(Type.None)
        mut brk := Expr.new(NodeType.Break, line, col)
        brk.set_til_type(Type.None)
        else_body.add_child(own brk)
        if_node.add_child(own else_body)

        mut true_lit := Expr.new(NodeType.Literal(Literal.Bool(true)), line, col)
        stmt.children[0] = true_lit

        mut old := Vec(Expr).new()
        old.move_from(body.children)

        // Exact final size: decl + if_node + old stmts.
        mut new_ch := Vec(Expr).with_capacity(old.len() + 2)
        new_ch.push(own decl)
        new_ch.push(own if_node)
        for j in 0..old.len() {
            new_ch.push_take(old, j)
        }
        body.children.move_from(new_ch)
    }
    while_scope := TypeScope(parent = scope)
    infer_body(while_scope, stmt.children[1], in_func, 1, 1, returns_ref, 0, ctx)
    garbager_destroy_body(ctx, stmt.children[1], while_scope)
    check_unused_locals(while_scope, ctx.path, ctx)
    check_unused_mut_locals(while_scope, ctx.path, ctx)
    stmt.set_til_type(Type.None)
}

priv infer_decl_type_def := proc(scope: TypeScope, mut stmt: Expr, ctx: Context) returns Bool {
    if is_struct_or_enum(stmt).not() { return false }
    is_enum := stmt.children[0].node_type.is(NodeType.EnumDef)
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        if sdecl.explicit_type.len() > 0 {
            declared := type_from_name(sdecl.explicit_type, scope, ctx)
            mut expected := Type.Struct("StructDef")
            if is_enum { expected = Type.Struct("EnumDef") }
            if declared.eq(expected).not() {
                mut value_type := "StructDef"
                if is_enum { value_type = "EnumDef" }
                stmt.type_error(format("'", sdecl.name, "' declared as ", sdecl.explicit_type, " but value is ", value_type), ctx)
            }
        }
        stmt.set_til_type(Type.None)
        ref sname : Str = sdecl.name
        ref existing : TypeBinding = scope.get_binding(sname)
        if existing.is_null().not() {
            ref existing_sd : Expr = scope.struct_def_of(existing.name)
            if existing_sd.is_null().not() {
                ref type_expr : Expr = stmt.children[0]
                if existing_sd.line.neq(type_expr.line).or(
                    existing_sd.col.neq(type_expr.col).or(
                        existing.path.eq(ctx.path).not()
                    )
                ) {
                    mut kind := "struct"
                    if is_enum { kind = "enum" }
                    stmt.type_error(format(kind, " '", sname, "' already declared at ", existing.path, ":", existing.line.to_str(), ":", existing.col.to_str()), ctx)
                    return true
                }
            }
        }
        mut builtin_type := Type.Struct(sname.clone())
        mut is_builtin := false
        if is_enum {
            builtin_type = Type.Enum(sname.clone())
        } else {
            mut prim : Primitive = Primitive.I64
            if builtin_primitive_from_name(sname, prim) {
                builtin_type = Type.Primitive(prim)
                is_builtin = true
            } else if sname == "Dynamic" {
                builtin_type = Type.Dynamic
                is_builtin = true
            }
        }
        scope.set(sname, builtin_type, false, ctx.path, stmt.line, stmt.col, false, OwnType.Shallow)
        scope.set_struct_def(sname, stmt.children[0])
        ref mut b : TypeBinding = scope.get_binding(sname)
        b.is_builtin = is_builtin
        b.is_priv = sdecl.is_priv
        b.orig_name = sdecl.orig_name.clone()
        return true
    case:
        UNREACHABLE()
        return false
    }
}

priv infer_decl_func_def := proc(scope: TypeScope, mut stmt: Expr, ctx: Context) returns Bool {
    if is_func_decl(stmt).not() { return false }
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        switch stmt.children[0].node_type {
        case NodeType.FuncDef(rhs_fd0):
            if rhs_fd0.captures.len() > 0 { return false }
        case:
        }
        if sdecl.explicit_type.len() > 0 {
            declared_t := type_from_name(sdecl.explicit_type, scope, ctx)
            if declared_t.is_funcptr() {
                switch stmt.children[0].node_type {
                case NodeType.FuncDef(rhs_fd):
                    if rhs_fd.captures.len() > 0 { return false }
                case:
                }
            }
        }
        // Issue #58: the metatype name from rstil's first_class.org is
        // ~FuncDef~; til's internal name is ~FunctionDef~ (the data
        // struct in src/core/ast.til). Accept both as the annotation
        // for a FuncDef value.
        annot_is_funcdef := sdecl.explicit_type.eq("FunctionDef").or(sdecl.explicit_type.eq("FuncDef"))
        if sdecl.explicit_type.len().gt(0).and(annot_is_funcdef.not()) {
            stmt.type_error(format("'", sdecl.name, "' declared as ", sdecl.explicit_type, " but value is FunctionDef"), ctx)
        }
        switch stmt.children[0].node_type {
        case NodeType.FuncDef(fdef):
            mut rt := Type.None
            if fdef.return_type.len() > 0 {
                ref resolved_return_type : Str = resolve_type_alias(scope, fdef.return_type)
                rt = type_from_name(resolved_return_type, scope, ctx)
            }
            stmt.set_til_type(rt)
            // Bodyless FuncDef is a FuncSig type-alias declaration:
            // bind the name to Type.FuncPtr so dyn_type_to_str and Vec.new
            // round-trip the name through Type.FuncPtr ("Fn") instead of
            // the function's return type. Issue #58.
            is_bodyless := stmt.children[0].children.len() == 0
            mut binding_type := rt
            if is_bodyless { binding_type = Type.FuncPtr }
            scope.set(sdecl.name, binding_type, false, ctx.path, stmt.line, stmt.col, false, OwnType.Shallow)
            scope.set_func_def(sdecl.name, stmt.children[0])
            ref mut fb : TypeBinding = scope.get_binding(sdecl.name)
            fb.is_func_decl = true
            fb.is_priv = sdecl.is_priv
            fb.orig_name = sdecl.orig_name.clone()
            if fdef.func_type.is(FuncType.ExtFunc).or(fdef.func_type.is(FuncType.ExtProc)).or(fdef.func_type.is(FuncType.CoreFunc)).or(fdef.func_type.is(FuncType.CoreProc)).or(fdef.func_type.is(FuncType.CoreLazyFunc)) {
                fb.is_builtin = true
            }
            return true
        case:
            UNREACHABLE()
            return false
        }
    case:
        UNREACHABLE()
        return false
    }
}

priv infer_decl_type_alias_passthrough := func(scope: TypeScope, mut stmt: Expr) returns Bool {
    if stmt.children[0].node_type.is(NodeType.Ident).not() { return false }
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        ref alias_b : TypeBinding = scope.get_binding(sdecl.name)
        if alias_b.is_null().not() {
            if alias_b.is_type_alias {
                stmt.set_til_type(Type.None)
                return true
            }
        }
        return false
    case:
        UNREACHABLE()
        return false
    }
}

priv declared_type_for_decl := func(scope: TypeScope, stmt: Expr, ctx: Context) returns Type {
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        mut declared := stmt.til_type()
        switch declared {
        case Type.Unknown:
            declared = type_from_name(sdecl.explicit_type, scope, ctx)
        case Type.Custom(cname):
            declared = type_from_name(cname, scope, ctx)
        case:
        }
        return declared
    case:
        UNREACHABLE()
        return Type.Unknown
    }
}

// Typed declarations can steer numeric method resolution (for example,
// `x : F32 = 1 / 2` -> `F32.div`), but explicit `to_*` conversions still need
// their literal receiver to keep the default numeric type so lookup lands on
// the source type's namespace.
priv pre_coerce_decl_numeric_literals := proc(mut expr: Expr, target: Type) {
    switch expr.node_type {
    case NodeType.Literal(Literal.Num):
        expr.set_til_type(target)
    case NodeType.FieldAccess(fname):
        for i in 0..expr.children.len() {
            if i.eq(0).and(fname.starts_with("to_")) { continue }
            pre_coerce_decl_numeric_literals(expr.children[i], target)
        }
    case:
        for c : Expr in expr.children {
            pre_coerce_decl_numeric_literals(c, target)
        }
    }
}

priv fcall_is_raw_alloc := func(e: Expr) returns Bool {
    if e.node_type.is(NodeType.FCall).not() { return false }
    if e.children.len() == 0 { return false }
    switch e.children[0].node_type {
    case NodeType.Ident(callee):
        ref name : Str = callee.ident_name()
        return name.eq("malloc").or(name.eq("calloc")).or(name.eq("realloc"))
    case:
        return false
    }
}

priv infer_decl_typed_value := proc(scope: TypeScope, mut stmt: Expr, in_func: I32, ctx: Context) {
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        mut declared := declared_type_for_decl(scope, stmt, ctx)
        // #179 follow-up: explicit type annotation on a Decl
        // (e.g. ~ref x : Foo = ...~) is a use of Foo's name from
        // declaration position. Check priv across files.
        check_priv_type_name(stmt, sdecl.explicit_type, scope, ctx)
        // #251 follow-up: a conforming concrete bound to an interface-typed
        // LOCAL coerces by BOXING, exactly like an interface-typed argument
        // (infer_and_validate_fcall_args). Done here -- before `val` is bound
        // below -- so the box (whose type is the interface, == declared) flows
        // through the rest of the checks without a type-mismatch error. The
        // box borrows the value via to_ptr, like the argument case: sound
        // while the source outlives the binding (same scope, reverse-order
        // teardown). Escaping sites (returns, fields, Vec elements) need an
        // OWNED box and remain a follow-up.
        if name_is_interface(sdecl.explicit_type, scope) {
            box_cname := til_type_name(stmt.children[0].til_type())
            if box_cname.len().gt(0).and(box_cname.eq(sdecl.explicit_type).not()).and(type_implements_iface(box_cname, sdecl.explicit_type, scope)) {
                box_line := stmt.children[0].line
                box_col := stmt.children[0].col
                mut iface_box := Expr.new(NodeType.FCall(FCallData()), box_line, box_col)
                iface_box.add_child(own Expr.new(ident_node(sdecl.explicit_type), box_line, box_col))
                mut na_tag := Expr.new(NodeType.NamedArg("iface_type_name"), box_line, box_col)
                na_tag.add_child(own Expr.new(NodeType.Literal(Literal.Str(box_cname.clone())), box_line, box_col))
                iface_box.add_child(own na_tag)
                mut na_val := Expr.new(NodeType.NamedArg("iface_val"), box_line, box_col)
                mut val_ptr := Expr.new(NodeType.FCall(FCallData()), box_line, box_col)
                val_ptr.add_child(own Expr.new(ident_node("to_ptr"), box_line, box_col))
                val_ptr.add_child(own stmt.children[0].clone())
                na_val.add_child(own val_ptr)
                iface_box.add_child(own na_val)
                stmt.children[0] = iface_box
                infer_expr(scope, stmt.children[0], in_func, ctx)
            }
        }
        ref mut val : Expr = stmt.children[0]
        switch val.til_type() {
        case Type.Custom(alias_name):
            ref resolved_alias_name : Str = resolve_type_alias(scope, alias_name)
            resolved_alias_type := type_from_name(resolved_alias_name, scope, ctx)
            if resolved_alias_type.is(Type.Unknown).not() {
                val.set_til_type(resolved_alias_type)
            }
        case:
        }
        if declared.is(Type.Unknown) {
            stmt.type_error(format("undefined type '", sdecl.explicit_type, "'"), ctx)
        } else if val.node_type.is_literal_num().and(is_numeric_type(declared).or(declared.is(Type.Dynamic))) {
            switch val.node_type {
            case NodeType.Literal(Literal.Num(lit_str)):
                if is_numeric_type(declared).and(literal_in_range(lit_str.literal_num_text(), declared).not()) {
                    val.type_error(format("integer literal ", lit_str.literal_num_text(), " out of range for ", type_to_name(declared)), ctx)
                }
            case:
            }
            val.set_til_type(declared)
        } else if val.node_type.is_literal_null().and(sdecl.own_type.is(OwnType.Ref).not()) {
            stmt.type_error("null can only be assigned to 'ref' declarations", ctx)
        } else if declared.is_funcptr().and(val.node_type.is(NodeType.FuncDef)) {
            switch val.node_type {
            case NodeType.FuncDef(vfd):
                if vfd.captures.len() > 0 {
                    val.set_til_type(declared.clone())
                } else {
                    stmt.type_error(format("'", sdecl.name, "' declared as ", type_to_name(declared), " but value is ", type_to_name(val.til_type())), ctx)
                }
            case:
            }
        } else if can_implicit_usize_coerce(val.til_type(), declared, sdecl.explicit_type).not()
        .and(val.til_type().is(declared).not())
        // Issue #58 / #147 step 5: FuncPtr/FuncPtrSig wildcard family-eq.
        .and(funcptr_eq(val.til_type(), declared).not())
        .and(val.til_type().is(Type.Dynamic).not())
    .and(declared.is(Type.Dynamic).not()) {
        stmt.type_error(format("'", sdecl.name, "' declared as ", type_to_name(declared), " but value is ", type_to_name(val.til_type())), ctx)
    } else if is_aggregate(declared) {
        val_sname := til_type_name(val.til_type())
        if val_sname.len().gt(0).and(resolve_type_alias(scope, sdecl.explicit_type).eq(val_sname).not()) {
            stmt.type_error(format("'", sdecl.name, "' declared as ", sdecl.explicit_type, " but value is ", val_sname), ctx)
        }
    }
    // Resolve type alias in declared til_type so that struct/enum names match
    // the canonical target (e.g. Point2 -> Point).
    if is_aggregate(declared) {
        ref resolved : Str = resolve_type_alias(scope, sdecl.explicit_type)
        if declared.is(Type.Struct) {
            declared = Type.Struct(resolved.clone())
        } else {
            declared = Type.Enum(resolved.clone())
        }
    }
    stmt.set_til_type(declared)
    if can_implicit_usize_coerce(val.til_type(), declared, sdecl.explicit_type) {
        val.set_til_type(declared)
    }
    narrow_dynamic(val, declared)
        if is_aggregate(declared) {
            if til_type_name(val.til_type()).len() > 0 {
                ref resolved : Str = resolve_type_alias(scope, sdecl.explicit_type)
                if declared.is(Type.Struct) {
                    val.set_til_type(Type.Struct(resolved.clone()))
                } else {
                    val.set_til_type(Type.Enum(resolved.clone()))
                }
            }
        }
    case:
        UNREACHABLE()
    }
}

priv infer_decl_untyped_value := proc(mut stmt: Expr, ctx: Context) {
    ref rhs : Expr = stmt.children[0]
    mut inferred := rhs.til_type()
    switch rhs.node_type {
    case NodeType.FuncDef(rhs_fd):
        if rhs_fd.captures.len() > 0 {
            inferred = Type.FuncPtr
            rhs.set_til_type(inferred.clone())
        }
    case NodeType.Literal(Literal.SetLit):
        if rhs.children.len() > 0 {
            elem_type := type_to_name(rhs.children[0].til_type())
            if elem_type.len() > 0 { inferred = Type.Struct(format("Set__", elem_type)) }
        }
    case NodeType.Literal(Literal.MapLit):
        if rhs.children.len() >= 2 {
            key_type := type_to_name(rhs.children[0].til_type())
            val_type := type_to_name(rhs.children[1].til_type())
            if key_type.len().gt(0).and(val_type.len().gt(0)) {
                inferred = Type.Struct(format("Map__", key_type, "_", val_type))
            }
        }
    case:
    }
    stmt.set_til_type(inferred)
    if stmt.til_type().is(Type.Dynamic) {
        switch stmt.node_type {
        case NodeType.Decl(sdecl):
            stmt.type_error(format("cannot store Dynamic in '", sdecl.name, "'; add a type annotation like '", sdecl.name, " : Type = ...' to specify the concrete type"), ctx)
        case:
            UNREACHABLE()
        }
    }
}

priv finalize_decl_binding := proc(scope: TypeScope, mut stmt: Expr, in_type_body: I32, ctx: Context) {
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        ref mut rhs : Expr = stmt.children[0]
        raw_alloc_rhs := fcall_is_raw_alloc(rhs)
        if in_type_body.eq(0).and(raw_alloc_rhs).and(sdecl.explicit_type.len().gt(0)) {
            if sdecl.own_type.is(OwnType.Ref) {
                stmt.type_error(format("raw allocation local '", sdecl.name, "' cannot be declared with 'ref'; locals are owned by default"), ctx)
            } else if ctx.path.contains("/src/self/").not().and(ctx.path.starts_with("src/self/").not())
                .and(stmt.til_type().is(Type.Dynamic))
                .and(ctx.current_type_name.contains("__").not())
                .and(ctx.current_top_func_name.contains("__").not()) {
                stmt.type_error(format("raw allocation local '", sdecl.name, "' must use a concrete type, not Dynamic"), ctx)
            }
        }
        if in_type_body.eq(0).and(sdecl.own_type.is(OwnType.Own)) {
            if sdecl.is_mut {
                stmt.type_error(format("no need for 'own' on mutable local '", sdecl.name, "'; write 'mut ", sdecl.name, " := ...'"), ctx)
            } else {
                stmt.type_error(format("no need for 'own' on local '", sdecl.name, "'; locals are owned by default"), ctx)
            }
        }
        scope.set(sdecl.name, stmt.til_type(), sdecl.is_mut, ctx.path, stmt.line, stmt.col, false, OwnType.Shallow)
        ref mut decl_b : TypeBinding = scope.get_binding(sdecl.name)
        // #164: snapshot the source-level `mut` keyword here, before any
        // later typer machinery (array/vec literal rewrite, alias
        // promotion etc.) auto-promotes is_mut.
        decl_b.mut_explicit = sdecl.is_mut
        decl_b.used = sdecl.used
        if ctx.throw_used_local_names.has(sdecl.name) { decl_b.used = true }
        decl_b.is_priv = sdecl.is_priv
        decl_b.orig_name = sdecl.orig_name.clone()
        if stmt.til_type().is_funcptr() {
            switch rhs.node_type {
            case NodeType.Ident(rhs_id):
                ref src : TypeBinding = scope.get_binding(rhs_id.ident_name())
                if src.is_null().not() {
                    ref src_fd : Expr = scope.lookup_func(src.name)
                    if src_fd.is_null().not() { scope.set_func_def(sdecl.name, src_fd) }
                }
            case NodeType.FCall:
                ref rfc_sig : Expr = resolve_fn_sig(rhs, scope)
                if rfc_sig.is_null().not() {
                    scope.set_func_def(sdecl.name, rfc_sig)
                }
            case NodeType.FuncDef(rhs_fd):
                if rhs_fd.captures.len() > 0 { scope.set_func_def(sdecl.name, rhs) }
            case:
            }
            if scope.lookup_func(decl_b.name).is_null() {
                // Issue #58 / #147 step 5: read FuncSig alias name from
                // sdecl.til_type (Type.FuncPtrSig payload) instead of
                // sdecl.explicit_type + get_binding indirection.
                if sdecl.til_type.is(Type.FuncPtrSig) {
                    sdsig_name := til_type_name(sdecl.til_type)
                    if sdsig_name.len() > 0 {
                        ref fsb_fd : Expr = scope.lookup_func(sdsig_name)
                        if fsb_fd.is_null().not() {
                            if fsb_fd.children.len() == 0 {
                                scope.set_func_def(sdecl.name, fsb_fd)
                            }
                        }
                    }
                }
            }
        }
        if sdecl.own_type.is(OwnType.Ref) {
            decl_b.own_type = OwnType.Ref
            // #211: payload binding `ref T = get_payload(<ident>)` is the
            // typer-emitted shape produced by make_switch_case_condition.
            // Mark its TypeBinding as an alias so the subsequent Assign
            // check at line 6935 recognises writes to it as
            // write-through-the-payload and accepts a constructor /
            // literal RHS (the builder lowers it to `*p = *new` for
            // structs and `*p = (Str){...}` for Str literals).
            if rhs.node_type.is(NodeType.FCall).and(rhs.children.len().eq(2)) {
                switch rhs.children[0].node_type {
                case NodeType.Ident(head_id):
                    if head_id.ident_name() == "get_payload" {
                        decl_b.is_alias = true
                    }
                case:
                }
            }
            if expr_is_ref_decl_source(rhs, scope).not().and(raw_alloc_rhs.not()) {
                stmt.type_error("'ref' declaration requires null, a ref-returning function, or ref/param variable", ctx)
            }
            if sdecl.is_mut {
                switch rhs.node_type {
                case NodeType.Ident(rid):
                    ref mut rb : TypeBinding = scope.get_binding(rid.ident_name())
                    if rb.is_null().not().and(rb.is_mut.not()) {
                        stmt.type_error("'ref mut' cannot bind to an immutable source; declare the source as 'mut' or 'ref mut'", ctx)
                    }
                    // #164: a `ref mut` binding launders mutability from the
                    // source. The source's `mut` is what makes this legal,
                    // so don't flag it as redundant even if the source name
                    // is never directly written through.
                    if rb.is_null().not() { rb.written = true }
                case:
                }
            }
        }
        if sdecl.own_type.is(OwnType.Ref).not().and(rhs.node_type.is(NodeType.FCall)).and(fcall_returns_ref(rhs, scope).neq(0)) {
            stmt.type_error("cannot own result of ref-returning function; use 'ref' or Type.clone()", ctx)
        }
        if sdecl.own_type.is(OwnType.Ref).not().and(sdecl.is_mut.not()).and(stmt.til_type().is_funcptr().not()).and(stmt.til_type().is(Type.Body).not()) {
            switch rhs.node_type {
            case NodeType.Ident(rhs_id2):
                ref rb : TypeBinding = scope.get_binding(rhs_id2.ident_name())
                if rb.is_null().not() {
                    if rb.is_mut.not().and(rb.own_type.is(OwnType.Own).not()).and(rb.own_type.is(OwnType.Ref).not().or(rb.is_alias)).and(rb.is_param.not()) {
                        sdecl.own_type = OwnType.Ref
                        decl_b.own_type = OwnType.Ref
                        decl_b.is_alias = true
                    }
                }
            case:
            }
        }
        if rhs.node_type.is(NodeType.Ident).or(
            rhs.node_type.is(NodeType.FieldAccess).and(
                is_aggregate(rhs.til_type())
            )
        ) {
            if sdecl.own_type.is(OwnType.Ref).not() {
                tname := type_to_name(stmt.til_type())
                // Issue #58 / #147 step 5: a FuncPtr/FuncPtrSig has no
                // T_clone method; it's a plain 8-byte pointer.
                if tname.len().gt(0).and(stmt.til_type().is_funcptr().not()).and(stmt.til_type().is(Type.Body).not()) {
                    mc := make_clone_call(tname, stmt.til_type(), rhs, stmt)
                    stmt.children[0] = mc
                }
            }
        }
    case:
        UNREACHABLE()
    }
}

priv infer_decl_stmt := proc(scope: TypeScope, mut stmt: Expr, in_func: I32, in_type_body: I32, ctx: Context) {
    if stmt.children.len() == 0 { return }
    ref first_child : Expr = stmt.children[0]
    if first_child.node_type.is(NodeType.StructDef).or(first_child.node_type.is(NodeType.EnumDef)) {
        switch stmt.node_type {
        case NodeType.Decl(td_decl):
            saved_type_name := ctx.current_type_name.clone()
            ctx.current_type_name = td_decl.name.clone()
            infer_expr(scope, stmt.children[0], in_func, ctx)
            ctx.current_type_name = saved_type_name
        case:
            UNREACHABLE()
        }
    } else {
        // Issue #93 follow-up: when the decl's rhs is a FuncDef body
        // (top-level after init_declarations_unit's nested-def lift),
        // set current_top_func_name so the function-scope priv check in
        // check_priv_access knows which parent we're inside while typing
        // the body.
        mut tracked_func := false
        saved_top_func := ctx.current_top_func_name.clone()
        switch stmt.node_type {
        case NodeType.Decl(sdecl):
            if sdecl.explicit_type.len() > 0 {
                declared := declared_type_for_decl(scope, stmt, ctx)
                if is_numeric_type(declared) {
                    pre_coerce_decl_numeric_literals(stmt.children[0], declared)
                }
                switch stmt.children[0].node_type {
                case NodeType.FuncDef(rhs_fd):
                    mut needs_sig_fill := false
                    if rhs_fd.params.len() > 0 {
                        needs_sig_fill = rhs_fd.params[0].explicit_type.len() == 0
                    }
                    if needs_sig_fill {
                        ref sig_expr : Expr = scope.lookup_func(sdecl.explicit_type)
                        if sig_expr.is_null().not() {
                            switch sig_expr.node_type {
                            case NodeType.FuncDef(sig_fd):
                                if sig_fd.params.len() == rhs_fd.params.len() {
                                    for sig_i in 0..rhs_fd.params.len() {
                                        ref mut dst_p : Declaration = rhs_fd.params[sig_i]
                                        ref src_p : Declaration = sig_fd.params[sig_i]
                                        dst_p.explicit_type = src_p.explicit_type.clone()
                                        dst_p.til_type = src_p.til_type.clone()
                                        if src_p.own_type.is(OwnType.Shallow).not() { dst_p.own_type = src_p.own_type }
                                    }
                                    rhs_fd.return_type = sig_fd.return_type.clone()
                                    if sig_fd.return_own_type.is(OwnType.Shallow).not() { rhs_fd.return_own_type = sig_fd.return_own_type }
                                }
                            case:
                            }
                        }
                    }
                case:
                }
            }
            if stmt.children[0].node_type.is(NodeType.FuncDef) {
                if stmt.children[0].children.len() > 0 {
                    ctx.current_top_func_name = sdecl.name.clone()
                    tracked_func = true
                }
            }
        case:
        }
        infer_expr(scope, stmt.children[0], in_func, ctx)
        if tracked_func {
            ctx.current_top_func_name = saved_top_func
        }
    }
    if infer_decl_type_def(scope, stmt, ctx) { return }
    if infer_decl_func_def(scope, stmt, ctx) { return }
    if infer_decl_type_alias_passthrough(scope, stmt) { return }
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        if sdecl.explicit_type.len() > 0 {
            infer_decl_typed_value(scope, stmt, in_func, ctx)
        } else {
            infer_decl_untyped_value(stmt, ctx)
        }
    case:
        UNREACHABLE()
    }
    check_ref_decl_owned_init(stmt, scope, ctx)
    check_ref_local_null_init(stmt, ctx)
    finalize_decl_binding(scope, stmt, in_type_body, ctx)
}

is_simple_lvalue_expr := func(e: Expr) returns Bool {
    if e.node_type.is(NodeType.Ident) { return true }
    if e.node_type.is(NodeType.FieldAccess) {
        if e.children.len() == 1 {
            return is_simple_lvalue_expr(e.children[0])
        }
    }
    return false
}

is_compile_directive := func(e: Expr) returns Bool {
    if e.node_type.is(NodeType.FCall).not() { return false }
    if e.children.len() < 1 { return false }
    switch e.children[0].node_type {
    case NodeType.Ident(name):
        ref name_str : Str = name.ident_name()
        return name_str.eq("link").or(name_str.eq("link_c")).or(name_str.eq("import"))
    case:
        return false
    }
}

// Issue #54 capture-block helpers. -------------------------------------

// Is `name` listed in the block's capture list?
priv capture_listed := func(captures: Vec(Declaration), name: Str) returns Bool {
    for cap : Declaration in captures {
        if cap.name == name { return true }
    }
    return false
}

// Was `name` captured with the `mut` modifier?
priv capture_is_mut := func(captures: Vec(Declaration), name: Str) returns Bool {
    for cap : Declaration in captures {
        if cap.name == name { return cap.is_mut }
    }
    return false
}

// Walk up to the file/global root scope.
priv scope_root_ref := func(s: TypeScope) returns ref TypeScope {
    if s.parent.is_null() { return s }
    return scope_root_ref(s.parent)
}

// Issue #54: a single name reference inside a capture block must resolve
// to a block-local, a captured name, a global/top-level func, or a type.
// A reference to an un-captured enclosing *local* is an error -- that is
// the whole point of the explicit capture list. `is_write` flags an
// assignment target, which additionally requires a `mut` capture.
priv capture_block_check_name := proc(e: Expr, name: Str, is_write: I32,
        enclosing: TypeScope, block_scope: TypeScope, root: TypeScope,
        captures: Vec(Declaration), ctx: Context) {
    if block_scope.bindings.has(name) { return }   // block-local (or shadow)
    if capture_listed(captures, name) {
        if is_write.eq(1).and(capture_is_mut(captures, name).not()) {
            e.type_error(format("capture '", name,
                "' is const here; capture it as 'mut' to assign to it"), ctx)
        }
        return
    }
    ref b : TypeBinding = enclosing.get_binding(name)
    if b.is_null() { return }                      // unresolved: normal diagnostics handle it
    if root.bindings.has(name) { return }          // global / top-level func / type
    if b.is_func_decl.or(b.is_builtin) { return }
    e.type_error(format("'", name,
        "' is not captured; add it to the '[...]' capture list to use it here"), ctx)
}

// Recurse the block body checking every variable reference. Nested
// capture blocks and func literals carry their own capture rules, so
// stop at them.
priv capture_block_check_refs := proc(e: Expr,
        enclosing: TypeScope, block_scope: TypeScope, root: TypeScope,
        captures: Vec(Declaration), ctx: Context) {
    expect(e.is_null().not(), "e is null")
    switch e.node_type {
    case NodeType.CaptureBlock: return
    case NodeType.BodyValue: return
    case NodeType.FuncDef: return
    case NodeType.Ident(idd):
        capture_block_check_name(e, idd.name, 0, enclosing, block_scope, root, captures, ctx)
    case NodeType.Assign(ad):
        capture_block_check_name(e, ad.name, 1, enclosing, block_scope, root, captures, ctx)
    case:
    }
    for c : Expr in e.children {
        capture_block_check_refs(c, enclosing, block_scope, root, captures, ctx)
    }
}

priv body_value_check_no_return := proc(e: Expr, ctx: Context) {
    switch e.node_type {
    case NodeType.FuncDef: return
    case NodeType.Return:
        e.type_error("Body value cannot contain return", ctx)
    case:
    }
    for c : Expr in e.children {
        body_value_check_no_return(c, ctx)
    }
}

priv infer_body_value_expr := proc(scope: TypeScope, mut expr: Expr, ctx: Context) {
    mut captures := Vec(Declaration).new()
    switch expr.node_type {
    case NodeType.BodyValue(bd):
        if bd.closure_name.len().eq(0) {
            bd.closure_name = format("body_", ctx.hoist_counter.to_str())
            ctx.hoist_counter++
        }
        captures = bd.captures.clone()
    case:
        UNREACHABLE()
    }
    validate_captures(scope, captures, expr, ctx)
    switch expr.node_type {
    case NodeType.BodyValue(bd): bd.captures = captures.clone()
    case:
        UNREACHABLE()
    }
    ref mut body : Expr = expr.children[0]
    body_value_check_no_return(body, ctx)
    body_scope := TypeScope(parent = scope)
    infer_body(body_scope, body, 0, 1, 0, 0, 0, ctx)
    ref root : TypeScope = scope_root_ref(scope)
    capture_block_check_refs(body, scope, body_scope, root, captures, ctx)
    garbager_destroy_body(ctx, body, body_scope)
    check_unused_locals(body_scope, ctx.path, ctx)
    check_unused_mut_locals(body_scope, ctx.path, ctx)
    expr.set_til_type(Type.Body)
}

// Issue #54: validate a capture list against the enclosing scope. Each
// captured name must exist; mark it used (so listing it counts as a use)
// and check the `mut` modifier against the source binding's mutability.
// Shared by capture blocks and capturing functions.
priv validate_captures := proc(scope: TypeScope, captures: Vec(Declaration), errnode: Expr, ctx: Context) {
    for mut cap : Declaration in captures {
        ref mut b : TypeBinding = scope.get_binding(cap.name)
        if b.is_null() {
            errnode.type_error(format("capture '", cap.name,
                "': no such variable in the enclosing scope"), ctx)
        } else {
            cap.til_type = b.type.clone()
            if cap.explicit_type.len() == 0 { cap.explicit_type = til_type_name_c(b.type) }
            b.used = true
            if cap.is_mut {
                if b.is_mut.not() {
                    errnode.type_error(format("cannot capture immutable '", cap.name,
                        "' as 'mut'"), ctx)
                }
                b.written = true
            }
        }
    }
}

// Issue #54: type-check a bare capture block `[a, mut b] { ... }`. The
// body is typed in a normal inline child scope, then a read-only
// restriction pass enforces that only captured outer locals are touched.
priv infer_capture_block := proc(scope: TypeScope, mut stmt: Expr,
        in_func: I32, in_loop: I32, returns_ref: I32, ctx: Context) {
    mut captures := Vec(Declaration).new()
    switch stmt.node_type {
    case NodeType.CaptureBlock(cbd):
        captures = cbd.captures.clone()
    case:
        UNREACHABLE()
    }
    // Each captured name must exist in the enclosing scope; mark it used
    // (so listing it counts as a use) and validate the `mut` modifier.
    validate_captures(scope, captures, stmt, ctx)
    if stmt.children.len() == 0 {
        stmt.set_til_type(Type.None)
        return
    }
    ref mut body : Expr = stmt.children[0]
    block_scope := TypeScope(parent = scope)
    infer_body(block_scope, body, in_func, 1, in_loop, returns_ref, 0, ctx)
    ref root : TypeScope = scope_root_ref(scope)
    capture_block_check_refs(body, scope, block_scope, root, captures, ctx)
    garbager_destroy_body(ctx, body, block_scope)
    check_unused_locals(block_scope, ctx.path, ctx)
    check_unused_mut_locals(block_scope, ctx.path, ctx)
    stmt.set_til_type(Type.None)
}

infer_body_stmt := proc(scope: TypeScope, mut body: Expr, mut i: USize, in_func: I32, in_loop: I32, returns_ref: I32, in_type_body: I32, ctx: Context) {
    // Issue #244: a Match at statement position is either the lowering's
    // result-temp-tagged form (desugar it like a switch) or a bare user
    // `match` whose value is discarded (an error pointing at switch).
    if body.children[i].node_type.is(NodeType.Match) {
        mut match_result_temp := ""
        switch body.children[i].node_type {
        case NodeType.Match(md): match_result_temp = md.result_temp.clone()
        case:
        }
        if match_result_temp.len() == 0 {
            ref mut bare_match : Expr = body.children[i]
            bare_match.type_error("match yields a value that is unused here; use 'switch' for arms that run statements", ctx)
            bare_match.set_til_type(Type.None)
            return
        }
        infer_switch_stmt(scope, body, i, in_func, in_loop, returns_ref, ctx)
        i--
        return
    }
    // Issue #244: lower any match nested in this statement into a result temp
    // plus a switch, spliced before it. `i` is advanced past the inserted
    // statements so the now-match-free statement is type-checked next.
    ref stmt_for_match : Expr = body.children[i]
    if stmt_for_match.node_type.is(NodeType.While).not().and(stmt_contains_match(stmt_for_match)) {
        inserted := lower_matches_in_stmt(scope, body, i, in_func, in_loop, returns_ref, ctx)
        i = i + inserted
    }
    ref mut stmt : Expr = body.children[i]
    if is_compile_directive(stmt) { stmt.set_til_type(Type.None); return }
    switch stmt.node_type {
    case NodeType.Decl:
        infer_decl_stmt(scope, stmt, in_func, in_type_body, ctx)
    case NodeType.Assign:
        infer_assign_stmt(scope, stmt, in_func, ctx)
    case NodeType.FieldAssign:
        infer_field_assign_stmt(scope, stmt, in_func, ctx)
    case NodeType.FCall:
        infer_expr(scope, stmt, in_func, ctx)
    case NodeType.Return:
        infer_return_stmt(scope, stmt, in_func, returns_ref, ctx)
    case NodeType.Break:
        if in_loop == 0 {
            stmt.type_error("break outside loop", ctx)
        }
        stmt.set_til_type(Type.None)
    case NodeType.Continue:
        if in_loop == 0 {
            stmt.type_error("continue outside loop", ctx)
        }
        stmt.set_til_type(Type.None)
    case NodeType.If:
        infer_if_stmt(scope, stmt, in_func, in_loop, returns_ref, ctx)
    case NodeType.Body:
        block_scope := TypeScope(parent = scope)
        infer_body(block_scope, stmt, in_func, 1, in_loop, returns_ref, 0, ctx)
        garbager_destroy_body(ctx, stmt, block_scope)
        check_unused_locals(block_scope, ctx.path, ctx)
        check_unused_mut_locals(block_scope, ctx.path, ctx)
    case NodeType.While:
        infer_while_stmt(scope, stmt, in_func, returns_ref, ctx)
    case NodeType.CaptureBlock:
        infer_capture_block(scope, stmt, in_func, in_loop, returns_ref, ctx)
    case NodeType.Switch:
        switch_lowered := infer_switch_stmt(scope, body, i, in_func, in_loop, returns_ref, ctx)
        if switch_lowered { i = i - 1 }
    case NodeType.ForIn:
        if desugar_for_in_kv_stmt(scope, body, i, in_func, ctx) {
            i--
        } else if desugar_for_in_range_stmt(scope, body, i, in_func, ctx) {
            i--
        } else if desugar_for_in_collection_stmt(scope, body, i, in_func, ctx) {
            i--
        }
    case NodeType.Throw:
        // Issue #198 step 5a: minimal dispatch -- type-check the
        // thrown expression so it isn't silently skipped. Validation
        // (throws-set tracking) and lowering land in later steps.
        if stmt.children.len() == 1 {
            infer_expr(scope, stmt.children[0], in_func, ctx)
        } else {
            stmt.type_error("throw must have exactly one parameter", ctx)
        }
        stmt.set_til_type(Type.None)
    case NodeType.Catch:
        // Issue #198 step 5a: minimal dispatch -- type-check the
        // catch body in a child scope. The err variable binding and
        // throws-set matching land in the validation step. Body
        // statements need infer_body so var refs etc. resolve.
        if stmt.children.len() == 3 {
            ref body_expr : Expr = stmt.children[2]
            catch_scope := TypeScope(parent = scope)
            infer_body(catch_scope, body_expr, in_func, 1, in_loop, returns_ref, 0, ctx)
            garbager_destroy_body(ctx, body_expr, catch_scope)
            check_unused_locals(catch_scope, ctx.path, ctx)
            check_unused_mut_locals(catch_scope, ctx.path, ctx)
        } else {
            stmt.type_error("catch must have 3 children: var, type, body", ctx)
        }
        stmt.set_til_type(Type.None)
    case:
        stmt.set_til_type(Type.None)
    }
}

priv reregister_scope_defs := func(body: Expr, scope: TypeScope) {
    for rstmt : Expr in body.children {
        if rstmt.children.len() == 0 { continue }
        ref rfirst : Expr = rstmt.children[0]
        switch rstmt.node_type {
        case NodeType.Decl(rdecl):
            ref mut rb : TypeBinding = scope.get_binding(rdecl.name)
            if rb.is_null().not() {
                ref rb_old_sd : Expr = scope.struct_def_of(rb.name)
                if rb_old_sd.is_null().not().and(
                    rfirst.node_type.is(NodeType.StructDef).or(rfirst.node_type.is(NodeType.EnumDef))) {
                        scope.set_struct_def(rb.name, rstmt.children[0])
                        for b in scope.bindings.values {
                            if b.ptr_eq(rb).not().and(scope.struct_def_of(b.name).ptr_eq(rb_old_sd)) {
                                scope.set_struct_def(b.name, rstmt.children[0])
                            }
                        }
                    }
                ref rb_old_fd : Expr = scope.lookup_func(rb.name)
                if rb_old_fd.is_null().not().and(rfirst.node_type.is(NodeType.FuncDef)) {
                    scope.set_func_def(rb.name, rstmt.children[0])
                    for b in scope.bindings.values {
                        if b.ptr_eq(rb).not().and(scope.lookup_func(b.name).ptr_eq(rb_old_fd)) {
                            scope.set_func_def(b.name, rstmt.children[0])
                        }
                    }
                }
                if rb.alias_target.is_empty().not() {
                    switch rstmt.children[0].node_type {
                    case NodeType.Ident(target_name):
                        // Refresh just this alias's target. We deliberately
                        // do NOT broadcast to other bindings whose
                        // alias_target string happened to match the old
                        // value -- two unrelated aliases can share a target
                        // (e.g. `A := Dynamic` and `B := Dynamic`), and
                        // rewriting them in lockstep here created
                        // self-referential chains (`ffi_raw := Dynamic`
                        // followed by `ffi_java_raw := ffi_raw` used to
                        // leave ffi_raw.alias_target = "ffi_raw", and
                        // type_from_name would loop until stack overflow).
                        // The struct/func re-binding above is fine because
                        // it pivots on ptr_eq of the old Expr.
                        rb.alias_target = Str.clone(target_name.ident_name())
                    case:
                    }
                }
            }
        case:
        }
    }
}

reregister_repl_scope_defs := func(body: Expr, scope: TypeScope) {
    reregister_scope_defs(body, scope)
}

// Type-inference walk for a single body. Issue #204 step 3a: this
// proc no longer runs the asap-destruction pass; the scope-management
// sites that call infer_body invoke garbager_destroy_body(body, scope)
// themselves before tearing the scope down.
infer_body := proc(scope: TypeScope, mut body: Expr, in_func: I32, owns_scope: I32, in_loop: I32, returns_ref: I32, in_type_body: I32, ctx: Context) {
    body.set_til_type(Type.None)
    mut i : USize = 0
    while i < body.children.len() {
        if scope.parent.is_null().and(in_func.eq(0)).and(in_type_body.eq(0)) {
            context_set_mode_from_path(ctx, ctx.path)
        }
        infer_body_stmt(scope, body, i, in_func, in_loop, returns_ref, in_type_body, ctx)
        i++
    }
    if body_pre_passes(ctx, body, scope, owns_scope) {
        reregister_scope_defs(body, scope)
    }
}

priv infer_body_unit := proc(scope: TypeScope, mut body: Expr, in_func: I32, owns_scope: I32, in_loop: I32, returns_ref: I32, in_type_body: I32, ctx: Context) {
    body.set_til_type(Type.None)
    // Issue #158: record foldable macro/func names so constfolder reuses
    // ctx.constfolder_foldables instead of re-scanning. Issue #315: classify
    // ALL top-level defs BEFORE the walk. infer_body_stmt type-checks each
    // nested body mid-walk (via infer_body -> body_pre_passes), and that
    // desugar/hoist pass asks is_macro_call (constfolder_foldables) whether to
    // skip hoisting a macro call's args. A foldable macro used by an earlier
    // body but declared LATER at the top level must already be recorded, or
    // its arg is hoisted into a temp and the constfolder then folds the macro
    // against the temp (e.g. `til_type_name(hoisted__Type_N)` -> a bogus type
    // name). Classifying per-statement during the walk left forward-referenced
    // macros invisible until too late. Lambdas are lifted and struct/enum
    // methods generated before this sweep (type_decls_file runs before
    // type_bodies_file), so body.children already holds every top-level def.
    // Doing this as a pre-walk pass (rather than reading body.children[i]
    // inside the walk) also sidesteps the issue #312 OutOfBounds: a top-level
    // `for i in 0..N` desugars its single ForIn at index 0, where
    // infer_body_stmt rewinds `i` (i--) and underflows the USize.
    for stmt : Expr in body.children {
        constfolder_classify_stmt(stmt, ctx)
    }
    mut i : USize = 0
    while i < body.children.len() {
        infer_body_stmt(scope, body, i, in_func, in_loop, returns_ref, in_type_body, ctx)
        i++
    }
    if body_pre_passes(ctx, body, scope, owns_scope) {
        reregister_scope_defs(body, scope)
    }
}

// Type-check a single file unit. Caller must have registered a mode for path.
// #165 step 1: post-init normalization sweep.
//
// Initer's registration helpers store user-defined-type names as
// ~Type.Custom(name)~ via the scope-free ~til_type_from_explicit_type~,
// so they don't have to read scope. This sweep -- run after every file's
// init has completed but before type_check -- walks the global bindings
// and replaces ~Custom(name)~ with ~Struct(name)~ or ~Enum(name)~ when
// the name resolves to a real struct/enum. Bindings whose type does
// not resolve are left as ~Custom~ and surface as undefined-symbol
// errors during type_check (same as today).
normalize_scope_bindings := func(scope: TypeScope) {
    for mut b in scope.bindings.values {
        switch b.type {
        case Type.Custom(name):
            ref alias_b : TypeBinding = scope.get_binding(name)
            if alias_b.is_null().not() {
                if alias_b.is_type_alias {
                    if alias_b.type.is(Type.Custom).not() {
                        b.type = alias_b.type.clone()
                        continue
                    }
                }
            }
            ref sdef : Expr = scope.get_struct(name)
            if sdef.is_null() { continue }
            if sdef.node_type.is(NodeType.EnumDef) {
                b.type = Type.Enum(name.clone())
            } else {
                b.type = Type.Struct(name.clone())
            }
        case:
        }
    }
}

// --- Lambda lifting -----------------------------------------------------
//
// Anonymous `func(...) {...}` literals in expression positions (FCall
// args, NamedArg values, struct field defaults, etc.) are lifted out to
// the program top level as `_lambda_<N> := func(...) {...}` priv decls
// before the typer's main body walk. The original spot in the AST is
// replaced with an `Ident("_lambda_N")` reference; the typer then types
// the lifted decl as an ordinary named function.
//
// This used to live in a separate pre-typer transform file.
// Moved into the typer module so the parser stays dumb and the lift
// happens during the typer phase rather than as its own #158 pass.

priv type_check_unit := proc(path: Str, program: Expr, scope: TypeScope, ctx: Context) returns I32 {
    ctx.errors = 0
    context_enter_file(ctx, path)
    // Lift anonymous func literals out of expression positions to
    // top-level _lambda_<N> priv decls. The typer then types them as
    // ordinary named functions through the normal walk below. Doing
    // this in the typer (rather than as a pre-typer pass in init_file)
    // keeps the parser dumb and avoids adding a #158-style extra walk.
    typer_lift_lambdas(scope, program, ctx)
    // Issue #198: extend signatures of throwing functions BEFORE
    // any body type-checking so call-site rewrites in
    // inject_throw_args_in_body see the post-extension param list.
    extend_throwing_func_sigs(ctx, program)
    // For per-file units, we do not switch modes per statement.
    infer_body_unit(scope, program, 0, 1, 0, 0, 0, ctx)
    // Program-scope asap runs from prepare_program via
    // garbager_destroy(ctx) once all files are typed -- see issue #204
    // step 3b.
    return ctx.errors
}

// Two-sweep typer driver (#174 / #147 step 3-4 prep). type_file calls
// type_decls_file first (decls + methodgen + layout, future home of
// init_declarations_global's scope-using work) and then
// type_bodies_file (function body type-checking). Both walks are
// rstil-style: recurse on imports in source order, then handle this
// file. The split memo Sets (imports_typer_decls_done /
// imports_typer_bodies_done) ensure each file is visited at most once
// per sweep, and the per-file ordering "imports first, then this
// file" within each sweep matches today's single-sweep behaviour.
//
// type_decls_file currently owns layout computation
// (compute_struct_layout / compute_enum_layout), the layout-dependent
// size methodgen (gen_*_size_method_for_stmt), and the scope-free
// cmp/unity derived-method helpers. Subsequent commits relocate the
// scope-using methodgen (gen_struct_clone_delete,
// gen_missing_enum_clone) the same way and eventually retire
// init_declarations_global's heavy parts entirely.
type_file := proc(path: Str, ctx: Context) returns I32 {
    mut total : I32 = 0
    total = total + type_decls_file(path, ctx)
    total = total + type_bodies_file(path, ctx)
    return total
}

priv type_repl_delta_decls_from := proc(program: Expr, start_idx: USize, ctx: Context) returns I32 {
    total : I32 = 0
    mut i := start_idx
    while i < program.children.len() {
        ref stmt : Expr = program.children[i]
        i++
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        if stmt.children.len() == 0 { continue }
        ref rhs : Expr = stmt.children[0]
        if rhs.node_type.is(NodeType.StructDef) {
            switch stmt.node_type {
            case NodeType.Decl(d):
                compute_struct_layout(d.name, rhs, ctx.scope, ctx)
            case:
            }
            gen_struct_size_method_for_stmt(stmt, ctx)
        } else if rhs.node_type.is(NodeType.EnumDef) {
            switch stmt.node_type {
            case NodeType.Decl(d):
                compute_enum_layout(d.name, rhs, ctx.scope, ctx)
            case:
            }
            gen_enum_size_method_for_stmt(stmt, ctx.scope, ctx)
        } else {
            continue
        }
        gen_cmp_derived_for_stmt(stmt)
        gen_unity_derived_for_stmt(stmt)
    }
    return total
}

type_repl_delta := proc(path: Str, program: Expr, ctx: Context) returns I32 {
    context_enter_file(ctx, path)
    mut total : I32 = 0
    total = total + type_repl_delta_decls_from(program, 0, ctx)
    post_decl_start := program.children.len()
    total = total + type_check_unit(path, program, ctx.scope, ctx)
    total = total + type_repl_delta_decls_from(program, post_decl_start, ctx)
    total = total + check_unused_priv_top_level(ctx.scope, ctx)
    total = total + check_unused_priv_members_in_program(program, path, ctx)
    return total
}

// First of two typer sweeps: per file, recurse on imports first
// (matching the existing rstil-style ordering), then walk top-level
// decls and do struct/enum layout computation, layout-dependent size
// methodgen, and the scope-free cmp/unity derived-method helpers.
// Layout's nested-type lookups follow scope.get_struct /
// get_binding; the topo-ordered import recursion above guarantees
// every import's layouts are already done before the parent file's
// layouts run, and within a file compute_*_layout recurses on
// nested defs for local forward references. The remaining
// scope-using methodgen (gen_struct_clone_delete,
// gen_missing_enum_clone) and the post-init re-registration loops
// stay in init_declarations_global for now -- they hit the #174
// method-body cycle and will migrate once the second sweep takes
// over function bodies.
priv type_decls_file := proc(path: Str, ctx: Context) returns I32 {
    if ctx.imports_typer_decls_done.has(path) {
        return 0
    }
    ctx.imports_typer_decls_done.add(own path.clone())

    ref iu : ImportUnit = ctx.imported[path]
    mut total : I32 = 0
    ast_count : USize = count_ast_imports(iu.ast)
    auto_count : USize = iu.imports.len() - ast_count
    for i in 0..auto_count {
        ref dep : Str = iu.imports[i]
        total = total + type_decls_file(dep, ctx)
    }
    mut import_idx : USize = auto_count
    for stmt : Expr in iu.ast.children {
        mut is_imp := false
        if stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0)) {
            ref imp_stmt : Expr = stmt.children[0]
            if imp_stmt.node_type.is(NodeType.FCall).and(imp_stmt.children.len().gte(2)) {
                if imp_stmt.children[1].node_type.is_literal_str() {
                    switch imp_stmt.children[0].node_type {
                    case NodeType.Ident(id):
                        if id.ident_name() == "import" { is_imp = true }
                    case:
                    }
                }
            }
        } else {
            if stmt.node_type.is(NodeType.FCall).and(stmt.children.len().gte(2)) {
                if stmt.children[1].node_type.is_literal_str() {
                    switch stmt.children[0].node_type {
                    case NodeType.Ident(id):
                        if id.ident_name() == "import" { is_imp = true }
                    case:
                    }
                }
            }
        }

        if is_imp {
            ref dep : Str = iu.imports[import_idx]
            total = total + type_decls_file(dep, ctx)
            import_idx++
        }
    }

    // Per-decl work in source order: compute struct/enum layouts,
    // synthesize the layout-dependent size method, and run the
    // scope-free cmp/unity derived-method helpers. Layout has to run
    // before gen_*_size_method_for_stmt (which reads
    // total_struct_size / total_enum_size) and before the cmp/unity
    // helpers (which inspect the same ns_decls that size methodgen
    // may have just populated). All three steps are safe in this
    // sweep because compute_*_layout's nested-type lookups follow
    // the same scope.get_struct / scope.get_binding path that
    // init_declarations_global used today; the rstil-style
    // topo-ordered recursion above guarantees every import's
    // layouts are already done by the time we get here. Within a
    // file, compute_struct_layout / compute_enum_layout internally
    // recurse on nested defs to handle local forward references.
    for stmt : Expr in iu.ast.children {
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        if stmt.children.len() == 0 { continue }
        ref rhs : Expr = stmt.children[0]
        if rhs.node_type.is(NodeType.StructDef) {
            switch stmt.node_type {
            case NodeType.Decl(d):
                compute_struct_layout(d.name, rhs, ctx.scope, ctx)
            case:
            }
            gen_struct_size_method_for_stmt(stmt, ctx)
        } else if rhs.node_type.is(NodeType.EnumDef) {
            switch stmt.node_type {
            case NodeType.Decl(d):
                compute_enum_layout(d.name, rhs, ctx.scope, ctx)
            case:
            }
            gen_enum_size_method_for_stmt(stmt, ctx.scope, ctx)
        } else {
            continue
        }
        gen_cmp_derived_for_stmt(stmt)
        gen_unity_derived_for_stmt(stmt)
    }
    return total
}

// Per-file body type-check sweep (the second of two). The recursion
// here is the same shape as the current single-sweep type_file: walk
// imports in source order, then type_check_unit. Renamed from
// type_file to make the two-sweep split explicit.
priv type_bodies_file := proc(path: Str, ctx: Context) returns I32 {
    if ctx.imports_typer_bodies_done.has(path) {
        return 0
    }
    ctx.imports_typer_bodies_done.add(own path.clone())

    ref iu : ImportUnit = ctx.imported[path]

    // Walk the AST in source order; recurse on each ~import("...")~ FCall.
    // iu.imports stays as a source-ordered side table for path resolution.
    // Loader-prepended mode auto-imports (e.g. mode gui -> gui.til) come
    // first in iu.imports without a matching AST FCall, so process those
    // leading entries before the walk. #165 step 5.
    mut total : I32 = 0
    ast_count : USize = count_ast_imports(iu.ast)
    auto_count : USize = iu.imports.len() - ast_count
    for i in 0..auto_count {
        ref dep : Str = iu.imports[i]
        total = total + type_bodies_file(dep, ctx)
    }
    mut import_idx : USize = auto_count
    for stmt : Expr in iu.ast.children {
        if stmt.node_type.is(NodeType.FCall).not() { continue }
        // >= 2, matching count_ast_imports: a selective import
        // (`import("x", Sym)`) has 3 children. Requiring exactly 2 here
        // desynchronized this walk from the auto_count math above, so
        // the dep AFTER a selective import was never body-typed -- its
        // priv uses stayed unmarked and tripped the #187 unused-priv
        // check (visible as bogus "unused priv" errors in that file).
        if stmt.children.len() < 2 { continue }
        if stmt.children[1].node_type.is_literal_str().not() { continue }
        switch stmt.children[0].node_type {
        case NodeType.Ident(id):
            if id.ident_name().eq("import").not() { continue }
            ref dep : Str = iu.imports[import_idx]
            total = total + type_bodies_file(dep, ctx)
            import_idx++
        case:
            continue
        }
    }

    context_enter_file(ctx, path)
    if iu.mode_str == "mode" {
        for stmt : Expr in iu.ast.children {
            mut is_valid := false
            if stmt.node_type.is(NodeType.Decl) {
                switch stmt.node_type {
                case NodeType.Decl(_dd):
                    if stmt.children.len() > 0 {
                        ref val : Expr = stmt.children[0]
                        if val.node_type.is(NodeType.NoDefaultArg).not() {
                            if val.node_type.is(NodeType.FCall).and(val.children.len().gt(0)) {
                                ref callee : Expr = val.children[0]
                                switch callee.node_type {
                                case NodeType.Ident(id):
                                    if id.ident_name() == "Mode" {
                                        is_valid = true
                                    }
                                case:
                                }
                            }
                        }
                    }
                case:
                }
            } else if stmt.node_type.is(NodeType.FCall).and(stmt.children.len().eq(2)) {
                if stmt.children[1].node_type.is_literal_str() {
                    switch stmt.children[0].node_type {
                    case NodeType.Ident(id):
                        if id.ident_name() == "import" { is_valid = true }
                    case:
                    }
                }
            }
            if is_valid.not() {
                stmt.type_error("only Mode declarations (e.g. `cli := Mode(...)`) and imports are allowed in 'mode mode'", ctx)
            }
        }
    }
    return total + type_check_unit(path, iu.ast, ctx.scope, ctx)
}

priv infer_assign_stmt := proc(scope: TypeScope, mut stmt: Expr, in_func: I32, ctx: Context) {
    infer_expr(scope, stmt.children[0], in_func, ctx)
    ref mut rhs : Expr = stmt.children[0]
    stmt.set_til_type(rhs.til_type())
    mut aname := ""
    switch stmt.node_type {
    case NodeType.Assign(adata):
        aname = adata.name.clone()
    case:
        UNREACHABLE()
        return
    }
    // A write isn't a read. Don't flip `used = true` on the assign
    // target for plain mut locals -- that's the accidental exception
    // that masks write-only locals like `mut y := x; y = 99` as
    // not-unused.
    //
    // Two carve-outs where the write IS observable:
    // - Params: a `mut foo: T` param is an output channel watched by
    //   the caller.
    // - Ref bindings: `ref mut x : T = &slot` followed by `x = v` is
    //   the explicit write-through-ref pattern -- the assign is the
    //   whole point of the binding.
    ref mut ub : TypeBinding = scope.get_binding(aname)
    if ub.is_null().not() {
        // #154: writing a cross-file global counts as using its import
        // even though it is not a read for the unused-variable check.
        note_cross_file_use(ctx, ub.path)
        if ub.is_param.or(ub.own_type.is(OwnType.Ref)) { ub.used = true }
    }
    existing := scope.get_type(aname)
    if existing.is(Type.Unknown) {
        stmt.type_error(format("undefined symbol '", aname, "'"), ctx)
    } else if scope.is_mut(aname).not() {
        stmt.type_error(format("cannot assign to immutable variable '", aname, "'"), ctx)
        sf := scope.find(aname)
        switch sf {
        case ScopeFind.Found(b):
            if b.is_param {
                println(ctx.path, ":", b.line.to_str(), ":", b.col.to_str(), ": note: '", aname, "' is a function parameter")
            } else {
                println(ctx.path, ":", b.line.to_str(), ":", b.col.to_str(), ": note: '", aname, "' declared here, consider adding 'mut'")
            }
        case:
        }
    } else if rhs.node_type.is_literal_num().and(is_numeric_type(existing)) {
        switch rhs.node_type {
        case NodeType.Literal(Literal.Num(lit_str)):
            if literal_in_range(lit_str.literal_num_text(), existing).not() {
                stmt.type_error(format("integer literal out of range for assignment to '", aname, "'"), ctx)
            }
        case:
        }
        rhs.set_til_type(existing)
        stmt.set_til_type(existing)
    } else if rhs.til_type().is(existing).not().and(rhs.til_type().is(Type.Unknown).not())
        // Issue #58 / #147 step 5: FuncPtr/FuncPtrSig wildcard family-eq.
        .and(funcptr_eq(rhs.til_type(), existing).not()) {
        // Issue #244: a `_m_*` target is a synthesized match result temp; an
        // arm-type mismatch was already reported cleanly by infer_match_expr,
        // so don't also surface the internal temp name here.
        if aname.starts_with("_m_").not() {
            stmt.type_error(format("'", aname, "' assignment type mismatch"), ctx)
        }
    }
    // #164: record that this binding was written through. Done before
    // the ScopeFind.Found read below because get_binding returns a ref
    // so the write actually persists (find returns Value semantics).
    {
        ref mut ab_w : TypeBinding = scope.get_binding(aname)
        if ab_w.is_null().not() { ab_w.written = true }
    }
    sf_assign := scope.find(aname)
    mut is_ref_target := false
    mut is_payload_alias := false
    switch sf_assign {
    case ScopeFind.Found(ab):
        if ab.own_type.is(OwnType.Ref).and(ab.is_param.not()) {
            is_ref_target = true
            if ab.is_alias { is_payload_alias = true }
        }
    case:
    }
    if is_payload_alias {
        switch stmt.node_type {
        case NodeType.Assign(adata_p):
            adata_p.is_payload_alias = true
        case:
        }
    }
    if is_ref_target {
        // #211: payload aliases accept an owned-value RHS (the builder
        // lowers it to `*p = *new` for structs and `*p = (Str){...}` for
        // Str literals); only plain ref bindings still reject.
        if is_payload_alias.not() {
            check_ref_assign_owned_rhs(stmt, aname, rhs, scope, ctx)
        }
    }
    if is_ref_target.not() {
        if rhs.node_type.is(NodeType.Ident).or(
            rhs.node_type.is(NodeType.FieldAccess).and(
                is_aggregate(rhs.til_type())
            )
        ) {
            tname := type_to_name(rhs.til_type())
            // Issue #58 / #147 step 5: FuncPtr/FuncPtrSig has no T_clone.
            if tname.len().gt(0).and(rhs.til_type().is_funcptr().not()).and(rhs.til_type().is(Type.Body).not()) {
                mc := make_clone_call(tname, rhs.til_type(), rhs, stmt)
                stmt.children[0] = mc
                if scope.bindings.has(aname).not() {
                    if is_aggregate(existing) {
                        if assign_target_is_func_local(scope, aname) {
                            switch stmt.node_type {
                            case NodeType.Assign(adata2):
                                adata2.save_old_delete = true
                            case:
                            }
                        }
                    }
                }
            }
        } else if rhs.node_type.is(NodeType.FCall).and(fcall_returns_own(rhs, scope)).and(
            is_aggregate(existing)
        ) {
            if scope.bindings.has(aname).not().and(assign_target_is_func_local(scope, aname)) {
                switch stmt.node_type {
                case NodeType.Assign(adata3):
                    adata3.save_old_delete = true
                case:
                }
            }
        } else if rhs.node_type.is_literal_str().and(
            is_aggregate(existing)
        ) {
            // mut X := some_str; ... X = "literal" -- the outer-scope local
            // owns a heap-allocated Str clone; the literal RHS just rebinds
            // the pointer, leaking the old clone. Same outer-scope shape as
            // the Ident/FCall branches above.
            if scope.bindings.has(aname).not().and(assign_target_is_func_local(scope, aname)) {
                switch stmt.node_type {
                case NodeType.Assign(adata4):
                    adata4.save_old_delete = true
                case:
                }
            }
        }
    }
}

rhs_is_clone_fcall := func(rhs: Expr) returns Bool {
    if rhs.node_type.is(NodeType.FCall).not() { return false }
    if rhs.children.len() < 1 { return false }
    ref callee : Expr = rhs.children[0]
    if callee.node_type.is(NodeType.FieldAccess).not() { return false }
    switch callee.node_type {
    case NodeType.FieldAccess(method):
        return method.field_access_name() == "clone"
    case:
        return false
    }
}

priv assign_target_is_func_local := func(mut scope: TypeScope, name: Str) returns Bool {
    ref mut s : TypeScope = scope
    while s.is_null().not() {
        if s.parent.is_null().not().and(s.bindings.has(name)) { return true }
        s = s.parent
    }
    return false
}

is_numeric_type := func(t: Type) returns Bool {
    switch t {
    case Type.Primitive(Primitive.I64): return true
    case Type.Primitive(Primitive.U8):  return true
    case Type.Primitive(Primitive.I8):  return true
    case Type.Primitive(Primitive.I16): return true
    case Type.Primitive(Primitive.U16): return true
    case Type.Primitive(Primitive.I32): return true
    case Type.Primitive(Primitive.U32): return true
    case Type.Primitive(Primitive.U64): return true
    case Type.Primitive(Primitive.F32): return true
    case: return false
    }
}

is_integral_numeric_type := func(t: Type) returns Bool {
    switch t {
    case Type.Primitive(Primitive.I64): return true
    case Type.Primitive(Primitive.U8):  return true
    case Type.Primitive(Primitive.I8):  return true
    case Type.Primitive(Primitive.I16): return true
    case Type.Primitive(Primitive.U16): return true
    case Type.Primitive(Primitive.I32): return true
    case Type.Primitive(Primitive.U32): return true
    case Type.Primitive(Primitive.U64): return true
    case: return false
    }
}

priv type_ctor_consumes := func(t: Type) returns Bool {
    // Primitives (now all Type.Primitive) are value types -- a ctor field
    // default of `0` with explicit type I32
    // shouldn't trigger "own" semantics. Without this short-circuit, the
    // generic Type.Struct case below pulls them into set_own_arg in
    // infer_struct_constructor_fcall, which makes the typer's hoist pass
    // promote the LiteralNum temp to Own, which makes the builder emit
    // `I32 *t = malloc(sizeof(I32)); *t = 0;` -- a per-LocalInfo leak that
    // never gets freed. (Issue #109.)
    if is_primitive(t) { return false }
    switch t {
    case Type.Struct: return true
    case Type.Enum: return true
    case Type.Dynamic: return true
    case Type.FuncPtr: return true
    case: return false
    }
}

priv is_usize_name := func(name: Str) returns Bool {
    return name == "USize"
}

priv is_uptr_name := func(name: Str) returns Bool {
    return name == "UPtr"
}

priv can_implicit_usize_coerce := func(from: Type, to: Type, to_name: Str) returns Bool {
    if is_usize_name(to_name) {
        switch to {
        case Type.Primitive(Primitive.U32):
            return is_integral_numeric_type(from)
        case Type.Primitive(Primitive.U64):
            return is_integral_numeric_type(from)
        case: return false
        }
    }
    if is_uptr_name(to_name) {
        switch to {
        case Type.Primitive(Primitive.U32):
            return is_integral_numeric_type(from)
        case Type.Primitive(Primitive.U64):
            return is_integral_numeric_type(from)
        case: return false
        }
    }
    return false
}

literal_in_range := func(val_str: Str, target: Type) returns Bool {
    switch target {
    case Type.Primitive(Primitive.I64): return true
    case Type.Primitive(Primitive.F32): return true
    case Type.Primitive(Primitive.U8):
        val := val_str.to_i64()
        return val.gte(0).and(val.lte(255))
    case Type.Primitive(Primitive.I8):
        val := val_str.to_i64()
        return val.gte(-128).and(val.lte(127))
    case Type.Primitive(Primitive.I16):
        val := val_str.to_i64()
        return val.gte(-32768).and(val.lte(32767))
    case Type.Primitive(Primitive.U16):
        val := val_str.to_i64()
        return val.gte(0).and(val.lte(65535))
    case Type.Primitive(Primitive.I32):
        val := val_str.to_i64()
        return val.gte(-2147483648).and(val.lte(2147483647))
    case Type.Primitive(Primitive.U32):
        val := val_str.to_i64()
        return val.gte(0).and(val.lte(4294967295))
    case Type.Primitive(Primitive.U64):
        val := val_str.to_i64()
        return val >= 0
    case: return true
    }
}

// Type-name resolution at a user-facing site (parameter type, return
// type, ref/let decl explicit_type). Shares the single
// scope.get_binding lookup with the priv check, so user-facing
// callers don't pay for two Map traversals per declaration position.
priv type_from_name_at := proc(name: Str, scope: TypeScope, mut e: Expr, ctx: Context) returns Type {
    pt := type_from_name(name, scope, ctx)
    if name.len() == 0 { return pt }
    if ctx.current_type_name == name { return pt }
    expect(scope.is_null().not(), "scope is null")
    ref mut b : TypeBinding = scope.get_binding(name)
    check_priv_access(e, name, b, ctx)
    return pt
}

type_from_name := func(name: Str, scope: TypeScope, ctx: Context) returns Type {
    mut bt := Type.Unknown
    if builtin_type_from_name(name, bt) { return bt }
    // #192: USize/UPtr resolve to the loader-stamped per-target primitive
    // name, same authority as type_from_name_init and resolve_type_alias.
    if name == "USize" { return type_from_name(ctx.target_usize_pname, scope, ctx) }
    if name == "UPtr" { return type_from_name(ctx.target_uptr_pname, scope, ctx) }
    if scope.is_null().not() {
        ref mut b : TypeBinding = scope.get_binding(name)
        if b.is_null().not() {
            // #154: a type annotation naming a cross-file type uses its
            // import (no auto_gen/current_type_name gate -- auto-generated
            // bodies only exist because this file declared the type, so
            // their annotations are source-level uses of the field types).
            note_cross_file_use(ctx, b.path)
            if b.is_type_alias {
                if b.alias_target.is_empty().not() {
                    return type_from_name(b.alias_target, scope, ctx)
                }
            }
            // #187: explicit type annotations (e.g. ~ref x : Foo = ...~,
            // function param/return types) count as a use of the named
            // type. Same gate as the Ident path -- skip when we're inside
            // the type's own namespace to keep auto-gen body references
            // from masking a genuinely unused priv type.
            if ctx.auto_gen_depth.eq(0).and(ctx.current_type_name.eq(name).not()) {
                b.used = true
            }
            if b.is_builtin {
                // A builtin binding is either a builtin TYPE (had a
                // struct_def) or a builtin ext_func (has a func_def);
                // never both. The old read here was
                // `if b.struct_def.is_null().not()`, i.e. "builtin type".
                // With struct_def removed, test the equivalent "builtin
                // and NOT a func". lookup_func is shadowing-aware (gates
                // on the binding's own scope) so it matches the exact
                // per-binding semantics the struct_def field read had,
                // unlike a get_struct name-walk which can fall through to
                // a parent type of the same name. Clone the result: every
                // type_from_name return path yields an owned Type that the
                // caller Type_deletes.
                if scope.lookup_func(b.name).is_null() { return b.type.clone() }
            }
            ref b_fd : Expr = scope.lookup_func(b.name)
            if b_fd.is_null().not() {
                if b_fd.children.len() == 0 {
                    // Issue #58 / #147 step 5: a name that resolves to a
                    // bodyless FuncDef (a FuncSig alias like `BinaryOp`)
                    // now carries the alias name in the type itself.
                    // Callsites that ask "is this a FuncPtr?" go through
                    // `t.is_funcptr()` (helper accepting both `FuncPtr`
                    // and `FuncPtrSig`). Consumers needing the FuncSig
                    // name read it from `til_type_name(t)` instead of
                    // from the carrier's `Declaration.explicit_type`,
                    // which is the migration that eventually drops the
                    // field.
                    return Type.FuncPtrSig(name.clone())
                }
            }
        }
        ref sdef : Expr = scope.get_struct(name)
        if sdef.is_null().not() {
            if sdef.node_type.is(NodeType.EnumDef) {
                return Type.Enum(name.clone())
            }
            return Type.Struct(name.clone())
        }
    }
    return Type.Unknown
}

resolve_type_alias := func(scope: TypeScope, name: Str) returns ref Str {
    // #192: USize/UPtr resolve to the per-target width registered by the
    // loader, the same authority the builtin type table uses, so the
    // name-form (this function) and the type-form never disagree -- even
    // during init, before the alias binding is retargeted.
    if name == "USize" { return scope_target_usize_pname(scope) }
    if name == "UPtr" { return scope_target_uptr_pname(scope) }
    ref b : TypeBinding = scope.get_binding(name)
    if b.is_null().not() {
        if b.is_type_alias {
            if b.alias_target.is_empty().not() { return b.alias_target }
        }
    }
    return name
}

priv usize_name := func(scope: TypeScope) returns Str {
    if scope.get_binding("USize").is_null().not() { return "USize" }
    return "U64"
}

usize_type := func(scope: TypeScope, ctx: Context) returns Type {
    return type_from_name(usize_name(scope), scope, ctx)
}

type_has_cmp := func(scope: TypeScope, type_name: Str) returns Bool {
    ref sdef : Expr = scope.get_struct(type_name)
    if sdef.is_null() { return false }
    ref cmp_ns : Vec(Declaration) = def_ns_decls(sdef)
    for decl : Declaration in cmp_ns {
        if decl.name == "cmp" { return true }
    }
    return false
}

priv type_has_to_str := func(scope: TypeScope, type_name: Str) returns Bool {
    ref sdef : Expr = scope.get_struct(type_name)
    if sdef.is_null() { return false }
    ref ts_ns : Vec(Declaration) = def_ns_decls(sdef)
    for decl : Declaration in ts_ns {
        if decl.name == "to_str" { return true }
    }
    return false
}

priv expr_contains_fcall := func(e: Expr) returns Bool {
    if e.node_type.is(NodeType.FCall) { return true }
    for e_i : Expr in e.children {
        if expr_contains_fcall(e_i) { return true }
    }
    return false
}

expr_uses_var := func(e: Expr, name: Str) returns Bool {
    if e.node_type.is(NodeType.FuncDef) { return false }
    switch e.node_type {
    case NodeType.Ident(id):
        if id.ident_name() == name { return true }
    case NodeType.Assign(asgn):
        if asgn.name == name { return true }
    case:
    }
    for e_i : Expr in e.children {
        if expr_uses_var(e_i, name) { return true }
    }
    return false
}

expr_contains_decl := func(e: Expr, name: Str) returns Bool {
    if e.node_type.is(NodeType.FuncDef) { return false }
    switch e.node_type {
    case NodeType.Decl(dd):
        if dd.name == name { return true }
    case:
    }
    for e_i : Expr in e.children {
        if expr_contains_decl(e_i, name) { return true }
    }
    return false
}

expr_used_in_nested_func := func(e: Expr, name: Str) returns Bool {
    switch e.node_type {
    case NodeType.FuncDef(fdef):
        for p : Declaration in fdef.params {
            if p.name == name { return false }
        }
        if e.children.len() > 0 {
            return expr_uses_var(e.children[0], name)
        }
        return false
    case:
    }
    for e_i : Expr in e.children {
        if expr_used_in_nested_func(e_i, name) { return true }
    }
    return false
}

type_prefix := func(t: Type) returns Str {
    switch t {
    case Type.Primitive(Primitive.I64): return "I64"
    case Type.Primitive(Primitive.U8): return "U8"
    case Type.Primitive(Primitive.I8): return "I8"
    case Type.Primitive(Primitive.I16): return "I16"
    case Type.Primitive(Primitive.U16): return "U16"
    case Type.Primitive(Primitive.I32): return "I32"
    case Type.Primitive(Primitive.U32): return "U32"
    case Type.Primitive(Primitive.U64): return "U64"
    case Type.Primitive(Primitive.F32): return "F32"
    case Type.Primitive(Primitive.Bool): return "Bool"
    case Type.None: return "None"
    case Type.Struct(s):
        if s.len() > 0 { return s.clone() }
        return "compound"
    case Type.Enum(s):
        if s.len() > 0 { return s.clone() }
        return "compound"
    case Type.Custom(s):
        // #165 step 1: Custom(name) is the unresolved form of
        // Struct(name)/Enum(name). Treat them the same here so type
        // comparisons (e.g. argument-type checks) see a consistent
        // prefix string.
        if s.len() > 0 { return s.clone() }
        return "compound"
    case: return "v"
    }
}

type_to_name := func(t: Type) returns Str {
    name := til_type_name(t)
    if name.len() > 0 { return name }
    switch t {
    case Type.Primitive(Primitive.I64): return I64Name.clone()
    case Type.Primitive(Primitive.U8): return U8Name.clone()
    case Type.Primitive(Primitive.I8): return I8Name.clone()
    case Type.Primitive(Primitive.I16): return I16Name.clone()
    case Type.Primitive(Primitive.U16): return U16Name.clone()
    case Type.Primitive(Primitive.I32): return I32Name.clone()
    case Type.Primitive(Primitive.U32): return U32Name.clone()
    case Type.Primitive(Primitive.U64): return U64Name.clone()
    case Type.Primitive(Primitive.F32): return F32Name.clone()
    case Type.Primitive(Primitive.Bool): return BoolName.clone()
    case Type.Body: return "Body"
    case: return ""
    }
}

make_closure_delete_call := func(var_name: Str, src: Expr) returns Expr {
    mut call := Expr.new(NodeType.FCall(FCallData()), src.line, src.col)
    call.set_til_type(Type.None)

    mut callee := Expr.new(ident_node("til_closure_delete"), src.line, src.col)
    call.add_child(own callee)

    mut arg := Expr.new(ident_node(var_name), src.line, src.col)
    arg.set_til_type(Type.FuncPtr)
    call.add_child(own arg)

    return call
}

make_delete_call := func(var_name: Str, shallow type: Type, arg_is_own: Bool, call_free: Bool, src: Expr) returns Expr {
    if type.is_funcptr().or(type.is(Type.Body)) {
        if call_free.not() { return NULL }
        return make_closure_delete_call(var_name, src)
    }
    tname := type_to_name(type)
    if tname.len() == 0 { return NULL }

    mut call := Expr.new(NodeType.FCall(FCallData()), src.line, src.col)
    call.set_til_type(Type.None)

    mut type_id := Expr.new(ident_node(tname), src.line, src.col)
    type_id.set_til_type(Type.Custom(tname.clone()))

    mut fa := Expr.new(field_access_node("delete"), src.line, src.col)
    fa.add_child(own type_id)
    call.add_child(own fa)

    mut arg := Expr.new(ident_node(var_name), src.line, src.col)
    arg.set_til_type(type)
    if arg_is_own { set_own_arg(call, call.children.len()) }
    call.add_child(own arg)

    mut cf_lit := Expr.new(NodeType.Literal(Literal.Bool(call_free)), src.line, src.col)
    call.add_child(own cf_lit)

    return call
}

// True when `e` (or any sub-expression) is a struct constructor FCall of the
// shape `Type(..., var_name, ...)` where var_name is at the position of a
// field whose declared own_type is `Shallow`. In that case the constructor
// emits `dst->field = *var_name`, i.e. value-copies the inner Str/Vec/etc.
// from var_name's heap wrapper into the field; the field's own destructor
// will free the inner data when the parent struct is destroyed, but nothing
// frees var_name's wrapper, so it leaks.
//
// This is the exact shape we want `make_free_call` to follow up. Other
// transfer shapes -- own arg to a function, struct constructor with an Own
// or Ref field -- already consume the wrapper, so we must NOT emit a free.
transfer_is_shallow_field_value_copy := func(e: Expr, var_name: Str, scope: TypeScope) returns Bool {
    expect(e.is_null().not(), "e is null")
    if e.node_type.is(NodeType.FuncDef) { return false }
    if e.node_type.is(NodeType.FCall) {
        if e.children.len() >= 2 {
            fcall_sname := til_type_name(e.til_type())
            if fcall_sname.len() > 0 {
                switch e.children[0].node_type {
                case NodeType.Ident(c0s):
                    if c0s.ident_name() == fcall_sname {
                        ref sdef : Expr = scope.get_struct(fcall_sname)
                        if sdef.is_null().not() {
                            switch sdef.node_type {
                            case NodeType.StructDef(tsv_sdd):
                                // Walk every constructor arg. For each
                                // arg that resolves to `Ident(var_name)`
                                // (positional or NamedArg-wrapped), look
                                // up the matching field by position
                                // (positional) or by name (NamedArg) to
                                // check its own_type. The previous loop
                                // only checked positional Ident args and
                                // missed every Type(field = local) form,
                                // so the local's wrapper leaked there.
                                for ci in 1..e.children.len() {
                                    ref arg : Expr = e.children[ci]
                                    mut inner : Expr = arg
                                    mut field_name : Str = ""
                                    switch arg.node_type {
                                    case NodeType.NamedArg(nan):
                                        field_name = nan
                                        if arg.children.len() > 0 { inner = arg.children[0] }
                                    case:
                                    }
                                    switch inner.node_type {
                                    case NodeType.Ident(an):
                                        if an.ident_name().eq(var_name).not() { continue }
                                        // Resolve the receiving field.
                                        mut fd_idx : I32 = -1
                                        if field_name.is_empty() {
                                            // Positional: arg position ci-1 maps to field index.
                                            fd_idx = ci.sub(1).to_i32()
                                        } else {
                                            for fi in 0..tsv_sdd.fields.len() {
                                                if tsv_sdd.fields[fi].name == field_name { fd_idx = fi.to_i32(); break }
                                            }
                                        }
                                        if fd_idx < 0 { continue }
                                        if fd_idx.to_usize() >= tsv_sdd.fields.len() { continue }
                                        ref fld_decl : Declaration = tsv_sdd.fields[fd_idx.to_usize()]
                                        if fld_decl.own_type.is(OwnType.Shallow).not() { continue }
                                        if type_ctor_consumes(fld_decl.til_type) {
                                            return true
                                        }
                                    case:
                                    }
                                }
                            case:
                            }
                        }
                    }
                case:
                }
            }
        }
    }
    for ec : Expr in e.children {
        if transfer_is_shallow_field_value_copy(ec, var_name, scope) { return true }
    }
    return false
}

// `free(own var_name)`: release just the heap wrapper without invoking the
// type's destructor. Used after value-copy ownership transfer to a Shallow
// struct field, where the field's own destructor will free the inner data.
make_free_call := func(var_name: Str, shallow type: Type, src: Expr) returns Expr {
    if type.is_funcptr().or(type.is(Type.Body)) { return make_closure_delete_call(var_name, src) }
    mut call := Expr.new(NodeType.FCall(FCallData()), src.line, src.col)
    call.set_til_type(Type.None)

    mut callee := Expr.new(ident_node("free"), src.line, src.col)
    call.add_child(own callee)

    mut arg := Expr.new(ident_node(var_name), src.line, src.col)
    arg.set_til_type(type)
    set_own_arg(call, call.children.len())
    call.add_child(own arg)

    return call
}

make_clone_call := func(type_name: Str, shallow type: Type, arg: Expr, src: Expr) returns Expr {
    mut call := Expr.new(NodeType.FCall(FCallData()), src.line, src.col)
    call.set_til_type(type)
    if type.is(Type.Struct).and(til_type_name(type).len().eq(0)) {
        call.set_til_type(Type.Struct(type_name.clone()))
    } else if type.is(Type.Enum).and(til_type_name(type).len().eq(0)) {
        call.set_til_type(Type.Enum(type_name.clone()))
    }

    mut type_id := Expr.new(ident_node(type_name), src.line, src.col)
    type_id.set_til_type(Type.Custom(type_name.clone()))

    mut fa := Expr.new(field_access_node("clone"), src.line, src.col)
    fa.add_child(own type_id)
    call.add_child(own fa)

    call.add_child(own arg.clone())
    return call
}

// Wrap `arg` with `T.to_str(arg)`, used to auto-coerce non-Str args
// passed to a `..Str` variadic param so `print(1+1)` etc. work.
priv make_to_str_call := func(type_name: Str, arg: Expr) returns Expr {
    mut call := make_ns_call(type_name, "to_str", Type.Struct("Str"), arg)
    call.add_child(own arg.clone())
    return call
}

make_ns_call := func(sname: Str, method: Str, shallow ret_type: Type, src: Expr) returns Expr {
    mut call := Expr.new(NodeType.FCall(FCallData()), src.line, src.col)
    call.set_til_type(ret_type)

    mut type_id := Expr.new(ident_node(sname), src.line, src.col)
    type_id.set_til_type(Type.Custom(sname.clone()))

    mut fa := Expr.new(field_access_node(method), src.line, src.col)
    fa.add_child(own type_id)
    call.add_child(own fa)
    return call
}

variadic_array_type_name := func(scope: TypeScope, elem_type: Str) returns Str {
    if scope.get_struct("Array").is_null().not() { return "Array" }
    return format("Array__", elem_type)
}

priv variadic_vec_type_name := func(scope: TypeScope, elem_type: Str) returns Str {
    if scope.get_struct("Vec").is_null().not() { return "Vec" }
    return format("Vec__", elem_type)
}

// True when `expr` is a syntactic enum-variant construction that supplies a
// payload, e.g. NodeType.Literal(Literal.SetLit). Bare variants (a plain
// FieldAccess like NodeType.Literal) and ordinary calls returning an enum are
// not matched. Used to reject such arguments to is(), which compares only the
// outer tag and so ignores the payload entirely.
priv is_enum_variant_ctor_with_payload := func(expr: Expr, scope: TypeScope) returns Bool {
    if expr.node_type.is(NodeType.FCall).not() { return false }
    // callee + at least one payload argument
    if expr.children.len() < 2 { return false }
    ref callee : Expr = expr.children[0]
    if callee.node_type.is(NodeType.FieldAccess).not() { return false }
    if callee.children.len() == 0 { return false }
    mut variant := ""
    switch callee.node_type {
    case NodeType.FieldAccess(fad): variant = Str.clone(fad.field_access_name())
    case: return false
    }
    ref base : Expr = callee.children[0]
    mut tn := ""
    switch base.node_type {
    case NodeType.Ident(idd): tn = Str.clone(idd.ident_name())
    case: return false
    }
    ref sdef : Expr = scope.get_struct(tn)
    if sdef.is_null() { return false }
    if sdef.node_type.is(NodeType.EnumDef).not() { return false }
    ref vc_ns : Vec(Declaration) = def_ns_decls(sdef)
    for fd : Declaration in vc_ns {
        if fd.name.eq(variant).not() { continue }
        if fd.default_value.is_null() { return false }
        switch fd.default_value.node_type {
        case NodeType.FuncDef(vfd):
            return vfd.is_enum_variant_ctor
        case: return false
        }
    }
    return false
}

priv check_own_args := func(fdef: Expr, fcall: Expr, var_name: Str) returns Bool {
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        if fd.params.len() == 0 { return false }
        for i in 0..fd.params.len() {
            if i + 1 >= fcall.children.len() { return false }
            ref p : Declaration = fd.params[i]
            if p.own_type.is(OwnType.Own) {
                ref arg : Expr = fcall.children[i + 1]
                switch arg.node_type {
                case NodeType.Ident(ai):
                    if ai.ident_name() == var_name { return true }
                case:
                }
            }
        }
        return false
    case:
        return false
    }
}

priv fcall_has_own_arg := func(fcall: Expr, var_name: Str, scope: TypeScope) returns Bool {
    if fcall.node_type.is(NodeType.FCall).not() { return false }
    if fcall.children.len() < 2 { return false }
    // Struct constructor
    fcall_sname := til_type_name(fcall.til_type())
    if fcall_sname.len() > 0 {
        switch fcall.children[0].node_type {
        case NodeType.Ident(c0s):
            if c0s.ident_name() == fcall_sname {
                ref sdef : Expr = scope.get_struct(fcall_sname)
                if sdef.is_null().not() {
                    switch sdef.node_type {
                    case NodeType.StructDef(fhoa_sdd):
                        for fi in 0..fhoa_sdd.fields.len() {
                            ref fld_decl : Declaration = fhoa_sdd.fields[fi]
                            arg_idx := fi + 1
                            if arg_idx < fcall.children.len() {
                                ref arg : Expr = fcall.children[arg_idx]
                                switch arg.node_type {
                                case NodeType.Ident(an):
                                    if an.ident_name().eq(var_name).and(fld_decl.own_type.is(OwnType.Ref).not()) {
                                        if fld_decl.own_type.is(OwnType.Own).or(type_ctor_consumes(fld_decl.til_type)) {
                                            return true
                                        }
                                    }
                                case:
                                }
                            }
                        }
                    case:
                    }
                }
            }
        case:
        }
    }
    // Direct call
    switch fcall.children[0].node_type {
    case NodeType.Ident(fn_name):
        ref fb : TypeBinding = scope.get_binding(fn_name.ident_name())
        if fb.is_null().not() {
            ref fb_fd : Expr = scope.lookup_func(fb.name)
            if fb_fd.is_null() { return false }
            return check_own_args(fb_fd, fcall, var_name)
        }
        return false
    case NodeType.FieldAccess(method):
        // Namespace method call
        if fa_is_ns(fcall.children[0], scope) {
            ref type_node : Expr = fcall.children[0].children[0]
            switch type_node.node_type {
            case NodeType.Ident(tn):
                ref sdef : Expr = scope.get_struct(tn.ident_name())
                if sdef.is_null() { return false }
                ref oa_ns : Vec(Declaration) = def_ns_decls(sdef)
                for fd : Declaration in oa_ns {
                    if fd.name == method.field_access_name() {
                        if fd.default_value.is_null().not().and(fd.default_value.node_type.is(NodeType.FuncDef)) {
                            return check_own_args(fd.default_value, fcall, var_name)
                        }
                    }
                }
            case:
            }
        }
    case:
    }
    return false
}

expr_transfers_own := func(e: Expr, var_name: Str, scope: TypeScope, ctx: Context) returns Bool {
    switch e.node_type {
    case NodeType.FuncDef(fd):
        for cap : Declaration in fd.captures {
            if cap.name.eq(var_name).and(cap.own_type.is(OwnType.Own)) { return true }
        }
        return false
    case:
    }
    if fcall_has_own_arg(e, var_name, scope) { return true }
    // FieldAssign is a transfer only when the receiving field is Own --
    // Ref fields take a borrow (caller keeps ownership), Shallow fields
    // value-copy (caller keeps too). The old check `not Shallow`
    // misclassified Ref-field assignments as transfers, so a local
    // assigned into a ref-typed field never got its scope-end delete.
    // (Issue #109: test/ref.til's `a.next = b` where `next` is `ref mut
    // next : RefNode` leaked b's 16-byte wrapper.)
    if e.node_type.is(NodeType.FieldAssign).and(e.fa_own_type(scope).is(OwnType.Own)) {
        if e.children.len() > 1 {
            switch e.children[1].node_type {
            case NodeType.Ident(ei):
                if ei.ident_name() == var_name { return true }
            case:
            }
        }
    }
    for e_i : Expr in e.children {
        if expr_transfers_own(e_i, var_name, scope, ctx) { return true }
    }
    return false
}

priv expr_is_borrow_source := func(e: Expr, scope: TypeScope) returns Bool {
    expect(e.is_null().not(), "e is null")
    if e.node_type.is_literal_null() { return true }
    if e.node_type.is(NodeType.FCall).and(fcall_returns_ref(e, scope).neq(0)) { return true }
    switch e.node_type {
    case NodeType.Ident(id):
        sf := scope.find(id.ident_name())
        switch sf {
        case ScopeFind.Found(b):
            if b.own_type.is(OwnType.Ref).or(b.is_param) { return true }
            // Owned compound locals are pointers in C -- valid borrow source
            if is_aggregate(b.type) { return true }
        case:
        }
    case:
    }
    if e.node_type.is(NodeType.FieldAccess) {
        if fa_is_ns(e, scope) { return false }
        return expr_is_borrow_source(e.children[0], scope)
    }
    return false
}

priv expr_is_stable_field_base := func(e: Expr, scope: TypeScope) returns Bool {
    expect(e.is_null().not(), "e is null")
    if expr_is_borrow_source(e, scope) { return true }
    switch e.node_type {
    case NodeType.Ident(id):
        sf := scope.find(id.ident_name())
        switch sf {
        case ScopeFind.Found(b):
            if scope.lookup_func(b.name).is_null().not() { return false }
            if scope.struct_def_of(b.name).is_null().not() { return false }
            return true
        case:
            return false
        }
    case:
    }
    if e.node_type.is(NodeType.FieldAccess) {
        if fa_is_ns(e, scope) { return false }
        return expr_is_stable_field_base(e.children[0], scope)
    }
    return false
}

priv expr_is_ref_decl_source := func(e: Expr, scope: TypeScope) returns Bool {
    expect(e.is_null().not(), "e is null")
    if expr_is_borrow_source(e, scope) { return true }
    if e.node_type.is(NodeType.FieldAccess) {
        if fa_is_ns(e, scope) { return false }
        return expr_is_stable_field_base(e.children[0], scope)
    }
    return false
}

// Asap-destruction helpers (LocalInfo, alias_used_in_stmts,
// collect_scope_locals, extend_ref_local_lifetimes,
// check_use_after_own_transfer, promote_own_transferred_locals,
// insert_exit_deletes / insert_nested_exit_deletes /
// insert_exit_deletes_into_stmt / insert_post_stmt_deletes /
// insert_assign_delete, insert_free_calls) moved to
// src/self/garbager.til. See issue #204 / doc/pipeline.org step 5.
// til_type derives Type.Struct("Str") and Type.Primitive(Primitive.Bool) for LiteralStr
// and LiteralBool directly from node_type, so this function only needs
// to handle the two variants with non-trivial inference: LiteralNum's
// I64-default-unless-already-narrowed (parser writes Type.Primitive(Primitive.U8) for char
// literals) and LiteralNull's initial Type.Dynamic (narrow_dynamic may
// mutate it post-write, so the field is still authoritative for that
// variant).
priv infer_literal_expr := func(mut expr: Expr) {
    switch expr.node_type {
    case NodeType.Literal(Literal.Num):
        if is_numeric_type(expr.til_type()).not() {
            expr.set_til_type(Type.Primitive(Primitive.I64))
        }
    case NodeType.Literal(Literal.Null):
        expr.set_til_type(Type.Dynamic)
    case:
    }
}

priv narrow_dynamic := func(mut expr: Expr, target: Type) {
    if expr.til_type().is(Type.Dynamic).not() { return }
    if target.is(Type.Dynamic) { return }
    if target.is(Type.Unknown) { return }
    expr.set_til_type(target)
}

fcall_is_get_method := func(fcall: Expr) returns Bool {
    if fcall.node_type.is(NodeType.FCall).not() { return false }
    if fcall.children.len() == 0 { return false }
    ref callee : Expr = fcall.children[0]
    switch callee.node_type {
    case NodeType.FieldAccess(fad):
        return fad.field_access_name() == "get"
    case:
        return false
    }
}

fcall_returns_ref := func(fcall: Expr, scope: TypeScope) returns I32 {
    if fcall.node_type.is(NodeType.FCall).not() { return 0 }
    if fcall.children.len() == 0 { return 0 }
    ref callee : Expr = fcall.children[0]
    switch callee.node_type {
    case NodeType.Ident(cn):
        ref cb : TypeBinding = scope.get_binding(cn.ident_name())
        if cb.is_null().not() {
            ref cb_fd : Expr = scope.lookup_func(cb.name)
            if cb_fd.is_null() { return 0 }
            switch cb_fd.node_type {
            case NodeType.FuncDef(cfd):
                return cfd.return_own_type.is(OwnType.Ref)
            case:
                return 0
            }
        }
        return 0
    case NodeType.FieldAccess(cfa):
        if fa_is_ns(callee, scope) {
            switch callee.children[0].node_type {
            case NodeType.Ident(cti):
                ref sdef : Expr = scope.get_struct(cti.ident_name())
                if sdef.is_null() { return 0 }
                ref cfa_ns : Vec(Declaration) = def_ns_decls(sdef)
                for fd : Declaration in cfa_ns {
                    if fd.name == cfa.field_access_name() {
                        if fd.default_value.is_null().not() {
                            switch fd.default_value.node_type {
                            case NodeType.FuncDef(ffd):
                                return ffd.return_own_type.is(OwnType.Ref)
                            case:
                            }
                        }
                    }
                }
            case:
            }
        }
        if callee.children.len() > 0 {
            ref obj : Expr = callee.children[0]
            sname := til_type_name(obj.til_type())
            if sname.len() > 0 {
                ref sdef2 : Expr = scope.get_struct(sname)
                ref method : Expr = find_namespace_func(sdef2, cfa.field_access_name(), scope)
                if method.is_null().not() {
                    switch method.node_type {
                    case NodeType.FuncDef(ffd2):
                        return ffd2.return_own_type.is(OwnType.Ref)
                    case:
                    }
                }
            }
        }
    case:
    }
    return 0
}

// Parallel to fcall_returns_ref: returns 1 when the FCall's callee is
// declared `returns shallow T`. Used by collect_scope_locals to keep
// the typer-emitted cleanup's call_free bool consistent with the
// builder's shallow-return stack-alloc path (no malloc, so freeing
// would touch a stack pointer).
fcall_returns_shallow := func(fcall: Expr, scope: TypeScope) returns I32 {
    if fcall.node_type.is(NodeType.FCall).not() { return 0 }
    if fcall.children.len() == 0 { return 0 }
    ref callee : Expr = fcall.children[0]
    switch callee.node_type {
    case NodeType.Ident(cn):
        ref cb : TypeBinding = scope.get_binding(cn.ident_name())
        if cb.is_null().not() {
            ref cb_fd : Expr = scope.lookup_func(cb.name)
            if cb_fd.is_null() { return 0 }
            switch cb_fd.node_type {
            case NodeType.FuncDef(cfd):
                return cfd.return_own_type.is(OwnType.Shallow)
            case:
                return 0
            }
        }
        return 0
    case NodeType.FieldAccess(cfa):
        if fa_is_ns(callee, scope) {
            switch callee.children[0].node_type {
            case NodeType.Ident(cti):
                ref sdef : Expr = scope.get_struct(cti.ident_name())
                if sdef.is_null() { return 0 }
                ref cfa_ns : Vec(Declaration) = def_ns_decls(sdef)
                for fd : Declaration in cfa_ns {
                    if fd.name == cfa.field_access_name() {
                        if fd.default_value.is_null().not() {
                            switch fd.default_value.node_type {
                            case NodeType.FuncDef(ffd):
                                return ffd.return_own_type.is(OwnType.Shallow)
                            case:
                            }
                        }
                    }
                }
            case:
            }
        }
    case:
    }
    return 0
}

// ---- switch / match / for-in TYPE INFERENCE (moved back from desugarer) ----
// These drive type inference (infer_expr / infer_body) and emit the
// exhaustiveness / pattern type errors, so they live in the typer. The pure
// lowering primitives they invoke (make_switch_case_condition, the if/elif and
// while builders) stay in desugarer.til.
// Issue #200: per-arm coverage trie for nested switch exhaustiveness.
// Each node corresponds to one enum's variants. ~fully_covered~ means the
// pattern bound the entire value at this level (e.g. ~case X.A(v):~ or
// ~case X.A:~) so no inner walk is needed. Otherwise the parallel vecs
// ~sub_names~ / ~sub_nodes~ hold per-variant child coverage; an empty
// ~sub_nodes~ entry means "the variant's payload was never decomposed"
// and is only fully_covered iff its own ~fully_covered~ bit is set.
priv CoverageNode := struct {
    fully_covered := false
    sub_names := Vec(Str).new()
    sub_nodes := Vec(CoverageNode).new()
}

// Seed a node with empty per-variant sub-coverage for an enum_def.
priv init_coverage_for_enum := func(mut node: CoverageNode, enum_def: Expr) {
    if enum_def.is_null() { return }
    switch enum_def.node_type {
    case NodeType.EnumDef(cn_edd):
        for vn : Str in cn_edd.variants {
            node.sub_names.push(own vn.clone())
            node.sub_nodes.push(own CoverageNode())
        }
    case:
    }
}

priv coverage_sub_index := func(coverage: CoverageNode, variant_name: Str) returns I32 {
    for csi in 0..coverage.sub_names.len() {
        ref n : Str = coverage.sub_names[csi]
        if n == variant_name { return csi.to_i32() }
    }
    return -1
}

// Read-only mirror of mark_pattern_coverage: true iff every value the
// pattern could match has already been captured by an earlier (unguarded)
// arm in this switch -- i.e. the arm carrying this pattern is dead.
// Patterns the trie doesn't statically describe (value literals, struct
// patterns, non-enum subjects) return false so a more permissive checker
// or guard-protected arm doesn't get a false positive.
priv is_pattern_covered := func(scope: TypeScope, coverage: CoverageNode, expected_type_name: Str, pattern: Expr) returns Bool {
    if expected_type_name.len() == 0 { return false }
    ref enum_def : Expr = scope.get_struct(expected_type_name)
    if enum_def.is_null() { return false }
    if enum_def.node_type.is(NodeType.EnumDef).not() { return false }

    if pattern.node_type.is(NodeType.FieldAccess) {
        if pattern.children.len() > 0 {
            if pattern.children[0].node_type.is(NodeType.Ident) {
                mut type_name := ""
                mut variant_name := ""
                switch pattern.children[0].node_type {
                case NodeType.Ident(tn): type_name = Str.clone(tn.ident_name())
                case:
                }
                switch pattern.node_type {
                case NodeType.FieldAccess(vn): variant_name = Str.clone(vn.field_access_name())
                case:
                }
                if type_name == expected_type_name {
                    idx := coverage_sub_index(coverage, variant_name)
                    if idx >= 0 {
                        ref sub : CoverageNode = coverage.sub_nodes[idx.to_usize()]
                        return sub.fully_covered
                    }
                }
            }
        }
        return false
    }

    if pattern.node_type.is(NodeType.FCall) {
        if pattern.children.len() == 2 {
            ref callee : Expr = pattern.children[0]
            if callee.node_type.is(NodeType.FieldAccess) {
                if callee.children.len() > 0 {
                    if callee.children[0].node_type.is(NodeType.Ident) {
                        mut type_name2 := ""
                        mut variant_name2 := ""
                        switch callee.children[0].node_type {
                        case NodeType.Ident(tn2): type_name2 = Str.clone(tn2.ident_name())
                        case:
                        }
                        switch callee.node_type {
                        case NodeType.FieldAccess(vn2): variant_name2 = Str.clone(vn2.field_access_name())
                        case:
                        }
                        if type_name2 == expected_type_name {
                            idx2 := coverage_sub_index(coverage, variant_name2)
                            if idx2 >= 0 {
                                ref sub2 : CoverageNode = coverage.sub_nodes[idx2.to_usize()]
                                if sub2.fully_covered { return true }
                                ref inner_pat : Expr = pattern.children[1]
                                if inner_pat.node_type.is(NodeType.Ident) {
                                    return false
                                }
                                vt_idx := enum_variant_index(enum_def, variant_name2)
                                if vt_idx >= 0 {
                                    inner_type_name := enum_variant_type(enum_def, vt_idx)
                                    if inner_type_name.len() > 0 {
                                        ref inner_def : Expr = scope.get_struct(inner_type_name)
                                        if inner_def.is_null().not().and(inner_def.node_type.is(NodeType.EnumDef)) {
                                            if sub2.sub_names.len() > 0 {
                                                return is_pattern_covered(scope, sub2, inner_type_name, inner_pat)
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
        return false
    }
    return false
}

// Walk a case pattern against the (expected) enum type and update the
// coverage trie. Returns silently for patterns that don't statically
// describe a variant of `expected_type_name` (e.g. ~case 42:~, or a
// pattern targeting a different enum -- those will surface as other
// type errors).
priv mark_pattern_coverage := func(scope: TypeScope, mut coverage: CoverageNode, expected_type_name: Str, pattern: Expr) {
    if expected_type_name.len() == 0 { return }
    ref enum_def : Expr = scope.get_struct(expected_type_name)
    if enum_def.is_null() { return }
    if enum_def.node_type.is(NodeType.EnumDef).not() { return }

    // `case Type.Variant` (bare).
    if pattern.node_type.is(NodeType.FieldAccess) {
        if pattern.children.len() > 0 {
            if pattern.children[0].node_type.is(NodeType.Ident) {
                mut type_name := ""
                mut variant_name := ""
                switch pattern.children[0].node_type {
                case NodeType.Ident(tn): type_name = Str.clone(tn.ident_name())
                case:
                }
                switch pattern.node_type {
                case NodeType.FieldAccess(vn): variant_name = Str.clone(vn.field_access_name())
                case:
                }
                if type_name == expected_type_name {
                    idx := coverage_sub_index(coverage, variant_name)
                    if idx >= 0 {
                        ref mut sub : CoverageNode = coverage.sub_nodes[idx.to_usize()]
                        sub.fully_covered = true
                    }
                }
            }
        }
        return
    }

    // `case Type.Variant(inner)` -- inner is either a binding (Ident, marks
    // the variant fully covered) or another enum pattern (recurse).
    if pattern.node_type.is(NodeType.FCall) {
        if pattern.children.len() == 2 {
            ref callee : Expr = pattern.children[0]
            if callee.node_type.is(NodeType.FieldAccess) {
                if callee.children.len() > 0 {
                    if callee.children[0].node_type.is(NodeType.Ident) {
                        mut type_name2 := ""
                        mut variant_name2 := ""
                        switch callee.children[0].node_type {
                        case NodeType.Ident(tn2): type_name2 = Str.clone(tn2.ident_name())
                        case:
                        }
                        switch callee.node_type {
                        case NodeType.FieldAccess(vn2): variant_name2 = Str.clone(vn2.field_access_name())
                        case:
                        }
                        if type_name2 == expected_type_name {
                            idx2 := coverage_sub_index(coverage, variant_name2)
                            if idx2 >= 0 {
                                ref mut sub2 : CoverageNode = coverage.sub_nodes[idx2.to_usize()]
                                ref inner_pat : Expr = pattern.children[1]
                                if inner_pat.node_type.is(NodeType.Ident) {
                                    // Whole-payload binding -> covers all sub-variants.
                                    sub2.fully_covered = true
                                } else {
                                    // Nested pattern: find inner enum and recurse.
                                    vt_idx := enum_variant_index(enum_def, variant_name2)
                                    if vt_idx >= 0 {
                                        inner_type_name := enum_variant_type(enum_def, vt_idx)
                                        if inner_type_name.len() > 0 {
                                            ref inner_def : Expr = scope.get_struct(inner_type_name)
                                            if inner_def.is_null().not().and(inner_def.node_type.is(NodeType.EnumDef)) {
                                                if sub2.sub_names.len() == 0 {
                                                    init_coverage_for_enum(sub2, inner_def)
                                                }
                                                mark_pattern_coverage(scope, sub2, inner_type_name, inner_pat)
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
        return
    }
}

// Collect "Outer.Inner.Leaf"-style paths for any uncovered variants of
// `enum_def` under `coverage`. A variant is OK iff fully_covered or
// (its payload is itself an enum AND its sub-coverage is exhaustive).
priv collect_missing_paths := func(scope: TypeScope, coverage: CoverageNode, enum_def: Expr, prefix: Str, mut out: Vec(Str), ctx: Context) {
    if enum_def.is_null() { return }
    switch enum_def.node_type {
    case NodeType.EnumDef(cm_edd):
        for cmi in 0..cm_edd.variants.len() {
            ref vn : Str = cm_edd.variants[cmi]
            ref sub : CoverageNode = coverage.sub_nodes[cmi]
            mut current := ""
            if prefix.len() == 0 {
                current = vn.clone()
            } else {
                current = format(prefix, ".", vn)
            }
            if sub.fully_covered { continue }
            mut recursed := false
            vt_idx := enum_variant_index(enum_def, vn)
            if vt_idx >= 0 {
                inner_type_name := enum_variant_type(enum_def, vt_idx)
                if inner_type_name.len() > 0 {
                    ref inner_def : Expr = scope.get_struct(inner_type_name)
                    if inner_def.is_null().not().and(inner_def.node_type.is(NodeType.EnumDef)) {
                        if sub.sub_names.len() > 0 {
                            collect_missing_paths(scope, sub, inner_def, current, out, ctx)
                            recursed = true
                        }
                    }
                }
            }
            if recursed.not() {
                out.push(own current.clone())
            }
        }
    case:
    }
}

// Issue #244: type a `match` expression by computing the common arm type.
// Each arm body is a single value-expression; the whole match yields that
// type. The actual lowering (result temp + synthetic switch) happens at the
// statement level in lower_matches_in_stmt; here we only set the node's type
// so enclosing decls/args/returns/nested-matches see it. The common type is
// taken from the first arm; the synthetic switch's per-arm assignment then
// enforces that every other arm agrees (a mismatch surfaces as an assign
// type error). Arm values are type-checked on a throwaway clone so the real
// arm nodes stay pristine for the desugar that re-infers them.
priv infer_match_expr := proc(scope: TypeScope, mut expr: Expr, in_func: I32, ctx: Context) {
    if expr.children.len() == 0 { expr.set_til_type(Type.Unknown); return }
    ref subj : Expr = expr.children[0]
    infer_expr(scope, subj, in_func, ctx)
    // The match's type is the common arm type. Take it from the first arm and
    // check the rest agree, so a mismatch is reported clearly here (rather than
    // surfacing later as a temp-named assignment error from the lowering).
    mut result_t := Type.Unknown
    mut has_t := false
    mut reported := false
    for ci in 1..expr.children.len() {
        arm_t := match_arm_value_type(scope, expr.children[ci], subj, in_func, ctx)
        if has_t.not() {
            result_t = arm_t
            has_t = true
        } else if reported.not().and(arm_t.is(Type.Unknown).not()).and(result_t.is(Type.Unknown).not()).and(arm_t.eq(result_t).not()) {
            expr.children[ci].type_error(format("match arms have incompatible types: '", type_to_name(result_t), "' vs '", type_to_name(arm_t), "'; all arms must yield the same type"), ctx)
            reported = true
        }
    }
    // Arm-type agreement is the one check unique to match (switch arms have no
    // type). Exhaustiveness -- enum and non-enum alike -- is enforced by the
    // shared switch desugar (infer_switch_stmt) once the match is lowered.
    expr.set_til_type(result_t)
}

// Type of one match arm's value-expression. Clones the arm body (so the real
// node is untouched), prepends the pattern's payload bindings via the shared
// switch helper, infers the bindings, then infers the value expression.
priv match_arm_value_type := proc(scope: TypeScope, case_node: Expr, subj: Expr, in_func: I32, ctx: Context) returns Type {
    arm_scope := TypeScope(parent = scope)
    mut body_idx : USize = 0
    mut has_pattern := false
    if case_node.children.len() == 1 {
        body_idx = 0                 // default `case:` -- child(0) is the Body
    } else if case_node.children.len() == 3 {
        body_idx = 2                 // guarded -- [pattern, guard, Body]
        has_pattern = true
    } else {
        body_idx = 1                 // [pattern, Body]
        has_pattern = true
    }
    mut trial := case_node.children[body_idx].clone()
    if has_pattern {
        sw_ref := subj.clone()
        make_switch_case_condition(arm_scope, trial, case_node.children[0], sw_ref, case_node.line, case_node.col)
    }
    mut t := Type.Unknown
    if trial.children.len() > 0 {
        last_idx := trial.children.len() - 1
        mut k : USize = 0
        while k < last_idx {
            infer_body_stmt(arm_scope, trial, k, in_func, 0, 0, 0, ctx)
            k++
        }
        infer_expr(arm_scope, trial.children[last_idx], in_func, ctx)
        t = trial.children[last_idx].til_type()
    }
    return t
}

// Lower every top-level Match in body.children[stmt_idx] into a result temp plus
// the match itself (tagged with that temp so the shared switch desugar handles
// it), spliced as new statements before stmt_idx. Each Match node is replaced
// in place by an Ident referencing its result temp. Returns the number of
// statements inserted, so the caller can advance past them to type-check the
// now-match-free statement.
priv lower_matches_in_stmt := proc(scope: TypeScope, mut body: Expr, stmt_idx: USize, in_func: I32, in_loop: I32, returns_ref: I32, ctx: Context) returns USize {
    mut pre := Vec(Expr).new()
    ref mut stmt : Expr = body.children[stmt_idx]
    replace_matches_rec(scope, stmt, in_func, in_loop, returns_ref, ctx, pre)
    inserted := pre.len()
    splice_stmts_before(body, stmt_idx, pre)
    return inserted
}

// Walk `node`, replacing each top-level Match child with an Ident to its
// lowered result temp and collecting the temp's setup statements into `pre`.
// Does not descend into a Match (its arms are lowered by lower_one_match's own
// infer_body pass) nor into nested blocks/definitions (handled separately).
priv replace_matches_rec := proc(scope: TypeScope, mut node: Expr, in_func: I32, in_loop: I32, returns_ref: I32, ctx: Context, mut pre: Vec(Expr)) {
    switch node.node_type {
    case NodeType.Body:      return
    case NodeType.FuncDef:   return
    case NodeType.StructDef: return
    case NodeType.EnumDef:   return
    // #282: do not hoist a match out of a case guard (or body) -- it is
    // conditionally evaluated and infer_switch_stmt lowers it into the
    // pattern-gated position. See stmt_contains_match for the rationale.
    case NodeType.Case:      return
    case:
    }
    mut ci : USize = 0
    while ci < node.children.len() {
        if node.children[ci].node_type.is(NodeType.Match) {
            infer_match_expr(scope, node.children[ci], in_func, ctx)
            mname := lower_one_match(scope, node.children[ci], in_func, in_loop, returns_ref, ctx, pre)
            mut id := Expr.new(ident_node(mname), node.children[ci].line, node.children[ci].col)
            id.set_til_type(node.children[ci].til_type())
            node.children[ci] = id
        } else {
            replace_matches_rec(scope, node.children[ci], in_func, in_loop, returns_ref, ctx, pre)
        }
        ci++
    }
}

// Build the lowering for one (already-typed) Match: a `mut _m := default(T)`
// temp plus the match itself tagged with that temp. The block is inferred here
// (declaring the temp in `scope`, then reaching infer_switch_stmt which turns
// the arms into `_m = <value>` assignments and emits the dispatch, including
// any nested matches in arm values), then its statements are appended to
// `pre`. Returns the temp's name.
priv lower_one_match := proc(scope: TypeScope, match_node: Expr, in_func: I32, in_loop: I32, returns_ref: I32, ctx: Context, mut pre: Vec(Expr)) returns Str {
    line := match_node.line
    col := match_node.col
    result_t := match_node.til_type()
    tname := type_to_name(result_t)
    mname := format("_m_", type_prefix(result_t), "_", ctx.hoist_counter.to_str())
    ctx.hoist_counter++

    mut decl := Expr.new(NodeType.Decl(Declaration(name = mname.clone(), is_mut = true, explicit_type = tname.clone(), til_type = result_t.clone())), line, col)
    decl.add_child(own make_default_value_expr(tname, line, col))

    // Clone the match and tag it with the result temp; the shared switch
    // desugar (infer_switch_stmt, reached via infer_body) turns its arms into
    // `mname = <value>` assignments and emits the dispatch.
    mut match_stmt := match_node.clone()
    switch match_stmt.node_type {
    case NodeType.Match(md): md.result_temp = mname.clone()
    case:
    }

    mut block := Expr.new(NodeType.Body, line, col)
    block.add_child(own decl)
    block.add_child(own match_stmt)
    infer_body(scope, block, in_func, 0, in_loop, returns_ref, 0, ctx)
    for bi in 0..block.children.len() {
        pre.push_take(block.children, bi)
    }
    return mname
}

// Issue #36: a struct pattern that omits fields needs an explicit `..`
// marker. Run on each non-default case BEFORE make_switch_case_condition
// (which is a func and can't call the proc-typed type_error). Skips
// silently for patterns that aren't struct-shaped.
priv validate_struct_pattern_rest := proc(scope: TypeScope, pattern: Expr, ctx: Context) {
    if pattern.node_type.is(NodeType.FCall).not() { return }
    if pattern.children.len() == 0 { return }
    if pattern.children[0].node_type.is(NodeType.Ident).not() { return }
    mut vsp_type_name := ""
    switch pattern.children[0].node_type {
    case NodeType.Ident(vspn): vsp_type_name = Str.clone(vspn.ident_name())
    case:
    }
    mut vsp_all_named := true
    mut vsp_has_rest := false
    for vci in 1..pattern.children.len() {
        ref vsc : Expr = pattern.children[vci]
        if vsc.node_type.is(NodeType.RestPattern) {
            vsp_has_rest = true
        } else if vsc.node_type.is(NodeType.NamedArg).not() {
            vsp_all_named = false
        }
    }
    if vsp_all_named.not() { return }
    ref vsp_def : Expr = scope.get_struct(vsp_type_name)
    if vsp_def.is_null() { return }
    if vsp_def.node_type.is(NodeType.StructDef).not() { return }
    if vsp_has_rest { return }
    switch vsp_def.node_type {
    case NodeType.StructDef(vsp_sdd):
        for vfld : Declaration in vsp_sdd.fields {
            mut vsp_found := false
            for vnai in 1..pattern.children.len() {
                ref vnac : Expr = pattern.children[vnai]
                switch vnac.node_type {
                case NodeType.NamedArg(vnan):
                    if vnan == vfld.name { vsp_found = true }
                case:
                }
            }
            if vsp_found.not() {
                pattern.type_error(format("struct pattern '", vsp_type_name, "' is missing field '", vfld.name, "'; either bind it or add '..' to allow partial matching"), ctx)
            }
        }
    case:
    }
}

// #254: type-check a C-like switch in place, leaving its Switch/Case nodes for
// the backends instead of desugaring to if/elif. Each case body is inferred in
// its own child scope, mirroring infer_if_stmt's branch handling. For an enum
// scrutinee, runs the same coverage/exhaustiveness checks as the desugar path;
// an exhaustive enum switch with no `case:` turns its last case into the
// default so the emitted C switch has a terminal arm (no -Wreturn-type).
priv infer_clike_switch := proc(scope: TypeScope, mut stmt: Expr, in_func: I32, in_loop: I32, returns_ref: I32, ctx: Context) {
    ref sw_expr : Expr = stmt.children[0]
    sw_sname := til_type_name(sw_expr.til_type())
    mut is_enum := false
    is_bool := type_is_primitive(sw_expr.til_type(), Primitive.Bool)
    mut bool_labels := 0
    mut coverage := CoverageNode()
    if sw_expr.til_type().is(Type.Enum).and(sw_sname.len().gt(0)) {
        ref edef : Expr = scope.get_struct(sw_sname)
        if edef.is_null().not() {
            if edef.node_type.is(NodeType.EnumDef) {
                is_enum = true
                init_coverage_for_enum(coverage, edef)
            }
        }
    }
    mut has_default := false
    mut default_line : U32 = 0
    mut default_col : U32 = 0
    mut last_case_idx : USize = 0
    mut has_last_case := false
    for ci in 1..stmt.children.len() {
        ref mut cn : Expr = stmt.children[ci]
        mut body_idx : USize = 1
        if cn.children.len() == 1 {
            body_idx = 0
            has_default = true
            default_line = cn.line
            default_col = cn.col
        } else {
            if is_enum {
                mark_pattern_coverage(scope, coverage, sw_sname, cn.children[0])
                prepend_clike_payload_binding(scope, sw_expr, cn, sw_sname)
            }
            if is_bool { bool_labels = bool_labels + 1 }
            last_case_idx = ci
            has_last_case = true
        }
        ref mut case_body : Expr = cn.children[body_idx]
        case_scope := TypeScope(parent = scope)
        infer_body(case_scope, case_body, in_func, 1, in_loop, returns_ref, 0, ctx)
        garbager_destroy_body(ctx, case_body, case_scope)
        check_unused_locals(case_scope, ctx.path, ctx)
        check_unused_mut_locals(case_scope, ctx.path, ctx)
    }
    if is_enum {
        ref edef2 : Expr = scope.get_struct(sw_sname)
        mut missing := Vec(Str).new()
        collect_missing_paths(scope, coverage, edef2, "", missing, ctx)
        if has_default {
            if missing.len() == 0 {
                type_error_at(ctx.path, default_line, default_col, format("unnecessary default `case:`; all variants of enum '", sw_sname, "' are already covered"), ctx)
            }
        } else if missing.len() > 0 {
            mut msg := format("non-exhaustive switch on enum '", sw_sname, "'; missing cases:")
            for mp : Str in missing {
                if msg.ends_with(":").not() { msg = format(msg, ",") }
                msg = format(msg, " ", mp)
            }
            stmt.type_error(msg, ctx)
        } else if has_last_case {
            ref mut last_cn : Expr = stmt.children[last_case_idx]
            mut bvec := Vec(Expr).new()
            bvec.push_take(last_cn.children, 1)
            last_cn.children.move_from(bvec)
        }
    } else if is_bool {
        // A bool switch covering both true and false with no `case:` is
        // exhaustive; turn the last case into the default so the emitted C
        // switch has a terminal arm (C does not know bool is only 0/1).
        if has_default.not().and(bool_labels.eq(2)).and(has_last_case) {
            ref mut last_cn : Expr = stmt.children[last_case_idx]
            mut bvec := Vec(Expr).new()
            bvec.push_take(last_cn.children, 1)
            last_cn.children.move_from(bvec)
        }
    }
    stmt.set_til_type(Type.None)
}

priv infer_switch_stmt := proc(scope: TypeScope, mut body: Expr, stmt_idx: USize, in_func: I32, in_loop: I32, returns_ref: I32, ctx: Context) returns Bool {
    ref mut stmt : Expr = body.children[stmt_idx]
    ref mut sw_expr : Expr = stmt.children[0]
    sw_line := stmt.line
    sw_col := stmt.col
    // Issue #244: a Match node rides the same desugar -- it is a switch whose
    // arms yield a value. The only difference: each arm body is a single
    // value-expression, which we wrap into `result_temp = <value>` up front so
    // every downstream step (conditions, payload bindings, guards, coverage,
    // unreachable/exhaustiveness diagnostics, if/elif building) is shared
    // verbatim with switch. The result temp itself is declared by the lowering
    // (it must live in the enclosing scope, not this block's scope).
    is_match := stmt.node_type.is(NodeType.Match)
    // Issue #262: a ListPattern case head is only legal on the variadic param
    // of a recursive variadic lazy body, where the loader's recursion-unroll
    // consumes it before typing. One surviving here is a misuse -- reject it
    // loudly instead of letting the pattern desugar into nonsense.
    for lp_ci in 1..stmt.children.len() {
        ref lp_case : Expr = stmt.children[lp_ci]
        if lp_case.node_type.is(NodeType.Case).and(lp_case.children.len().gt(1)) {
            if lp_case.children[0].node_type.is(NodeType.ListPattern) {
                lp_case.type_error("list patterns ('[]', '[x, ..tl]') are only supported matching the variadic param of a recursive variadic lazy_func/lazy_proc body (issue #262)", ctx)
                return false
            }
        }
    }
    mut kind_word := "switch"
    mut result_temp := ""
    if is_match {
        kind_word = "match"
        switch stmt.node_type {
        case NodeType.Match(md): result_temp = md.result_temp.clone()
        case:
        }
        for tci in 1..stmt.children.len() {
            ref tcase : Expr = stmt.children[tci]
            mut tbody_idx : USize = 1
            if tcase.children.len() == 1 { tbody_idx = 0 }
            else if tcase.children.len() == 3 { tbody_idx = 2 }
            ref tvbody : Expr = tcase.children[tbody_idx]
            mut tvalue : Expr = tvbody.children.pop()
            mut tassign := Expr.new(NodeType.Assign(AssignData(name = result_temp.clone())), tvbody.line, tvbody.col)
            tassign.add_child(own tvalue)
            tvbody.add_child(own tassign)
        }
    }
    infer_expr(scope, sw_expr, in_func, ctx)
    // #154: case patterns (`case Color.Red:`) textually reference the
    // subject's enum; credit its declaring file so a pattern-only use
    // doesn't flag the import as unused. Must sit BEFORE the clike
    // dispatch -- payload-free enums lower through infer_clike_switch
    // and return early.
    if sw_expr.til_type().is(Type.Enum) {
        note_cross_file_type_use(scope, ctx, til_type_name(sw_expr.til_type()))
    }
    if switch_is_clike(scope, stmt, sw_expr, is_match) {
        infer_clike_switch(scope, stmt, in_func, in_loop, returns_ref, ctx)
        return false
    }
    mut coverage := CoverageNode()
    mut has_default_case := false
    mut has_switch_enum_def := false
    sw_expr_sname := til_type_name(sw_expr.til_type())
    ref switch_enum_def : Expr = scope.get_struct(sw_expr_sname)
    if sw_expr.til_type().is(Type.Enum).and(sw_expr_sname.len().gt(0)) {
        if switch_enum_def.is_null().not() {
            if switch_enum_def.node_type.is(NodeType.EnumDef) {
                has_switch_enum_def = true
                init_coverage_for_enum(coverage, switch_enum_def)
            }
        }
    }

    mut sw_ref := Expr.new(NodeType.Literal(Literal.Null), sw_line, sw_col)
    mut block := Expr.new(NodeType.Body, stmt.line, stmt.col)
    // #196.B: Never hoist enum-typed subjects. A hoisted local would be
    // either a shallow value copy (whose destructor frees aliased Vec/Str
    // pointers and corrupts the source AST in compile mode) or a deep
    // clone (whose destructor frees clone-owned strings that downstream
    // case-bindings expose via CAP_VIEW pointers in callers like
    // ffi_register). Re-evaluate sw_expr per case condition instead.
    if is_simple_lvalue_expr(sw_expr).or(sw_expr.til_type().is(Type.Enum)) {
        sw_ref = sw_expr.clone()
    } else {
        tp := type_prefix(sw_expr.til_type())
        sw_name := format("_sw_", tp, "_", ctx.hoist_counter.to_str())
        ctx.hoist_counter++
        mut decl := Expr.new(NodeType.Decl(Declaration(name = sw_name.clone())), stmt.line, stmt.col)
        decl.add_child(own sw_expr.clone())
        block.add_child(own decl)
        sw_ref = Expr.new(ident_node(sw_name), sw_line, sw_col)
    }

    // Issue #199: a Case with 3 children is `[pattern, guard, body]`; with
    // 2 children it's `[pattern, body]`. When ANY case in this switch has
    // a guard we can't use a plain if/elif chain -- a failed guard must
    // fall through to the next case, which an if/elif chain cannot model.
    // Instead we hoist a `_sw_matched_<n> := false` flag and emit each
    // case as an independent `if _sw_matched.not().and(cond) { body;
    // _sw_matched = true }`. Guards become an inner `if <guard> { ...
    // _sw_matched = true }` wrapped around the user body so a failed
    // guard leaves _sw_matched false and the next case runs. Plain
    // switches keep the cheaper if/elif chain.
    mut any_guard := false
    for ag_ci in 1..stmt.children.len() {
        ref ag_cn : Expr = stmt.children[ag_ci]
        if ag_cn.children.len() == 3 { any_guard = true }
    }

    mut first_if := Expr.new(NodeType.Body, stmt.line, stmt.col)
    mut has_first_if := false
    mut default_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
    mut has_default_body := false
    // For an exhaustive enum switch with no `case:`, the if/elif chain
    // would have no terminal else and C's -Wreturn-type would fire on
    // value-returning funcs. Stash the last non-guarded case body so we
    // can attach it as the synthetic terminal else after the loop.
    mut last_case_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
    mut has_last_case_body := false

    mut matched_name := ""
    if any_guard {
        matched_name = format("_sw_matched_", ctx.hoist_counter.to_str())
        ctx.hoist_counter++
        mut matched_decl := Expr.new(NodeType.Decl(Declaration(name = matched_name.clone(), is_mut = true, explicit_type = "Bool", til_type = Type.Primitive(Primitive.Bool), own_type = OwnType.Shallow)), stmt.line, stmt.col)
        matched_decl.add_child(own Expr.new(NodeType.Literal(Literal.Bool(false)), stmt.line, stmt.col))
        block.add_child(own matched_decl)
    }

    // Dead-arm detection: any case after a default arm is unreachable
    // (the default absorbs everything earlier cases didn't match). Tracked
    // here as a flag rather than re-scanning the case vec per case.
    mut saw_default := false
    mut default_line : U32 = 0
    mut default_col : U32 = 0

    // #282: once an earlier case's guard/body can leave _err_kind set (a `?`
    // throw), the following independent case `if`s must be gated on
    // `_err_kind == 0` so they don't run after a throw. Tracks that state
    // across the case loop (only meaningful on the any_guard path).
    mut switch_can_throw := false

    for ci in 1..stmt.children.len() {
        ref case_node : Expr = stmt.children[ci]
        if case_node.children.len() == 1 {
            if saw_default {
                case_node.type_error("unreachable default arm; an earlier `case:` already covers everything", ctx)
            }
            default_body = case_node.children[0].clone()
            has_default_body = true
            has_default_case = true
            saw_default = true
            default_line = case_node.line
            default_col = case_node.col
            continue
        }
        mut has_guard := false
        mut body_idx : USize = 1
        if case_node.children.len() == 3 {
            has_guard = true
            body_idx = 2
        }
        ref match_expr : Expr = case_node.children[0]
        ref mut case_body : Expr = case_node.children[body_idx]
        validate_struct_pattern_rest(scope, match_expr, ctx)
        if saw_default {
            case_node.type_error("unreachable case; an earlier `case:` default already covers everything", ctx)
        } else if has_switch_enum_def.and(has_guard.not()) {
            if is_pattern_covered(scope, coverage, sw_expr_sname, match_expr) {
                case_node.type_error("unreachable case; the variant is already fully covered by an earlier arm", ctx)
            }
        }
        // Guards may fail at runtime, so they don't mark the pattern as
        // covered for exhaustiveness.
        if has_switch_enum_def.and(has_guard.not()) {
            mark_pattern_coverage(scope, coverage, sw_expr_sname, match_expr)
        }
        user_stmt_count := case_body.children.len()
        condition := make_switch_case_condition(scope, case_body, match_expr, sw_ref, sw_line, sw_col)

        if any_guard {
            // Build the case_body for the flag-based desugar:
            //   [bindings..., if <guard> { user_stmts; _sw_matched = true }]
            //   or (no guard)
            //   [bindings..., user_stmts..., _sw_matched = true]
            total_count := case_body.children.len()
            n_bindings := total_count - user_stmt_count
            mut all_children := Vec(Expr).new()
            all_children.move_from(case_body.children)
            // Lower bound: the bindings plus the guard-if/user-stmts wrapper
            // pushed below.
            mut new_body := Vec(Expr).with_capacity(n_bindings + 2)
            for bi in 0..n_bindings {
                new_body.push_take(all_children, bi)
            }
            mut user_stmts := Expr.new(NodeType.Body, case_node.line, case_node.col)
            for ui in 0..user_stmt_count {
                user_stmts.children.push_take(all_children, n_bindings + ui)
            }
            mut matched_assign := Expr.new(NodeType.Assign(AssignData(name = matched_name.clone())), case_node.line, case_node.col)
            matched_assign.add_child(own Expr.new(NodeType.Literal(Literal.Bool(true)), case_node.line, case_node.col))
            user_stmts.add_child(own matched_assign)

            if has_guard {
                ref guard_expr : Expr = case_node.children[1]
                mut guard_if := Expr.new(NodeType.If, case_node.line, case_node.col)
                guard_if.add_child(own guard_expr.clone())
                guard_if.add_child(own user_stmts)
                // #282: the pre-infer throw pass deliberately left a throwing
                // (bang) call in the guard un-hoisted. Lower it now into
                // new_body, before the guard `if`. new_body is the body of the
                // pattern gate (`if _sw_matched.not().and(pattern) { ... }`),
                // so the call -- and its panic-on-throw check -- run only when
                // the pattern matches; short-circuit preserved.
                if subtree_has_bang(guard_if.children[0]) {
                    lower_guard_bang_calls(scope, guard_if, new_body, body, ctx)
                }
                new_body.push(own guard_if)
            } else {
                for us_i in 0..user_stmts.children.len() {
                    new_body.push_take(user_stmts.children, us_i)
                }
            }
            case_body.children.move_from(new_body)

            // Outer condition: _sw_matched.not().and(pattern_cond)
            mut not_id := Expr.new(ident_node(matched_name), case_node.line, case_node.col)
            mut not_call := make_method_call_fcall(own not_id, "not", case_node.line, case_node.col)
            mut gated_cond := make_method_call_fcall(own not_call, "and", case_node.line, case_node.col)
            gated_cond.add_child(own condition)

            mut if_node := Expr.new(NodeType.If, case_node.line, case_node.col)
            if_node.add_child(own gated_cond)
            if_node.add_child(own case_body.clone())
            // #282: this case can leave _err_kind set if its guard or body
            // contains a (lowered) throwing call -- detected by a reference to
            // _err_kind. Gate it on `_err_kind == 0` when a PRIOR case could
            // throw, then propagate the flag.
            case_can_throw := subtree_references_name(if_node, "_err_kind")
            if switch_can_throw {
                block.add_child(own make_if_kind_eq_zero_wrap(if_node, case_node.line, case_node.col))
            } else {
                block.add_child(own if_node)
            }
            if case_can_throw { switch_can_throw = true }
        } else {
            mut if_node := Expr.new(NodeType.If, case_node.line, case_node.col)
            if_node.add_child(own condition)
            if_node.add_child(own case_body.clone())
            if has_first_if.not() {
                first_if = if_node
                has_first_if = true
            } else {
                append_switch_else_if(first_if, if_node)
            }
            last_case_body = case_body.clone()
            has_last_case_body = true
        }
    }

    if any_guard {
        if has_default_body {
            mut nid2 := Expr.new(ident_node(matched_name), stmt.line, stmt.col)
            mut ncall2 := make_method_call_fcall(own nid2, "not", stmt.line, stmt.col)
            mut def_if := Expr.new(NodeType.If, stmt.line, stmt.col)
            def_if.add_child(own ncall2)
            def_if.add_child(own default_body.clone())
            // #282: skip the default too if an earlier case's guard threw.
            if switch_can_throw {
                block.add_child(own make_if_kind_eq_zero_wrap(def_if, stmt.line, stmt.col))
            } else {
                block.add_child(own def_if)
            }
        }
    } else {
        if has_default_body.and(has_first_if) {
            attach_switch_default_body(first_if, default_body)
        } else if has_default_body.and(has_first_if.not()) {
            first_if = default_body.clone()
            has_first_if = true
        }
    }

    if has_switch_enum_def {
        ref switch_enum_def : Expr = scope.get_struct(sw_expr_sname)
        mut missing_paths := Vec(Str).new()
        collect_missing_paths(scope, coverage, switch_enum_def, "", missing_paths, ctx)
        if has_default_case {
            if missing_paths.len() == 0 {
                type_error_at(ctx.path, default_line, default_col, format("unnecessary default `case:`; all variants of enum '", sw_expr_sname, "' are already covered"), ctx)
            }
        } else if missing_paths.len() > 0 {
            mut msg := format("non-exhaustive ", kind_word, " on enum '", sw_expr_sname, "'; missing cases:")
            for mp : Str in missing_paths {
                if msg.ends_with(":").not() { msg = format(msg, ",") }
                msg = format(msg, " ", mp)
            }
            stmt.type_error(msg, ctx)
        } else if any_guard.not().and(has_first_if).and(has_last_case_body) {
            // Exhaustive enum switch, no `case:`, no guards: attach a clone
            // of the last case body as the chain's terminal else so C sees
            // an unconditional return path. By exhaustiveness the duplicate
            // body never runs at the source level; it exists purely so the
            // generated C compiles under -Wreturn-type.
            attach_switch_default_body(first_if, last_case_body)
        }
    }
    // Issue #244: a match must yield a value on every path. The enum case is
    // covered above (same check switch uses); for any other subject, require an
    // explicit `case:` default. switch has no such requirement, so this is the
    // one place the two forms genuinely diverge.
    if is_match.and(has_switch_enum_def.not()).and(has_default_case.not()) {
        stmt.type_error("non-exhaustive match; add a 'case:' default arm to cover the remaining values", ctx)
    }

    if has_first_if { block.add_child(own first_if.clone()) }
    replace_switch_stmt_with_block(body, stmt_idx, own block)
    return true
}

priv desugar_for_in_range_stmt := proc(scope: TypeScope, mut body: Expr, stmt_idx: USize, in_func: I32, ctx: Context) returns Bool {
    ref mut stmt : Expr = body.children[stmt_idx]
    ref mut iter : Expr = stmt.children[0]
    if iter.node_type.is(NodeType.FCall).not() { return false }
    if iter.children.len() != 3 { return false }
    ref callee : Expr = iter.children[0]
    switch callee.node_type {
    case NodeType.FieldAccess(callee_field):
        if callee_field.field_access_name().eq("new").not() { return false }
    case:
        return false
    }
    if callee.children.len() == 0 { return false }
    ref callee_base : Expr = callee.children[0]
    switch callee_base.node_type {
    case NodeType.Ident(callee_name):
        if callee_name.ident_name().eq("Range").not() { return false }
    case:
        return false
    }

    ref mut start_expr : Expr = iter.children[1]
    ref mut end_expr : Expr = iter.children[2]
    infer_expr(scope, start_expr, in_func, ctx)
    infer_expr(scope, end_expr, in_func, ctx)

    mut elem_type := til_type_name(stmt.til_type())
    if elem_type.len() == 0 {
        mut type_src := start_expr
        if start_expr.node_type.is_literal_num().and(end_expr.node_type.is_literal_num().not()) {
            type_src = end_expr
        } else if end_expr.node_type.is_literal_num().and(start_expr.node_type.is_literal_num().not()) {
            type_src = start_expr
        }
        if is_aggregate(type_src.til_type()) {
            ts_sname := til_type_name(type_src.til_type())
            if ts_sname.len() > 0 {
                elem_type = ts_sname
            } else {
                elem_type = type_to_name(type_src.til_type())
            }
        } else {
            elem_type = type_to_name(type_src.til_type())
        }
    }

    mut var_name := ""
    mut forin_is_mut := false
    switch stmt.node_type {
    case NodeType.ForIn(forin_data_r):
        var_name = forin_data_r.name.clone()
        forin_is_mut = forin_data_r.is_mut
    case:
        UNREACHABLE()
        return false
    }
    ref for_body : Expr = stmt.children[1]
    line := stmt.line
    col := stmt.col
    counter := ctx.hoist_counter
    ctx.hoist_counter++

    end_name := format("_re_", elem_type, "_", counter.to_str())
    cur_name := format("_rc_", elem_type, "_", counter.to_str())

    mut block := Expr.new(NodeType.Body, line, col)

    mut end_decl := Expr.new(NodeType.Decl(decl_typed(name = end_name, explicit_type = elem_type)), line, col)
    end_decl.add_child(own end_expr.clone())
    block.add_child(own end_decl)

    mut cur_decl := Expr.new(NodeType.Decl(decl_typed(name = cur_name, explicit_type = elem_type, is_mut = true)), line, col)
    cur_decl.add_child(own start_expr.clone())
    block.add_child(own cur_decl)

    mut cur_ident_lt := Expr.new(ident_node(cur_name), line, col)
    mut lt_call := make_method_call_fcall(own cur_ident_lt, "lt", line, col)
    mut end_ident_lt := Expr.new(ident_node(end_name), line, col)
    lt_call.add_child(own end_ident_lt)
    mut asc_while := Expr.new(NodeType.While, line, col)
    asc_while.add_child(own lt_call)
    asc_while.add_child(own make_for_in_range_while_body(var_name, cur_name, "inc", for_body, line, col, elem_type, forin_is_mut))

    mut cur_ident_gt := Expr.new(ident_node(cur_name), line, col)
    mut gt_call := make_method_call_fcall(own cur_ident_gt, "gt", line, col)
    mut end_ident_gt := Expr.new(ident_node(end_name), line, col)
    gt_call.add_child(own end_ident_gt)
    mut desc_while := Expr.new(NodeType.While, line, col)
    desc_while.add_child(own gt_call)
    desc_while.add_child(own make_for_in_range_while_body(var_name, cur_name, "dec", for_body, line, col, elem_type, forin_is_mut))

    mut if_node := Expr.new(NodeType.If, line, col)
    mut cur_ident_lte := Expr.new(ident_node(cur_name), line, col)
    mut lte_call := make_method_call_fcall(own cur_ident_lte, "lte", line, col)
    mut end_ident_lte := Expr.new(ident_node(end_name), line, col)
    lte_call.add_child(own end_ident_lte)
    if_node.add_child(own lte_call)

    mut then_body := Expr.new(NodeType.Body, line, col)
    then_body.add_child(own asc_while)
    if_node.add_child(own then_body)

    mut else_body := Expr.new(NodeType.Body, line, col)
    else_body.add_child(own desc_while)
    if_node.add_child(own else_body)
    block.add_child(own if_node)

    replace_body_stmt_with_block(body, stmt_idx, own block)
    return true
}

priv desugar_for_in_collection_stmt := proc(scope: TypeScope, mut body: Expr, stmt_idx: USize, in_func: I32, ctx: Context) returns Bool {
    ref mut stmt : Expr = body.children[stmt_idx]
    ref mut iter : Expr = stmt.children[0]

    infer_expr(scope, iter, in_func, ctx)

    mut type_name := ""
    if is_aggregate(iter.til_type()) {
        iter_sname := til_type_name(iter.til_type())
        if iter_sname.len() > 0 {
            type_name = iter_sname
        }
    }
    if type_name.len() == 0 {
        stmt.type_error("for-in requires a collection type with get() and len() methods", ctx)
        return false
    }

    ref sdef : Expr = scope.get_struct(type_name)
    if sdef.is_null() {
        stmt.type_error("for-in requires a collection type with get() and len() methods", ctx)
        return false
    }

    ref len_func : Expr = find_namespace_func(sdef, "len", scope)
    // Issue #284: prefer an unchecked accessor when the collection offers
    // one. The desugared index runs exactly 0..len(), so the loop's own
    // `_fi < len()` test already proves the access in bounds -- the
    // per-element bounds check inside the throwing `get` is pure redundancy.
    // Because unsafe_get is non-throwing, the whole get_throws branch below
    // (err out-params, malloc(OutOfBounds) slot, post-call _err_kind check)
    // is never emitted; the loop body collapses to one compare + ptr
    // arithmetic. Falls back to `get` for collections without unsafe_get.
    mut method_name := "unsafe_get"
    if find_namespace_func(sdef, "unsafe_get", scope).is_null() {
        method_name = "get"
    }
    ref get_func : Expr = find_namespace_func(sdef, method_name, scope)

    if len_func.is_null() {
        stmt.type_error(format("type '", type_name, "' has no 'len' method (required for for-in)"), ctx)
        return false
    }
    mut idx_type := ""
    switch len_func.node_type {
    case NodeType.FuncDef(len_def):
        if len_def.params.len().neq(1).or(len_def.return_type.len().eq(0)) {
            stmt.type_error(format("type '", type_name, "' len() must take 1 param and return a scalar for for-in"), ctx)
            return false
        }
        idx_type = len_def.return_type.clone()
    case:
        UNREACHABLE()
        return false
    }

    if get_func.is_null() {
        stmt.type_error(format("type '", type_name, "' has no 'get' method (required for for-in)"), ctx)
        return false
    }
    mut elem_type := til_type_name(stmt.til_type())
    mut get_returns_ref := false
    mut get_throws := false
    mut get_throw_types := Vec(Str).new()
    // Issue #281: a get() may carry trailing defaulted params (e.g.
    // `loc: Str = __LOC__`). The for-in hand-builds the get call below, so it
    // must fill those itself; capture their default expressions here while
    // get_def is in scope. Empty (no-op) for the common get(self, i) shape.
    mut get_trailing_defaults := Vec(Expr).new()
    switch get_func.node_type {
    case NodeType.FuncDef(get_def):
        // A throwing get gets its signature extended in place with
        // synthetic _err_kind/_err_<T> params below. Allow either
        // the original (self, idx) shape or the already-extended one
        // -- the original 2-param form is what user code wrote, and
        // any subsequent for-in over the same type sees the extended
        // shape because we mutated its FuncDef.
        if get_def.params.len() < 2 {
            stmt.type_error(format("type '", type_name, "' get() second param must match len() return type for for-in"), ctx)
            return false
        }
        ref get_idx_param : Declaration = get_def.params[1]
        if get_idx_param.explicit_type.len().eq(0).or(get_idx_param.explicit_type.eq(idx_type).not()) {
            stmt.type_error(format("type '", type_name, "' get() second param must match len() return type for for-in"), ctx)
            return false
        }
        if elem_type.len() == 0 {
            if get_def.return_type.len().eq(0).or(get_def.return_type.eq("Dynamic")) {
                stmt.type_error(format("cannot infer element type for '", type_name, "', use explicit type: for x : Type in ..."), ctx)
                return false
            }
            elem_type = get_def.return_type.clone()
        }
        get_returns_ref = get_def.return_own_type.is(OwnType.Ref)
        get_throws = get_def.throw_types.len() > 0
        if get_throws {
            for gtn : Str in get_def.throw_types {
                get_throw_types.push(own gtn.clone())
            }
            // Extend the get FuncDef in place with the synthetic
            // _err_kind + _err_<T> out-params so the call we emit
            // below (4-arg shape for a 1-throw get) matches the
            // callee's arity. Idempotent: only extends once.
            mut already_extended := false
            for p : Declaration in get_def.params {
                if p.name == "_err_kind" { already_extended = true }
            }
            if already_extended.not() {
                append_err_out_params(get_def.params, get_def.throw_types, ctx)
            }
        }
        // Issue #281: capture any params beyond self + idx (+ the err out-args
        // for a throwing get) -- the trailing defaulted params (e.g. a
        // `loc: Str = __LOC__`) the hand-built call below must fill itself.
        mut forin_filled : USize = 1
        if get_throws {
            // _err_kind is always present; fieldless throws carry no slot.
            forin_filled++
            for gtn : Str in get_throw_types {
                if throw_type_has_payload(ctx, gtn) { forin_filled++ }
            }
        }
        for tp_i in forin_filled.add(1)..get_def.params.len() {
            get_trailing_defaults.push(own get_def.params[tp_i].default_value.clone())
        }
    case:
        UNREACHABLE()
        return false
    }

    mut var_name := ""
    mut forin_is_mut := false
    switch stmt.node_type {
    case NodeType.ForIn(forin_data_c):
        var_name = forin_data_c.name.clone()
        forin_is_mut = forin_data_c.is_mut
    case:
        UNREACHABLE()
        return false
    }
    // A `for mut x in coll` mutates coll's elements through the element
    // ref, so coll's `mut` qualifier is justified. Mark its root binding
    // written here -- otherwise check_unused_mut_locals later flags
    // `mut coll` as "never written through", forcing the user to drop a
    // `mut` that actually reflects the loop's intent.
    if forin_is_mut {
        mark_field_assign_root_written(scope, iter)
    }
    ref for_body : Expr = stmt.children[1]
    line := stmt.line
    col := stmt.col

    counter := ctx.hoist_counter
    ctx.hoist_counter++
    col_name := format("_fc_", type_name, "_", counter.to_str())
    idx_name := format("_fi_USize_", counter.to_str())

    mut block := Expr.new(NodeType.Body, line, col)

    // When iter is an lvalue (ident or field access), bind _fc as a ref to
    // alias the source instead of letting infer_decl_value insert a deep
    // .clone() that would dangle any refs taken out of the loop body.
    // For rvalues (literals, calls), keep the default Shallow so the result
    // gets stored as a value.
    mut col_own_type := OwnType.Shallow
    if iter.node_type.is(NodeType.Ident).or(iter.node_type.is(NodeType.FieldAccess)) {
        col_own_type = OwnType.Ref
    }
    mut col_decl := Expr.new(NodeType.Decl(Declaration(name = col_name.clone(), own_type = col_own_type)), line, col)
    col_decl.add_child(own iter.clone())
    block.add_child(own col_decl)

    mut idx_decl := Expr.new(NodeType.Decl(decl_typed(name = idx_name, explicit_type = idx_type, is_mut = true)), line, col)
    mut zero := Expr.new(literal_num_node("0"), line, col)
    idx_decl.add_child(own zero)
    block.add_child(own idx_decl)

    // For a throwing get, declare block-local err slots: we lower
    // the iteration access as an explicit `get(idx, mut _kind, mut _slot)`
    // followed by `if _kind != 0 { panic(...) }`, instead of routing
    // through the bang/throw-catch pipeline. Self-contained: no extra
    // pre-pass, no fdef-level slot prepend.
    fk_name := format("_forin_err_kind_", counter.to_str())
    if get_throws {
        mut kind_decl := Expr.new(NodeType.Decl(Declaration(name = fk_name.clone(),
            explicit_type = "I64", til_type = Type.Primitive(Primitive.I64), is_mut = true)), line, col)
        kind_decl.add_child(own make_int_lit(0, line, col))
        block.add_child(own kind_decl)
        for gtn : Str in get_throw_types {
            if throw_type_has_payload(ctx, gtn).not() { continue }
            slot_name := format("_forin_", gtn, "_", counter.to_str())
            mut slot_decl := Expr.new(NodeType.Decl(decl_typed(name = slot_name,
                explicit_type = gtn,
                is_mut = true)), line, col)
            slot_decl.add_child(own make_default_value_expr(gtn, line, col))
            block.add_child(own slot_decl)
        }
    }

    mut while_node := Expr.new(NodeType.While, line, col)

    mut idx_ident_cond := Expr.new(ident_node(idx_name), line, col)
    mut cond_call := make_method_call_fcall(own idx_ident_cond, "lt", line, col)
    mut col_ident_len := Expr.new(ident_node(col_name), line, col)
    cond_call.add_child(own make_method_call_fcall(own col_ident_len, "len", line, col))
    while_node.add_child(own cond_call)

    mut wbody := Expr.new(NodeType.Body, line, col)

    mut forin_own := OwnType.Shallow
    if get_returns_ref { forin_own = OwnType.Ref }
    mut elem_decl := Expr.new(NodeType.Decl(decl_typed(name = var_name, explicit_type = elem_type, own_type = forin_own, is_mut = forin_is_mut)), line, col)
    mut col_ident_get := Expr.new(ident_node(col_name), line, col)
    mut get_call := make_method_call_fcall(own col_ident_get, method_name, line, col)
    mut idx_ident_get := Expr.new(ident_node(idx_name), line, col)
    get_call.add_child(own idx_ident_get)
    if get_throws {
        // Pass the block-local err slots as out-args so the throwing
        // get's extended signature is satisfied without any flag-and-
        // lower roundtrip through the throw/catch pass.
        mut kind_arg := Expr.new(ident_node(fk_name), line, col)
        kind_arg.set_til_type(Type.Primitive(Primitive.I64))
        get_call.add_child(own kind_arg)
        for gtn : Str in get_throw_types {
            if throw_type_has_payload(ctx, gtn).not() { continue }
            slot_name := format("_forin_", gtn, "_", counter.to_str())
            mut slot_arg := Expr.new(ident_node(slot_name), line, col)
            slot_arg.set_til_type(til_type_from_explicit_type(gtn))
            get_call.add_child(own slot_arg)
        }
    }
    // Issue #281: fill get's trailing defaulted params (e.g. `loc: Str =
    // __LOC__`). resolve_default_value stamps a __LOC__ default with the for-in
    // loop's location (get_call's coords) -- the loop is the caller. No-op when
    // get_trailing_defaults is empty (the common get(self, i) shape).
    for td : Expr in get_trailing_defaults {
        get_call.add_child(own resolve_default_value(td, get_call, ctx))
    }
    elem_decl.add_child(own get_call)
    wbody.add_child(own elem_decl)

    if get_throws {
        // if _forin_err_kind_<n>.eq(0).not() { panic("<T>") }
        // for-in is the only caller of this get; on-error semantics is
        // panic-with-type-name, matching the user-visible `arr[i]`.
        mut kind_id := Expr.new(ident_node(fk_name), line, col)
        kind_id.set_til_type(Type.Primitive(Primitive.I64))
        mut zero_lit := make_int_lit(0, line, col)
        mut eq_call := make_method_call_fcall(own kind_id, "eq", line, col)
        eq_call.add_child(own zero_lit)
        mut not_call := make_method_call_fcall(own eq_call, "not", line, col)

        loc_str := format(ctx.path, ":", line.to_str(), ":", col.to_str())
        mut panic_call := Expr.new(NodeType.FCall(FCallData()), line, col)
        panic_call.add_child(own Expr.new(ident_node("panic"), line, col))
        panic_call.add_child(own Expr.new(NodeType.Literal(Literal.Str(loc_str)), line, col))
        ref first_throw : Str = get_throw_types[0]
        panic_call.add_child(own Expr.new(NodeType.Literal(Literal.Str(first_throw.clone())), line, col))

        mut panic_body := Expr.new(NodeType.Body, line, col)
        panic_body.add_child(own panic_call)
        mut if_panic := Expr.new(NodeType.If, line, col)
        if_panic.add_child(own not_call)
        if_panic.add_child(own panic_body)
        wbody.add_child(own if_panic)
    }

    mut idx_assign := Expr.new(NodeType.Assign(AssignData(name = idx_name.clone())), line, col)
    mut idx_ident_inc := Expr.new(ident_node(idx_name), line, col)
    mut add_call := make_method_call_fcall(own idx_ident_inc, "add", line, col)
    mut one := Expr.new(literal_num_node("1"), line, col)
    add_call.add_child(own one)
    idx_assign.add_child(own add_call)
    wbody.add_child(own idx_assign)

    for e_bi : Expr in for_body.children {
        wbody.add_child(own e_bi.clone())
    }

    while_node.add_child(own wbody)
    block.add_child(own while_node)
    replace_body_stmt_with_block(body, stmt_idx, own block)
    return true
}

// True when struct/enum def `sdef` declares a field named `field_name`.
priv struct_def_has_field := func(sdef: Expr, field_name: Str) returns Bool {
    switch sdef.node_type {
    case NodeType.StructDef(sd):
        for fd : Declaration in sd.fields {
            if fd.name == field_name { return true }
        }
    case:
    }
    return false
}

// Element type of a collection type named `col_type_name`, read off its
// unchecked accessor's (unsafe_get, else get) return type -- the same
// resolution desugar_for_in_collection_stmt uses for the single-variable
// element decl. Returns "" when the type or accessor is missing. The
// element decls need this concrete type explicitly: a typeless `ref`
// decl makes the interpreter copy the value instead of aliasing the
// slot, so a `for k, mut v` write would not persist.
priv collection_elem_type_of := func(scope: TypeScope, col_type_name: Str) returns Str {
    ref col_sdef : Expr = scope.get_struct(col_type_name)
    if col_sdef.is_null() { return "" }
    mut method_name := "unsafe_get"
    if find_namespace_func(col_sdef, "unsafe_get", scope).is_null() {
        method_name = "get"
    }
    ref get_func : Expr = find_namespace_func(col_sdef, method_name, scope)
    if get_func.is_null() { return "" }
    switch get_func.node_type {
    case NodeType.FuncDef(get_def):
        return get_def.return_type.clone()
    case:
        return ""
    }
}

// Issue #287: key-value for-in over maps -- `for k, v in map`.
//
// Maps (Map, HashMap, and the dyn variants) store their entries as two
// index-aligned Vecs, `keys` and `values`. A two-variable for-in lowers
// to a single lockstep index walk over those backing Vecs, going
// straight through the public fields -- no map-level key/value accessor
// is leaked into the desugared loop::
//
//   _fc := ref map
//   _fi := 0
//   while _fi < _fc.keys.len() {
//       ref k : K = _fc.keys.unsafe_get(_fi)     // unchecked: _fi < len
//       ref v : V = _fc.values.unsafe_get(_fi)
//       _fi++
//       <body>
//   }
//
// Like the single-variable collection for-in (#284) this rides
// Vec.unsafe_get, so the loop body is one `_fi < len` compare plus
// pointer arithmetic with no per-element bounds check. The element
// types K/V are resolved and set explicitly (see collection_elem_type_of)
// so the interpreter aliases each slot -- a `for k, mut v` write must
// persist into the map. Returns false for the single-variable form
// (name2 empty), leaving the other for-in desugars to handle it.
priv desugar_for_in_kv_stmt := proc(scope: TypeScope, mut body: Expr, stmt_idx: USize, in_func: I32, ctx: Context) returns Bool {
    ref mut stmt : Expr = body.children[stmt_idx]

    mut var_name := ""
    mut var_name2 := ""
    mut forin_is_mut := false
    mut forin_is_mut2 := false
    switch stmt.node_type {
    case NodeType.ForIn(fid):
        if fid.name2.len() == 0 { return false }
        var_name = fid.name.clone()
        var_name2 = fid.name2.clone()
        forin_is_mut = fid.is_mut
        forin_is_mut2 = fid.is_mut2
    case:
        UNREACHABLE()
        return false
    }

    // The key of a two-variable for-in cannot be `mut`: mutating a key in
    // place breaks the map's key ordering (Map/DynMap binary search) and
    // bucket placement (HashMap), so a later get/has/set would silently
    // miss. Values may be mutated (`for k, mut v`); keys may not. Flag it
    // and continue as a non-mut key so the rest of typing stays sane.
    if forin_is_mut {
        stmt.type_error("for k, v in map: the key binding cannot be 'mut' -- mutating a key in place breaks the map's key ordering; drop 'mut' on the key (use 'for k, mut v' to mutate values)", ctx)
        forin_is_mut = false
    }

    ref mut iter : Expr = stmt.children[0]
    infer_expr(scope, iter, in_func, ctx)

    // `for [mut] k, mut v in map` mutates the map's keys/values through
    // the element refs, so the map's `mut` is justified -- mark its root
    // binding written so check_unused_mut_locals doesn't later flag a
    // `mut map` whose only writer is this loop.
    if forin_is_mut.or(forin_is_mut2) {
        mark_field_assign_root_written(scope, iter)
    }

    mut type_name := ""
    if is_aggregate(iter.til_type()) {
        iter_sname := til_type_name(iter.til_type())
        if iter_sname.len() > 0 { type_name = iter_sname }
    }
    if type_name.len() == 0 {
        stmt.type_error("for k, v in ...: requires a map type with 'keys' and 'values' fields", ctx)
        return false
    }

    ref sdef : Expr = scope.get_struct(type_name)
    if sdef.is_null() {
        stmt.type_error("for k, v in ...: requires a map type with 'keys' and 'values' fields", ctx)
        return false
    }
    if struct_def_has_field(sdef, "keys").not().or(struct_def_has_field(sdef, "values").not()) {
        stmt.type_error(format("type '", type_name, "' has no 'keys'/'values' fields (required for two-variable for-in)"), ctx)
        return false
    }

    ref for_body : Expr = stmt.children[1]
    line := stmt.line
    col := stmt.col
    counter := ctx.hoist_counter
    ctx.hoist_counter++
    col_name := format("_fc_", type_name, "_", counter.to_str())
    idx_name := format("_fi_USize_", counter.to_str())

    // Resolve the concrete key/value element types. Probe the inferred
    // map's `keys` / `values` field types (which carry the monomorphized
    // backing-Vec types), then read each element type off the Vec's
    // unsafe_get return -- mirroring the single-variable desugar. These
    // must be set explicitly on the element decls; a typeless `ref` decl
    // makes the interpreter copy rather than alias, so `for k, mut v`
    // writes would not persist.
    mut keys_probe := Expr.new(field_access_node("keys"), line, col)
    keys_probe.add_child(own iter.clone())
    infer_expr(scope, keys_probe, in_func, ctx)
    mut vals_probe := Expr.new(field_access_node("values"), line, col)
    vals_probe.add_child(own iter.clone())
    infer_expr(scope, vals_probe, in_func, ctx)
    key_elem := collection_elem_type_of(scope, til_type_name(keys_probe.til_type()))
    val_elem := collection_elem_type_of(scope, til_type_name(vals_probe.til_type()))
    if key_elem.len().eq(0).or(val_elem.len().eq(0)) {
        stmt.type_error(format("cannot resolve key/value element types for two-variable for-in over '", type_name, "'"), ctx)
        return false
    }

    mut block := Expr.new(NodeType.Body, line, col)

    // _fc := ref map  (ref when iter is an lvalue, mirroring the
    // single-variable collection desugar; else a shallow value bind).
    mut col_own_type := OwnType.Shallow
    if iter.node_type.is(NodeType.Ident).or(iter.node_type.is(NodeType.FieldAccess)) {
        col_own_type = OwnType.Ref
    }
    mut col_decl := Expr.new(NodeType.Decl(Declaration(name = col_name.clone(), own_type = col_own_type)), line, col)
    col_decl.add_child(own iter.clone())
    block.add_child(own col_decl)

    // _fi := 0
    mut idx_decl := Expr.new(NodeType.Decl(decl_typed(name = idx_name, explicit_type = "USize", is_mut = true)), line, col)
    idx_decl.add_child(own Expr.new(literal_num_node("0"), line, col))
    block.add_child(own idx_decl)

    // while _fi < _fc.keys.len()
    mut while_node := Expr.new(NodeType.While, line, col)
    mut idx_ident_cond := Expr.new(ident_node(idx_name), line, col)
    mut cond_call := make_method_call_fcall(own idx_ident_cond, "lt", line, col)
    mut keys_len_recv := Expr.new(field_access_node("keys"), line, col)
    keys_len_recv.add_child(own Expr.new(ident_node(col_name), line, col))
    cond_call.add_child(own make_method_call_fcall(own keys_len_recv, "len", line, col))
    while_node.add_child(own cond_call)

    mut wbody := Expr.new(NodeType.Body, line, col)

    // ref [mut] k : K = _fc.keys.unsafe_get(_fi)
    // A `_` binding is a discard: emit no decl for it. The body never
    // references `_`, and two `_` element decls in one scope would collide
    // as identical C identifiers (`for _, _ in map` -> "redefinition of _").
    if var_name.eq("_").not() {
        mut key_decl := Expr.new(NodeType.Decl(decl_typed(name = var_name, explicit_type = key_elem, own_type = OwnType.Ref, is_mut = forin_is_mut)), line, col)
        mut keys_recv := Expr.new(field_access_node("keys"), line, col)
        keys_recv.add_child(own Expr.new(ident_node(col_name), line, col))
        mut key_get := make_method_call_fcall(own keys_recv, "unsafe_get", line, col)
        key_get.add_child(own Expr.new(ident_node(idx_name), line, col))
        key_decl.add_child(own key_get)
        wbody.add_child(own key_decl)
    }

    // ref [mut] v : V = _fc.values.unsafe_get(_fi)
    if var_name2.eq("_").not() {
        mut val_decl := Expr.new(NodeType.Decl(decl_typed(name = var_name2, explicit_type = val_elem, own_type = OwnType.Ref, is_mut = forin_is_mut2)), line, col)
        mut vals_recv := Expr.new(field_access_node("values"), line, col)
        vals_recv.add_child(own Expr.new(ident_node(col_name), line, col))
        mut val_get := make_method_call_fcall(own vals_recv, "unsafe_get", line, col)
        val_get.add_child(own Expr.new(ident_node(idx_name), line, col))
        val_decl.add_child(own val_get)
        wbody.add_child(own val_decl)
    }

    // _fi = _fi.add(1)
    mut idx_assign_kv := Expr.new(NodeType.Assign(AssignData(name = idx_name.clone())), line, col)
    mut idx_ident_inc_kv := Expr.new(ident_node(idx_name), line, col)
    mut add_call_kv := make_method_call_fcall(own idx_ident_inc_kv, "add", line, col)
    add_call_kv.add_child(own Expr.new(literal_num_node("1"), line, col))
    idx_assign_kv.add_child(own add_call_kv)
    wbody.add_child(own idx_assign_kv)

    for e_bi_kv : Expr in for_body.children {
        wbody.add_child(own e_bi_kv.clone())
    }

    while_node.add_child(own wbody)
    block.add_child(own while_node)
    replace_body_stmt_with_block(body, stmt_idx, own block)
    return true
}
