mode lib

mut hoist_counter : I32 = 0
mut _va_counter : I32 = 0
mut _kw_counter : I32 = 0
mut errors : I32 = 0
I64Name := "I64"
U8Name := "U8"
I16Name := "I16"
I32Name := "I32"
U32Name := "U32"
U64Name := "U64"
F32Name := "F32"
BoolName := "Bool"

LocalInfo := struct {
    ref mut name : Str = NULL
    mut type := TilType.Unknown
    ref mut struct_name : Str = NULL
    mut decl_index : I32 = 0
    mut last_use : I32 = 0
    mut own_transfer : I32 = -1.to_i32()
    mut skip_scope_delete := false
}

CtorArg := enum {
    Unfilled,
    Filled: Expr,
}

type_error := proc(e: Expr, msg: Str) {
    println(e.path, ":", e.line.to_str(), ":", e.col.to_str(), ": type error: ", msg)
    errors.inc()
}

find_namespace_func := func(sdef: Expr, method: Str) returns ref Expr {
    if is_null(sdef) { return NULL }
    ref body : Expr = sdef.child(0)
    for i in 0..body.child_count() {
        ref field : Expr = body.child(i)
        if is_variant(field.data, NodeType.Decl).not() { continue }
        ref fd : Declaration = get_payload(field.data)
        if fd.is_namespace.not() { continue }
        if fd.name.eq(method).not() { continue }
        if is_variant(field.child(0).data, NodeType.FuncDef).not() { continue }
        return field.child(0)
    }
    return NULL
}

try_ufcs_rewrite := proc(scope: TypeScope, mut e: Expr, fa: Expr, mut obj: Expr, method: Str, type_name: Str) returns shallow Bool {
    ref top : TypeBinding = scope.get_binding(method)
    mut ufcs_match : I32 = 0
    if is_null(top).not() {
        if is_null(top.func_def).not() {
            ref top_fdef : FunctionDef = get_payload(top.func_def.data)
            if top_fdef.nparam.gt(0) {
                ref top_param : Param = top_fdef.params.get(0)
                ref first_param : Str = top_param.ptype
                if first_param.len().gt(0) {
                    if is_null(type_name).not() {
                        if first_param.eq(type_name) {
                            ufcs_match = 1
                        }
                    } else if is_variant(obj.til_type, TilType.Dynamic) {
                        pt := type_from_name(first_param, scope)
                        narrow_dynamic(obj, pt, first_param)
                        ufcs_match = 1
                    }
                }
            }
        }
    }
    if ufcs_match.eq(0) { return false }
    mut fn_ident := Expr.new(NodeType.Ident(method.clone()), fa.line, fa.col, fa.path)
    e.children.set(0, own fn_ident)
    mut instance := obj
    mut new_children := Vec.new("Expr", Expr.size())
    new_children.push(own e.child(0).clone())
    new_children.push(own instance.clone())
    for i in 1..e.child_count() {
        new_children.push(own e.child(i).clone())
    }
    e.children = new_children
    return true
}

infer_func_ptr_field_call := proc(scope: TypeScope, mut e: Expr, mut fa: Expr, obj: Expr, sdef: Expr, method: Str, shallow in_func: I32, ctx: Context) returns shallow Bool {
    if is_null(sdef).or(is_variant(obj.til_type, TilType.Struct).not().and(is_variant(obj.til_type, TilType.Enum).not())) { return false }
    ref body : Expr = sdef.child(0)
    for fi in 0..body.child_count() {
        ref field : Expr = body.child(fi)
        if is_variant(field.data, NodeType.Decl).not() { continue }
        ref fd : Declaration = get_payload(field.data)
        if fd.is_namespace { continue }
        if fd.name.eq(method).not() { continue }
        if fd.explicit_type.len().eq(0) { continue }
        sf_ftb := scope.find(fd.explicit_type)
        if is_variant(sf_ftb, ScopeFind.Found).not() { continue }
        ref ftb : TypeBinding = get_payload(sf_ftb)
        if is_null(ftb.func_def).or(ftb.func_def.child_count().neq(0)) { continue }
        fa.til_type = TilType.FuncPtr
        fa.fn_sig = ftb.func_def
        ref sig : Expr = ftb.func_def
        mut nargs : U32 = e.child_count()
        nargs = nargs.sub(1)
        ref sig_fdef : FunctionDef = get_payload(sig.data)
        if nargs.neq(sig_fdef.nparam) {
            type_error(e, "function pointer field '".concat(method).concat("' expects ").concat(sig_fdef.nparam.to_i64().to_str()).concat(" args, got ").concat(nargs.to_i64().to_str()))
        }
        mut ai : U32 = 0
        while ai.lt(nargs) {
            if ai.gte(sig_fdef.nparam) { break }
            infer_expr(scope, e.child(ai.add(1)), in_func, ctx)
            ai = ai.add(1)
        }
        e.fn_sig = sig.clone()
        ref mut fcall_data : FCallData = get_payload(e.data)
        fcall_data.fn_sig = sig.clone()
        if sig_fdef.return_type.len().gt(0) {
            e.til_type = type_from_name(sig_fdef.return_type, scope)
            if is_variant(e.til_type, TilType.Struct).or(is_variant(e.til_type, TilType.Enum)) {
                e.struct_name = sig_fdef.return_type.clone()
            }
        } else {
            e.til_type = TilType.None
        }
        return true
    }
    return false
}

validate_fcall_own_args := proc(scope: TypeScope, e: Expr, callee_bind: TypeBinding) {
    if is_null(callee_bind) { return }
    if is_null(callee_bind.func_def) { return }
    ref fdef : Expr = callee_bind.func_def
    ref fdef_data : FunctionDef = get_payload(fdef.data)
    fvi := fdef_data.variadic_index
    fkwi := fdef_data.kwargs_index
    mut fvc : U32 = 0
    if fvi.gte(0) {
        ref fcall_data0 : FCallData = get_payload(e.data)
        fvc = fcall_data0.variadic_count
    }
    mut fkc : U32 = 0
    if fkwi.gte(0) {
        ref fcall_data1 : FCallData = get_payload(e.data)
        fkc = fcall_data1.kwargs_count
    }
    mut ci : U32 = 1
    mut pi : U32 = 0
    while pi.lt(fdef_data.nparam) {
        if ci.gte(e.child_count()) { break }
        if fvi.gte(0) {
            if pi.to_i64().to_i32().eq(fvi) {
                ci = ci.add(fvc)
                pi = pi.add(1)
                continue
            }
        }
        if fkwi.gte(0) {
            if pi.to_i64().to_i32().eq(fkwi) {
                ci = ci.add(fkc)
                pi = pi.add(1)
                continue
            }
        }
        ref pp2 : Param = fdef_data.params.get(pi)
        pown := pp2.own_type.eq(OwnType.Own)
        ref arg : Expr = e.child(ci)
        if pown {
            if arg.is_own_arg.not() {
                type_error(arg, "argument for 'own' parameter '".concat(pp2.name).concat("' must be marked 'own'"))
            }
        } else if arg.is_own_arg {
            type_error(arg, "'own' on argument but parameter '".concat(pp2.name).concat("' is not 'own'"))
        }
        if pown {
            if is_variant(arg.data, NodeType.Ident) {
                sf_ab := scope.find(get_payload(arg.data))
                if is_variant(sf_ab, ScopeFind.Found) {
                    ref ab : TypeBinding = get_payload(sf_ab)
                    if ab.is_ref {
                        type_error(arg, "cannot pass ref variable to 'own' parameter; use .clone() to make an owned copy")
                    }
                }
            }
        }
        if pown {
            if is_variant(arg.data, NodeType.LiteralNull) {
                type_error(arg, "cannot pass null to 'own' parameter")
            }
        }
        if pp2.own_type.eq(OwnType.Shallow) {
            if is_variant(arg.data, NodeType.LiteralNull) {
                type_error(arg, "cannot pass null to 'shallow' parameter")
            }
        }
        ci = ci.add(1)
        pi = pi.add(1)
    }
}

infer_struct_constructor_fcall := proc(scope: TypeScope, mut e: Expr, name: Str, shallow in_func: I32, ctx: Context) returns shallow Bool {
    ref sdef : Expr = scope.get_struct(name)
    if is_null(sdef) { return false }
    sf_sb := scope.find(name)
    if is_variant(sf_sb, ScopeFind.Found) {
        ref sb : TypeBinding = get_payload(sf_sb)
        if sb.is_builtin {
            type_error(e, "cannot instantiate builtin type '".concat(name).concat("'"))
            e.til_type = TilType.Unknown
            return true
        }
    }
    ref body : Expr = sdef.child(0)
    mut nfields : U32 = 0
    for i in 0..body.child_count() {
        ref fld_decl : Declaration = get_payload(body.child(i).data)
        if fld_decl.is_namespace.not() {
            nfields = nfields.add(1)
        }
    }
    mut field_vals := Vec.new("CtorArg", CtorArg.size())
    for i in 0..nfields {
        field_vals.push(own CtorArg.Unfilled())
    }
    mut field_idx := Vec.new("U32", U32.size())
    for i in 0..body.child_count() {
        ref fld_decl : Declaration = get_payload(body.child(i).data)
        if fld_decl.is_namespace.not() {
            field_idx.push(own i)
        }
    }
    for i in 1..e.child_count() {
        ref arg : Expr = e.child(i)
        if is_variant(arg.data, NodeType.NamedArg).not() {
            type_error(arg, "struct instantiation requires named arguments")
            continue
        }
        ref aname : Str = get_payload(arg.data)
        mut slot := -1.to_i32()
        for j in 0..nfields {
            ref fld_idx : U32 = field_idx.get(j)
            ref fld_decl : Declaration = get_payload(body.child(fld_idx).data)
            if fld_decl.name.eq(aname) {
                slot = j.to_i64().to_i32()
                break
            }
        }
        if slot.lt(0) {
            msg := format("struct '", name, "' has no field '", aname, "'")
            type_error(arg, msg)
        }
        if slot.gte(0) {
            ref slot_arg : CtorArg = field_vals.get(slot.to_i64().to_u32())
            if is_variant(slot_arg, CtorArg.Filled) {
                msg := format("duplicate argument for field '", aname, "'")
                type_error(arg, msg)
            }
            if is_variant(slot_arg, CtorArg.Filled).not() {
                field_vals.set(slot.to_i64().to_u32(), own CtorArg.Filled(arg.child(0).clone()))
            }
        }
    }
    for i in 0..nfields {
        ref slot_arg : CtorArg = field_vals.get(i)
        if is_variant(slot_arg, CtorArg.Filled).not() {
            ref fld_idx : U32 = field_idx.get(i)
            field_vals.set(i, own CtorArg.Filled(body.child(fld_idx).child(0).clone()))
        }
    }
    mut new_ch := Vec.new("Expr", Expr.size())
    ref callee : Expr = e.child(0)
    new_ch.push(own callee.clone())
    for i in 0..nfields {
        ref slot_arg : CtorArg = field_vals.get(i)
        ref filled_arg : Expr = get_payload(slot_arg)
        new_ch.push(own filled_arg.clone())
    }
    e.children = new_ch
    for i in 1..e.child_count() {
        if is_variant(e.child(i).til_type, TilType.Unknown) {
            infer_expr(scope, e.child(i), in_func, ctx)
        }
    }
    mut fi : U32 = 0
    for bi in 0..body.child_count() {
        if fi.gte(e.child_count().sub(1)) { break }
        ref fld : Expr = body.child(bi)
        ref fld_decl : Declaration = get_payload(fld.data)
        if fld_decl.is_namespace { continue }
        ai := fi.add(1).to_i64().to_i32()
        fi = fi.add(1)
        if fld_decl.is_ref { continue }
        if fld_decl.is_own.not() {
            if type_ctor_consumes(fld.til_type).not() { continue }
        }
        ref mut arg2 : Expr = e.child(ai.to_i64().to_u32())
        arg2.is_own_arg = true
    }
    e.til_type = TilType.Struct
    e.struct_name = resolve_type_alias(scope, name).clone()
    return true
}

desugar_user_func_fcall_args := proc(mut e: Expr, name: Str, callee_bind: TypeBinding) {
    ref fdef : Expr = callee_bind.func_def
    ref fdef_data : FunctionDef = get_payload(fdef.data)
    nparam := fdef_data.nparam
    vi := fdef_data.variadic_index
    kwi := fdef_data.kwargs_index
    mut fixed_count : U32 = nparam
    if vi.gte(0) {
        fixed_count = vi.to_i64().to_u32()
    }
    mut va_args := Vec.new("Expr", Expr.size())
    mut kw_args := Vec.new("Expr", Expr.size())
    mut new_args := Vec.new("CtorArg", CtorArg.size())
    for i in 0..nparam {
        new_args.push(own CtorArg.Unfilled())
    }
    mut pos_idx : U32 = 0
    mut seen_named := false
    for i in 1..e.child_count() {
        ref arg : Expr = e.child(i)
        if is_variant(arg.data, NodeType.NamedArg) {
            seen_named = true
            ref aname : Str = get_payload(arg.data)
            mut slot := -1.to_i32()
            for j in 0..nparam {
                if j.to_i64().to_i32().eq(vi) { continue }
                if j.to_i64().to_i32().eq(kwi) { continue }
                ref param : Param = fdef_data.params.get(j)
                if param.name.eq(aname) {
                    slot = j.to_i64().to_i32()
                    break
                }
            }
            if slot.lt(0) {
                if kwi.gte(0) {
                    kw_args.push(own arg.clone())
                } else {
                    type_error(arg, format("'", name, "' has no parameter '", aname, "'"))
                }
            } else {
                ref slot_arg : CtorArg = new_args.get(slot.to_i64().to_u32())
                if is_variant(slot_arg, CtorArg.Filled) {
                    type_error(arg, format("duplicate argument for parameter '", aname, "'"))
                } else {
                    new_args.set(slot.to_i64().to_u32(), own CtorArg.Filled(arg.child(0).clone()))
                }
            }
        } else {
            if seen_named {
                type_error(arg, "positional argument after named argument")
            }
            if vi.gte(0) {
                if pos_idx.gte(fixed_count) {
                    va_args.push(own arg.clone())
                } else if pos_idx.lt(nparam) {
                    new_args.set(pos_idx, own CtorArg.Filled(arg.clone()))
                }
            } else if pos_idx.lt(nparam) {
                new_args.set(pos_idx, own CtorArg.Filled(arg.clone()))
            }
            pos_idx = pos_idx.add(1)
        }
    }
    for i in 0..nparam {
        if i.to_i64().to_i32().eq(vi) { continue }
        if i.to_i64().to_i32().eq(kwi) { continue }
        ref slot_arg : CtorArg = new_args.get(i)
        if is_variant(slot_arg, CtorArg.Filled).not() {
            ref param : Param = fdef_data.params.get(i)
            if fdef_data.param_defaults.has(param.name) {
                ref def_expr : Expr = fdef_data.param_defaults.get(param.name)
                new_args.set(i, own CtorArg.Filled(def_expr.clone()))
            } else {
                type_error(e, format("missing argument for parameter '", param.name, "'"))
            }
        }
    }
    mut max_pos : U32 = nparam
    if kwi.gte(0) {
        max_pos = max_pos.sub(1)
    }
    if vi.lt(0) {
        if pos_idx.gt(max_pos) {
            type_error(e, format("too many arguments: expected ", nparam.to_i64().to_str(), ", got ", pos_idx.to_i64().to_str()))
        }
    }
    mut new_ch := Vec.new("Expr", Expr.size())
    ref callee : Expr = e.child(0)
    new_ch.push(own callee.clone())
    for i in 0..nparam {
        if i.to_i64().to_i32().eq(vi) {
            ref mut fcall_data : FCallData = get_payload(e.data)
            fcall_data.variadic_index = new_ch.len().to_i64().to_i32()
            for j in 0..va_args.len() {
                ref va : Expr = va_args.get(j)
                new_ch.push(own va.clone())
            }
            fcall_data.variadic_count = va_args.len().to_i64().to_u32()
        } else if i.to_i64().to_i32().eq(kwi) {
            ref mut fcall_data : FCallData = get_payload(e.data)
            fcall_data.kwargs_index = new_ch.len().to_i64().to_i32()
            for j in 0..kw_args.len() {
                ref kw : Expr = kw_args.get(j)
                new_ch.push(own kw.clone())
            }
            fcall_data.kwargs_count = kw_args.len().to_i64().to_u32()
        } else {
            ref slot_arg : CtorArg = new_args.get(i)
            ref filled_arg : Expr = get_payload(slot_arg)
            new_ch.push(own filled_arg.clone())
        }
    }
    e.children = new_ch
}

infer_and_validate_fcall_args := proc(scope: TypeScope, mut e: Expr, callee_bind: TypeBinding, shallow in_func: I32, ctx: Context) {
    for i in 1..e.child_count() {
        infer_expr(scope, e.child(i), in_func, ctx)
    }
    if is_null(callee_bind) { return }
    if is_null(callee_bind.func_def) { return }
    ref fdef : Expr = callee_bind.func_def
    ref fdef_data : FunctionDef = get_payload(fdef.data)
    fvi := fdef_data.variadic_index
    fkwi := fdef_data.kwargs_index
    mut fvc : U32 = 0
    if fvi.gte(0) {
        ref fcall_data0 : FCallData = get_payload(e.data)
        fvc = fcall_data0.variadic_count
    }
    mut fkc : U32 = 0
    if fkwi.gte(0) {
        ref fcall_data1 : FCallData = get_payload(e.data)
        fkc = fcall_data1.kwargs_count
    }
    mut ci : U32 = 1
    mut pi : U32 = 0
    while pi.lt(fdef_data.nparam) {
        if ci.gte(e.child_count()) { break }
        if fvi.gte(0) {
            if pi.to_i64().to_i32().eq(fvi) {
                ci = ci.add(fvc)
                pi = pi.add(1)
                continue
            }
        }
        if fkwi.gte(0) {
            if pi.to_i64().to_i32().eq(fkwi) {
                ci = ci.add(fkc)
                pi = pi.add(1)
                continue
            }
        }
        ref param1 : Param = fdef_data.params.get(pi)
        ref ptype : Str = param1.ptype
        narrow_dynamic(e.child(ci), type_from_name(ptype, scope), ptype)
        ci = ci.add(1)
        pi = pi.add(1)
    }
    ci = 1
    pi = 0
    while pi.lt(fdef_data.nparam) {
        if ci.gte(e.child_count()) { break }
        if fvi.gte(0) {
            if pi.to_i64().to_i32().eq(fvi) {
                ci = ci.add(fvc)
                pi = pi.add(1)
                continue
            }
        }
        if fkwi.gte(0) {
            if pi.to_i64().to_i32().eq(fkwi) {
                ci = ci.add(fkc)
                pi = pi.add(1)
                continue
            }
        }
        ref param2 : Param = fdef_data.params.get(pi)
        ref ptype_name : Str = param2.ptype
        if ptype_name.len().eq(0) {
            ci = ci.add(1)
            pi = pi.add(1)
            continue
        }
        ref arg : Expr = e.child(ci)
        if is_variant(arg.til_type, TilType.Dynamic) {
            ci = ci.add(1)
            pi = pi.add(1)
            continue
        }
        ptype := type_from_name(ptype_name, scope)
        if is_variant(ptype, TilType.Dynamic) {
            ci = ci.add(1)
            pi = pi.add(1)
            continue
        }
        if is_variant(arg.data, NodeType.LiteralNum) {
            if is_numeric_type(ptype) {
                if literal_in_range(get_payload(arg.data), ptype).not() {
                    type_error(arg, "integer literal ".concat(get_payload(arg.data)).concat(" out of range for ").concat(type_to_name(ptype, "")))
                }
                arg.til_type = ptype
                ci = ci.add(1)
                pi = pi.add(1)
                continue
            }
        }
        if can_implicit_widen(arg.til_type, ptype) {
            arg.til_type = ptype
            ci = ci.add(1)
            pi = pi.add(1)
            continue
        }
        if can_implicit_usize_coerce(arg.til_type, ptype, ptype_name) {
            arg.til_type = ptype
            ci = ci.add(1)
            pi = pi.add(1)
            continue
        }
        if is_variant(arg.til_type, ptype).not() {
            type_error(arg, "argument type mismatch for '".concat(param2.name).concat("': expected ").concat(ptype_name).concat(", got ").concat(type_to_name(arg.til_type, arg.struct_name)))
        } else if is_variant(ptype, TilType.Struct).or(is_variant(ptype, TilType.Enum)) {
            if arg.struct_name.len().gt(0) {
                if ptype_name.eq(arg.struct_name).not() {
                    type_error(arg, "argument type mismatch for '".concat(param2.name).concat("': expected ").concat(ptype_name).concat(", got ").concat(arg.struct_name))
                }
            }
        }
        ci = ci.add(1)
        pi = pi.add(1)
    }
}

resolve_fcall_return_type := proc(scope: TypeScope, mut e: Expr, name: Str, callee_bind: TypeBinding, shallow in_func: I32, ctx: Context) {
    if name.eq("dyn_call").or(name.eq("dyn_call_ret")).or(name.eq("dyn_has_method")).or(name.eq("dyn_fn")) {
        if e.child_count().gte(3) {
            ref method_arg : Expr = e.child(2)
            if is_variant(method_arg.data, NodeType.LiteralStr).not() {
                type_error(method_arg, "dyn_call method argument must be a string literal")
            }
        }
    }
    if name.eq("array").or(name.eq("vec")) {
        if e.child_count().gte(2) {
            ref type_arg : Expr = e.child(1)
            if is_variant(type_arg.data, NodeType.LiteralStr).not() {
                type_error(type_arg, "array/vec type_name argument must be a string literal")
            }
        }
    }
    fn_type := scope.get_type(name)
    if is_variant(fn_type, TilType.Unknown) {
        type_error(e, "undefined function '".concat(name).concat("'"))
    }
    if is_variant(fn_type, TilType.FuncPtr) {
        if is_null(callee_bind).not() {
            if callee_bind.is_proc.lt(0) {
                ref callee0 : Expr = e.child(0)
                callee0.til_type = TilType.FuncPtr
                if is_null(callee_bind.func_def).not() {
                    e.fn_sig = callee_bind.func_def.clone()
                    ref mut fcall_data0 : FCallData = get_payload(e.data)
                    fcall_data0.fn_sig = callee_bind.func_def.clone()
                }
                if is_null(callee_bind.func_def).not() {
                    ref cb_fdef : FunctionDef = get_payload(callee_bind.func_def.data)
                    if cb_fdef.return_type.len().gt(0) {
                        rt := type_from_name(cb_fdef.return_type, scope)
                        e.til_type = rt
                        if is_variant(rt, TilType.Struct).or(is_variant(rt, TilType.Enum)) {
                            e.struct_name = cb_fdef.return_type.clone()
                        }
                    } else {
                        e.til_type = TilType.Dynamic
                    }
                } else {
                    e.til_type = TilType.Dynamic
                }
                if is_null(callee_bind.func_def).not() {
                    ref sig : Expr = callee_bind.func_def
                    ref sig_fdef : FunctionDef = get_payload(sig.data)
                    mut nargs : U32 = e.child_count()
                    nargs = nargs.sub(1)
                    if nargs.neq(sig_fdef.nparam) {
                        type_error(e, "function pointer '".concat(name).concat("' expects ").concat(sig_fdef.nparam.to_i64().to_str()).concat(" args, got ").concat(nargs.to_i64().to_str()))
                    }
                    mut ai : U32 = 0
                    while ai.lt(nargs) {
                        if ai.gte(sig_fdef.nparam) { break }
                        ref arg : Expr = e.child(ai.add(1))
                        ref expected_param : Param = sig_fdef.params.get(ai)
                        ref expected_name : Str = expected_param.ptype
                        if expected_name.len().eq(0) {
                            ai = ai.add(1)
                            continue
                        }
                        expected := type_from_name(expected_name, scope)
                        if is_variant(expected, TilType.Unknown).or(is_variant(expected, TilType.Dynamic)) {
                            ai = ai.add(1)
                            continue
                        }
                        if is_variant(arg.til_type, TilType.Dynamic) {
                            ai = ai.add(1)
                            continue
                        }
                        if is_variant(arg.til_type, expected).not() {
                            type_error(e, "function pointer '".concat(name).concat("' param ").concat(ai.add(1).to_i64().to_str()).concat(": expected ").concat(expected_name).concat(", got ").concat(type_to_name(arg.til_type, arg.struct_name)))
                        }
                        ai = ai.add(1)
                    }
                }
                return
            }
        }
    }
    e.til_type = fn_type
    if is_variant(fn_type, TilType.Struct).or(is_variant(fn_type, TilType.Enum)) {
        if is_null(callee_bind).not() {
            if is_null(callee_bind.func_def).not() {
                ref cb_fdef2 : FunctionDef = get_payload(callee_bind.func_def.data)
                if cb_fdef2.return_type.len().gt(0) {
                    e.struct_name = cb_fdef2.return_type.clone()
                }
            }
        }
    }
    if is_variant(fn_type, TilType.FuncPtr) {
        if is_null(callee_bind).not() {
            if is_null(callee_bind.func_def).not() {
                ref cb_fdef3 : FunctionDef = get_payload(callee_bind.func_def.data)
                if cb_fdef3.return_type.len().gt(0) {
                    sf_rsb := scope.find(cb_fdef3.return_type)
                    if is_variant(sf_rsb, ScopeFind.Found) {
                        ref rsb : TypeBinding = get_payload(sf_rsb)
                        if is_null(rsb.func_def).not() {
                            if rsb.func_def.child_count().eq(0) {
                                e.fn_sig = rsb.func_def.clone()
                                ref mut fcall_data1 : FCallData = get_payload(e.data)
                                fcall_data1.fn_sig = rsb.func_def.clone()
                            }
                        }
                    }
                }
            }
        }
    }
    ref cur_mode : Mode = context_mode(ctx)
    mut debug_exempt := false
    if cur_mode.debug_prints {
        if name.eq("print").or(name.eq("println")) {
            debug_exempt = true
        }
    }
    if is_variant(fn_type, TilType.FuncPtr).not() {
        if in_func.neq(0) {
            if scope.is_proc(name).eq(1) {
                if name.eq("panic").not() {
                    if debug_exempt.not() {
                        type_error(e, "func cannot call proc '".concat(name).concat("'"))
                    }
                }
            }
        }
    }
    if scope.is_proc(name).eq(2) {
        type_error(e, "test functions cannot be called ('".concat(name).concat("')"))
    }
}

infer_field_access_fcall := proc(scope: TypeScope, mut e: Expr, shallow in_func: I32, ctx: Context) returns shallow Bool {
    ref mut fa : Expr = e.child(0)
    ref mut obj : Expr = fa.child(0)
    ref method0 : Str = get_payload(fa.data)
    mut method := method0.clone()
    infer_expr(scope, obj, in_func, ctx)

    mut obj_is_type := false
    if is_variant(obj.data, NodeType.Ident) {
        sf_tb := scope.find(get_payload(obj.data))
        if is_variant(sf_tb, ScopeFind.Found) {
            ref tb : TypeBinding = get_payload(sf_tb)
            if is_null(tb.struct_def).not() {
                obj_is_type = true
            }
        }
    }

    mut ufcs_desugared := false
    if obj_is_type.not() {
        ref mut type_name : Str = NULL
        if is_variant(obj.til_type, TilType.I64)
            .or(is_variant(obj.til_type, TilType.U8))
            .or(is_variant(obj.til_type, TilType.I16))
            .or(is_variant(obj.til_type, TilType.I32))
            .or(is_variant(obj.til_type, TilType.U32))
            .or(is_variant(obj.til_type, TilType.U64))
            .or(is_variant(obj.til_type, TilType.F32))
            .or(is_variant(obj.til_type, TilType.Bool)) {
            type_name = til_type_name_c(obj.til_type)
        } else if is_variant(obj.til_type, TilType.Struct).or(is_variant(obj.til_type, TilType.Enum)) {
            if obj.struct_name.len().gt(0) {
                type_name = obj.struct_name
            }
        }

        ref mut sdef1 : Expr = NULL
        if is_null(type_name).not() {
            sdef1 = scope.get_struct(type_name)
        }
        ref ns_func1 : Expr = find_namespace_func(sdef1, method)
        if is_null(ns_func1) {
            if try_ufcs_rewrite(scope, e, fa, obj, method, type_name) {
                return false
            }
            if infer_func_ptr_field_call(scope, e, fa, obj, sdef1, method, in_func, ctx) {
                return true
            }
            if is_null(type_name) {
                if is_variant(obj.til_type, TilType.Dynamic) {
                    type_error(e, format(
                        "cannot call method '", method, "' on Dynamic value; ",
                        "use 'ref x : Type = ...' to declare with an explicit type first",
                    ))
                } else {
                    type_error(e, format("no method '", method, "' for type 'unknown'"))
                }
            } else {
                type_error(e, format("no method '", method, "' for type '", type_name, "'"))
            }
            e.til_type = TilType.Unknown
            return true
        }
        ufcs_desugared = true
        mut instance := obj.clone()
        mut type_ident := Expr.new(NodeType.Ident(type_name.clone()), obj.line, obj.col, obj.path)
        fa.children.set(0, own type_ident)
        mut new_children := Vec.new("Expr", Expr.size())
        new_children.push(own e.child(0).clone())
        new_children.push(own instance)
        for i in 1..e.child_count() {
            new_children.push(own e.child(i).clone())
        }
        e.children = new_children
        ref mut fa2 : Expr = e.child(0)
        ref method2 : Str = get_payload(fa2.data)
        method = method2.clone()
    }

    ref mut fa3 : Expr = e.child(0)
    ref mut obj3 : Expr = fa3.child(0)
    if is_variant(obj3.til_type, TilType.Unknown) {
        infer_expr(scope, obj3, in_func, ctx)
    }
    ref mut sdef2 : Expr = NULL
    if obj3.struct_name.len().gt(0) {
        sdef2 = scope.get_struct(obj3.struct_name)
    }
    ref ns_func2 : Expr = find_namespace_func(sdef2, method)
    if is_null(ns_func2) {
        type_error(e, format("no namespace function '", method, "'"))
        e.til_type = TilType.Unknown
        return true
    }
    fa3.is_ns_field = true
    {
        ref ns_fdef : FunctionDef = get_payload(ns_func2.data)
        np := ns_fdef.nparam
        mut new_args := Vec.new("CtorArg", CtorArg.size())
        for i in 0..np {
            new_args.push(own CtorArg.Unfilled())
        }
        mut pos_idx : U32 = 0
        mut seen_named := false
        for i in 1..e.child_count() {
            ref arg : Expr = e.child(i)
            if is_variant(arg.data, NodeType.NamedArg) {
                seen_named = true
                ref aname : Str = get_payload(arg.data)
                mut slot := -1.to_i32()
                for j in 0..np {
                    ref param : Param = ns_fdef.params.get(j)
                    if param.name.eq(aname) {
                        slot = j.to_i64().to_i32()
                        break
                    }
                }
                if slot.lt(0) {
                    type_error(arg, format("no parameter '", aname, "'"))
                } else {
                    ref slot_arg : CtorArg = new_args.get(slot.to_i64().to_u32())
                    if is_variant(slot_arg, CtorArg.Filled) {
                        type_error(arg, format("duplicate argument for parameter '", aname, "'"))
                    } else {
                        new_args.set(slot.to_i64().to_u32(), own CtorArg.Filled(arg.child(0).clone()))
                    }
                }
            } else {
                if seen_named {
                    type_error(arg, "positional argument after named argument")
                }
                if pos_idx.lt(np) {
                    new_args.set(pos_idx, own CtorArg.Filled(arg.clone()))
                }
                pos_idx = pos_idx.add(1)
            }
        }
        for i in 0..np {
            ref slot_arg : CtorArg = new_args.get(i)
            if is_variant(slot_arg, CtorArg.Filled).not() {
                ref param : Param = ns_fdef.params.get(i)
                if ns_fdef.param_defaults.has(param.name) {
                    ref def_expr : Expr = ns_fdef.param_defaults.get(param.name)
                    new_args.set(i, own CtorArg.Filled(def_expr.clone()))
                } else {
                    type_error(e, format("missing argument for parameter '", param.name, "'"))
                }
            }
        }
        if pos_idx.gt(np) {
            type_error(e, format("too many arguments: expected ", np.to_i64().to_str(), ", got ", pos_idx.to_i64().to_str()))
        }
        mut new_ch := Vec.new("Expr", Expr.size())
        ref callee : Expr = e.child(0)
        new_ch.push(own callee.clone())
        for i in 0..np {
            ref slot_arg : CtorArg = new_args.get(i)
            ref filled_arg : Expr = get_payload(slot_arg)
            new_ch.push(own filled_arg.clone())
        }
        e.children = new_ch
    }
    for i in 1..e.child_count() {
        infer_expr(scope, e.child(i), in_func, ctx)
    }
    for i in 1..e.child_count() {
        ref ns_fdef2 : FunctionDef = get_payload(ns_func2.data)
        if i.sub(1).gte(ns_fdef2.nparam) { break }
        ref param2 : Param = ns_fdef2.params.get(i.sub(1))
        ref ptype : Str = param2.ptype
        narrow_dynamic(e.child(i), type_from_name(ptype, scope), ptype)
    }
    for i in 1..e.child_count() {
        ref ns_fdef3 : FunctionDef = get_payload(ns_func2.data)
        if i.sub(1).gte(ns_fdef3.nparam) { break }
        ref param3 : Param = ns_fdef3.params.get(i.sub(1))
        ref ptype_name : Str = param3.ptype
        ref arg : Expr = e.child(i)
        if is_variant(arg.til_type, TilType.Dynamic) { continue }
        ptype := type_from_name(ptype_name, scope)
        if is_variant(ptype, TilType.Dynamic) { continue }
        if is_variant(arg.data, NodeType.LiteralNum) {
            if is_numeric_type(ptype) {
                if literal_in_range(get_payload(arg.data), ptype).not() {
                    type_error(arg, format(
                        "integer literal ", get_payload(arg.data), " out of range for ", til_type_name_c(ptype),
                    ))
                }
                arg.til_type = ptype
                continue
            }
        }
        if can_implicit_widen(arg.til_type, ptype)
            .or(can_implicit_usize_coerce(arg.til_type, ptype, ptype_name)) {
            arg.til_type = ptype
            continue
        }
        if type_prefix(arg.til_type, arg.struct_name).eq(type_prefix(ptype, ptype_name)).not() {
            ref param_name : Str = param3.name
            type_error(arg, format(
                "argument type mismatch for '", param_name,
                "': expected ", ptype_name, ", got ", til_type_name_c(arg.til_type),
            ))
        } else if is_variant(ptype, TilType.Struct).or(is_variant(ptype, TilType.Enum)) {
            if arg.struct_name.len().gt(0) {
                if ptype_name.eq(arg.struct_name).not() {
                    ref param_name : Str = param3.name
                    type_error(arg, format(
                        "argument type mismatch for '", param_name,
                        "': expected ", ptype_name, ", got ", arg.struct_name,
                    ))
                }
            }
        }
    }
    if ufcs_desugared {
        if e.child(0).is_own_arg {
            if e.child_count().gt(1) {
                ref mut arg2 : Expr = e.child(1)
                arg2.is_own_arg = true
            }
        }
    }
    {
        ref ns_fdef4 : FunctionDef = get_payload(ns_func2.data)
        np := ns_fdef4.nparam
        if ns_fdef4.params.len().gt(0) {
            for i in 1..e.child_count() {
                if i.sub(1).gte(np) { break }
                ref pp : Param = ns_fdef4.params.get(i.sub(1))
                pown := pp.own_type.eq(OwnType.Own)
                ref arg : Expr = e.child(i)
                if pown {
                    if arg.is_own_arg.not() {
                        type_error(arg, format("argument for 'own' parameter '", pp.name, "' must be marked 'own'"))
                    }
                } else if arg.is_own_arg {
                    type_error(arg, format("'own' on argument but parameter '", pp.name, "' is not 'own'"))
                }
                if pown {
                    if is_variant(arg.data, NodeType.Ident) {
                        sf_ab := scope.find(get_payload(arg.data))
                        if is_variant(sf_ab, ScopeFind.Found) {
                            ref ab : TypeBinding = get_payload(sf_ab)
                            if ab.is_ref {
                                type_error(arg, "cannot pass ref variable to 'own' parameter; use .clone() to make an owned copy")
                            }
                        }
                    }
                }
                if pown {
                    if is_variant(arg.data, NodeType.LiteralNull) {
                        type_error(arg, "cannot pass null to 'own' parameter")
                    }
                }
                if pp.own_type.eq(OwnType.Shallow) {
                    if is_variant(arg.data, NodeType.LiteralNull) {
                        type_error(arg, "cannot pass null to 'shallow' parameter")
                    }
                }
            }
        }
    }
    mut rt := TilType.None
    ref ns_fdef5 : FunctionDef = get_payload(ns_func2.data)
    if ns_fdef5.return_type.len().gt(0) {
        rt = type_from_name(ns_fdef5.return_type, scope)
    }
    e.til_type = rt
    if is_variant(rt, TilType.Struct).or(is_variant(rt, TilType.Enum)) {
        if ns_fdef5.return_type.len().gt(0) {
            e.struct_name = ns_fdef5.return_type.clone()
        }
    }
    return true
}

infer_fcall_expr := proc(scope: TypeScope, mut e: Expr, shallow in_func: I32, ctx: Context) {
    if is_variant(e.child(0).data, NodeType.FieldAccess) {
        if infer_field_access_fcall(scope, e, in_func, ctx) { return }
    }
    ref mut callee : Expr = e.child(0)
    ref name0 : Str = get_payload(callee.data)
    mut name := name0.clone()
    ref resolved_name : Str = resolve_type_alias(scope, name)
    if resolved_name.eq(name).not() {
        callee.data = NodeType.Ident(resolved_name.clone())
        name = resolved_name.clone()
    }
    if infer_struct_constructor_fcall(scope, e, name, in_func, ctx) { return }
    ref callee_bind : TypeBinding = scope.get_binding(name)
    if is_null(callee_bind).not() {
        if is_null(callee_bind.func_def).not() {
            if callee_bind.is_builtin.not().or(callee_bind.func_def.is_core.not()) {
                desugar_user_func_fcall_args(e, name, callee_bind)
            }
        }
    }
    infer_and_validate_fcall_args(scope, e, callee_bind, in_func, ctx)
    validate_fcall_own_args(scope, e, callee_bind)
    resolve_fcall_return_type(scope, e, name, callee_bind, in_func, ctx)
    return
}

infer_expr := proc(scope: TypeScope, mut expr: Expr, shallow in_func: I32, ctx: Context) {
    if is_variant(expr.data, NodeType.LiteralStr)
        .or(is_variant(expr.data, NodeType.LiteralNum))
        .or(is_variant(expr.data, NodeType.LiteralBool))
        .or(is_variant(expr.data, NodeType.LiteralNull)) {
        infer_literal_expr(expr)
    } else if is_variant(expr.data, NodeType.Ident) {
        infer_ident_expr(scope, expr)
    } else if is_variant(expr.data, NodeType.FuncDef) {
        infer_func_def_expr(scope, expr, ctx)
    } else if is_variant(expr.data, NodeType.StructDef).or(is_variant(expr.data, NodeType.EnumDef)) {
        infer_type_def_expr(scope, expr, ctx)
    } else if is_variant(expr.data, NodeType.FCall) {
        infer_fcall_expr(scope, expr, in_func, ctx)
    } else if is_variant(expr.data, NodeType.FieldAccess) {
        infer_field_access_expr(scope, expr, in_func, ctx)
    } else if is_variant(expr.data, NodeType.MapLit) {
        infer_map_lit_expr(scope, expr, in_func, ctx)
    } else if is_variant(expr.data, NodeType.SetLit) {
        infer_set_lit_expr(scope, expr, in_func, ctx)
    } else if is_variant(expr.data, NodeType.NamedArg) {
        infer_named_arg_expr(scope, expr, in_func, ctx)
    } else {
        expr.til_type = TilType.Unknown
    }
}

infer_ident_expr := proc(scope: TypeScope, mut expr: Expr) {
    type := scope.get_type(get_payload(expr.data))
    if is_variant(type, TilType.Unknown) {
        type_error(expr, "undefined symbol '".concat(get_payload(expr.data)).concat("'"))
    }
    expr.til_type = type
    ref ib : TypeBinding = scope.get_binding(get_payload(expr.data))
    if is_null(ib).not() {
        if is_variant(type, TilType.Struct).or(is_variant(type, TilType.Enum)) {
            if ib.struct_name.len().gt(0) { expr.struct_name = ib.struct_name.clone() }
        }
        if is_null(ib.func_def).not() {
            expr.til_type = TilType.FuncPtr
        }
        if is_null(ib.struct_def).not() {
            expr.struct_name = resolve_type_alias(scope, get_payload(expr.data)).clone()
        }
    }
}

infer_named_arg_expr := proc(scope: TypeScope, mut expr: Expr, shallow in_func: I32, ctx: Context) {
    if expr.child_count().gt(0) {
        infer_expr(scope, expr.child(0), in_func, ctx)
        ref val : Expr = expr.child(0)
        expr.til_type = val.til_type
        if val.struct_name.len().gt(0) { expr.struct_name = val.struct_name.clone() }
    }
}

infer_map_lit_expr := proc(scope: TypeScope, mut expr: Expr, shallow in_func: I32, ctx: Context) {
    for i in 0..expr.child_count() {
        infer_expr(scope, expr.child(i), in_func, ctx)
    }
    expr.til_type = TilType.Struct
    expr.struct_name = "Map".clone()
}

infer_set_lit_expr := proc(scope: TypeScope, mut expr: Expr, shallow in_func: I32, ctx: Context) {
    for i in 0..expr.child_count() {
        infer_expr(scope, expr.child(i), in_func, ctx)
    }
    expr.til_type = TilType.Struct
    expr.struct_name = "Set".clone()
}

infer_type_def_expr := proc(scope: TypeScope, mut expr: Expr, ctx: Context) {
    expr.til_type = TilType.None
    if is_variant(expr.data, NodeType.EnumDef) {
        ref body : Expr = expr.child(0)
        for vi in 0..body.child_count() {
            ref v : Expr = body.child(vi)
            if is_variant(v.data, NodeType.Decl) {
                ref dd : Declaration = get_payload(v.data)
                if dd.is_namespace.not().and(dd.explicit_type.len().gt(0)).and(dd.is_ref) {
                    type_error(v, "ref payloads in tagged enum variants are not supported")
                }
            }
        }
    }
    inner := TypeScope.new(scope)
    infer_body(inner, expr.child(0), 0, 0, 0, 0, 1, ctx)
    TypeScope.delete(own inner)
}

infer_func_sig_expr := proc(scope: TypeScope, mut expr: Expr) {
    ref mut fdef : FunctionDef = get_payload(expr.data)
    if fdef.return_type.len().gt(0) {
        return_type_name := fdef.return_type.clone()
        ref resolved_return_type : Str = resolve_type_alias(scope, return_type_name)
        fdef.return_type = resolved_return_type
    }
    for i in 0..fdef.nparam {
        ref mut param : Param = fdef.params.get(i)
        ptype_name := param.ptype.clone()
        ref resolved_ptype : Str = resolve_type_alias(scope, ptype_name)
        param.ptype = resolved_ptype
    }
    expr.til_type = TilType.FuncPtr
}

check_ref_function_returns := proc(func_scope: TypeScope, expr: Expr) {
    ref fdef : FunctionDef = get_payload(expr.data)
    if fdef.return_own_type.eq(OwnType.Ref).not() { return }
    ref body : Expr = expr.child(0)
    for ri in 0..body.child_count() {
        ref stmt : Expr = body.child(ri)
        if is_variant(stmt.data, NodeType.Return).not() { continue }
        if stmt.child_count().eq(0) { continue }
        ref rv : Expr = stmt.child(0)
        if expr_is_borrow_source(rv, func_scope).not() {
            type_error(stmt, "ref function must return a parameter or ref variable")
        }
    }
}

infer_func_def_expr := proc(scope: TypeScope, mut expr: Expr, ctx: Context) {
    if expr.child_count().eq(0) {
        infer_func_sig_expr(scope, expr)
        return
    }
    expr.til_type = TilType.None
    ref mut fdef : FunctionDef = get_payload(expr.data)
    is_func := is_variant(fdef.func_type, FuncType.Func)
    is_macro := is_variant(fdef.func_type, FuncType.Macro)
    if is_variant(fdef.func_type, FuncType.Test) {
        if is_null(scope.parent).not() {
            type_error(expr, "test functions can only be declared in root scope")
        }
        if fdef.return_type.len().gt(0) {
            type_error(expr, "test functions cannot have a return type")
        }
        if fdef.nparam.gt(0) {
            type_error(expr, "test functions cannot have parameters")
        }
    }
    ref cur_mode : Mode = context_mode(ctx)
    if cur_mode.is_pure {
        if is_variant(fdef.func_type, FuncType.Proc) {
            type_error(expr, "proc not allowed in pure mode")
        }
    }
    mut func_scope := TypeScope.new(scope)
    if fdef.return_type.len().gt(0) {
        return_type_name := fdef.return_type.clone()
        ref resolved_return_type : Str = resolve_type_alias(scope, return_type_name)
        fdef.return_type = resolved_return_type
    }
    for i in 0..fdef.nparam {
        ref mut param : Param = fdef.params.get(i)
        ptype_name := param.ptype.clone()
        ref resolved_ptype : Str = resolve_type_alias(scope, ptype_name)
        param.ptype = resolved_ptype
        ref ptn : Str = param.ptype
        pt := type_from_name(ptn, scope)
        if is_variant(pt, TilType.Unknown) {
            type_error(expr, "undefined type '".concat(ptn).concat("'"))
        }
        pmut := param.is_mut
        pown := param.own_type.eq(OwnType.Own)
        pshallow := param.own_type.eq(OwnType.Shallow)
        if pshallow {
            is_scalar := is_variant(pt, TilType.I64)
                .or(is_variant(pt, TilType.U8))
                .or(is_variant(pt, TilType.I16))
                .or(is_variant(pt, TilType.I32))
                .or(is_variant(pt, TilType.U32))
                .or(is_variant(pt, TilType.U64))
                .or(is_variant(pt, TilType.F32))
                .or(is_variant(pt, TilType.Bool))
            if is_scalar.not().and(is_variant(pt, TilType.Struct).not()).and(is_variant(pt, TilType.StructDef).not()).and(is_variant(pt, TilType.Enum).not()) {
                type_error(expr, "shallow parameter '".concat(param.name).concat("' must be a scalar or struct type"))
            }
            if pown {
                type_error(expr, "parameter cannot be both 'shallow' and 'own'")
            }
        }
        if i.to_i64().to_i32().eq(fdef.variadic_index) {
            param.own_type = OwnType.Own
            func_scope.set(param.name, TilType.Struct, -1.to_i32(), false, expr.line, expr.col, true, true)
            ref mut pb : TypeBinding = func_scope.get_binding(param.name)
            pb.struct_name = "Array"
        } else if i.to_i64().to_i32().eq(fdef.kwargs_index) {
            param.own_type = OwnType.Own
            func_scope.set(param.name, TilType.Struct, -1.to_i32(), false, expr.line, expr.col, true, true)
            ref mut pb : TypeBinding = func_scope.get_binding(param.name)
            pb.struct_name = "DynMap"
        } else {
            func_scope.set(param.name, pt, -1.to_i32(), pmut, expr.line, expr.col, true, pown)
            ref mut pb : TypeBinding = func_scope.get_binding(param.name)
            if is_variant(pt, TilType.Struct).or(is_variant(pt, TilType.Enum)) {
                pb.struct_name = ptn.clone()
            }
            if is_variant(pt, TilType.FuncPtr) {
                sf_fsb := scope.find(ptn)
                if is_variant(sf_fsb, ScopeFind.Found) {
                    ref fsb : TypeBinding = get_payload(sf_fsb)
                    if is_null(fsb.func_def).not() {
                        if fsb.func_def.child_count().eq(0) {
                            pb.func_def = fsb.func_def
                        }
                    }
                }
            }
        }
    }
    mut in_func_val := 0.to_i32()
    if is_func { in_func_val = 1 }
    mut returns_ref_val := 0.to_i32()
    if fdef.return_own_type.eq(OwnType.Ref) { returns_ref_val = 1 }
    infer_body(func_scope, expr.child(0), in_func_val, 1, 0, returns_ref_val, 0, ctx)
    if is_macro.and(fdef.return_type.len().eq(0)) {
        type_error(expr, "macro must declare a return type")
    }
    check_ref_function_returns(func_scope, expr)
    TypeScope.delete(own func_scope)
}

infer_return_stmt := proc(scope: TypeScope, mut stmt: Expr, shallow in_func: I32, shallow returns_ref: I32, ctx: Context) {
    if stmt.child_count().gt(0) {
        infer_expr(scope, stmt.child(0), in_func, ctx)
        stmt.til_type = stmt.child(0).til_type
        if returns_ref.eq(0).and(is_variant(stmt.child(0).data, NodeType.Ident)) {
            sf := scope.find(get_payload(stmt.child(0).data))
            if is_variant(sf, ScopeFind.Found) {
                ref b : TypeBinding = get_payload(sf)
                if b.is_ref.and(b.is_alias.not()).and(b.is_param.not()) {
                    type_error(stmt, "cannot return ref variable from non-ref function; use .clone() or 'returns ref'")
                }
            }
        }
        if returns_ref.eq(0).and(is_variant(stmt.child(0).data, NodeType.Ident)) {
            sf := scope.find(get_payload(stmt.child(0).data))
            if is_variant(sf, ScopeFind.Found) {
                ref b : TypeBinding = get_payload(sf)
                if b.is_ref.and(b.is_alias).or(b.is_param.and(b.is_own.not())) {
                    tname := type_to_name(stmt.til_type, stmt.child(0).struct_name)
                    if tname.len().gt(0) {
                        mc := make_clone_call(tname, stmt.til_type, stmt.child(0), stmt)
                        stmt.children.set(0, own mc)
                    }
                }
            }
        }
    } else {
        stmt.til_type = TilType.None
    }
}

infer_if_stmt := proc(scope: TypeScope, mut stmt: Expr, shallow in_func: I32, shallow in_loop: I32, shallow returns_ref: I32, ctx: Context) {
    infer_expr(scope, stmt.child(0), in_func, ctx)
    if is_variant(stmt.child(0).til_type, TilType.Bool).not().and(is_variant(stmt.child(0).til_type, TilType.Unknown).not()) {
        type_error(stmt, "if condition must be Bool")
    }
    then_scope := TypeScope.new(scope)
    infer_body(then_scope, stmt.child(1), in_func, 1, in_loop, returns_ref, 0, ctx)
    TypeScope.delete(own then_scope)
    if stmt.child_count().gt(2) {
        else_scope := TypeScope.new(scope)
        infer_body(else_scope, stmt.child(2), in_func, 1, in_loop, returns_ref, 0, ctx)
        TypeScope.delete(own else_scope)
    }
    stmt.til_type = TilType.None
}

infer_field_access_expr := proc(scope: TypeScope, mut expr: Expr, shallow in_func: I32, ctx: Context) {
    infer_expr(scope, expr.child(0), in_func, ctx)
    ref obj : Expr = expr.child(0)
    if obj.struct_name.len().gt(0) {
        ref sdef : Expr = scope.get_struct(obj.struct_name)
        if is_null(sdef).not() {
            ref body : Expr = sdef.child(0)
            ref fname : Str = get_payload(expr.data)
            mut found := false
            for i in 0..body.child_count() {
                ref field : Expr = body.child(i)
                ref fld_decl : Declaration = get_payload(field.data)
                if is_variant(sdef.data, NodeType.EnumDef).and(fld_decl.is_namespace.not()) {
                    continue
                }
                if fld_decl.name.eq(fname) {
                    expr.til_type = field.til_type
                    expr.is_ns_field = fld_decl.is_namespace
                    expr.is_own_field = fld_decl.is_own.or(fld_decl.is_ref)
                    expr.is_ref_field = fld_decl.is_ref
                    if is_variant(field.til_type, TilType.Struct).or(is_variant(field.til_type, TilType.Enum)) {
                        ref child0 : Expr = field.child(0)
                        if child0.struct_name.len().gt(0) {
                            expr.struct_name = child0.struct_name.clone()
                        }
                    } else {
                        if obj.struct_name.len().gt(0) {
                            expr.struct_name = obj.struct_name.clone()
                        }
                    }
                    if is_variant(sdef.data, NodeType.EnumDef).and(fld_decl.is_namespace).and(field.child_count().gt(0)) {
                        ref fc : Expr = field.child(0)
                        if is_variant(fc.data, NodeType.FuncDef).not() {
                            expr.til_type = TilType.Enum
                            if obj.struct_name.len().gt(0) {
                                expr.struct_name = obj.struct_name.clone()
                            }
                        } else {
                            ref fd : FunctionDef = get_payload(fc.data)
                            if is_variant(fd.func_type, FuncType.ExtFunc).and(fd.return_type.len().gt(0)).and(fd.return_type.eq(obj.struct_name)) {
                                expr.til_type = TilType.Enum
                                if obj.struct_name.len().gt(0) {
                                    expr.struct_name = obj.struct_name.clone()
                                }
                            }
                        }
                    }
                    found = true
                    break
                }
            }
            if found.not() {
                mut kind := "struct"
                if is_variant(sdef.data, NodeType.EnumDef) { kind = "enum" }
                type_error(expr, kind.concat(" '").concat(obj.struct_name).concat("' has no field '").concat(fname).concat("'"))
                expr.til_type = TilType.Unknown
            }
        }
    } else {
        type_error(expr, "field access on non-struct value")
        expr.til_type = TilType.Unknown
    }
}

infer_field_assign_stmt := proc(scope: TypeScope, mut stmt: Expr, shallow in_func: I32, ctx: Context) {
    infer_expr(scope, stmt.child(0), in_func, ctx)
    infer_expr(scope, stmt.child(1), in_func, ctx)
    ref obj : Expr = stmt.child(0)
    ref mut rhs : Expr = stmt.child(1)
    ref fname : Str = get_payload(stmt.data)
    if obj.struct_name.len().gt(0) {
        ref sdef : Expr = scope.get_struct(obj.struct_name)
        if is_null(sdef).not() {
            ref body : Expr = sdef.child(0)
            mut found := false
            for i in 0..body.child_count() {
                ref field : Expr = body.child(i)
                ref fld_decl : Declaration = get_payload(field.data)
                if fld_decl.name.eq(fname) {
                    found = true
                    stmt.is_ns_field = fld_decl.is_namespace
                    stmt.is_own_field = fld_decl.is_own.or(fld_decl.is_ref)
                    stmt.is_ref_field = fld_decl.is_ref
                    if fld_decl.is_mut.not() {
                        type_error(stmt, "cannot assign to immutable field '".concat(fname).concat("'"))
                    }
                    if is_variant(rhs.data, NodeType.LiteralNum).and(is_numeric_type(field.til_type)) {
                        if literal_in_range(get_payload(rhs.data), field.til_type).not() {
                            type_error(rhs, "integer literal out of range for field '".concat(fname).concat("'"))
                        }
                        rhs.til_type = field.til_type
                    } else {
                        rhs_type := rhs.til_type
                        if is_variant(rhs_type, field.til_type).not() {
                            if is_variant(rhs_type, TilType.Unknown).not() {
                                if is_variant(rhs_type, TilType.Dynamic).not() {
                                    type_error(stmt, "field '".concat(fname).concat("' type mismatch"))
                                }
                            }
                        }
                    }
                    break
                }
            }
            if found.not() {
                type_error(stmt, "struct '".concat(obj.struct_name).concat("' has no field '").concat(fname).concat("'"))
            }
        }
    } else {
        type_error(stmt, "field assignment on non-struct value")
    }
    stmt.til_type = TilType.None
    if stmt.is_ref_field.not().and(
        is_variant(rhs.data, NodeType.Ident).or(
            is_variant(rhs.data, NodeType.FieldAccess).and(
                is_variant(rhs.til_type, TilType.Struct).or(
                    is_variant(rhs.til_type, TilType.Enum)
                )
            )
        )
    ) {
        tname := type_to_name(rhs.til_type, rhs.struct_name)
        if tname.len().gt(0) {
            mc := make_clone_call(tname, rhs.til_type, rhs, rhs)
            stmt.children.set(1, own mc)
        }
    }
}

infer_while_stmt := proc(scope: TypeScope, mut stmt: Expr, shallow in_func: I32, shallow returns_ref: I32, ctx: Context) {
    infer_expr(scope, stmt.child(0), in_func, ctx)
    if is_variant(stmt.child(0).til_type, TilType.Bool).not().and(is_variant(stmt.child(0).til_type, TilType.Unknown).not()) {
        type_error(stmt, "while condition must be Bool, got ".concat(type_to_name(stmt.child(0).til_type, stmt.child(0).struct_name)))
    }
    if expr_contains_fcall(stmt.child(0)) {
        ref cond : Expr = stmt.child(0)
        line := cond.line
        col := cond.col
        path := cond.path
        ref body : Expr = stmt.child(1)
        wname := "_wcond_Bool_".concat(hoist_counter.to_str())
        hoist_counter.inc()

        mut decl := Expr.new(NodeType.Decl(Declaration(name = wname.clone())), line, col, path)
        decl.til_type = TilType.Bool
        decl.add_child(own cond.clone())
        ref mut decl_rhs : Expr = decl.child(0)
        decl_rhs.til_type = TilType.Bool

        mut ident := Expr.new(NodeType.Ident(wname.clone()), line, col, path)
        ident.til_type = TilType.Bool

        mut if_node := Expr.new(NodeType.If, line, col, path)
        if_node.til_type = TilType.None
        if_node.add_child(own ident)

        mut then_body := Expr.new(NodeType.Body, line, col, path)
        then_body.til_type = TilType.None
        if_node.add_child(own then_body)

        mut else_body := Expr.new(NodeType.Body, line, col, path)
        else_body.til_type = TilType.None
        mut brk := Expr.new(NodeType.Break, line, col, path)
        brk.til_type = TilType.None
        else_body.add_child(own brk)
        if_node.add_child(own else_body)

        mut new_ch := Vec.new("Expr", Expr.size())
        new_ch.push(own decl)
        new_ch.push(own if_node)
        for j in 0..body.child_count() {
            new_ch.push(own body.child(j).clone())
        }
        body.children = new_ch

        mut true_lit := Expr.new(NodeType.LiteralBool(true), line, col, path)
        true_lit.til_type = TilType.Bool
        stmt.children.set(0, own true_lit)
    }
    while_scope := TypeScope.new(scope)
    infer_body(while_scope, stmt.child(1), in_func, 1, 1, returns_ref, 0, ctx)
    TypeScope.delete(own while_scope)
    stmt.til_type = TilType.None
}

infer_decl_type_def := proc(scope: TypeScope, mut stmt: Expr) returns shallow Bool {
    if is_variant(stmt.child(0).data, NodeType.StructDef).not().and(is_variant(stmt.child(0).data, NodeType.EnumDef).not()) {
        return false
    }
    is_enum := is_variant(stmt.child(0).data, NodeType.EnumDef)
    ref mut sdecl : Declaration = get_payload(stmt.data)
    if sdecl.explicit_type.len().gt(0) {
        declared := type_from_name(sdecl.explicit_type, scope)
        mut expected := TilType.StructDef
        if is_enum { expected = TilType.EnumDef }
        if is_variant(declared, expected).not() {
            mut value_type := "StructDef"
            if is_enum { value_type = "EnumDef" }
            type_error(stmt, "'".concat(sdecl.name).concat("' declared as ").concat(sdecl.explicit_type).concat(" but value is ").concat(value_type))
        }
    }
    stmt.til_type = TilType.None
    ref sname : Str = sdecl.name
    ref existing : TypeBinding = scope.get_binding(sname)
    if is_null(existing).not() {
        if is_null(existing.struct_def).not() {
            if existing.struct_def.line.neq(stmt.child(0).line).or(
                existing.struct_def.col.neq(stmt.child(0).col).or(
                    existing.struct_def.path.eq(stmt.child(0).path).not()
                )
            ) {
                mut kind := "struct"
                if is_enum { kind = "enum" }
                type_error(stmt, kind.concat(" '").concat(sname).concat("' already declared at ")
                    .concat(existing.struct_def.path).concat(":").concat(existing.line.to_str()).concat(":").concat(existing.col.to_str()))
                return true
            }
        }
    }
    mut builtin_type := TilType.Struct
    mut is_builtin := false
    if is_enum { builtin_type = TilType.Enum }
    if sname.eq("I64") { builtin_type = TilType.I64; is_builtin = true }
    else if sname.eq("U8") { builtin_type = TilType.U8; is_builtin = true }
    else if sname.eq("I16") { builtin_type = TilType.I16; is_builtin = true }
    else if sname.eq("I32") { builtin_type = TilType.I32; is_builtin = true }
    else if sname.eq("U32") { builtin_type = TilType.U32; is_builtin = true }
    else if sname.eq("U64") { builtin_type = TilType.U64; is_builtin = true }
    else if sname.eq("F32") { builtin_type = TilType.F32; is_builtin = true }
    else if sname.eq("Str") { is_builtin = false }
    else if sname.eq("Bool") { builtin_type = TilType.Bool; is_builtin = true }
    else if sname.eq("StructDef") { builtin_type = TilType.StructDef; is_builtin = true }
    else if sname.eq("EnumDef") { builtin_type = TilType.EnumDef; is_builtin = true }
    else if sname.eq("FunctionDef") { is_builtin = false }
    else if sname.eq("Dynamic") { builtin_type = TilType.Dynamic; is_builtin = true }
    scope.set(sname, builtin_type, -1.to_i32(), false, stmt.line, stmt.col, false, false)
    ref mut b : TypeBinding = scope.get_binding(sname)
    b.struct_def = stmt.child(0)
    b.is_builtin = is_builtin
    return true
}

infer_decl_func_def := proc(scope: TypeScope, mut stmt: Expr) returns shallow Bool {
    if is_variant(stmt.child(0).data, NodeType.FuncDef).not() { return false }
    ref mut sdecl : Declaration = get_payload(stmt.data)
    if sdecl.explicit_type.len().gt(0).and(sdecl.explicit_type.eq("FunctionDef").not()) {
        type_error(stmt, "'".concat(sdecl.name).concat("' declared as ").concat(sdecl.explicit_type).concat(" but value is FunctionDef"))
    }
    ref fdef : FunctionDef = get_payload(stmt.child(0).data)
    mut callee_is_proc : I32 = 0
    if is_variant(fdef.func_type, FuncType.Test) {
        callee_is_proc = 2
    } else if is_variant(fdef.func_type, FuncType.Proc).or(is_variant(fdef.func_type, FuncType.ExtProc)) {
        callee_is_proc = 1
    }
    mut rt := TilType.None
    if fdef.return_type.len().gt(0) {
        rt = type_from_name(fdef.return_type, scope)
    }
    stmt.til_type = rt
    scope.set(sdecl.name, rt, callee_is_proc, false, stmt.line, stmt.col, false, false)
    ref mut fb : TypeBinding = scope.get_binding(sdecl.name)
    fb.func_def = stmt.child(0)
    if is_variant(fdef.func_type, FuncType.ExtFunc).or(is_variant(fdef.func_type, FuncType.ExtProc)) {
        fb.is_builtin = true
    }
    return true
}

infer_decl_type_alias_passthrough := proc(scope: TypeScope, mut stmt: Expr) returns shallow Bool {
    if is_variant(stmt.child(0).data, NodeType.Ident).not() { return false }
    ref mut sdecl : Declaration = get_payload(stmt.data)
    ref alias_b : TypeBinding = scope.get_binding(sdecl.name)
    if is_null(alias_b).not() {
        if alias_b.is_type_alias {
            stmt.til_type = TilType.None
            return true
        }
    }
    return false
}

infer_decl_typed_value := proc(scope: TypeScope, mut stmt: Expr) {
    ref mut sdecl : Declaration = get_payload(stmt.data)
    declared := type_from_name(sdecl.explicit_type, scope)
    ref mut val : Expr = stmt.child(0)
    if is_variant(declared, TilType.Unknown) {
        type_error(stmt, "undefined type '".concat(sdecl.explicit_type).concat("'"))
    } else if is_variant(val.data, NodeType.LiteralNum).and(is_numeric_type(declared).or(is_variant(declared, TilType.Dynamic))) {
        if is_numeric_type(declared).and(literal_in_range(get_payload(val.data), declared).not()) {
            type_error(val, "integer literal ".concat(get_payload(val.data)).concat(" out of range for ").concat(type_to_name(declared, "")))
        }
        val.til_type = declared
    } else if is_variant(val.data, NodeType.LiteralNull).and(sdecl.is_ref.not()) {
        type_error(stmt, "null can only be assigned to 'ref' declarations")
    } else if can_implicit_usize_coerce(val.til_type, declared, sdecl.explicit_type).not()
        .and(is_variant(val.til_type, declared).not())
        .and(is_variant(val.til_type, TilType.Dynamic).not()) {
        type_error(stmt, "'".concat(sdecl.name).concat("' declared as ").concat(type_to_name(declared, ""))
            .concat(" but value is ").concat(type_to_name(val.til_type, "")))
    } else if is_variant(declared, TilType.Struct).or(is_variant(declared, TilType.Enum)) {
        if val.struct_name.len().gt(0).and(resolve_type_alias(scope, sdecl.explicit_type).eq(val.struct_name).not()) {
            type_error(stmt, "'".concat(sdecl.name).concat("' declared as ").concat(sdecl.explicit_type)
                .concat(" but value is ").concat(val.struct_name))
        }
    }
    stmt.til_type = declared
    if can_implicit_usize_coerce(val.til_type, declared, sdecl.explicit_type) {
        val.til_type = declared
    }
    narrow_dynamic(val, declared, sdecl.explicit_type)
    if is_variant(declared, TilType.Struct).or(is_variant(declared, TilType.Enum)) {
        val.struct_name = resolve_type_alias(scope, sdecl.explicit_type).clone()
    }
}

infer_decl_untyped_value := proc(mut stmt: Expr) {
    stmt.til_type = stmt.child(0).til_type
    if stmt.child(0).struct_name.len().gt(0) {
        stmt.struct_name = stmt.child(0).struct_name.clone()
    }
    if is_variant(stmt.til_type, TilType.Dynamic) {
        ref sdecl : Declaration = get_payload(stmt.data)
        type_error(stmt, "cannot store Dynamic in '".concat(sdecl.name)
            .concat("'; add a type annotation like '").concat(sdecl.name).concat(" : Type = ...' to specify the concrete type"))
    }
}

finalize_decl_binding := proc(scope: TypeScope, mut stmt: Expr, shallow in_type_body: I32) {
    ref mut sdecl : Declaration = get_payload(stmt.data)
    ref mut rhs : Expr = stmt.child(0)
    if in_type_body.eq(0).and(sdecl.is_own) {
        if sdecl.is_mut {
            type_error(stmt, "no need for 'own' on mutable local '".concat(sdecl.name).concat("'; write 'mut ").concat(sdecl.name).concat(" := ...'"))
        } else {
            type_error(stmt, "no need for 'own' on local '".concat(sdecl.name).concat("'; locals are owned by default"))
        }
    }
    scope.set(sdecl.name, stmt.til_type, -1.to_i32(), sdecl.is_mut, stmt.line, stmt.col, false, false)
    ref mut decl_b : TypeBinding = scope.get_binding(sdecl.name)
    if is_variant(stmt.til_type, TilType.Struct).or(is_variant(stmt.til_type, TilType.Enum)) {
        if rhs.struct_name.len().gt(0) { decl_b.struct_name = rhs.struct_name.clone() }
    }
    if is_variant(stmt.til_type, TilType.FuncPtr) {
        if is_null(sdecl.fn_sig).not() {
            decl_b.func_def = sdecl.fn_sig
        } else if is_variant(rhs.data, NodeType.Ident) {
            ref src : TypeBinding = scope.get_binding(get_payload(rhs.data))
            if is_null(src).not() {
                if is_null(src.func_def).not() { decl_b.func_def = src.func_def }
            }
        } else if is_null(rhs.fn_sig).not() {
            decl_b.func_def = rhs.fn_sig
        }
        if is_null(decl_b.func_def) {
            if sdecl.explicit_type.len().gt(0) {
                ref fsb : TypeBinding = scope.get_binding(sdecl.explicit_type)
                if is_null(fsb).not() {
                    if is_null(fsb.func_def).not() {
                        if fsb.func_def.child_count().eq(0) {
                            decl_b.func_def = fsb.func_def
                        }
                    }
                }
            }
        }
    }
    if sdecl.is_ref {
        decl_b.is_ref = true
        if expr_is_ref_decl_source(rhs, scope).not() {
            type_error(stmt, "'ref' declaration requires null, a ref-returning function, or ref/param variable")
        }
    }
    if sdecl.is_ref.not().and(is_variant(rhs.data, NodeType.FCall)).and(fcall_returns_ref(rhs, scope).neq(0)) {
        type_error(stmt, "cannot own result of ref-returning function; use 'ref' or Type.clone()")
    }
    if sdecl.is_ref.not().and(sdecl.is_mut.not()).and(is_variant(stmt.til_type, TilType.FuncPtr).not()).and(is_variant(rhs.data, NodeType.Ident)) {
        ref rb : TypeBinding = scope.get_binding(get_payload(rhs.data))
        if is_null(rb).not() {
            if rb.is_mut.not().and(rb.is_own.not()).and(rb.is_ref.not().or(rb.is_alias)).and(rb.is_param.not()) {
                sdecl.is_ref = true
                decl_b.is_ref = true
                decl_b.is_alias = true
            }
        }
    }
    if is_variant(rhs.data, NodeType.Ident).or(
        is_variant(rhs.data, NodeType.FieldAccess).and(
            is_variant(rhs.til_type, TilType.Struct).or(is_variant(rhs.til_type, TilType.Enum))
        )
    ) {
        if sdecl.is_ref.not() {
            tname := type_to_name(stmt.til_type, rhs.struct_name)
            if tname.len().gt(0) {
                mc := make_clone_call(tname, stmt.til_type, rhs, stmt)
                stmt.children.set(0, own mc)
            }
        }
    }
}

infer_decl_stmt := proc(scope: TypeScope, mut stmt: Expr, shallow in_func: I32, shallow in_type_body: I32, ctx: Context) {
    if stmt.child_count().eq(0) { return }
    infer_expr(scope, stmt.child(0), in_func, ctx)
    if infer_decl_type_def(scope, stmt) { return }
    if infer_decl_func_def(scope, stmt) { return }
    if infer_decl_type_alias_passthrough(scope, stmt) { return }
    ref sdecl : Declaration = get_payload(stmt.data)
    if sdecl.explicit_type.len().gt(0) {
        infer_decl_typed_value(scope, stmt)
    } else {
        infer_decl_untyped_value(stmt)
    }
    finalize_decl_binding(scope, stmt, in_type_body)
}

mark_switch_case_covered_variant := proc(switch_enum_def: Expr, mut covered_variants: Vec, shallow n_variants: I32, sw_expr: Expr, match_expr: Expr) {
    if is_null(switch_enum_def).or(covered_variants.len().eq(0)) { return }
    mut covered_variant_name := ""
    if is_variant(match_expr.data, NodeType.FieldAccess) {
        if match_expr.child_count().gt(0) {
            if is_variant(match_expr.child(0).data, NodeType.Ident) {
                ref base_name : Str = get_payload(match_expr.child(0).data)
                if base_name.eq(sw_expr.struct_name) {
                    ref field_name : Str = get_payload(match_expr.data)
                    covered_variant_name = field_name.clone()
                }
            }
        }
    }
    if covered_variant_name.len().eq(0) {
        if is_variant(match_expr.data, NodeType.FCall) {
            if match_expr.child_count().eq(2) {
                if is_variant(match_expr.child(0).data, NodeType.FieldAccess) {
                    if match_expr.child(0).child_count().gt(0) {
                        if is_variant(match_expr.child(0).child(0).data, NodeType.Ident) {
                            if is_variant(match_expr.child(1).data, NodeType.Ident) {
                                ref type_name : Str = get_payload(match_expr.child(0).child(0).data)
                                if type_name.eq(sw_expr.struct_name) {
                                    ref field_name : Str = get_payload(match_expr.child(0).data)
                                    covered_variant_name = field_name.clone()
                                }
                            }
                        }
                    }
                }
            }
        }
    }
    if covered_variant_name.len().eq(0) { return }
    mut covered_tag : I32 = -1.to_i32()
    mut variant_idx : I32 = 0
    ref enum_body : Expr = switch_enum_def.child(0)
    for vi in 0..enum_body.child_count() {
        ref variant : Expr = enum_body.child(vi)
        if is_variant(variant.data, NodeType.Decl) {
            ref vd : Declaration = get_payload(variant.data)
            if vd.is_namespace { continue }
            if vd.name.eq(covered_variant_name) {
                covered_tag = variant_idx
                break
            }
            variant_idx.inc()
        }
    }
    if covered_tag.gte(0.to_i32()).and(covered_tag.lt(n_variants)) {
        ref mut covered : Bool = covered_variants.get(covered_tag.to_i64().to_u32())
        covered = true
    }
}

make_switch_case_condition := func(scope: TypeScope, mut case_body: Expr, match_expr: Expr, sw_name: Str, shallow sw_line: U32, shallow sw_col: U32, sw_path: Str) returns Expr {
    mut condition := Expr.new(NodeType.Body, sw_line, sw_col, sw_path)
    mut has_condition := false
    if is_variant(match_expr.data, NodeType.FCall) {
        if match_expr.child_count().eq(3) {
            if is_variant(match_expr.child(0).data, NodeType.FieldAccess) {
                ref method_name : Str = get_payload(match_expr.child(0).data)
                if method_name.eq("new") {
                    if match_expr.child(0).child_count().gt(0) {
                        if is_variant(match_expr.child(0).child(0).data, NodeType.Ident) {
                            ref range_name : Str = get_payload(match_expr.child(0).child(0).data)
                            if range_name.eq("Range") {
                ref start_expr : Expr = match_expr.child(1)
                ref end_expr : Expr = match_expr.child(2)

                mut sw1 := Expr.new(NodeType.Ident(sw_name.clone()), sw_line, sw_col, sw_path)
                mut gte_acc := Expr.new(NodeType.FieldAccess("gte"), sw_line, sw_col, sw_path)
                gte_acc.add_child(own sw1)
                mut gte_call := Expr.new(NodeType.FCall(FCallData()), sw_line, sw_col, sw_path)
                gte_call.add_child(own gte_acc)
                gte_call.add_child(own start_expr.clone())

                mut sw2 := Expr.new(NodeType.Ident(sw_name.clone()), sw_line, sw_col, sw_path)
                mut lte_acc := Expr.new(NodeType.FieldAccess("lte"), sw_line, sw_col, sw_path)
                lte_acc.add_child(own sw2)
                mut lte_call := Expr.new(NodeType.FCall(FCallData()), sw_line, sw_col, sw_path)
                lte_call.add_child(own lte_acc)
                lte_call.add_child(own end_expr.clone())

                mut and_acc := Expr.new(NodeType.FieldAccess("and"), sw_line, sw_col, sw_path)
                and_acc.add_child(own gte_call)
                condition = Expr.new(NodeType.FCall(FCallData()), sw_line, sw_col, sw_path)
                condition.add_child(own and_acc)
                condition.add_child(own lte_call)
                has_condition = true
                            }
                        }
                    }
                }
            }
        }
    }

    if has_condition.not() {
        if is_variant(match_expr.data, NodeType.FCall) {
            if match_expr.child_count().eq(2) {
                if is_variant(match_expr.child(0).data, NodeType.FieldAccess) {
                    if match_expr.child(0).child_count().gt(0) {
                        if is_variant(match_expr.child(0).child(0).data, NodeType.Ident) {
                            if is_variant(match_expr.child(1).data, NodeType.Ident) {
                                ref callee : Expr = match_expr.child(0)
                                ref type_name : Str = get_payload(callee.child(0).data)
                                ref variant_name : Str = get_payload(callee.data)
                                ref binding_name : Str = get_payload(match_expr.child(1).data)
                                ref enum_def : Expr = scope.get_struct(type_name)
                                if is_null(enum_def).not().and(is_variant(enum_def.data, NodeType.EnumDef)) {
                                    mut payload_type := ""
                                    ref enum_body : Expr = enum_def.child(0)
                                    for vi in 0..enum_body.child_count() {
                                        ref variant : Expr = enum_body.child(vi)
                                        if is_variant(variant.data, NodeType.Decl) {
                                            ref vd : Declaration = get_payload(variant.data)
                                            if vd.is_namespace.not().and(vd.name.eq(variant_name)) {
                                                payload_type = vd.explicit_type.clone()
                                                break
                                            }
                                        }
                                    }
                                    if payload_type.len().gt(0) {
                    mut iv_id := Expr.new(NodeType.Ident("is_variant"), sw_line, sw_col, sw_path)
                    mut sw_id := Expr.new(NodeType.Ident(sw_name.clone()), sw_line, sw_col, sw_path)
                    mut vtype_id := Expr.new(NodeType.Ident(type_name.clone()), sw_line, sw_col, sw_path)
                    mut vref := Expr.new(NodeType.FieldAccess(variant_name.clone()), sw_line, sw_col, sw_path)
                    vref.add_child(own vtype_id)
                    condition = Expr.new(NodeType.FCall(FCallData()), sw_line, sw_col, sw_path)
                    condition.add_child(own iv_id)
                    condition.add_child(own sw_id)
                    condition.add_child(own vref)

                    mut gp_ident := Expr.new(NodeType.Ident("get_payload"), sw_line, sw_col, sw_path)
                    mut sw_id2 := Expr.new(NodeType.Ident(sw_name.clone()), sw_line, sw_col, sw_path)
                    mut get_call := Expr.new(NodeType.FCall(FCallData()), sw_line, sw_col, sw_path)
                    get_call.add_child(own gp_ident)
                    get_call.add_child(own sw_id2)

                    mut bind_decl := Expr.new(NodeType.Decl(Declaration(name = binding_name.clone(), explicit_type = payload_type.clone(), is_ref = true)), sw_line, sw_col, sw_path)
                    bind_decl.add_child(own get_call)

                    mut new_ch := Vec.new("Expr", Expr.size())
                    new_ch.push(own bind_decl)
                    for bi in 0..case_body.child_count() {
                        new_ch.push(own case_body.child(bi).clone())
                    }
                    case_body.children = new_ch
                    has_condition = true
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    if has_condition.not() {
        if is_variant(match_expr.data, NodeType.FieldAccess) {
            if match_expr.child_count().gt(0) {
                if is_variant(match_expr.child(0).data, NodeType.Ident) {
                    ref type_name : Str = get_payload(match_expr.child(0).data)
                    ref variant_name : Str = get_payload(match_expr.data)
                    ref enum_def : Expr = scope.get_struct(type_name)
                    if is_null(enum_def).not().and(is_variant(enum_def.data, NodeType.EnumDef)) {
                        mut payload_type := ""
                        ref enum_body : Expr = enum_def.child(0)
                        for vi in 0..enum_body.child_count() {
                            ref variant : Expr = enum_body.child(vi)
                            if is_variant(variant.data, NodeType.Decl) {
                                ref vd : Declaration = get_payload(variant.data)
                                if vd.is_namespace.not().and(vd.name.eq(variant_name)) {
                                    payload_type = vd.explicit_type.clone()
                                    break
                                }
                            }
                        }
                        if payload_type.len().gt(0) {
                            mut iv_id := Expr.new(NodeType.Ident("is_variant"), sw_line, sw_col, sw_path)
                            mut sw_id := Expr.new(NodeType.Ident(sw_name.clone()), sw_line, sw_col, sw_path)
                            mut vtype_id := Expr.new(NodeType.Ident(type_name.clone()), sw_line, sw_col, sw_path)
                            mut vref := Expr.new(NodeType.FieldAccess(variant_name.clone()), sw_line, sw_col, sw_path)
                            vref.add_child(own vtype_id)
                            condition = Expr.new(NodeType.FCall(FCallData()), sw_line, sw_col, sw_path)
                            condition.add_child(own iv_id)
                            condition.add_child(own sw_id)
                            condition.add_child(own vref)
                            has_condition = true
                        }
                    }
                }
            }
        }
    }

    if has_condition.not() {
        mut sw_ident := Expr.new(NodeType.Ident(sw_name.clone()), sw_line, sw_col, sw_path)
        mut eq_access := Expr.new(NodeType.FieldAccess("eq"), sw_line, sw_col, sw_path)
        eq_access.add_child(own sw_ident)
        condition = Expr.new(NodeType.FCall(FCallData()), sw_line, sw_col, sw_path)
        condition.add_child(own eq_access)
        condition.add_child(own match_expr.clone())
    }
    return condition
}

replace_switch_stmt_with_block := proc(mut body: Expr, shallow stmt_idx: U32, mut block: Expr) {
    body.children.set(stmt_idx, own block.clone())
}

append_switch_else_if := proc(mut root_if: Expr, if_node: Expr) {
    if root_if.child_count().gt(2) {
        ref mut else_body : Expr = root_if.child(2)
        if else_body.child_count().gt(0) {
            if is_variant(else_body.child(0).data, NodeType.If) {
                append_switch_else_if(else_body.child(0), if_node)
                return
            }
        }
    }
    mut else_body := Expr.new(NodeType.Body, if_node.line, if_node.col, if_node.path)
    else_body.add_child(own if_node.clone())
    root_if.add_child(own else_body)
}

attach_switch_default_body := proc(mut root_if: Expr, default_body: Expr) {
    if root_if.child_count().gt(2) {
        ref mut else_body : Expr = root_if.child(2)
        if else_body.child_count().gt(0) {
            if is_variant(else_body.child(0).data, NodeType.If) {
                attach_switch_default_body(else_body.child(0), default_body)
                return
            }
        }
    }
    root_if.add_child(own default_body.clone())
}

infer_switch_stmt := proc(scope: TypeScope, mut body: Expr, shallow stmt_idx: U32, shallow in_func: I32, ctx: Context) {
    ref mut stmt : Expr = body.child(stmt_idx)
    ref mut sw_expr : Expr = stmt.child(0)
    sw_line := stmt.line
    sw_col := stmt.col
    sw_path := stmt.path
    infer_expr(scope, sw_expr, in_func, ctx)
    mut covered_variants := Vec.new("Bool", Bool.size())
    mut n_variants : I32 = 0
    mut has_default_case := false
    mut has_switch_enum_def := false
    if is_variant(sw_expr.til_type, TilType.Enum).and(sw_expr.struct_name.len().gt(0)) {
        ref switch_enum_def : Expr = scope.get_struct(sw_expr.struct_name)
        if is_null(switch_enum_def).not().and(is_variant(switch_enum_def.data, NodeType.EnumDef)) {
            has_switch_enum_def = true
            ref enum_body : Expr = switch_enum_def.child(0)
            for vi in 0..enum_body.child_count() {
                ref variant : Expr = enum_body.child(vi)
                if is_variant(variant.data, NodeType.Decl) {
                    ref vd : Declaration = get_payload(variant.data)
                    if vd.is_namespace.not() {
                        n_variants.inc()
                        covered_variants.push(own false)
                    }
                }
            }
        }
    }

    tp := type_prefix(sw_expr.til_type, sw_expr.struct_name)
    sw_name := "_sw_".concat(tp).concat("_").concat(hoist_counter.to_str())
    hoist_counter.inc()

    mut block := Expr.new(NodeType.Body, stmt.line, stmt.col, sw_path)
    mut decl := Expr.new(NodeType.Decl(Declaration(name = sw_name.clone())), stmt.line, stmt.col, sw_path)
    decl.add_child(own sw_expr.clone())
    block.add_child(own decl)

    ref mut first_if : Expr = NULL
    ref mut default_body : Expr = NULL

    for ci in 1..stmt.child_count() {
        ref case_node : Expr = stmt.child(ci)
        if case_node.child_count().eq(1) {
            default_body = case_node.child(0)
            has_default_case = true
            continue
        }
        ref mut match_expr : Expr = case_node.child(0)
        ref mut case_body : Expr = case_node.child(1)
        if has_switch_enum_def {
            ref switch_enum_def : Expr = scope.get_struct(sw_expr.struct_name)
            mark_switch_case_covered_variant(switch_enum_def, covered_variants, n_variants, sw_expr, match_expr)
        }
        condition := make_switch_case_condition(scope, case_body, match_expr, sw_name, sw_line, sw_col, sw_path)

        mut if_node := Expr.new(NodeType.If, case_node.line, case_node.col, sw_path)
        if_node.add_child(own condition)
        if_node.add_child(own case_body.clone())

        if is_null(first_if) {
            first_if = if_node
        } else {
            append_switch_else_if(first_if, if_node)
        }
    }

    if is_null(default_body).not().and(is_null(first_if).not()) {
        attach_switch_default_body(first_if, default_body)
    } else if is_null(default_body).not().and(is_null(first_if)) {
        first_if = default_body
    }

    if has_switch_enum_def.and(covered_variants.len().gt(0)).and(has_default_case.not()) {
        ref switch_enum_def : Expr = scope.get_struct(sw_expr.struct_name)
        ref enum_body : Expr = switch_enum_def.child(0)
        mut msg := "non-exhaustive switch on enum '".concat(sw_expr.struct_name).concat("'; missing cases:")
        mut variant_idx : U32 = 0
        mut missing := false
        for vi in 0..enum_body.child_count() {
            ref variant : Expr = enum_body.child(vi)
            if is_variant(variant.data, NodeType.Decl).not() { continue }
            ref vd : Declaration = get_payload(variant.data)
            if vd.is_namespace { continue }
            ref covered : Bool = covered_variants.get(variant_idx)
            if covered.not() {
                missing = true
                if msg.ends_with(":").not() { msg = msg.concat(",") }
                msg = msg.concat(" ").concat(vd.name)
            }
            variant_idx.inc()
        }
        if missing { type_error(stmt, msg) }
    }

    if is_null(first_if).not() { block.add_child(own first_if.clone()) }
    replace_switch_stmt_with_block(body, stmt_idx, block)
}

replace_body_stmt_with_block := proc(mut body: Expr, shallow stmt_idx: U32, mut block: Expr) {
    body.children.set(stmt_idx, own block.clone())
}

make_field_access_call0 := func(base: Expr, field: Str, shallow line: U32, shallow col: U32, path: Str) returns Expr {
    mut fa := Expr.new(NodeType.FieldAccess(field.clone()), line, col, path)
    fa.add_child(own base.clone())
    mut fc := Expr.new(NodeType.FCall(FCallData()), line, col, path)
    fc.add_child(own fa)
    return fc
}

make_field_access_call1 := func(base: Expr, field: Str, arg: Expr, shallow line: U32, shallow col: U32, path: Str) returns Expr {
    mut fa := Expr.new(NodeType.FieldAccess(field.clone()), line, col, path)
    fa.add_child(own base.clone())
    mut fc := Expr.new(NodeType.FCall(FCallData()), line, col, path)
    fc.add_child(own fa)
    fc.add_child(own arg.clone())
    return fc
}

make_for_in_range_while_body := func(var_name: Str, cur_name: Str, step: Str, for_body: Expr, shallow line: U32, shallow col: U32, path: Str, elem_type: Str) returns Expr {
    mut wb := Expr.new(NodeType.Body, line, col, path)

    mut vd := Expr.new(NodeType.Decl(Declaration(name = var_name.clone(), explicit_type = elem_type.clone())), line, col, path)
    mut cur_ident := Expr.new(NodeType.Ident(cur_name.clone()), line, col, path)
    vd.add_child(own cur_ident)
    wb.add_child(own vd)

    mut step_ident := Expr.new(NodeType.Ident(cur_name.clone()), line, col, path)
    wb.add_child(own make_field_access_call0(step_ident, step, line, col, path))

    for bi in 0..for_body.child_count() {
        wb.add_child(own for_body.child(bi).clone())
    }
    return wb
}

desugar_for_in_range_stmt := proc(scope: TypeScope, mut body: Expr, shallow stmt_idx: U32, shallow in_func: I32, ctx: Context) returns shallow Bool {
    ref mut stmt : Expr = body.child(stmt_idx)
    ref mut iter : Expr = stmt.child(0)
    if is_variant(iter.data, NodeType.FCall).not() { return false }
    if iter.child_count().neq(3) { return false }
    ref callee : Expr = iter.child(0)
    if is_variant(callee.data, NodeType.FieldAccess).not() { return false }
    ref callee_field : Str = get_payload(callee.data)
    if callee_field.eq("new").not() { return false }
    if callee.child_count().eq(0) { return false }
    ref callee_base : Expr = callee.child(0)
    if is_variant(callee_base.data, NodeType.Ident).not() { return false }
    ref callee_name : Str = get_payload(callee_base.data)
    if callee_name.eq("Range").not() { return false }

    ref mut start_expr : Expr = iter.child(1)
    ref mut end_expr : Expr = iter.child(2)
    infer_expr(scope, start_expr, in_func, ctx)
    infer_expr(scope, end_expr, in_func, ctx)

    mut elem_type := stmt.struct_name.clone()
    if elem_type.len().eq(0) {
        ref mut type_src : Expr = start_expr
        if is_variant(start_expr.data, NodeType.LiteralNum).and(is_variant(end_expr.data, NodeType.LiteralNum).not()) {
            type_src = end_expr
        } else if is_variant(end_expr.data, NodeType.LiteralNum).and(is_variant(start_expr.data, NodeType.LiteralNum).not()) {
            type_src = start_expr
        }
        if is_variant(type_src.til_type, TilType.Struct).or(is_variant(type_src.til_type, TilType.Enum)) {
            if type_src.struct_name.len().gt(0) {
                elem_type = type_src.struct_name.clone()
            } else {
                elem_type = type_to_name(type_src.til_type, "")
            }
        } else {
            elem_type = type_to_name(type_src.til_type, "")
        }
    }

    ref var_name : Str = get_payload(stmt.data)
    ref for_body : Expr = stmt.child(1)
    line := stmt.line
    col := stmt.col
    path := stmt.path
    counter := hoist_counter
    hoist_counter.inc()

    end_name := "_re_".concat(elem_type).concat("_").concat(counter.to_str())
    cur_name := "_rc_".concat(elem_type).concat("_").concat(counter.to_str())

    mut block := Expr.new(NodeType.Body, line, col, path)

    mut end_decl := Expr.new(NodeType.Decl(Declaration(name = end_name.clone(), explicit_type = elem_type.clone())), line, col, path)
    end_decl.add_child(own end_expr.clone())
    block.add_child(own end_decl)

    mut cur_decl := Expr.new(NodeType.Decl(Declaration(name = cur_name.clone(), explicit_type = elem_type.clone(), is_mut = true)), line, col, path)
    cur_decl.add_child(own start_expr.clone())
    block.add_child(own cur_decl)

    mut cur_ident_lt := Expr.new(NodeType.Ident(cur_name.clone()), line, col, path)
    mut end_ident_lt := Expr.new(NodeType.Ident(end_name.clone()), line, col, path)
    mut asc_while := Expr.new(NodeType.While, line, col, path)
    asc_while.add_child(own make_field_access_call1(cur_ident_lt, "lt", end_ident_lt, line, col, path))
    asc_while.add_child(own make_for_in_range_while_body(var_name, cur_name, "inc", for_body, line, col, path, elem_type))

    mut cur_ident_gt := Expr.new(NodeType.Ident(cur_name.clone()), line, col, path)
    mut end_ident_gt := Expr.new(NodeType.Ident(end_name.clone()), line, col, path)
    mut desc_while := Expr.new(NodeType.While, line, col, path)
    desc_while.add_child(own make_field_access_call1(cur_ident_gt, "gt", end_ident_gt, line, col, path))
    desc_while.add_child(own make_for_in_range_while_body(var_name, cur_name, "dec", for_body, line, col, path, elem_type))

    mut if_node := Expr.new(NodeType.If, line, col, path)
    mut cur_ident_lte := Expr.new(NodeType.Ident(cur_name.clone()), line, col, path)
    mut end_ident_lte := Expr.new(NodeType.Ident(end_name.clone()), line, col, path)
    if_node.add_child(own make_field_access_call1(cur_ident_lte, "lte", end_ident_lte, line, col, path))

    mut then_body := Expr.new(NodeType.Body, line, col, path)
    then_body.add_child(own asc_while)
    if_node.add_child(own then_body)

    mut else_body := Expr.new(NodeType.Body, line, col, path)
    else_body.add_child(own desc_while)
    if_node.add_child(own else_body)
    block.add_child(own if_node)

    replace_body_stmt_with_block(body, stmt_idx, block)
    return true
}

desugar_for_in_collection_stmt := proc(scope: TypeScope, mut body: Expr, shallow stmt_idx: U32, shallow in_func: I32, ctx: Context) returns shallow Bool {
    ref mut stmt : Expr = body.child(stmt_idx)
    ref mut iter : Expr = stmt.child(0)

    infer_expr(scope, iter, in_func, ctx)

    mut type_name := ""
    if is_variant(iter.til_type, TilType.Struct).or(is_variant(iter.til_type, TilType.Enum)) {
        if iter.struct_name.len().gt(0) {
            type_name = iter.struct_name.clone()
        }
    }
    if type_name.len().eq(0) {
        type_error(stmt, "for-in requires a collection type with get() and len() methods")
        return false
    }

    ref sdef : Expr = scope.get_struct(type_name)
    if is_null(sdef) {
        type_error(stmt, "for-in requires a collection type with get() and len() methods")
        return false
    }

    ref sbody : Expr = sdef.child(0)
    ref mut len_func : Expr = NULL
    ref mut get_func : Expr = NULL
    for fi in 0..sbody.child_count() {
        ref field : Expr = sbody.child(fi)
        if is_variant(field.data, NodeType.Decl).not() { continue }
        ref fd : Declaration = get_payload(field.data)
        if fd.is_namespace.not() { continue }
        if is_variant(field.child(0).data, NodeType.FuncDef).not() { continue }
        if fd.name.eq("len") { len_func = field.child(0) }
        if fd.name.eq("get") { get_func = field.child(0) }
    }

    if is_null(len_func) {
        type_error(stmt, "type '".concat(type_name).concat("' has no 'len' method (required for for-in)"))
        return false
    }
    ref len_def : FunctionDef = get_payload(len_func.data)
    if len_def.nparam.neq(1).or(len_def.return_type.len().eq(0)) {
        type_error(stmt, "type '".concat(type_name).concat("' len() must take 1 param and return a scalar for for-in"))
        return false
    }
    idx_type := len_def.return_type.clone()

    if is_null(get_func) {
        type_error(stmt, "type '".concat(type_name).concat("' has no 'get' method (required for for-in)"))
        return false
    }
    ref get_def : FunctionDef = get_payload(get_func.data)
    if get_def.nparam.neq(2) {
        type_error(stmt, "type '".concat(type_name).concat("' get() second param must match len() return type for for-in"))
        return false
    }
    ref get_idx_param : Param = get_def.params.get(1.to_usize())
    if get_idx_param.ptype.len().eq(0).or(get_idx_param.ptype.eq(idx_type).not()) {
        type_error(stmt, "type '".concat(type_name).concat("' get() second param must match len() return type for for-in"))
        return false
    }

    mut elem_type := stmt.struct_name.clone()
    if elem_type.len().eq(0) {
        if get_def.return_type.len().eq(0).or(get_def.return_type.eq("Dynamic")) {
            type_error(stmt, "cannot infer element type for '".concat(type_name).concat("', use explicit type: for x : Type in ..."))
            return false
        }
        elem_type = get_def.return_type.clone()
    }

    ref var_name : Str = get_payload(stmt.data)
    ref for_body : Expr = stmt.child(1)
    line := stmt.line
    col := stmt.col
    path := stmt.path

    counter := hoist_counter
    hoist_counter.inc()
    col_name := "_fc_".concat(type_name).concat("_").concat(counter.to_str())
    idx_name := "_fi_USize_".concat(counter.to_str())

    mut block := Expr.new(NodeType.Body, line, col, path)

    mut col_decl := Expr.new(NodeType.Decl(Declaration(name = col_name.clone())), line, col, path)
    col_decl.add_child(own iter.clone())
    block.add_child(own col_decl)

    mut idx_decl := Expr.new(NodeType.Decl(Declaration(name = idx_name.clone(), explicit_type = idx_type.clone(), is_mut = true)), line, col, path)
    mut zero := Expr.new(NodeType.LiteralNum("0"), line, col, path)
    idx_decl.add_child(own zero)
    block.add_child(own idx_decl)

    mut while_node := Expr.new(NodeType.While, line, col, path)

    mut idx_ident_cond := Expr.new(NodeType.Ident(idx_name.clone()), line, col, path)
    mut col_ident_len := Expr.new(NodeType.Ident(col_name.clone()), line, col, path)
    len_call := make_field_access_call0(col_ident_len, "len", line, col, path)
    while_node.add_child(own make_field_access_call1(idx_ident_cond, "lt", len_call, line, col, path))

    mut wbody := Expr.new(NodeType.Body, line, col, path)

    mut elem_decl := Expr.new(NodeType.Decl(Declaration(name = var_name.clone(), explicit_type = elem_type.clone(), is_ref = get_def.return_own_type.eq(OwnType.Ref))), line, col, path)
    mut col_ident_get := Expr.new(NodeType.Ident(col_name.clone()), line, col, path)
    mut idx_ident_get := Expr.new(NodeType.Ident(idx_name.clone()), line, col, path)
    elem_decl.add_child(own make_field_access_call1(col_ident_get, "get", idx_ident_get, line, col, path))
    wbody.add_child(own elem_decl)

    mut idx_assign := Expr.new(NodeType.Assign(idx_name.clone()), line, col, path)
    mut idx_ident_inc := Expr.new(NodeType.Ident(idx_name.clone()), line, col, path)
    mut one := Expr.new(NodeType.LiteralNum("1"), line, col, path)
    idx_assign.add_child(own make_field_access_call1(idx_ident_inc, "add", one, line, col, path))
    wbody.add_child(own idx_assign)

    for bi in 0..for_body.child_count() {
        wbody.add_child(own for_body.child(bi).clone())
    }

    while_node.add_child(own wbody)
    block.add_child(own while_node)
    replace_body_stmt_with_block(body, stmt_idx, block)
    return true
}

infer_body_stmt := proc(scope: TypeScope, mut body: Expr, mut i: U32, shallow in_func: I32, shallow in_loop: I32, shallow returns_ref: I32, shallow in_type_body: I32, ctx: Context) {
    ref mut stmt : Expr = body.child(i)
    switch stmt.data {
    case NodeType.Decl:
        infer_decl_stmt(scope, stmt, in_func, in_type_body, ctx)
    case NodeType.Assign:
        infer_assign_stmt(scope, stmt, in_func, ctx)
    case NodeType.FieldAssign:
        infer_field_assign_stmt(scope, stmt, in_func, ctx)
    case NodeType.FCall:
        infer_expr(scope, stmt, in_func, ctx)
    case NodeType.Return:
        infer_return_stmt(scope, stmt, in_func, returns_ref, ctx)
    case NodeType.Break:
        if in_loop.eq(0) {
            type_error(stmt, "break outside loop")
        }
        stmt.til_type = TilType.None
    case NodeType.Continue:
        if in_loop.eq(0) {
            type_error(stmt, "continue outside loop")
        }
        stmt.til_type = TilType.None
    case NodeType.If:
        infer_if_stmt(scope, stmt, in_func, in_loop, returns_ref, ctx)
    case NodeType.Body:
        block_scope := TypeScope.new(scope)
        infer_body(block_scope, stmt, in_func, 1, in_loop, returns_ref, 0, ctx)
        TypeScope.delete(own block_scope)
    case NodeType.While:
        infer_while_stmt(scope, stmt, in_func, returns_ref, ctx)
    case NodeType.Switch:
        infer_switch_stmt(scope, body, i, in_func, ctx)
        i = i.sub(1)
    case NodeType.ForIn:
        if desugar_for_in_range_stmt(scope, body, i, in_func, ctx) {
            i = i.sub(1)
        } else if desugar_for_in_collection_stmt(scope, body, i, in_func, ctx) {
            i = i.sub(1)
        }
    case:
        stmt.til_type = TilType.None
    }
}

infer_body := proc(scope: TypeScope, mut body: Expr, shallow in_func: I32, shallow owns_scope: I32, shallow in_loop: I32, shallow returns_ref: I32, shallow in_type_body: I32, ctx: Context) {
    body.til_type = TilType.None
    mut i := 0.to_u32()
    while i.lt(body.child_count().to_i64().to_u32()) {
        if is_null(scope.parent).and(in_func.eq(0)).and(in_type_body.eq(0)) {
            context_set_mode_from_path(ctx, body.child(i).path)
        }
        infer_body_stmt(scope, body, i, in_func, in_loop, returns_ref, in_type_body, ctx)
        i.inc()
    }
    if owns_scope.neq(0) { desugar_set_literals(body, scope) }
    if owns_scope.neq(0) { desugar_map_literals(body, scope) }
    if owns_scope.neq(0) { desugar_variadic_calls(body, scope) }
    if owns_scope.neq(0) { desugar_kwargs_calls(body, scope) }
    if owns_scope.neq(0) { hoist_fcall_args(body, scope) }
    insert_field_deletes(body)
    insert_free_calls(body, scope, owns_scope)
}

infer_assign_stmt := proc(scope: TypeScope, mut stmt: Expr, shallow in_func: I32, ctx: Context) {
    infer_expr(scope, stmt.child(0), in_func, ctx)
    ref mut rhs : Expr = stmt.child(0)
    stmt.til_type = rhs.til_type
    if rhs.struct_name.len().gt(0) {
        stmt.struct_name = rhs.struct_name.clone()
    }
    ref aname : Str = get_payload(stmt.data)
    existing := scope.get_type(aname)
    if is_variant(existing, TilType.Unknown) {
        type_error(stmt, "undefined symbol '".concat(aname).concat("'"))
    } else if scope.is_mut(aname).not() {
        type_error(stmt, "cannot assign to immutable variable '".concat(aname).concat("'"))
        sf := scope.find(aname)
        if is_variant(sf, ScopeFind.Found) {
            ref b : TypeBinding = get_payload(sf)
            if b.is_param {
                println(stmt.path, ":", b.line.to_str(), ":", b.col.to_str(), ": note: '", aname, "' is a function parameter")
            } else {
                println(stmt.path, ":", b.line.to_str(), ":", b.col.to_str(), ": note: '", aname, "' declared here, consider adding 'mut'")
            }
        }
    } else if is_variant(rhs.data, NodeType.LiteralNum).and(is_numeric_type(existing)) {
        if literal_in_range(get_payload(rhs.data), existing).not() {
            type_error(stmt, "integer literal out of range for assignment to '".concat(aname).concat("'"))
        }
        rhs.til_type = existing
        stmt.til_type = existing
    } else if is_variant(rhs.til_type, existing).not().and(is_variant(rhs.til_type, TilType.Unknown).not()) {
        type_error(stmt, "'".concat(aname).concat("' assignment type mismatch"))
    }
    if is_variant(rhs.data, NodeType.Ident).or(
        is_variant(rhs.data, NodeType.FieldAccess).and(
            is_variant(rhs.til_type, TilType.Struct).or(is_variant(rhs.til_type, TilType.Enum))
        )
    ) {
        tname := type_to_name(rhs.til_type, rhs.struct_name)
        if tname.len().gt(0) {
            mc := make_clone_call(tname, rhs.til_type, rhs, stmt)
            stmt.children.set(0, own mc)
        }
    }
}

is_numeric_type := func(t: TilType) returns shallow Bool {
    switch t {
    case TilType.I64: return true
    case TilType.U8:  return true
    case TilType.I16: return true
    case TilType.I32: return true
    case TilType.U32: return true
    case TilType.U64: return true
    case TilType.F32: return true
    case: return false
    }
}

is_integral_numeric_type := func(t: TilType) returns shallow Bool {
    switch t {
    case TilType.I64: return true
    case TilType.U8:  return true
    case TilType.I16: return true
    case TilType.I32: return true
    case TilType.U32: return true
    case TilType.U64: return true
    case: return false
    }
}

type_ctor_consumes := func(t: TilType) returns shallow Bool {
    switch t {
    case TilType.Struct: return true
    case TilType.Enum: return true
    case TilType.Dynamic: return true
    case TilType.FuncPtr: return true
    case: return false
    }
}

is_usize_name := func(name: Str) returns shallow Bool {
    return name.eq("USize")
}

can_implicit_usize_coerce := func(from: TilType, to: TilType, to_name: Str) returns shallow Bool {
    if is_usize_name(to_name).not() { return false }
    switch to {
    case TilType.U32:
        return is_integral_numeric_type(from)
    case: return false
    }
}

literal_in_range := func(val_str: Str, target: TilType) returns shallow Bool {
    switch target {
    case TilType.I64: return true
    case TilType.F32: return true
    case TilType.U8:
        val := val_str.to_i64()
        return val.gte(0).and(val.lte(255))
    case TilType.I16:
        val := val_str.to_i64()
        return val.gte(-32768).and(val.lte(32767))
    case TilType.I32:
        val := val_str.to_i64()
        return val.gte(-2147483648).and(val.lte(2147483647))
    case TilType.U32:
        val := val_str.to_i64()
        return val.gte(0).and(val.lte(4294967295))
    case TilType.U64:
        val := val_str.to_i64()
        return val.gte(0)
    case: return true
    }
}

can_implicit_widen := func(from: TilType, to: TilType) returns shallow Bool {
    if from.eq(to) { return false }
    switch from {
    case TilType.U8:
        switch to {
        case TilType.I16: return true
        case TilType.I32: return true
        case TilType.I64: return true
        case TilType.U32: return true
        case TilType.U64: return true
        case: return false
        }
    case TilType.I16:
        switch to {
        case TilType.I32: return true
        case TilType.I64: return true
        case: return false
        }
    case TilType.U32:
        switch to {
        case TilType.U64: return true
        case TilType.I64: return true
        case: return false
        }
    case TilType.I32:
        switch to {
        case TilType.I64: return true
        case: return false
        }
    case: return false
    }
}

type_from_name := func(name: Str, scope: TypeScope) returns TilType {
    if name.eq("I64")  { return TilType.I64 }
    if name.eq("U8")   { return TilType.U8 }
    if name.eq("I16")  { return TilType.I16 }
    if name.eq("I32")  { return TilType.I32 }
    if name.eq("U32")  { return TilType.U32 }
    if name.eq("U64")  { return TilType.U64 }
    if name.eq("F32")  { return TilType.F32 }
    if name.eq("Str")  { return TilType.Struct }
    if name.eq("Bool") { return TilType.Bool }
    if name.eq("StructDef") { return TilType.StructDef }
    if name.eq("EnumDef")   { return TilType.EnumDef }
    if name.eq("Fn")        { return TilType.FuncPtr }
    if name.eq("Dynamic")   { return TilType.Dynamic }
    if is_null(scope).not() {
        ref b : TypeBinding = scope.get_binding(name)
        if is_null(b).not() {
            if b.is_builtin {
                if is_null(b.struct_def).not() { return b.type }
            }
            if is_null(b.func_def).not() {
                if b.func_def.child_count().eq(0) {
                    return TilType.FuncPtr
                }
            }
        }
        ref sdef : Expr = scope.get_struct(name)
        if is_null(sdef).not() {
            if is_variant(sdef.data, NodeType.EnumDef) {
                return TilType.Enum
            }
            return TilType.Struct
        }
    }
    return TilType.Unknown
}

resolve_type_alias := func(scope: TypeScope, name: Str) returns ref Str {
    ref b : TypeBinding = scope.get_binding(name)
    if is_null(b).not() {
        if b.is_type_alias {
            if is_null(b.alias_target).not() { return b.alias_target }
        }
    }
    return name
}

usize_name := func(scope: TypeScope) returns Str {
    if is_null(scope.get_binding("USize")).not() { return "USize" }
    return "U64"
}

usize_type := func(scope: TypeScope) returns TilType {
    return type_from_name(usize_name(scope), scope)
}

type_has_cmp := func(scope: TypeScope, type_name: Str) returns shallow Bool {
    ref sdef : Expr = scope.get_struct(type_name)
    if is_null(sdef) { return false }
    ref body : Expr = sdef.child(0)
    for i in 0..body.child_count() {
        ref f : Expr = body.child(i)
        if is_variant(f.data, NodeType.Decl) {
            ref decl : Declaration = get_payload(f.data)
            if decl.is_namespace.and(decl.name.eq("cmp")) {
                return true
            }
        }
    }
    return false
}

expr_contains_fcall := func(e: Expr) returns shallow Bool {
    if is_variant(e.data, NodeType.FCall) { return true }
    for i in 0..e.child_count() {
        if expr_contains_fcall(e.child(i)) { return true }
    }
    return false
}

expr_uses_var := func(e: Expr, name: Str) returns shallow Bool {
    if is_variant(e.data, NodeType.FuncDef) { return false }
    if is_variant(e.data, NodeType.Ident) {
        ref _id : Str = get_payload(e.data)
        if _id.eq(name) { return true }
    }
    if is_variant(e.data, NodeType.Assign) {
        ref _as : Str = get_payload(e.data)
        if _as.eq(name) { return true }
    }
    for i in 0..e.child_count() {
        if expr_uses_var(e.child(i), name) { return true }
    }
    return false
}

expr_contains_decl := func(e: Expr, name: Str) returns shallow Bool {
    if is_variant(e.data, NodeType.FuncDef) { return false }
    if is_variant(e.data, NodeType.Decl) {
        ref _dd : Declaration = get_payload(e.data)
        if _dd.name.eq(name) { return true }
    }
    for i in 0..e.child_count() {
        if expr_contains_decl(e.child(i), name) { return true }
    }
    return false
}

expr_used_in_nested_func := func(e: Expr, name: Str) returns shallow Bool {
    if is_variant(e.data, NodeType.FuncDef) {
        ref fdef : FunctionDef = get_payload(e.data)
        for j in 0..fdef.nparam {
            ref p : Param = fdef.params.get(j)
            if p.name.eq(name) { return false }
        }
        if e.child_count().gt(0) {
            return expr_uses_var(e.child(0), name)
        }
        return false
    }
    for i in 0..e.child_count() {
        if expr_used_in_nested_func(e.child(i), name) { return true }
    }
    return false
}

find_variadic_fcall := func(e: Expr) returns ref Expr {
    if is_null(e) { return NULL }
    if is_variant(e.data, NodeType.FuncDef) { return NULL }
    if is_variant(e.data, NodeType.StructDef) { return NULL }
    if is_variant(e.data, NodeType.EnumDef) { return NULL }
    if is_variant(e.data, NodeType.Body) { return NULL }
    if is_variant(e.data, NodeType.FCall) {
        ref fcall : FCallData = get_payload(e.data)
        if fcall.variadic_index.gte(0) {
            if e.child(0).data.is(NodeType.Ident) {
                ref cn : Str = get_payload(e.child(0).data)
                if cn.eq("array").or(cn.eq("vec")) {
                    return NULL
                }
            }
            return e
        }
    }
    for i in 0..e.child_count() {
        ref found : Expr = find_variadic_fcall(e.child(i))
        if is_null(found).not() { return found }
    }
    return NULL
}

find_kwargs_fcall := func(e: Expr) returns ref Expr {
    if is_null(e) { return NULL }
    if is_variant(e.data, NodeType.FuncDef) { return NULL }
    if is_variant(e.data, NodeType.StructDef) { return NULL }
    if is_variant(e.data, NodeType.EnumDef) { return NULL }
    if is_variant(e.data, NodeType.Body) { return NULL }
    if is_variant(e.data, NodeType.FCall) {
        ref fcall : FCallData = get_payload(e.data)
        if fcall.kwargs_index.gte(0) { return e }
    }
    for i in 0..e.child_count() {
        ref found : Expr = find_kwargs_fcall(e.child(i))
        if is_null(found).not() { return found }
    }
    return NULL
}

type_prefix := func(t: TilType, sname: Str) returns Str {
    switch t {
    case TilType.I64: return "I64"
    case TilType.U8: return "U8"
    case TilType.I16: return "I16"
    case TilType.I32: return "I32"
    case TilType.U32: return "U32"
    case TilType.U64: return "U64"
    case TilType.F32: return "F32"
    case TilType.Bool: return "Bool"
    case TilType.None: return "None"
    case TilType.Struct:
        if sname.len().gt(0) { return sname }
        return "compound"
    case TilType.Enum:
        if sname.len().gt(0) { return sname }
        return "compound"
    case: return "v"
    }
}

type_to_name := func(t: TilType, struct_name: Str) returns Str {
    if struct_name.len().gt(0) { return struct_name }
    switch t {
    case TilType.I64: return I64Name
    case TilType.U8: return U8Name
    case TilType.I16: return I16Name
    case TilType.I32: return I32Name
    case TilType.U32: return U32Name
    case TilType.U64: return U64Name
    case TilType.F32: return F32Name
    case TilType.Bool: return BoolName
    case: return ""
    }
}

make_field_delete := func(field_assign: Expr, shallow is_own: Bool) returns Expr {
    ref rhs : Expr = field_assign.child(1)
    tname := type_to_name(rhs.til_type, rhs.struct_name)
    if tname.len().eq(0) { return NULL }

    mut call := Expr.new(NodeType.FCall(FCallData()), field_assign.line, field_assign.col, field_assign.path)
    call.til_type = TilType.None

    mut type_id := Expr.new(NodeType.Ident(tname.clone()), field_assign.line, field_assign.col, field_assign.path)
    type_id.struct_name = tname.clone()

    mut fa := Expr.new(NodeType.FieldAccess("delete"), field_assign.line, field_assign.col, field_assign.path)
    fa.is_ns_field = true
    fa.add_child(own type_id)
    call.add_child(own fa)

    mut field_acc := Expr.new(NodeType.FieldAccess(get_payload(field_assign.data)), field_assign.line, field_assign.col, field_assign.path)
    field_acc.is_own_field = is_own
    field_acc.til_type = rhs.til_type
    if rhs.struct_name.len().gt(0) { field_acc.struct_name = rhs.struct_name.clone() }
    field_acc.add_child(own field_assign.child(0).clone())
    call.add_child(own field_acc)

    mut cf_lit := Expr.new(NodeType.LiteralBool(is_own), field_assign.line, field_assign.col, field_assign.path)
    cf_lit.til_type = TilType.Bool
    call.add_child(own cf_lit)

    return call
}

make_delete_call := func(var_name: Str, shallow type: TilType, struct_name: Str, shallow arg_is_own: Bool, shallow call_free: Bool, src: Expr) returns Expr {
    tname := type_to_name(type, struct_name)
    if tname.len().eq(0) { return NULL }

    mut call := Expr.new(NodeType.FCall(FCallData()), src.line, src.col, src.path)
    call.til_type = TilType.None

    mut type_id := Expr.new(NodeType.Ident(tname.clone()), src.line, src.col, src.path)
    type_id.struct_name = tname.clone()

    mut fa := Expr.new(NodeType.FieldAccess("delete"), src.line, src.col, src.path)
    fa.is_ns_field = true
    fa.add_child(own type_id)
    call.add_child(own fa)

    mut arg := Expr.new(NodeType.Ident(var_name.clone()), src.line, src.col, src.path)
    arg.til_type = type
    if struct_name.len().gt(0) { arg.struct_name = struct_name.clone() }
    arg.is_own_arg = arg_is_own
    call.add_child(own arg)

    mut cf_lit := Expr.new(NodeType.LiteralBool(call_free), src.line, src.col, src.path)
    cf_lit.til_type = TilType.Bool
    call.add_child(own cf_lit)

    return call
}

make_clone_call := func(type_name: Str, shallow type: TilType, arg: Expr, src: Expr) returns Expr {
    mut call := Expr.new(NodeType.FCall(FCallData()), src.line, src.col, src.path)
    call.til_type = type
    if type.eq(TilType.Struct).or(type.eq(TilType.Enum)) {
        call.struct_name = type_name.clone()
    }

    mut type_id := Expr.new(NodeType.Ident(type_name.clone()), src.line, src.col, src.path)
    type_id.struct_name = type_name.clone()

    mut fa := Expr.new(NodeType.FieldAccess("clone"), src.line, src.col, src.path)
    fa.is_ns_field = true
    fa.add_child(own type_id)
    call.add_child(own fa)

    call.add_child(own arg.clone())
    return call
}

make_ns_call := func(sname: Str, method: Str, shallow ret_type: TilType, ret_sname: Str, src: Expr) returns Expr {
    mut call := Expr.new(NodeType.FCall(FCallData()), src.line, src.col, src.path)
    call.til_type = ret_type
    if ret_sname.len().gt(0) { call.struct_name = ret_sname.clone() }

    mut type_id := Expr.new(NodeType.Ident(sname.clone()), src.line, src.col, src.path)
    type_id.struct_name = sname.clone()

    mut fa := Expr.new(NodeType.FieldAccess(method.clone()), src.line, src.col, src.path)
    fa.is_ns_field = true
    fa.add_child(own type_id)
    call.add_child(own fa)
    return call
}

build_kwargs_dynmap_decl := func(fcall: Expr, kw_name: Str) returns Expr {
    mut new_call := make_ns_call("DynMap", "new", TilType.Struct, "DynMap", fcall)
    mut kw_decl := Expr.new(NodeType.Decl(Declaration()), fcall.line, fcall.col, fcall.path)
    ref mut dd : Declaration = get_payload(kw_decl.data)
    dd.name = kw_name.clone()
    kw_decl.til_type = TilType.Struct
    kw_decl.add_child(own new_call)
    return kw_decl
}

build_kwargs_dynmap_set := func(fcall: Expr, scope: TypeScope, kw_name: Str, named_arg: Expr) returns Expr {
    ref key_name : Str = get_payload(named_arg.data)
    ref val : Expr = named_arg.child(0)
    mut set_call := make_ns_call("DynMap", "set", TilType.None, "", fcall)

    mut self_id := Expr.new(NodeType.Ident(kw_name.clone()), fcall.line, fcall.col, fcall.path)
    self_id.til_type = TilType.Struct
    self_id.struct_name = "DynMap"
    set_call.add_child(own self_id)

    mut key_lit := Expr.new(NodeType.LiteralStr(key_name.clone()), fcall.line, fcall.col, fcall.path)
    key_lit.til_type = TilType.Struct
    key_lit.struct_name = "Str"
    key_lit.is_own_arg = true
    set_call.add_child(own key_lit)

    tname := type_to_name(val.til_type, val.struct_name)
    mut type_lit := Expr.new(NodeType.LiteralStr(tname.clone()), fcall.line, fcall.col, fcall.path)
    type_lit.til_type = TilType.Struct
    type_lit.struct_name = "Str"
    type_lit.is_own_arg = true
    set_call.add_child(own type_lit)

    mut size_call := make_ns_call(tname, "size", usize_type(scope), "", fcall)
    set_call.add_child(own size_call)

    mut out_val := val.clone()
    if is_variant(val.data, NodeType.Ident).or(is_variant(val.data, NodeType.FieldAccess)) {
        if tname.len().gt(0) {
            out_val = make_clone_call(tname, val.til_type, val, val)
        }
    }
    out_val.is_own_arg = true
    set_call.add_child(own out_val)
    return set_call
}

build_variadic_array_decl := func(fcall: Expr, scope: TypeScope, elem_type: Str, va_name: Str, shallow vc: U32) returns Expr {
    mut new_call := make_ns_call("Array", "new", TilType.Struct, "Array", fcall)

    mut et := Expr.new(NodeType.LiteralStr(elem_type.clone()), fcall.line, fcall.col, fcall.path)
    et.til_type = TilType.Struct
    et.struct_name = "Str"
    new_call.add_child(own et)

    mut sz := make_ns_call(elem_type, "size", usize_type(scope), "", fcall)
    new_call.add_child(own sz)

    cap_str := vc.to_i64().to_str()
    mut cap := Expr.new(NodeType.LiteralNum(cap_str.clone()), fcall.line, fcall.col, fcall.path)
    cap.til_type = usize_type(scope)
    new_call.add_child(own cap)

    mut va_decl := Expr.new(NodeType.Decl(Declaration()), fcall.line, fcall.col, fcall.path)
    ref mut dd : Declaration = get_payload(va_decl.data)
    dd.name = va_name.clone()
    va_decl.til_type = TilType.Struct
    va_decl.add_child(own new_call)
    return va_decl
}

build_variadic_array_set := func(fcall: Expr, scope: TypeScope, va_name: Str, shallow vi: I32, shallow j: U32) returns Expr {
    mut set_call := make_ns_call("Array", "set", TilType.None, "", fcall)

    mut self_id := Expr.new(NodeType.Ident(va_name.clone()), fcall.line, fcall.col, fcall.path)
    self_id.til_type = TilType.Struct
    self_id.struct_name = "Array"
    set_call.add_child(own self_id)

    idx_str := j.to_i64().to_str()
    mut idx := Expr.new(NodeType.LiteralNum(idx_str.clone()), fcall.line, fcall.col, fcall.path)
    idx.til_type = usize_type(scope)
    set_call.add_child(own idx)

    ref val_in : Expr = fcall.child(vi.add(j.to_i64().to_i32()).to_i64().to_usize())
    mut val := val_in.clone()
    if is_variant(val_in.data, NodeType.Ident).or(is_variant(val_in.data, NodeType.FieldAccess)) {
        tname := type_to_name(val_in.til_type, val_in.struct_name)
        if tname.len().gt(0) {
            val = make_clone_call(tname, val_in.til_type, val_in, val_in)
        }
    }
    val.is_own_arg = true
    set_call.add_child(own val)
    return set_call
}

desugar_set_literal_decl := proc(stmt: Expr, mut new_ch: Vec, mut scope: TypeScope) {
    ref set_lit : Expr = stmt.child(0)
    ref stmt_decl : Declaration = get_payload(stmt.data)
    ref var_name : Str = stmt_decl.name

    if set_lit.child_count().eq(0) {
        type_error(set_lit, "set literal must have at least one element")
        new_ch.push(own stmt.clone())
        return
    }

    ref first : Expr = set_lit.child(0)
    elem_type := type_to_name(first.til_type, first.struct_name)
    if elem_type.len().eq(0) {
        type_error(first, "set literal: cannot determine element type")
        new_ch.push(own stmt.clone())
        return
    }

    if type_has_cmp(scope, elem_type).not() {
        type_error(first, "set literal: element type '".concat(elem_type).concat("' must implement cmp"))
    }

    for j in 1..set_lit.child_count() {
        ref v : Expr = set_lit.child(j)
        vt := type_to_name(v.til_type, v.struct_name)
        if vt.len().eq(0).or(vt.eq(elem_type).not()) {
            type_error(v, "set literal: all elements must be the same type")
        }
    }

    mut new_call := make_ns_call("Set", "new", TilType.Struct, "Set", set_lit)
    mut et_str := Expr.new(NodeType.LiteralStr(elem_type.clone()), set_lit.line, set_lit.col, set_lit.path)
    et_str.til_type = TilType.Struct
    et_str.struct_name = "Str"
    new_call.add_child(own et_str)
    mut esz := make_ns_call(elem_type, "size", usize_type(scope), "", set_lit)
    new_call.add_child(own esz)

    mut decl := Expr.new(NodeType.Decl(Declaration()), stmt.line, stmt.col, set_lit.path)
    ref mut dd : Declaration = get_payload(decl.data)
    dd.name = var_name.clone()
    dd.is_mut = true
    decl.til_type = TilType.Struct
    decl.add_child(own new_call)

    scope.set(var_name, TilType.Struct, -1.to_i32(), true, stmt.line, stmt.col, false, false)
    ref mut vb : TypeBinding = scope.get_binding(var_name)
    vb.struct_name = "Set"

    new_ch.push(own decl)

    for j in 0..set_lit.child_count() {
        mut add_call := make_ns_call("Set", "add", TilType.None, "", set_lit)
        mut self_id := Expr.new(NodeType.Ident(var_name.clone()), set_lit.line, set_lit.col, set_lit.path)
        self_id.til_type = TilType.Struct
        self_id.struct_name = "Set"
        add_call.add_child(own self_id)
        mut val := set_lit.child(j).clone()
        val.is_own_arg = true
        add_call.add_child(own val)
        new_ch.push(own add_call)
    }
}

desugar_map_literal_decl := proc(stmt: Expr, mut new_ch: Vec, mut scope: TypeScope) {
    ref map_lit : Expr = stmt.child(0)
    ref stmt_decl : Declaration = get_payload(stmt.data)
    ref var_name : Str = stmt_decl.name
    n_pairs := map_lit.child_count().div(2)

    if map_lit.child_count().eq(0) {
        type_error(map_lit, "map literal must have at least one entry")
        new_ch.push(own stmt.clone())
        return
    }
    if map_lit.child_count().mod(2).eq(0).not() {
        type_error(map_lit, "map literal has mismatched key/value pairs")
        new_ch.push(own stmt.clone())
        return
    }

    ref first_key : Expr = map_lit.child(0)
    ref first_val : Expr = map_lit.child(1)
    key_type := type_to_name(first_key.til_type, first_key.struct_name)
    val_type := type_to_name(first_val.til_type, first_val.struct_name)

    if key_type.len().eq(0) {
        type_error(first_key, "map literal: cannot determine key type")
        new_ch.push(own stmt.clone())
        return
    }
    if val_type.len().eq(0) {
        type_error(first_val, "map literal: cannot determine value type")
        new_ch.push(own stmt.clone())
        return
    }

    if type_has_cmp(scope, key_type).not() {
        type_error(first_key, "map literal: key type '".concat(key_type).concat("' must implement cmp"))
    }

    for j in 2..map_lit.child_count() {
        if j.mod(2).eq(0) {
            ref k : Expr = map_lit.child(j)
            kt := type_to_name(k.til_type, k.struct_name)
            if kt.len().eq(0).or(kt.eq(key_type).not()) {
                type_error(k, "map literal: all keys must be the same type")
            }
        } else {
            ref v : Expr = map_lit.child(j)
            vt := type_to_name(v.til_type, v.struct_name)
            if vt.len().eq(0).or(vt.eq(val_type).not()) {
                type_error(v, "map literal: all values must be the same type")
            }
        }
    }

    mut new_call := make_ns_call("Map", "new", TilType.Struct, "Map", map_lit)
    mut kt_str := Expr.new(NodeType.LiteralStr(key_type.clone()), map_lit.line, map_lit.col, map_lit.path)
    kt_str.til_type = TilType.Struct
    kt_str.struct_name = "Str"
    new_call.add_child(own kt_str)
    mut ksz := make_ns_call(key_type, "size", usize_type(scope), "", map_lit)
    new_call.add_child(own ksz)
    mut vt_str := Expr.new(NodeType.LiteralStr(val_type.clone()), map_lit.line, map_lit.col, map_lit.path)
    vt_str.til_type = TilType.Struct
    vt_str.struct_name = "Str"
    new_call.add_child(own vt_str)
    mut vsz := make_ns_call(val_type, "size", usize_type(scope), "", map_lit)
    new_call.add_child(own vsz)

    mut decl := Expr.new(NodeType.Decl(Declaration()), stmt.line, stmt.col, map_lit.path)
    ref mut dd : Declaration = get_payload(decl.data)
    dd.name = var_name.clone()
    dd.is_mut = true
    decl.til_type = TilType.Struct
    decl.add_child(own new_call)

    scope.set(var_name, TilType.Struct, -1.to_i32(), true, stmt.line, stmt.col, false, false)
    ref mut vb : TypeBinding = scope.get_binding(var_name)
    vb.struct_name = "Map"

    new_ch.push(own decl)

    for j in 0..n_pairs {
        mut set_call := make_ns_call("Map", "set", TilType.None, "", map_lit)
        mut self_id := Expr.new(NodeType.Ident(var_name.clone()), map_lit.line, map_lit.col, map_lit.path)
        self_id.til_type = TilType.Struct
        self_id.struct_name = "Map"
        set_call.add_child(own self_id)
        mut key := map_lit.child(j.mul(2)).clone()
        key.is_own_arg = true
        set_call.add_child(own key)
        mut mval := map_lit.child(j.mul(2).add(1)).clone()
        mval.is_own_arg = true
        set_call.add_child(own mval)
        new_ch.push(own set_call)
    }
}

desugar_set_literals := proc(mut body: Expr, mut scope: TypeScope) {
    mut new_ch := Vec.new("Expr", Expr.size())
    mut changed := false

    for i in 0..body.child_count() {
        ref stmt : Expr = body.child(i)
        if is_variant(stmt.data, NodeType.Decl).not() {
            new_ch.push(own stmt.clone())
            continue
        }
        if stmt.child_count().eq(0) {
            new_ch.push(own stmt.clone())
            continue
        }
        if is_variant(stmt.child(0).data, NodeType.SetLit).not() {
            new_ch.push(own stmt.clone())
            continue
        }
        changed = true
        desugar_set_literal_decl(stmt, new_ch, scope)
    }

    if changed {
        body.children = new_ch
    }
}

desugar_map_literals := proc(mut body: Expr, mut scope: TypeScope) {
    mut new_ch := Vec.new("Expr", Expr.size())
    mut changed := false

    for i in 0..body.child_count() {
        ref stmt : Expr = body.child(i)
        if is_variant(stmt.data, NodeType.Decl).not() {
            new_ch.push(own stmt.clone())
            continue
        }
        if stmt.child_count().eq(0) {
            new_ch.push(own stmt.clone())
            continue
        }
        if is_variant(stmt.child(0).data, NodeType.MapLit).not() {
            new_ch.push(own stmt.clone())
            continue
        }
        changed = true
        desugar_map_literal_decl(stmt, new_ch, scope)
    }

    if changed {
        body.children = new_ch
    }
}

hoist_param_swap_assign := proc(mut stmt: Expr, mut hoisted: Vec, mut scope: TypeScope) {
    sf := scope.find(get_payload(stmt.data))
    if is_variant(sf, ScopeFind.Found).not() { return }
    ref ab : TypeBinding = get_payload(sf)
    if ab.is_param.not() { return }
    if ab.is_mut.not() { return }
    if is_variant(ab.type, TilType.Struct).not() {
        if is_variant(ab.type, TilType.Enum).not() { return }
    }

    mut call := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col, stmt.path)
    call.til_type = TilType.None
    mut fn := Expr.new(NodeType.Ident("swap"), stmt.line, stmt.col, stmt.path)
    call.add_child(own fn)
    ref stmt_name : Str = get_payload(stmt.data)
    mut a := Expr.new(NodeType.Ident(stmt_name.clone()), stmt.line, stmt.col, stmt.path)
    a.til_type = ab.type
    if ab.struct_name.len().gt(0) { a.struct_name = ab.struct_name.clone() }
    call.add_child(own a)
    call.add_child(own stmt.child(0).clone())
    tname := type_to_name(ab.type, ab.struct_name)
    mut sz_call := make_ns_call(tname, "size", usize_type(scope), "", stmt)
    mut sz := hoist_to_temp(sz_call, hoisted, scope)
    call.add_child(own sz)
    stmt = call
}

hoist_expr := proc(mut expr: Expr, mut hoisted: Vec, mut scope: TypeScope) {
    if is_variant(expr.data, NodeType.FuncDef) { return }
    if is_variant(expr.data, NodeType.StructDef) { return }
    if is_variant(expr.data, NodeType.EnumDef) { return }
    if is_variant(expr.data, NodeType.Body) { return }

    for i in 0..expr.child_count() {
        hoist_expr(expr.child(i), hoisted, scope)
    }
    if is_variant(expr.data, NodeType.FCall).not() { return }

    ref mut ctor_body : Expr = NULL
    if expr.struct_name.len().gt(0) {
        if expr.child_count().gt(0) {
            ref callee : Expr = expr.child(0)
            if is_variant(callee.data, NodeType.Ident) {
                ref callee_name : Str = get_payload(callee.data)
                if callee_name.eq(expr.struct_name) {
                    ref sdef : Expr = scope.get_struct(expr.struct_name)
                    if is_null(sdef).not() {
                        ctor_body = sdef.child(0)
                    }
                }
            }
        }
    }

    mut is_dyn_call := false
    if expr.child_count().gt(0) {
        ref callee : Expr = expr.child(0)
        if is_variant(callee.data, NodeType.Ident) {
            ref cn : Str = get_payload(callee.data)
            if cn.eq("dyn_call") { is_dyn_call = true }
            if cn.eq("dyn_call_ret") { is_dyn_call = true }
            if cn.eq("dyn_has_method") { is_dyn_call = true }
            if cn.eq("dyn_fn") { is_dyn_call = true }
        }
    }

    mut is_array_vec := false
    if expr.child_count().gt(0) {
        ref callee : Expr = expr.child(0)
        if is_variant(callee.data, NodeType.Ident) {
            ref cn : Str = get_payload(callee.data)
            if cn.eq("array") { is_array_vec = true }
            if cn.eq("vec") { is_array_vec = true }
        }
    }

    mut fi := 0.to_usize()
    for i in 1..expr.child_count() {
        if is_dyn_call {
            if i.eq(2).or(i.eq(3)) { continue }
        }
        if is_array_vec {
            if i.eq(1) { continue }
        }

        ref arg : Expr = expr.child(i)
        if is_variant(arg.data, NodeType.FCall).not() {
            if is_variant(arg.data, NodeType.LiteralNum).not() {
                if is_variant(arg.data, NodeType.LiteralStr).not() {
                    if is_variant(arg.data, NodeType.LiteralBool).not() {
                        continue
                    }
                }
            }
        }

        if is_null(ctor_body).not() {
            mut is_own := false
            mut field_type := TilType.None
            while fi.lt(ctor_body.child_count()) {
                ref field : Expr = ctor_body.child(fi)
                fi = fi.add(1)
                if is_variant(field.data, NodeType.Decl) {
                    ref fd : Declaration = get_payload(field.data)
                    if fd.is_namespace.not() {
                        is_own = fd.is_own
                        field_type = field.child(0).til_type
                        break
                    }
                }
            }
            if is_own.not() {
                if is_variant(field_type, TilType.Struct).or(is_variant(field_type, TilType.Enum)) {
                    continue
                }
            }
        }

        expr.children.set(i, own hoist_to_temp(arg.clone(), hoisted, scope))
    }
}

hoist_decl_rhs := proc(stmt: Expr, mut hoisted: Vec, mut scope: TypeScope) {
    hoist_expr(stmt.child(0), hoisted, scope)
}

hoist_if_cond := proc(mut stmt: Expr, mut hoisted: Vec, mut scope: TypeScope) {
    hoist_expr(stmt.child(0), hoisted, scope)
    ref cond : Expr = stmt.child(0)
    if is_variant(cond.data, NodeType.FCall) {
        stmt.children.set(0, own hoist_to_temp(cond, hoisted, scope))
    }
}

hoist_return_expr := proc(mut stmt: Expr, mut hoisted: Vec, mut scope: TypeScope) {
    if stmt.child_count().eq(0) { return }
    hoist_expr(stmt.child(0), hoisted, scope)
    ref rhs : Expr = stmt.child(0)
    if is_variant(rhs.data, NodeType.FCall)
        .or(is_variant(rhs.data, NodeType.LiteralNum))
        .or(is_variant(rhs.data, NodeType.LiteralStr))
        .or(is_variant(rhs.data, NodeType.LiteralBool)) {
        stmt.children.set(0, own hoist_to_temp(rhs, hoisted, scope))
    }
}

hoist_assign_rhs := proc(mut stmt: Expr, mut hoisted: Vec, mut scope: TypeScope) {
    hoist_expr(stmt.child(0), hoisted, scope)
    mut do_hoist := true
    sf := scope.find(get_payload(stmt.data))
    if is_variant(sf, ScopeFind.Found) {
        ref ab : TypeBinding = get_payload(sf)
        if ab.is_param.not() {
            if is_variant(ab.type, TilType.Struct).or(is_variant(ab.type, TilType.Enum)) {
                do_hoist = false
            }
        }
    }
    ref rhs : Expr = stmt.child(0)
    if do_hoist.and(
        is_variant(rhs.data, NodeType.FCall)
        .or(is_variant(rhs.data, NodeType.LiteralNum))
        .or(is_variant(rhs.data, NodeType.LiteralStr))
        .or(is_variant(rhs.data, NodeType.LiteralBool))
    ) {
        stmt.children.set(0, own hoist_to_temp(rhs, hoisted, scope))
    }
}

hoist_field_assign_rhs := proc(mut stmt: Expr, mut hoisted: Vec, mut scope: TypeScope) {
    hoist_expr(stmt.child(1), hoisted, scope)
    mut fa_hoist := true
    if stmt.is_own_field.not() {
        rhs_type := stmt.child(1).til_type
        if is_variant(rhs_type, TilType.Struct).or(is_variant(rhs_type, TilType.Enum)) {
            fa_hoist = false
        }
    }
    ref rhs : Expr = stmt.child(1)
    if fa_hoist.and(
        is_variant(rhs.data, NodeType.FCall)
        .or(is_variant(rhs.data, NodeType.LiteralNum))
        .or(is_variant(rhs.data, NodeType.LiteralStr))
        .or(is_variant(rhs.data, NodeType.LiteralBool))
    ) {
        stmt.children.set(1, own hoist_to_temp(rhs, hoisted, scope))
    }
}

hoist_stmt_fcall := proc(mut stmt: Expr, mut hoisted: Vec, mut scope: TypeScope) returns Expr {
    hoist_expr(stmt, hoisted, scope)
    if is_variant(stmt.til_type, TilType.None).not() {
        hoist_to_temp(stmt, hoisted, scope)
        popped : Expr = hoisted.pop()
        stmt = popped
    }
    return stmt
}

hoist_fcall_args := proc(mut body: Expr, mut scope: TypeScope) {
    mut new_ch := Vec.new("Expr", Expr.size())
    for i in 0..body.child_count() {
        ref stmt_in_body : Expr = body.child(i)
        mut stmt := stmt_in_body.clone()
        mut hoisted := Vec.new("Expr", Expr.size())

        switch stmt.data {
        case NodeType.Decl:
            hoist_decl_rhs(stmt, hoisted, scope)
        case NodeType.FCall:
            stmt = hoist_stmt_fcall(stmt, hoisted, scope)
        case NodeType.Return:
            hoist_return_expr(stmt, hoisted, scope)
        case NodeType.Assign:
            hoist_assign_rhs(stmt, hoisted, scope)
            hoist_param_swap_assign(stmt, hoisted, scope)
        case NodeType.FieldAssign:
            hoist_field_assign_rhs(stmt, hoisted, scope)
        case NodeType.If:
            hoist_if_cond(stmt, hoisted, scope)
        case:
            // NodeType.While: skip condition -- hoisting changes loop semantics
        }

        for j in 0..hoisted.len() {
            ref h : Expr = hoisted.get(j)
            new_ch.push(own h.clone())
        }
        new_ch.push(own stmt)
    }

    if new_ch.len().neq(body.child_count()) {
        body.children = new_ch
    }
}

insert_field_deletes := proc(mut body: Expr) {
    mut new_ch := Vec.new("Expr", Expr.size())
    mut changed := false

    for i in 0..body.child_count() {
        ref stmt : Expr = body.child(i)
        if is_variant(stmt.data, NodeType.FieldAssign) {
            is_own := stmt.is_own_field
            if field_assign_needs_delete(stmt) {
                ref rhs : Expr = stmt.child(1)
                if type_to_name(rhs.til_type, rhs.struct_name).len().gt(0) {
                    del := make_field_delete(stmt, is_own)
                    new_ch.push(own del.clone())
                    changed = true
                }
            }
        }
        new_ch.push(own stmt.clone())
    }

    if changed {
        body.children = new_ch
    }
}

rewrite_variadic_fcall_args := proc(mut fcall: Expr, va_name: Str) {
    ref fcall_data : FCallData = get_payload(fcall.data)
    vi := fcall_data.variadic_index
    vc := fcall_data.variadic_count
    line := fcall.line
    col := fcall.col
    path := fcall.path
    mut fcall_new_ch := Vec.new("Expr", Expr.size())
    mut va_inserted := false
    for j in 0..fcall.child_count() {
        if j.to_i64().to_i32().gte(vi).and(j.to_i64().to_i32().lt(vi.add(vc.to_i64().to_i32()))) {
            if va_inserted.not() {
                mut va_id := Expr.new(NodeType.Ident(va_name.clone()), line, col, path)
                va_id.til_type = TilType.Struct
                va_id.struct_name = "Array"
                va_id.is_own_arg = true
                fcall_new_ch.push(own va_id)
                va_inserted = true
            }
            continue
        }
        if j.to_i64().to_i32().eq(vi).and(va_inserted.not()) {
            mut va_id := Expr.new(NodeType.Ident(va_name.clone()), line, col, path)
            va_id.til_type = TilType.Struct
            va_id.struct_name = "Array"
            va_id.is_own_arg = true
            fcall_new_ch.push(own va_id)
            va_inserted = true
        }
        fcall_new_ch.push(own fcall.child(j).clone())
    }
    if va_inserted.not() {
        mut va_id := Expr.new(NodeType.Ident(va_name.clone()), line, col, path)
        va_id.til_type = TilType.Struct
        va_id.struct_name = "Array"
        va_id.is_own_arg = true
        fcall_new_ch.push(own va_id)
    }
    fcall.children = fcall_new_ch
    fcall_data.variadic_index = -1.to_i32()
    fcall_data.variadic_count = 0.to_u32()
}

desugar_variadic_calls := proc(mut body: Expr, mut scope: TypeScope) {
    mut new_ch := Vec.new("Expr", Expr.size())
    mut changed := false

    for i in 0..body.child_count() {
        ref stmt : Expr = body.child(i)
        ref fcall : Expr = find_variadic_fcall(stmt)
        if is_null(fcall) {
            new_ch.push(own stmt.clone())
            continue
        }
        changed = true
        ref fcall_data : FCallData = get_payload(fcall.data)
        vi := fcall_data.variadic_index
        vc := fcall_data.variadic_count
        line := fcall.line
        col := fcall.col

        ref elem_type : Str = resolve_variadic_elem_type(fcall, scope)
        if is_null(elem_type) {
            new_ch.push(own stmt.clone())
            continue
        }

        if desugar_pure_splat_variadic_call(fcall, new_ch, stmt) {
            continue
        }

        va_name := "_va_Array_".concat(_va_counter.to_i64().to_str())
        _va_counter.inc()
        mut va_decl := build_variadic_array_decl(fcall, scope, elem_type, va_name, vc)

        scope.set(va_name, TilType.Struct, -1.to_i32(), false, line, col, false, false)
        ref vab : TypeBinding = scope.get_binding(va_name)
        vab.struct_name = "Array"

        new_ch.push(own va_decl)

        for j in 0..vc {
            new_ch.push(own build_variadic_array_set(fcall, scope, va_name, vi, j))
        }

        rewrite_variadic_fcall_args(fcall, va_name)
        new_ch.push(own stmt.clone())
    }

    if changed {
        body.children = new_ch
    }
}

resolve_variadic_elem_type := func(fcall: Expr, scope: TypeScope) returns ref Str {
    ref callee : Expr = fcall.child(0)
    if is_variant(callee.data, NodeType.Ident) {
        ref callee_name : Str = get_payload(callee.data)
        ref cb : TypeBinding = scope.get_binding(callee_name)
        if is_null(cb).not() {
            if is_null(cb.func_def).not() {
                ref cb_fdef : FunctionDef = get_payload(cb.func_def.data)
                fvi := cb_fdef.variadic_index
                if fvi.gte(0) {
                    ref param : Param = cb_fdef.params.get(fvi.to_i64().to_usize())
                    return param.ptype
                }
            }
        }
    } else if is_variant(callee.data, NodeType.FieldAccess) {
        if callee.is_ns_field {
            ref type_node : Expr = callee.child(0)
            if is_variant(type_node.data, NodeType.Ident) {
                ref type_name : Str = get_payload(type_node.data)
                ref sdef : Expr = scope.get_struct(type_name)
                if is_null(sdef).not() {
                    ref sbody : Expr = sdef.child(0)
                    ref method_name : Str = get_payload(callee.data)
                    for j in 0..sbody.child_count() {
                        ref f : Expr = sbody.child(j)
                        if is_variant(f.data, NodeType.Decl).not() { continue }
                        ref fd : Declaration = get_payload(f.data)
                        if fd.is_namespace.not() { continue }
                        if fd.name.eq(method_name).not() { continue }
                        if is_variant(f.child(0).data, NodeType.FuncDef).not() { continue }
                        ref ffd : FunctionDef = get_payload(f.child(0).data)
                        fvi := ffd.variadic_index
                        if fvi.gte(0) {
                            ref param : Param = ffd.params.get(fvi.to_i64().to_usize())
                            return param.ptype
                        }
                        break
                    }
                }
            }
        }
    }
    return NULL
}

desugar_pure_splat_variadic_call := proc(mut fcall: Expr, mut new_ch: Vec, stmt: Expr) returns shallow Bool {
    ref fcd : FCallData = get_payload(fcall.data)
    vi := fcd.variadic_index
    vc := fcd.variadic_count
    if vc.eq(1).not() { return false }
    if fcall.child(vi.to_i64().to_usize()).is_splat.not() { return false }

    ref splat_in : Expr = fcall.child(vi.to_i64().to_usize())
    mut splat := splat_in.clone()
    splat.is_splat = false
    if is_variant(splat_in.data, NodeType.Ident) {
        splat = make_clone_call("Array", TilType.Struct, splat_in, splat_in)
    }
    splat.is_own_arg = true

    mut fcall_new_ch := Vec.new("Expr", Expr.size())
    for j in 0..fcall.child_count() {
        ji := j.to_i64().to_i32()
        if ji.eq(vi) {
            fcall_new_ch.push(own splat)
        } else {
            fcall_new_ch.push(own fcall.child(j).clone())
        }
    }
    fcall.children = fcall_new_ch
    fcd.variadic_index = -1.to_i32()
    fcd.variadic_count = 0
    new_ch.push(own stmt.clone())
    return true
}

desugar_kwargs_calls := proc(mut body: Expr, mut scope: TypeScope) {
    mut new_ch := Vec.new("Expr", Expr.size())
    mut changed := false

    for i in 0..body.child_count() {
        ref stmt : Expr = body.child(i)
        ref fcall : Expr = find_kwargs_fcall(stmt)
        if is_null(fcall) {
            new_ch.push(own stmt.clone())
            continue
        }
        changed = true
        ref fcd : FCallData = get_payload(fcall.data)
        ki := fcd.kwargs_index
        kc := fcd.kwargs_count

        kw_name := "_kw".concat(_kw_counter.to_str())
        _kw_counter.inc()

        kw_decl := build_kwargs_dynmap_decl(fcall, kw_name)

        scope.set(kw_name, TilType.Struct, -1.to_i32(), false, fcall.line, fcall.col, false, false)
        ref mut kwb : TypeBinding = scope.get_binding(kw_name)
        kwb.struct_name = "DynMap"

        new_ch.push(own kw_decl)

        for j in 0..kc {
            ref named_arg : Expr = fcall.child(ki.add(j.to_i64().to_i32()).to_i64().to_usize())
            new_ch.push(own build_kwargs_dynmap_set(fcall, scope, kw_name, named_arg))
        }

        rewrite_kwargs_fcall_args(fcall, kw_name)
        new_ch.push(own stmt.clone())
    }

    if changed {
        body.children = new_ch
    }
}

rewrite_kwargs_fcall_args := proc(mut fcall: Expr, kw_name: Str) {
    ref mut fcd : FCallData = get_payload(fcall.data)
    ki := fcd.kwargs_index
    kc := fcd.kwargs_count
    mut fcall_new_ch := Vec.new("Expr", Expr.size())
    mut kw_inserted := false

    for j in 0..fcall.child_count() {
        ji := j.to_i64().to_i32()
        if ji.gte(ki).and(ji.lt(ki.add(kc.to_i64().to_i32()))) {
            if kw_inserted.not() {
                mut kw_id := Expr.new(NodeType.Ident(kw_name.clone()), fcall.line, fcall.col, fcall.path)
                kw_id.til_type = TilType.Struct
                kw_id.struct_name = "DynMap"
                kw_id.is_own_arg = true
                fcall_new_ch.push(own kw_id)
                kw_inserted = true
            }
            continue
        }
        if ji.eq(ki).and(kw_inserted.not()) {
            mut kw_id := Expr.new(NodeType.Ident(kw_name.clone()), fcall.line, fcall.col, fcall.path)
            kw_id.til_type = TilType.Struct
            kw_id.struct_name = "DynMap"
            kw_id.is_own_arg = true
            fcall_new_ch.push(own kw_id)
            kw_inserted = true
        }
        fcall_new_ch.push(own fcall.child(j).clone())
    }
    if kw_inserted.not() {
        mut kw_id := Expr.new(NodeType.Ident(kw_name.clone()), fcall.line, fcall.col, fcall.path)
        kw_id.til_type = TilType.Struct
        kw_id.struct_name = "DynMap"
        kw_id.is_own_arg = true
        fcall_new_ch.push(own kw_id)
    }

    fcall.children = fcall_new_ch
    fcd.kwargs_index = -1.to_i32()
    fcd.kwargs_count = 0
}

check_own_args := func(fdef: Expr, fcall: Expr, var_name: Str) returns shallow Bool {
    ref fd : FunctionDef = get_payload(fdef.data)
    if fd.params.len().eq(0) { return false }
    for i in 0..fd.nparam {
        if i.add(1).gte(fcall.child_count()) { return false }
        ref p : Param = fd.params.get(i)
        if p.own_type.eq(OwnType.Own) {
            ref arg : Expr = fcall.child(i.add(1))
            if is_variant(arg.data, NodeType.Ident) {
                ref _ai : Str = get_payload(arg.data)
                if _ai.eq(var_name) { return true }
            }
        }
    }
    return false
}

fcall_has_own_arg := func(fcall: Expr, var_name: Str, scope: TypeScope) returns shallow Bool {
    if is_variant(fcall.data, NodeType.FCall).not() { return false }
    if fcall.child_count().lt(2) { return false }
    // Struct constructor
    if fcall.struct_name.len().gt(0) { if is_variant(fcall.child(0).data, NodeType.Ident) {
        ref _c0s : Str = get_payload(fcall.child(0).data)
        if _c0s.eq(fcall.struct_name) {
        ref sdef : Expr = scope.get_struct(fcall.struct_name)
        if is_null(sdef).not() {
            ref body : Expr = sdef.child(0)
            mut fi : USize = 0
            for i in 0..body.child_count() {
                ref fld : Expr = body.child(i)
                if is_variant(fld.data, NodeType.Decl).not() { continue }
                ref fld_decl : Declaration = get_payload(fld.data)
                if fld_decl.is_namespace { continue }
                arg_idx := fi.add(1)
                fi = fi.add(1)
                if arg_idx.lt(fcall.child_count()) {
                    ref arg : Expr = fcall.child(arg_idx)
                    if is_variant(arg.data, NodeType.Ident) {
                        ref _an : Str = get_payload(arg.data)
                        if _an.eq(var_name).and(fld_decl.is_ref.not()) {
                            if fld_decl.is_own.or(type_ctor_consumes(fld.til_type)) {
                            return true
                            }
                        }
                    }
                }
            }
        }
    } } }
    // Direct call
    if is_variant(fcall.child(0).data, NodeType.Ident) {
        ref fn_name : Str = get_payload(fcall.child(0).data)
        ref fb : TypeBinding = scope.get_binding(fn_name)
        if is_null(fb).not() {
            if is_null(fb.func_def) { return false }
            return check_own_args(fb.func_def, fcall, var_name)
        }
        return false
    }
    // Namespace method call
    if is_variant(fcall.child(0).data, NodeType.FieldAccess).and(fcall.child(0).is_ns_field) {
        ref method : Str = get_payload(fcall.child(0).data)
        ref type_node : Expr = fcall.child(0).child(0)
        if is_variant(type_node.data, NodeType.Ident).not() { return false }
        ref _tn : Str = get_payload(type_node.data)
        ref sdef : Expr = scope.get_struct(_tn)
        if is_null(sdef) { return false }
        ref body : Expr = sdef.child(0)
        for i in 0..body.child_count() {
            ref field : Expr = body.child(i)
            if is_variant(field.data, NodeType.Decl) {
                ref fd : Declaration = get_payload(field.data)
                if fd.is_namespace.and(fd.name.eq(method)) {
                    if is_variant(field.child(0).data, NodeType.FuncDef) {
                        return check_own_args(field.child(0), fcall, var_name)
                    }
                }
            }
        }
    }
    return false
}

expr_transfers_own := func(e: Expr, var_name: Str, scope: TypeScope) returns shallow Bool {
    if is_variant(e.data, NodeType.FuncDef) { return false }
    if fcall_has_own_arg(e, var_name, scope) { return true }
    if is_variant(e.data, NodeType.FieldAssign).and(e.is_own_field) {
        if e.child_count().gt(1) {
            if is_variant(e.child(1).data, NodeType.Ident) {
                ref _ei : Str = get_payload(e.child(1).data)
                if _ei.eq(var_name) { return true }
            }
        }
    }
    for i in 0..e.child_count() {
        if expr_transfers_own(e.child(i), var_name, scope) { return true }
    }
    return false
}

expr_is_borrow_source := func(e: Expr, scope: TypeScope) returns shallow Bool {
    if is_null(e) { return false }
    if is_variant(e.data, NodeType.LiteralNull) { return true }
    if is_variant(e.data, NodeType.FCall).and(fcall_returns_ref(e, scope).neq(0)) { return true }
    if is_variant(e.data, NodeType.Ident) {
        ref id : Str = get_payload(e.data)
        sf := scope.find(id)
        if is_variant(sf, ScopeFind.Found) {
            ref b : TypeBinding = get_payload(sf)
            if b.is_ref.or(b.is_param) { return true }
        }
    }
    if is_variant(e.data, NodeType.FieldAccess) {
        if e.is_ns_field { return false }
        return expr_is_borrow_source(e.child(0), scope)
    }
    return false
}

expr_is_stable_field_base := func(e: Expr, scope: TypeScope) returns shallow Bool {
    if is_null(e) { return false }
    if expr_is_borrow_source(e, scope) { return true }
    if is_variant(e.data, NodeType.Ident) {
        ref id : Str = get_payload(e.data)
        sf := scope.find(id)
        if is_variant(sf, ScopeFind.Found).not() { return false }
        ref b : TypeBinding = get_payload(sf)
        if is_null(b.func_def).not() { return false }
        if is_null(b.struct_def).not() { return false }
        return true
    }
    if is_variant(e.data, NodeType.FieldAccess) {
        if e.is_ns_field { return false }
        return expr_is_stable_field_base(e.child(0), scope)
    }
    return false
}

expr_is_ref_decl_source := func(e: Expr, scope: TypeScope) returns shallow Bool {
    if is_null(e) { return false }
    if expr_is_borrow_source(e, scope) { return true }
    if is_variant(e.data, NodeType.FieldAccess) {
        if e.is_ns_field { return false }
        return expr_is_stable_field_base(e.child(0), scope)
    }
    return false
}

field_assign_needs_delete := func(stmt: Expr) returns shallow Bool {
    if stmt.is_ref_field { return false }
    if stmt.is_own_field { return true }
    ft := stmt.child(1).til_type
    if is_variant(ft, TilType.Struct).or(is_variant(ft, TilType.Enum)) { return true }
    return false
}

alias_used_in_expr := func(body: Expr, name: Str, expr: Expr) returns shallow Bool {
    for k in 0..body.child_count() {
        ref d : Expr = body.child(k)
        if is_variant(d.data, NodeType.Decl) {
            ref dd : Declaration = get_payload(d.data)
            if dd.is_ref.and(d.child_count().gt(0)) {
                if is_variant(d.child(0).data, NodeType.Ident) {
                    ref _di : Str = get_payload(d.child(0).data)
                    if _di.eq(name) {
                        if expr_uses_var(expr, dd.name) { return true }
                    }
                }
            }
        }
    }
    return false
}

collect_scope_locals := proc(body: Expr, scope: TypeScope, shallow is_program_scope: Bool, mut locals_vec: Vec) {
    for i in 0..scope.bindings.count {
        ref b : TypeBinding = ptr_add(scope.bindings.val_data, i.mul(scope.bindings.val_size))
        if b.is_param.and(b.is_own.not()) { continue }
        if is_null(b.struct_def).not() { continue }
        if is_null(b.func_def).not() { continue }

        mut decl_idx := -1.to_i32()
        for j in 0..body.child_count() {
            ref s : Expr = body.child(j)
            if is_variant(s.data, NodeType.Decl) {
                ref dd : Declaration = get_payload(s.data)
                if dd.name.eq(b.name) {
                    decl_idx = j.to_i64().to_i32()
                    break
                }
            }
        }
        if decl_idx.eq(-1.to_i32()) {
            for j in 0..body.child_count() {
                if expr_contains_decl(body.child(j), b.name) {
                    decl_idx = j.to_i64().to_i32()
                    break
                }
            }
        }

        mut last_use := -1.to_i32()
        mut own_transfer := -1.to_i32()
        mut scan_from : USize = 0
        if decl_idx.gte(0) {
            scan_from = decl_idx.add(1).to_i64().to_usize()
        }
        for j in scan_from..body.child_count() {
            ref stmt : Expr = body.child(j)
            if expr_uses_var(stmt, b.name) {
                last_use = j.to_i64().to_i32()
            }
            if own_transfer.eq(-1.to_i32()) {
                if expr_transfers_own(stmt, b.name, scope) {
                    own_transfer = j.to_i64().to_i32()
                }
            }
        }

        mut skip_scope_delete := is_program_scope.and(decl_idx.gte(0))
        if skip_scope_delete.not() {
            for j in scan_from..body.child_count() {
                if expr_used_in_nested_func(body.child(j), b.name) {
                    skip_scope_delete = true
                    break
                }
            }
        }
        if b.is_ref { skip_scope_delete = true }

        mut li := LocalInfo()
        li.name = b.name
        li.type = b.type
        li.struct_name = b.struct_name
        li.decl_index = decl_idx
        li.last_use = last_use
        li.own_transfer = own_transfer
        li.skip_scope_delete = skip_scope_delete
        locals_vec.push(own li)
    }
}

extend_ref_local_lifetimes := proc(body: Expr, locals: Dynamic, shallow n_locals: U32) {
    mut ref_changed := true
    while ref_changed {
        ref_changed = false
        for i in 0..body.child_count() {
            ref stmt : Expr = body.child(i)
            if is_variant(stmt.data, NodeType.Decl).not() { continue }
            ref dd : Declaration = get_payload(stmt.data)
            if dd.is_ref.not() { continue }
            ref rhs : Expr = stmt.child(0)

            mut ref_last := -1.to_i32()
            for j in i.add(1)..body.child_count() {
                if expr_uses_var(body.child(j), dd.name) {
                    ref_last = j.to_i64().to_i32()
                }
            }
            if ref_last.eq(-1.to_i32()) { ref_last = i.to_i64().to_i32() }
            for j in 0..n_locals {
                ref local : LocalInfo = ptr_add(locals, j.mul(LocalInfo.size()))
                if local.name.eq(dd.name).and(local.last_use.gt(ref_last)) {
                    ref_last = local.last_use
                }
            }

            if is_variant(rhs.data, NodeType.Ident) {
                ref src_name : Str = get_payload(rhs.data)
                for j in 0..n_locals {
                    ref mut local : LocalInfo = ptr_add(locals, j.mul(LocalInfo.size()))
                    if local.name.eq(src_name).and(local.last_use.lt(ref_last)) {
                        local.last_use = ref_last
                        ref_changed = true
                    }
                }
                continue
            }
            if is_variant(rhs.data, NodeType.FCall).not() { continue }
            for a in 1..rhs.child_count() {
                ref mut arg : Expr = rhs.child(a)
                while is_variant(arg.data, NodeType.FieldAccess).and(arg.child_count().gt(0)) {
                    arg = arg.child(0)
                }
                if is_variant(arg.data, NodeType.Ident).not() { continue }
                ref aname : Str = get_payload(arg.data)
                for j in 0..n_locals {
                    ref mut local : LocalInfo = ptr_add(locals, j.mul(LocalInfo.size()))
                    if local.name.eq(aname).and(local.last_use.lt(ref_last)) {
                        local.last_use = ref_last
                        ref_changed = true
                    }
                }
            }
        }
    }
}

check_use_after_own_transfer := proc(body: Expr, locals: Dynamic, shallow n_locals: U32) {
    for j in 0..n_locals {
        ref local : LocalInfo = ptr_add(locals, j.mul(LocalInfo.size()))
        if local.own_transfer.gte(0).and(local.last_use.gt(local.own_transfer)) {
            ref stmt : Expr = body.child(local.last_use.to_i64().to_usize())
            type_error(stmt, "use of '".concat(local.name).concat("' after ownership transfer"))
            ref xfer : Expr = body.child(local.own_transfer.to_i64().to_usize())
            println(xfer.path, ":", xfer.line.to_str(), ":", xfer.col.to_str(), ": note: ownership transferred here")
            println("  help: pass a clone instead: own ", local.name, ".clone()")
        }
    }
}

insert_exit_deletes := proc(mut body: Expr, live: Dynamic, shallow n_live: U32, shallow return_only: Bool) {
    mut new_ch := Vec.new("Expr", Expr.size())
    for i in 0..body.child_count() {
        ref stmt : Expr = body.child(i)
        if is_variant(stmt.data, NodeType.If) {
            for c in 1..stmt.child_count() {
                insert_exit_deletes(stmt.child(c), live, n_live, return_only)
            }
        }
        if is_variant(stmt.data, NodeType.While) {
            insert_exit_deletes(stmt.child(1), live, n_live, true)
        }
        if is_variant(stmt.data, NodeType.Return).or(return_only.not().and(is_variant(stmt.data, NodeType.Break).or(is_variant(stmt.data, NodeType.Continue)))) {
            for j in 0..n_live {
                ref local : LocalInfo = ptr_add(live, j.mul(LocalInfo.size()))
                if stmt.child_count().gt(0) {
                    ref retval : Expr = stmt.child(0)
                    if expr_uses_var(retval, local.name).or(alias_used_in_expr(body, local.name, retval)) {
                        continue
                    }
                }
                if type_to_name(local.type, local.struct_name).len().gt(0) {
                    del := make_delete_call(local.name, local.type, local.struct_name, true, true, stmt)
                    new_ch.push(own del.clone())
                }
            }
        }
        new_ch.push(own stmt.clone())
    }
    if new_ch.len().neq(body.child_count()) {
        body.children = new_ch
    }
}

insert_nested_exit_deletes := proc(stmt: Expr, locals: Dynamic, shallow n_locals: U32, shallow stmt_idx: U32) {
    if is_variant(stmt.data, NodeType.If).not() {
        if is_variant(stmt.data, NodeType.While).not() { return }
    }
    mut live_vec := Vec.new("LocalInfo", LocalInfo.size())
    for j in 0..n_locals {
        ref local : LocalInfo = ptr_add(locals, j.mul(LocalInfo.size()))
        if local.skip_scope_delete { continue }
        if local.own_transfer.gte(0) { continue }
        if local.decl_index.lt(stmt_idx.to_i64().to_i32()) {
            if local.last_use.gte(stmt_idx.to_i64().to_i32()).or(local.last_use.eq(-1.to_i32())) {
                live_vec.push(own local.clone())
            }
        }
    }
    if live_vec.len().gt(0) {
        n_live := live_vec.len()
        live : Dynamic = Vec_take(live_vec)
        if is_variant(stmt.data, NodeType.If) {
            for c in 1..stmt.child_count() {
                insert_exit_deletes(stmt.child(c), live, n_live, false)
            }
        } else {
            insert_exit_deletes(stmt.child(1), live, n_live, true)
        }
        free(own live)
    }
}

insert_exit_deletes_into_stmt := proc(stmt: Expr, body: Expr, locals: Dynamic, shallow n_locals: U32, shallow stmt_idx: U32, mut new_ch: Vec) {
    if is_variant(stmt.data, NodeType.Return).not() {
        if is_variant(stmt.data, NodeType.Break).not() {
            if is_variant(stmt.data, NodeType.Continue).not() { return }
        }
    }
    for j in 0..n_locals {
        ref local : LocalInfo = ptr_add(locals, j.mul(LocalInfo.size()))
        if stmt.child_count().gt(0) {
            ref retval : Expr = stmt.child(0)
            if expr_uses_var(retval, local.name).or(alias_used_in_expr(body, local.name, retval)) {
                continue
            }
        }
        if local.skip_scope_delete { continue }
        if local.own_transfer.gte(0) { continue }
        if local.decl_index.lt(stmt_idx.to_i64().to_i32()) {
            if local.last_use.gte(stmt_idx.to_i64().to_i32()).or(local.last_use.eq(-1.to_i32())) {
                if type_to_name(local.type, local.struct_name).len().gt(0) {
                    del := make_delete_call(local.name, local.type, local.struct_name, false, false, stmt)
                    new_ch.push(own del.clone())
                }
            }
        }
    }
}

insert_post_stmt_deletes := proc(stmt: Expr, locals: Dynamic, shallow n_locals: U32, shallow stmt_idx: U32, mut new_ch: Vec) {
    if is_variant(stmt.data, NodeType.Return).or(is_variant(stmt.data, NodeType.Break)).or(is_variant(stmt.data, NodeType.Continue)) {
        return
    }
    for j in 0..n_locals {
        ref local : LocalInfo = ptr_add(locals, j.mul(LocalInfo.size()))
        if local.skip_scope_delete { continue }
        if local.own_transfer.gte(0) { continue }
        if local.last_use.eq(stmt_idx.to_i64().to_i32()) {
            if type_to_name(local.type, local.struct_name).len().gt(0) {
                del := make_delete_call(local.name, local.type, local.struct_name, false, false, stmt)
                new_ch.push(own del.clone())
            }
        }
        if local.last_use.eq(-1.to_i32()).and(local.decl_index.eq(stmt_idx.to_i64().to_i32())) {
            if type_to_name(local.type, local.struct_name).len().gt(0) {
                del := make_delete_call(local.name, local.type, local.struct_name, false, false, stmt)
                new_ch.push(own del.clone())
            }
        }
    }
}

insert_assign_delete := proc(mut stmt: Expr, locals: Dynamic, shallow n_locals: U32, mut new_ch: Vec) {
    if is_variant(stmt.data, NodeType.Assign).not() { return }
    ref vname : Str = get_payload(stmt.data)
    for j in 0..n_locals {
        ref local : LocalInfo = ptr_add(locals, j.mul(LocalInfo.size()))
        if local.name.eq(vname).not() { continue }
        if is_variant(local.type, TilType.Struct).or(is_variant(local.type, TilType.Enum)) {
            ref rhs : Expr = stmt.child(0)
            if expr_uses_var(rhs, vname) {
                stmt.save_old_delete = true
                if is_null(local.struct_name).not() {
                    if local.struct_name.len().gt(0) {
                        stmt.struct_name = local.struct_name.clone()
                    }
                }
            } else {
                if type_to_name(local.type, local.struct_name).len().gt(0) {
                    del := make_delete_call(local.name, local.type, local.struct_name, false, false, stmt)
                    new_ch.push(own del.clone())
                }
            }
        }
        break
    }
}

insert_free_calls := proc(mut body: Expr, mut scope: TypeScope, shallow scope_exit: I32) {
    if scope_exit.eq(0) { return }
    is_program_scope := is_null(scope.parent)

    mut locals_vec := Vec.new("LocalInfo", LocalInfo.size())
    collect_scope_locals(body, scope, is_program_scope, locals_vec)
    if locals_vec.len().eq(0) { return }
    n_locals := locals_vec.len().to_i64().to_u32()
    locals : Dynamic = Vec_take(locals_vec)

    extend_ref_local_lifetimes(body, locals, n_locals)
    check_use_after_own_transfer(body, locals, n_locals)

    mut new_ch := Vec.new("Expr", Expr.size())
    for i in 0..body.child_count() {
        ref stmt : Expr = body.child(i)
        insert_exit_deletes_into_stmt(stmt, body, locals, n_locals, i.to_i64().to_u32(), new_ch)
        insert_nested_exit_deletes(stmt, locals, n_locals, i.to_i64().to_u32())
        insert_assign_delete(stmt, locals, n_locals, new_ch)
        new_ch.push(own stmt.clone())
        insert_post_stmt_deletes(stmt, locals, n_locals, i.to_i64().to_u32(), new_ch)
    }

    body.children = new_ch
    free(own locals)
}

infer_literal_expr := proc(mut expr: Expr) {
    switch expr.data {
    case NodeType.LiteralStr:
        expr.til_type = TilType.Struct
        expr.struct_name = "Str"
    case NodeType.LiteralNum:
        if is_variant(expr.til_type, TilType.U8).not() {
            expr.til_type = TilType.I64
        }
    case NodeType.LiteralBool:
        expr.til_type = TilType.Bool
    case NodeType.LiteralNull:
        expr.til_type = TilType.Dynamic
    case:
    }
}

narrow_dynamic := proc(mut expr: Expr, target: TilType, target_struct_name: Str) {
    if is_variant(expr.til_type, TilType.Dynamic).not() { return }
    if is_variant(target, TilType.Dynamic) { return }
    if is_variant(target, TilType.Unknown) { return }
    expr.til_type = target
    if is_variant(target, TilType.Struct).or(is_variant(target, TilType.Enum)) {
        expr.struct_name = target_struct_name
    }
}

fcall_returns_ref := func(fcall: Expr, scope: TypeScope) returns shallow I32 {
    if is_variant(fcall.data, NodeType.FCall).not() { return 0.to_i32() }
    ref callee : Expr = fcall.child(0)
    if is_variant(callee.data, NodeType.Ident) {
        ref _cn : Str = get_payload(callee.data)
        ref cb : TypeBinding = scope.get_binding(_cn)
        if is_null(cb).not() {
            if is_null(cb.func_def) { return 0.to_i32() }
            ref _cfd : FunctionDef = get_payload(cb.func_def.data)
            return _cfd.return_own_type.eq(OwnType.Ref)
        }
        return 0.to_i32()
    }
    if is_variant(callee.data, NodeType.FieldAccess).and(callee.is_ns_field) {
        ref _cti : Str = get_payload(callee.child(0).data)
        ref sdef : Expr = scope.get_struct(_cti)
        if is_null(sdef) { return 0.to_i32() }
        ref body : Expr = sdef.child(0)
        ref _cfa : Str = get_payload(callee.data)
        for j in 0..body.child_count() {
            ref f : Expr = body.child(j)
            if is_variant(f.data, NodeType.Decl) {
                ref fd : Declaration = get_payload(f.data)
                if fd.is_namespace.and(fd.name.eq(_cfa)) {
                    if is_variant(f.child(0).data, NodeType.FuncDef) {
                        ref _ffd : FunctionDef = get_payload(f.child(0).data)
                        return _ffd.return_own_type.eq(OwnType.Ref)
                    }
                }
            }
        }
    }
    return 0.to_i32()
}

hoist_to_temp := func(val: Expr, mut hoisted: Vec, mut scope: TypeScope) returns Expr {
    tp := type_prefix(val.til_type, val.struct_name)
    tname := "_t_".concat(tp).concat("_").concat(hoist_counter.to_i64().to_str())
    hoist_counter.inc()

    mut decl := Expr.new(NodeType.Decl(Declaration()), val.line, val.col, val.path)
    ref mut dd : Declaration = get_payload(decl.data)
    dd.name = tname.clone()
    dd.is_mut = false
    dd.is_namespace = false
    decl.til_type = val.til_type
    if val.struct_name.len().gt(0) {
        decl.struct_name = val.struct_name.clone()
    }

    mut val_is_ref := false
    if is_variant(val.data, NodeType.FCall) {
        val_is_ref = fcall_returns_ref(val, scope).eq(0).not()
    }

    decl.add_child(own val.clone())

    mut ident := Expr.new(NodeType.Ident(tname.clone()), val.line, val.col, val.path)
    ident.til_type = val.til_type
    if val.struct_name.len().gt(0) {
        ident.struct_name = val.struct_name.clone()
    }
    ident.is_own_arg = val.is_own_arg

    scope.set(tname, val.til_type, -1.to_i32(), false, val.line, val.col, false, false)
    ref mut tb : TypeBinding = scope.get_binding(tname)
    tb.struct_name = val.struct_name.clone()
    if val_is_ref {
        dd.is_ref = true
        if is_null(tb).not() { tb.is_ref = true }
    }

    hoisted.push(own decl)
    return ident
}

type_check := proc(program: Expr, scope: TypeScope, ctx: Context) returns shallow I32 {
    errors = 0.to_i32()
    infer_body(scope, program, 0, 1, 0, 0, 0, ctx)
    return errors
}
