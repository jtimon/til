mode lib

// Check if a FieldAccess/FieldAssign Expr accesses a namespace field.
fa_is_ns := func(e: Expr, scope: TypeScope) returns shallow Bool {
    if e.children.len().eq(0) { return false }
    if e.node_type.is(NodeType.FieldAccess).not().and(e.node_type.is(NodeType.FieldAssign).not()) { return false }
    ref obj : Expr = e.child(0)
    mut sn := til_type_name(obj.til_type)
    if sn.len().eq(0) {
        switch obj.node_type {
        case NodeType.Ident(id):
            sn = id.clone()
        case:
            return false
        }
    }
    ref sdef : Expr = scope.get_struct(sn)
    if is_null(sdef) { return false }
    mut fname := ""
    switch e.node_type {
    case NodeType.FieldAccess(fn):
        fname = fn
    case NodeType.FieldAssign(fn):
        fname = fn
    case:
        UNREACHABLE(__LOC__)
        return false
    }
    ref ns : Vec = def_ns_decls(sdef)
    for dd : Declaration in ns {
        if dd.name.eq(fname) { return true }
    }
    return false
}

// Look up the OwnType for the instance field of a FieldAccess/FieldAssign.
fa_own_type := func(e: Expr, scope: TypeScope) returns shallow OwnType {
    if e.children.len().eq(0) { return OwnType.Shallow }
    if e.node_type.is(NodeType.FieldAccess).not().and(e.node_type.is(NodeType.FieldAssign).not()) { return OwnType.Shallow }
    ref obj : Expr = e.child(0)
    mut sn := til_type_name(obj.til_type)
    if sn.len().eq(0) {
        switch obj.node_type {
        case NodeType.Ident(id):
            sn = id.clone()
        case:
            return OwnType.Shallow
        }
    }
    ref sdef : Expr = scope.get_struct(sn)
    if is_null(sdef) { return OwnType.Shallow }
    mut fname := ""
    switch e.node_type {
    case NodeType.FieldAccess(fn):
        fname = fn
    case NodeType.FieldAssign(fn):
        fname = fn
    case:
        UNREACHABLE(__LOC__)
        return OwnType.Shallow
    }
    switch sdef.node_type {
    case NodeType.StructDef(ot_sdd):
        for dd : Declaration in ot_sdd.fields {
            if dd.name.eq(fname) { return dd.own_type }
        }
    case:
    }
    return OwnType.Shallow
}

mut hoist_counter : I32 = 0
mut va_counter : I32 = 0
mut kw_counter : I32 = 0
mut errors : I32 = 0
mut proc_calls_count : I32 = 0
mut proc_def_depth : I32 = 0
mut current_type_name := ""
// #187 step 2: nesting depth of auto-generated FuncDef bodies
// (clone/delete/size/etc emitted by initer). The unused-priv-member
// check ignores reads inside these so genuinely-unused priv fields
// and ns methods are not masked by boilerplate references.
mut auto_gen_depth : I32 = 0
I64Name := "I64"
U8Name := "U8"
I16Name := "I16"
I32Name := "I32"
U32Name := "U32"
U64Name := "U64"
F32Name := "F32"
BoolName := "Bool"

priv LocalInfo := struct {
    ref mut name : Str = NULL
    mut type := TilType.Unknown
    mut decl_index : I32 = 0
    mut last_use : I32 = 0
    mut own_transfer : I32 = -1.to_i32()
    mut skip_scope_delete := false
    mut is_heap := false
}

priv CtorArg := enum {
    Unfilled,
    Filled: Expr,
}

// Active file path for diagnostics (Expr no longer stores path).
mut typer_path := ""

priv type_error := proc(e: Expr, msg: Str) {
    e.error(typer_path, msg)
    errors++
}

type_error_at := proc(path: Str, shallow line: U32, shallow col: U32, msg: Str) {
    println(path, ":", line.to_str(), ":", col.to_str(), ": error: ", msg)
    errors++
}

find_namespace_func := func(sdef: Expr, method: Str) returns ref Expr {
    if is_null(sdef) { return NULL }
    ref ns : Vec = def_ns_decls(sdef)
    for fd : Declaration in ns {
        if fd.name.eq(method) { return fd.default_value }
    }
    return NULL
}

// Issue #179 step 5: locate a namespace member's Declaration so the
// caller can read its is_priv flag (find_namespace_func only returns
// the default_value FuncDef Expr).
namespace_member_is_priv := func(sdef: Expr, method: Str) returns shallow Bool {
    if is_null(sdef) { return false }
    ref ns : Vec = def_ns_decls(sdef)
    for fd : Declaration in ns {
        if fd.name.eq(method) { return fd.is_priv }
    }
    return false
}

// #187 step 3: mark a namespace member as used. Skipped while
// auto_gen_depth > 0 so auto-emitted clone/delete/size don't mask
// genuinely-unused priv namespace methods.
mark_ns_member_used := func(sdef: Expr, method: Str) returns shallow Bool {
    if is_null(sdef) { return false }
    ref ns : Vec = def_ns_decls(sdef)
    for fd : Declaration in ns {
        if fd.name.eq(method) { fd.used = true; return true }
    }
    return false
}

try_ufcs_rewrite := func(scope: TypeScope, mut e: Expr, fa: Expr, mut obj: Expr, method: Str, type_name: Str) returns shallow Bool {
    ref top : TypeBinding = scope.get_binding(method)
    mut ufcs_match : I32 = 0
    if is_null(top).not() {
        if is_null(top.func_def).not() {
            switch top.func_def.node_type {
            case NodeType.FuncDef(top_fdef):
                if top_fdef.params.len().gt(0) {
                    ref top_param : Declaration = top_fdef.params.get(0)
                    ref first_param : Str = top_param.explicit_type
                    if first_param.len().gt(0) {
                        is_free_func := top.func_type.is(FuncType.Func)
                        .or(top.func_type.is(FuncType.ExtFunc))
                        .or(top.func_type.is(FuncType.Proc))
                        .or(top.func_type.is(FuncType.ExtProc))
                        if type_name.len().gt(0) {
                            if first_param.eq(type_name) {
                                ufcs_match = 1
                            } else if first_param.eq("Dynamic").and(is_free_func) {
                                ufcs_match = 1
                            }
                        } else if obj.til_type.is(TilType.Dynamic) {
                            pt := type_from_name(first_param, scope)
                            narrow_dynamic(obj, pt)
                            ufcs_match = 1
                        }
                    }
                }
            case:
            }
        }
    }
    if ufcs_match.eq(0) { return false }
    mut fn_ident := Expr.new(NodeType.Ident(method.clone()), fa.line, fa.col)
    e.children.set(0, own fn_ident)
    mut instance := obj
    mut new_children := Vec.new("Expr", Expr.size())
    new_children.push(own e.child(0).clone())
    new_children.push(own instance.clone())
    for i in 1..e.children.len() {
        new_children.push(own e.child(i).clone())
    }
    e.children = new_children
    return true
}

// Resolve the FunctionDef Expr that describes the callee signature for an
// FCall, by walking the AST + scope rather than reading a cached field.
// Mirrors the four FuncPtr-indirect cases the typer used to handle:
//   1/2. callee is FieldAccess on a struct whose field has a FuncSig type
//   3.   callee is an Ident bound to a FuncPtr local/param
//   4.   callee is an Ident for a regular func that returns a FuncSig
// Returns NULL when the binding is not in `scope` (e.g. param/local at
// builder time after func_scope was destroyed). Callers that need to
// resolve those cases must layer their own fallback on top.
resolve_fn_sig := func(fcall: Expr, scope: TypeScope) returns ref Expr {
    if is_null(fcall) { return NULL }
    if fcall.node_type.is(NodeType.FCall).not() { return NULL }
    if fcall.children.len().eq(0) { return NULL }
    ref callee : Expr = fcall.child(0)
    switch callee.node_type {
    case NodeType.Ident(name):
        ref cb : TypeBinding = scope.get_binding(name)
        if is_null(cb) { return NULL }
        if cb.type.is(TilType.FuncPtr).not() { return NULL }
        if is_null(cb.func_def) { return NULL }
        if cb.func_type.is(FuncType.None) {
            return cb.func_def
        }
        switch cb.func_def.node_type {
        case NodeType.FuncDef(cb_fdef):
            if cb_fdef.return_type.len().eq(0) { return NULL }
            sf := scope.find(cb_fdef.return_type)
            switch sf {
            case ScopeFind.Found(rsb):
                if is_null(rsb.func_def) { return NULL }
                if rsb.func_def.children.len().neq(0) { return NULL }
                return rsb.func_def
            case:
            }
        case:
        }
        return NULL
    case NodeType.FieldAccess(method):
        if callee.children.len().eq(0) { return NULL }
        ref obj : Expr = callee.child(0)
        sname := til_type_name(obj.til_type)
        if sname.len().eq(0) { return NULL }
        ref sdef : Expr = scope.get_struct(sname)
        if is_null(sdef) { return NULL }
        switch sdef.node_type {
        case NodeType.StructDef(sdd):
            for fd : Declaration in sdd.fields {
                if fd.name.eq(method).not() { continue }
                if fd.explicit_type.len().eq(0) { continue }
                sf := scope.find(fd.explicit_type)
                switch sf {
                case ScopeFind.Found(ftb):
                    if is_null(ftb.func_def) { return NULL }
                    if ftb.func_def.children.len().neq(0) { return NULL }
                    return ftb.func_def
                case:
                }
            }
        case:
        }
        return NULL
    case:
        return NULL
    }
}

// #168 step 2: resolve an FCall's callee to its declared `return_own_type`,
// or NULL if not resolvable. Mirrors the shape of `fcall_returns_ref` for
// the OwnType.Own predicate. Recognised callee shapes:
//   - Ident("foo")     -> scope binding's func_def.return_own_type
//   - Type.method(...) -> namespace lookup on the type's def
//   - obj.method(...)  -> namespace lookup on the receiver's type def
fcall_returns_own := func(fcall: Expr, scope: TypeScope) returns shallow Bool {
    if fcall.node_type.is(NodeType.FCall).not() { return false }
    if fcall.children.len().eq(0) { return false }
    ref callee : Expr = fcall.child(0)
    switch callee.node_type {
    case NodeType.Ident(_cn):
        // Struct/enum constructor: `Foo(...)` where Foo is a registered
        // struct/enum type. The result is a freshly-constructed owned value.
        ref ctor_sdef : Expr = scope.get_struct(_cn)
        if is_null(ctor_sdef).not() { return true }
        ref cb : TypeBinding = scope.get_binding(_cn)
        if is_null(cb) { return false }
        if is_null(cb.func_def) { return false }
        switch cb.func_def.node_type {
        case NodeType.FuncDef(_cfd):
            return _cfd.return_own_type.is(OwnType.Own)
        case:
        }
        return false
    case NodeType.FieldAccess(_cfa):
        // Type-name dispatch: Type.method(args). Receiver Ident is the type.
        if fa_is_ns(callee, scope) {
            switch callee.child(0).node_type {
            case NodeType.Ident(_cti):
                ref sdef : Expr = scope.get_struct(_cti)
                ref method : Expr = find_namespace_func(sdef, _cfa)
                if is_null(method) { return false }
                switch method.node_type {
                case NodeType.FuncDef(_ffd):
                    return _ffd.return_own_type.is(OwnType.Own)
                case:
                }
                return false
            case:
            }
        }
        // UFCS / instance method: obj.method(args). Resolve via receiver's type.
        if callee.children.len().gt(0) {
            ref obj : Expr = callee.child(0)
            sname := til_type_name(obj.til_type)
            if sname.len().eq(0) { return false }
            ref sdef : Expr = scope.get_struct(sname)
            ref method : Expr = find_namespace_func(sdef, _cfa)
            if is_null(method) { return false }
            switch method.node_type {
            case NodeType.FuncDef(_ffd):
                return _ffd.return_own_type.is(OwnType.Own)
            case:
            }
        }
        return false
    case:
    }
    return false
}

// #168 step 1+2: ref bindings cannot be initialized from an owned value --
// the value would be heap-allocated with no owner. Step 1 caught literal
// `.clone()`; step 2 generalises to any FCall whose callee returns
// `OwnType.Own` (constructors, take_* helpers, factory funcs, etc.).
// Future steps broaden the surface (struct field defaults, assignments,
// ref-typed returns).
check_ref_decl_owned_init := proc(stmt: Expr, scope: TypeScope) {
    if stmt.children.len().eq(0) { return }
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        if sdecl.own_type.is(OwnType.Ref).not() { return }
        ref rhs : Expr = stmt.child(0)
        if rhs.node_type.is(NodeType.FCall).not() { return }
        if fcall_returns_own(rhs, scope).not() { return }
        type_error(stmt, "ref binding '".concat(sdecl.name).concat("' cannot be initialized from an owned value (.clone() / constructor / function returning own) -- use 'own' to keep the value, or borrow the source directly"))
    case:
    }
}

// #168 step 3: struct field defaults follow the same predicate -- a
// `ref` field cannot have an owned-RHS default. NULL is still allowed
// (forced exception for ref fields, since the type doesn't yet have
// an instance to borrow from at default-value time).
check_ref_field_owned_default := proc(fd: Declaration, scope: TypeScope) {
    if fd.own_type.is(OwnType.Ref).not() { return }
    if is_null(fd.default_value) { return }
    if fd.default_value.node_type.is(NodeType.NoDefaultArg) { return }
    if fd.default_value.node_type.is(NodeType.LiteralNull) { return }
    if fd.default_value.node_type.is(NodeType.FCall).not() { return }
    if fcall_returns_own(fd.default_value, scope).not() { return }
    type_error(fd.default_value, "ref field '".concat(fd.name).concat("' default cannot be an owned value (.clone() / constructor / function returning own) -- use NULL or change the field to 'own'"))
}

// #168 step 4: assignments to ref-typed lvalues follow the same
// predicate. Catches the original FCallData.fn_sig motivating case
// (`fcd.fn_sig = src.clone()` where fn_sig was `ref mut Expr = NULL`).
// Caller passes the resolved target name (just for the diagnostic) and
// the rhs Expr; the predicate is the same as steps 1-3.
check_ref_assign_owned_rhs := proc(stmt: Expr, target_name: Str, rhs: Expr, scope: TypeScope) {
    if rhs.node_type.is(NodeType.FCall).not() { return }
    if fcall_returns_own(rhs, scope).not() { return }
    type_error(stmt, "ref target '".concat(target_name).concat("' cannot be assigned an owned value (.clone() / constructor / function returning own) -- borrow the source directly, or change the target to 'own'/'mut'")
    )
}

// #168 step 1b / #177: ref bindings cannot be initialized to NULL. A
// `ref` slot initialized to NULL is structurally an uninitialized
// borrow; every legitimate use is rewritable as the borrow at the
// point you actually have it, as a sentinel value, or as a Context
// field on a longer-lived owner.
//
// Allowed exception: struct/namespace field defaults (where the
// parent type doesn't yet have an instance to point at).
//
// Module-scope globals were the original conservative carve-out; the
// 8 remaining sites flagged in #177 (interpreter cached_*_def/_name,
// builder current_fdef, typer current_struct_def) all migrated to
// Context fields. Module scope now enforces the same rule as locals.
check_ref_local_null_init := proc(stmt: Expr) {
    if stmt.children.len().eq(0) { return }
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        if sdecl.own_type.is(OwnType.Ref).not() { return }
        ref rhs : Expr = stmt.child(0)
        if rhs.node_type.is(NodeType.LiteralNull).not() { return }
        type_error(stmt, "ref binding '".concat(sdecl.name).concat("' cannot be initialized to NULL -- borrow the source directly, or use a non-ref shape (own/mut + sentinel)"))
    case:
    }
}

infer_func_ptr_field_call := proc(scope: TypeScope, mut e: Expr, mut fa: Expr, obj: Expr, sdef: Expr, method: Str, shallow in_func: I32, ctx: Context) returns shallow Bool {
    if is_null(sdef).or(obj.til_type.is(TilType.Struct).not().and(obj.til_type.is(TilType.Enum).not())) { return false }
    switch sdef.node_type {
    case NodeType.StructDef(fpf_sdd):
        for fd : Declaration in fpf_sdd.fields {
            if fd.name.eq(method).not() { continue }
            if fd.explicit_type.len().eq(0) { continue }
            sf_ftb := scope.find(fd.explicit_type)
            switch sf_ftb {
            case ScopeFind.Found(ftb):
                if is_null(ftb.func_def).or(ftb.func_def.children.len().neq(0)) { continue }
                fa.til_type = TilType.FuncPtr
                ref sig : Expr = ftb.func_def
                mut nargs : U32 = e.children.len()
                nargs = nargs.sub(1)
                switch sig.node_type {
                case NodeType.FuncDef(sig_fdef):
                    if nargs.neq(sig_fdef.params.len()) {
                        type_error(e, "function pointer field '".concat(method).concat("' expects ").concat(sig_fdef.params.len().to_str()).concat(" args, got ").concat(nargs.to_str()))
                    }
                    mut ai : U32 = 0
                    while ai.lt(nargs) {
                        if ai.gte(sig_fdef.params.len()) { break }
                        infer_expr(scope, e.child(ai.add(1)), in_func, ctx)
                        ai = ai.add(1)
                    }
                    if sig_fdef.return_type.len().gt(0) {
                        e.til_type = type_from_name(sig_fdef.return_type, scope)
                    } else {
                        e.til_type = TilType.None
                    }
                case:
                    UNREACHABLE(__LOC__)
                }
                return true
            case:
                continue
            }
        }
    case:
    }
    return false
}

validate_fcall_own_args := proc(scope: TypeScope, e: Expr, callee_bind: TypeBinding) {
    if is_null(callee_bind) { return }
    if is_null(callee_bind.func_def) { return }
    ref fdef : Expr = callee_bind.func_def
    switch fdef.node_type {
    case NodeType.FuncDef(fdef_data):
        fvi := fdef_data.variadic_index
        fkwi := fdef_data.kwargs_index
        mut fvc : U32 = 0
        if fvi.gte(0) {
            switch e.node_type {
            case NodeType.FCall(fcall_data0):
                fvc = fcall_data0.variadic_count
            case:
                UNREACHABLE(__LOC__)
            }
        }
        mut fkc : U32 = 0
        if fkwi.gte(0) {
            switch e.node_type {
            case NodeType.FCall(fcall_data1):
                fkc = fcall_data1.kwargs_count
            case:
                UNREACHABLE(__LOC__)
            }
        }
        mut ci : U32 = 1
        mut pi : U32 = 0
        while pi.lt(fdef_data.params.len()) {
            if ci.gte(e.children.len()) { break }
            if fvi.gte(0) {
                if pi.to_i64().to_i32().eq(fvi) {
                    ci = ci.add(fvc)
                    pi = pi.add(1)
                    continue
                }
            }
            if fkwi.gte(0) {
                if pi.to_i64().to_i32().eq(fkwi) {
                    ci = ci.add(fkc)
                    pi = pi.add(1)
                    continue
                }
            }
            ref pp2 : Declaration = fdef_data.params.get(pi)
            pown := pp2.own_type.is(OwnType.Own)
            ref arg : Expr = e.child(ci)
            if pown {
                if get_own_arg(e, ci).not() {
                    type_error(arg, "argument for 'own' parameter '".concat(pp2.name).concat("' must be marked 'own'"))
                }
            } else if get_own_arg(e, ci) {
                type_error(arg, "'own' on argument but parameter '".concat(pp2.name).concat("' is not 'own'"))
            }
            if pown {
                switch arg.node_type {
                case NodeType.Ident(an):
                    sf_ab := scope.find(an)
                    switch sf_ab {
                    case ScopeFind.Found(ab):
                        if ab.own_type.is(OwnType.Ref) {
                            type_error(arg, "cannot pass ref variable to 'own' parameter; use .clone() to make an owned copy")
                        }
                    case:
                    }
                case:
                }
            }
            if pown {
                if arg.node_type.is(NodeType.LiteralNull) {
                    type_error(arg, "cannot pass null to 'own' parameter")
                }
            }
            if pp2.own_type.is(OwnType.Shallow) {
                if arg.node_type.is(NodeType.LiteralNull) {
                    type_error(arg, "cannot pass null to 'shallow' parameter")
                }
            }
            ci = ci.add(1)
            pi = pi.add(1)
        }
    case:
        UNREACHABLE(__LOC__)
    }
}

infer_struct_constructor_fcall := proc(scope: TypeScope, mut e: Expr, name: Str, shallow in_func: I32, ctx: Context) returns shallow Bool {
    ref sdef : Expr = scope.get_struct(name)
    if is_null(sdef) { return false }
    // #187 step 1: mark the struct binding as used so a priv struct
    // that is only ever instantiated (no namespace method calls) is
    // not misreported as dead. Skip when current_type_name matches
    // the struct itself: that's an internal constructor inside the
    // struct's own auto-generated or user-written ns methods, which
    // does not count as "used externally".
    if current_type_name.eq(name).not() {
        ref mut sb_used : TypeBinding = scope.get_binding(name)
        if is_null(sb_used).not() { sb_used.used = true }
    }
    sf_sb := scope.find(name)
    switch sf_sb {
    case ScopeFind.Found(sb):
        if sb.is_builtin {
            type_error(e, "cannot instantiate builtin type '".concat(name).concat("'"))
            e.til_type = TilType.Unknown
            return true
        }
        check_priv_access(e, name, sb)
    case:
    }

    // #99: if struct has new(), disallow literal outside its namespace
    if current_type_name.eq(name).not() {
        mut has_new := false
        ref new_ns : Vec = def_ns_decls(sdef)
        for nd : Declaration in new_ns {
            if nd.name.eq("new") {
                has_new = true
                break
            }
        }
        if has_new {
            type_error(e, "struct '".concat(name).concat("' has a new() constructor; use ").concat(name).concat(".new(...) instead"))
            e.til_type = TilType.Struct(name.clone())
            return true
        }
    }

    switch sdef.node_type {
    case NodeType.StructDef(ctor_sdd):
        nfields := ctor_sdd.fields.len()
        mut field_vals := Vec.new("CtorArg", CtorArg.size())
        for _ in 0..nfields {
            field_vals.push(own CtorArg.Unfilled())
        }
        for i in 1..e.children.len() {
            ref arg : Expr = e.child(i)
            switch arg.node_type {
            case NodeType.NamedArg(aname):
                mut slot := -1.to_i32()
                for j in 0..nfields {
                    ref fld_decl : Declaration = ctor_sdd.fields.get(j)
                    if fld_decl.name.eq(aname) {
                        slot = j.to_i64().to_i32()
                        break
                    }
                }
                if slot.lt(0) {
                    msg := format("struct '", name, "' has no field '", aname, "'")
                    type_error(arg, msg)
                }
                if slot.gte(0) {
                    ref ctor_fld : Declaration = ctor_sdd.fields.get(slot.to_i64().to_u32())
                    check_member_priv(arg, name, aname, ctor_fld.is_priv)
                    if auto_gen_depth.eq(0) { ctor_fld.used = true }
                    ref slot_arg : CtorArg = field_vals.get(slot.to_i64().to_u32())
                    if slot_arg.is(CtorArg.Filled) {
                        msg := format("duplicate argument for field '", aname, "'")
                        type_error(arg, msg)
                    }
                    if slot_arg.is(CtorArg.Filled).not() {
                        field_vals.set(slot.to_i64().to_u32(), own CtorArg.Filled(arg.child(0).clone()))
                    }
                }
            case:
                type_error(arg, "struct instantiation requires named arguments")
                continue
            }
        }
        for i in 0..nfields {
            ref slot_arg : CtorArg = field_vals.get(i)
            if slot_arg.is(CtorArg.Filled).not() {
                ref fld_d : Declaration = ctor_sdd.fields.get(i)
                field_vals.set(i, own CtorArg.Filled(fld_d.default_value.clone()))
            }
        }
        mut new_ch := Vec.new("Expr", Expr.size())
        ref callee : Expr = e.child(0)
        new_ch.push(own callee.clone())
        for i in 0..nfields {
            ref slot_arg : CtorArg = field_vals.get(i)
            switch slot_arg {
            case CtorArg.Filled(filled_arg):
                new_ch.push(own filled_arg.clone())
            case:
                UNREACHABLE(__LOC__)
            }
        }
        e.children = new_ch
        for i in 1..e.children.len() {
            if e.child(i).til_type.is(TilType.Unknown) {
                infer_expr(scope, e.child(i), in_func, ctx)
            }
        }
        for fi in 0..nfields {
            if fi.gte(e.children.len().sub(1)) { break }
            ref fld_decl : Declaration = ctor_sdd.fields.get(fi)
            ai := fi.add(1).to_i64().to_i32()
            if fld_decl.own_type.is(OwnType.Ref) { continue }
            if fld_decl.own_type.is(OwnType.Own).not() {
                if type_ctor_consumes(fld_decl.til_type).not() { continue }
            }
            set_own_arg(e, ai.to_i64().to_usize())
        }
        e.til_type = TilType.Struct(resolve_type_alias(scope, name).clone())
        return true
    case:
        UNREACHABLE(__LOC__)
        return false
    }
}

desugar_user_func_fcall_args :=proc(mut e: Expr, name: Str, callee_bind: TypeBinding) {
    ref fdef : Expr = callee_bind.func_def
    switch fdef.node_type {
    case NodeType.FuncDef(fdef_data):
        nparam := fdef_data.params.len()
        vi := fdef_data.variadic_index
        kwi := fdef_data.kwargs_index
        mut fixed_count : U32 = nparam
        if vi.gte(0) {
            fixed_count = vi.to_i64().to_u32()
        }
        mut va_args := Vec.new("Expr", Expr.size())
        mut kw_args := Vec.new("Expr", Expr.size())
        mut new_args := Vec.new("CtorArg", CtorArg.size())
        for _ in 0..nparam {
            new_args.push(own CtorArg.Unfilled())
        }
        mut pos_idx : U32 = 0
        mut seen_named := false
        for i in 1..e.children.len() {
            ref arg : Expr = e.child(i)
            switch arg.node_type {
            case NodeType.NamedArg(aname):
                seen_named = true
                mut slot := -1.to_i32()
                for j in 0..nparam {
                    if j.to_i64().to_i32().eq(vi) { continue }
                    if j.to_i64().to_i32().eq(kwi) { continue }
                    ref param : Declaration = fdef_data.params.get(j)
                    if param.name.eq(aname) {
                        slot = j.to_i64().to_i32()
                        break
                    }
                }
                if slot.lt(0) {
                    if kwi.gte(0) {
                        kw_args.push(own arg.clone())
                    } else {
                        type_error(arg, format("'", name, "' has no parameter '", aname, "'"))
                    }
                } else {
                    ref slot_arg : CtorArg = new_args.get(slot.to_i64().to_u32())
                    if slot_arg.is(CtorArg.Filled) {
                        type_error(arg, format("duplicate argument for parameter '", aname, "'"))
                    } else {
                        new_args.set(slot.to_i64().to_u32(), own CtorArg.Filled(arg.child(0).clone()))
                    }
                }
            case:
                if seen_named {
                    type_error(arg, "positional argument after named argument")
                }
                if vi.gte(0) {
                    if pos_idx.gte(fixed_count) {
                        va_args.push(own arg.clone())
                    } else if pos_idx.lt(nparam) {
                        new_args.set(pos_idx, own CtorArg.Filled(arg.clone()))
                    }
                } else if pos_idx.lt(nparam) {
                    new_args.set(pos_idx, own CtorArg.Filled(arg.clone()))
                }
                pos_idx = pos_idx.add(1)
            }
        }
        for i in 0..nparam {
            if i.to_i64().to_i32().eq(vi) { continue }
            if i.to_i64().to_i32().eq(kwi) { continue }
            ref slot_arg : CtorArg = new_args.get(i)
            if slot_arg.is(CtorArg.Filled).not() {
                ref param : Declaration = fdef_data.params.get(i)
                if param.default_value.node_type.is(NodeType.NoDefaultArg).not() {
                    new_args.set(i, own CtorArg.Filled(param.default_value.clone()))
                } else {
                    type_error(e, format("missing argument for parameter '", param.name, "'"))
                }
            }
        }
        mut max_pos : U32 = nparam
        if kwi.gte(0) {
            max_pos = max_pos.sub(1)
        }
        if vi.lt(0) {
            if pos_idx.gt(max_pos) {
                type_error(e, format("too many arguments: expected ", nparam.to_str(), ", got ", pos_idx.to_str()))
            }
        }
        mut new_ch := Vec.new("Expr", Expr.size())
        ref callee : Expr = e.child(0)
        new_ch.push(own callee.clone())
        for i in 0..nparam {
            if i.to_i64().to_i32().eq(vi) {
                switch e.node_type {
                case NodeType.FCall(fcall_data):
                    fcall_data.variadic_index = new_ch.len().to_i64().to_i32()
                    for va : Expr in va_args {
                        new_ch.push(own va.clone())
                    }
                    fcall_data.variadic_count = va_args.len().to_i64().to_u32()
                case:
                    UNREACHABLE(__LOC__)
                }
            } else if i.to_i64().to_i32().eq(kwi) {
                switch e.node_type {
                case NodeType.FCall(fcall_data):
                    fcall_data.kwargs_index = new_ch.len().to_i64().to_i32()
                    for kw : Expr in kw_args {
                        new_ch.push(own kw.clone())
                    }
                    fcall_data.kwargs_count = kw_args.len().to_i64().to_u32()
                case:
                    UNREACHABLE(__LOC__)
                }
            } else {
                ref slot_arg : CtorArg = new_args.get(i)
                switch slot_arg {
                case CtorArg.Filled(filled_arg):
                    new_ch.push(own filled_arg.clone())
                case:
                    UNREACHABLE(__LOC__)
                }
            }
        }
        e.children = new_ch
    case:
        UNREACHABLE(__LOC__)
    }
}

// Validate a single argument against its parameter's type. Narrows
// numeric literals to fit the param type, applies implicit widen /
// usize-coerce, and emits a type_error on mismatch. Skips Dynamic-typed
// args (the caller has already decided this arg is not constrained).
validate_fcall_arg := proc(mut arg: Expr, ptype: TilType, ptype_name: Str, param_name: Str) {
    if arg.til_type.is(TilType.Dynamic) { return }
    if arg.til_type.is(TilType.Unknown) { return }
    switch arg.node_type {
    case NodeType.LiteralNum(lit_str):
        if is_numeric_type(ptype) {
            if literal_in_range(lit_str, ptype).not() {
                type_error(arg, "integer literal ".concat(lit_str).concat(" out of range for ").concat(type_to_name(ptype)))
            }
            arg.til_type = ptype
            return
        }
    case:
    }
    if can_implicit_widen(arg.til_type, ptype) {
        arg.til_type = ptype
        return
    }
    if can_implicit_usize_coerce(arg.til_type, ptype, ptype_name) {
        arg.til_type = ptype
        return
    }
    if arg.til_type.is(ptype).not() {
        type_error(arg, "argument type mismatch for '".concat(param_name).concat("': expected ").concat(ptype_name).concat(", got ").concat(type_to_name(arg.til_type)))
    } else if ptype.is(TilType.Struct).or(ptype.is(TilType.Enum)) {
        arg_sname := til_type_name(arg.til_type)
        if arg_sname.len().gt(0) {
            if ptype_name.eq(arg_sname).not() {
                type_error(arg, "argument type mismatch for '".concat(param_name).concat("': expected ").concat(ptype_name).concat(", got ").concat(arg_sname))
            }
        }
    }
}

infer_and_validate_fcall_args := proc(scope: TypeScope, mut e: Expr, callee_bind: TypeBinding, shallow in_func: I32, ctx: Context) {
    for i in 1..e.children.len() {
        infer_expr(scope, e.child(i), in_func, ctx)
    }
    if is_null(callee_bind) { return }
    if is_null(callee_bind.func_def) { return }
    ref fdef : Expr = callee_bind.func_def
    switch fdef.node_type {
    case NodeType.FuncDef(fdef_data):
        fvi := fdef_data.variadic_index
        fkwi := fdef_data.kwargs_index
        mut fvc : U32 = 0
        if fvi.gte(0) {
            switch e.node_type {
            case NodeType.FCall(fcall_data0):
                fvc = fcall_data0.variadic_count
            case:
                UNREACHABLE(__LOC__)
            }
        }
        mut fkc : U32 = 0
        if fkwi.gte(0) {
            switch e.node_type {
            case NodeType.FCall(fcall_data1):
                fkc = fcall_data1.kwargs_count
            case:
                UNREACHABLE(__LOC__)
            }
        }
        mut ci : U32 = 1
        mut pi : U32 = 0
        while pi.lt(fdef_data.params.len()) {
            if ci.gte(e.children.len()) { break }
            if fvi.gte(0) {
                if pi.to_i64().to_i32().eq(fvi) {
                    ref vparam : Declaration = fdef_data.params.get(pi)
                    vptype := type_from_name(vparam.explicit_type, scope)
                    for vk in 0..fvc {
                        narrow_dynamic(e.child(ci.add(vk)), vptype)
                    }
                    ci = ci.add(fvc)
                    pi = pi.add(1)
                    continue
                }
            }
            if fkwi.gte(0) {
                if pi.to_i64().to_i32().eq(fkwi) {
                    ci = ci.add(fkc)
                    pi = pi.add(1)
                    continue
                }
            }
            ref param1 : Declaration = fdef_data.params.get(pi)
            ref ptype : Str = param1.explicit_type
            narrow_dynamic(e.child(ci), type_from_name(ptype, scope))
            ci = ci.add(1)
            pi = pi.add(1)
        }
        ci = 1
        pi = 0
        while pi.lt(fdef_data.params.len()) {
            if ci.gte(e.children.len()) { break }
            if fvi.gte(0) {
                if pi.to_i64().to_i32().eq(fvi) {
                    ref vparam : Declaration = fdef_data.params.get(pi)
                    ref vptype_name : Str = vparam.explicit_type
                    mut is_splat := false
                    switch e.node_type {
                    case NodeType.FCall(fcd_v):
                        is_splat = fcd_v.is_splat
                    case:
                        UNREACHABLE(__LOC__)
                    }
                    if vptype_name.len().gt(0).and(is_splat.not()) {
                        vptype := type_from_name(vptype_name, scope)
                        if vptype.is(TilType.Dynamic).not() {
                            is_str_va := vptype_name.eq("Str")
                            for vk in 0..fvc {
                                if is_str_va {
                                    ref vk_arg : Expr = e.child(ci.add(vk))
                                    if vk_arg.til_type.is(vptype).not() {
                                        if vk_arg.til_type.is(TilType.Dynamic).not().and(vk_arg.til_type.is(TilType.Unknown).not()) {
                                            arg_tname := type_to_name(vk_arg.til_type)
                                            if arg_tname.len().gt(0).and(arg_tname.eq("Str").not()) {
                                                if type_has_to_str(scope, arg_tname) {
                                                    e.children.set(ci.add(vk), own make_to_str_call(arg_tname, vk_arg))
                                                    continue
                                                }
                                            }
                                        }
                                    }
                                }
                                validate_fcall_arg(e.child(ci.add(vk)), vptype, vptype_name, vparam.name)
                            }
                        }
                    }
                    ci = ci.add(fvc)
                    pi = pi.add(1)
                    continue
                }
            }
            if fkwi.gte(0) {
                if pi.to_i64().to_i32().eq(fkwi) {
                    ci = ci.add(fkc)
                    pi = pi.add(1)
                    continue
                }
            }
            ref param2 : Declaration = fdef_data.params.get(pi)
            ref ptype_name : Str = param2.explicit_type
            if ptype_name.len().eq(0) {
                ci = ci.add(1)
                pi = pi.add(1)
                continue
            }
            ptype := type_from_name(ptype_name, scope)
            if ptype.is(TilType.Dynamic) {
                ci = ci.add(1)
                pi = pi.add(1)
                continue
            }
            validate_fcall_arg(e.child(ci), ptype, ptype_name, param2.name)
            ci = ci.add(1)
            pi = pi.add(1)
        }
    case:
        UNREACHABLE(__LOC__)
    }
}

resolve_fcall_return_type := proc(scope: TypeScope, mut e: Expr, name: Str, callee_bind: TypeBinding, shallow in_func: I32, ctx: Context) {
    if name.eq("dyn_call").or(name.eq("dyn_call_ret")).or(name.eq("dyn_has_method")).or(name.eq("dyn_fn")) {
        if e.children.len().gte(3) {
            ref method_arg : Expr = e.child(2)
            if method_arg.node_type.is(NodeType.LiteralStr).not() {
                type_error(method_arg, "dyn_call method argument must be a string literal")
            }
        }
    }
    if name.eq("array").or(name.eq("vec")) {
        if e.children.len().gte(2) {
            ref type_arg : Expr = e.child(1)
            if type_arg.node_type.is(NodeType.LiteralStr).not() {
                type_error(type_arg, "array/vec type_name argument must be a string literal")
            }
        }
    }
    fn_type := scope.get_type(name)
    if fn_type.is(TilType.Unknown) {
        type_error(e, "undefined function '".concat(name).concat("'"))
    }
    if fn_type.is(TilType.FuncPtr) {
        if is_null(callee_bind).not() {
            if callee_bind.func_type.is(FuncType.None) {
                ref callee0 : Expr = e.child(0)
                callee0.til_type = TilType.FuncPtr
                if is_null(callee_bind.func_def).not() {
                    switch callee_bind.func_def.node_type {
                    case NodeType.FuncDef(cb_fdef):
                        if cb_fdef.return_type.len().gt(0) {
                            rt := type_from_name(cb_fdef.return_type, scope)
                            e.til_type = rt
                        } else {
                            e.til_type = TilType.None
                        }
                    case:
                        UNREACHABLE(__LOC__)
                    }
                } else {
                    e.til_type = TilType.Dynamic
                }
                if is_null(callee_bind.func_def).not() {
                    ref sig : Expr = callee_bind.func_def
                    switch sig.node_type {
                    case NodeType.FuncDef(sig_fdef):
                        mut nargs : U32 = e.children.len()
                        nargs = nargs.sub(1)
                        if nargs.neq(sig_fdef.params.len()) {
                            type_error(e, "function pointer '".concat(name).concat("' expects ").concat(sig_fdef.params.len().to_str()).concat(" args, got ").concat(nargs.to_str()))
                        }
                        mut ai : U32 = 0
                        while ai.lt(nargs) {
                            if ai.gte(sig_fdef.params.len()) { break }
                            ref arg : Expr = e.child(ai.add(1))
                            ref expected_param : Declaration = sig_fdef.params.get(ai)
                            ref expected_name : Str = expected_param.explicit_type
                            if expected_name.len().eq(0) {
                                ai = ai.add(1)
                                continue
                            }
                            expected := type_from_name(expected_name, scope)
                            if expected.is(TilType.Unknown).or(expected.is(TilType.Dynamic)) {
                                ai = ai.add(1)
                                continue
                            }
                            if arg.til_type.is(TilType.Dynamic) {
                                ai = ai.add(1)
                                continue
                            }
                            if arg.til_type.is(expected).not() {
                                type_error(e, "function pointer '".concat(name).concat("' param ").concat(ai.add(1).to_str()).concat(": expected ").concat(expected_name).concat(", got ").concat(type_to_name(arg.til_type)))
                            }
                            ai = ai.add(1)
                        }
                    case:
                        UNREACHABLE(__LOC__)
                    }
                }
                return
            }
        }
    }
    e.til_type = fn_type
    // fn_type (from binding.type) already carries the name payload via
    // TilType.Struct(name) or TilType.Enum(name) when registered, so
    // no additional struct_name assignment is needed.
    ref cur_mode : Mode = ctx.mode
    mut debug_exempt := false
    if cur_mode.debug_prints {
        if name.eq("print").or(name.eq("println")) {
            debug_exempt = true
        }
    }
    if fn_type.is(TilType.FuncPtr).not() {
        if in_func.neq(0) {
            callee_ft := scope.get_func_type(name)
            if callee_ft.is(FuncType.Proc).or(callee_ft.is(FuncType.ExtProc)) {
                proc_calls_count = proc_calls_count.add(1.to_i32())
                if debug_exempt.not() {
                    type_error(e, "func cannot call proc '".concat(name).concat("'"))
                }
            }
        } else if proc_def_depth.gt(0) {
            callee_ft2 := scope.get_func_type(name)
            if callee_ft2.is(FuncType.Proc).or(callee_ft2.is(FuncType.ExtProc)) {
                proc_calls_count = proc_calls_count.add(1.to_i32())
            }
        }
    }
    if scope.get_func_type(name).is(FuncType.Test) {
        type_error(e, "test functions cannot be called ('".concat(name).concat("')"))
    }
}

// For methods like `obj.foo(...)`: returns the type-name lookup key
// (a primitive's c_name, a struct/enum payload name, or "" when no
// match). Used by infer_field_access_fcall to find the namespace.
// Avoids the `mut type_name := ""; type_name = ...` reassign pattern
// that leaked the empty Str default.
obj_method_type_name := func(obj: Expr) returns Str {
    if obj.til_type.is(TilType.I64)
    .or(obj.til_type.is(TilType.U8))
    .or(obj.til_type.is(TilType.I16))
    .or(obj.til_type.is(TilType.I32))
    .or(obj.til_type.is(TilType.U32))
    .or(obj.til_type.is(TilType.U64))
    .or(obj.til_type.is(TilType.F32))
    .or(obj.til_type.is(TilType.Bool)) {
        return til_type_name_c(obj.til_type)
    }
    if obj.til_type.is(TilType.Struct).or(obj.til_type.is(TilType.Enum)) {
        return til_type_name(obj.til_type)
    }
    return ""
}

infer_field_access_fcall := proc(scope: TypeScope, mut e: Expr, shallow in_func: I32, ctx: Context) returns shallow Bool {
    ref mut fa : Expr = e.child(0)
    ref mut obj : Expr = fa.child(0)
    mut method := ""
    switch fa.node_type {
    case NodeType.FieldAccess(m):
        method = m.clone()
    case:
        UNREACHABLE(__LOC__)
        return false
    }
    infer_expr(scope, obj, in_func, ctx)

    mut obj_is_type := false
    switch obj.node_type {
    case NodeType.Ident(oit_id):
        if is_null(scope.get_struct(oit_id)).not() {
            obj_is_type = true
        }
    case:
    }

    mut ufcs_desugared := false
    if obj_is_type.not() {
        type_name := obj_method_type_name(obj)
        has_type_name := type_name.len().gt(0)

        ref sdef1 : Expr = scope.get_struct(type_name)
        ref ns_func1 : Expr = find_namespace_func(sdef1, method)
        if is_null(ns_func1) {
            if try_ufcs_rewrite(scope, e, fa, obj, method, type_name) {
                return false
            }
            if infer_func_ptr_field_call(scope, e, fa, obj, sdef1, method, in_func, ctx) {
                return true
            }
            if has_type_name.not() {
                if obj.til_type.is(TilType.Dynamic) {
                    type_error(e, format(
                        "cannot call method '", method, "' on Dynamic value; ",
                        "use 'ref x : Type = ...' to declare with an explicit type first",
                    ))
                } else {
                    type_error(e, format("no method '", method, "' for type 'unknown'"))
                }
            } else {
                type_error(e, format("no method '", method, "' for type '", type_name, "'"))
            }
            e.til_type = TilType.Unknown
            return true
        }
        ufcs_desugared = true
        mut instance := obj.clone()
        mut type_ident := Expr.new(NodeType.Ident(type_name.clone()), obj.line, obj.col)
        type_ident.til_type = TilType.Struct(type_name.clone())
        fa.children.set(0, own type_ident)
        // Shift own_args bitmask: bits at position >=1 move to position+1
        // (UFCS inserts self at position 1)
        switch e.node_type {
        case NodeType.FCall(ufcs_fcd):
            old_own := ufcs_fcd.own_args
            mut new_own : U64 = 0
            mut bit : U64 = 1
            for bi in 0..e.children.len() {
                if old_own.and(bit).gt(0) {
                    if bi.eq(0) {
                        new_own = new_own.or(bit)
                    } else {
                        // Shift this bit left by 1 position
                        new_own = new_own.or(bit.mul(2))
                    }
                }
                bit = bit.mul(2)
            }
            ufcs_fcd.own_args = new_own
        case:
            UNREACHABLE(__LOC__)
        }
        mut new_children := Vec.new("Expr", Expr.size())
        new_children.push(own e.child(0).clone())
        new_children.push(own instance)
        for i in 1..e.children.len() {
            new_children.push(own e.child(i).clone())
        }
        e.children = new_children
        ref mut fa2 : Expr = e.child(0)
        switch fa2.node_type {
        case NodeType.FieldAccess(_m2):
            method = _m2.clone()
        case:
            UNREACHABLE(__LOC__)
        }
    }

    ref mut fa3 : Expr = e.child(0)
    ref mut obj3 : Expr = fa3.child(0)
    if obj3.til_type.is(TilType.Unknown) {
        infer_expr(scope, obj3, in_func, ctx)
    }
    mut obj3_sname := til_type_name(obj3.til_type)
    if obj3_sname.len().eq(0) {
        switch obj3.node_type {
        case NodeType.Ident(obj3_id):
            obj3_sname = obj3_id.clone()
        case:
        }
    }
    ref sdef2 : Expr = scope.get_struct(obj3_sname)
    ref ns_func2 : Expr = find_namespace_func(sdef2, method)
    if is_null(ns_func2) {
        type_error(e, format("no namespace function '", method, "'"))
        e.til_type = TilType.Unknown
        return true
    }
    check_member_priv(e, obj3_sname, method, namespace_member_is_priv(sdef2, method))
    if auto_gen_depth.eq(0) { mark_ns_member_used(sdef2, method) }
    if proc_def_depth.gt(0).or(in_func.neq(0)) {
        ref ns_fdef0 : FunctionDef = get_payload(ns_func2.node_type)
        if ns_fdef0.func_type.is(FuncType.Proc).or(ns_fdef0.func_type.is(FuncType.ExtProc)) {
            proc_calls_count = proc_calls_count.add(1.to_i32())
        }
    }
    // Ensure obj3 carries the resolved struct type so the interpreter can
    // extract the parent type name via til_type_name for dispatch.
    if obj3_sname.len().gt(0).and(obj3.til_type.is(TilType.Struct).not()) {
        obj3.til_type = TilType.Struct(obj3_sname.clone())
    }
    switch ns_func2.node_type {
    case NodeType.FuncDef(ns_fdef):
        np := ns_fdef.params.len()
        mut new_args := Vec.new("CtorArg", CtorArg.size())
        for _ in 0..np {
            new_args.push(own CtorArg.Unfilled())
        }
        mut pos_idx : U32 = 0
        mut seen_named := false
        for i in 1..e.children.len() {
            ref arg : Expr = e.child(i)
            switch arg.node_type {
            case NodeType.NamedArg(aname):
                seen_named = true
                mut slot := -1.to_i32()
                for j in 0..np {
                    ref param : Declaration = ns_fdef.params.get(j)
                    if param.name.eq(aname) {
                        slot = j.to_i64().to_i32()
                        break
                    }
                }
                if slot.lt(0) {
                    type_error(arg, format("no parameter '", aname, "'"))
                } else {
                    ref slot_arg : CtorArg = new_args.get(slot.to_i64().to_u32())
                    if slot_arg.is(CtorArg.Filled) {
                        type_error(arg, format("duplicate argument for parameter '", aname, "'"))
                    } else {
                        new_args.set(slot.to_i64().to_u32(), own CtorArg.Filled(arg.child(0).clone()))
                    }
                }
            case:
                if seen_named {
                    type_error(arg, "positional argument after named argument")
                }
                if pos_idx.lt(np) {
                    new_args.set(pos_idx, own CtorArg.Filled(arg.clone()))
                }
                pos_idx = pos_idx.add(1)
            }
        }
        for i in 0..np {
            ref slot_arg : CtorArg = new_args.get(i)
            if slot_arg.is(CtorArg.Filled).not() {
                ref param : Declaration = ns_fdef.params.get(i)
                if param.default_value.node_type.is(NodeType.NoDefaultArg).not() {
                    new_args.set(i, own CtorArg.Filled(param.default_value.clone()))
                } else {
                    type_error(e, format("missing argument for parameter '", param.name, "'"))
                }
            }
        }
        if pos_idx.gt(np) {
            type_error(e, format("too many arguments: expected ", np.to_str(), ", got ", pos_idx.to_str()))
        }
        mut new_ch := Vec.new("Expr", Expr.size())
        ref callee : Expr = e.child(0)
        new_ch.push(own callee.clone())
        for i in 0..np {
            ref slot_arg : CtorArg = new_args.get(i)
            switch slot_arg {
            case CtorArg.Filled(filled_arg):
                new_ch.push(own filled_arg.clone())
            case:
                UNREACHABLE(__LOC__)
            }
        }
        e.children = new_ch
        for i in 1..e.children.len() {
            infer_expr(scope, e.child(i), in_func, ctx)
        }
        for i in 1..e.children.len() {
            if i.sub(1).gte(ns_fdef.params.len()) { break }
            ref param2 : Declaration = ns_fdef.params.get(i.sub(1))
            ref ptype : Str = param2.explicit_type
            narrow_dynamic(e.child(i), type_from_name(ptype, scope))
        }
        for i in 1..e.children.len() {
            if i.sub(1).gte(ns_fdef.params.len()) { break }
            ref param3 : Declaration = ns_fdef.params.get(i.sub(1))
            ref ptype_name : Str = param3.explicit_type
            ref arg : Expr = e.child(i)
            if arg.til_type.is(TilType.Dynamic) { continue }
            ptype := type_from_name(ptype_name, scope)
            if ptype.is(TilType.Dynamic) { continue }
            switch arg.node_type {
            case NodeType.LiteralNum(lit_str):
                if is_numeric_type(ptype) {
                    if literal_in_range(lit_str, ptype).not() {
                        type_error(arg, format(
                            "integer literal ", lit_str, " out of range for ", til_type_name_c(ptype),
                        ))
                    }
                    arg.til_type = ptype
                    continue
                }
            case:
            }
            if can_implicit_widen(arg.til_type, ptype)
            .or(can_implicit_usize_coerce(arg.til_type, ptype, ptype_name)) {
                arg.til_type = ptype
                continue
            }
            if type_prefix(arg.til_type).eq(type_prefix(ptype)).not() {
                ref param_name : Str = param3.name
                type_error(arg, format(
                    "argument type mismatch for '", param_name,
                    "': expected ", ptype_name, ", got ", til_type_name_c(arg.til_type),
                ))
            } else if ptype.is(TilType.Struct).or(ptype.is(TilType.Enum)) {
                arg_sname := til_type_name(arg.til_type)
                if arg_sname.len().gt(0) {
                    if ptype_name.eq(arg_sname).not() {
                        ref param_name : Str = param3.name
                        type_error(arg, format(
                            "argument type mismatch for '", param_name,
                            "': expected ", ptype_name, ", got ", arg_sname,
                        ))
                    }
                }
            }
        }
        if ufcs_desugared {
            // If bit 0 (callee) was set by the parser's 'own expr' handler,
            // propagate it to bit 1 (the UFCS self arg) and clear bit 0.
            if get_own_arg(e, 0) {
                switch e.node_type {
                case NodeType.FCall(ufcs_fcd2):
                    ufcs_fcd2.own_args = ufcs_fcd2.own_args.sub(1)
                case:
                    UNREACHABLE(__LOC__)
                }
                set_own_arg(e, 1)
            }
        }
        np2 := ns_fdef.params.len()
        if ns_fdef.params.len().gt(0) {
            for i in 1..e.children.len() {
                if i.sub(1).gte(np2) { break }
                ref pp : Declaration = ns_fdef.params.get(i.sub(1))
                pown := pp.own_type.is(OwnType.Own)
                ref arg : Expr = e.child(i)
                if pown {
                    if get_own_arg(e, i).not() {
                        type_error(arg, format("argument for 'own' parameter '", pp.name, "' must be marked 'own'"))
                    }
                } else if get_own_arg(e, i) {
                    type_error(arg, format("'own' on argument but parameter '", pp.name, "' is not 'own'"))
                }
                if pown {
                    switch arg.node_type {
                    case NodeType.Ident(an):
                        sf_ab := scope.find(an)
                        switch sf_ab {
                        case ScopeFind.Found(ab):
                            if ab.own_type.is(OwnType.Ref) {
                                type_error(arg, "cannot pass ref variable to 'own' parameter; use .clone() to make an owned copy")
                            }
                        case:
                        }
                    case:
                    }
                }
                if pown {
                    if arg.node_type.is(NodeType.LiteralNull) {
                        type_error(arg, "cannot pass null to 'own' parameter")
                    }
                }
                if pp.own_type.is(OwnType.Shallow) {
                    if arg.node_type.is(NodeType.LiteralNull) {
                        type_error(arg, "cannot pass null to 'shallow' parameter")
                    }
                }
            }
        }
        mut rt := TilType.None
        if ns_fdef.return_type.len().gt(0) {
            rt = type_from_name(ns_fdef.return_type, scope)
        }
        e.til_type = rt
    case:
        UNREACHABLE(__LOC__)
        return false
    }
    return true
}

// Issue #179 step 1: cross-file priv check for standalone funcs.
// Idempotent per binding: a failing call site can be visited twice
// (e.g. via FieldAccess receiver re-walks), so we track whether the
// error has already been reported and emit at most one diagnostic.
priv check_priv_access := proc(mut e: Expr, name: Str, mut b: TypeBinding) {
    if is_null(b) { return }
    if b.is_priv.not() { return }
    if b.path.eq(typer_path) { return }
    if b.priv_err_reported { return }
    type_error(e, "'".concat(name).concat("' is private to '").concat(b.path).concat("'"))
    b.priv_err_reported = true
}

// Issue #179 steps 4-5: priv check for struct fields and namespace
// methods. Stricter than top-level priv: priv members are only
// visible inside the struct's own namespace methods, not just the
// declaring file. current_type_name == owner_name iff we are
// type-checking a member body of that struct.
check_member_priv := proc(mut e: Expr, owner_name: Str, member_name: Str, member_is_priv: Bool) {
    if member_is_priv.not() { return }
    if current_type_name.eq(owner_name) { return }
    type_error(e, "'".concat(owner_name).concat(".").concat(member_name).concat("' is private to its struct"))
}

infer_fcall_expr := proc(scope: TypeScope, mut e: Expr, shallow in_func: I32, ctx: Context) {
    if e.child(0).node_type.is(NodeType.FieldAccess) {
        if infer_field_access_fcall(scope, e, in_func, ctx) { return }
    }
    ref mut callee : Expr = e.child(0)
    mut name := ""
    switch callee.node_type {
    case NodeType.Ident(name0):
        name = name0.clone()
    case:
        UNREACHABLE(__LOC__)
        return
    }
    ref resolved_name : Str = resolve_type_alias(scope, name)
    if resolved_name.eq(name).not() {
        callee.node_type = NodeType.Ident(resolved_name.clone())
        name = resolved_name.clone()
    }
    if infer_struct_constructor_fcall(scope, e, name, in_func, ctx) { return }
    ref mut callee_bind : TypeBinding = scope.get_binding(name)
    if is_null(callee_bind).not() {
        callee_bind.used = true
        check_priv_access(e, name, callee_bind)
        if is_null(callee_bind.func_def).not() {
            desugar_user_func_fcall_args(e, name, callee_bind)
        }
    }
    infer_and_validate_fcall_args(scope, e, callee_bind, in_func, ctx)
    validate_fcall_own_args(scope, e, callee_bind)
    resolve_fcall_return_type(scope, e, name, callee_bind, in_func, ctx)
    return
}

priv infer_expr := proc(scope: TypeScope, mut expr: Expr, shallow in_func: I32, ctx: Context) {
    switch expr.node_type {
    case NodeType.LiteralStr:  infer_literal_expr(expr)
    case NodeType.LiteralNum:  infer_literal_expr(expr)
    case NodeType.LiteralBool: infer_literal_expr(expr)
    case NodeType.LiteralNull: infer_literal_expr(expr)
    case NodeType.Ident:       infer_ident_expr(scope, expr)
    case NodeType.FuncDef:     infer_func_def_expr(scope, expr, ctx)
    case NodeType.StructDef:   infer_type_def_expr(scope, expr, ctx)
    case NodeType.EnumDef:     infer_type_def_expr(scope, expr, ctx)
    case NodeType.FCall:       infer_fcall_expr(scope, expr, in_func, ctx)
    case NodeType.FieldAccess: infer_field_access_expr(scope, expr, in_func, ctx)
    case NodeType.MapLit:      infer_map_lit_expr(scope, expr, in_func, ctx)
    case NodeType.SetLit:      infer_set_lit_expr(scope, expr, in_func, ctx)
    case NodeType.NamedArg:    infer_named_arg_expr(scope, expr, in_func, ctx)
    case:
        expr.til_type = TilType.Unknown
    }
}

infer_ident_expr := proc(scope: TypeScope, mut expr: Expr) {
    switch expr.node_type {
    case NodeType.Ident(id_name):
        type := scope.get_type(id_name)
        if type.is(TilType.Unknown) {
            type_error(expr, "undefined symbol '".concat(id_name).concat("'"))
        }
        expr.til_type = type
        ref mut ib : TypeBinding = scope.get_binding(id_name)
        if is_null(ib).not() {
            // #187 step 1: skip "used" marking when we're inside the
            // ident's own type namespace. Auto-generated clone/delete/
            // variant-constructor bodies reference the parent type by
            // name; counting those would mask a genuinely unused priv
            // type. External Ident references still mark it used.
            if current_type_name.eq(id_name).not() {
                ib.used = true
            }
            check_priv_access(expr, id_name, ib)
            if is_null(ib.func_def).not() {
                expr.til_type = TilType.FuncPtr
            }
            if is_null(ib.struct_def).not() {
                if til_type_name(expr.til_type).len().eq(0) {
                    ref resolved_name : Str = resolve_type_alias(scope, id_name)
                    expr.til_type = TilType.Custom(resolved_name.clone())
                }
            }
        }
    case:
        UNREACHABLE(__LOC__)
    }
}

infer_named_arg_expr := proc(scope: TypeScope, mut expr: Expr, shallow in_func: I32, ctx: Context) {
    if expr.children.len().gt(0) {
        infer_expr(scope, expr.child(0), in_func, ctx)
        ref val : Expr = expr.child(0)
        expr.til_type = val.til_type
    }
}

infer_map_lit_expr := proc(scope: TypeScope, mut expr: Expr, shallow in_func: I32, ctx: Context) {
    for e_i : Expr in expr.children {
        infer_expr(scope, e_i, in_func, ctx)
    }
    expr.til_type = TilType.Struct("Map".clone())
}

infer_set_lit_expr := proc(scope: TypeScope, mut expr: Expr, shallow in_func: I32, ctx: Context) {
    for e_i : Expr in expr.children {
        infer_expr(scope, e_i, in_func, ctx)
    }
    expr.til_type = TilType.Struct("Set".clone())
}

infer_type_def_expr := proc(scope: TypeScope, mut expr: Expr, ctx: Context) {
    expr.til_type = TilType.None
    inner := TypeScope(parent = scope)
    switch expr.node_type {
    case NodeType.StructDef(tc_sdd):
        for fd : Declaration in tc_sdd.fields {
            if is_null(fd.default_value).not().and(fd.default_value.node_type.is(NodeType.NoDefaultArg).not()) {
                infer_expr(inner, fd.default_value, 0, ctx)
                check_ref_field_owned_default(fd, inner)
            }
            if fd.explicit_type.len().gt(0) {
                fd.til_type = type_from_name(fd.explicit_type, inner)
                if fd.til_type.is(TilType.Unknown).not() {
                    if is_null(fd.default_value).not().and(fd.default_value.node_type.is(NodeType.NoDefaultArg).not()) {
                        if fd.default_value.node_type.is(NodeType.LiteralNum).and(is_numeric_type(fd.til_type)) {
                            fd.default_value.til_type = fd.til_type
                        }
                        if fd.default_value.node_type.is(NodeType.LiteralNull).not() {
                            narrow_dynamic(fd.default_value, fd.til_type)
                        }
                    }
                }
            } else {
                if is_null(fd.default_value).not() {
                    fd.til_type = fd.default_value.til_type
                }
            }
            inner.set(fd.name, fd.til_type, FuncType.None, fd.is_mut, typer_path, expr.line, expr.col, false, fd.own_type)
            if fd.til_type.is(TilType.FuncPtr) {
                ref mut _fb : TypeBinding = inner.get_binding(fd.name)
                if is_null(fd.default_value).not() {
                    switch fd.default_value.node_type {
                    case NodeType.Ident(_dv_id):
                        ref _src : TypeBinding = inner.get_binding(_dv_id)
                        if is_null(_src).not().and(is_null(_src.func_def).not()) {
                            _fb.func_def = _src.func_def
                        }
                    case:
                    }
                }
                if is_null(_fb.func_def) {
                    if fd.explicit_type.len().gt(0) {
                        ref _fsb : TypeBinding = inner.get_binding(fd.explicit_type)
                        if is_null(_fsb).not().and(is_null(_fsb.func_def).not()) {
                            if _fsb.func_def.children.len().eq(0) {
                                _fb.func_def = _fsb.func_def
                            }
                        }
                    }
                }
            }
        }
    case:
    }
    // Type-check ns_decls (stored directly by parser, not via body)
    ref tc_ns : Vec = def_ns_decls(expr)
    for tc_nd : Declaration in tc_ns {
        if is_null(tc_nd.default_value) { continue }
        if tc_nd.default_value.node_type.is(NodeType.NoDefaultArg) { continue }
        switch tc_nd.default_value.node_type {
        case NodeType.FuncDef(tc_fd):
            mut tc_rt := TilType.None
            if tc_fd.return_type.len().gt(0) {
                tc_rt = type_from_name(tc_fd.return_type, inner)
            }
            tc_nd.til_type = tc_rt.clone()
            inner.set(tc_nd.name, tc_rt, tc_fd.func_type, false, typer_path, 0, 0, false, OwnType.Shallow)
            ref mut tc_fb : TypeBinding = inner.get_binding(tc_nd.name)
            tc_fb.func_def = tc_nd.default_value
            if tc_fd.func_type.is(FuncType.ExtFunc).or(tc_fd.func_type.is(FuncType.ExtProc)) {
                tc_fb.is_builtin = true
            }
            infer_func_def_expr(inner, tc_nd.default_value, ctx)
        case:
            infer_expr(inner, tc_nd.default_value, 0, ctx)
            tc_nd.til_type = tc_nd.default_value.til_type.clone()
        }
    }
    TypeScope.delete(own inner)
}

infer_func_sig_expr := func(scope: TypeScope, mut expr: Expr) {
    switch expr.node_type {
    case NodeType.FuncDef(fdef):
        if fdef.return_type.len().gt(0) {
            return_type_name := fdef.return_type.clone()
            ref resolved_return_type : Str = resolve_type_alias(scope, return_type_name)
            fdef.return_type = resolved_return_type
        }
        for param : Declaration in fdef.params {
            ptype_name := param.explicit_type.clone()
            ref resolved_ptype : Str = resolve_type_alias(scope, ptype_name)
            param.explicit_type = resolved_ptype
            param.til_type = til_type_from_explicit_type(resolved_ptype)
        }
    case:
        UNREACHABLE(__LOC__)
    }
    expr.til_type = TilType.FuncPtr
}

check_ref_function_returns := proc(func_scope: TypeScope, expr: Expr) {
    switch expr.node_type {
    case NodeType.FuncDef(fdef):
        if fdef.return_own_type.is(OwnType.Ref).not() { return }
    case:
        UNREACHABLE(__LOC__)
        return
    }
    ref body : Expr = expr.child(0)
    for stmt : Expr in body.children {
        if stmt.node_type.is(NodeType.Return).not() { continue }
        if stmt.children.len().eq(0) { continue }
        ref rv : Expr = stmt.child(0)
        if expr_is_borrow_source(rv, func_scope).not() {
            type_error(stmt, "ref function must return a parameter or ref variable")
        }
    }
}

infer_func_def_expr := proc(scope: TypeScope, mut expr: Expr, ctx: Context) {
    if expr.children.len().eq(0) {
        infer_func_sig_expr(scope, expr)
        return
    }
    expr.til_type = TilType.None
    switch expr.node_type {
    case NodeType.FuncDef(fdef):
        is_func := fdef.func_type.is(FuncType.Func)
        is_macro := fdef.func_type.is(FuncType.Macro)
        if fdef.func_type.is(FuncType.Test) {
            if is_null(scope.parent).not() {
                type_error(expr, "test functions can only be declared in root scope")
            }
            if fdef.return_type.len().gt(0) {
                type_error(expr, "test functions cannot have a return type")
            }
            if fdef.params.len().gt(0) {
                type_error(expr, "test functions cannot have parameters")
            }
        }
        ref cur_mode : Mode = ctx.mode
        if cur_mode.is_pure {
            if fdef.func_type.is(FuncType.Proc) {
                type_error(expr, "proc not allowed in pure mode")
            }
        }
        mut func_scope := TypeScope(parent = scope)
        if fdef.return_type.len().gt(0) {
            return_type_name := fdef.return_type.clone()
            ref resolved_return_type : Str = resolve_type_alias(scope, return_type_name)
            fdef.return_type = resolved_return_type
        }
        for i in 0..fdef.params.len() {
            ref mut param : Declaration = fdef.params.get(i)
            ptype_name := param.explicit_type.clone()
            ref resolved_ptype : Str = resolve_type_alias(scope, ptype_name)
            param.explicit_type = resolved_ptype
            param.til_type = til_type_from_explicit_type(resolved_ptype)
            ref ptn : Str = param.explicit_type
            pt := type_from_name(ptn, scope)
            if pt.is(TilType.Unknown) {
                type_error(expr, "undefined type '".concat(ptn).concat("'"))
            }
            pmut := param.is_mut
            pown := param.own_type.is(OwnType.Own)
            pshallow := param.own_type.is(OwnType.Shallow)
            if pshallow {
                is_scalar := pt.is(TilType.I64)
                .or(pt.is(TilType.U8))
                .or(pt.is(TilType.I16))
                .or(pt.is(TilType.I32))
                .or(pt.is(TilType.U32))
                .or(pt.is(TilType.U64))
                .or(pt.is(TilType.F32))
                .or(pt.is(TilType.Bool))
                if is_scalar.not().and(pt.is(TilType.Struct).not()).and(pt.is(TilType.Enum).not()) {
                    type_error(expr, "shallow parameter '".concat(param.name).concat("' must be a scalar or struct type"))
                }
                if pown {
                    type_error(expr, "parameter cannot be both 'shallow' and 'own'")
                }
            }
            if i.to_i64().to_i32().eq(fdef.variadic_index) {
                param.own_type = OwnType.Own
                func_scope.set(param.name, TilType.Struct("Array".clone()), FuncType.None, false, typer_path, expr.line, expr.col, true, OwnType.Own)
            } else if i.to_i64().to_i32().eq(fdef.kwargs_index) {
                param.own_type = OwnType.Own
                func_scope.set(param.name, TilType.Struct("DynMap".clone()), FuncType.None, false, typer_path, expr.line, expr.col, true, OwnType.Own)
            } else {
                func_scope.set(param.name, pt, FuncType.None, pmut, typer_path, expr.line, expr.col, true, param.own_type)
                ref mut pb : TypeBinding = func_scope.get_binding(param.name)
                if pt.is(TilType.FuncPtr) {
                    sf_fsb := scope.find(ptn)
                    switch sf_fsb {
                    case ScopeFind.Found(fsb):
                        if is_null(fsb.func_def).not() {
                            if fsb.func_def.children.len().eq(0) {
                                pb.func_def = fsb.func_def
                            }
                        }
                    case:
                    }
                }
            }
        }
        mut in_func_val := 0.to_i32()
        if is_func { in_func_val = 1 }
        mut returns_ref_val := 0.to_i32()
        if fdef.return_own_type.is(OwnType.Ref) { returns_ref_val = 1 }
        is_proc := fdef.func_type.is(FuncType.Proc)
        saved_proc_calls := proc_calls_count
        if is_proc {
            proc_calls_count = 0.to_i32()
            proc_def_depth = proc_def_depth.add(1.to_i32())
        }
        if fdef.auto_generated {
            auto_gen_depth = auto_gen_depth.add(1.to_i32())
        }
        infer_body(func_scope, expr.child(0), in_func_val, 1, 0, returns_ref_val, 0, ctx)
        if fdef.auto_generated {
            auto_gen_depth = auto_gen_depth.sub(1.to_i32())
        }
        if is_proc {
            if proc_calls_count.eq(0) {
                type_error(expr, "proc has no proc/ext_proc calls; should be a func")
            }
            proc_calls_count = saved_proc_calls
            proc_def_depth = proc_def_depth.sub(1.to_i32())
        }
        if is_macro.and(fdef.return_type.len().eq(0)) {
            type_error(expr, "macro must declare a return type")
        }
        check_ref_function_returns(func_scope, expr)
        check_unused_params(func_scope, expr)
        check_unused_locals(func_scope, typer_path)
        TypeScope.delete(own func_scope)
    case:
        UNREACHABLE(__LOC__)
    }
}

check_unused_params := proc(func_scope: TypeScope, expr: Expr) {
    switch expr.node_type {
    case NodeType.FuncDef(fdef):
        if fdef.func_type.is(FuncType.ExtFunc) { return }
        if fdef.func_type.is(FuncType.ExtProc) { return }
        for param : Declaration in fdef.params {
            if param.name.len().eq(0) { continue }
            if param.name.starts_with("_") { continue }
            ref pb : TypeBinding = func_scope.get_binding(param.name)
            if is_null(pb) { continue }
            if pb.used.not() {
                type_error(expr, "unused parameter '".concat(param.name).concat("'"))
            }
        }
    case:
        UNREACHABLE(__LOC__)
    }
}

check_unused_locals := proc(scope: TypeScope, path: Str) {
    for bi in 0..scope.bindings.len() {
        ref b : TypeBinding = Map.val_ptr(scope.bindings, bi)
        if b.is_param { continue }
        if b.is_builtin { continue }
        if b.is_type_alias { continue }
        if is_null(b.struct_def).not() { continue }
        if is_null(b.func_def).not() { continue }
        if b.name.len().eq(0) { continue }
        if b.name.starts_with("_") { continue }
        if b.used { continue }
        type_error_at(path, b.line, b.col, "unused variable '".concat(b.name).concat("'"))
    }
}

// Issue #187 step 1: top-level priv items (funcs, structs, enums,
// globals) are file-local by construction. If nothing in the
// declaring file references one, it is dead code -- no importer can
// possibly reach it. Flag and suggest removing 'priv' to expose it.
// Returns the number of errors emitted so the loader can fold the
// count into its overall type_errors total.
check_unused_priv_top_level := proc(scope: TypeScope) returns shallow I32 {
    mut found : I32 = 0
    for bi in 0..scope.bindings.len() {
        ref b : TypeBinding = Map.val_ptr(scope.bindings, bi)
        if b.is_priv.not() { continue }
        if b.is_builtin { continue }
        if b.used { continue }
        if b.name.len().eq(0) { continue }
        if b.name.starts_with("_") { continue }
        mut kind := "value"
        if is_null(b.func_def).not() { kind = "func" }
        if is_null(b.struct_def).not() {
            if b.struct_def.node_type.is(NodeType.EnumDef) { kind = "enum" }
            else { kind = "struct" }
        }
        type_error_at(b.path, b.line, b.col,
            "unused priv ".concat(kind).concat(" '").concat(b.name)
                .concat("'; remove 'priv' to expose it"))
        found = found.add(1.to_i32())
    }
    return found
}

// #187 steps 2-3: priv struct fields and namespace methods that no
// code in the struct's own namespace ever reads. The typer marks
// fields/ns_decls used on every successful access (gated on
// auto_gen_depth == 0 so boilerplate clone/delete don't mask
// unused decls). After type_check, walk every struct/enum decl in
// each ImportUnit and flag the leftovers.
check_unused_priv_members_in_program := proc(program: Expr, path: Str) returns shallow I32 {
    mut found : I32 = 0
    for stmt : Expr in program.children {
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        if stmt.children.len().eq(0) { continue }
        ref tdef : Expr = stmt.child(0)
        if tdef.node_type.is(NodeType.StructDef).not()
            .and(tdef.node_type.is(NodeType.EnumDef).not()) { continue }
        mut owner_name := ""
        switch stmt.node_type {
        case NodeType.Decl(td_decl):
            owner_name = td_decl.name.clone()
        case:
            UNREACHABLE(__LOC__)
        }
        // Field walk (StructDef only). Report at the field's
        // default_value location (every field has one -- the parser
        // requires `name := value` or `name : Type = value`) so the
        // diagnostic points at the dead member, not the enclosing
        // struct. Fall back to tdef location for compiler-generated
        // decls that may carry the NoDefaultArg sentinel.
        switch tdef.node_type {
        case NodeType.StructDef(walk_sdd):
            for fld : Declaration in walk_sdd.fields {
                if fld.is_priv.not() { continue }
                if fld.used { continue }
                if fld.name.len().eq(0) { continue }
                if fld.name.starts_with("_") { continue }
                mut fl_line : U32 = tdef.line
                mut fl_col : U32 = tdef.col
                if is_null(fld.default_value).not()
                    .and(fld.default_value.node_type.is(NodeType.NoDefaultArg).not()) {
                    fl_line = fld.default_value.line
                    fl_col = fld.default_value.col
                }
                type_error_at(path, fl_line, fl_col,
                    "unused priv field '".concat(owner_name).concat(".").concat(fld.name)
                        .concat("'; remove 'priv' to expose it"))
                found = found.add(1.to_i32())
            }
        case:
        }
        // Namespace walk (both StructDef and EnumDef). Same
        // default_value-location strategy as fields.
        ref ns : Vec = def_ns_decls(tdef)
        for nsd : Declaration in ns {
            if nsd.is_priv.not() { continue }
            if nsd.used { continue }
            if nsd.name.len().eq(0) { continue }
            if nsd.name.starts_with("_") { continue }
            mut ns_line : U32 = tdef.line
            mut ns_col : U32 = tdef.col
            if is_null(nsd.default_value).not()
                .and(nsd.default_value.node_type.is(NodeType.NoDefaultArg).not()) {
                ns_line = nsd.default_value.line
                ns_col = nsd.default_value.col
            }
            type_error_at(path, ns_line, ns_col,
                "unused priv ns member '".concat(owner_name).concat(".").concat(nsd.name)
                    .concat("'; remove 'priv' to expose it"))
            found = found.add(1.to_i32())
        }
    }
    return found
}

infer_return_stmt := proc(scope: TypeScope, mut stmt: Expr, shallow in_func: I32, shallow returns_ref: I32, ctx: Context) {
    if stmt.children.len().gt(0) {
        infer_expr(scope, stmt.child(0), in_func, ctx)
        stmt.til_type = stmt.child(0).til_type
        if returns_ref.eq(0) {
            switch stmt.child(0).node_type {
            case NodeType.Ident(rn):
                sf := scope.find(rn)
                switch sf {
                case ScopeFind.Found(b):
                    if b.own_type.is(OwnType.Ref).and(b.is_alias.not()).and(b.is_param.not()) {
                        type_error(stmt, "cannot return ref variable from non-ref function; use .clone() or 'returns ref'")
                    }
                    if b.own_type.is(OwnType.Ref).and(b.is_alias).or(b.is_param.and(b.own_type.is(OwnType.Own).not())) {
                        tname := type_to_name(stmt.til_type)
                        if tname.len().gt(0) {
                            mc := make_clone_call(tname, stmt.til_type, stmt.child(0), stmt)
                            stmt.children.set(0, own mc)
                        }
                    }
                case:
                }
            case:
            }
        } else {
            // #168 step 5: a ref-typed function cannot return an owned value
            // -- the heap allocation has nowhere to live in the caller.
            ref ret_expr : Expr = stmt.child(0)
            if ret_expr.node_type.is(NodeType.FCall).and(fcall_returns_own(ret_expr, scope)) {
                type_error(stmt, "ref-typed function cannot return an owned value (.clone() / constructor / function returning own) -- return a borrow source directly, or change the signature to return owned")
            }
        }
    } else {
        stmt.til_type = TilType.None
    }
}

infer_if_stmt := proc(scope: TypeScope, mut stmt: Expr, shallow in_func: I32, shallow in_loop: I32, shallow returns_ref: I32, ctx: Context) {
    infer_expr(scope, stmt.child(0), in_func, ctx)
    if stmt.child(0).til_type.is(TilType.Bool).not().and(stmt.child(0).til_type.is(TilType.Unknown).not()) {
        type_error(stmt, "if condition must be Bool")
    }
    then_scope := TypeScope(parent = scope)
    infer_body(then_scope, stmt.child(1), in_func, 1, in_loop, returns_ref, 0, ctx)
    check_unused_locals(then_scope, typer_path)
    TypeScope.delete(own then_scope)
    if stmt.children.len().gt(2) {
        else_scope := TypeScope(parent = scope)
        infer_body(else_scope, stmt.child(2), in_func, 1, in_loop, returns_ref, 0, ctx)
        check_unused_locals(else_scope, typer_path)
        TypeScope.delete(own else_scope)
    }
    stmt.til_type = TilType.None
}

infer_field_access_expr := proc(scope: TypeScope, mut expr: Expr, shallow in_func: I32, ctx: Context) {
    infer_expr(scope, expr.child(0), in_func, ctx)
    ref obj : Expr = expr.child(0)
    obj_sname := til_type_name(obj.til_type)
    if obj_sname.len().gt(0) {
        ref sdef : Expr = scope.get_struct(obj_sname)
        if is_null(sdef).not() {
            mut fname := ""
            switch expr.node_type {
            case NodeType.FieldAccess(fn):
                fname = fn
            case:
                UNREACHABLE(__LOC__)
                return
            }
            mut found := false
            // Search struct fields from payload
            switch sdef.node_type {
            case NodeType.StructDef(fa_sdd):
                for fld : Declaration in fa_sdd.fields {
                    if fld.name.eq(fname) {
                        expr.til_type = fld.til_type.clone()
                        check_member_priv(expr, obj_sname, fname, fld.is_priv)
                        if auto_gen_depth.eq(0) { fld.used = true }
                        found = true
                        break
                    }
                }
            case:
            }
            // Search namespace declarations from payload ns_decls
            if found.not() {
                ref fa_ns : Vec = def_ns_decls(sdef)
                for nsd : Declaration in fa_ns {
                    if nsd.name.eq(fname) {
                        expr.til_type = nsd.til_type.clone()
                        if sdef.node_type.is(NodeType.EnumDef).and(is_null(nsd.default_value).not()) {
                            switch nsd.default_value.node_type {
                            case NodeType.FuncDef(fd):
                                if fd.func_type.is(FuncType.ExtFunc).and(fd.return_type.len().gt(0)).and(fd.return_type.eq(obj_sname)) {
                                    expr.til_type = TilType.Enum(obj_sname.clone())
                                }
                            case:
                                expr.til_type = TilType.Enum(obj_sname.clone())
                            }
                        }
                        check_member_priv(expr, obj_sname, fname, nsd.is_priv)
                        if auto_gen_depth.eq(0) { nsd.used = true }
                        found = true
                        break
                    }
                }
            }
            if found.not() {
                mut kind := "struct"
                if sdef.node_type.is(NodeType.EnumDef) { kind = "enum" }
                type_error(expr, kind.concat(" '").concat(obj_sname).concat("' has no field '").concat(fname).concat("'"))
                expr.til_type = TilType.Unknown
            }
        }
    } else {
        type_error(expr, "field access on non-struct value")
        expr.til_type = TilType.Unknown
    }
}

infer_field_assign_stmt := proc(scope: TypeScope, mut stmt: Expr, shallow in_func: I32, ctx: Context) {
    infer_expr(scope, stmt.child(0), in_func, ctx)
    infer_expr(scope, stmt.child(1), in_func, ctx)
    ref obj : Expr = stmt.child(0)
    ref mut rhs : Expr = stmt.child(1)
    mut fname := ""
    switch stmt.node_type {
    case NodeType.FieldAssign(fn):
        fname = fn.clone()
    case:
        UNREACHABLE(__LOC__)
        return
    }
    obj_sname := til_type_name(obj.til_type)
    if obj_sname.len().gt(0) {
        ref sdef : Expr = scope.get_struct(obj_sname)
        if is_null(sdef).not() {
            mut found := false
            switch sdef.node_type {
            case NodeType.StructDef(fa_sdd):
                for fld : Declaration in fa_sdd.fields {
                    if fld.name.eq(fname) {
                        found = true
                        check_member_priv(stmt, obj_sname, fname, fld.is_priv)
                        if auto_gen_depth.eq(0) { fld.used = true }
                        if fld.is_mut.not() {
                            type_error(stmt, "cannot assign to immutable field '".concat(fname).concat("'"))
                        }
                        if fld.own_type.is(OwnType.Ref) {
                            check_ref_assign_owned_rhs(stmt, fname, rhs, scope)
                        }
                        mut handled_lit := false
                        switch rhs.node_type {
                        case NodeType.LiteralNum(lit_str):
                            if is_numeric_type(fld.til_type) {
                                if literal_in_range(lit_str, fld.til_type).not() {
                                    type_error(rhs, "integer literal out of range for field '".concat(fname).concat("'"))
                                }
                                rhs.til_type = fld.til_type.clone()
                                handled_lit = true
                            }
                        case:
                        }
                        if handled_lit.not() {
                            rhs_type := rhs.til_type
                            if rhs_type.is(fld.til_type).not() {
                                if rhs_type.is(TilType.Unknown).not() {
                                    if rhs_type.is(TilType.Dynamic).not() {
                                        type_error(stmt, "field '".concat(fname).concat("' type mismatch"))
                                    }
                                }
                            }
                        }
                        break
                    }
                }
            case:
            }
            // Search namespace declarations from payload ns_decls
            if found.not() {
                ref fa_ns : Vec = def_ns_decls(sdef)
                for nsd : Declaration in fa_ns {
                    if nsd.name.eq(fname) {
                        found = true
                        if nsd.is_mut.not() {
                            type_error(stmt, "cannot assign to immutable field '".concat(fname).concat("'"))
                        }
                        mut handled_lit2 := false
                        switch rhs.node_type {
                        case NodeType.LiteralNum(lit_str):
                            if is_numeric_type(nsd.til_type) {
                                if literal_in_range(lit_str, nsd.til_type).not() {
                                    type_error(rhs, "integer literal out of range for field '".concat(fname).concat("'"))
                                }
                                rhs.til_type = nsd.til_type.clone()
                                handled_lit2 = true
                            }
                        case:
                        }
                        if handled_lit2.not() {
                            rhs_type := rhs.til_type
                            if rhs_type.is(nsd.til_type).not() {
                                if rhs_type.is(TilType.Unknown).not() {
                                    if rhs_type.is(TilType.Dynamic).not() {
                                        type_error(stmt, "field '".concat(fname).concat("' type mismatch"))
                                    }
                                }
                            }
                        }
                        break
                    }
                }
            }
            if found.not() {
                type_error(stmt, "struct '".concat(obj_sname).concat("' has no field '").concat(fname).concat("'"))
            }
        }
    } else {
        type_error(stmt, "field assignment on non-struct value")
    }
    stmt.til_type = TilType.None
    if fa_own_type(stmt, scope).is(OwnType.Ref).not().and(
        rhs.node_type.is(NodeType.Ident).or(
            rhs.node_type.is(NodeType.FieldAccess).and(
                rhs.til_type.is(TilType.Struct).or(
                    rhs.til_type.is(TilType.Enum)
                )
            )
        )
    ) {
        tname := type_to_name(rhs.til_type)
        if tname.len().gt(0) {
            mc := make_clone_call(tname, rhs.til_type, rhs, rhs)
            stmt.children.set(1, own mc)
        }
    }
}

infer_while_stmt := proc(scope: TypeScope, mut stmt: Expr, shallow in_func: I32, shallow returns_ref: I32, ctx: Context) {
    infer_expr(scope, stmt.child(0), in_func, ctx)
    if stmt.child(0).til_type.is(TilType.Bool).not().and(stmt.child(0).til_type.is(TilType.Unknown).not()) {
        type_error(stmt, "while condition must be Bool, got ".concat(type_to_name(stmt.child(0).til_type)))
    }
    if expr_contains_fcall(stmt.child(0)) {
        ref cond : Expr = stmt.child(0)
        line := cond.line
        col := cond.col
        ref body : Expr = stmt.child(1)
        wname := "_wcond_Bool_".concat(hoist_counter.to_str())
        hoist_counter++

        mut decl := Expr.new(NodeType.Decl(Declaration(name = wname.clone())), line, col)
        decl.til_type = TilType.Bool
        decl.add_child(own cond.clone())
        ref mut decl_rhs : Expr = decl.child(0)
        decl_rhs.til_type = TilType.Bool

        mut ident := Expr.new(NodeType.Ident(wname.clone()), line, col)
        ident.til_type = TilType.Bool

        mut if_node := Expr.new(NodeType.If, line, col)
        if_node.til_type = TilType.None
        if_node.add_child(own ident)

        mut then_body := Expr.new(NodeType.Body, line, col)
        then_body.til_type = TilType.None
        if_node.add_child(own then_body)

        mut else_body := Expr.new(NodeType.Body, line, col)
        else_body.til_type = TilType.None
        mut brk := Expr.new(NodeType.Break, line, col)
        brk.til_type = TilType.None
        else_body.add_child(own brk)
        if_node.add_child(own else_body)

        mut true_lit := Expr.new(NodeType.LiteralBool(true), line, col)
        true_lit.til_type = TilType.Bool
        stmt.children.set(0, own true_lit)

        mut old := Vec.new("Expr", Expr.size())
        old.move_from(body.children)

        mut new_ch := Vec.new("Expr", Expr.size())
        new_ch.push(own decl)
        new_ch.push(own if_node)
        for j in 0..old.len() {
            new_ch.push_take(old, j)
        }
        body.children.move_from(new_ch)
    }
    while_scope := TypeScope(parent = scope)
    infer_body(while_scope, stmt.child(1), in_func, 1, 1, returns_ref, 0, ctx)
    check_unused_locals(while_scope, typer_path)
    TypeScope.delete(own while_scope)
    stmt.til_type = TilType.None
}

infer_decl_type_def := proc(scope: TypeScope, mut stmt: Expr) returns shallow Bool {
    if is_struct_or_enum(stmt).not() { return false }
    is_enum := stmt.child(0).node_type.is(NodeType.EnumDef)
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        if sdecl.explicit_type.len().gt(0) {
            declared := type_from_name(sdecl.explicit_type, scope)
            mut expected := TilType.Struct("StructDef".clone())
            if is_enum { expected = TilType.Struct("EnumDef".clone()) }
            if declared.eq(expected).not() {
                mut value_type := "StructDef"
                if is_enum { value_type = "EnumDef" }
                type_error(stmt, "'".concat(sdecl.name).concat("' declared as ").concat(sdecl.explicit_type).concat(" but value is ").concat(value_type))
            }
        }
        stmt.til_type = TilType.None
        ref sname : Str = sdecl.name
        ref existing : TypeBinding = scope.get_binding(sname)
        if is_null(existing).not() {
            if is_null(existing.struct_def).not() {
                if existing.struct_def.line.neq(stmt.child(0).line).or(
                    existing.struct_def.col.neq(stmt.child(0).col).or(
                        existing.path.eq(typer_path).not()
                    )
                ) {
                    mut kind := "struct"
                    if is_enum { kind = "enum" }
                    type_error(stmt, kind.concat(" '").concat(sname).concat("' already declared at ")
                        .concat(existing.path).concat(":").concat(existing.line.to_str()).concat(":").concat(existing.col.to_str()))
                    return true
                }
            }
        }
        mut builtin_type := TilType.Struct(sname.clone())
        mut is_builtin := false
        if is_enum { builtin_type = TilType.Enum(sname.clone()) }
        if sname.eq("I64") { builtin_type = TilType.I64; is_builtin = true }
        else if sname.eq("U8") { builtin_type = TilType.U8; is_builtin = true }
        else if sname.eq("I16") { builtin_type = TilType.I16; is_builtin = true }
        else if sname.eq("I32") { builtin_type = TilType.I32; is_builtin = true }
        else if sname.eq("U32") { builtin_type = TilType.U32; is_builtin = true }
        else if sname.eq("U64") { builtin_type = TilType.U64; is_builtin = true }
        else if sname.eq("F32") { builtin_type = TilType.F32; is_builtin = true }
        else if sname.eq("Str") { is_builtin = false }
        else if sname.eq("Bool") { builtin_type = TilType.Bool; is_builtin = true }
        else if sname.eq("StructDef") { is_builtin = false }
        else if sname.eq("FunctionDef") { is_builtin = false }
        else if sname.eq("Dynamic") { builtin_type = TilType.Dynamic; is_builtin = true }
        scope.set(sname, builtin_type, FuncType.None, false, typer_path, stmt.line, stmt.col, false, OwnType.Shallow)
        ref mut b : TypeBinding = scope.get_binding(sname)
        b.struct_def = stmt.child(0)
        b.is_builtin = is_builtin
        b.is_priv = sdecl.is_priv
        return true
    case:
        UNREACHABLE(__LOC__)
        return false
    }
}

infer_decl_func_def := proc(scope: TypeScope, mut stmt: Expr) returns shallow Bool {
    if is_func_decl(stmt).not() { return false }
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        if sdecl.explicit_type.len().gt(0).and(sdecl.explicit_type.eq("FunctionDef").not()) {
            type_error(stmt, "'".concat(sdecl.name).concat("' declared as ").concat(sdecl.explicit_type).concat(" but value is FunctionDef"))
        }
        switch stmt.child(0).node_type {
        case NodeType.FuncDef(fdef):
            mut rt := TilType.None
            if fdef.return_type.len().gt(0) {
                rt = type_from_name(fdef.return_type, scope)
            }
            stmt.til_type = rt
            scope.set(sdecl.name, rt, fdef.func_type, false, typer_path, stmt.line, stmt.col, false, OwnType.Shallow)
            ref mut fb : TypeBinding = scope.get_binding(sdecl.name)
            fb.func_def = stmt.child(0)
            fb.is_priv = sdecl.is_priv
            if fdef.func_type.is(FuncType.ExtFunc).or(fdef.func_type.is(FuncType.ExtProc)) {
                fb.is_builtin = true
            }
            return true
        case:
            UNREACHABLE(__LOC__)
            return false
        }
    case:
        UNREACHABLE(__LOC__)
        return false
    }
}

infer_decl_type_alias_passthrough := func(scope: TypeScope, mut stmt: Expr) returns shallow Bool {
    if stmt.child(0).node_type.is(NodeType.Ident).not() { return false }
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        ref alias_b : TypeBinding = scope.get_binding(sdecl.name)
        if is_null(alias_b).not() {
            if alias_b.is_type_alias {
                stmt.til_type = TilType.None
                return true
            }
        }
        return false
    case:
        UNREACHABLE(__LOC__)
        return false
    }
}

infer_decl_typed_value := proc(scope: TypeScope, mut stmt: Expr) {
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        mut declared := stmt.til_type
        switch declared {
        case TilType.Unknown:
            declared = type_from_name(sdecl.explicit_type, scope)
        case TilType.Custom(cname):
            declared = type_from_name(cname, scope)
        case:
        }
        ref mut val : Expr = stmt.child(0)
        if declared.is(TilType.Unknown) {
            type_error(stmt, "undefined type '".concat(sdecl.explicit_type).concat("'"))
        } else if val.node_type.is(NodeType.LiteralNum).and(is_numeric_type(declared).or(declared.is(TilType.Dynamic))) {
            switch val.node_type {
            case NodeType.LiteralNum(lit_str):
                if is_numeric_type(declared).and(literal_in_range(lit_str, declared).not()) {
                    type_error(val, "integer literal ".concat(lit_str).concat(" out of range for ").concat(type_to_name(declared)))
                }
            case:
            }
            val.til_type = declared
        } else if val.node_type.is(NodeType.LiteralNull).and(sdecl.own_type.is(OwnType.Ref).not()) {
            type_error(stmt, "null can only be assigned to 'ref' declarations")
        } else if can_implicit_usize_coerce(val.til_type, declared, sdecl.explicit_type).not()
        .and(val.til_type.is(declared).not())
        .and(val.til_type.is(TilType.Dynamic).not())
    .and(declared.is(TilType.Dynamic).not()) {
        type_error(stmt, "'".concat(sdecl.name).concat("' declared as ").concat(type_to_name(declared))
            .concat(" but value is ").concat(type_to_name(val.til_type)))
    } else if declared.is(TilType.Struct).or(declared.is(TilType.Enum)) {
        val_sname := til_type_name(val.til_type)
        if val_sname.len().gt(0).and(resolve_type_alias(scope, sdecl.explicit_type).eq(val_sname).not()) {
            type_error(stmt, "'".concat(sdecl.name).concat("' declared as ").concat(sdecl.explicit_type)
                .concat(" but value is ").concat(val_sname))
        }
    }
    // Resolve type alias in declared til_type so that struct/enum names match
    // the canonical target (e.g. Point2 -> Point).
    if declared.is(TilType.Struct).or(declared.is(TilType.Enum)) {
        ref _resolved : Str = resolve_type_alias(scope, sdecl.explicit_type)
        if declared.is(TilType.Struct) {
            declared = TilType.Struct(_resolved.clone())
        } else {
            declared = TilType.Enum(_resolved.clone())
        }
    }
    stmt.til_type = declared
    if can_implicit_usize_coerce(val.til_type, declared, sdecl.explicit_type) {
        val.til_type = declared
    }
    narrow_dynamic(val, declared)
        if declared.is(TilType.Struct).or(declared.is(TilType.Enum)) {
            if til_type_name(val.til_type).len().gt(0) {
                ref resolved : Str = resolve_type_alias(scope, sdecl.explicit_type)
                if declared.is(TilType.Struct) {
                    val.til_type = TilType.Struct(resolved.clone())
                } else {
                    val.til_type = TilType.Enum(resolved.clone())
                }
            }
        }
    case:
        UNREACHABLE(__LOC__)
    }
}

infer_decl_untyped_value := proc(mut stmt: Expr) {
    stmt.til_type = stmt.child(0).til_type
    if stmt.til_type.is(TilType.Dynamic) {
        switch stmt.node_type {
        case NodeType.Decl(sdecl):
            type_error(stmt, "cannot store Dynamic in '".concat(sdecl.name)
                .concat("'; add a type annotation like '").concat(sdecl.name).concat(" : Type = ...' to specify the concrete type"))
        case:
            UNREACHABLE(__LOC__)
        }
    }
}

finalize_decl_binding := proc(scope: TypeScope, mut stmt: Expr, shallow in_type_body: I32) {
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        ref mut rhs : Expr = stmt.child(0)
        if in_type_body.eq(0).and(sdecl.own_type.is(OwnType.Own)) {
            if sdecl.is_mut {
                type_error(stmt, "no need for 'own' on mutable local '".concat(sdecl.name).concat("'; write 'mut ").concat(sdecl.name).concat(" := ...'"))
            } else {
                type_error(stmt, "no need for 'own' on local '".concat(sdecl.name).concat("'; locals are owned by default"))
            }
        }
        scope.set(sdecl.name, stmt.til_type, FuncType.None, sdecl.is_mut, typer_path, stmt.line, stmt.col, false, OwnType.Shallow)
        ref mut decl_b : TypeBinding = scope.get_binding(sdecl.name)
        decl_b.is_priv = sdecl.is_priv
        if stmt.til_type.is(TilType.FuncPtr) {
            switch rhs.node_type {
            case NodeType.Ident(rhs_id):
                ref src : TypeBinding = scope.get_binding(rhs_id)
                if is_null(src).not() {
                    if is_null(src.func_def).not() { decl_b.func_def = src.func_def }
                }
            case NodeType.FCall:
                ref rfc_sig : Expr = resolve_fn_sig(rhs, scope)
                if is_null(rfc_sig).not() {
                    decl_b.func_def = rfc_sig
                }
            case:
            }
            if is_null(decl_b.func_def) {
                if sdecl.explicit_type.len().gt(0) {
                    ref fsb : TypeBinding = scope.get_binding(sdecl.explicit_type)
                    if is_null(fsb).not() {
                        if is_null(fsb.func_def).not() {
                            if fsb.func_def.children.len().eq(0) {
                                decl_b.func_def = fsb.func_def
                            }
                        }
                    }
                }
            }
        }
        if sdecl.own_type.is(OwnType.Ref) {
            decl_b.own_type = OwnType.Ref
            if expr_is_ref_decl_source(rhs, scope).not() {
                type_error(stmt, "'ref' declaration requires null, a ref-returning function, or ref/param variable")
            }
            if sdecl.is_mut {
                switch rhs.node_type {
                case NodeType.Ident(_rid):
                    ref _rb : TypeBinding = scope.get_binding(_rid)
                    if is_null(_rb).not().and(_rb.is_mut.not()) {
                        type_error(stmt, "'ref mut' cannot bind to an immutable source; declare the source as 'mut' or 'ref mut'")
                    }
                case:
                }
            }
        }
        if sdecl.own_type.is(OwnType.Ref).not().and(rhs.node_type.is(NodeType.FCall)).and(fcall_returns_ref(rhs, scope).neq(0)) {
            type_error(stmt, "cannot own result of ref-returning function; use 'ref' or Type.clone()")
        }
        if sdecl.own_type.is(OwnType.Ref).not().and(sdecl.is_mut.not()).and(stmt.til_type.is(TilType.FuncPtr).not()) {
            switch rhs.node_type {
            case NodeType.Ident(rhs_id2):
                ref rb : TypeBinding = scope.get_binding(rhs_id2)
                if is_null(rb).not() {
                    if rb.is_mut.not().and(rb.own_type.is(OwnType.Own).not()).and(rb.own_type.is(OwnType.Ref).not().or(rb.is_alias)).and(rb.is_param.not()) {
                        sdecl.own_type = OwnType.Ref
                        decl_b.own_type = OwnType.Ref
                        decl_b.is_alias = true
                    }
                }
            case:
            }
        }
        if rhs.node_type.is(NodeType.Ident).or(
            rhs.node_type.is(NodeType.FieldAccess).and(
                rhs.til_type.is(TilType.Struct).or(rhs.til_type.is(TilType.Enum))
            )
        ) {
            if sdecl.own_type.is(OwnType.Ref).not() {
                tname := type_to_name(stmt.til_type)
                if tname.len().gt(0) {
                    mc := make_clone_call(tname, stmt.til_type, rhs, stmt)
                    stmt.children.set(0, own mc)
                }
            }
        }
    case:
        UNREACHABLE(__LOC__)
    }
}

infer_decl_stmt := proc(scope: TypeScope, mut stmt: Expr, shallow in_func: I32, shallow in_type_body: I32, ctx: Context) {
    if stmt.children.len().eq(0) { return }
    if stmt.child(0).node_type.is(NodeType.StructDef).or(stmt.child(0).node_type.is(NodeType.EnumDef)) {
        switch stmt.node_type {
        case NodeType.Decl(td_decl):
            saved_type_name := current_type_name.clone()
            current_type_name = td_decl.name.clone()
            infer_expr(scope, stmt.child(0), in_func, ctx)
            current_type_name = saved_type_name
        case:
            UNREACHABLE(__LOC__)
        }
    } else {
        infer_expr(scope, stmt.child(0), in_func, ctx)
    }
    if infer_decl_type_def(scope, stmt) { return }
    if infer_decl_func_def(scope, stmt) { return }
    if infer_decl_type_alias_passthrough(scope, stmt) { return }
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        if sdecl.explicit_type.len().gt(0) {
            infer_decl_typed_value(scope, stmt)
        } else {
            infer_decl_untyped_value(stmt)
        }
    case:
        UNREACHABLE(__LOC__)
    }
    check_ref_decl_owned_init(stmt, scope)
    check_ref_local_null_init(stmt)
    finalize_decl_binding(scope, stmt, in_type_body)
}

mark_switch_case_covered_variant := func(switch_enum_def: Expr, mut covered_variants: Vec, shallow n_variants: I32, sw_expr: Expr, match_expr: Expr) {
    if is_null(switch_enum_def).or(covered_variants.len().eq(0)) { return }
    mut covered_variant_name := ""
    switch match_expr.node_type {
    case NodeType.FieldAccess(field_name):
        if match_expr.children.len().gt(0) {
            switch match_expr.child(0).node_type {
            case NodeType.Ident(base_name):
                if base_name.eq(til_type_name(sw_expr.til_type)) {
                    covered_variant_name = field_name.clone()
                }
            case:
            }
        }
    case:
    }
    if covered_variant_name.len().eq(0) {
        if match_expr.node_type.is(NodeType.FCall) {
            if match_expr.children.len().eq(2) {
                if match_expr.child(0).node_type.is(NodeType.FieldAccess) {
                    if match_expr.child(0).children.len().gt(0) {
                        if match_expr.child(0).child(0).node_type.is(NodeType.Ident).and(match_expr.child(1).node_type.is(NodeType.Ident)) {
                            switch match_expr.child(0).child(0).node_type {
                            case NodeType.Ident(type_name):
                                if type_name.eq(til_type_name(sw_expr.til_type)) {
                                    switch match_expr.child(0).node_type {
                                    case NodeType.FieldAccess(field_name):
                                        covered_variant_name = field_name.clone()
                                    case:
                                    }
                                }
                            case:
                            }
                        }
                    }
                }
            }
        }
    }
    if covered_variant_name.len().eq(0) { return }
    covered_tag := enum_variant_tag(switch_enum_def, covered_variant_name)
    if covered_tag.gte(0.to_i32()).and(covered_tag.lt(n_variants)) {
        ref mut covered : Bool = covered_variants.get(covered_tag.to_i64().to_u32())
        covered = true
    }
}

is_simple_lvalue_expr := func(e: Expr) returns shallow Bool {
    if e.node_type.is(NodeType.Ident) { return true }
    if e.node_type.is(NodeType.FieldAccess) {
        if e.children.len().eq(1) {
            return is_simple_lvalue_expr(e.child(0))
        }
    }
    return false
}

make_switch_case_condition := func(scope: TypeScope, mut case_body: Expr, match_expr: Expr, sw_ref: Expr, shallow sw_line: U32, shallow sw_col: U32) returns Expr {
    mut condition := Expr.new(NodeType.Body, sw_line, sw_col)
    mut has_condition := false
    if match_expr.node_type.is(NodeType.FCall) {
        if match_expr.children.len().eq(3) {
            switch match_expr.child(0).node_type {
            case NodeType.FieldAccess(method_name):
                if method_name.eq("new") {
                    if match_expr.child(0).children.len().gt(0) {
                        switch match_expr.child(0).child(0).node_type {
                        case NodeType.Ident(range_name):
                            if range_name.eq("Range") {
                                ref start_expr : Expr = match_expr.child(1)
                                ref end_expr : Expr = match_expr.child(2)

                                mut sw1 := sw_ref.clone()
                                mut gte_acc := Expr.new(NodeType.FieldAccess("gte"), sw_line, sw_col)
                                gte_acc.add_child(own sw1)
                                mut gte_call := Expr.new(NodeType.FCall(FCallData()), sw_line, sw_col)
                                gte_call.add_child(own gte_acc)
                                gte_call.add_child(own start_expr.clone())

                                mut sw2 := sw_ref.clone()
                                mut lte_acc := Expr.new(NodeType.FieldAccess("lte"), sw_line, sw_col)
                                lte_acc.add_child(own sw2)
                                mut lte_call := Expr.new(NodeType.FCall(FCallData()), sw_line, sw_col)
                                lte_call.add_child(own lte_acc)
                                lte_call.add_child(own end_expr.clone())

                                mut and_acc := Expr.new(NodeType.FieldAccess("and"), sw_line, sw_col)
                                and_acc.add_child(own gte_call)
                                condition = Expr.new(NodeType.FCall(FCallData()), sw_line, sw_col)
                                condition.add_child(own and_acc)
                                condition.add_child(own lte_call)
                                has_condition = true
                            }
                        case:
                        }
                    }
                }
            case:
            }
        }
    }

    if has_condition.not() {
        if match_expr.node_type.is(NodeType.FCall) {
            if match_expr.children.len().eq(2) {
                if match_expr.child(0).node_type.is(NodeType.FieldAccess) {
                    if match_expr.child(0).children.len().gt(0) {
                        if match_expr.child(0).child(0).node_type.is(NodeType.Ident) {
                            if match_expr.child(1).node_type.is(NodeType.Ident) {
                                ref callee : Expr = match_expr.child(0)
                                mut type_name := ""
                                mut variant_name := ""
                                mut binding_name := ""
                                switch callee.child(0).node_type {
                                case NodeType.Ident(tn):
                                    type_name = tn.clone()
                                case:
                                }
                                switch callee.node_type {
                                case NodeType.FieldAccess(vn):
                                    variant_name = vn.clone()
                                case:
                                }
                                switch match_expr.child(1).node_type {
                                case NodeType.Ident(bn):
                                    binding_name = bn.clone()
                                case:
                                }
                                ref enum_def : Expr = scope.get_struct(type_name)
                                if is_null(enum_def).not().and(enum_def.node_type.is(NodeType.EnumDef)) {
                                    vt_tag := enum_variant_tag(enum_def, variant_name)
                                    mut payload_type := ""
                                    if vt_tag.gte(0.to_i32()) {
                                        payload_type = enum_variant_type(enum_def, vt_tag)
                                    }
                                    if payload_type.len().gt(0) {
                                        mut iv_id := Expr.new(NodeType.Ident("is"), sw_line, sw_col)
                                        mut sw_id := sw_ref.clone()
                                        mut vtype_id := Expr.new(NodeType.Ident(type_name.clone()), sw_line, sw_col)
                                        mut vref := Expr.new(NodeType.FieldAccess(variant_name.clone()), sw_line, sw_col)
                                        vref.add_child(own vtype_id)
                                        condition = Expr.new(NodeType.FCall(FCallData()), sw_line, sw_col)
                                        condition.add_child(own iv_id)
                                        condition.add_child(own sw_id)
                                        condition.add_child(own vref)

                                        mut gp_ident := Expr.new(NodeType.Ident("get_payload"), sw_line, sw_col)
                                        mut sw_id2 := sw_ref.clone()
                                        mut get_call := Expr.new(NodeType.FCall(FCallData()), sw_line, sw_col)
                                        get_call.add_child(own gp_ident)
                                        get_call.add_child(own sw_id2)

                                        mut bind_decl := Expr.new(NodeType.Decl(Declaration(name = binding_name.clone(), explicit_type = payload_type.clone(), til_type = til_type_from_explicit_type(payload_type), own_type = OwnType.Ref)), sw_line, sw_col)
                                        bind_decl.add_child(own get_call)

                                        mut old := Vec.new("Expr", Expr.size())
                                        old.move_from(case_body.children)

                                        mut new_ch := Vec.new("Expr", Expr.size())
                                        new_ch.push(own bind_decl)
                                        for bi in 0..old.len() {
                                            new_ch.push_take(old, bi)
                                        }
                                    case_body.children.move_from(new_ch)
                                        has_condition = true
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    if has_condition.not() {
        if match_expr.node_type.is(NodeType.FieldAccess) {
            if match_expr.children.len().gt(0) {
                if match_expr.child(0).node_type.is(NodeType.Ident) {
                    mut type_name := ""
                    mut variant_name := ""
                    switch match_expr.child(0).node_type {
                    case NodeType.Ident(tn):
                        type_name = tn.clone()
                    case:
                    }
                    switch match_expr.node_type {
                    case NodeType.FieldAccess(vn):
                        variant_name = vn.clone()
                    case:
                    }
                    ref enum_def : Expr = scope.get_struct(type_name)
                    if is_null(enum_def).not().and(enum_def.node_type.is(NodeType.EnumDef)) {
                        vt_tag2 := enum_variant_tag(enum_def, variant_name)
                        mut payload_type := ""
                        if vt_tag2.gte(0.to_i32()) {
                            payload_type = enum_variant_type(enum_def, vt_tag2)
                        }
                        if payload_type.len().gt(0) {
                            mut iv_id := Expr.new(NodeType.Ident("is"), sw_line, sw_col)
                            mut sw_id := sw_ref.clone()
                            mut vtype_id := Expr.new(NodeType.Ident(type_name.clone()), sw_line, sw_col)
                            mut vref := Expr.new(NodeType.FieldAccess(variant_name.clone()), sw_line, sw_col)
                            vref.add_child(own vtype_id)
                            condition = Expr.new(NodeType.FCall(FCallData()), sw_line, sw_col)
                            condition.add_child(own iv_id)
                            condition.add_child(own sw_id)
                            condition.add_child(own vref)
                            has_condition = true
                        }
                    }
                }
            }
        }
    }

    if has_condition.not() {
        mut sw_ident := sw_ref.clone()
        mut eq_access := Expr.new(NodeType.FieldAccess("eq"), sw_line, sw_col)
        eq_access.add_child(own sw_ident)
        condition = Expr.new(NodeType.FCall(FCallData()), sw_line, sw_col)
        condition.add_child(own eq_access)
        condition.add_child(own match_expr.clone())
    }
    return condition
}

replace_switch_stmt_with_block := func(mut body: Expr, shallow stmt_idx: U32, mut block: Expr) {
    body.children.set(stmt_idx, own block.clone())
}

append_switch_else_if := proc(mut root_if: Expr, if_node: Expr) {
    if root_if.children.len().gt(2) {
        ref mut else_body : Expr = root_if.child(2)
        if else_body.children.len().gt(0) {
            if else_body.child(0).node_type.is(NodeType.If) {
                append_switch_else_if(else_body.child(0), if_node)
                return
            }
        }
    }
    mut else_body := Expr.new(NodeType.Body, if_node.line, if_node.col)
    else_body.add_child(own if_node.clone())
    root_if.add_child(own else_body)
}

attach_switch_default_body := proc(mut root_if: Expr, default_body: Expr) {
    if root_if.children.len().gt(2) {
        ref mut else_body : Expr = root_if.child(2)
        if else_body.children.len().gt(0) {
            if else_body.child(0).node_type.is(NodeType.If) {
                attach_switch_default_body(else_body.child(0), default_body)
                return
            }
        }
    }
    root_if.add_child(own default_body.clone())
}

infer_switch_stmt := proc(scope: TypeScope, mut body: Expr, shallow stmt_idx: U32, shallow in_func: I32, ctx: Context) {
    ref mut stmt : Expr = body.child(stmt_idx)
    ref mut sw_expr : Expr = stmt.child(0)
    sw_line := stmt.line
    sw_col := stmt.col
    infer_expr(scope, sw_expr, in_func, ctx)
    mut covered_variants := Vec.new("Bool", Bool.size())
    mut n_variants : I32 = 0
    mut has_default_case := false
    mut has_switch_enum_def := false
    sw_expr_sname := til_type_name(sw_expr.til_type)
    ref switch_enum_def : Expr = scope.get_struct(sw_expr_sname)
    if sw_expr.til_type.is(TilType.Enum).and(sw_expr_sname.len().gt(0)) {
        if is_null(switch_enum_def).not() {
            switch switch_enum_def.node_type {
            case NodeType.EnumDef(sw_edd):
                has_switch_enum_def = true
                n_variants = sw_edd.variants.len().to_i64().to_i32()
                for _ in 0..n_variants.to_i64().to_usize() {
                    covered_variants.push(own false)
                }
            case:
            }
        }
    }

    mut sw_ref := Expr.new(NodeType.LiteralNull, sw_line, sw_col)
    mut block := Expr.new(NodeType.Body, stmt.line, stmt.col)
    if is_simple_lvalue_expr(sw_expr) {
        sw_ref = sw_expr.clone()
    } else {
        tp := type_prefix(sw_expr.til_type)
        sw_name := "_sw_".concat(tp).concat("_").concat(hoist_counter.to_str())
        hoist_counter++
        mut decl := Expr.new(NodeType.Decl(Declaration(name = sw_name.clone())), stmt.line, stmt.col)
        decl.add_child(own sw_expr.clone())
        block.add_child(own decl)
        sw_ref = Expr.new(NodeType.Ident(sw_name.clone()), sw_line, sw_col)
    }

    mut first_if := Expr.new(NodeType.Body, stmt.line, stmt.col)
    mut has_first_if := false
    mut default_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
    mut has_default_body := false

    for ci in 1..stmt.children.len() {
        ref case_node : Expr = stmt.child(ci)
        if case_node.children.len().eq(1) {
            default_body = case_node.child(0).clone()
            has_default_body = true
            has_default_case = true
            continue
        }
        ref mut match_expr : Expr = case_node.child(0)
        ref mut case_body : Expr = case_node.child(1)
        if has_switch_enum_def {
            ref switch_enum_def : Expr = scope.get_struct(sw_expr_sname)
            mark_switch_case_covered_variant(switch_enum_def, covered_variants, n_variants, sw_expr, match_expr)
        }
        condition := make_switch_case_condition(scope, case_body, match_expr, sw_ref, sw_line, sw_col)

        mut if_node := Expr.new(NodeType.If, case_node.line, case_node.col)
        if_node.add_child(own condition)
        if_node.add_child(own case_body.clone())

        if has_first_if.not() {
            first_if = if_node
            has_first_if = true
        } else {
            append_switch_else_if(first_if, if_node)
        }
    }

    if has_default_body.and(has_first_if) {
        attach_switch_default_body(first_if, default_body)
    } else if has_default_body.and(has_first_if.not()) {
        first_if = default_body.clone()
        has_first_if = true
    }

    if has_switch_enum_def.and(covered_variants.len().gt(0)).and(has_default_case.not()) {
        ref switch_enum_def : Expr = scope.get_struct(sw_expr_sname)
        mut msg := "non-exhaustive switch on enum '".concat(sw_expr_sname).concat("'; missing cases:")
        switch switch_enum_def.node_type {
        case NodeType.EnumDef(mc_edd):
            mut missing := false
            for vi in 0..n_variants.to_i64().to_usize() {
                ref covered : Bool = covered_variants.get(vi.to_i64().to_u32())
                if covered.not() {
                    missing = true
                    ref vn : Str = mc_edd.variants.get(vi)
                    if msg.ends_with(":").not() { msg = msg.concat(",") }
                    msg = msg.concat(" ").concat(vn)
                }
            }
            if missing { type_error(stmt, msg) }
        case:
            UNREACHABLE(__LOC__)
        }
    }

    if has_first_if { block.add_child(own first_if.clone()) }
    replace_switch_stmt_with_block(body, stmt_idx, block)
}

replace_body_stmt_with_block := func(mut body: Expr, shallow stmt_idx: U32, mut block: Expr) {
    body.children.set(stmt_idx, own block.clone())
}

make_field_access_call0 := func(base: Expr, field: Str, shallow line: U32, shallow col: U32) returns Expr {
    mut fa := Expr.new(NodeType.FieldAccess(field.clone()), line, col)
    fa.add_child(own base.clone())
    mut fc := Expr.new(NodeType.FCall(FCallData()), line, col)
    fc.add_child(own fa)
    return fc
}

make_field_access_call1 := func(base: Expr, field: Str, arg: Expr, shallow line: U32, shallow col: U32) returns Expr {
    mut fa := Expr.new(NodeType.FieldAccess(field.clone()), line, col)
    fa.add_child(own base.clone())
    mut fc := Expr.new(NodeType.FCall(FCallData()), line, col)
    fc.add_child(own fa)
    fc.add_child(own arg.clone())
    return fc
}

make_for_in_range_while_body := func(var_name: Str, cur_name: Str, step: Str, for_body: Expr, shallow line: U32, shallow col: U32, elem_type: Str, shallow var_is_mut: Bool) returns Expr {
    mut wb := Expr.new(NodeType.Body, line, col)

    mut vd := Expr.new(NodeType.Decl(Declaration(name = var_name.clone(), explicit_type = elem_type.clone(), til_type = til_type_from_explicit_type(elem_type), is_mut = var_is_mut)), line, col)
    mut cur_ident := Expr.new(NodeType.Ident(cur_name.clone()), line, col)
    vd.add_child(own cur_ident)
    wb.add_child(own vd)

    mut step_ident := Expr.new(NodeType.Ident(cur_name.clone()), line, col)
    wb.add_child(own make_field_access_call0(step_ident, step, line, col))

    for e_bi : Expr in for_body.children {
        wb.add_child(own e_bi.clone())
    }
    return wb
}

desugar_for_in_range_stmt := proc(scope: TypeScope, mut body: Expr, shallow stmt_idx: U32, shallow in_func: I32, ctx: Context) returns shallow Bool {
    ref mut stmt : Expr = body.child(stmt_idx)
    ref mut iter : Expr = stmt.child(0)
    if iter.node_type.is(NodeType.FCall).not() { return false }
    if iter.children.len().neq(3) { return false }
    ref callee : Expr = iter.child(0)
    switch callee.node_type {
    case NodeType.FieldAccess(callee_field):
        if callee_field.eq("new").not() { return false }
    case:
        return false
    }
    if callee.children.len().eq(0) { return false }
    ref callee_base : Expr = callee.child(0)
    switch callee_base.node_type {
    case NodeType.Ident(callee_name):
        if callee_name.eq("Range").not() { return false }
    case:
        return false
    }

    ref mut start_expr : Expr = iter.child(1)
    ref mut end_expr : Expr = iter.child(2)
    infer_expr(scope, start_expr, in_func, ctx)
    infer_expr(scope, end_expr, in_func, ctx)

    mut elem_type := til_type_name(stmt.til_type)
    if elem_type.len().eq(0) {
        mut type_src := start_expr
        if start_expr.node_type.is(NodeType.LiteralNum).and(end_expr.node_type.is(NodeType.LiteralNum).not()) {
            type_src = end_expr
        } else if end_expr.node_type.is(NodeType.LiteralNum).and(start_expr.node_type.is(NodeType.LiteralNum).not()) {
            type_src = start_expr
        }
        if type_src.til_type.is(TilType.Struct).or(type_src.til_type.is(TilType.Enum)) {
            ts_sname := til_type_name(type_src.til_type)
            if ts_sname.len().gt(0) {
                elem_type = ts_sname
            } else {
                elem_type = type_to_name(type_src.til_type)
            }
        } else {
            elem_type = type_to_name(type_src.til_type)
        }
    }

    mut var_name := ""
    mut forin_is_mut := false
    switch stmt.node_type {
    case NodeType.ForIn(forin_data_r):
        var_name = forin_data_r.name.clone()
        forin_is_mut = forin_data_r.is_mut
    case:
        UNREACHABLE(__LOC__)
        return false
    }
    ref for_body : Expr = stmt.child(1)
    line := stmt.line
    col := stmt.col
    counter := hoist_counter
    hoist_counter++

    end_name := "_re_".concat(elem_type).concat("_").concat(counter.to_str())
    cur_name := "_rc_".concat(elem_type).concat("_").concat(counter.to_str())

    mut block := Expr.new(NodeType.Body, line, col)

    mut end_decl := Expr.new(NodeType.Decl(Declaration(name = end_name.clone(), explicit_type = elem_type.clone(), til_type = til_type_from_explicit_type(elem_type))), line, col)
    end_decl.add_child(own end_expr.clone())
    block.add_child(own end_decl)

    mut cur_decl := Expr.new(NodeType.Decl(Declaration(name = cur_name.clone(), explicit_type = elem_type.clone(), til_type = til_type_from_explicit_type(elem_type), is_mut = true)), line, col)
    cur_decl.add_child(own start_expr.clone())
    block.add_child(own cur_decl)

    mut cur_ident_lt := Expr.new(NodeType.Ident(cur_name.clone()), line, col)
    mut end_ident_lt := Expr.new(NodeType.Ident(end_name.clone()), line, col)
    mut asc_while := Expr.new(NodeType.While, line, col)
    asc_while.add_child(own make_field_access_call1(cur_ident_lt, "lt", end_ident_lt, line, col))
    asc_while.add_child(own make_for_in_range_while_body(var_name, cur_name, "inc", for_body, line, col, elem_type, forin_is_mut))

    mut cur_ident_gt := Expr.new(NodeType.Ident(cur_name.clone()), line, col)
    mut end_ident_gt := Expr.new(NodeType.Ident(end_name.clone()), line, col)
    mut desc_while := Expr.new(NodeType.While, line, col)
    desc_while.add_child(own make_field_access_call1(cur_ident_gt, "gt", end_ident_gt, line, col))
    desc_while.add_child(own make_for_in_range_while_body(var_name, cur_name, "dec", for_body, line, col, elem_type, forin_is_mut))

    mut if_node := Expr.new(NodeType.If, line, col)
    mut cur_ident_lte := Expr.new(NodeType.Ident(cur_name.clone()), line, col)
    mut end_ident_lte := Expr.new(NodeType.Ident(end_name.clone()), line, col)
    if_node.add_child(own make_field_access_call1(cur_ident_lte, "lte", end_ident_lte, line, col))

    mut then_body := Expr.new(NodeType.Body, line, col)
    then_body.add_child(own asc_while)
    if_node.add_child(own then_body)

    mut else_body := Expr.new(NodeType.Body, line, col)
    else_body.add_child(own desc_while)
    if_node.add_child(own else_body)
    block.add_child(own if_node)

    replace_body_stmt_with_block(body, stmt_idx, block)
    return true
}

desugar_for_in_collection_stmt := proc(scope: TypeScope, mut body: Expr, shallow stmt_idx: U32, shallow in_func: I32, ctx: Context) returns shallow Bool {
    ref mut stmt : Expr = body.child(stmt_idx)
    ref mut iter : Expr = stmt.child(0)

    infer_expr(scope, iter, in_func, ctx)

    mut type_name := ""
    if iter.til_type.is(TilType.Struct).or(iter.til_type.is(TilType.Enum)) {
        iter_sname := til_type_name(iter.til_type)
        if iter_sname.len().gt(0) {
            type_name = iter_sname
        }
    }
    if type_name.len().eq(0) {
        type_error(stmt, "for-in requires a collection type with get() and len() methods")
        return false
    }

    ref sdef : Expr = scope.get_struct(type_name)
    if is_null(sdef) {
        type_error(stmt, "for-in requires a collection type with get() and len() methods")
        return false
    }

    ref len_func : Expr = find_namespace_func(sdef, "len")
    ref get_func : Expr = find_namespace_func(sdef, "get")

    if is_null(len_func) {
        type_error(stmt, "type '".concat(type_name).concat("' has no 'len' method (required for for-in)"))
        return false
    }
    mut idx_type := ""
    switch len_func.node_type {
    case NodeType.FuncDef(len_def):
        if len_def.params.len().neq(1).or(len_def.return_type.len().eq(0)) {
            type_error(stmt, "type '".concat(type_name).concat("' len() must take 1 param and return a scalar for for-in"))
            return false
        }
        idx_type = len_def.return_type.clone()
    case:
        UNREACHABLE(__LOC__)
        return false
    }

    if is_null(get_func) {
        type_error(stmt, "type '".concat(type_name).concat("' has no 'get' method (required for for-in)"))
        return false
    }
    mut elem_type := til_type_name(stmt.til_type)
    mut get_returns_ref := false
    switch get_func.node_type {
    case NodeType.FuncDef(get_def):
        if get_def.params.len().neq(2) {
            type_error(stmt, "type '".concat(type_name).concat("' get() second param must match len() return type for for-in"))
            return false
        }
        ref get_idx_param : Declaration = get_def.params.get(1.to_usize())
        if get_idx_param.explicit_type.len().eq(0).or(get_idx_param.explicit_type.eq(idx_type).not()) {
            type_error(stmt, "type '".concat(type_name).concat("' get() second param must match len() return type for for-in"))
            return false
        }
        if elem_type.len().eq(0) {
            if get_def.return_type.len().eq(0).or(get_def.return_type.eq("Dynamic")) {
                type_error(stmt, "cannot infer element type for '".concat(type_name).concat("', use explicit type: for x : Type in ..."))
                return false
            }
            elem_type = get_def.return_type.clone()
        }
        get_returns_ref = get_def.return_own_type.is(OwnType.Ref)
    case:
        UNREACHABLE(__LOC__)
        return false
    }

    mut var_name := ""
    mut forin_is_mut := false
    switch stmt.node_type {
    case NodeType.ForIn(forin_data_c):
        var_name = forin_data_c.name.clone()
        forin_is_mut = forin_data_c.is_mut
    case:
        UNREACHABLE(__LOC__)
        return false
    }
    ref for_body : Expr = stmt.child(1)
    line := stmt.line
    col := stmt.col

    counter := hoist_counter
    hoist_counter++
    col_name := "_fc_".concat(type_name).concat("_").concat(counter.to_str())
    idx_name := "_fi_USize_".concat(counter.to_str())

    mut block := Expr.new(NodeType.Body, line, col)

    // When iter is an lvalue (ident or field access), bind _fc as a ref to
    // alias the source instead of letting infer_decl_value insert a deep
    // .clone() that would dangle any refs taken out of the loop body.
    // For rvalues (literals, calls), keep the default Shallow so the result
    // gets stored as a value.
    mut col_own_type := OwnType.Shallow
    if iter.node_type.is(NodeType.Ident).or(iter.node_type.is(NodeType.FieldAccess)) {
        col_own_type = OwnType.Ref
    }
    mut col_decl := Expr.new(NodeType.Decl(Declaration(name = col_name.clone(), own_type = col_own_type)), line, col)
    col_decl.add_child(own iter.clone())
    block.add_child(own col_decl)

    mut idx_decl := Expr.new(NodeType.Decl(Declaration(name = idx_name.clone(), explicit_type = idx_type.clone(), til_type = til_type_from_explicit_type(idx_type), is_mut = true)), line, col)
    mut zero := Expr.new(NodeType.LiteralNum("0"), line, col)
    idx_decl.add_child(own zero)
    block.add_child(own idx_decl)

    mut while_node := Expr.new(NodeType.While, line, col)

    mut idx_ident_cond := Expr.new(NodeType.Ident(idx_name.clone()), line, col)
    mut col_ident_len := Expr.new(NodeType.Ident(col_name.clone()), line, col)
    len_call := make_field_access_call0(col_ident_len, "len", line, col)
    while_node.add_child(own make_field_access_call1(idx_ident_cond, "lt", len_call, line, col))

    mut wbody := Expr.new(NodeType.Body, line, col)

    mut forin_own := OwnType.Shallow
    if get_returns_ref { forin_own = OwnType.Ref }
    mut elem_decl := Expr.new(NodeType.Decl(Declaration(name = var_name.clone(), explicit_type = elem_type.clone(), til_type = til_type_from_explicit_type(elem_type), own_type = forin_own, is_mut = forin_is_mut)), line, col)
    mut col_ident_get := Expr.new(NodeType.Ident(col_name.clone()), line, col)
    mut idx_ident_get := Expr.new(NodeType.Ident(idx_name.clone()), line, col)
    elem_decl.add_child(own make_field_access_call1(col_ident_get, "get", idx_ident_get, line, col))
    wbody.add_child(own elem_decl)

    mut idx_assign := Expr.new(NodeType.Assign(AssignData(name = idx_name.clone())), line, col)
    mut idx_ident_inc := Expr.new(NodeType.Ident(idx_name.clone()), line, col)
    mut one := Expr.new(NodeType.LiteralNum("1"), line, col)
    idx_assign.add_child(own make_field_access_call1(idx_ident_inc, "add", one, line, col))
    wbody.add_child(own idx_assign)

    for e_bi : Expr in for_body.children {
        wbody.add_child(own e_bi.clone())
    }

    while_node.add_child(own wbody)
    block.add_child(own while_node)
    replace_body_stmt_with_block(body, stmt_idx, block)
    return true
}

is_compile_directive := func(e: Expr) returns shallow Bool {
    if e.node_type.is(NodeType.FCall).not() { return false }
    if e.children.len().lt(1) { return false }
    switch e.child(0).node_type {
    case NodeType.Ident(name):
        return name.eq("link").or(name.eq("link_c")).or(name.eq("import"))
    case:
        return false
    }
}

infer_body_stmt := proc(scope: TypeScope, mut body: Expr, mut i: U32, shallow in_func: I32, shallow in_loop: I32, shallow returns_ref: I32, shallow in_type_body: I32, ctx: Context) {
    ref mut stmt : Expr = body.child(i)
    if is_compile_directive(stmt) { stmt.til_type = TilType.None; return }
    switch stmt.node_type {
    case NodeType.Decl:
        infer_decl_stmt(scope, stmt, in_func, in_type_body, ctx)
    case NodeType.Assign:
        infer_assign_stmt(scope, stmt, in_func, ctx)
    case NodeType.FieldAssign:
        infer_field_assign_stmt(scope, stmt, in_func, ctx)
    case NodeType.FCall:
        infer_expr(scope, stmt, in_func, ctx)
    case NodeType.Return:
        infer_return_stmt(scope, stmt, in_func, returns_ref, ctx)
    case NodeType.Break:
        if in_loop.eq(0) {
            type_error(stmt, "break outside loop")
        }
        stmt.til_type = TilType.None
    case NodeType.Continue:
        if in_loop.eq(0) {
            type_error(stmt, "continue outside loop")
        }
        stmt.til_type = TilType.None
    case NodeType.If:
        infer_if_stmt(scope, stmt, in_func, in_loop, returns_ref, ctx)
    case NodeType.Body:
        block_scope := TypeScope(parent = scope)
        infer_body(block_scope, stmt, in_func, 1, in_loop, returns_ref, 0, ctx)
        check_unused_locals(block_scope, typer_path)
        TypeScope.delete(own block_scope)
    case NodeType.While:
        infer_while_stmt(scope, stmt, in_func, returns_ref, ctx)
    case NodeType.Switch:
        infer_switch_stmt(scope, body, i, in_func, ctx)
        i = i.sub(1)
    case NodeType.ForIn:
        if desugar_for_in_range_stmt(scope, body, i, in_func, ctx) {
            i = i.sub(1)
        } else if desugar_for_in_collection_stmt(scope, body, i, in_func, ctx) {
            i = i.sub(1)
        }
    case:
        stmt.til_type = TilType.None
    }
}

reregister_scope_defs := func(body: Expr, scope: TypeScope) {
    for rstmt : Expr in body.children {
        if rstmt.children.len().eq(0) { continue }
        switch rstmt.node_type {
        case NodeType.Decl(rdecl):
            ref mut rb : TypeBinding = scope.get_binding(rdecl.name)
            if is_null(rb).not() {
                if is_null(rb.struct_def).not().and(
                    rstmt.child(0).node_type.is(NodeType.StructDef).or(rstmt.child(0).node_type.is(NodeType.EnumDef))) {
                        ref old_sd : Expr = rb.struct_def
                        rb.struct_def = rstmt.child(0)
                        for bi in 0..scope.bindings.len() {
                            ref mut b : TypeBinding = Map.val_ptr(scope.bindings, bi)
                            if ptr_eq(b, rb).not().and(ptr_eq(b.struct_def, old_sd)) {
                                b.struct_def = rstmt.child(0)
                            }
                        }
                    }
                if is_null(rb.func_def).not().and(rstmt.child(0).node_type.is(NodeType.FuncDef)) {
                    ref old_fd : Expr = rb.func_def
                    rb.func_def = rstmt.child(0)
                    for bi in 0..scope.bindings.len() {
                        ref mut b : TypeBinding = Map.val_ptr(scope.bindings, bi)
                        if ptr_eq(b, rb).not().and(ptr_eq(b.func_def, old_fd)) {
                            b.func_def = rstmt.child(0)
                        }
                    }
                }
                if rb.alias_target.is_empty().not() {
                    switch rstmt.child(0).node_type {
                    case NodeType.Ident(target_name):
                        old_at := rb.alias_target.clone()
                        rb.alias_target = target_name.clone()
                        for bi in 0..scope.bindings.len() {
                            ref mut b : TypeBinding = Map.val_ptr(scope.bindings, bi)
                            if ptr_eq(b, rb).not().and(b.alias_target.eq(old_at)) {
                                b.alias_target = target_name.clone()
                            }
                        }
                    case:
                    }
                }
            }
        case:
        }
    }
    reregister_field_struct_defs(body, scope)
}

reregister_field_struct_defs := func(body: Expr, scope: TypeScope) {
    for rstmt : Expr in body.children {
        if rstmt.node_type.is(NodeType.Decl).and(rstmt.children.len().gt(0)) {
            ref sdef : Expr = rstmt.child(0)
            switch sdef.node_type {
            case NodeType.StructDef(sdd):
                for fd : Declaration in sdd.fields {
                    if is_null(fd.field_struct_def).not() {
                        ref ftype_name : Str = fd.explicit_type
                        if ftype_name.len().gt(0) {
                            ref new_fsd : Expr = scope.get_struct(ftype_name)
                            if is_null(new_fsd).not() {
                                fd.field_struct_def = new_fsd
                            }
                        }
                    }
                }
            case:
            }
        }
    }
}

infer_body := proc(scope: TypeScope, mut body: Expr, shallow in_func: I32, shallow owns_scope: I32, shallow in_loop: I32, shallow returns_ref: I32, shallow in_type_body: I32, ctx: Context) {
    body.til_type = TilType.None
    mut i := 0.to_u32()
    while i.lt(body.children.len().to_i64().to_u32()) {
        if is_null(scope.parent).and(in_func.eq(0)).and(in_type_body.eq(0)) {
            context_set_mode_from_path(ctx, typer_path)
        }
        infer_body_stmt(scope, body, i, in_func, in_loop, returns_ref, in_type_body, ctx)
        i++
    }
    if owns_scope.neq(0) { desugar_body(body, scope) }
    hoist_and_insert_field_deletes(body, scope, owns_scope)
    insert_free_calls(body, scope, owns_scope)
}

infer_body_unit := proc(scope: TypeScope, mut body: Expr, shallow in_func: I32, shallow owns_scope: I32, shallow in_loop: I32, shallow returns_ref: I32, shallow in_type_body: I32, ctx: Context) {
    body.til_type = TilType.None
    mut i := 0.to_u32()
    while i.lt(body.children.len().to_i64().to_u32()) {
        infer_body_stmt(scope, body, i, in_func, in_loop, returns_ref, in_type_body, ctx)
        i++
    }
    if owns_scope.neq(0) { desugar_body(body, scope) }
    hoist_and_insert_field_deletes(body, scope, owns_scope)
    insert_free_calls(body, scope, owns_scope)
}

// Type-check a single file unit. Caller must have registered a mode for path.
// #165 step 1: post-init normalization sweep.
//
// Initer's registration helpers store user-defined-type names as
// ~TilType.Custom(name)~ via the scope-free ~til_type_from_explicit_type~,
// so they don't have to read scope. This sweep -- run after every file's
// init has completed but before type_check -- walks the global bindings
// and replaces ~Custom(name)~ with ~Struct(name)~ or ~Enum(name)~ when
// the name resolves to a real struct/enum. Bindings whose type does
// not resolve are left as ~Custom~ and surface as undefined-symbol
// errors during type_check (same as today).
normalize_scope_bindings := func(scope: TypeScope) {
    for bi in 0..scope.bindings.len() {
        ref mut b : TypeBinding = Map.val_ptr(scope.bindings, bi)
        if b.type.is(TilType.Custom).not() { continue }
        ref name : Str = get_payload(b.type)
        ref sdef : Expr = scope.get_struct(name)
        if is_null(sdef) { continue }
        if sdef.node_type.is(NodeType.EnumDef) {
            b.type = TilType.Enum(name.clone())
        } else {
            b.type = TilType.Struct(name.clone())
        }
    }
}

type_check_unit := proc(path: Str, program: Expr, scope: TypeScope, ctx: Context) returns shallow I32 {
    errors = 0.to_i32()
    context_enter_file(ctx, path)
    typer_path = ctx.path.clone()
    // For per-file units, we do not switch modes per statement.
    infer_body_unit(scope, program, 0, 1, 0, 0, 0, ctx)
    return errors
}

// rstil-style typer: recursively type imports then this file.
type_file := proc(path: Str, ctx: Context) returns shallow I32 {
    if ctx.imports_typer_done.has(path) {
        return 0.to_i32()
    }
    ctx.imports_typer_done.add(own path.clone())

    ref iu : ImportUnit = ctx.imported.get(path)

    // Walk the AST in source order; recurse on each ~import("...")~ FCall.
    // iu.imports stays as a source-ordered side table for path resolution.
    // Loader-prepended mode auto-imports (e.g. mode gui -> gui.til) come
    // first in iu.imports without a matching AST FCall, so process those
    // leading entries before the walk. #165 step 5.
    mut total : I32 = 0.to_i32()
    ast_count : USize = count_ast_imports(iu.ast)
    auto_count : USize = iu.imports.len().sub(ast_count)
    for i in 0..auto_count {
        ref dep : Str = iu.imports.get(i)
        total = total.add(type_file(dep, ctx))
    }
    mut import_idx : USize = auto_count
    for stmt : Expr in iu.ast.children {
        if stmt.node_type.is(NodeType.FCall).not() { continue }
        if stmt.children.len().neq(2) { continue }
        if stmt.child(0).node_type.is(NodeType.Ident).not() { continue }
        if stmt.child(1).node_type.is(NodeType.LiteralStr).not() { continue }
        ref id : Str = get_payload(stmt.child(0).node_type)
        if id.eq("import").not() { continue }
        ref dep : Str = iu.imports.get(import_idx)
        total = total.add(type_file(dep, ctx))
        import_idx = import_idx.add(1.to_u32())
    }

    ctx.mode = iu.mode.clone()
    return total.add(type_check_unit(path, iu.ast, ctx.scope, ctx))
}

infer_assign_stmt := proc(scope: TypeScope, mut stmt: Expr, shallow in_func: I32, ctx: Context) {
    infer_expr(scope, stmt.child(0), in_func, ctx)
    ref mut rhs : Expr = stmt.child(0)
    stmt.til_type = rhs.til_type
    mut aname := ""
    switch stmt.node_type {
    case NodeType.Assign(adata):
        aname = adata.name.clone()
    case:
        UNREACHABLE(__LOC__)
        return
    }
    ref mut ub : TypeBinding = scope.get_binding(aname)
    if is_null(ub).not() { ub.used = true }
    existing := scope.get_type(aname)
    if existing.is(TilType.Unknown) {
        type_error(stmt, "undefined symbol '".concat(aname).concat("'"))
    } else if scope.is_mut(aname).not() {
        type_error(stmt, "cannot assign to immutable variable '".concat(aname).concat("'"))
        sf := scope.find(aname)
        switch sf {
        case ScopeFind.Found(b):
            if b.is_param {
                println(typer_path, ":", b.line.to_str(), ":", b.col.to_str(), ": note: '", aname, "' is a function parameter")
            } else {
                println(typer_path, ":", b.line.to_str(), ":", b.col.to_str(), ": note: '", aname, "' declared here, consider adding 'mut'")
            }
        case:
        }
    } else if rhs.node_type.is(NodeType.LiteralNum).and(is_numeric_type(existing)) {
        switch rhs.node_type {
        case NodeType.LiteralNum(lit_str):
            if literal_in_range(lit_str, existing).not() {
                type_error(stmt, "integer literal out of range for assignment to '".concat(aname).concat("'"))
            }
        case:
        }
        rhs.til_type = existing
        stmt.til_type = existing
    } else if rhs.til_type.is(existing).not().and(rhs.til_type.is(TilType.Unknown).not()) {
        type_error(stmt, "'".concat(aname).concat("' assignment type mismatch"))
    }
    sf_assign := scope.find(aname)
    mut is_ref_target := false
    switch sf_assign {
    case ScopeFind.Found(ab):
        if ab.own_type.is(OwnType.Ref).and(ab.is_param.not()) { is_ref_target = true }
    case:
    }
    if is_ref_target {
        check_ref_assign_owned_rhs(stmt, aname, rhs, scope)
    }
    if is_ref_target.not() {
        if rhs.node_type.is(NodeType.Ident).or(
            rhs.node_type.is(NodeType.FieldAccess).and(
                rhs.til_type.is(TilType.Struct).or(rhs.til_type.is(TilType.Enum))
            )
        ) {
            tname := type_to_name(rhs.til_type)
            if tname.len().gt(0) {
                mc := make_clone_call(tname, rhs.til_type, rhs, stmt)
                stmt.children.set(0, own mc)
                if scope.bindings.has(aname).not() {
                    if existing.is(TilType.Struct).or(existing.is(TilType.Enum)) {
                        if assign_target_is_func_local(scope, aname) {
                            switch stmt.node_type {
                            case NodeType.Assign(adata2):
                                adata2.save_old_delete = true
                            case:
                            }
                        }
                    }
                }
            }
        } else if rhs.node_type.is(NodeType.FCall).and(fcall_returns_own(rhs, scope)).and(
            existing.is(TilType.Struct).or(existing.is(TilType.Enum))
        ) {
            if scope.bindings.has(aname).not().and(assign_target_is_func_local(scope, aname)) {
                switch stmt.node_type {
                case NodeType.Assign(adata3):
                    adata3.save_old_delete = true
                case:
                }
            }
        }
    }
}

rhs_is_clone_fcall := func(rhs: Expr) returns shallow Bool {
    if rhs.node_type.is(NodeType.FCall).not() { return false }
    if rhs.children.len().lt(1) { return false }
    ref callee : Expr = rhs.child(0)
    if callee.node_type.is(NodeType.FieldAccess).not() { return false }
    switch callee.node_type {
    case NodeType.FieldAccess(method):
        return method.eq("clone")
    case:
        return false
    }
}

assign_target_is_func_local := func(mut scope: TypeScope, name: Str) returns shallow Bool {
    ref mut s : TypeScope = scope
    while is_null(s).not() {
        if is_null(s.parent).not().and(s.bindings.has(name)) { return true }
        s = s.parent
    }
    return false
}

is_numeric_type := func(t: TilType) returns shallow Bool {
    switch t {
    case TilType.I64: return true
    case TilType.U8:  return true
    case TilType.I16: return true
    case TilType.I32: return true
    case TilType.U32: return true
    case TilType.U64: return true
    case TilType.F32: return true
    case: return false
    }
}

is_integral_numeric_type := func(t: TilType) returns shallow Bool {
    switch t {
    case TilType.I64: return true
    case TilType.U8:  return true
    case TilType.I16: return true
    case TilType.I32: return true
    case TilType.U32: return true
    case TilType.U64: return true
    case: return false
    }
}

type_ctor_consumes := func(t: TilType) returns shallow Bool {
    switch t {
    case TilType.Struct: return true
    case TilType.Enum: return true
    case TilType.Dynamic: return true
    case TilType.FuncPtr: return true
    case: return false
    }
}

is_usize_name := func(name: Str) returns shallow Bool {
    return name.eq("USize")
}

can_implicit_usize_coerce := func(from: TilType, to: TilType, to_name: Str) returns shallow Bool {
    if is_usize_name(to_name).not() { return false }
    switch to {
    case TilType.U32:
        return is_integral_numeric_type(from)
    case: return false
    }
}

literal_in_range := func(val_str: Str, target: TilType) returns shallow Bool {
    switch target {
    case TilType.I64: return true
    case TilType.F32: return true
    case TilType.U8:
        val := val_str.to_i64()
        return val.gte(0).and(val.lte(255))
    case TilType.I16:
        val := val_str.to_i64()
        return val.gte(-32768).and(val.lte(32767))
    case TilType.I32:
        val := val_str.to_i64()
        return val.gte(-2147483648).and(val.lte(2147483647))
    case TilType.U32:
        val := val_str.to_i64()
        return val.gte(0).and(val.lte(4294967295))
    case TilType.U64:
        val := val_str.to_i64()
        return val.gte(0)
    case: return true
    }
}

can_implicit_widen := func(from: TilType, to: TilType) returns shallow Bool {
    if from.eq(to) { return false }
    switch from {
    case TilType.U8:
        switch to {
        case TilType.I16: return true
        case TilType.I32: return true
        case TilType.I64: return true
        case TilType.U32: return true
        case TilType.U64: return true
        case: return false
        }
    case TilType.I16:
        switch to {
        case TilType.I32: return true
        case TilType.I64: return true
        case: return false
        }
    case TilType.U32:
        switch to {
        case TilType.U64: return true
        case TilType.I64: return true
        case: return false
        }
    case TilType.I32:
        switch to {
        case TilType.I64: return true
        case: return false
        }
    case: return false
    }
}

type_from_name := func(name: Str, scope: TypeScope) returns TilType {
    if name.eq("I64")  { return TilType.I64 }
    if name.eq("U8")   { return TilType.U8 }
    if name.eq("I16")  { return TilType.I16 }
    if name.eq("I32")  { return TilType.I32 }
    if name.eq("U32")  { return TilType.U32 }
    if name.eq("U64")  { return TilType.U64 }
    if name.eq("F32")  { return TilType.F32 }
    if name.eq("Str")  { return TilType.Struct("Str".clone()) }
    if name.eq("Bool") { return TilType.Bool }
    if name.eq("StructDef") { return TilType.Struct("StructDef".clone()) }
    if name.eq("EnumDef")   { return TilType.Struct("EnumDef".clone()) }
    if name.eq("Fn")        { return TilType.FuncPtr }
    if name.eq("Dynamic")   { return TilType.Dynamic }
    if is_null(scope).not() {
        ref mut b : TypeBinding = scope.get_binding(name)
        if is_null(b).not() {
            // #187: explicit type annotations (e.g. ~ref x : Foo = ...~,
            // function param/return types) count as a use of the named
            // type. Same gate as the Ident path -- skip when we're inside
            // the type's own namespace to keep auto-gen body references
            // from masking a genuinely unused priv type.
            if auto_gen_depth.eq(0).and(current_type_name.eq(name).not()) {
                b.used = true
            }
            if b.is_builtin {
                if is_null(b.struct_def).not() { return b.type }
            }
            if is_null(b.func_def).not() {
                if b.func_def.children.len().eq(0) {
                    return TilType.FuncPtr
                }
            }
        }
        ref sdef : Expr = scope.get_struct(name)
        if is_null(sdef).not() {
            if sdef.node_type.is(NodeType.EnumDef) {
                return TilType.Enum(name.clone())
            }
            return TilType.Struct(name.clone())
        }
    }
    return TilType.Unknown
}

resolve_type_alias := func(scope: TypeScope, name: Str) returns ref Str {
    ref b : TypeBinding = scope.get_binding(name)
    if is_null(b).not() {
        if b.is_type_alias {
            if b.alias_target.is_empty().not() { return b.alias_target }
        }
    }
    return name
}

usize_name := func(scope: TypeScope) returns Str {
    if is_null(scope.get_binding("USize")).not() { return "USize" }
    return "U64"
}

usize_type := func(scope: TypeScope) returns TilType {
    return type_from_name(usize_name(scope), scope)
}

type_has_cmp := func(scope: TypeScope, type_name: Str) returns shallow Bool {
    ref sdef : Expr = scope.get_struct(type_name)
    if is_null(sdef) { return false }
    ref cmp_ns : Vec = def_ns_decls(sdef)
    for decl : Declaration in cmp_ns {
        if decl.name.eq("cmp") { return true }
    }
    return false
}

type_has_to_str := func(scope: TypeScope, type_name: Str) returns shallow Bool {
    ref sdef : Expr = scope.get_struct(type_name)
    if is_null(sdef) { return false }
    ref ts_ns : Vec = def_ns_decls(sdef)
    for decl : Declaration in ts_ns {
        if decl.name.eq("to_str") { return true }
    }
    return false
}

expr_contains_fcall := func(e: Expr) returns shallow Bool {
    if e.node_type.is(NodeType.FCall) { return true }
    for e_i : Expr in e.children {
        if expr_contains_fcall(e_i) { return true }
    }
    return false
}

expr_uses_var := func(e: Expr, name: Str) returns shallow Bool {
    if e.node_type.is(NodeType.FuncDef) { return false }
    switch e.node_type {
    case NodeType.Ident(_id):
        if _id.eq(name) { return true }
    case NodeType.Assign(_as):
        if _as.name.eq(name) { return true }
    case:
    }
    for e_i : Expr in e.children {
        if expr_uses_var(e_i, name) { return true }
    }
    return false
}

expr_contains_decl := func(e: Expr, name: Str) returns shallow Bool {
    if e.node_type.is(NodeType.FuncDef) { return false }
    switch e.node_type {
    case NodeType.Decl(_dd):
        if _dd.name.eq(name) { return true }
    case:
    }
    for e_i : Expr in e.children {
        if expr_contains_decl(e_i, name) { return true }
    }
    return false
}

expr_used_in_nested_func := func(e: Expr, name: Str) returns shallow Bool {
    switch e.node_type {
    case NodeType.FuncDef(fdef):
        for p : Declaration in fdef.params {
            if p.name.eq(name) { return false }
        }
        if e.children.len().gt(0) {
            return expr_uses_var(e.child(0), name)
        }
        return false
    case:
    }
    for e_i : Expr in e.children {
        if expr_used_in_nested_func(e_i, name) { return true }
    }
    return false
}

priv find_variadic_fcall := func(e: Expr) returns ref Expr {
    if is_null(e) { return NULL }
    if e.node_type.is(NodeType.FuncDef) { return NULL }
    if e.node_type.is(NodeType.StructDef) { return NULL }
    if e.node_type.is(NodeType.EnumDef) { return NULL }
    if e.node_type.is(NodeType.Body) { return NULL }
    switch e.node_type {
    case NodeType.FCall(fcall):
        if fcall.variadic_index.gte(0) {
            switch e.child(0).node_type {
            case NodeType.Ident(cn):
                if cn.eq("array").or(cn.eq("vec")) {
                    return NULL
                }
            case:
            }
            return e
        }
    case:
    }
    for e_i : Expr in e.children {
        ref found : Expr = find_variadic_fcall(e_i)
        if is_null(found).not() { return found }
    }
    return NULL
}

find_kwargs_fcall := func(e: Expr) returns ref Expr {
    if is_null(e) { return NULL }
    if e.node_type.is(NodeType.FuncDef) { return NULL }
    if e.node_type.is(NodeType.StructDef) { return NULL }
    if e.node_type.is(NodeType.EnumDef) { return NULL }
    if e.node_type.is(NodeType.Body) { return NULL }
    switch e.node_type {
    case NodeType.FCall(fcall):
        if fcall.kwargs_index.gte(0) { return e }
    case:
    }
    for e_i : Expr in e.children {
        ref found : Expr = find_kwargs_fcall(e_i)
        if is_null(found).not() { return found }
    }
    return NULL
}

type_prefix := func(t: TilType) returns Str {
    switch t {
    case TilType.I64: return "I64"
    case TilType.U8: return "U8"
    case TilType.I16: return "I16"
    case TilType.I32: return "I32"
    case TilType.U32: return "U32"
    case TilType.U64: return "U64"
    case TilType.F32: return "F32"
    case TilType.Bool: return "Bool"
    case TilType.None: return "None"
    case TilType.Struct(s):
        if s.len().gt(0) { return s.clone() }
        return "compound"
    case TilType.Enum(s):
        if s.len().gt(0) { return s.clone() }
        return "compound"
    case TilType.Custom(s):
        // #165 step 1: Custom(name) is the unresolved form of
        // Struct(name)/Enum(name). Treat them the same here so type
        // comparisons (e.g. argument-type checks) see a consistent
        // prefix string.
        if s.len().gt(0) { return s.clone() }
        return "compound"
    case: return "v"
    }
}

type_to_name := func(t: TilType) returns Str {
    name := til_type_name(t)
    if name.len().gt(0) { return name }
    switch t {
    case TilType.I64: return I64Name.clone()
    case TilType.U8: return U8Name.clone()
    case TilType.I16: return I16Name.clone()
    case TilType.I32: return I32Name.clone()
    case TilType.U32: return U32Name.clone()
    case TilType.U64: return U64Name.clone()
    case TilType.F32: return F32Name.clone()
    case TilType.Bool: return BoolName.clone()
    case: return ""
    }
}

make_field_delete := func(field_assign: Expr, shallow field_own_type: OwnType) returns Expr {
    ref rhs : Expr = field_assign.child(1)
    tname := type_to_name(rhs.til_type)
    if tname.len().eq(0) { return NULL }

    mut call := Expr.new(NodeType.FCall(FCallData()), field_assign.line, field_assign.col)
    call.til_type = TilType.None

    mut type_id := Expr.new(NodeType.Ident(tname.clone()), field_assign.line, field_assign.col)
    type_id.til_type = TilType.Custom(tname.clone())

    mut fa := Expr.new(NodeType.FieldAccess("delete"), field_assign.line, field_assign.col)
    fa.add_child(own type_id)
    call.add_child(own fa)

    mut fa_name := ""
    switch field_assign.node_type {
    case NodeType.FieldAssign(fn):
        fa_name = fn.clone()
    case:
        UNREACHABLE(__LOC__)
    }
    mut field_acc := Expr.new(NodeType.FieldAccess(fa_name), field_assign.line, field_assign.col)
    field_acc.til_type = rhs.til_type
    field_acc.add_child(own field_assign.child(0).clone())
    call.add_child(own field_acc)

    mut cf_lit := Expr.new(NodeType.LiteralBool(field_own_type.is(OwnType.Own)), field_assign.line, field_assign.col)
    cf_lit.til_type = TilType.Bool
    call.add_child(own cf_lit)

    return call
}

make_delete_call := func(var_name: Str, shallow type: TilType, shallow arg_is_own: Bool, shallow call_free: Bool, src: Expr) returns Expr {
    tname := type_to_name(type)
    if tname.len().eq(0) { return NULL }

    mut call := Expr.new(NodeType.FCall(FCallData()), src.line, src.col)
    call.til_type = TilType.None

    mut type_id := Expr.new(NodeType.Ident(tname.clone()), src.line, src.col)
    type_id.til_type = TilType.Custom(tname.clone())

    mut fa := Expr.new(NodeType.FieldAccess("delete"), src.line, src.col)
    fa.add_child(own type_id)
    call.add_child(own fa)

    mut arg := Expr.new(NodeType.Ident(var_name.clone()), src.line, src.col)
    arg.til_type = type
    if arg_is_own { set_own_arg(call, call.children.len()) }
    call.add_child(own arg)

    mut cf_lit := Expr.new(NodeType.LiteralBool(call_free), src.line, src.col)
    cf_lit.til_type = TilType.Bool
    call.add_child(own cf_lit)

    return call
}

// True when `e` (or any sub-expression) is a struct constructor FCall of the
// shape `Type(..., var_name, ...)` where var_name is at the position of a
// field whose declared own_type is `Shallow`. In that case the constructor
// emits `dst->field = *var_name`, i.e. value-copies the inner Str/Vec/etc.
// from var_name's heap wrapper into the field; the field's own destructor
// will free the inner data when the parent struct is destroyed, but nothing
// frees var_name's wrapper, so it leaks.
//
// This is the exact shape we want `make_free_call` to follow up. Other
// transfer shapes -- own arg to a function, struct constructor with an Own
// or Ref field -- already consume the wrapper, so we must NOT emit a free.
transfer_is_shallow_field_value_copy := func(e: Expr, var_name: Str, scope: TypeScope) returns shallow Bool {
    if is_null(e) { return false }
    if e.node_type.is(NodeType.FuncDef) { return false }
    if e.node_type.is(NodeType.FCall) {
        if e.children.len().gte(2) {
            fcall_sname := til_type_name(e.til_type)
            if fcall_sname.len().gt(0) {
                switch e.child(0).node_type {
                case NodeType.Ident(_c0s):
                    if _c0s.eq(fcall_sname) {
                        ref sdef : Expr = scope.get_struct(fcall_sname)
                        if is_null(sdef).not() {
                            switch sdef.node_type {
                            case NodeType.StructDef(tsv_sdd):
                                for fi in 0..tsv_sdd.fields.len() {
                                    ref fld_decl : Declaration = tsv_sdd.fields.get(fi)
                                    arg_idx := fi.add(1)
                                    if arg_idx.lt(e.children.len()) {
                                        ref arg : Expr = e.child(arg_idx)
                                        switch arg.node_type {
                                        case NodeType.Ident(_an):
                                            if _an.eq(var_name).and(fld_decl.own_type.is(OwnType.Shallow)) {
                                                if type_ctor_consumes(fld_decl.til_type) {
                                                    return true
                                                }
                                            }
                                        case:
                                        }
                                    }
                                }
                            case:
                            }
                        }
                    }
                case:
                }
            }
        }
    }
    for ec : Expr in e.children {
        if transfer_is_shallow_field_value_copy(ec, var_name, scope) { return true }
    }
    return false
}

// `free(own var_name)`: release just the heap wrapper without invoking the
// type's destructor. Used after value-copy ownership transfer to a Shallow
// struct field, where the field's own destructor will free the inner data.
make_free_call := func(var_name: Str, shallow type: TilType, src: Expr) returns Expr {
    mut call := Expr.new(NodeType.FCall(FCallData()), src.line, src.col)
    call.til_type = TilType.None

    mut callee := Expr.new(NodeType.Ident("free".clone()), src.line, src.col)
    call.add_child(own callee)

    mut arg := Expr.new(NodeType.Ident(var_name.clone()), src.line, src.col)
    arg.til_type = type
    set_own_arg(call, call.children.len())
    call.add_child(own arg)

    return call
}

make_clone_call := func(type_name: Str, shallow type: TilType, arg: Expr, src: Expr) returns Expr {
    mut call := Expr.new(NodeType.FCall(FCallData()), src.line, src.col)
    call.til_type = type
    if type.is(TilType.Struct).and(til_type_name(type).len().eq(0)) {
        call.til_type = TilType.Struct(type_name.clone())
    } else if type.is(TilType.Enum).and(til_type_name(type).len().eq(0)) {
        call.til_type = TilType.Enum(type_name.clone())
    }

    mut type_id := Expr.new(NodeType.Ident(type_name.clone()), src.line, src.col)
    type_id.til_type = TilType.Custom(type_name.clone())

    mut fa := Expr.new(NodeType.FieldAccess("clone"), src.line, src.col)
    fa.add_child(own type_id)
    call.add_child(own fa)

    call.add_child(own arg.clone())
    return call
}

// Wrap `arg` with `T.to_str(arg)`, used to auto-coerce non-Str args
// passed to a `..Str` variadic param so `print(1+1)` etc. work.
make_to_str_call := func(type_name: Str, arg: Expr) returns Expr {
    mut call := make_ns_call(type_name, "to_str", TilType.Struct("Str".clone()), arg)
    call.add_child(own arg.clone())
    return call
}

make_ns_call := func(sname: Str, method: Str, shallow ret_type: TilType, src: Expr) returns Expr {
    mut call := Expr.new(NodeType.FCall(FCallData()), src.line, src.col)
    call.til_type = ret_type

    mut type_id := Expr.new(NodeType.Ident(sname.clone()), src.line, src.col)
    type_id.til_type = TilType.Custom(sname.clone())

    mut fa := Expr.new(NodeType.FieldAccess(method.clone()), src.line, src.col)
    fa.add_child(own type_id)
    call.add_child(own fa)
    return call
}

build_kwargs_dynmap_decl := func(fcall: Expr, kw_name: Str) returns Expr {
    mut new_call := make_ns_call("DynMap", "new", TilType.Struct("DynMap".clone()), fcall)
    mut kw_decl := Expr.new(NodeType.Decl(Declaration()), fcall.line, fcall.col)
    switch kw_decl.node_type {
    case NodeType.Decl(dd):
        dd.name = kw_name.clone()
    case:
        UNREACHABLE(__LOC__)
    }
    kw_decl.til_type = TilType.Struct("DynMap".clone())
    kw_decl.add_child(own new_call)
    return kw_decl
}

build_kwargs_dynmap_set := func(fcall: Expr, scope: TypeScope, kw_name: Str, named_arg: Expr) returns Expr {
    mut key_name := ""
    switch named_arg.node_type {
    case NodeType.NamedArg(kn):
        key_name = kn.clone()
    case:
        UNREACHABLE(__LOC__)
    }
    ref val : Expr = named_arg.child(0)
    mut set_call := make_ns_call("DynMap", "set", TilType.None, fcall)

    mut self_id := Expr.new(NodeType.Ident(kw_name.clone()), fcall.line, fcall.col)
    self_id.til_type = TilType.Struct("DynMap".clone())
    set_call.add_child(own self_id)

    mut key_lit := Expr.new(NodeType.LiteralStr(key_name.clone()), fcall.line, fcall.col)
    key_lit.til_type = TilType.Struct("Str".clone())
    set_own_arg(set_call, set_call.children.len())
    set_call.add_child(own key_lit)

    tname := type_to_name(val.til_type)
    mut type_lit := Expr.new(NodeType.LiteralStr(tname.clone()), fcall.line, fcall.col)
    type_lit.til_type = TilType.Struct("Str".clone())
    set_own_arg(set_call, set_call.children.len())
    set_call.add_child(own type_lit)

    mut size_call := make_ns_call(tname, "size", usize_type(scope), fcall)
    set_call.add_child(own size_call)

    mut out_val := val.clone()
    if val.node_type.is(NodeType.Ident).or(val.node_type.is(NodeType.FieldAccess)) {
        if tname.len().gt(0) {
            out_val = make_clone_call(tname, val.til_type, val, val)
        }
    }
    set_own_arg(set_call, set_call.children.len())
    set_call.add_child(own out_val)
    return set_call
}

build_variadic_array_decl := func(fcall: Expr, scope: TypeScope, elem_type: Str, va_name: Str, shallow vc: U32) returns Expr {
    mut new_call := make_ns_call("Array", "new", TilType.Struct("Array".clone()), fcall)

    mut et := Expr.new(NodeType.LiteralStr(elem_type.clone()), fcall.line, fcall.col)
    et.til_type = TilType.Struct("Str".clone())
    new_call.add_child(own et)

    mut sz := make_ns_call(elem_type, "size", usize_type(scope), fcall)
    new_call.add_child(own sz)

    cap_str := vc.to_str()
    mut cap := Expr.new(NodeType.LiteralNum(cap_str.clone()), fcall.line, fcall.col)
    cap.til_type = usize_type(scope)
    new_call.add_child(own cap)

    mut va_decl := Expr.new(NodeType.Decl(Declaration()), fcall.line, fcall.col)
    switch va_decl.node_type {
    case NodeType.Decl(dd):
        dd.name = va_name.clone()
        dd.own_type = OwnType.Own
    case:
        UNREACHABLE(__LOC__)
    }
    va_decl.til_type = TilType.Struct("Array".clone())
    va_decl.add_child(own new_call)
    return va_decl
}

build_variadic_array_set := func(fcall: Expr, scope: TypeScope, va_name: Str, shallow vi: I32, shallow j: U32) returns Expr {
    mut set_call := make_ns_call("Array", "set", TilType.None, fcall)

    mut self_id := Expr.new(NodeType.Ident(va_name.clone()), fcall.line, fcall.col)
    self_id.til_type = TilType.Struct("Array".clone())
    set_call.add_child(own self_id)

    idx_str := j.to_str()
    mut idx := Expr.new(NodeType.LiteralNum(idx_str.clone()), fcall.line, fcall.col)
    idx.til_type = usize_type(scope)
    set_call.add_child(own idx)

    ref val_in : Expr = fcall.child(vi.add(j.to_i64().to_i32()).to_i64().to_usize())
    mut val := val_in.clone()
    if val_in.node_type.is(NodeType.Ident).or(val_in.node_type.is(NodeType.FieldAccess)) {
        tname := type_to_name(val_in.til_type)
        if tname.len().gt(0) {
            val = make_clone_call(tname, val_in.til_type, val_in, val_in)
        }
    }
    set_own_arg(set_call, set_call.children.len())
    set_call.add_child(own val)
    return set_call
}

// Returns true if the call constructed replacement stmts and pushed them
// to new_ch; false if the original stmt should be kept (caller pushes it).
desugar_set_literal_decl := proc(stmt: Expr, mut new_ch: Vec, mut scope: TypeScope) returns shallow Bool {
    ref set_lit : Expr = stmt.child(0)
    mut var_name := ""
    switch stmt.node_type {
    case NodeType.Decl(stmt_decl):
        var_name = stmt_decl.name.clone()
    case:
        UNREACHABLE(__LOC__)
        return false
    }

    if set_lit.children.len().eq(0) {
        type_error(set_lit, "set literal must have at least one element")
        return false
    }

    ref first : Expr = set_lit.child(0)
    elem_type := type_to_name(first.til_type)
    if elem_type.len().eq(0) {
        type_error(first, "set literal: cannot determine element type")
        return false
    }

    if type_has_cmp(scope, elem_type).not() {
        type_error(first, "set literal: element type '".concat(elem_type).concat("' must implement cmp"))
    }

    for j in 1..set_lit.children.len() {
        ref v : Expr = set_lit.child(j)
        vt := type_to_name(v.til_type)
        if vt.len().eq(0).or(vt.eq(elem_type).not()) {
            type_error(v, "set literal: all elements must be the same type")
        }
    }

    mut new_call := make_ns_call("Set", "new", TilType.Struct("Set".clone()), set_lit)
    mut et_str := Expr.new(NodeType.LiteralStr(elem_type.clone()), set_lit.line, set_lit.col)
    et_str.til_type = TilType.Struct("Str".clone())
    new_call.add_child(own et_str)
    mut esz := make_ns_call(elem_type, "size", usize_type(scope), set_lit)
    new_call.add_child(own esz)

    mut decl := Expr.new(NodeType.Decl(Declaration()), stmt.line, stmt.col)
    switch decl.node_type {
    case NodeType.Decl(dd):
        dd.name = var_name.clone()
        dd.is_mut = true
    case:
        UNREACHABLE(__LOC__)
    }
    decl.til_type = TilType.Struct("Set".clone())
    decl.add_child(own new_call)

    scope.set(var_name, TilType.Struct("Set".clone()), FuncType.None, true, typer_path, stmt.line, stmt.col, false, OwnType.Shallow)

    new_ch.push(own decl)

    for e_j : Expr in set_lit.children {
        mut add_call := make_ns_call("Set", "add", TilType.None, set_lit)
        mut self_id := Expr.new(NodeType.Ident(var_name.clone()), set_lit.line, set_lit.col)
        self_id.til_type = TilType.Struct("Set".clone())
        add_call.add_child(own self_id)
        mut val := e_j.clone()
        set_own_arg(add_call, add_call.children.len())
        add_call.add_child(own val)
        new_ch.push(own add_call)
    }
    return true
}

// Returns true if the call constructed replacement stmts and pushed them
// to new_ch; false if the original stmt should be kept (caller pushes it).
desugar_map_literal_decl := proc(stmt: Expr, mut new_ch: Vec, mut scope: TypeScope) returns shallow Bool {
    ref map_lit : Expr = stmt.child(0)
    mut var_name := ""
    switch stmt.node_type {
    case NodeType.Decl(stmt_decl):
        var_name = stmt_decl.name.clone()
    case:
        UNREACHABLE(__LOC__)
        return false
    }
    n_pairs := map_lit.children.len().div(2)

    if map_lit.children.len().eq(0) {
        type_error(map_lit, "map literal must have at least one entry")
        return false
    }
    if map_lit.children.len().mod(2).eq(0).not() {
        type_error(map_lit, "map literal has mismatched key/value pairs")
        return false
    }

    ref first_key : Expr = map_lit.child(0)
    ref first_val : Expr = map_lit.child(1)
    key_type := type_to_name(first_key.til_type)
    val_type := type_to_name(first_val.til_type)

    if key_type.len().eq(0) {
        type_error(first_key, "map literal: cannot determine key type")
        return false
    }
    if val_type.len().eq(0) {
        type_error(first_val, "map literal: cannot determine value type")
        return false
    }

    if type_has_cmp(scope, key_type).not() {
        type_error(first_key, "map literal: key type '".concat(key_type).concat("' must implement cmp"))
    }

    for j in 2..map_lit.children.len() {
        if j.mod(2).eq(0) {
            ref k : Expr = map_lit.child(j)
            kt := type_to_name(k.til_type)
            if kt.len().eq(0).or(kt.eq(key_type).not()) {
                type_error(k, "map literal: all keys must be the same type")
            }
        } else {
            ref v : Expr = map_lit.child(j)
            vt := type_to_name(v.til_type)
            if vt.len().eq(0).or(vt.eq(val_type).not()) {
                type_error(v, "map literal: all values must be the same type")
            }
        }
    }

    mut new_call := make_ns_call("Map", "new", TilType.Struct("Map".clone()), map_lit)
    mut kt_str := Expr.new(NodeType.LiteralStr(key_type.clone()), map_lit.line, map_lit.col)
    kt_str.til_type = TilType.Struct("Str".clone())
    new_call.add_child(own kt_str)
    mut ksz := make_ns_call(key_type, "size", usize_type(scope), map_lit)
    new_call.add_child(own ksz)
    mut vt_str := Expr.new(NodeType.LiteralStr(val_type.clone()), map_lit.line, map_lit.col)
    vt_str.til_type = TilType.Struct("Str".clone())
    new_call.add_child(own vt_str)
    mut vsz := make_ns_call(val_type, "size", usize_type(scope), map_lit)
    new_call.add_child(own vsz)

    mut decl := Expr.new(NodeType.Decl(Declaration()), stmt.line, stmt.col)
    switch decl.node_type {
    case NodeType.Decl(dd):
        dd.name = var_name.clone()
        dd.is_mut = true
    case:
        UNREACHABLE(__LOC__)
    }
    decl.til_type = TilType.Struct("Map".clone())
    decl.add_child(own new_call)

    scope.set(var_name, TilType.Struct("Map".clone()), FuncType.None, true, typer_path, stmt.line, stmt.col, false, OwnType.Shallow)

    new_ch.push(own decl)

    for j in 0..n_pairs {
        mut set_call := make_ns_call("Map", "set", TilType.None, map_lit)
        mut self_id := Expr.new(NodeType.Ident(var_name.clone()), map_lit.line, map_lit.col)
        self_id.til_type = TilType.Struct("Map".clone())
        set_call.add_child(own self_id)
        mut key := map_lit.child(j.mul(2)).clone()
        set_own_arg(set_call, set_call.children.len())
        set_call.add_child(own key)
        mut mval := map_lit.child(j.mul(2).add(1)).clone()
        set_own_arg(set_call, set_call.children.len())
        set_call.add_child(own mval)
        new_ch.push(own set_call)
    }
    return true
}

// Combine desugar_set_literals and desugar_map_literals: both filter on
// Decl + SetLit/MapLit rhs at the body's top level, both rebuild
// body.children, and both end with reregister_scope_defs (which is O(N*K)
// over body decls and scope bindings). Sharing the prefilter, rebuild,
// and reregister halves that cost when both transformations apply, and
// drops one walk + one reregister even when only one applies.
// Apply the variadic and kwargs desugars to a single stmt (in place).
// Prepends va_decl/va_setters and kw_decl/kw_setters to new_ch as needed
// and rewrites the discovered fcall's args. Caller is responsible for
// pushing the (possibly-mutated) stmt to new_ch afterwards.
// Desugar every variadic and kwargs fcall reachable from stmt in a
// single post-order walk. Children are processed before their parent,
// so by the time we build a parent's setter (which clones a variadic
// arg) the inner fcall has already been rewritten in place. That
// covers nested fcalls in one walk, and sibling fcalls naturally fall
// out of the children iteration -- no recursion on setters and no
// repeated find_*_fcall scans. #186 / #188 / #189 all came from the
// same root cause (single-pass-per-stmt instead of full traversal).
//
// Note: the traversal mirrors the recursion guards used by
// find_variadic_fcall / find_kwargs_fcall (FuncDef / StructDef /
// EnumDef / Body) so a body-level walk doesn't dive into a nested
// function definition or nested block, which the outer desugar_body
// pass will reach separately.
process_call_desugars := func(mut e: Expr, mut new_ch: Vec, mut scope: TypeScope, shallow has_variadic: Bool, shallow has_kwargs: Bool) {
    if is_null(e) { return }
    if e.node_type.is(NodeType.FuncDef) { return }
    if e.node_type.is(NodeType.StructDef) { return }
    if e.node_type.is(NodeType.EnumDef) { return }
    if e.node_type.is(NodeType.Body) { return }

    for e_i : Expr in e.children {
        process_call_desugars(e_i, new_ch, scope, has_variadic, has_kwargs)
    }

    switch e.node_type {
    case NodeType.FCall(fcall_data):
        if has_variadic.and(fcall_data.variadic_index.gte(0)) {
            // Skip array/vec callees -- handled separately by the
            // container literal builders, not by the variadic desugar.
            mut skip := false
            switch e.child(0).node_type {
            case NodeType.Ident(cn):
                if cn.eq("array").or(cn.eq("vec")) { skip = true }
            case:
            }
            if skip.not() {
                if desugar_pure_splat_variadic_call(e).not() {
                    line := e.line
                    col := e.col
                    vi := fcall_data.variadic_index
                    vc := fcall_data.variadic_count
                    ref elem_type : Str = resolve_variadic_elem_type(e, scope)
                    // elem_type-null here means the typer already
                    // reported an error upstream; just leave the
                    // fcall raw rather than emit a half-formed wrap.
                    if is_null(elem_type).not() {
                        va_name := "_va_Array_".concat(va_counter.to_str())
                        va_counter++
                        mut va_decl := build_variadic_array_decl(e, scope, elem_type, va_name, vc)
                        scope.set(va_name, TilType.Struct("Array".clone()), FuncType.None, false, typer_path, line, col, false, OwnType.Own)
                        new_ch.push(own va_decl)
                        for j in 0..vc {
                            mut setter := build_variadic_array_set(e, scope, va_name, vi, j)
                            new_ch.push(own setter)
                        }
                        rewrite_variadic_fcall_args(e, va_name)
                    }
                }
            }
        }
        if has_kwargs.and(fcall_data.kwargs_index.gte(0)) {
            ki := fcall_data.kwargs_index
            kc := fcall_data.kwargs_count
            kw_name := "_kw".concat(kw_counter.to_str())
            kw_counter++
            kw_decl := build_kwargs_dynmap_decl(e, kw_name)
            scope.set(kw_name, TilType.Struct("DynMap".clone()), FuncType.None, false, typer_path, e.line, e.col, false, OwnType.Shallow)
            new_ch.push(own kw_decl)
            for j in 0..kc {
                ref named_arg : Expr = e.child(ki.add(j.to_i64().to_i32()).to_i64().to_usize())
                mut setter := build_kwargs_dynmap_set(e, scope, kw_name, named_arg)
                new_ch.push(own setter)
            }
            rewrite_kwargs_fcall_args(e, kw_name)
        }
    case:
    }
}

// Combine all four body-level desugars (set/map literal, variadic call,
// kwargs call) into a single AST walk over body.children. One prefilter,
// one move-out + rebuild + move-back, one reregister_scope_defs.
//
// Set/map literal desugaring replaces a Decl with multiple new stmts
// (Set.new/Set.add or Map.new/Map.set), and those new stmts can contain
// variadic or kwargs fcalls. To preserve the original sequential
// semantics where the calls pass ran *after* the literals pass and saw
// the rewritten body, the loop captures literal-desugar output in a
// per-stmt temp_ch, applies the call desugars to each result stmt, and
// then transfers them to new_ch. Stmts that aren't set/map decls go
// through the same call-desugar path before being pushed.
priv desugar_body := proc(mut body: Expr, mut scope: TypeScope) {
    mut has_set_lit := false
    mut has_map_lit := false
    mut has_variadic := false
    mut has_kwargs := false
    for stmt : Expr in body.children {
        if stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0)) {
            ref rhs : Expr = stmt.child(0)
            if rhs.node_type.is(NodeType.SetLit) { has_set_lit = true }
            if rhs.node_type.is(NodeType.MapLit) { has_map_lit = true }
        }
        if has_variadic.not() {
            if is_null(find_variadic_fcall(stmt)).not() { has_variadic = true }
        }
        if has_kwargs.not() {
            if is_null(find_kwargs_fcall(stmt)).not() { has_kwargs = true }
        }
    }
    if has_set_lit.not().and(has_map_lit.not()).and(has_variadic.not()).and(has_kwargs.not()) {
        return
    }

    mut old := Vec.new("Expr", Expr.size())
    old.move_from(body.children)

    mut new_ch := Vec.new("Expr", Expr.size())
    for i in 0..old.len() {
        ref stmt : Expr = old.get(i)

        // First try the literal desugars. They replace stmt with N new
        // stmts and may produce stmts that themselves contain variadic
        // or kwargs fcalls (e.g. set { f(a..) } -> Set.new(...);
        // Set.add(f(a..))), so each result stmt then runs through the
        // call desugars before being flushed to new_ch.
        mut literal_handled := false
        if stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0)) {
            ref rhs : Expr = stmt.child(0)
            mut temp_ch := Vec.new("Expr", Expr.size())
            if has_set_lit.and(rhs.node_type.is(NodeType.SetLit)) {
                if desugar_set_literal_decl(stmt, temp_ch, scope) {
                    literal_handled = true
                }
            } else if has_map_lit.and(rhs.node_type.is(NodeType.MapLit)) {
                if desugar_map_literal_decl(stmt, temp_ch, scope) {
                    literal_handled = true
                }
            }
            if literal_handled {
                for j in 0..temp_ch.len() {
                    ref ts : Expr = temp_ch.get(j)
                    process_call_desugars(ts, new_ch, scope, has_variadic, has_kwargs)
                    new_ch.push_take(temp_ch, j)
                }
            }
            Vec.delete(own temp_ch, false)
        }

        if literal_handled.not() {
            process_call_desugars(stmt, new_ch, scope, has_variadic, has_kwargs)
            new_ch.push_take(old, i)
        }
    }
    body.children.move_from(new_ch)
    reregister_scope_defs(body, scope)
}

hoist_param_swap_assign := func(mut stmt: Expr, mut hoisted: Vec, mut scope: TypeScope) {
    mut stmt_name := ""
    switch stmt.node_type {
    case NodeType.Assign(adata):
        stmt_name = adata.name.clone()
    case:
        return
    }
    sf := scope.find(stmt_name)
    switch sf {
    case ScopeFind.Found(ab):
        if ab.is_param.not() { return }
        if ab.is_mut.not() { return }
        if ab.type.is(TilType.Struct).not() {
            if ab.type.is(TilType.Enum).not() { return }
        }

        mut call := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col)
        call.til_type = TilType.None
        mut fn := Expr.new(NodeType.Ident("swap"), stmt.line, stmt.col)
        call.add_child(own fn)
        mut a := Expr.new(NodeType.Ident(stmt_name.clone()), stmt.line, stmt.col)
        a.til_type = ab.type
        call.add_child(own a)
        call.add_child(own stmt.child(0).clone())
        tname := type_to_name(ab.type)
        mut sz_call := make_ns_call(tname, "size", usize_type(scope), stmt)
        mut sz := hoist_to_temp(sz_call, hoisted, scope, false)
        call.add_child(own sz)
        stmt = call
    case:
    }
}

hoist_expr := proc(mut expr: Expr, mut hoisted: Vec, mut scope: TypeScope) {
    if expr.node_type.is(NodeType.FuncDef) { return }
    if expr.node_type.is(NodeType.StructDef) { return }
    if expr.node_type.is(NodeType.EnumDef) { return }
    if expr.node_type.is(NodeType.Body) { return }

    for e_i : Expr in expr.children {
        hoist_expr(e_i, hoisted, scope)
    }
    if expr.node_type.is(NodeType.FCall).not() { return }

    expr_sname := til_type_name(expr.til_type)
    mut is_dyn_call := false
    mut is_array_vec := false
    mut is_ctor_call := false
    if expr.children.len().gt(0) {
        ref callee : Expr = expr.child(0)
        switch callee.node_type {
        case NodeType.Ident(cn):
            if expr_sname.len().gt(0).and(cn.eq(expr_sname)) {
                is_ctor_call = true
            }
            if cn.eq("dyn_call") { is_dyn_call = true }
            if cn.eq("dyn_call_ret") { is_dyn_call = true }
            if cn.eq("dyn_has_method") { is_dyn_call = true }
            if cn.eq("dyn_fn") { is_dyn_call = true }
            if cn.eq("array") { is_array_vec = true }
            if cn.eq("vec") { is_array_vec = true }
        case:
        }
    }
    ref hoist_sdef : Expr = scope.get_struct(expr_sname)

    mut fi := 0.to_usize()
    for i in 1..expr.children.len() {
        if is_dyn_call {
            if i.eq(2).or(i.eq(3)) { continue }
        }
        if is_array_vec {
            if i.eq(1) { continue }
        }

        ref arg : Expr = expr.child(i)
        mut hoist_fi := fi
        if is_ctor_call.and(is_null(hoist_sdef).not()) {
        if hoist_sdef.node_type.is(NodeType.StructDef) {
            fi = fi.add(1)
        }
        }
        if arg.node_type.is(NodeType.FCall).not() {
            if arg.node_type.is(NodeType.LiteralNum).not() {
                if arg.node_type.is(NodeType.LiteralStr).not() {
                    if arg.node_type.is(NodeType.LiteralBool).not() {
                        continue
                    }
                }
            }
        }

        mut slot_is_own := false
        if is_ctor_call.and(is_null(hoist_sdef).not()) {
        switch hoist_sdef.node_type {
        case NodeType.StructDef(h_sdd):
            mut fld_own := OwnType.Shallow
            mut field_type := TilType.None
            if hoist_fi.lt(h_sdd.fields.len()) {
                ref h_fd : Declaration = h_sdd.fields.get(hoist_fi)
                fld_own = h_fd.own_type
                field_type = h_fd.til_type
            }
            if fld_own.is(OwnType.Own).not() {
                if field_type.is(TilType.Struct).or(field_type.is(TilType.Enum)) {
                    continue
                }
            }
            slot_is_own = fld_own.is(OwnType.Own)
        case:
            slot_is_own = get_own_arg(expr, i)
        }
        } else {
            slot_is_own = get_own_arg(expr, i)
        }

        expr.children.set(i, own hoist_to_temp(arg.clone(), hoisted, scope, slot_is_own))
    }
}

hoist_decl_rhs := proc(stmt: Expr, mut hoisted: Vec, mut scope: TypeScope) {
    hoist_expr(stmt.child(0), hoisted, scope)
}

hoist_if_cond := proc(mut stmt: Expr, mut hoisted: Vec, mut scope: TypeScope) {
    hoist_expr(stmt.child(0), hoisted, scope)
    ref cond : Expr = stmt.child(0)
    if cond.node_type.is(NodeType.FCall) {
        stmt.children.set(0, own hoist_to_temp(cond, hoisted, scope, false))
    }
}

hoist_return_expr := proc(mut stmt: Expr, mut hoisted: Vec, mut scope: TypeScope) {
    if stmt.children.len().eq(0) { return }
    hoist_expr(stmt.child(0), hoisted, scope)
    ref rhs : Expr = stmt.child(0)
    if rhs.node_type.is(NodeType.FCall)
    .or(rhs.node_type.is(NodeType.LiteralNum))
    .or(rhs.node_type.is(NodeType.LiteralStr))
    .or(rhs.node_type.is(NodeType.LiteralBool)) {
        stmt.children.set(0, own hoist_to_temp(rhs, hoisted, scope, false))
    }
}

hoist_assign_rhs := proc(mut stmt: Expr, mut hoisted: Vec, mut scope: TypeScope) {
    hoist_expr(stmt.child(0), hoisted, scope)
    mut do_hoist := true
    mut a_name := ""
    switch stmt.node_type {
    case NodeType.Assign(adata):
        a_name = adata.name.clone()
    case:
        UNREACHABLE(__LOC__)
    }
    sf := scope.find(a_name)
    switch sf {
    case ScopeFind.Found(ab):
        if ab.is_param.not() {
            if ab.type.is(TilType.Struct).or(ab.type.is(TilType.Enum)) {
                do_hoist = false
            }
        }
    case:
    }
    ref rhs : Expr = stmt.child(0)
    if do_hoist.and(
        rhs.node_type.is(NodeType.FCall)
        .or(rhs.node_type.is(NodeType.LiteralNum))
        .or(rhs.node_type.is(NodeType.LiteralStr))
        .or(rhs.node_type.is(NodeType.LiteralBool))
    ) {
        stmt.children.set(0, own hoist_to_temp(rhs, hoisted, scope, false))
    }
}

hoist_field_assign_rhs := proc(mut stmt: Expr, mut hoisted: Vec, mut scope: TypeScope) {
    hoist_expr(stmt.child(1), hoisted, scope)
    mut fa_hoist := true
    if fa_own_type(stmt, scope).is(OwnType.Shallow) {
        rhs_type := stmt.child(1).til_type
        if rhs_type.is(TilType.Struct).or(rhs_type.is(TilType.Enum)) {
            fa_hoist = false
        }
    }
    ref rhs : Expr = stmt.child(1)
    if fa_hoist.and(
        rhs.node_type.is(NodeType.FCall)
        .or(rhs.node_type.is(NodeType.LiteralNum))
        .or(rhs.node_type.is(NodeType.LiteralStr))
        .or(rhs.node_type.is(NodeType.LiteralBool))
    ) {
        stmt.children.set(1, own hoist_to_temp(rhs, hoisted, scope, false))
    }
}

hoist_stmt_fcall := proc(mut stmt: Expr, mut hoisted: Vec, mut scope: TypeScope) {
    hoist_expr(stmt, hoisted, scope)
    if stmt.til_type.is(TilType.None).not() {
        hoist_to_temp(stmt, hoisted, scope, false)
        popped : Expr = hoisted.pop()
        stmt = popped
    }
}

// Combine hoist_fcall_args and insert_field_deletes into one body walk.
// Both ran back-to-back over the same body.children, both used the
// prepend-N-then-push-stmt shape, and both ended with a conditional
// reregister_scope_defs. Merging halves the walks/move-outs and avoids
// running reregister twice when only one of the two actually changed
// anything.
//
// owns_scope gates only the hoist half: hoisting registers temp Decls
// in scope so the body must own a scope. insert_field_deletes runs
// unconditionally (just like its standalone predecessor) because it
// doesn't introduce new scope bindings.
//
// Order within a single stmt mirrors the original sequential semantics:
// hoist's temp Decls come first, then (for FieldAssign with a non-trivial
// owned rhs type) the synthesized delete call, then the (possibly
// rewritten) stmt itself.
hoist_and_insert_field_deletes := proc(mut body: Expr, mut scope: TypeScope, shallow do_hoist: I32) {
    // insert_field_deletes-style prefilter: cheaper to walk once than to
    // pay the rebuild when nothing needs deleting AND no hoist is allowed.
    mut needs_delete := false
    for stmt : Expr in body.children {
        if stmt.node_type.is(NodeType.FieldAssign) {
            if field_assign_needs_delete(stmt, scope) {
                ref rhs : Expr = stmt.child(1)
                if type_to_name(rhs.til_type).len().gt(0) {
                    needs_delete = true
                    break
                }
            }
        }
    }
    if do_hoist.eq(0).and(needs_delete.not()) { return }

    mut old := Vec.new("Expr", Expr.size())
    old.move_from(body.children)

    mut new_ch := Vec.new("Expr", Expr.size())
    mut any_hoisted := false
    mut any_field_deleted := false
    for i in 0..old.len() {
        ref stmt : Expr = old.get(i)
        if is_compile_directive(stmt) { continue }

        // hoist_fcall_args: per-stmt dispatch, hoisted temps go first.
        if do_hoist.neq(0) {
            mut hoisted := Vec.new("Expr", Expr.size())
            switch stmt.node_type {
            case NodeType.Decl:
                hoist_decl_rhs(stmt, hoisted, scope)
            case NodeType.FCall:
                hoist_stmt_fcall(stmt, hoisted, scope)
            case NodeType.Return:
                hoist_return_expr(stmt, hoisted, scope)
            case NodeType.Assign:
                hoist_assign_rhs(stmt, hoisted, scope)
                hoist_param_swap_assign(stmt, hoisted, scope)
            case NodeType.FieldAssign:
                hoist_field_assign_rhs(stmt, hoisted, scope)
            case NodeType.If:
                hoist_if_cond(stmt, hoisted, scope)
            case:
                // NodeType.While: skip condition -- hoisting changes loop semantics
            }
            if hoisted.len().gt(0) { any_hoisted = true }
            new_ch.append(own hoisted)
        }

        // insert_field_deletes: prepend the delete call before the
        // FieldAssign stmt (after any hoisted temps).
        if needs_delete.and(stmt.node_type.is(NodeType.FieldAssign)) {
            fot := fa_own_type(stmt, scope)
            if field_assign_needs_delete(stmt, scope) {
                ref rhs : Expr = stmt.child(1)
                if type_to_name(rhs.til_type).len().gt(0) {
                    del := make_field_delete(stmt, fot)
                    new_ch.push(own del)
                    any_field_deleted = true
                }
            }
        }

        new_ch.push_take(old, i)
    }

    body.children.move_from(new_ch)
    if any_hoisted.or(any_field_deleted) {
        reregister_scope_defs(body, scope)
    }
}

rewrite_variadic_fcall_args := func(mut fcall: Expr, va_name: Str) {
    switch fcall.node_type {
    case NodeType.FCall(fcall_data):
        vi := fcall_data.variadic_index
        vc := fcall_data.variadic_count
        old_own := fcall_data.own_args
        line := fcall.line
        col := fcall.col
        mut old_args := Vec.new("Expr", Expr.size())
        old_args.move_from(fcall.children)
        mut fcall_new_ch := Vec.new("Expr", Expr.size())
        mut va_inserted := false
        mut new_own : U64 = 0
        for j in 0..old_args.len() {
            if j.to_i64().to_i32().gte(vi).and(j.to_i64().to_i32().lt(vi.add(vc.to_i64().to_i32()))) {
                if va_inserted.not() {
                    mut va_id := Expr.new(NodeType.Ident(va_name.clone()), line, col)
                    va_id.til_type = TilType.Struct("Array".clone())
                    mut bit : U64 = 1
                    for _ in 0..fcall_new_ch.len() { bit = bit.mul(2) }
                    new_own = new_own.or(bit)
                    fcall_new_ch.push(own va_id)
                    va_inserted = true
                }
                continue
            }
            if j.to_i64().to_i32().eq(vi).and(va_inserted.not()) {
                mut va_id := Expr.new(NodeType.Ident(va_name.clone()), line, col)
                va_id.til_type = TilType.Struct("Array".clone())
                mut bit : U64 = 1
                for _ in 0..fcall_new_ch.len() { bit = bit.mul(2) }
                new_own = new_own.or(bit)
                fcall_new_ch.push(own va_id)
                va_inserted = true
            }
            // Transfer own bit from old position j to new position
            mut old_bit : U64 = 1
            for _ in 0..j { old_bit = old_bit.mul(2) }
            if old_own.and(old_bit).gt(0) {
                mut nb : U64 = 1
                for _ in 0..fcall_new_ch.len() { nb = nb.mul(2) }
                new_own = new_own.or(nb)
            }
            fcall_new_ch.push_take(old_args, j)
        }
        if va_inserted.not() {
            mut va_id := Expr.new(NodeType.Ident(va_name.clone()), line, col)
            va_id.til_type = TilType.Struct("Array".clone())
            mut bit : U64 = 1
            for _ in 0..fcall_new_ch.len() { bit = bit.mul(2) }
            new_own = new_own.or(bit)
            fcall_new_ch.push(own va_id)
        }
        fcall.children.move_from(fcall_new_ch)
        fcall_data.own_args = new_own
        fcall_data.variadic_index = -1.to_i32()
        fcall_data.variadic_count = 0.to_u32()
    case:
        UNREACHABLE(__LOC__)
    }
}

// Combine desugar_variadic_calls and desugar_kwargs_calls. Same shape
// as desugar_body_literals: shared prefilter, shared rebuild, single
// reregister_scope_defs at the end. A stmt can contain BOTH a variadic
// fcall and a kwargs fcall (rare, but legal -- e.g. f(1, 2, k=v)
// where 1,2 are variadic and k=v is kwargs); we apply variadic first
// then kwargs to the same stmt before pushing, matching the original
// sequential order so the kwargs pass sees the variadic-rewritten
// fcall.
resolve_variadic_elem_type := func(fcall: Expr, scope: TypeScope) returns ref Str {
    ref callee : Expr = fcall.child(0)
    switch callee.node_type {
    case NodeType.Ident(callee_name):
        ref cb : TypeBinding = scope.get_binding(callee_name)
        if is_null(cb).not() {
            if is_null(cb.func_def).not() {
                switch cb.func_def.node_type {
                case NodeType.FuncDef(cb_fdef):
                    fvi := cb_fdef.variadic_index
                    if fvi.gte(0) {
                        ref param : Declaration = cb_fdef.params.get(fvi.to_i64().to_usize())
                        return param.explicit_type
                    }
                case:
                }
            }
        }
    case NodeType.FieldAccess(method_name):
        if fa_is_ns(callee, scope) {
            ref type_node : Expr = callee.child(0)
            switch type_node.node_type {
            case NodeType.Ident(type_name):
                ref sdef : Expr = scope.get_struct(type_name)
                if is_null(sdef).not() {
                    ref ns : Vec = def_ns_decls(sdef.child(0))
                    for nd : Declaration in ns {
                        if nd.name.eq(method_name).not() { continue }
                        if is_null(nd.default_value) { break }
                        switch nd.default_value.node_type {
                        case NodeType.FuncDef(ffd):
                            fvi := ffd.variadic_index
                            if fvi.gte(0) {
                                ref param : Declaration = ffd.params.get(fvi.to_i64().to_usize())
                                return param.explicit_type
                            }
                        case:
                        }
                        break
                    }
                }
            case:
            }
        }
    case:
    }
    return NULL
}

// Returns true if it rewrote fcall in place. Caller is responsible for
// pushing the (now mutated) stmt into new_ch.
desugar_pure_splat_variadic_call := func(mut fcall: Expr) returns shallow Bool {
    switch fcall.node_type {
    case NodeType.FCall(fcd):
        vi := fcd.variadic_index
        vc := fcd.variadic_count
        if vc.eq(1).not() { return false }
        if fcd.is_splat.not() { return false }

        mut old_args := Vec.new("Expr", Expr.size())
        old_args.move_from(fcall.children)

        ref splat_in : Expr = old_args.get(vi.to_i64().to_usize())
        mut splat := splat_in.clone()
        fcd.is_splat = false
        if splat_in.node_type.is(NodeType.Ident) {
            splat = make_clone_call("Array", TilType.Struct("Array".clone()), splat_in, splat_in)
        }
        mut fcall_new_ch := Vec.new("Expr", Expr.size())
        for j in 0..old_args.len() {
            ji := j.to_i64().to_i32()
            if ji.eq(vi) {
                fcall_new_ch.push(own splat)
            } else {
                fcall_new_ch.push_take(old_args, j)
            }
        }
        fcall.children.move_from(fcall_new_ch)
        set_own_arg(fcall, vi.to_i64().to_usize())
        fcd.variadic_index = -1.to_i32()
        fcd.variadic_count = 0
        return true
    case:
        UNREACHABLE(__LOC__)
        return false
    }
}

rewrite_kwargs_fcall_args := func(mut fcall: Expr, kw_name: Str) {
    switch fcall.node_type {
    case NodeType.FCall(fcd):
        ki := fcd.kwargs_index
        kc := fcd.kwargs_count
        old_own := fcd.own_args
        mut old_args := Vec.new("Expr", Expr.size())
        old_args.move_from(fcall.children)
        mut fcall_new_ch := Vec.new("Expr", Expr.size())
        mut kw_inserted := false
        mut new_own : U64 = 0

        for j in 0..old_args.len() {
            ji := j.to_i64().to_i32()
            if ji.gte(ki).and(ji.lt(ki.add(kc.to_i64().to_i32()))) {
                if kw_inserted.not() {
                    mut kw_id := Expr.new(NodeType.Ident(kw_name.clone()), fcall.line, fcall.col)
                    kw_id.til_type = TilType.Struct("DynMap".clone())
                    mut bit : U64 = 1
                    for _ in 0..fcall_new_ch.len() { bit = bit.mul(2) }
                    new_own = new_own.or(bit)
                    fcall_new_ch.push(own kw_id)
                    kw_inserted = true
                }
                continue
            }
            if ji.eq(ki).and(kw_inserted.not()) {
                mut kw_id := Expr.new(NodeType.Ident(kw_name.clone()), fcall.line, fcall.col)
                kw_id.til_type = TilType.Struct("DynMap".clone())
                mut bit : U64 = 1
                for _ in 0..fcall_new_ch.len() { bit = bit.mul(2) }
                new_own = new_own.or(bit)
                fcall_new_ch.push(own kw_id)
                kw_inserted = true
            }
            // Transfer own bit from old position j to new position
            mut old_bit : U64 = 1
            for _ in 0..j { old_bit = old_bit.mul(2) }
            if old_own.and(old_bit).gt(0) {
                mut nb : U64 = 1
                for _ in 0..fcall_new_ch.len() { nb = nb.mul(2) }
                new_own = new_own.or(nb)
            }
            fcall_new_ch.push_take(old_args, j)
        }
        if kw_inserted.not() {
            mut kw_id := Expr.new(NodeType.Ident(kw_name.clone()), fcall.line, fcall.col)
            kw_id.til_type = TilType.Struct("DynMap".clone())
            mut bit : U64 = 1
            for _ in 0..fcall_new_ch.len() { bit = bit.mul(2) }
            new_own = new_own.or(bit)
            fcall_new_ch.push(own kw_id)
        }

        fcall.children.move_from(fcall_new_ch)
        fcd.own_args = new_own
        fcd.kwargs_index = -1.to_i32()
        fcd.kwargs_count = 0
    case:
        UNREACHABLE(__LOC__)
    }
}

check_own_args := func(fdef: Expr, fcall: Expr, var_name: Str) returns shallow Bool {
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        if fd.params.len().eq(0) { return false }
        for i in 0..fd.params.len() {
            if i.add(1).gte(fcall.children.len()) { return false }
            ref p : Declaration = fd.params.get(i)
            if p.own_type.is(OwnType.Own) {
                ref arg : Expr = fcall.child(i.add(1))
                switch arg.node_type {
                case NodeType.Ident(_ai):
                    if _ai.eq(var_name) { return true }
                case:
                }
            }
        }
        return false
    case:
        return false
    }
}

fcall_has_own_arg := func(fcall: Expr, var_name: Str, scope: TypeScope) returns shallow Bool {
    if fcall.node_type.is(NodeType.FCall).not() { return false }
    if fcall.children.len().lt(2) { return false }
    // Struct constructor
    fcall_sname := til_type_name(fcall.til_type)
    if fcall_sname.len().gt(0) {
        switch fcall.child(0).node_type {
        case NodeType.Ident(_c0s):
            if _c0s.eq(fcall_sname) {
                ref sdef : Expr = scope.get_struct(fcall_sname)
                if is_null(sdef).not() {
                    switch sdef.node_type {
                    case NodeType.StructDef(fhoa_sdd):
                        for fi in 0..fhoa_sdd.fields.len() {
                            ref fld_decl : Declaration = fhoa_sdd.fields.get(fi)
                            arg_idx := fi.add(1)
                            if arg_idx.lt(fcall.children.len()) {
                                ref arg : Expr = fcall.child(arg_idx)
                                switch arg.node_type {
                                case NodeType.Ident(_an):
                                    if _an.eq(var_name).and(fld_decl.own_type.is(OwnType.Ref).not()) {
                                        if fld_decl.own_type.is(OwnType.Own).or(type_ctor_consumes(fld_decl.til_type)) {
                                            return true
                                        }
                                    }
                                case:
                                }
                            }
                        }
                    case:
                    }
                }
            }
        case:
        }
    }
    // Direct call
    switch fcall.child(0).node_type {
    case NodeType.Ident(fn_name):
        ref fb : TypeBinding = scope.get_binding(fn_name)
        if is_null(fb).not() {
            if is_null(fb.func_def) { return false }
            return check_own_args(fb.func_def, fcall, var_name)
        }
        return false
    case NodeType.FieldAccess(method):
        // Namespace method call
        if fa_is_ns(fcall.child(0), scope) {
            ref type_node : Expr = fcall.child(0).child(0)
            switch type_node.node_type {
            case NodeType.Ident(_tn):
                ref sdef : Expr = scope.get_struct(_tn)
                if is_null(sdef) { return false }
                ref oa_ns : Vec = def_ns_decls(sdef)
                for fd : Declaration in oa_ns {
                    if fd.name.eq(method) {
                        if is_null(fd.default_value).not().and(fd.default_value.node_type.is(NodeType.FuncDef)) {
                            return check_own_args(fd.default_value, fcall, var_name)
                        }
                    }
                }
            case:
            }
        }
    case:
    }
    return false
}

expr_transfers_own := func(e: Expr, var_name: Str, scope: TypeScope) returns shallow Bool {
    if e.node_type.is(NodeType.FuncDef) { return false }
    if fcall_has_own_arg(e, var_name, scope) { return true }
    if e.node_type.is(NodeType.FieldAssign).and(fa_own_type(e, scope).is(OwnType.Shallow).not()) {
        if e.children.len().gt(1) {
            switch e.child(1).node_type {
            case NodeType.Ident(_ei):
                if _ei.eq(var_name) { return true }
            case:
            }
        }
    }
    for e_i : Expr in e.children {
        if expr_transfers_own(e_i, var_name, scope) { return true }
    }
    return false
}

expr_is_borrow_source := func(e: Expr, scope: TypeScope) returns shallow Bool {
    if is_null(e) { return false }
    if e.node_type.is(NodeType.LiteralNull) { return true }
    if e.node_type.is(NodeType.FCall).and(fcall_returns_ref(e, scope).neq(0)) { return true }
    switch e.node_type {
    case NodeType.Ident(id):
        sf := scope.find(id)
        switch sf {
        case ScopeFind.Found(b):
            if b.own_type.is(OwnType.Ref).or(b.is_param) { return true }
            // Owned compound locals are pointers in C -- valid borrow source
            if b.type.is(TilType.Struct).or(b.type.is(TilType.Enum)) { return true }
        case:
        }
    case:
    }
    if e.node_type.is(NodeType.FieldAccess) {
        if fa_is_ns(e, scope) { return false }
        return expr_is_borrow_source(e.child(0), scope)
    }
    return false
}

expr_is_stable_field_base := func(e: Expr, scope: TypeScope) returns shallow Bool {
    if is_null(e) { return false }
    if expr_is_borrow_source(e, scope) { return true }
    switch e.node_type {
    case NodeType.Ident(id):
        sf := scope.find(id)
        switch sf {
        case ScopeFind.Found(b):
            if is_null(b.func_def).not() { return false }
            if is_null(b.struct_def).not() { return false }
            return true
        case:
            return false
        }
    case:
    }
    if e.node_type.is(NodeType.FieldAccess) {
        if fa_is_ns(e, scope) { return false }
        return expr_is_stable_field_base(e.child(0), scope)
    }
    return false
}

expr_is_ref_decl_source := func(e: Expr, scope: TypeScope) returns shallow Bool {
    if is_null(e) { return false }
    if expr_is_borrow_source(e, scope) { return true }
    if e.node_type.is(NodeType.FieldAccess) {
        if fa_is_ns(e, scope) { return false }
        return expr_is_stable_field_base(e.child(0), scope)
    }
    return false
}

field_assign_needs_delete := func(stmt: Expr, scope: TypeScope) returns shallow Bool {
    if fa_own_type(stmt, scope).is(OwnType.Ref) { return false }
    if fa_own_type(stmt, scope).is(OwnType.Shallow).not() { return true }
    ft := stmt.child(1).til_type
    if ft.is(TilType.Struct).or(ft.is(TilType.Enum)) { return true }
    return false
}

alias_used_in_stmts := func(stmts: Vec, name: Str, expr: Expr) returns shallow Bool {
    for d : Expr in stmts {
        switch d.node_type {
        case NodeType.Decl(dd):
            if dd.own_type.is(OwnType.Ref).and(d.children.len().gt(0)) {
                switch d.child(0).node_type {
                case NodeType.Ident(_di):
                    if _di.eq(name) {
                        if expr_uses_var(expr, dd.name) { return true }
                    }
                case:
                }
            }
        case:
        }
    }
    return false
}

collect_scope_locals := func(body: Expr, scope: TypeScope, shallow is_program_scope: Bool, mut locals_vec: Vec) {
    for i in 0..scope.bindings.len() {
        ref b : TypeBinding = Map.val_ptr(scope.bindings, i)
        if b.is_param.and(b.own_type.is(OwnType.Own).not()) { continue }
        if is_null(b.struct_def).not() { continue }
        if is_null(b.func_def).not() { continue }

        mut decl_idx := -1.to_i32()
        for j in 0..body.children.len() {
            ref s : Expr = body.child(j)
            switch s.node_type {
            case NodeType.Decl(dd):
                if dd.name.eq(b.name) {
                    decl_idx = j.to_i64().to_i32()
                    break
                }
            case:
            }
        }
        if decl_idx.eq(-1.to_i32()) {
            for j in 0..body.children.len() {
                if expr_contains_decl(body.child(j), b.name) {
                    decl_idx = j.to_i64().to_i32()
                    break
                }
            }
        }

        mut last_use := -1.to_i32()
        mut own_transfer := -1.to_i32()
        mut scan_from : USize = 0
        if decl_idx.gte(0) {
            scan_from = decl_idx.add(1).to_i64().to_usize()
        }
        for j in scan_from..body.children.len() {
            ref stmt : Expr = body.child(j)
            if is_compile_directive(stmt) { continue }
            if expr_uses_var(stmt, b.name) {
                last_use = j.to_i64().to_i32()
            }
            if own_transfer.eq(-1.to_i32()) {
                if expr_transfers_own(stmt, b.name, scope) {
                    own_transfer = j.to_i64().to_i32()
                }
            }
        }

        mut skip_scope_delete := is_program_scope.and(decl_idx.gte(0))
        if skip_scope_delete.not() {
            for j in scan_from..body.children.len() {
                if is_compile_directive(body.child(j)) { continue }
                if expr_used_in_nested_func(body.child(j), b.name) {
                    skip_scope_delete = true
                    break
                }
            }
        }
        if b.own_type.is(OwnType.Ref) { skip_scope_delete = true }

        mut li := LocalInfo()
        li.name = b.name
        li.type = b.type
        li.decl_index = decl_idx
        li.last_use = last_use
        li.own_transfer = own_transfer
        li.skip_scope_delete = skip_scope_delete
        li.is_heap = b.own_type.is(OwnType.Own).and(b.is_param.not())
        locals_vec.push(own li)
    }
}

extend_ref_local_lifetimes := func(mut body: Expr, mut locals: Vec) {
    mut ref_changed := true
    while ref_changed {
        ref_changed = false
        for i in 0..body.children.len() {
            ref mut stmt : Expr = body.child(i)
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            mut dd_name := ""
            mut dd_is_ref := false
            switch stmt.node_type {
            case NodeType.Decl(dd):
                dd_name = dd.name.clone()
                dd_is_ref = dd.own_type.is(OwnType.Ref)
            case:
            }
            if dd_is_ref.not() { continue }
            ref mut rhs : Expr = stmt.child(0)

            mut ref_last := -1.to_i32()
            for j in i.add(1)..body.children.len() {
                if expr_uses_var(body.child(j), dd_name) {
                    ref_last = j.to_i64().to_i32()
                }
            }
            if ref_last.eq(-1.to_i32()) { ref_last = i.to_i64().to_i32() }
            for local : LocalInfo in locals {
                if local.name.eq(dd_name).and(local.last_use.gt(ref_last)) {
                    ref_last = local.last_use
                }
            }

            switch rhs.node_type {
            case NodeType.Ident(src_name):
                for local : LocalInfo in locals {
                    if local.name.eq(src_name).and(local.last_use.lt(ref_last)) {
                        local.last_use = ref_last
                        ref_changed = true
                    }
                }
                continue
            case:
            }
            if rhs.node_type.is(NodeType.FieldAccess) {
                ref mut root : Expr = rhs
                while root.node_type.is(NodeType.FieldAccess).and(root.children.len().gt(0)) {
                    root = root.child(0)
                }
                switch root.node_type {
                case NodeType.Ident(src_name):
                    for local : LocalInfo in locals {
                        if local.name.eq(src_name).and(local.last_use.lt(ref_last)) {
                            local.last_use = ref_last
                            ref_changed = true
                        }
                    }
                case:
                }
                continue
            }
            if rhs.node_type.is(NodeType.FCall).not() { continue }
            for a in 1..rhs.children.len() {
                ref mut arg : Expr = rhs.child(a)
                while arg.node_type.is(NodeType.FieldAccess).and(arg.children.len().gt(0)) {
                    arg = arg.child(0)
                }
                switch arg.node_type {
                case NodeType.Ident(aname):
                    for local : LocalInfo in locals {
                        if local.name.eq(aname).and(local.last_use.lt(ref_last)) {
                            local.last_use = ref_last
                            ref_changed = true
                        }
                    }
                case:
                }
            }
        }
    }
}

check_use_after_own_transfer := proc(body: Expr, mut locals: Vec) {
    for local : LocalInfo in locals {
        if local.own_transfer.gte(0).and(local.last_use.gt(local.own_transfer)) {
            ref stmt : Expr = body.child(local.last_use.to_i64().to_usize())
            type_error(stmt, "use of '".concat(local.name).concat("' after ownership transfer"))
            ref xfer : Expr = body.child(local.own_transfer.to_i64().to_usize())
            println(typer_path, ":", xfer.line.to_str(), ":", xfer.col.to_str(), ": note: ownership transferred here")
            println("  help: pass a clone instead: own ", local.name, ".clone()")
        }
    }
}

insert_exit_deletes := proc(mut body: Expr, mut live: Vec, shallow return_only: Bool) {
    // Quick check: any returns/breaks/continues or nested if/while/body?
    mut needs_scan := false
    for s : Expr in body.children {
        if s.node_type.is(NodeType.Return).or(s.node_type.is(NodeType.If)).or(s.node_type.is(NodeType.While)).or(s.node_type.is(NodeType.Body)) {
            needs_scan = true
            break
        }
        if return_only.not().and(s.node_type.is(NodeType.Break).or(s.node_type.is(NodeType.Continue))) {
            needs_scan = true
            break
        }
    }
    if needs_scan.not() { return }

    mut old := Vec.new("Expr", Expr.size())
    old.move_from(body.children)

    mut new_ch := Vec.new("Expr", Expr.size())
    for i in 0..old.len() {
        ref stmt : Expr = old.get(i)
        if is_compile_directive(stmt) { continue }
        if stmt.node_type.is(NodeType.If) {
            for c in 1..stmt.children.len() {
                insert_exit_deletes(stmt.child(c), live, return_only)
            }
        }
        if stmt.node_type.is(NodeType.While) {
            insert_exit_deletes(stmt.child(1), live, true)
        }
        if stmt.node_type.is(NodeType.Body) {
            insert_exit_deletes(stmt, live, return_only)
        }
        if stmt.node_type.is(NodeType.Return).or(return_only.not().and(stmt.node_type.is(NodeType.Break).or(stmt.node_type.is(NodeType.Continue)))) {
            for local : LocalInfo in live {
                if stmt.children.len().gt(0) {
                    ref retval : Expr = stmt.child(0)
                    if expr_uses_var(retval, local.name).or(alias_used_in_stmts(old, local.name, retval)) {
                        continue
                    }
                }
                if type_to_name(local.type).len().gt(0) {
                    heap := local.is_heap
                    del := make_delete_call(local.name, local.type, heap, heap, stmt)
                    new_ch.push(own del)
                }
            }
        }
        new_ch.push_take(old, i)
    }
    body.children.move_from(new_ch)
}

insert_nested_exit_deletes := proc(stmt: Expr, mut locals: Vec, shallow stmt_idx: U32) {
    if stmt.node_type.is(NodeType.If).not() {
        if stmt.node_type.is(NodeType.While).not() {
            if stmt.node_type.is(NodeType.Body).not() { return }
        }
    }
    mut live_vec := Vec.new("LocalInfo", LocalInfo.size())
    for local : LocalInfo in locals {
        if local.skip_scope_delete { continue }
        if local.own_transfer.gte(0) { continue }
        if local.decl_index.lt(stmt_idx.to_i64().to_i32()) {
            if local.last_use.gte(stmt_idx.to_i64().to_i32()).or(local.last_use.eq(-1.to_i32())) {
                live_vec.push(own local.clone())
            }
        }
    }
    if live_vec.len().gt(0) {
        switch stmt.node_type {
        case NodeType.If:
            for c in 1..stmt.children.len() {
                insert_exit_deletes(stmt.child(c), live_vec, false)
            }
        case NodeType.While:
            insert_exit_deletes(stmt.child(1), live_vec, true)
        case:
            // NodeType.Body -- desugared for-in wraps its decls + while in a Body block
            insert_exit_deletes(stmt, live_vec, true)
        }
    }
}

insert_exit_deletes_into_stmt := func(stmt: Expr, body_stmts: Vec, mut locals: Vec, shallow stmt_idx: U32, mut new_ch: Vec) {
    if stmt.node_type.is(NodeType.Return).not() {
        if stmt.node_type.is(NodeType.Break).not() {
            if stmt.node_type.is(NodeType.Continue).not() { return }
        }
    }
    for local : LocalInfo in locals {
        if stmt.children.len().gt(0) {
            ref retval : Expr = stmt.child(0)
            if expr_uses_var(retval, local.name).or(alias_used_in_stmts(body_stmts, local.name, retval)) {
                continue
            }
        }
        if local.skip_scope_delete { continue }
        if local.own_transfer.gte(0) { continue }
        if local.decl_index.lt(stmt_idx.to_i64().to_i32()) {
            if local.last_use.gte(stmt_idx.to_i64().to_i32()).or(local.last_use.eq(-1.to_i32())) {
                if type_to_name(local.type).len().gt(0) {
                    heap := local.is_heap
                    del := make_delete_call(local.name, local.type, heap, heap, stmt)
                    new_ch.push(own del)
                }
            }
        }
    }
}

insert_post_stmt_deletes := func(stmt: Expr, mut locals: Vec, shallow stmt_idx: U32, mut new_ch: Vec, scope: TypeScope) {
    if stmt.node_type.is(NodeType.Return).or(stmt.node_type.is(NodeType.Break)).or(stmt.node_type.is(NodeType.Continue)) {
        return
    }
    for local : LocalInfo in locals {
        if local.skip_scope_delete { continue }
        if local.own_transfer.gte(0) {
            // Ownership transferred via value-copy to a Shallow struct field
            // (e.g. `Decl(name = local, ...)` where Declaration.name has the
            // default Shallow ownership) leaves the local's heap wrapper
            // orphaned: the field gets a bit-copy of *local, the field's own
            // destructor frees the inner data, but nothing frees the wrapper.
            // Skipping the delete entirely (the previous behavior) leaks the
            // wrapper. Emit a raw `free(local)` after the transfer stmt to
            // release the wrapper without touching the inner data.
            //
            // This only fires when the transfer is a struct constructor with
            // the receiving field declared Shallow. Other transfer shapes
            // (`free(own X)`, `Type.delete(own X, ...)`, `field = X` where the
            // field is Own/Ref, passing X as `own` arg to a function that
            // takes ownership of the wrapper) already consume the wrapper, so
            // adding a `free` here would double-free.
            if local.is_heap.and(local.type.is(TilType.Struct)) {
                if local.own_transfer.eq(stmt_idx.to_i64().to_i32()) {
                    if type_to_name(local.type).len().gt(0) {
                        if transfer_is_shallow_field_value_copy(stmt, local.name, scope) {
                            free_call := make_free_call(local.name, local.type, stmt)
                            if is_null(free_call).not() {
                                new_ch.push(own free_call)
                            }
                        }
                    }
                }
            }
            continue
        }
        if local.last_use.eq(stmt_idx.to_i64().to_i32()) {
            if type_to_name(local.type).len().gt(0) {
                heap := local.is_heap
                del := make_delete_call(local.name, local.type, heap, heap, stmt)
                new_ch.push(own del)
            }
        }
        if local.last_use.eq(-1.to_i32()).and(local.decl_index.eq(stmt_idx.to_i64().to_i32())) {
            if type_to_name(local.type).len().gt(0) {
                heap := local.is_heap
                del := make_delete_call(local.name, local.type, heap, heap, stmt)
                new_ch.push(own del)
            }
        }
    }
}

insert_assign_delete := func(mut stmt: Expr, mut locals: Vec, mut new_ch: Vec) {
    switch stmt.node_type {
    case NodeType.Assign(ad):
        vname := ad.name
        for local : LocalInfo in locals {
            if local.name.eq(vname).not() { continue }
            if local.type.is(TilType.Struct).or(local.type.is(TilType.Enum)) {
                ref rhs : Expr = stmt.child(0)
                if expr_uses_var(rhs, vname) {
                    ad.save_old_delete = true
                    stmt.til_type = local.type.clone()
                } else {
                    if type_to_name(local.type).len().gt(0) {
                        heap := local.is_heap
                        del := make_delete_call(local.name, local.type, heap, heap, stmt)
                        new_ch.push(own del)
                    }
                }
            }
            break
        }
    case:
    }
}

promote_own_transferred_locals := func(mut body: Expr, mut locals: Vec) {
    for local : LocalInfo in locals {
        if local.decl_index.lt(0.to_i32()) { continue }
        ref stmt : Expr = body.child(local.decl_index.to_i64().to_u32())
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        switch stmt.node_type {
        case NodeType.Decl(dd):
        if dd.own_type.is(OwnType.Ref) { continue }
        is_struct := local.type.is(TilType.Struct)
        if local.own_transfer.lt(0.to_i32()).and(is_struct.not()) { continue }
        dd.own_type = OwnType.Own
        local.is_heap = true
        case:
        }
    }
}

insert_free_calls := proc(mut body: Expr, mut scope: TypeScope, shallow scope_exit: I32) {
    if scope_exit.eq(0) { return }
    is_program_scope := is_null(scope.parent)

    mut locals_vec := Vec.new("LocalInfo", LocalInfo.size())
    collect_scope_locals(body, scope, is_program_scope, locals_vec)
    if locals_vec.len().eq(0) { return }

    extend_ref_local_lifetimes(body, locals_vec)
    check_use_after_own_transfer(body, locals_vec)
    promote_own_transferred_locals(body, locals_vec)

    mut old := Vec.new("Expr", Expr.size())
    old.move_from(body.children)

    mut new_ch := Vec.new("Expr", Expr.size())
    for i in 0..old.len() {
        ref stmt : Expr = old.get(i)
        if is_compile_directive(stmt) { continue }
        insert_exit_deletes_into_stmt(stmt, old, locals_vec, i.to_i64().to_u32(), new_ch)
        insert_nested_exit_deletes(stmt, locals_vec, i.to_i64().to_u32())
        insert_assign_delete(stmt, locals_vec, new_ch)
        mut post_deletes := Vec.new("Expr", Expr.size())
        insert_post_stmt_deletes(stmt, locals_vec, i.to_i64().to_u32(), post_deletes, scope)
        new_ch.push_take(old, i)
        new_ch.append(own post_deletes)
    }

    body.children.move_from(new_ch)
    reregister_scope_defs(body, scope)
}

infer_literal_expr := func(mut expr: Expr) {
    switch expr.node_type {
    case NodeType.LiteralStr:
        expr.til_type = TilType.Struct("Str".clone())
    case NodeType.LiteralNum:
        if expr.til_type.is(TilType.U8).not() {
            expr.til_type = TilType.I64
        }
    case NodeType.LiteralBool:
        expr.til_type = TilType.Bool
    case NodeType.LiteralNull:
        expr.til_type = TilType.Dynamic
    case:
    }
}

narrow_dynamic := func(mut expr: Expr, target: TilType) {
    if expr.til_type.is(TilType.Dynamic).not() { return }
    if target.is(TilType.Dynamic) { return }
    if target.is(TilType.Unknown) { return }
    expr.til_type = target
}

fcall_returns_ref := func(fcall: Expr, scope: TypeScope) returns shallow I32 {
    if fcall.node_type.is(NodeType.FCall).not() { return 0.to_i32() }
    if fcall.children.len().eq(0) { return 0.to_i32() }
    ref callee : Expr = fcall.child(0)
    switch callee.node_type {
    case NodeType.Ident(_cn):
        ref cb : TypeBinding = scope.get_binding(_cn)
        if is_null(cb).not() {
            if is_null(cb.func_def) { return 0.to_i32() }
            switch cb.func_def.node_type {
            case NodeType.FuncDef(_cfd):
                return _cfd.return_own_type.is(OwnType.Ref)
            case:
                return 0.to_i32()
            }
        }
        return 0.to_i32()
    case NodeType.FieldAccess(_cfa):
        if fa_is_ns(callee, scope) {
            switch callee.child(0).node_type {
            case NodeType.Ident(_cti):
                ref sdef : Expr = scope.get_struct(_cti)
                if is_null(sdef) { return 0.to_i32() }
                ref cfa_ns : Vec = def_ns_decls(sdef)
                for fd : Declaration in cfa_ns {
                    if fd.name.eq(_cfa) {
                        if is_null(fd.default_value).not() {
                            switch fd.default_value.node_type {
                            case NodeType.FuncDef(_ffd):
                                return _ffd.return_own_type.is(OwnType.Ref)
                            case:
                            }
                        }
                    }
                }
            case:
            }
        }
    case:
    }
    return 0.to_i32()
}

hoist_to_temp := func(val: Expr, mut hoisted: Vec, mut scope: TypeScope, shallow is_own: Bool) returns Expr {
    tp := type_prefix(val.til_type)
    tname := "_t_".concat(tp).concat("_").concat(hoist_counter.to_str())
    hoist_counter++

    mut decl := Expr.new(NodeType.Decl(Declaration()), val.line, val.col)
    decl.til_type = val.til_type

    mut val_is_ref := false
    if val.node_type.is(NodeType.FCall) {
        val_is_ref = fcall_returns_ref(val, scope).eq(0).not()
    }

    is_compound := val.til_type.is(TilType.Struct).or(val.til_type.is(TilType.Enum))

    decl.add_child(own val.clone())

    mut ident := Expr.new(NodeType.Ident(tname.clone()), val.line, val.col)
    ident.til_type = val.til_type
    scope.set(tname, val.til_type, FuncType.None, false, typer_path, val.line, val.col, false, OwnType.Shallow)
    ref mut tb : TypeBinding = scope.get_binding(tname)
    switch decl.node_type {
    case NodeType.Decl(dd):
        dd.name = tname.clone()
        dd.is_mut = false
        if val_is_ref {
            dd.own_type = OwnType.Ref
            if is_null(tb).not() { tb.own_type = OwnType.Ref }
        } else if is_own.or(is_compound) {
            dd.own_type = OwnType.Own
            if is_null(tb).not() { tb.own_type = OwnType.Own }
        }
    case:
        UNREACHABLE(__LOC__)
    }

    hoisted.push(own decl)
    return ident
}

type_check := proc(program: Expr, scope: TypeScope, ctx: Context) returns shallow I32 {
    errors = 0.to_i32()
    infer_body(scope, program, 0, 1, 0, 0, 0, ctx)
    return errors
}
