mode lib

// Check if a FieldAccess/FieldAssign Expr accesses a namespace field.
fa_is_ns := func(e: Expr, scope: TypeScope) returns Bool {
    if e.children.len().eq(0) { return false }
    if e.node_type.is(NodeType.FieldAccess).not().and(e.node_type.is(NodeType.FieldAssign).not()) { return false }
    ref obj : Expr = e.child(0)
    mut sn := til_type_name(obj.expr_til_type())
    if sn.len().eq(0) {
        switch obj.node_type {
        case NodeType.Ident(id):
            sn = id.ident_name()
        case:
            return false
        }
    }
    ref sdef : Expr = scope.get_struct(sn)
    if sdef.is_null() { return false }
    mut fname := ""
    switch e.node_type {
    case NodeType.FieldAccess(fn):
        fname = fn.field_access_name()
    case NodeType.FieldAssign(fad):
        fname = fad.name
    case:
        UNREACHABLE(__LOC__)
        return false
    }
    ref ns : Vec = def_ns_decls(sdef)
    for dd : Declaration in ns {
        if dd.name.eq(fname) { return true }
    }
    return false
}

type_binding_is_type_token := func(b: TypeBinding) returns Bool {
    if b.is_null() { return false }
    if b.is_type_alias { return true }
    if b.is_builtin { return true }
    if b.struct_def.is_null().not() { return true }
    if b.func_def.is_null().not() {
        if b.func_def.children.len().eq(0) { return true }
    }
    return false
}

make_til_type_expr := func(src: Expr, t: Type) returns Expr {
    mut variant_name := ""
    mut payload_name := ""
    mut has_payload := false
    // Variants stored under Type.Primitive(Primitive.X) need a nested
    // construction `Type.Primitive(Primitive.X)`, not a bare
    // `Type.X` (Type has no such field). Built below after the switch.
    mut primitive_variant := ""
    switch t {
    case Type.Unknown:   variant_name = "Unknown"
    case Type.None:      variant_name = "None"
    case Type.I64:       variant_name = "I64"
    case Type.U8:        variant_name = "U8"
    case Type.I8:        variant_name = "I8"
    case Type.Primitive(Primitive.I16):       primitive_variant = "I16"
    case Type.Primitive(Primitive.U16):       primitive_variant = "U16"
    case Type.I32:       variant_name = "I32"
    case Type.U32:       variant_name = "U32"
    case Type.U64:       variant_name = "U64"
    case Type.F32:       variant_name = "F32"
    case Type.Bool:      variant_name = "Bool"
    case Type.Struct(s): variant_name = "Struct"; payload_name = s.clone(); has_payload = true
    case Type.StructDef: variant_name = "StructDef"
    case Type.Enum(s):   variant_name = "Enum"; payload_name = s.clone(); has_payload = true
    case Type.EnumDef:   variant_name = "EnumDef"
    case Type.FuncDef:   variant_name = "FuncDef"
    case Type.FuncPtr:   variant_name = "FuncPtr"
    case Type.Dynamic:   variant_name = "Dynamic"
    case Type.Custom(s): variant_name = "Custom"; payload_name = s.clone(); has_payload = true
    }
    if primitive_variant.len().gt(0) {
        // Build Type.Primitive(Primitive.<primitive_variant>).
        mut type_ident_p := Expr.new(ident_node("Type"), src.line, src.col)
        type_ident_p.set_expr_til_type(Type.Enum("Type"))
        mut prim_ident := Expr.new(ident_node("Primitive"), src.line, src.col)
        prim_ident.set_expr_til_type(Type.Enum("Primitive"))
        mut prim_fa := Expr.new(field_access_node(primitive_variant), src.line, src.col)
        prim_fa.add_child(own prim_ident)
        prim_fa.set_expr_til_type(Type.Enum("Primitive"))
        mut type_prim_fa := Expr.new(field_access_node("Primitive"), src.line, src.col)
        type_prim_fa.add_child(own type_ident_p)
        type_prim_fa.set_expr_til_type(Type.Unknown)
        mut call := Expr.new(NodeType.FCall(FCallData()), src.line, src.col)
        call.add_child(own type_prim_fa)
        call.add_child(own prim_fa)
        call.set_expr_til_type(Type.Enum("Type"))
        return call
    }
    mut type_ident := Expr.new(ident_node("Type"), src.line, src.col)
    type_ident.set_expr_til_type(Type.Enum("Type"))
    mut fa := Expr.new(field_access_node(variant_name), src.line, src.col)
    fa.add_child(own type_ident)
    if has_payload.not() {
        fa.set_expr_til_type(Type.Enum("Type"))
        return fa
    }
    fa.set_expr_til_type(Type.Unknown)
    mut call := Expr.new(NodeType.FCall(FCallData()), src.line, src.col)
    call.add_child(own fa)
    mut payload := Expr.new(NodeType.Literal(Literal.Str(payload_name)), src.line, src.col)
    call.add_child(own payload)
    call.set_expr_til_type(Type.Enum("Type"))
    return call
}

rewrite_til_type_arg := proc(scope: TypeScope, mut arg: Expr, ptype: Type, in_func: I32, ctx: Context) {
    if ptype.is(Type.Enum("Type")).not() { return }
    switch arg.node_type {
    case NodeType.Ident(arg_name):
        ref b : TypeBinding = scope.get_binding(arg_name.ident_name())
        if type_binding_is_type_token(b).not() { return }
        mut replacement := arg.make_til_type_expr(b.type)
        move(arg, replacement, Expr.size())
        infer_expr(scope, arg, in_func, ctx)
    case:
    }
}

// Look up the OwnType for the instance field of a FieldAccess/FieldAssign.
fa_own_type := func(e: Expr, scope: TypeScope) returns shallow OwnType {
    if e.children.len().eq(0) { return OwnType.Shallow }
    if e.node_type.is(NodeType.FieldAccess).not().and(e.node_type.is(NodeType.FieldAssign).not()) { return OwnType.Shallow }
    ref obj : Expr = e.child(0)
    mut sn := til_type_name(obj.expr_til_type())
    if sn.len().eq(0) {
        switch obj.node_type {
        case NodeType.Ident(id):
            sn = id.ident_name()
        case:
            return OwnType.Shallow
        }
    }
    ref sdef : Expr = scope.get_struct(sn)
    if sdef.is_null() { return OwnType.Shallow }
    mut fname := ""
    switch e.node_type {
    case NodeType.FieldAccess(fn):
        fname = fn.field_access_name()
    case NodeType.FieldAssign(fad):
        fname = fad.name
    case:
        UNREACHABLE(__LOC__)
        return OwnType.Shallow
    }
    switch sdef.node_type {
    case NodeType.StructDef(ot_sdd):
        for dd : Declaration in ot_sdd.fields {
            if dd.name.eq(fname) { return dd.own_type }
        }
    case:
    }
    return OwnType.Shallow
}

// hoist_counter / va_counter / kw_counter / coll_counter previously
// lived here as module-level mut; they moved to Context (see
// initer.til). The hoist/desugar pre-pass chain (body_pre_passes ->
// apply_call_hoist_delete -> process_call_desugars +
// apply_hoist_to_stmt -> hoist_to_temp / hoist_expr / ...) threads
// `mut ctx: Context` so the same Context that already owns the rest
// of the typer scratch state also owns these unique-name counters.
// proc_calls_count / proc_def_depth previously lived here as
// module-level mut; they moved to Context (see initer.til). The
// typer reads/writes via ctx.proc_calls_count / ctx.proc_def_depth.
// errors / current_type_name / current_top_func_name / auto_gen_depth /
// throw_used_local_names likewise moved onto Context (see initer.til);
// helpers with ctx in scope use ctx.<field>, and the leaf diagnostics
// (type_error / type_error_at) reach it via ctx.
// Issue #93 follow-up: name of the top-level Decl whose body we are
// currently typing (function rhs or struct/enum that contains the
// active ns method body via current_type_name). Lifted nested defs
// carry their original parent in TypeBinding.orig_name; the function-
// scope priv check uses these two tracking globals to decide whether
// a reference at the current location is allowed to see the mangled
// name (only the original parent function and any of its other lifted
// descendants can). current_top_func_name now lives on Context.
// Issue #198: the throw_type_registry / throws_names_global /
// throws_per_global tables previously declared here moved onto the
// `Context` struct (see initer.til) so cross-unit typer state lives
// on the same ctx everything else threads through. The accessors
// below take `ctx` and the body-walk helpers thread it down.
// #187 step 2: nesting depth of auto-generated FuncDef bodies
// (clone/delete/size/etc emitted by initer). The unused-priv-member
// check ignores reads inside these so genuinely-unused priv fields
// and ns methods are not masked by boilerplate references.
// auto_gen_depth / throw_used_local_names now live on Context.
// typer_in_shallow_return / typer_in_main_func previously lived as
// module-level mut here. They moved to Context (see initer.til) since
// garbager.til reads them and the garbager entry points already thread
// ctx. infer_func_def_expr writes ctx.typer_in_* while typing each
// body; collect_scope_locals / promote_own_transferred_locals read
// them through ctx.
I64Name := "I64"
U8Name := "U8"
I8Name := "I8"
I16Name := "I16"
U16Name := "U16"
I32Name := "I32"
U32Name := "U32"
U64Name := "U64"
F32Name := "F32"
BoolName := "Bool"

// Free the heap allocations inside an Expr that lives inline in a Vec
// buffer. Used before children.set(...) replaces a slot so the prior Expr
// payload does not leak. Non-priv so the garbager module
// (src/self/garbager.til) can reuse it from insert_post_stmt_deletes.
free_expr_slot_in_place := func(mut e: Expr) {
    Type.delete(own e.expr_til_type(), true)
    NodeType.delete(own e.node_type, false)
    Vec.delete(own e.children, false)
}

priv CtorArg := enum {
    Unfilled,
    Filled: Expr,
}

// Issue #200: per-arm coverage trie for nested switch exhaustiveness.
// Each node corresponds to one enum's variants. ~fully_covered~ means the
// pattern bound the entire value at this level (e.g. ~case X.A(v):~ or
// ~case X.A:~) so no inner walk is needed. Otherwise the parallel vecs
// ~sub_names~ / ~sub_nodes~ hold per-variant child coverage; an empty
// ~sub_nodes~ entry means "the variant's payload was never decomposed"
// and is only fully_covered iff its own ~fully_covered~ bit is set.
priv CoverageNode := struct {
    fully_covered := false
    sub_names := Vec.new(Str)
    sub_nodes := Vec.new(CoverageNode)
}

// Seed a node with empty per-variant sub-coverage for an enum_def.
priv init_coverage_for_enum := func(mut node: CoverageNode, enum_def: Expr) {
    if enum_def.is_null() { return }
    switch enum_def.node_type {
    case NodeType.EnumDef(cn_edd):
        for cvi in 0..cn_edd.variants.len() {
            ref vn : Str = cn_edd.variants[cvi]
            node.sub_names.push(own vn.clone())
            node.sub_nodes.push(own CoverageNode())
        }
    case:
    }
}

priv coverage_sub_index := func(coverage: CoverageNode, variant_name: Str) returns I32 {
    for csi in 0..coverage.sub_names.len() {
        ref n : Str = coverage.sub_names[csi]
        if n.eq(variant_name) { return csi.cast(I32) }
    }
    return -1
}

// Read-only mirror of mark_pattern_coverage: true iff every value the
// pattern could match has already been captured by an earlier (unguarded)
// arm in this switch -- i.e. the arm carrying this pattern is dead.
// Patterns the trie doesn't statically describe (value literals, struct
// patterns, non-enum subjects) return false so a more permissive checker
// or guard-protected arm doesn't get a false positive.
priv is_pattern_covered := func(scope: TypeScope, coverage: CoverageNode, expected_type_name: Str, pattern: Expr) returns Bool {
    if expected_type_name.len().eq(0) { return false }
    ref enum_def : Expr = scope.get_struct(expected_type_name)
    if enum_def.is_null() { return false }
    if enum_def.node_type.is(NodeType.EnumDef).not() { return false }

    if pattern.node_type.is(NodeType.FieldAccess) {
        if pattern.children.len().gt(0) {
            if pattern.child(0).node_type.is(NodeType.Ident) {
                mut type_name := ""
                mut variant_name := ""
                switch pattern.child(0).node_type {
                case NodeType.Ident(tn): type_name = tn.ident_name()
                case:
                }
                switch pattern.node_type {
                case NodeType.FieldAccess(vn): variant_name = vn.field_access_name()
                case:
                }
                if type_name.eq(expected_type_name) {
                    idx := coverage_sub_index(coverage, variant_name)
                    if idx.gte(0) {
                        ref sub : CoverageNode = coverage.sub_nodes[idx.cast(U32)]
                        return sub.fully_covered
                    }
                }
            }
        }
        return false
    }

    if pattern.node_type.is(NodeType.FCall) {
        if pattern.children.len().eq(2) {
            ref callee : Expr = pattern.child(0)
            if callee.node_type.is(NodeType.FieldAccess) {
                if callee.children.len().gt(0) {
                    if callee.child(0).node_type.is(NodeType.Ident) {
                        mut type_name2 := ""
                        mut variant_name2 := ""
                        switch callee.child(0).node_type {
                        case NodeType.Ident(tn2): type_name2 = tn2.ident_name()
                        case:
                        }
                        switch callee.node_type {
                        case NodeType.FieldAccess(vn2): variant_name2 = vn2.field_access_name()
                        case:
                        }
                        if type_name2.eq(expected_type_name) {
                            idx2 := coverage_sub_index(coverage, variant_name2)
                            if idx2.gte(0) {
                                ref sub2 : CoverageNode = coverage.sub_nodes[idx2.cast(U32)]
                                if sub2.fully_covered { return true }
                                ref inner_pat : Expr = pattern.child(1)
                                if inner_pat.node_type.is(NodeType.Ident) {
                                    return false
                                }
                                vt_tag := enum_variant_tag(enum_def, variant_name2)
                                if vt_tag.gte(0) {
                                    inner_type_name := enum_variant_type(enum_def, vt_tag)
                                    if inner_type_name.len().gt(0) {
                                        ref inner_def : Expr = scope.get_struct(inner_type_name)
                                        if inner_def.is_null().not().and(inner_def.node_type.is(NodeType.EnumDef)) {
                                            if sub2.sub_names.len().gt(0) {
                                                return is_pattern_covered(scope, sub2, inner_type_name, inner_pat)
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
        return false
    }
    return false
}

// Walk a case pattern against the (expected) enum type and update the
// coverage trie. Returns silently for patterns that don't statically
// describe a variant of `expected_type_name` (e.g. ~case 42:~, or a
// pattern targeting a different enum -- those will surface as other
// type errors).
priv mark_pattern_coverage := func(scope: TypeScope, mut coverage: CoverageNode, expected_type_name: Str, pattern: Expr) {
    if expected_type_name.len().eq(0) { return }
    ref enum_def : Expr = scope.get_struct(expected_type_name)
    if enum_def.is_null() { return }
    if enum_def.node_type.is(NodeType.EnumDef).not() { return }

    // `case Type.Variant` (bare).
    if pattern.node_type.is(NodeType.FieldAccess) {
        if pattern.children.len().gt(0) {
            if pattern.child(0).node_type.is(NodeType.Ident) {
                mut type_name := ""
                mut variant_name := ""
                switch pattern.child(0).node_type {
                case NodeType.Ident(tn): type_name = tn.ident_name()
                case:
                }
                switch pattern.node_type {
                case NodeType.FieldAccess(vn): variant_name = vn.field_access_name()
                case:
                }
                if type_name.eq(expected_type_name) {
                    idx := coverage_sub_index(coverage, variant_name)
                    if idx.gte(0) {
                        ref mut sub : CoverageNode = coverage.sub_nodes[idx.cast(U32)]
                        sub.fully_covered = true
                    }
                }
            }
        }
        return
    }

    // `case Type.Variant(inner)` -- inner is either a binding (Ident, marks
    // the variant fully covered) or another enum pattern (recurse).
    if pattern.node_type.is(NodeType.FCall) {
        if pattern.children.len().eq(2) {
            ref callee : Expr = pattern.child(0)
            if callee.node_type.is(NodeType.FieldAccess) {
                if callee.children.len().gt(0) {
                    if callee.child(0).node_type.is(NodeType.Ident) {
                        mut type_name2 := ""
                        mut variant_name2 := ""
                        switch callee.child(0).node_type {
                        case NodeType.Ident(tn2): type_name2 = tn2.ident_name()
                        case:
                        }
                        switch callee.node_type {
                        case NodeType.FieldAccess(vn2): variant_name2 = vn2.field_access_name()
                        case:
                        }
                        if type_name2.eq(expected_type_name) {
                            idx2 := coverage_sub_index(coverage, variant_name2)
                            if idx2.gte(0) {
                                ref mut sub2 : CoverageNode = coverage.sub_nodes[idx2.cast(U32)]
                                ref inner_pat : Expr = pattern.child(1)
                                if inner_pat.node_type.is(NodeType.Ident) {
                                    // Whole-payload binding -> covers all sub-variants.
                                    sub2.fully_covered = true
                                } else {
                                    // Nested pattern: find inner enum and recurse.
                                    vt_tag := enum_variant_tag(enum_def, variant_name2)
                                    if vt_tag.gte(0) {
                                        inner_type_name := enum_variant_type(enum_def, vt_tag)
                                        if inner_type_name.len().gt(0) {
                                            ref inner_def : Expr = scope.get_struct(inner_type_name)
                                            if inner_def.is_null().not().and(inner_def.node_type.is(NodeType.EnumDef)) {
                                                if sub2.sub_names.len().eq(0) {
                                                    init_coverage_for_enum(sub2, inner_def)
                                                }
                                                mark_pattern_coverage(scope, sub2, inner_type_name, inner_pat)
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
        return
    }
}

// Collect "Outer.Inner.Leaf"-style paths for any uncovered variants of
// `enum_def` under `coverage`. A variant is OK iff fully_covered or
// (its payload is itself an enum AND its sub-coverage is exhaustive).
priv collect_missing_paths := func(scope: TypeScope, coverage: CoverageNode, enum_def: Expr, prefix: Str, mut out: Vec, ctx: Context) {
    if enum_def.is_null() { return }
    switch enum_def.node_type {
    case NodeType.EnumDef(cm_edd):
        for cmi in 0..cm_edd.variants.len() {
            ref vn : Str = cm_edd.variants[cmi]
            ref sub : CoverageNode = coverage.sub_nodes[cmi]
            mut current := ""
            if prefix.len().eq(0) {
                current = vn.clone()
            } else {
                current = prefix.concat(".").concat(vn)
            }
            if sub.fully_covered { continue }
            mut recursed := false
            vt_tag := enum_variant_tag(enum_def, vn)
            if vt_tag.gte(0) {
                inner_type_name := enum_variant_type(enum_def, vt_tag)
                if inner_type_name.len().gt(0) {
                    ref inner_def : Expr = scope.get_struct(inner_type_name)
                    if inner_def.is_null().not().and(inner_def.node_type.is(NodeType.EnumDef)) {
                        if sub.sub_names.len().gt(0) {
                            collect_missing_paths(scope, sub, inner_def, current, out, ctx)
                            recursed = true
                        }
                    }
                }
            }
            if recursed.not() {
                out.push(own current.clone())
            }
        }
    case:
    }
}

// Active file path and error counter for diagnostics live on Context
// (ctx.path / ctx.errors), threaded explicitly through type_error /
// type_error_at and every caller.
// Non-priv so the garbager module can report use-after-ownership-transfer
// against the same diagnostic counter.
type_error := proc(e: Expr, msg: Str, ctx: Context) {
    e.error(ctx.path, msg)
    ctx.errors++
}

type_error_at := proc(path: Str, line: U32, col: U32, msg: Str, ctx: Context) {
    println(path, ":", line.to_str(), ":", col.to_str(), ": error: ", msg)
    ctx.errors++
}

find_namespace_func := func(sdef: Expr, method: Str, scope: TypeScope) returns ref Expr {
    if sdef.is_null() { return NULL }
    ref ns : Vec = def_ns_decls(sdef)
    for fd : Declaration in ns {
        if fd.name.eq(method) {
            ref e : Expr = fd.default_value
            if scope.is_null().not() {
                if e.node_type.is(NodeType.Ident) {
                    switch e.node_type {
                    case NodeType.Ident(id):
                        sf := scope.find(id.ident_name())
                        switch sf {
                        case ScopeFind.Found(b):
                            if b.func_def.is_null().not() { return b.func_def }
                            if b.struct_def.is_null().not() { return b.struct_def }
                        case:
                        }
                    case:
                    }
                }
            }
            return e
        }
    }
    return NULL
}

// Issue #191: check if an Expr is comptime-known. Used by typer to
// validate macro arguments and by precomp to decide func folding.
// Conservative: only accepts shapes that are definitely known at
// compile time.
expr_is_comptime := func(e: Expr, scope: TypeScope) returns Bool {
    switch e.node_type {
    case NodeType.Literal(Literal.Num):    return true
    case NodeType.Literal(Literal.Str):    return true
    case NodeType.Literal(Literal.Bool):   return true
    case NodeType.Literal(Literal.Null):   return true
    case NodeType.Ident(id):
        ref b : TypeBinding = scope.get_binding(id.ident_name())
        if b.is_null() { return false }
        if b.is_mut { return false }
        if b.is_param { return false }
        return true
    case NodeType.FCall:
        if e.children.len().eq(0) { return false }
        // Issue #57: a `Type.<Variant>(...)` constructor call returns a Type
        // metatype value -- pure and comptime when its arg(s) are. The typer
        // rewrites a Type-typed ident (e.g. `mymacro(NamedEnum)` or anon-lifted
        // `enum { ... }`) into this form via make_til_type_expr, so recognise
        // it before the binding lookup below (there is no `Type_Enum` binding
        // for the receiver-qualified method name).
        if e.expr_til_type().is(Type.Enum("Type")) {
            for ai in 1..e.children.len() {
                if e.child(ai).expr_is_comptime(scope).not() { return false }
            }
            return true
        }
        ref callee : Expr = e.child(0)
        mut callee_name := ""
        switch callee.node_type {
        case NodeType.Ident(cn):
            callee_name = cn.ident_name()
        case NodeType.FieldAccess(_mn):
            if callee.children.len().gt(0) {
                ref recv : Expr = callee.child(0)
                mut sname := til_type_name(recv.expr_til_type())
                if sname.len().eq(0) {
                    switch recv.node_type {
                    case NodeType.Ident(rn):
                        sname = rn.ident_name()
                    case:
                    }
                }
                callee_name = sname.format("_", _mn.field_access_name())
            }
        case:
            return false
        }
        if callee_name.len().eq(0) { return false }
        ref cb : TypeBinding = scope.get_binding(callee_name)
        if cb.is_null() { return false }
        if cb.func_type.is(FuncType.Proc).or(cb.func_type.is(FuncType.ExtProc)) {
            return false
        }
        if cb.func_type.is(FuncType.Macro).or(cb.func_type.is(FuncType.Func)).or(cb.func_type.is(FuncType.ExtFunc)) {
            for ai in 1..e.children.len() {
                if e.child(ai).expr_is_comptime(scope).not() { return false }
            }
            return true
        }
        return false
    case NodeType.FieldAccess:
        // Issue #57: `Type.<Variant>` (no payload, e.g. `Type.I64` produced
        // by make_til_type_expr for primitive type-token args) is a Type
        // metatype value -- pure and comptime.
        if e.expr_til_type().is(Type.Enum("Type")) {
            return true
        }
        return false
    case:
        return false
    }
}

// Issue #179 step 5: locate a namespace member's Declaration so the
// caller can read its is_priv flag (find_namespace_func only returns
// the default_value FuncDef Expr).
namespace_member_is_priv := func(sdef: Expr, method: Str) returns Bool {
    if sdef.is_null() { return false }
    ref ns : Vec = def_ns_decls(sdef)
    for fd : Declaration in ns {
        if fd.name.eq(method) { return fd.is_priv }
    }
    return false
}

// #187 step 3: mark a namespace member as used. Skipped while
// auto_gen_depth > 0 so auto-emitted clone/delete/size don't mask
// genuinely-unused priv namespace methods.
mark_ns_member_used := func(sdef: Expr, method: Str) returns Bool {
    if sdef.is_null() { return false }
    ref ns : Vec = def_ns_decls(sdef)
    for fd : Declaration in ns {
        if fd.name.eq(method) { fd.used = true; return true }
    }
    return false
}

try_ufcs_rewrite := func(scope: TypeScope, mut e: Expr, fa: Expr, mut obj: Expr, method: Str, type_name: Str, ctx: Context) returns Bool {
    // Top-level `priv` free functions are file-mangled to
    // `priv__<path>__<name>`, and init_rewrite_refs only rewrites Ident
    // references -- not the method name on a UFCS FieldAccess. So
    // `x.priv_helper(...)` arrives here with the bare name while the
    // binding lives under the mangled name. Retry the lookup mangled so
    // priv free functions are UFCS-callable in their own file (the U in
    // UFCS is universal). cross-file priv access is still rejected later
    // by check_priv_access.
    mut lookup_name := method.clone()
    ref bare : TypeBinding = scope.get_binding(method)
    if bare.is_null() {
        mangled := priv_c_name(ctx.path, method)
        ref pm : TypeBinding = scope.get_binding(mangled)
        if pm.is_null().not() { lookup_name = mangled.clone() }
    }
    ref top : TypeBinding = scope.get_binding(lookup_name)
    mut ufcs_match : I32 = 0
    if top.is_null().not() {
        if top.func_def.is_null().not() {
            switch top.func_def.node_type {
            case NodeType.FuncDef(top_fdef):
                if top_fdef.params.len().gt(0) {
                    ref top_param : Declaration = top_fdef.params[0]
                    ref first_param : Str = top_param.explicit_type
                    if first_param.len().gt(0) {
                        is_free_func := top.func_type.is(FuncType.Func)
                        .or(top.func_type.is(FuncType.ExtFunc))
                        .or(top.func_type.is(FuncType.Proc))
                        .or(top.func_type.is(FuncType.ExtProc))
                        if type_name.len().gt(0) {
                            if first_param.eq(type_name) {
                                ufcs_match = 1
                            } else if first_param.eq("Dynamic").and(is_free_func) {
                                ufcs_match = 1
                            }
                        } else if obj.expr_til_type().is(Type.Dynamic) {
                            pt := type_from_name(first_param, scope, ctx)
                            narrow_dynamic(obj, pt)
                            ufcs_match = 1
                        }
                    }
                }
            case:
            }
        }
    }
    if ufcs_match.eq(0) { return false }
    mut fn_ident := Expr.new(ident_node(lookup_name), fa.line, fa.col)
    mut new_children := Vec.new(Expr)
    new_children.push(own fn_ident)
    // Move the receiver out of the old callee `fa` (slot 0) instead of
    // cloning it: push_take zeroes fa's slot so the trailing
    // `e.children = new_children` FieldAssign frees the old callee --
    // including its FieldAccess method-name Str -- without leaking and
    // without an extra clone of the receiver subtree. #109.
    new_children.push_take(e.child(0).children, 0)
    for i in 1..e.children.len() {
        new_children.push_take(e.children, i)
    }
    e.children = new_children
    return true
}

// Resolve the FunctionDef Expr that describes the callee signature for an
// FCall, by walking the AST + scope rather than reading a cached field.
// Mirrors the four FuncPtr-indirect cases the typer used to handle:
//   1/2. callee is FieldAccess on a struct whose field has a FuncSig type
//   3.   callee is an Ident bound to a FuncPtr local/param
//   4.   callee is an Ident for a regular func that returns a FuncSig
// Returns NULL when the binding is not in `scope` (e.g. param/local at
// builder time after func_scope was destroyed). Callers that need to
// resolve those cases must layer their own fallback on top.
resolve_fn_sig := func(fcall: Expr, scope: TypeScope) returns ref Expr {
    if fcall.is_null() { return NULL }
    if fcall.node_type.is(NodeType.FCall).not() { return NULL }
    if fcall.children.len().eq(0) { return NULL }
    ref callee : Expr = fcall.child(0)
    switch callee.node_type {
    case NodeType.Ident(name):
        ref cb : TypeBinding = scope.get_binding(name.ident_name())
        if cb.is_null() { return NULL }
        if cb.type.is(Type.FuncPtr).not() { return NULL }
        if cb.func_def.is_null() { return NULL }
        if cb.func_type.is(FuncType.None) {
            return cb.func_def
        }
        switch cb.func_def.node_type {
        case NodeType.FuncDef(cb_fdef):
            if cb_fdef.return_type.len().eq(0) { return NULL }
            // Use scope.get_binding directly instead of scope.find:
            // `case ScopeFind.Found(rsb):` binds rsb to storage inside
            // the heap-allocated ScopeFind wrapper, and the asap pass
            // deletes the wrapper before the ref return reads
            // rsb.func_def -- a heap-use-after-free that ASAN flags in
            // strings.til translate (the value happens to still be the
            // valid Expr pointer because the freed slot is not reused
            // before the deref, so make test doesn't catch it).
            ref rsb : TypeBinding = scope.get_binding(cb_fdef.return_type)
            if rsb.is_null() { return NULL }
            if rsb.func_def.is_null() { return NULL }
            if rsb.func_def.children.len().neq(0) { return NULL }
            return rsb.func_def
        case:
        }
        return NULL
    case NodeType.FieldAccess(method):
        if callee.children.len().eq(0) { return NULL }
        ref obj : Expr = callee.child(0)
        sname := til_type_name(obj.expr_til_type())
        if sname.len().eq(0) { return NULL }
        ref sdef : Expr = scope.get_struct(sname)
        if sdef.is_null() { return NULL }
        switch sdef.node_type {
        case NodeType.StructDef(sdd):
            for fd : Declaration in sdd.fields {
                if fd.name.eq(method.field_access_name()).not() { continue }
                if fd.explicit_type.len().eq(0) { continue }
                // Same UAF guard as the Ident branch above -- use
                // get_binding directly, not the ScopeFind destructure.
                ref ftb : TypeBinding = scope.get_binding(fd.explicit_type)
                if ftb.is_null() { continue }
                if ftb.func_def.is_null() { continue }
                if ftb.func_def.children.len().neq(0) { continue }
                return ftb.func_def
            }
        case:
        }
        return NULL
    case:
        return NULL
    }
}

// #168 step 2: true when an FCall yields a by-value result that a `ref`
// cannot borrow -- i.e. the callee returns Own (heap value the caller owns)
// OR Shallow (a stack value: a primitive, or an issue #223 auto-shallow
// struct). Only a `returns ref T` callee yields a borrowable pointer, so the
// predicate is "return_own_type is not Ref". A struct/enum constructor always
// produces a fresh owned value. Recognised callee shapes:
//   - Ident("foo")     -> scope binding's func_def.return_own_type
//   - Type.method(...) -> namespace lookup on the type's def
//   - obj.method(...)  -> namespace lookup on the receiver's type def
// A callee whose return is a fresh by-value result a `ref` cannot borrow:
// either an Own return, or (issue #223) a Shallow-returning callee whose
// return type is a STRUCT/ENUM. A Shallow primitive return (I64, ...) is
// left out: `ref x : I64 = f()` predates auto-shallow and other code relies
// on the existing classification; only the struct case is newly value-typed.
fdef_returns_unborrowable := func(fd: FunctionDef, scope: TypeScope) returns Bool {
    if fd.return_own_type.is(OwnType.Own) { return true }
    if fd.return_own_type.is(OwnType.Shallow) {
        rt := type_from_name_init(fd.return_type, scope)
        if rt.is(Type.Struct).or(rt.is(Type.Enum)) { return is_primitive(rt).not() }
    }
    return false
}

fcall_returns_own := func(fcall: Expr, scope: TypeScope) returns Bool {
    if fcall.node_type.is(NodeType.FCall).not() { return false }
    if fcall.children.len().eq(0) { return false }
    ref callee : Expr = fcall.child(0)
    switch callee.node_type {
    case NodeType.Ident(_cn):
        // Struct/enum constructor: `Foo(...)` where Foo is a registered
        // struct/enum type. The result is a freshly-constructed owned value.
        ref ctor_sdef : Expr = scope.get_struct(_cn.ident_name())
        if ctor_sdef.is_null().not() { return true }
        ref cb : TypeBinding = scope.get_binding(_cn.ident_name())
        if cb.is_null() { return false }
        if cb.func_def.is_null() { return false }
        switch cb.func_def.node_type {
        case NodeType.FuncDef(_cfd):
            return fdef_returns_unborrowable(_cfd, scope)
        case:
        }
        return false
    case NodeType.FieldAccess(_cfa):
        // Type-name dispatch: Type.method(args). Receiver Ident is the type.
        if fa_is_ns(callee, scope) {
            switch callee.child(0).node_type {
            case NodeType.Ident(_cti):
                ref sdef : Expr = scope.get_struct(_cti.ident_name())
                ref method : Expr = find_namespace_func(sdef, _cfa.field_access_name(), scope)
                if method.is_null() { return false }
                switch method.node_type {
                case NodeType.FuncDef(_ffd):
                    return fdef_returns_unborrowable(_ffd, scope)
                case:
                }
                return false
            case:
            }
        }
        // UFCS / instance method: obj.method(args). Resolve via receiver's type.
        if callee.children.len().gt(0) {
            ref obj : Expr = callee.child(0)
            sname := til_type_name(obj.expr_til_type())
            if sname.len().eq(0) { return false }
            ref sdef : Expr = scope.get_struct(sname)
            ref method : Expr = find_namespace_func(sdef, _cfa.field_access_name(), scope)
            if method.is_null() { return false }
            switch method.node_type {
            case NodeType.FuncDef(_ffd):
                return fdef_returns_unborrowable(_ffd, scope)
            case:
            }
        }
        return false
    case:
    }
    return false
}

// #168 step 1+2: ref bindings cannot be initialized from an owned value --
// the value would be heap-allocated with no owner. Step 1 caught literal
// `.clone()`; step 2 generalises to any FCall whose callee returns
// `OwnType.Own` (constructors, take_* helpers, factory funcs, etc.).
// Future steps broaden the surface (struct field defaults, assignments,
// ref-typed returns).
check_ref_decl_owned_init := proc(stmt: Expr, scope: TypeScope, ctx: Context) {
    if stmt.children.len().eq(0) { return }
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        if sdecl.own_type.is(OwnType.Ref).not() { return }
        ref rhs : Expr = stmt.child(0)
        if rhs.node_type.is(NodeType.FCall).not() { return }
        if fcall_returns_own(rhs, scope).not() { return }
        stmt.type_error("ref binding '".concat(sdecl.name).concat("' cannot be initialized from an owned value (.clone() / constructor / function returning own) -- use 'own' to keep the value, or borrow the source directly"), ctx)
    case:
    }
}

// #168 step 3: struct field defaults follow the same predicate -- a
// `ref` field cannot have an owned-RHS default. NULL is still allowed
// (forced exception for ref fields, since the type doesn't yet have
// an instance to borrow from at default-value time).
check_ref_field_owned_default := proc(fd: Declaration, scope: TypeScope, ctx: Context) {
    if fd.own_type.is(OwnType.Ref).not() { return }
    if fd.default_value.is_null() { return }
    if fd.default_value.node_type.is(NodeType.NoDefaultArg) { return }
    if fd.default_value.node_type.is_literal_null() { return }
    if fd.default_value.node_type.is(NodeType.FCall).not() { return }
    if fcall_returns_own(fd.default_value, scope).not() { return }
    fd.default_value.type_error("ref field '".concat(fd.name).concat("' default cannot be an owned value (.clone() / constructor / function returning own) -- use NULL or change the field to 'own'"), ctx)
}

// #168 step 4: assignments to ref-typed lvalues follow the same
// predicate. Catches the original FCallData.fn_sig motivating case
// (`fcd.fn_sig = src.clone()` where fn_sig was `ref mut Expr = NULL`).
// Caller passes the resolved target name (just for the diagnostic) and
// the rhs Expr; the predicate is the same as steps 1-3.
check_ref_assign_owned_rhs := proc(stmt: Expr, target_name: Str, rhs: Expr, scope: TypeScope, ctx: Context) {
    if rhs.node_type.is(NodeType.FCall).not() { return }
    if fcall_returns_own(rhs, scope).not() { return }
    stmt.type_error("ref target '".concat(target_name).concat("' cannot be assigned an owned value (.clone() / constructor / function returning own) -- borrow the source directly, or change the target to 'own'/'mut'")
    , ctx)
}

// #168 step 1b / #177: ref bindings cannot be initialized to NULL. A
// `ref` slot initialized to NULL is structurally an uninitialized
// borrow; every legitimate use is rewritable as the borrow at the
// point you actually have it, as a sentinel value, or as a Context
// field on a longer-lived owner.
//
// Allowed exception: struct/namespace field defaults (where the
// parent type doesn't yet have an instance to point at).
//
// Module-scope globals were the original conservative carve-out; the
// 8 remaining sites flagged in #177 (interpreter cached_*_def/_name,
// builder current_fdef, typer current_struct_def) all migrated to
// Context fields. Module scope now enforces the same rule as locals.
check_ref_local_null_init := proc(stmt: Expr, ctx: Context) {
    if stmt.children.len().eq(0) { return }
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        if sdecl.own_type.is(OwnType.Ref).not() { return }
        ref rhs : Expr = stmt.child(0)
        if rhs.node_type.is_literal_null().not() { return }
        stmt.type_error("ref binding '".concat(sdecl.name).concat("' cannot be initialized to NULL -- borrow the source directly, or use a non-ref shape (own/mut + sentinel)"), ctx)
    case:
    }
}

infer_func_ptr_field_call := proc(scope: TypeScope, mut e: Expr, mut fa: Expr, obj: Expr, sdef: Expr, method: Str, in_func: I32, ctx: Context) returns Bool {
    if sdef.is_null().or(obj.expr_til_type().is(Type.Struct).not().and(obj.expr_til_type().is(Type.Enum).not())) { return false }
    switch sdef.node_type {
    case NodeType.StructDef(fpf_sdd):
        for fd : Declaration in fpf_sdd.fields {
            if fd.name.eq(method).not() { continue }
            if fd.explicit_type.len().eq(0) { continue }
            sf_ftb := scope.find(fd.explicit_type)
            switch sf_ftb {
            case ScopeFind.Found(ftb):
                if ftb.func_def.is_null().or(ftb.func_def.children.len().neq(0)) { continue }
                fa.set_expr_til_type(Type.FuncPtr)
                ref sig : Expr = ftb.func_def
                mut nargs : U32 = e.children.len()
                nargs = nargs.sub(1)
                switch sig.node_type {
                case NodeType.FuncDef(sig_fdef):
                    if nargs.neq(sig_fdef.params.len()) {
                        e.type_error("function pointer field '".concat(method).concat("' expects ").concat(sig_fdef.params.len().to_str()).concat(" args, got ").concat(nargs.to_str()), ctx)
                    }
                    mut ai : U32 = 0
                    while ai.lt(nargs) {
                        if ai.gte(sig_fdef.params.len()) { break }
                        infer_expr(scope, e.child(ai.add(1)), in_func, ctx)
                        ai = ai.add(1)
                    }
                    if sig_fdef.return_type.len().gt(0) {
                        e.set_expr_til_type(type_from_name(sig_fdef.return_type, scope, ctx))
                    } else {
                        e.set_expr_til_type(Type.None)
                    }
                case:
                    UNREACHABLE(__LOC__)
                }
                return true
            case:
                continue
            }
        }
    case:
    }
    return false
}

// True when `e` is a `.clone()` method call (either UFCS form
// `x.clone()` or the desugared namespace form `Type.clone(x)`): an FCall
// whose callee is a FieldAccess named "clone".
is_clone_fcall := func(e: Expr) returns Bool {
    if e.node_type.is(NodeType.FCall).not() { return false }
    if e.children.len().eq(0) { return false }
    ref callee : Expr = e.child(0)
    switch callee.node_type {
    case NodeType.FieldAccess(cfa):
        return cfa.field_access_name().eq("clone")
    case:
        return false
    }
}

validate_fcall_own_args := proc(scope: TypeScope, e: Expr, callee_bind: TypeBinding, ctx: Context) {
    if callee_bind.is_null() { return }
    if callee_bind.func_def.is_null() { return }
    ref fdef : Expr = callee_bind.func_def
    switch fdef.node_type {
    case NodeType.FuncDef(fdef_data):
        fvi := fdef_data.variadic_index
        fkwi := fdef_data.kwargs_index
        mut fvc : U32 = 0
        if fvi.gte(0) {
            fvc = fcall_variadic_count(e, fdef_data.params.len(), fkwi.gte(0))
        }
        mut fkc : U32 = 0
        if fkwi.gte(0) {
            fkc = fcall_kwargs_count(e)
        }
        mut ci : U32 = 1
        mut pi : U32 = 0
        while pi.lt(fdef_data.params.len()) {
            if ci.gte(e.children.len()) { break }
            if fvi.gte(0) {
                if pi.cast(I32).eq(fvi) {
                    ci = ci.add(fvc)
                    pi = pi.add(1)
                    continue
                }
            }
            if fkwi.gte(0) {
                if pi.cast(I32).eq(fkwi) {
                    ci = ci.add(fkc)
                    pi = pi.add(1)
                    continue
                }
            }
            ref pp2 : Declaration = fdef_data.params[pi]
            pown := pp2.own_type.is(OwnType.Own)
            ref arg : Expr = e.child(ci)
            // A `.clone()` passed to an immutable ref (borrow) parameter
            // is pure waste: the callee only borrows, so the fresh copy
            // is allocated and dropped without ever being retained or
            // mutated. Pass the value directly. (Own params legitimately
            // consume the clone; ref-mut params may mutate the copy.)
            if pp2.own_type.is(OwnType.Ref).and(pp2.is_mut.not()) {
                if arg.is_clone_fcall() {
                    arg.type_error("redundant '.clone()': parameter '".concat(pp2.name).concat("' is a ref (borrow); pass the value directly"), ctx)
                }
            }
            if pown {
                if get_own_arg(e, ci).not() {
                    arg.type_error("argument for 'own' parameter '".concat(pp2.name).concat("' must be marked 'own'"), ctx)
                }
            } else if get_own_arg(e, ci) {
                arg.type_error("'own' on argument but parameter '".concat(pp2.name).concat("' is not 'own'"), ctx)
            }
            if pown {
                switch arg.node_type {
                case NodeType.Ident(an):
                    sf_ab := scope.find(an.ident_name())
                    switch sf_ab {
                    case ScopeFind.Found(ab):
                        if ab.own_type.is(OwnType.Ref) {
                            arg.type_error("cannot pass ref variable to 'own' parameter; use .clone() to make an owned copy", ctx)
                        }
                    case:
                    }
                case:
                }
            }
            if pown {
                if arg.node_type.is_literal_null() {
                    arg.type_error("cannot pass null to 'own' parameter", ctx)
                }
            }
            if pp2.own_type.is(OwnType.Shallow) {
                if arg.node_type.is_literal_null() {
                    arg.type_error("cannot pass null to 'shallow' parameter", ctx)
                }
            }
            ci = ci.add(1)
            pi = pi.add(1)
        }
    case:
        UNREACHABLE(__LOC__)
    }
}

infer_struct_constructor_fcall := proc(scope: TypeScope, mut e: Expr, name: Str, in_func: I32, ctx: Context) returns Bool {
    ref sdef : Expr = scope.get_struct(name)
    if sdef.is_null() { return false }
    return infer_struct_constructor_fcall_impl(scope, sdef, e, name, in_func, ctx)
}

infer_struct_constructor_fcall_impl := proc(scope: TypeScope, sdef: Expr, mut e: Expr, name: Str, in_func: I32, ctx: Context) returns Bool {
    // #187 step 1: mark the struct binding as used so a priv struct
    // that is only ever instantiated (no namespace method calls) is
    // not misreported as dead. Skip when current_type_name matches
    // the struct itself: that's an internal constructor inside the
    // struct's own auto-generated or user-written ns methods, which
    // does not count as "used externally".
    if ctx.current_type_name.eq(name).not() {
        ref mut sb_used : TypeBinding = scope.get_binding(name)
        if sb_used.is_null().not() { sb_used.used = true }
    }
    sf_sb := scope.find(name)
    switch sf_sb {
    case ScopeFind.Found(sb):
        if sb.is_builtin {
            e.type_error("cannot instantiate builtin type '".concat(name).concat("'"), ctx)
            e.set_expr_til_type(Type.Unknown)
            return true
        }
        check_priv_access(e, name, sb, ctx)
    case:
    }

    // #99: if struct has new(), disallow literal outside its namespace
    if ctx.current_type_name.eq(name).not() {
        mut has_new := false
        ref new_ns : Vec = def_ns_decls(sdef)
        for nd : Declaration in new_ns {
            if nd.name.eq("new") {
                has_new = true
                break
            }
        }
        if has_new {
            e.type_error("struct '".concat(name).concat("' has a new() constructor; use ").concat(name).concat(".new(...) instead"), ctx)
            e.set_expr_til_type(Type.Struct(name.clone()))
            return true
        }
    }

    switch sdef.node_type {
    case NodeType.StructDef(ctor_sdd):
        nfields := ctor_sdd.fields.len()
        mut field_vals := Vec.new(CtorArg)
        for _ in 0..nfields {
            field_vals.push(own CtorArg.Unfilled())
        }
        for i in 1..e.children.len() {
            ref arg : Expr = e.child(i)
            switch arg.node_type {
            case NodeType.NamedArg(aname):
                mut slot : I32 = -1
                for j in 0..nfields {
                    ref fld_decl : Declaration = ctor_sdd.fields[j]
                    if fld_decl.name.eq(aname) {
                        slot = j.cast(I32)
                        break
                    }
                }
                if slot.lt(0) {
                    msg := format("struct '", name, "' has no field '", aname, "'")
                    arg.type_error(msg, ctx)
                }
                if slot.gte(0) {
                    ref ctor_fld : Declaration = ctor_sdd.fields[slot.cast(U32)]
                    check_member_priv(arg, name, aname, ctor_fld.is_priv, ctx)
                    if ctx.auto_gen_depth.eq(0) { ctor_fld.used = true }
                    ref slot_arg : CtorArg = field_vals[slot.cast(U32)]
                    if slot_arg.is(CtorArg.Filled) {
                        msg := format("duplicate argument for field '", aname, "'")
                        arg.type_error(msg, ctx)
                    }
                    if slot_arg.is(CtorArg.Filled).not() {
                        field_vals.set(slot.cast(U32), own CtorArg.Filled(arg.child(0).clone()))
                    }
                }
            case:
                arg.type_error("struct instantiation requires named arguments", ctx)
                continue
            }
        }
        for i in 0..nfields {
            ref slot_arg : CtorArg = field_vals[i]
            if slot_arg.is(CtorArg.Filled).not() {
                ref fld_d : Declaration = ctor_sdd.fields[i]
                field_vals.set(i, own CtorArg.Filled(fld_d.default_value.clone()))
            }
        }
        mut new_ch := Vec.new(Expr)
        new_ch.push_take(e.children, 0)
        for i in 0..nfields {
            ref slot_arg : CtorArg = field_vals[i]
            switch slot_arg {
            case CtorArg.Filled(filled_arg):
                new_ch.push(own filled_arg.clone())
            case:
                UNREACHABLE(__LOC__)
            }
        }
        e.children = new_ch
        for i in 1..e.children.len() {
            if e.child(i).expr_til_type().is(Type.Unknown) {
                infer_expr(scope, e.child(i), in_func, ctx)
            }
        }
        for fi in 0..nfields {
            if fi.gte(e.children.len().sub(1)) { break }
            ref fld_decl : Declaration = ctor_sdd.fields[fi]
            ai := fi.add(1).cast(I32)
            if fld_decl.own_type.is(OwnType.Ref) { continue }
            if fld_decl.own_type.is(OwnType.Own).not() {
                if type_ctor_consumes(fld_decl.til_type).not() { continue }
            }
            set_own_arg(e, ai.to_usize())
        }
        e.set_expr_til_type(Type.Struct(resolve_type_alias(scope, name).clone()))
        return true
    case:
        UNREACHABLE(__LOC__)
        return false
    }
}

desugar_user_func_fcall_args := proc(mut e: Expr, name: Str, callee_bind: TypeBinding, ctx: Context) {
    ref fdef : Expr = callee_bind.func_def
    switch fdef.node_type {
    case NodeType.FuncDef(fdef_data):
        nparam := fdef_data.params.len()
        vi := fdef_data.variadic_index
        kwi := fdef_data.kwargs_index
        mut fixed_count : U32 = nparam
        if vi.gte(0) {
            fixed_count = vi.cast(U32)
        }
        mut va_args := Vec.new(Expr)
        mut kw_args := Vec.new(Expr)
        mut new_args := Vec.new(Expr)
        for _ in 0..nparam {
            new_args.push(own Expr.new(NodeType.NoDefaultArg, e.line, e.col))
        }
        mut pos_idx : U32 = 0
        mut seen_named := false
        for i in 1..e.children.len() {
            ref arg : Expr = e.child(i)
            switch arg.node_type {
            case NodeType.NamedArg(aname):
                seen_named = true
                mut slot : I32 = -1
                for j in 0..nparam {
                    if j.cast(I32).eq(vi) { continue }
                    if j.cast(I32).eq(kwi) { continue }
                    ref param : Declaration = fdef_data.params[j]
                    if param.name.eq(aname) {
                        slot = j.cast(I32)
                        break
                    }
                }
                if slot.lt(0) {
                    if kwi.gte(0) {
                        kw_args.push(own arg.clone())
                    } else {
                        arg.type_error(format("'", name, "' has no parameter '", aname, "'"), ctx)
                    }
                } else {
                    ref slot_arg : Expr = new_args[slot.cast(U32)]
                    if slot_arg.node_type.is(NodeType.NoDefaultArg).not() {
                        arg.type_error(format("duplicate argument for parameter '", aname, "'"), ctx)
                    } else {
                        ref slot_e : Expr = new_args[slot.cast(U32)]
                        slot_e.free_expr_slot_in_place()
                        new_args.set(slot.cast(U32), own arg.child(0).clone())
                    }
                }
            case:
                if seen_named {
                    arg.type_error("positional argument after named argument", ctx)
                }
                if vi.gte(0) {
                    if pos_idx.gte(fixed_count) {
                        va_args.push(own arg.clone())
                    } else if pos_idx.lt(nparam) {
                        ref pos_slot_va : Expr = new_args[pos_idx]
                        pos_slot_va.free_expr_slot_in_place()
                        new_args.set(pos_idx, own arg.clone())
                    }
                } else if pos_idx.lt(nparam) {
                    ref pos_slot : Expr = new_args[pos_idx]
                    pos_slot.free_expr_slot_in_place()
                    new_args.set(pos_idx, own arg.clone())
                }
                pos_idx = pos_idx.add(1)
            }
        }
        for i in 0..nparam {
            if i.cast(I32).eq(vi) { continue }
            if i.cast(I32).eq(kwi) { continue }
            ref slot_arg : Expr = new_args[i]
            if slot_arg.node_type.is(NodeType.NoDefaultArg) {
                ref param : Declaration = fdef_data.params[i]
                if param.default_value.node_type.is(NodeType.NoDefaultArg).not() {
                    slot_arg.free_expr_slot_in_place()
                    new_args.set(i, own param.default_value.clone())
                } else {
                    e.type_error(format("missing argument for parameter '", param.name, "'"), ctx)
                }
            }
        }
        mut max_pos : U32 = nparam
        if kwi.gte(0) {
            max_pos = max_pos.sub(1)
        }
        if vi.lt(0) {
            if pos_idx.gt(max_pos) {
                e.type_error(format("too many arguments: expected ", nparam.to_str(), ", got ", pos_idx.to_str()), ctx)
            }
        }
        mut new_ch := Vec.new(Expr)
        ref callee : Expr = e.child(0)
        new_ch.push(own callee.clone())
        for i in 0..nparam {
            if i.cast(I32).eq(vi) {
                va_count := va_args.len()
                for vai in 0..va_count {
                    new_ch.push_take(va_args, vai)
                }
            } else if i.cast(I32).eq(kwi) {
                kw_count := kw_args.len()
                for kwi2 in 0..kw_count {
                    new_ch.push_take(kw_args, kwi2)
                }
            } else {
                ref slot_arg : Expr = new_args[i]
                if slot_arg.node_type.is(NodeType.NoDefaultArg) {
                    // Missing-argument case: diagnostic already emitted
                    // above. Bail out of the arg desugar rather than
                    // panic so the typer can keep reporting later
                    // errors in the same file.
                    return
                } else {
                    new_ch.push_take(new_args, i)
                }
            }
        }
        mut old := e.children
        e.children = new_ch
        Vec.delete(own old, true)
        Vec.delete(own va_args, true)
        Vec.delete(own kw_args, true)
        Vec.delete(own new_args, true)
    case:
        UNREACHABLE(__LOC__)
    }
}

// Validate a single argument against its parameter's type. Narrows
// numeric literals to fit the param type, applies implicit widen /
// usize-coerce, and emits a type_error on mismatch. Skips Dynamic-typed
// args (the caller has already decided this arg is not constrained).
// A numeric literal that is the receiver of a `to_<numeric>()` conversion
// is a redundant conversion when the surrounding context already narrows
// the bare literal to `expected` with the same value (literal_in_range
// holds). Out-of-range cases stay legal because the conversion is then
// doing real work: -1.to_usize() (wraparound to the max sentinel) and
// 300.to_u8() (truncation) both return false here.
redundant_literal_conversion := func(e: Expr, expected: Type) returns Bool {
    if is_numeric_type(expected).not() { return false }
    if e.node_type.is(NodeType.FCall).not() { return false }
    if is_numeric_type(e.expr_til_type()).not() { return false }
    // `<lit>.to_X()` form: FCall with 1 child (a FieldAccess callee).
    if e.children.len().eq(1) {
        ref fa : Expr = e.child(0)
        mut method := ""
        switch fa.node_type {
        case NodeType.FieldAccess(m):
            method = m.field_access_name()
        case:
            return false
        }
        if method.starts_with("to_").not() { return false }
        if fa.children.len().eq(0) { return false }
        ref recv : Expr = fa.child(0)
        switch recv.node_type {
        case NodeType.Literal(Literal.Num(lit_str)):
            return literal_in_range(lit_str.literal_num_text(), expected)
        case:
            return false
        }
    }
    // `<lit>.cast(T)` UFCS form: FCall with FieldAccess(lit, "cast")
    // callee plus the T arg as e.child(1).
    if e.children.len().eq(2) {
        ref fa : Expr = e.child(0)
        mut method := ""
        switch fa.node_type {
        case NodeType.FieldAccess(m):
            method = m.field_access_name()
        case:
            return false
        }
        if method.eq("cast").not() { return false }
        if fa.children.len().eq(0) { return false }
        ref recv : Expr = fa.child(0)
        ref tgt_arg : Expr = e.child(1)
        // Literal receiver + target name matching `expected` -- same
        // shape as the to_<X> case, with the target on the call side
        // instead of the method name.
        mut tgt_name := ""
        switch tgt_arg.node_type {
        case NodeType.Ident(tn_id):
            tgt_name = tn_id.ident_name()
        case:
            return false
        }
        if til_type_name_c(expected).eq(tgt_name).not() { return false }
        switch recv.node_type {
        case NodeType.Literal(Literal.Num(lit_str)):
            return literal_in_range(lit_str.literal_num_text(), expected)
        case:
            return false
        }
    }
    return false
}

redundant_conversion_error := proc(at: Expr, expected: Type, ctx: Context) {
    at.type_error("redundant conversion: numeric literal already narrows to "
        .concat(type_to_name(expected)).concat(" in this context; drop the .to_* / .cast(T) conversion"), ctx)
}

validate_fcall_arg := proc(mut arg: Expr, ptype: Type, ptype_name: Str, param_name: Str, ctx: Context) {
    if arg.expr_til_type().is(Type.Dynamic) { return }
    if arg.expr_til_type().is(Type.Unknown) { return }
    if arg.redundant_literal_conversion(ptype) {
        redundant_conversion_error(arg, ptype, ctx)
        return
    }
    switch arg.node_type {
    case NodeType.Literal(Literal.Num(lit_str)):
        if is_numeric_type(ptype) {
            if literal_in_range(lit_str.literal_num_text(), ptype).not() {
                arg.type_error("integer literal ".concat(lit_str.literal_num_text()).concat(" out of range for ").concat(type_to_name(ptype)), ctx)
            }
            arg.set_expr_til_type(ptype)
            return
        }
    case:
    }
    if can_implicit_widen(arg.expr_til_type(), ptype) {
        arg.set_expr_til_type(ptype)
        return
    }
    if can_implicit_usize_coerce(arg.expr_til_type(), ptype, ptype_name) {
        arg.set_expr_til_type(ptype)
        return
    }
    if arg.expr_til_type().is(ptype).not() {
        arg.type_error("argument type mismatch for '".concat(param_name).concat("': expected ").concat(ptype_name).concat(", got ").concat(type_to_name(arg.expr_til_type())), ctx)
    } else if is_aggregate(ptype) {
        arg_sname := til_type_name(arg.expr_til_type())
        if arg_sname.len().gt(0) {
            if ptype_name.eq(arg_sname).not() {
                arg.type_error("argument type mismatch for '".concat(param_name).concat("': expected ").concat(ptype_name).concat(", got ").concat(arg_sname), ctx)
            }
        }
    }
}

infer_and_validate_fcall_args := proc(scope: TypeScope, mut e: Expr, callee_bind: TypeBinding, in_func: I32, ctx: Context) {
    for i in 1..e.children.len() {
        infer_expr(scope, e.child(i), in_func, ctx)
    }
    if callee_bind.is_null() { return }
    if callee_bind.func_def.is_null() { return }
    ref fdef : Expr = callee_bind.func_def
    switch fdef.node_type {
    case NodeType.FuncDef(fdef_data):
        fvi := fdef_data.variadic_index
        fkwi := fdef_data.kwargs_index
        mut fvc : U32 = 0
        if fvi.gte(0) {
            fvc = fcall_variadic_count(e, fdef_data.params.len(), fkwi.gte(0))
        }
        mut fkc : U32 = 0
        if fkwi.gte(0) {
            fkc = fcall_kwargs_count(e)
        }
        mut ci : U32 = 1
        mut pi : U32 = 0
        while pi.lt(fdef_data.params.len()) {
            if ci.gte(e.children.len()) { break }
            if fvi.gte(0) {
                if pi.cast(I32).eq(fvi) {
                    ref vparam : Declaration = fdef_data.params[pi]
                    vptype := type_from_name(vparam.explicit_type, scope, ctx)
                    for vk in 0..fvc {
                        rewrite_til_type_arg(scope, e.child(ci.add(vk)), vptype, in_func, ctx)
                        narrow_dynamic(e.child(ci.add(vk)), vptype)
                    }
                    ci = ci.add(fvc)
                    pi = pi.add(1)
                    continue
                }
            }
            if fkwi.gte(0) {
                if pi.cast(I32).eq(fkwi) {
                    ci = ci.add(fkc)
                    pi = pi.add(1)
                    continue
                }
            }
            ref param1 : Declaration = fdef_data.params[pi]
            ref ptype : Str = param1.explicit_type
            ptype_t := type_from_name(ptype, scope, ctx)
            rewrite_til_type_arg(scope, e.child(ci), ptype_t, in_func, ctx)
            narrow_dynamic(e.child(ci), ptype_t)
            ci = ci.add(1)
            pi = pi.add(1)
        }
        ci = 1
        pi = 0
        while pi.lt(fdef_data.params.len()) {
            if ci.gte(e.children.len()) { break }
            if fvi.gte(0) {
                if pi.cast(I32).eq(fvi) {
                    ref vparam : Declaration = fdef_data.params[pi]
                    ref vptype_name : Str = vparam.explicit_type
                    mut is_splat := false
                    switch e.node_type {
                    case NodeType.FCall(fcd_v):
                        is_splat = fcd_v.is_splat
                    case:
                        UNREACHABLE(__LOC__)
                    }
                    if vptype_name.len().gt(0).and(is_splat.not()) {
                        vptype := type_from_name(vptype_name, scope, ctx)
                        if vptype.is(Type.Dynamic).not() {
                            is_str_va := vptype_name.eq("Str")
                            for vk in 0..fvc {
                                if is_str_va {
                                    ref vk_arg : Expr = e.child(ci.add(vk))
                                    if vk_arg.expr_til_type().is(vptype).not() {
                                        if vk_arg.expr_til_type().is(Type.Dynamic).not().and(vk_arg.expr_til_type().is(Type.Unknown).not()) {
                                            arg_tname := type_to_name(vk_arg.expr_til_type())
                                                if arg_tname.len().gt(0).and(arg_tname.eq("Str").not()) {
                                                    if type_has_to_str(scope, arg_tname) {
                                                        e.children.replace(ci.add(vk), own make_to_str_call(arg_tname, vk_arg))
                                                        continue
                                                    }
                                            }
                                        }
                                    }
                                }
                                rewrite_til_type_arg(scope, e.child(ci.add(vk)), vptype, in_func, ctx)
                                validate_fcall_arg(e.child(ci.add(vk)), vptype, vptype_name, vparam.name, ctx)
                            }
                        }
                    }
                    ci = ci.add(fvc)
                    pi = pi.add(1)
                    continue
                }
            }
            if fkwi.gte(0) {
                if pi.cast(I32).eq(fkwi) {
                    ci = ci.add(fkc)
                    pi = pi.add(1)
                    continue
                }
            }
            ref param2 : Declaration = fdef_data.params[pi]
            ref ptype_name : Str = param2.explicit_type
            if ptype_name.len().eq(0) {
                ci = ci.add(1)
                pi = pi.add(1)
                continue
            }
            ptype := type_from_name(ptype_name, scope, ctx)
            if ptype.is(Type.Dynamic) {
                ci = ci.add(1)
                pi = pi.add(1)
                continue
            }
            rewrite_til_type_arg(scope, e.child(ci), ptype, in_func, ctx)
            validate_fcall_arg(e.child(ci), ptype, ptype_name, param2.name, ctx)
            ci = ci.add(1)
            pi = pi.add(1)
        }
    case:
        UNREACHABLE(__LOC__)
    }
}

resolve_fcall_return_type := proc(scope: TypeScope, mut e: Expr, name: Str, callee_bind: TypeBinding, in_func: I32, ctx: Context) {
    if name.eq("dyn_call").or(name.eq("dyn_call_ret")).or(name.eq("dyn_has_method")).or(name.eq("dyn_fn")) {
        if e.children.len().gte(3) {
            ref method_arg : Expr = e.child(2)
            if method_arg.node_type.is_literal_str().not() {
                method_arg.type_error("dyn_call method argument must be a string literal", ctx)
            }
        }
    }
    if name.eq("array").or(name.eq("vec")) {
        if e.children.len().gte(2) {
            ref type_arg : Expr = e.child(1)
            if type_arg.node_type.is_literal_str().not() {
                type_arg.type_error("array/vec type_name argument must be a string literal", ctx)
            }
        }
    }
    mut fn_type := scope.get_type(name)
    if fn_type.is(Type.Unknown) {
        e.type_error("undefined function '".concat(name).concat("'"), ctx)
    }
    if fn_type.is(Type.FuncPtr) {
        if callee_bind.is_null().not() {
            if callee_bind.func_type.is(FuncType.None) {
                ref callee0 : Expr = e.child(0)
                callee0.set_expr_til_type(Type.FuncPtr)
                if callee_bind.func_def.is_null().not() {
                    switch callee_bind.func_def.node_type {
                    case NodeType.FuncDef(cb_fdef):
                        if cb_fdef.return_type.len().gt(0) {
                            ref resolved_return_type : Str = resolve_type_alias(scope, cb_fdef.return_type)
                            rt := type_from_name(resolved_return_type, scope, ctx)
                            e.set_expr_til_type(rt)
                        } else {
                            e.set_expr_til_type(Type.None)
                        }
                    case:
                        UNREACHABLE(__LOC__)
                    }
                } else {
                    e.set_expr_til_type(Type.Dynamic)
                }
                if callee_bind.func_def.is_null().not() {
                    ref sig : Expr = callee_bind.func_def
                    switch sig.node_type {
                    case NodeType.FuncDef(sig_fdef):
                        mut nargs : U32 = e.children.len()
                        nargs = nargs.sub(1)
                        if nargs.neq(sig_fdef.params.len()) {
                            e.type_error("function pointer '".concat(name).concat("' expects ").concat(sig_fdef.params.len().to_str()).concat(" args, got ").concat(nargs.to_str()), ctx)
                        }
                        mut ai : U32 = 0
                        while ai.lt(nargs) {
                            if ai.gte(sig_fdef.params.len()) { break }
                            ref arg : Expr = e.child(ai.add(1))
                            ref expected_param : Declaration = sig_fdef.params[ai]
                            ref expected_name : Str = expected_param.explicit_type
                            if expected_name.len().eq(0) {
                                ai = ai.add(1)
                                continue
                            }
                            expected := type_from_name(expected_name, scope, ctx)
                            if expected.is(Type.Unknown).or(expected.is(Type.Dynamic)) {
                                ai = ai.add(1)
                                continue
                            }
                            if arg.expr_til_type().is(Type.Dynamic) {
                                ai = ai.add(1)
                                continue
                            }
                            if arg.expr_til_type().is(expected).not() {
                                e.type_error("function pointer '".concat(name).concat("' param ").concat(ai.add(1).to_str()).concat(": expected ").concat(expected_name).concat(", got ").concat(type_to_name(arg.expr_til_type())), ctx)
                            }
                            ai = ai.add(1)
                        }
                    case:
                        UNREACHABLE(__LOC__)
                    }
                }
                return
            }
        }
    }
    switch fn_type {
    case Type.Custom(ret_name):
        ref resolved_ret_name : Str = resolve_type_alias(scope, ret_name)
        resolved_ret := type_from_name(resolved_ret_name, scope, ctx)
        if resolved_ret.is(Type.Unknown).not() {
            fn_type = resolved_ret
        }
    case:
    }
    e.set_expr_til_type(fn_type)
    // fn_type (from binding.type) already carries the name payload via
    // Type.Struct(name) or Type.Enum(name) when registered, so
    // no additional struct_name assignment is needed.
    ref cur_mode : Mode = ctx.mode
    mut debug_exempt := false
    if cur_mode.debug_prints {
        if name.eq("print").or(name.eq("println")) {
            debug_exempt = true
        }
    }
    if fn_type.is(Type.FuncPtr).not() {
        if in_func.neq(0) {
            callee_ft := scope.get_func_type(name)
            if callee_ft.is(FuncType.Proc).or(callee_ft.is(FuncType.ExtProc)) {
                ctx.proc_calls_count = ctx.proc_calls_count.add(1)
                if debug_exempt.not() {
                    e.type_error("func cannot call proc '".concat(name).concat("'"), ctx)
                }
            }
        } else if ctx.proc_def_depth.gt(0) {
            callee_ft2 := scope.get_func_type(name)
            if callee_ft2.is(FuncType.Proc).or(callee_ft2.is(FuncType.ExtProc)) {
                ctx.proc_calls_count = ctx.proc_calls_count.add(1)
            }
        }
    }
    if scope.get_func_type(name).is(FuncType.Test) {
        e.type_error("test functions cannot be called ('".concat(name).concat("')"), ctx)
    }
}

// True when `method` is a `to_<X>` conversion whose suffix matches the
// receiver's `type_name` ASCII case-insensitively (e.g. `to_u32` on a
// U32, `to_aaa` on an Aaa). Converting a value to its own type is
// always redundant, so the typer emits a clearer diagnostic than the
// generic "no method 'to_u32' for type 'U32'". The check is purely on
// the call shape: core defines no identity converters (no `to_u32` on
// U32, no `to_str` on Str), so this only ever fires on a mistake.
is_self_conversion_method := func(method: Str, type_name: Str) returns Bool {
    if method.starts_with("to_").not() { return false }
    if type_name.len().eq(0) { return false }
    suffix_len := method.len().sub(3)
    if suffix_len.eq(type_name.len()).not() { return false }
    for i in 0..suffix_len {
        ref mc : I8 = method.get(i.add(3))
        ref tc : I8 = type_name.get(i)
        if mc.eq(tc) { continue }
        if tc.gte('A').and(tc.lte('Z')) {
            if tc.add(32).eq(mc) { continue }
        }
        return false
    }
    return true
}

// For methods like `obj.foo(...)`: returns the type-name lookup key
// (a primitive's c_name, a struct/enum payload name, or "" when no
// match). Used by infer_field_access_fcall to find the namespace.
// Avoids the `mut type_name := ""; type_name = ...` reassign pattern
// that leaked the empty Str default.
obj_method_type_name := func(obj: Expr) returns Str {
    if is_primitive(obj.expr_til_type()) {
        return til_type_name_c(obj.expr_til_type())
    }
    if is_aggregate(obj.expr_til_type()) {
        return til_type_name(obj.expr_til_type())
    }
    return ""
}

infer_field_access_fcall := proc(scope: TypeScope, mut e: Expr, in_func: I32, ctx: Context) returns Bool {
    ref mut fa : Expr = e.child(0)
    ref mut obj : Expr = fa.child(0)
    mut method := ""
    switch fa.node_type {
    case NodeType.FieldAccess(m):
        method = m.field_access_name()
    case:
        UNREACHABLE(__LOC__)
        return false
    }
    // `.clone()` on a literal receiver is always redundant: the literal
    // itself is a fresh value, so the clone allocates a copy that the
    // surrounding code would have produced anyway. Reject at the typer
    // level so callers fix the source instead of paying for the copy.
    if method.eq("clone") {
        if obj.node_type.is_nonnull_literal() {
            e.type_error("redundant '' on a literal", ctx)
            e.set_expr_til_type( Type.Unknown)
            return true
        }
    }
    infer_expr(scope, obj, in_func, ctx)

    mut obj_is_type := false
    switch obj.node_type {
    case NodeType.Ident(oit_id):
        if scope.get_struct(oit_id.ident_name()).is_null().not() {
            obj_is_type = true
        }
    case:
    }

    mut ufcs_desugared := false
    if obj_is_type.not() {
        type_name := obj_method_type_name(obj)
        has_type_name := type_name.len().gt(0)

        // Calling `to_<self>` on a value that is already of that type is
        // a redundant self-conversion. Caught here -- before the
        // namespace lookup -- so the diagnostic names the mistake
        // directly instead of surfacing as a generic "no method". Skip
        // namespace calls like `Str.to_str(x)` (handled by the
        // obj_is_type branch), which dispatch on the explicit type.
        if has_type_name.and(is_self_conversion_method(method, type_name)) {
            e.type_error(format(
                "redundant self-conversion: '", method,
                "' would convert ", type_name, " to itself; ",
                "value is already of type '", type_name, "'",
            ), ctx)
            e.set_expr_til_type(Type.Unknown)
            return true
        }
        // Same diagnostic for `x.cast(X)` where X matches the receiver's
        // type -- identity casts are accepted by infer_cast_fcall's
        // same-size rule, but they are always pointless and almost
        // always a copy-paste / migration mistake.
        if has_type_name.and(method.eq("cast")).and(e.children.len().eq(2)) {
            ref cast_target_arg : Expr = e.child(1)
            switch cast_target_arg.node_type {
            case NodeType.Ident(cast_id_data):
                if cast_id_data.ident_name().eq(type_name) {
                    e.type_error(format(
                        "redundant self-cast: 'cast(", type_name,
                        ")' would reinterpret ", type_name,
                        " as itself; drop the .cast(", type_name, ")",
                    ), ctx)
                    e.set_expr_til_type(Type.Unknown)
                    return true
                }
            case:
            }
        }

        ref sdef1 : Expr = scope.get_struct(type_name)
        ref ns_func1 : Expr = find_namespace_func(sdef1, method, scope)
        if ns_func1.is_null() {
            if try_ufcs_rewrite(scope, e, fa, obj, method, type_name, ctx) {
                return false
            }
            if infer_func_ptr_field_call(scope, e, fa, obj, sdef1, method, in_func, ctx) {
                return true
            }
            if has_type_name.not() {
                if obj.expr_til_type().is(Type.Dynamic) {
                    e.type_error(format(
                        "cannot call method '", method, "' on Dynamic value; ",
                        "use 'ref x : Type = ...' to declare with an explicit type first",
                    ), ctx)
                } else {
                    e.type_error(format("no method '", method, "' for type 'unknown'"), ctx)
                }
            } else {
                e.type_error(format("no method '", method, "' for type '", type_name, "'"), ctx)
            }
            e.set_expr_til_type(Type.Unknown)
            return true
        }
        ufcs_desugared = true
        mut instance := obj.clone()
        mut type_ident := Expr.new(ident_node(type_name), obj.line, obj.col)
        type_ident.set_expr_til_type(Type.Struct(type_name.clone()))
        fa.children.set(0, own type_ident)
        // Shift own_args bitmask: bits at position >=1 move to position+1
        // (UFCS inserts self at position 1)
        switch e.node_type {
        case NodeType.FCall(ufcs_fcd):
            old_own := ufcs_fcd.own_args
            mut new_own : U64 = 0
            mut bit : U64 = 1
            for bi in 0..e.children.len() {
                if old_own.band(bit).gt(0) {
                    if bi.eq(0) {
                        new_own = new_own.bor(bit)
                    } else {
                        // Shift this bit left by 1 position
                        new_own = new_own.bor(bit.mul(2))
                    }
                }
                bit = bit.mul(2)
            }
            ufcs_fcd.own_args = new_own
        case:
            UNREACHABLE(__LOC__)
        }
        mut new_children := Vec.new(Expr)
        new_children.push_take(e.children, 0)
        new_children.push(own instance)
        for i in 1..e.children.len() {
            new_children.push_take(e.children, i)
        }
        e.children = new_children
        ref mut fa2 : Expr = e.child(0)
        switch fa2.node_type {
        case NodeType.FieldAccess(_m2):
            method = _m2.field_access_name()
        case:
            UNREACHABLE(__LOC__)
        }
    }

    ref mut fa3 : Expr = e.child(0)
    ref mut obj3 : Expr = fa3.child(0)
    if obj3.expr_til_type().is(Type.Unknown) {
        infer_expr(scope, obj3, in_func, ctx)
    }
    mut obj3_sname := til_type_name(obj3.expr_til_type())
    if obj3_sname.len().eq(0) {
        switch obj3.node_type {
        case NodeType.Ident(obj3_id):
            obj3_sname = obj3_id.ident_name()
        case:
        }
    }
    ref sdef2 : Expr = scope.get_struct(obj3_sname)
    ref ns_func2 : Expr = find_namespace_func(sdef2, method, scope)
    if ns_func2.is_null() {
        e.type_error(format("no namespace function '", method, "'"), ctx)
        e.set_expr_til_type(Type.Unknown)
        return true
    }
    check_member_priv(e, obj3_sname, method, namespace_member_is_priv(sdef2, method), ctx)
    if ctx.auto_gen_depth.eq(0) { mark_ns_member_used(sdef2, method) }
    if ctx.proc_def_depth.gt(0).or(in_func.neq(0)) {
        switch ns_func2.node_type {
        case NodeType.FuncDef(ns_fdef0):
            if ns_fdef0.func_type.is(FuncType.Proc).or(ns_fdef0.func_type.is(FuncType.ExtProc)) {
                ctx.proc_calls_count = ctx.proc_calls_count.add(1)
            }
        case:
        }
    }
    // Ensure obj3 carries the resolved struct type so the interpreter can
    // extract the parent type name via til_type_name for dispatch.
    if obj3_sname.len().gt(0).and(obj3.expr_til_type().is(Type.Struct).not()) {
        obj3.set_expr_til_type(Type.Struct(obj3_sname.clone()))
    }
    switch ns_func2.node_type {
    case NodeType.FuncDef(ns_fdef):
        np := ns_fdef.params.len()
        mut new_args := Vec.new(CtorArg)
        for _ in 0..np {
            new_args.push(own CtorArg.Unfilled())
        }
        mut pos_idx : U32 = 0
        mut seen_named := false
        for i in 1..e.children.len() {
            ref arg : Expr = e.child(i)
            switch arg.node_type {
            case NodeType.NamedArg(aname):
                seen_named = true
                mut slot : I32 = -1
                for j in 0..np {
                    ref param : Declaration = ns_fdef.params[j]
                    if param.name.eq(aname) {
                        slot = j.cast(I32)
                        break
                    }
                }
                if slot.lt(0) {
                    arg.type_error(format("no parameter '", aname, "'"), ctx)
                } else {
                    ref slot_arg : CtorArg = new_args[slot.cast(U32)]
                    if slot_arg.is(CtorArg.Filled) {
                        arg.type_error(format("duplicate argument for parameter '", aname, "'"), ctx)
                    } else {
                        new_args.set(slot.cast(U32), own CtorArg.Filled(arg.child(0).clone()))
                    }
                }
            case:
                if seen_named {
                    arg.type_error("positional argument after named argument", ctx)
                }
                if pos_idx.lt(np) {
                    new_args.set(pos_idx, own CtorArg.Filled(arg.clone()))
                }
                pos_idx = pos_idx.add(1)
            }
        }
        for i in 0..np {
            ref slot_arg : CtorArg = new_args[i]
            if slot_arg.is(CtorArg.Filled).not() {
                ref param : Declaration = ns_fdef.params[i]
                if param.default_value.node_type.is(NodeType.NoDefaultArg).not() {
                    new_args.set(i, own CtorArg.Filled(param.default_value.clone()))
                } else {
                    e.type_error(format("missing argument for parameter '", param.name, "'"), ctx)
                }
            }
        }
        if pos_idx.gt(np) {
            e.type_error(format("too many arguments: expected ", np.to_str(), ", got ", pos_idx.to_str()), ctx)
        }
        mut new_ch := Vec.new(Expr)
        ref callee : Expr = e.child(0)
        new_ch.push(own callee.clone())
        mut missing_filled := false
        for i in 0..np {
            ref slot_arg : CtorArg = new_args[i]
            switch slot_arg {
            case CtorArg.Filled(filled_arg):
                new_ch.push(own filled_arg.clone())
            case:
                // Missing argument already diagnosed above; mark and
                // bail rather than panic so the typer can keep
                // reporting later errors in the same file.
                missing_filled = true
            }
        }
        if missing_filled {
            // Treat as handled so the caller doesn't fall into its
            // FieldAccess-vs-Ident UNREACHABLE -- the missing-args
            // diagnostic was already emitted above.
            return true
        }
        // (Issue #109) `e.children = new_ch` is a bitwise overwrite of
        // the entire Vec struct, which would orphan the old children's
        // data buffer + cloned elem_type Str.  Move-into-existing
        // drops the old contents in place, resizes if needed, and
        // bit-copies the new payload over.
        e.children.move_from(new_ch)
        Vec.delete(own new_ch, true)
        // After UFCS rewriting, e.child(1) is the original receiver
        // Expr that was already inferred at the top of this proc. Skip
        // it (and any already-typed positional arg) to avoid firing
        // priv / member checks twice on the same node. Genuinely
        // unresolved args (Unknown til_type) still get inferred here.
        for i in 1..e.children.len() {
            if e.child(i).expr_til_type().is(Type.Unknown) {
                infer_expr(scope, e.child(i), in_func, ctx)
            }
        }
        for i in 1..e.children.len() {
            if i.sub(1).gte(ns_fdef.params.len()) { break }
            ref param2 : Declaration = ns_fdef.params[i.sub(1)]
            ref ptype : Str = param2.explicit_type
            ptype_t := type_from_name(ptype, scope, ctx)
            rewrite_til_type_arg(scope, e.child(i), ptype_t, in_func, ctx)
            narrow_dynamic(e.child(i), ptype_t)
        }
        for i in 1..e.children.len() {
            if i.sub(1).gte(ns_fdef.params.len()) { break }
            ref param3 : Declaration = ns_fdef.params[i.sub(1)]
            ref ptype_name : Str = param3.explicit_type
            ref arg : Expr = e.child(i)
            if arg.expr_til_type().is(Type.Dynamic) { continue }
            ptype := type_from_name(ptype_name, scope, ctx)
            if ptype.is(Type.Dynamic) { continue }
            switch arg.node_type {
            case NodeType.Literal(Literal.Num(lit_str)):
                if is_numeric_type(ptype) {
                    if literal_in_range(lit_str.literal_num_text(), ptype).not() {
                        arg.type_error(format(
                            "integer literal ", lit_str.literal_num_text(), " out of range for ", til_type_name_c(ptype),
                        ), ctx)
                    }
                    arg.set_expr_til_type(ptype)
                    continue
                }
            case:
            }
            if can_implicit_widen(arg.expr_til_type(), ptype)
            .or(can_implicit_usize_coerce(arg.expr_til_type(), ptype, ptype_name)) {
                arg.set_expr_til_type(ptype)
                continue
            }
            if type_prefix(arg.expr_til_type()).eq(type_prefix(ptype)).not() {
                ref param_name : Str = param3.name
                arg.type_error(format(
                    "argument type mismatch for '", param_name,
                    "': expected ", ptype_name, ", got ", til_type_name_c(arg.expr_til_type()),
                ), ctx)
            } else if is_aggregate(ptype) {
                arg_sname := til_type_name(arg.expr_til_type())
                if arg_sname.len().gt(0) {
                    if ptype_name.eq(arg_sname).not() {
                        ref param_name : Str = param3.name
                        arg.type_error(format(
                            "argument type mismatch for '", param_name,
                            "': expected ", ptype_name, ", got ", arg_sname,
                        ), ctx)
                    }
                }
            }
        }
        if ufcs_desugared {
            // If bit 0 (callee) was set by the parser's 'own expr' handler,
            // propagate it to bit 1 (the UFCS self arg) and clear bit 0.
            if get_own_arg(e, 0) {
                switch e.node_type {
                case NodeType.FCall(ufcs_fcd2):
                    ufcs_fcd2.own_args = ufcs_fcd2.own_args.sub(1)
                case:
                    UNREACHABLE(__LOC__)
                }
                set_own_arg(e, 1)
            }
        }
        np2 := ns_fdef.params.len()
        if ns_fdef.is_enum_variant_ctor {
            for i in 1..e.children.len() {
                if i.sub(1).gte(np2) { break }
                ref pp_evc : Declaration = ns_fdef.params[i.sub(1)]
                if pp_evc.own_type.is(OwnType.Own) { set_own_arg(e, i) }
            }
        }
        if ns_fdef.params.len().gt(0) {
            for i in 1..e.children.len() {
                if i.sub(1).gte(np2) { break }
                ref pp : Declaration = ns_fdef.params[i.sub(1)]
                pown := pp.own_type.is(OwnType.Own)
                ref arg : Expr = e.child(i)
                if pown {
                    if get_own_arg(e, i).not() {
                        arg.type_error(format("argument for 'own' parameter '", pp.name, "' must be marked 'own'"), ctx)
                    }
                } else if get_own_arg(e, i) {
                    arg.type_error(format("'own' on argument but parameter '", pp.name, "' is not 'own'"), ctx)
                }
                if pown {
                switch arg.node_type {
                case NodeType.Ident(an):
                        sf_ab := scope.find(an.ident_name())
                        switch sf_ab {
                        case ScopeFind.Found(ab):
                            if ab.own_type.is(OwnType.Ref) {
                                arg.type_error("cannot pass ref variable to 'own' parameter; use .clone() to make an owned copy", ctx)
                            }
                        case:
                        }
                    case:
                    }
                }
                if pown {
                    if arg.node_type.is_literal_null() {
                        arg.type_error("cannot pass null to 'own' parameter", ctx)
                    }
                }
                if pp.own_type.is(OwnType.Shallow) {
                    if arg.node_type.is_literal_null() {
                        arg.type_error("cannot pass null to 'shallow' parameter", ctx)
                    }
                }
            }
        }
        mut rt := Type.None
        if ns_fdef.return_type.len().gt(0) {
            rt = type_from_name(ns_fdef.return_type, scope, ctx)
        }
        e.set_expr_til_type(rt)
        // Issue #191: namespace macro calls require all arguments to be comptime-known.
        if ns_fdef.func_type.is(FuncType.Macro) {
            for ai in 1..e.children.len() {
                if e.child(ai).expr_is_comptime(scope).not() {
                    e.child(ai).type_error("macro argument must be known at compile time", ctx)
                }
            }
        }
    case NodeType.StructDef(_ns_sdef):
        mut type_ident := Expr.new(ident_node(method), e.child(0).line, e.child(0).col)
        e.children.set(0, own type_ident)
        return infer_struct_constructor_fcall_impl(scope, ns_func2, e, method, in_func, ctx)
    case:
        UNREACHABLE(__LOC__)
        return false
    }
    return true
}

// Issue #179 step 1: cross-file priv check for standalone funcs.
// The duplicate-fire problem this used to dedup against (FieldAccess
// receiver re-walk in infer_field_access_fcall) is now prevented at
// source: the post-UFCS re-walk skips already-typed children, so the
// receiver Expr is inferred exactly once.
priv check_priv_access := proc(mut e: Expr, name: Str, mut b: TypeBinding, ctx: Context) {
    if b.is_null() { return }
    if b.is_priv.not() { return }
    if b.path.eq(ctx.path).not() {
        // init_declarations_unit rewrote top-level priv decls to
        // `priv__<path>__<orig>`. Prefer the original identifier in the
        // diagnostic so users see the source form, not the mangle.
        mut display_name := name
        if b.orig_name.len().gt(0).and(b.name.starts_with("priv__")) {
            display_name = b.orig_name
        }
        e.type_error("'".concat(display_name).concat("' is private to '").concat(b.path)
            .concat("'; remove 'priv' to expose it"), ctx)
        return
    }
    if b.orig_name.len().eq(0) { return }
    // Top-level priv decls (mangled `priv__<path>__<orig>`) live at file
    // scope, so the same-file path check above is sufficient -- skip the
    // nested-parent check that follows, which assumes the
    // `<parent>_<orig>` lifted-nested layout.
    if b.name.starts_with("priv__") { return }
    // Issue #93 follow-up: lifted nested defs are function-scoped within
    // the original parent function. init_declarations_unit sets
    // b.orig_name to the user-facing identifier and mangles b.name as
    // `<parent>_<orig>`. Allow references from:
    //   - the parent function itself (current_top_func_name == parent), or
    //   - any other lifted descendant whose own mangled name starts with
    //     `<parent>_` (sibling helpers and inner ns methods), or
    //   - a ns-method body of a lifted struct/enum (tracked through
    //     current_type_name).
    parent_len := b.name.len().sub(b.orig_name.len()).sub(1)
    parent_name := b.name.substr(0, parent_len)
    parent_underscore := parent_name.concat("_")
    if ctx.current_top_func_name.eq(parent_name) { return }
    if ctx.current_top_func_name.starts_with(parent_underscore) { return }
    if ctx.current_type_name.eq(parent_name) { return }
    if ctx.current_type_name.starts_with(parent_underscore) { return }
    e.type_error("'".concat(b.orig_name).concat("' is a local def of '")
        .concat(parent_name).concat("' and cannot be referenced from outside it"), ctx)
}

// Issue #179 + follow-up: cross-file priv check for type names that
// appear in declaration positions (parameter types, return types,
// ref/let decl explicit_type). The Ident-path check_priv_access only
// fires when a name is referenced as a value -- a user can otherwise
// write ~func(x: PrivStruct) returns PrivStruct~ in another file
// silently. Skip when inside the type's own namespace (auto-gen and
// hand-written ns methods both reference the parent type by name).
// Thin wrapper: looks up the binding, gates on current_type_name,
// then defers to check_priv_access for the actual emit.
priv check_priv_type_name := proc(mut e: Expr, name: Str, scope: TypeScope, ctx: Context) {
    if name.len().eq(0) { return }
    if ctx.current_type_name.eq(name) { return }
    ref mut b : TypeBinding = scope.get_binding(name)
    check_priv_access(e, name, b, ctx)
}

// Issue #179 steps 4-5: priv check for struct fields and namespace
// methods. Stricter than top-level priv: priv members are only
// visible inside the struct's own namespace methods, not just the
// declaring file. current_type_name == owner_name iff we are
// type-checking a member body of that struct.
check_member_priv := proc(mut e: Expr, owner_name: Str, member_name: Str, member_is_priv: Bool, ctx: Context) {
    if member_is_priv.not() { return }
    if ctx.current_type_name.eq(owner_name) { return }
    e.type_error("'".concat(owner_name).concat(".").concat(member_name)
        .concat("' is private to its struct; remove 'priv' to expose it"), ctx)
}

// Forbid `free(own X)` when X is an aggregate local whose type has a
// `delete` method. Such a shallow free releases only the struct box, and
// because passing `own X` makes the asap pass treat X as transferred (see
// expr_transfers_own), asap then skips the proper X.delete -- so X's owned
// fields leak. Demonstrated: `free(own vec_local)` leaks the element buffer.
// Exceptions fall out naturally: `self` is a param (not a local) so a
// delete method's own `free(own self)` box-release is allowed, and raw
// pointer types (U8/Dynamic) have no `delete` method so raw frees are fine.
priv check_free_managed_local := proc(scope: TypeScope, e: Expr, ctx: Context) {
    if e.children.len().lt(2) { return }
    if get_own_arg(e, 1).not() { return }
    ref arg : Expr = e.child(1)
    switch arg.node_type {
    case NodeType.Ident(an):
        sf := scope.find(an.ident_name())
        switch sf {
        case ScopeFind.Found(b):
            if b.is_param { return }
            if b.own_type.is(OwnType.Ref) { return }
            tn := til_type_name(b.type)
            if tn.len().eq(0) { return }
            ref sdef : Expr = scope.get_struct(tn)
            if sdef.is_null() { return }
            ref del : Expr = find_namespace_func(sdef, "delete", scope)
            if del.is_null() { return }
            e.type_error(format(
                "free(own ", an.ident_name(), ") shallow-frees managed type '", tn,
                "': passing 'own' makes the asap pass skip ", tn,
                ".delete, leaking its owned fields -- call ", tn, ".delete(own ",
                an.ident_name(), ", true) or let the asap pass free it",
            ), ctx)
        case:
        }
    case:
    }
}

// Issue #212: byte size of an integer primitive Type, or 0 for any
// non-integer-reinterpret-able type. F32 (4 bytes) and Bool are
// deliberately excluded -- `cast` is a bit reinterpret, not a value
// conversion. Only the sizes with a full same-size signed/unsigned pair
// in both the codegen and interpreter value model are returned (4 and 8);
// 1-byte (I8 has no interpreter Value variant) and 2-byte (no U16) are
// intentionally left at 0 for now.
cast_int_size := func(t: Type) returns I32 {
    tn := til_type_name_c(t)
    if tn.eq("I8").or(tn.eq("U8"))   { return 1 }
    if tn.eq("I16").or(tn.eq("U16")) { return 2 }
    if tn.eq("I32").or(tn.eq("U32")) { return 4 }
    if tn.eq("I64").or(tn.eq("U64")) { return 8 }
    return 0
}

// True for the signed integer primitives the cast typer recognises.
// Used by cast_pair_ok to gate same-signedness widening; cross-
// signedness widening (e.g. I8 -> U16) is deferred for now because it
// changes the value's signed interpretation -- the operand and result
// no longer agree on what the bits mean.
cast_is_signed := func(t: Type) returns Bool {
    tn := til_type_name_c(t)
    if tn.eq("I8").or(tn.eq("I16")).or(tn.eq("I32")).or(tn.eq("I64")) {
        return true
    }
    return false
}

// True iff cast(src -> target) is legal for issue #212's current
// scope: same-size integer reinterpret (any signedness combination)
// OR same-signedness widening (src.size < target.size, both signed
// or both unsigned). Narrowing and cross-signedness widening are
// intentionally rejected.
cast_pair_ok := func(src: Type, target: Type) returns Bool {
    src_size := cast_int_size(src)
    target_size := cast_int_size(target)
    if src_size.eq(0).or(target_size.eq(0)) { return false }
    if src_size.eq(target_size) { return true }
    if src_size.lt(target_size) {
        return cast_is_signed(src).eq(cast_is_signed(target))
    }
    return false
}

// Issue #212: type-check a `cast(e, T)` call. Validates that e and T are
// integer primitives of the same byte size, rewrites the T argument into
// a Type value (so downstream passes see a well-formed Type, as with
// Vec.new(I32)), and sets the call's result type to T -- the typer's
// stand-in for the not-yet-expressible `returns T`.
infer_cast_fcall := proc(scope: TypeScope, mut e: Expr, in_func: I32, ctx: Context) {
    if e.children.len().neq(3) {
        e.type_error("cast expects (value, Type), e.g. x.cast(I32)", ctx)
        e.set_expr_til_type(Type.Unknown)
        return
    }
    // Idempotency: if the typer has already processed this cast (e.g. a
    // for-range desugar re-infers an already-typed FCall), child(2) is
    // no longer the bare Ident but a Type-value expr from
    // make_til_type_expr. Re-infer args for safety but skip the rewrite
    // / target-type derivation.
    if e.expr_til_type().is(Type.Unknown).not() {
        infer_expr(scope, e.child(1), in_func, ctx)
        return
    }
    infer_expr(scope, e.child(1), in_func, ctx)
    src_type := e.child(1).expr_til_type()
    mut tname := ""
    switch e.child(2).node_type {
    case NodeType.Ident(tn0): tname = tn0.ident_name()
    case:
        e.child(2).type_error("cast target must be a type name, e.g. cast(x, I32)", ctx)
        e.set_expr_til_type(Type.Unknown)
        return
    }
    target_type := til_type_from_explicit_type(tname)
    if cast_pair_ok(src_type, target_type).not() {
        e.type_error(format(
            "cast only supports same-size integer reinterpret ",
            "(any signedness) and same-signedness widening; ",
            "cannot cast ", til_type_name_c(src_type), " to ", tname,
        ), ctx)
        e.set_expr_til_type(Type.Unknown)
        return
    }
    mut replacement := e.child(2).make_til_type_expr(target_type)
    move(e.child(2), replacement, Expr.size())
    infer_expr(scope, e.child(2), in_func, ctx)
    e.set_expr_til_type(target_type)
}

infer_fcall_expr := proc(scope: TypeScope, mut e: Expr, in_func: I32, ctx: Context) {
    if e.child(0).node_type.is(NodeType.FieldAccess) {
        if infer_field_access_fcall(scope, e, in_func, ctx) { return }
    }
    ref mut callee : Expr = e.child(0)
    mut name := ""
    switch callee.node_type {
    case NodeType.Ident(name0):
        // Reject user-code calls to the internal ~get_payload~ builtin.
        // The typer's switch case desugar in make_switch_case_condition
        // and the initer's generated method bodies pre-set til_type on
        // their emitted FCalls; user-written FCalls arrive here with
        // til_type still Unknown.
        if name0.ident_name().eq("get_payload") {
            if e.expr_til_type().is(Type.Unknown) {
                e.type_error("bare get_payload(...) is not allowed; use a switch case binding instead", ctx)
                return
            }
            // typer-emitted: infer the receiver argument so downstream
            // checks see its type, but skip the normal callee-binding
            // resolution -- otherwise resolve_fcall_return_type would
            // overwrite our preset Struct/Enum til_type with the
            // declared `Dynamic` return of dyn.til's get_payload, and a
            // condition-side field access on this FCall (e.g.
            // ~case Shape.Dot(Point(x = 0)):~) would then fail with
            // "field access on non-struct value".
            if e.children.len().gt(1) {
                infer_expr(scope, e.child(1), in_func, ctx)
            }
            return
        }
        name = name0.ident_name()
    case:
        UNREACHABLE(__LOC__)
        return
    }
    ref resolved_name : Str = resolve_type_alias(scope, name)
    if resolved_name.eq(name).not() {
        callee.node_type = ident_node(resolved_name)
        name = resolved_name.clone()
    }
    if name.eq("cast") {
        infer_cast_fcall(scope, e, in_func, ctx)
        return
    }
    if infer_struct_constructor_fcall(scope, e, name, in_func, ctx) { return }
    ref mut callee_bind : TypeBinding = scope.get_binding(name)
    if callee_bind.is_null().not() {
        callee_bind.used = true
        check_priv_access(e, name, callee_bind, ctx)
        if callee_bind.func_def.is_null().not() {
            desugar_user_func_fcall_args(e, name, callee_bind, ctx)
        }
    }
    infer_and_validate_fcall_args(scope, e, callee_bind, in_func, ctx)
    if name.eq("free") { check_free_managed_local(scope, e, ctx) }
    // Issue #191: macro calls require all arguments to be comptime-known.
    if callee_bind.is_null().not() {
        if callee_bind.func_type.is(FuncType.Macro) {
            for ai in 1..e.children.len() {
                if e.child(ai).expr_is_comptime(scope).not() {
                    e.child(ai).type_error("macro argument must be known at compile time", ctx)
                }
            }
        }
    }
    validate_fcall_own_args(scope, e, callee_bind, ctx)
    resolve_fcall_return_type(scope, e, name, callee_bind, in_func, ctx)
    return
}

priv infer_expr := proc(scope: TypeScope, mut expr: Expr, in_func: I32, ctx: Context) {
    switch expr.node_type {
    case NodeType.Literal(Literal.Num):  infer_literal_expr(expr)
    case NodeType.Literal(Literal.Null): infer_literal_expr(expr)
    case NodeType.Ident:       infer_ident_expr(scope, expr, ctx)
    case NodeType.FuncDef:     infer_func_def_expr(scope, expr, ctx)
    case NodeType.StructDef:   infer_type_def_expr(scope, expr, ctx)
    case NodeType.EnumDef:     infer_type_def_expr(scope, expr, ctx)
    case NodeType.FCall:       infer_fcall_expr(scope, expr, in_func, ctx)
    case NodeType.FieldAccess: infer_field_access_expr(scope, expr, in_func, ctx)
    case NodeType.MapLit:      infer_map_lit_expr(scope, expr, in_func, ctx)
    case NodeType.SetLit:      infer_set_lit_expr(scope, expr, in_func, ctx)
    case NodeType.NamedArg:    infer_named_arg_expr(scope, expr, in_func, ctx)
    case:
        expr.set_expr_til_type(Type.Unknown)
    }
}

infer_ident_expr := proc(scope: TypeScope, mut expr: Expr, ctx: Context) {
    switch expr.node_type {
    case NodeType.Ident(id_name):
        type := scope.get_type(id_name.ident_name())
        if type.is(Type.Unknown) {
            expr.type_error("undefined symbol '".concat(id_name.ident_name()).concat("'"), ctx)
        }
        expr.set_expr_til_type(type)
        ref mut ib : TypeBinding = scope.get_binding(id_name.ident_name())
        if ib.is_null().not() {
            // #187 step 1: skip "used" marking when we're inside the
            // ident's own type namespace. Auto-generated clone/delete/
            // variant-constructor bodies reference the parent type by
            // name; counting those would mask a genuinely unused priv
            // type. External Ident references still mark it used.
            if ctx.current_type_name.eq(id_name.ident_name()).not() {
                ib.used = true
            }
            check_priv_access(expr, id_name.ident_name(), ib, ctx)
            if ib.func_def.is_null().not() {
                expr.set_expr_til_type(Type.FuncPtr)
            }
            if ib.struct_def.is_null().not() {
                if til_type_name(expr.expr_til_type()).len().eq(0) {
                    ref resolved_name : Str = resolve_type_alias(scope, id_name.ident_name())
                    expr.set_expr_til_type(Type.Custom(resolved_name.clone()))
                }
            }
        }
    case:
        UNREACHABLE(__LOC__)
    }
}

infer_named_arg_expr := proc(scope: TypeScope, mut expr: Expr, in_func: I32, ctx: Context) {
    if expr.children.len().gt(0) {
        infer_expr(scope, expr.child(0), in_func, ctx)
    }
}

infer_map_lit_expr := proc(scope: TypeScope, mut expr: Expr, in_func: I32, ctx: Context) {
    for e_i : Expr in expr.children {
        infer_expr(scope, e_i, in_func, ctx)
    }
}

infer_set_lit_expr := proc(scope: TypeScope, mut expr: Expr, in_func: I32, ctx: Context) {
    for e_i : Expr in expr.children {
        infer_expr(scope, e_i, in_func, ctx)
    }
}

// Recursively scan `e` for any read or write of `self.<field_name>`
// (FieldAccess or FieldAssign whose receiver chain bottoms out in
// Ident("self")). Used to verify that user-written delete bodies
// reference each declared `own` field at least once -- if a field is
// never touched, the delete cannot possibly free it and any heap
// allocation the field's `own` qualifier announced is leaked at every
// destruction site (Map.delete, Vec.delete, scope_free, the
// auto-generated Value.delete chain, etc.).
priv expr_uses_self_field := proc(e: Expr, field_name: Str) returns Bool {
    if e.is_null() { return false }
    switch e.node_type {
    case NodeType.FieldAccess(_fa_name):
        if _fa_name.field_access_name().eq(field_name) {
            if e.children.len().gt(0) {
                ref recv : Expr = e.child(0)
                switch recv.node_type {
                case NodeType.Ident(_id):
                    if _id.ident_name().eq("self") { return true }
                case:
                }
            }
        }
    case NodeType.FieldAssign(fad):
        _fa_name := fad.name
        if _fa_name.eq(field_name) {
            if e.children.len().gt(0) {
                ref recv2 : Expr = e.child(0)
                switch recv2.node_type {
                case NodeType.Ident(_id2):
                    if _id2.ident_name().eq("self") { return true }
                case:
                }
            }
        }
    case:
    }
    for ec : Expr in e.children {
        if expr_uses_self_field(ec, field_name) { return true }
    }
    return false
}

// Walk a struct's namespace decls; for the user-written `delete`
// (skip auto-generated ones), verify the body references each `own`
// field that the struct declares. A miss means the field's heap
// allocation has no path out -- the destructor silently leaks every
// time it runs. Issued at struct typing time so the error points at
// the struct declaration.
priv check_user_delete_frees_own_fields := proc(struct_name: Str, sdef: Expr, ctx: Context) {
    switch sdef.node_type {
    case NodeType.StructDef(_cdsdd):
        ref cdns : Vec = def_ns_decls(sdef)
        for cdnd : Declaration in cdns {
            if cdnd.name.eq("delete").not() { continue }
            if cdnd.default_value.is_null() { continue }
            switch cdnd.default_value.node_type {
            case NodeType.FuncDef(_cdfd):
                if _cdfd.auto_generated { continue }
                if cdnd.default_value.children.len().eq(0) { continue }
                ref cdbody : Expr = cdnd.default_value.child(0)
                for fd : Declaration in _cdsdd.fields {
                    if fd.own_type.is(OwnType.Own).not() { continue }
                    if expr_uses_self_field(cdbody, fd.name).not() {
                        cdnd.default_value.type_error(
                            "delete on '".concat(struct_name)
                                .concat("' never references 'own' field 'self.")
                                .concat(fd.name)
                                .concat("' -- declaring the field 'own' announces a heap allocation; the destructor must free it (e.g. `free(own self.")
                                .concat(fd.name)
                                .concat(")`) or transfer its ownership."), ctx)
                    }
                }
            case:
            }
        }
    case:
    }
}

// Resolve enum payload type names against scope so e.g. a macro param `T`
// used as `Variant: T` payload is marked used, matching how StructDef
// field types do. Helper takes EnumDef directly (not via the switch-case
// destructure) so the typer carries Map<I64,Str> type info into the
// payload-types subscript without mixing the OutOfBounds (Vec) and
// KeyNotFound (Map) throws-inference paths.
priv typer_resolve_enum_payload_types := func(edef: EnumDef, scope: TypeScope, ctx: Context) {
    for k_e in 0..edef.variants.len() {
        if edef.payload_types.has(k_e.to_i64()) {
            ref pt_e : Str = edef.payload_types[k_e.to_i64()]
            if pt_e.len().gt(0) {
                _ : Type = type_from_name(pt_e, scope, ctx)
            }
        }
    }
}

infer_type_def_expr := proc(scope: TypeScope, mut expr: Expr, ctx: Context) {
    expr.set_expr_til_type(Type.None)
    inner := TypeScope(parent = scope)
    switch expr.node_type {
    case NodeType.StructDef(tc_sdd):
        for fd : Declaration in tc_sdd.fields {
            if fd.redundant_mut {
                fd.default_value.type_error("redundant 'mut' on struct field '".concat(fd.name).concat("': fields are mutable by default; drop the 'mut' (use 'const' to make the field immutable)"), ctx)
            }
            if fd.default_value.is_null().not().and(fd.default_value.node_type.is(NodeType.NoDefaultArg).not()) {
                infer_expr(inner, fd.default_value, 0, ctx)
                check_ref_field_owned_default(fd, inner, ctx)
            }
            if fd.explicit_type.len().gt(0) {
                fd.til_type =type_from_name(fd.explicit_type, inner, ctx)
                if fd.til_type.is(Type.Unknown).not() {
                    if fd.default_value.is_null().not().and(fd.default_value.node_type.is(NodeType.NoDefaultArg).not()) {
                        if fd.default_value.node_type.is_literal_num().and(is_numeric_type(fd.til_type)) {
                            fd.default_value.set_expr_til_type(fd.til_type)
                        }
                        if fd.default_value.node_type.is_literal_null().not() {
                            narrow_dynamic(fd.default_value, fd.til_type)
                        }
                    }
                }
            } else {
                if fd.default_value.is_null().not() {
                    fd.til_type =fd.default_value.expr_til_type()
                }
            }
            inner.set(fd.name, fd.til_type, FuncType.None, fd.is_mut, ctx.path, expr.line, expr.col, false, fd.own_type)
            if fd.til_type.is(Type.FuncPtr) {
                ref mut _fb : TypeBinding = inner.get_binding(fd.name)
                if fd.default_value.is_null().not() {
                    switch fd.default_value.node_type {
                    case NodeType.Ident(_dv_id):
                        ref _src : TypeBinding = inner.get_binding(_dv_id.ident_name())
                        if _src.is_null().not().and(_src.func_def.is_null().not()) {
                            _fb.func_def = _src.func_def
                        }
                    case:
                    }
                }
                if _fb.func_def.is_null() {
                    if fd.explicit_type.len().gt(0) {
                        ref _fsb : TypeBinding = inner.get_binding(fd.explicit_type)
                        if _fsb.is_null().not().and(_fsb.func_def.is_null().not()) {
                            if _fsb.func_def.children.len().eq(0) {
                                _fb.func_def = _fsb.func_def
                            }
                        }
                    }
                }
            }
        }
    case NodeType.EnumDef(tc_edd):
        // Issue #57: see typer_resolve_enum_payload_types.
        typer_resolve_enum_payload_types(tc_edd, inner, ctx)
    case:
    }
    // Type-check ns_decls (stored directly by parser, not via body).
    // Flip ctx.typing_namespace_member so infer_func_def_expr accepts
    // test() decls at the namespace level (issue #51).
    saved_in_ns := ctx.typing_namespace_member
    ctx.typing_namespace_member = true
    ref tc_ns : Vec = def_ns_decls(expr)
    for tc_nd : Declaration in tc_ns {
        if tc_nd.default_value.is_null() { continue }
        if tc_nd.default_value.node_type.is(NodeType.NoDefaultArg) { continue }
        switch tc_nd.default_value.node_type {
        case NodeType.FuncDef(tc_fd):
            mut tc_rt := Type.None
            if tc_fd.return_type.len().gt(0) {
                tc_rt = type_from_name(tc_fd.return_type, inner, ctx)
            }
            tc_nd.til_type =tc_rt.clone()
            inner.set(tc_nd.name, tc_rt, tc_fd.func_type, false, ctx.path, 0, 0, false, OwnType.Shallow)
            ref mut tc_fb : TypeBinding = inner.get_binding(tc_nd.name)
            tc_fb.func_def = tc_nd.default_value
            if tc_fd.func_type.is(FuncType.ExtFunc).or(tc_fd.func_type.is(FuncType.ExtProc)) {
                tc_fb.is_builtin = true
            }
            infer_func_def_expr(inner, tc_nd.default_value, ctx)
        case:
            infer_expr(inner, tc_nd.default_value, 0, ctx)
            tc_nd.til_type =tc_nd.default_value.expr_til_type().clone()
        }
    }
    ctx.typing_namespace_member = saved_in_ns
    // Static check: a hand-written `delete` must free (or transfer) every
    // `own` field, otherwise the auto-generated destructor chain through
    // Value.delete / Map.delete / Vec.delete / scope_free leaks the
    // allocation the field's `own` qualifier declared.
    if expr.node_type.is(NodeType.StructDef) {
        check_user_delete_frees_own_fields(ctx.current_type_name, expr, ctx)
    }
    TypeScope.delete(own inner)
}

// Issue #223 step 3: a struct is auto-shallow (safe to pass/return by a
// byte copy, like a primitive) when ALL of:
//   - its size fits in a machine word (total_struct_size <= 8 = UPtr.size()),
//   - it has no `own` fields (an owned heap pointer would be aliased /
//     double-freed by a byte copy -> the struct is "deep"),
//   - it has no `ref` fields (disqualified for now; revisitable later), AND
//   - every field's TYPE is itself auto-shallow (a primitive or another
//     auto-shallow struct). The transitive check closes the hole where a
//     size-8 struct embeds a deep struct inline.
// Enums are not covered here (revisit separately). Mirrors builder's
// is_pod_struct field rules, plus the size gate.
PTR_SIZE_BYTES : I32 = 8
is_shallow_struct := func(type_name: Str, scope: TypeScope) returns Bool {
    if type_name.len().eq(0) { return false }
    if scope.is_null() { return false }
    ref sdef : Expr = scope.get_struct(type_name)
    if sdef.is_null() { return false }
    switch sdef.node_type {
    case NodeType.StructDef(sdd):
        if sdd.total_struct_size.gt(PTR_SIZE_BYTES) { return false }
        if sdd.fields.len().eq(0) { return false }
        for fd : Declaration in sdd.fields {
            if fd.own_type.is(OwnType.Own) { return false }
            if fd.own_type.is(OwnType.Ref) { return false }
            ref ftn : Str = fd.explicit_type
            if ftn.len().eq(0) { return false }
            if is_primitive(til_type_from_explicit_type(ftn)) { continue }
            if is_shallow_struct(ftn, scope) { continue }
            return false
        }
        return true
    case:
    }
    return false
}

// A param/return type qualifies for auto-shallow if it is a primitive
// (step 1) or a small value-shaped struct (step 3).
is_auto_shallow_type := func(t: Type, type_name: Str, scope: TypeScope) returns Bool {
    if is_primitive(t) { return true }
    return is_shallow_struct(type_name, scope)
}

infer_func_sig_expr := func(scope: TypeScope, mut expr: Expr) {
    switch expr.node_type {
    case NodeType.FuncDef(fdef):
        // Issue #223 step 1: a function-pointer signature must match the
        // auto-shallow ABI of the ordinary func/proc it will hold, so
        // normalize primitive params/returns to Shallow here too. Otherwise
        // the call-through codegen would deref a value return as a pointer.
        sig_auto_shallow := fdef.func_type.is(FuncType.Func).or(fdef.func_type.is(FuncType.Proc))
        if fdef.return_type.len().gt(0) {
            return_type_name := fdef.return_type.clone()
            ref resolved_return_type : Str = resolve_type_alias(scope, return_type_name)
            fdef.return_type = resolved_return_type
            // Issue #223 step 2: forbid redundant 'shallow' on a primitive
            // funcptr return. COMMENTED OUT during rollout (see infer_func_def_expr).
            // NOTE: infer_func_sig_expr is a func with no ctx, so enabling this
            // needs the diagnostic raised from a proc context.
            // if sig_auto_shallow.and(fdef.return_own_type.is(OwnType.Shallow)) {
            //     if is_primitive(til_type_from_explicit_type(resolved_return_type)) {
            //         <raise: redundant 'shallow' on primitive return type ... drop it>
            //     }
            // }
            if sig_auto_shallow.and(fdef.return_own_type.is(OwnType.Own)) {
                if is_primitive(til_type_from_explicit_type(resolved_return_type)) {
                    fdef.return_own_type = OwnType.Shallow
                }
            }
        }
        for param : Declaration in fdef.params {
            ptype_name := param.explicit_type.clone()
            ref resolved_ptype : Str = resolve_type_alias(scope, ptype_name)
            param.explicit_type = resolved_ptype
            param.til_type =til_type_from_explicit_type(resolved_ptype)
            // Issue #223 step 2: forbid redundant 'shallow' on a primitive
            // funcptr parameter. COMMENTED OUT during rollout (see infer_func_def_expr).
            // if sig_auto_shallow.and(fdef.return_own_type.is(OwnType.Ref).not()).and(param.own_type.is(OwnType.Shallow)).and(param.is_mut.not()).and(is_primitive(param.til_type)) {
            //     <raise: redundant 'shallow' on primitive parameter ... drop it>
            // }
            if sig_auto_shallow.and(fdef.return_own_type.is(OwnType.Ref).not()).and(param.own_type.is(OwnType.Ref)).and(param.is_mut.not()).and(is_primitive(param.til_type)) {
                param.own_type = OwnType.Shallow
            }
            // A FuncPtr param is an 8-byte pointer; the C ABI passes it
            // by value just like a primitive, so the funcptr-sig has to
            // match auto-shallow too. Otherwise emit_fcall_funcptr_cast
            // generates `(void * *)` for the param and the arg emit
            // takes its address, both wrong for a callee that expects
            // the function pointer by value. param.til_type at this
            // point is Type.Custom(name) -- the FuncPtr-ness lives in
            // the scope binding for the alias name, not in the inline
            // Type, so look it up.
            if sig_auto_shallow.and(fdef.return_own_type.is(OwnType.Ref).not()).and(param.own_type.is(OwnType.Ref)).and(param.is_mut.not()) {
                ref pbind : TypeBinding = scope.get_binding(resolved_ptype)
                if pbind.is_null().not().and(pbind.type.is(Type.FuncPtr)) {
                    param.own_type = OwnType.Shallow
                }
            }
        }
    case:
        UNREACHABLE(__LOC__)
    }
    expr.set_expr_til_type(Type.FuncPtr)
}

check_ref_function_returns := proc(func_scope: TypeScope, expr: Expr, ctx: Context) {
    mut throws_count : USize = 0
    switch expr.node_type {
    case NodeType.FuncDef(fdef):
        if fdef.return_own_type.is(OwnType.Ref).not() { return }
        throws_count = fdef.throw_types.len()
    case:
        UNREACHABLE(__LOC__)
        return
    }
    ref body : Expr = expr.child(0)
    for stmt : Expr in body.children {
        if stmt.node_type.is(NodeType.Return).not() { continue }
        if stmt.children.len().eq(0) { continue }
        ref rv : Expr = stmt.child(0)
        // A throwing ref-returning fn gets a synthetic `return null`
        // fallback from process_throw_catch_in_func_body. It is
        // unreachable on the success path and unused on the error path
        // (the err code flows out through the out-param), so allow it.
        if throws_count.gt(0).and(rv.node_type.is_literal_null()) { continue }
        if expr_is_borrow_source(rv, func_scope).not() {
            stmt.type_error("ref function must return a parameter or ref variable", ctx)
        }
    }
}

// Look up the payload type for a variant of a named enum, by enum
// name and variant name. Returns "" if either is unknown. Used by
// collect_switch_case_bindings to translate a `case E.V(x):` pattern
// into the type that binding `x` will carry once the case-body
// payload Decl is emitted.
priv lookup_variant_payload_type := func(scope: TypeScope, enum_name: Str, variant_name: Str) returns Str {
    ref edef : Expr = scope.get_struct(enum_name)
    if edef.is_null() { return "" }
    switch edef.node_type {
    case NodeType.EnumDef(edd):
        for vi in 0..edd.variants.len() {
            ref vn : Str = edd.variants[vi]
            if vn.eq(variant_name) {
                vtag : I64 = vi.to_i64()
                if edd.payload_types.has(vtag) {
                    ref pt : Str = edd.payload_types[vtag]
                    return pt.clone()
                }
                return ""
            }
        }
    case:
    }
    return ""
}

// Walk a function body and seed ctx.lowering_param_types with the
// names + payload types bound by switch-case patterns. The
// throw/catch lowering pass runs before infer_body emits the
// case-body payload Decls (via make_switch_case_condition), so the
// body-Decl scan in resolve_value_type can't see them yet.
// Without this seeding, a `case NodeType.EnumDef(ed):` body that
// does `ed.payload_types[idx]!` resolves `ed`'s type as "" and the
// throws lookup falls back to suffix-matching ".get", picking the
// wrong throw type (Array.get's OutOfBounds instead of Map.get's
// KeyNotFound).
priv collect_switch_case_bindings := proc(mut ctx: Context, e: Expr) {
    if e.node_type.is(NodeType.Case).and(e.children.len().gte(1)) {
        ref pat : Expr = e.child(0)
        // Pattern shape: FCall(<EnumName>.<Variant>, <binding_ident>)
        if pat.node_type.is(NodeType.FCall).and(pat.children.len().eq(2)) {
            ref callee : Expr = pat.child(0)
            ref bind : Expr = pat.child(1)
            if callee.node_type.is(NodeType.FieldAccess).and(callee.children.len().gt(0))
              .and(bind.node_type.is(NodeType.Ident)) {
                ref enum_recv : Expr = callee.child(0)
                switch enum_recv.node_type {
                case NodeType.Ident(en_id):
                    switch callee.node_type {
                    case NodeType.FieldAccess(fa):
                        switch bind.node_type {
                        case NodeType.Ident(b_id):
                            payload_type := lookup_variant_payload_type(ctx.scope, en_id.ident_name(), fa.field_access_name())
                            if payload_type.len().gt(0) {
                                ctx.lowering_param_types.set(own b_id.ident_name(), own payload_type)
                            }
                        case:
                        }
                    case:
                    }
                case:
                }
            }
        }
    }
    for ci in 0..e.children.len() {
        ref c : Expr = e.child(ci)
        collect_switch_case_bindings(ctx, c)
    }
}

infer_func_def_expr := proc(scope: TypeScope, mut expr: Expr, mut ctx: Context) {
    if expr.children.len().eq(0) {
        infer_func_sig_expr(scope, expr)
        return
    }
    expr.set_expr_til_type(Type.None)
    // Snapshot + clear the namespace flag so nested funcs typed by
    // recursive infer_expr calls aren't treated as namespace members.
    ifd_in_ns := ctx.typing_namespace_member
    ctx.typing_namespace_member = false
    switch expr.node_type {
    case NodeType.FuncDef(fdef):
        is_func := fdef.func_type.is(FuncType.Func)
        is_macro := fdef.func_type.is(FuncType.Macro)
        // Issue #57: macros that are pure templates (returning
        // StructDef / EnumDef / FuncDef, or with a `Type` parameter) are
        // expanded at each call site by initer's pre-pass. Detect the
        // condition up front so every subsequent body-walk and param-
        // resolution skip cleanly -- references to the type-params can't
        // be resolved until expansion. Mirrors rstil typer.rs:1090-1097.
        mut macro_is_template := false
        if is_macro {
            mtg_ret := fdef.return_type.eq("StructDef")
                .or(fdef.return_type.eq("EnumDef"))
                .or(fdef.return_type.eq("FuncDef"))
                .or(fdef.return_type.eq("FunctionDef"))
            if mtg_ret { macro_is_template = true }
            if macro_is_template.not() {
                for tmp_param : Declaration in fdef.params {
                    if tmp_param.explicit_type.eq("Type") {
                        macro_is_template = true
                    }
                }
            }
        }
        // Issue #223 step 1: auto-shallow applies to ordinary til
        // func/proc definitions only. ext_func/ext_proc qualifiers map
        // directly to a hand-written C signature (e.g. U64_clone takes a
        // 'const U64 *'), so their shallow-ness must be preserved exactly.
        auto_shallow_ok := fdef.func_type.is(FuncType.Func).or(fdef.func_type.is(FuncType.Proc))
        if fdef.func_type.is(FuncType.Test) {
            // Allowed at root scope, or at the immediate namespace
            // level of a struct/enum (issue #51).  Tests in arbitrary
            // nested function bodies are still rejected.
            if scope.parent.is_null().not().and(ifd_in_ns.not()) {
                expr.type_error("test functions can only be declared at root scope or in a struct/enum namespace", ctx)
            }
            if fdef.return_type.len().gt(0) {
                expr.type_error("test functions cannot have a return type", ctx)
            }
            if fdef.params.len().gt(0) {
                expr.type_error("test functions cannot have parameters", ctx)
            }
        }
        ref cur_mode : Mode = ctx.mode
        if cur_mode.is_pure {
            if fdef.func_type.is(FuncType.Proc) {
                expr.type_error("proc not allowed in pure mode", ctx)
            }
        }
        mut func_scope := TypeScope(parent = scope)
        if fdef.return_type.len().gt(0) {
            return_type_name := fdef.return_type.clone()
            ref resolved_return_type : Str = resolve_type_alias(scope, return_type_name)
            fdef.return_type = resolved_return_type
            check_priv_type_name(expr, resolved_return_type, scope, ctx)
            // Issue #223 step 2: an explicit 'shallow' on a primitive return is
            // redundant (auto-shallow handles it). Reject it. Checked before the
            // step-1 normalization below, which would otherwise erase the
            // distinction between an explicit and an inferred shallow.
            if auto_shallow_ok.and(fdef.return_own_type.is(OwnType.Shallow)) {
                if is_primitive(type_from_name_at(resolved_return_type, scope, expr, ctx)) {
                    expr.type_error("redundant 'shallow' on primitive return type: primitives are returned by value automatically (issue #223); drop it", ctx)
                }
            }
            // Issue #223 step 1/3: a primitive (step 1) or a small value-shaped
            // struct (step 3) is returned by value (shallow) even without the
            // qualifier. Normalize the default (Own) to Shallow for those types
            // so every downstream stage treats them as value types. Explicit
            // 'ref' returns are left alone (a borrowed pointer is intentional).
            if auto_shallow_ok.and(fdef.return_own_type.is(OwnType.Own)) {
                rt := type_from_name_at(resolved_return_type, scope, expr, ctx)
                if is_auto_shallow_type(rt, resolved_return_type, scope) { fdef.return_own_type = OwnType.Shallow }
            }
        }
        for i in 0..fdef.params.len() {
            ref mut param : Declaration = fdef.params[i]
            ptype_name := param.explicit_type.clone()
            ref resolved_ptype : Str = resolve_type_alias(scope, ptype_name)
            param.explicit_type = resolved_ptype
            param.til_type =til_type_from_explicit_type(resolved_ptype)
            ref ptn : Str = param.explicit_type
            pt := type_from_name_at(ptn, scope, expr, ctx)
            // Issue #57: skip the undefined-type diagnostic for template
            // macros -- a param like `T` is a stand-in resolved at
            // expansion time, not a real type.
            if pt.is(Type.Unknown).and(macro_is_template.not()) {
                expr.type_error("undefined type '".concat(ptn).concat("'"), ctx)
            }
            pmut := param.is_mut
            pown := param.own_type.is(OwnType.Own)
            pshallow := param.own_type.is(OwnType.Shallow)
            if pshallow {
                is_scalar := is_primitive(pt)
                if is_scalar.not().and(pt.is(Type.Struct).not()).and(pt.is(Type.Enum).not()) {
                    expr.type_error("shallow parameter '".concat(param.name).concat("' must be a scalar or struct type"), ctx)
                }
                if pown {
                    expr.type_error("parameter cannot be both 'shallow' and 'own'", ctx)
                }
                // Issue #223 step 2: an explicit 'shallow' on a primitive
                // parameter is redundant where auto-shallow applies (ordinary
                // func/proc not returning ref). Reject it.
                if is_scalar.and(auto_shallow_ok).and(fdef.return_own_type.is(OwnType.Ref).not()) {
                    expr.type_error("redundant 'shallow' on primitive parameter '".concat(param.name).concat("': primitives are passed by value automatically (issue #223); drop it"), ctx)
                }
            }
            if i.cast(I32).eq(fdef.variadic_index) {
                // Regular til funcs get a callee-side auto-cleanup
                // (Array.delete at scope exit) so the caller can transfer
                // ownership cleanly. ext_func/ext_proc bodies are
                // user-written C with no auto-cleanup -- transferring
                // ownership leaks the synthesized Array. Keep the parser's
                // Ref setting for ext bindings; force Own elsewhere.
                // (Issue #109: ffi_run was 228B/9 from exactly this.)
                is_ext_va := fdef.func_type.is(FuncType.ExtFunc).or(fdef.func_type.is(FuncType.ExtProc))
                if is_ext_va.not() { param.own_type = OwnType.Own }
                func_scope.set(param.name, Type.Struct("Array"), FuncType.None, false, ctx.path, expr.line, expr.col, true, param.own_type)
            } else if i.cast(I32).eq(fdef.kwargs_index) {
                // Same rationale as variadic above.
                is_ext_kw := fdef.func_type.is(FuncType.ExtFunc).or(fdef.func_type.is(FuncType.ExtProc))
                if is_ext_kw.not() { param.own_type = OwnType.Own }
                func_scope.set(param.name, Type.Struct("DynMap"), FuncType.None, false, ctx.path, expr.line, expr.col, true, param.own_type)
            } else {
                // Issue #223 step 1/3: a primitive (step 1) or small value-shaped
                // struct (step 3) param is passed by value (shallow) even without
                // the qualifier. Normalize the plain borrowed default (Ref,
                // non-mut) to Shallow for those types so every downstream stage
                // treats them as value types. 'mut', 'own', and 'shallow' params
                // are left as the user wrote them. A ref-returning function may
                // hand a param back by reference (e.g. min(a, b) returns ref I64),
                // so its params must stay borrowed pointers -- skip auto-shallow
                // there.
                if auto_shallow_ok.and(fdef.return_own_type.is(OwnType.Ref).not()).and(param.own_type.is(OwnType.Ref)).and(pmut.not()).and(is_auto_shallow_type(pt, ptn, scope)) {
                    param.own_type = OwnType.Shallow
                }
                func_scope.set(param.name, pt, FuncType.None, pmut, ctx.path, expr.line, expr.col, true, param.own_type)
                ref mut pb : TypeBinding = func_scope.get_binding(param.name)
                if pt.is(Type.FuncPtr) {
                    sf_fsb := scope.find(ptn)
                    switch sf_fsb {
                    case ScopeFind.Found(fsb):
                        if fsb.func_def.is_null().not() {
                            if fsb.func_def.children.len().eq(0) {
                                pb.func_def = fsb.func_def
                            }
                        }
                    case:
                    }
                }
            }
        }
        mut in_func_val : I32 = 0
        if is_func { in_func_val = 1 }
        mut returns_ref_val : I32 = 0
        if fdef.return_own_type.is(OwnType.Ref) { returns_ref_val = 1 }
        is_proc := fdef.func_type.is(FuncType.Proc)
        saved_proc_calls := ctx.proc_calls_count
        if is_proc {
            ctx.proc_calls_count = 0
            ctx.proc_def_depth = ctx.proc_def_depth.add(1)
        }
        if fdef.auto_generated {
            ctx.auto_gen_depth = ctx.auto_gen_depth.add(1)
        }
        saved_in_shallow_ret := ctx.typer_in_shallow_return
        ctx.typer_in_shallow_return = fdef.return_own_type.is(OwnType.Shallow)
        saved_in_main_func := ctx.typer_in_main_func
        ctx.typer_in_main_func = ctx.current_top_func_name.eq("main").and(scope.parent.is_null())
        saved_return_type_name := ctx.typer_return_type_name.clone()
        if is_func { ctx.typer_return_type_name = fdef.return_type.clone() } else { ctx.typer_return_type_name = "" }
        // Issue #198: lower throw/catch BEFORE infer_body so the
        // synthesised mut _err_kind / _err_<T> locals + if-guards
        // get type-checked normally and reach all downstream stages
        // (interpreter and builder) as plain til. Then inject the
        // extra err args at every does_throw call site so the
        // typer's arity check passes. UFCS calls keep their
        // FieldAccess(method) callee at this stage; the inject
        // matches by method name so the appended args end up at
        // the end of the eventual rewritten FCall.
        if fdef.auto_generated.not().and(macro_is_template.not()) {
            // Issue #158-aligned: single per-body walk for all
            // throw/catch processing (replaces the previous chain
            // of desugar_bang + validate + lower + inject + fallback
            // return). One walk does the work the five old passes
            // did, integrated per stmt.
            // Seed the receiver-type map so the walk's type-qualified
            // throws lookup can resolve `param.method(...)` receivers.
            ctx.lowering_param_types = Map.new(Str, Str)
            for lpi in 0..fdef.params.len() {
                ref lpp : Declaration = fdef.params[lpi]
                mut lptn := lpp.explicit_type.clone()
                if lpi.cast(I32).eq(fdef.variadic_index) { lptn = "Array" }
                if lpi.cast(I32).eq(fdef.kwargs_index) { lptn = "DynMap" }
                if lptn.len().gt(0) { ctx.lowering_param_types.set(own lpp.name.clone(), own lptn) }
            }
            // Also seed switch-case payload bindings: `case E.V(x):` binds
            // `x` to the variant's payload type. The case-body Decls don't
            // exist yet at this stage (they are emitted inside infer_body
            // by make_switch_case_condition), so the throw/catch walk
            // can't see their explicit_type via the body-Decl scan.
            collect_switch_case_bindings(ctx, expr.child(0))
            process_throw_catch_in_func_body(ctx, expr.child(0), fdef.throw_types, fdef.return_type, fdef.return_own_type)
        }
        if macro_is_template.not() {
            infer_body(func_scope, expr.child(0), in_func_val, 1, 0, returns_ref_val, 0, ctx)
            garbager_destroy_body(ctx, expr.child(0), func_scope)
        }
        ctx.typer_in_shallow_return = saved_in_shallow_ret
        ctx.typer_in_main_func = saved_in_main_func
        ctx.typer_return_type_name = saved_return_type_name
        if fdef.auto_generated {
            ctx.auto_gen_depth = ctx.auto_gen_depth.sub(1)
        }
        if is_proc {
            if ctx.proc_calls_count.eq(0) {
                expr.type_error("proc has no proc/ext_proc calls; should be a func", ctx)
            }
            ctx.proc_calls_count = saved_proc_calls
            ctx.proc_def_depth = ctx.proc_def_depth.sub(1)
        }
        if is_macro.and(fdef.return_type.len().eq(0)) {
            expr.type_error("macro must declare a return type", ctx)
        }
        if macro_is_template.not() {
            check_ref_function_returns(func_scope, expr, ctx)
            check_unused_params(func_scope, expr, ctx)
            check_unused_locals(func_scope, ctx.path, ctx)
        }
        TypeScope.delete(own func_scope)
    case:
        UNREACHABLE(__LOC__)
    }
    ctx.typing_namespace_member = ifd_in_ns
}

check_unused_params := proc(func_scope: TypeScope, expr: Expr, ctx: Context) {
    switch expr.node_type {
    case NodeType.FuncDef(fdef):
        if fdef.func_type.is(FuncType.ExtFunc) { return }
        if fdef.func_type.is(FuncType.ExtProc) { return }
        for param : Declaration in fdef.params {
            if param.name.len().eq(0) { continue }
            if param.name.starts_with("_") { continue }
            ref pb : TypeBinding = func_scope.get_binding(param.name)
            if pb.is_null() { continue }
            if pb.used.not() {
                expr.type_error("unused parameter '".concat(param.name).concat("'"), ctx)
            }
        }
    case:
        UNREACHABLE(__LOC__)
    }
}

check_unused_locals := proc(scope: TypeScope, path: Str, ctx: Context) {
    for bi in 0..scope.bindings.len() {
        ref b : TypeBinding = Map.val_ptr(scope.bindings, bi)
        if b.is_param { continue }
        if b.is_builtin { continue }
        if b.is_type_alias { continue }
        if b.struct_def.is_null().not() { continue }
        if b.func_def.is_null().not() { continue }
        if b.name.len().eq(0) { continue }
        if b.name.starts_with("_") { continue }
        // Hoist temps are compiler-internal and always have their use
        // substituted into the AST after typing, so `b.used` is never
        // flipped by the regular Ident-lookup path. Body DCE catches
        // any of these that go dead after precomp; the typer's job
        // here is just to report user bugs.
        if b.name.starts_with("hoisted__") { continue }
        if ctx.throw_used_local_names.has(b.name) { continue }
        if b.used { continue }
        type_error_at(path, b.line, b.col, "unused variable '".concat(b.name).concat("'"), ctx)
    }
}

// Issue #187 step 1: top-level priv items (funcs, structs, enums,
// globals) are file-local by construction. If nothing in the
// declaring file references one, it is dead code -- no importer can
// possibly reach it. Flag and suggest removing 'priv' to expose it.
// Returns the number of errors emitted so the loader can fold the
// count into its overall type_errors total.
check_unused_priv_top_level := proc(scope: TypeScope, ctx: Context) returns I32 {
    mut found : I32 = 0
    for bi in 0..scope.bindings.len() {
        ref b : TypeBinding = Map.val_ptr(scope.bindings, bi)
        if b.is_priv.not() { continue }
        if b.is_builtin { continue }
        if b.used { continue }
        if b.name.len().eq(0) { continue }
        if b.name.starts_with("_") { continue }
        mut kind := "value"
        if b.func_def.is_null().not() { kind = "func" }
        if b.struct_def.is_null().not() {
            if b.struct_def.node_type.is(NodeType.EnumDef) { kind = "enum" }
            else { kind = "struct" }
        }
        // Two flavors of mangled priv names land here:
        //   * top-level `priv X` rewritten by init_declarations_unit to
        //     `priv__<path>__<orig>` (b.name has the "priv__" prefix).
        //     Report it as a top-level priv with the original identifier.
        //   * Issue #93 nested defs hoisted out of a function body, named
        //     `<parent>_<orig>` (no "priv__" prefix). Report parent +
        //     local in source terms.
        if b.name.starts_with("priv__").and(b.orig_name.len().gt(0)) {
            type_error_at(b.path, b.line, b.col,
                "unused priv ".concat(kind).concat(" '").concat(b.orig_name)
                    .concat("'; remove 'priv' to expose it"), ctx)
            found = found.add(1)
            continue
        }
        if b.orig_name.len().gt(0) {
            mangled_len := b.name.len()
            orig_len := b.orig_name.len()
            parent_len := mangled_len.sub(orig_len).sub(1)
            parent_name := b.name.substr(0, parent_len)
            type_error_at(b.path, b.line, b.col,
                "unused local ".concat(kind).concat(" '").concat(b.orig_name)
                    .concat("' in '").concat(parent_name)
                    .concat("'; remove it or move it to file scope"), ctx)
            found = found.add(1)
            continue
        }
        type_error_at(b.path, b.line, b.col,
            "unused priv ".concat(kind).concat(" '").concat(b.name)
                .concat("'; remove 'priv' to expose it"), ctx)
        found = found.add(1)
    }
    return found
}

// #187 steps 2-3: priv struct fields and namespace methods that no
// code in the struct's own namespace ever reads. The typer marks
// fields/ns_decls used on every successful access (gated on
// auto_gen_depth == 0 so boilerplate clone/delete don't mask
// unused decls). After type_check, walk every struct/enum decl in
// each ImportUnit and flag the leftovers.
check_unused_priv_members_in_program := proc(program: Expr, path: Str, ctx: Context) returns I32 {
    mut found : I32 = 0
    for stmt : Expr in program.children {
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        if stmt.children.len().eq(0) { continue }
        ref tdef : Expr = stmt.child(0)
        if tdef.node_type.is(NodeType.StructDef).not()
            .and(tdef.node_type.is(NodeType.EnumDef).not()) { continue }
        mut owner_name := ""
        switch stmt.node_type {
        case NodeType.Decl(td_decl):
            owner_name = td_decl.name.clone()
        case:
            UNREACHABLE(__LOC__)
        }
        // Field walk (StructDef only). Report at the field's
        // default_value location (every field has one -- the parser
        // requires `name := value` or `name : Type = value`) so the
        // diagnostic points at the dead member, not the enclosing
        // struct. Fall back to tdef location for compiler-generated
        // decls that may carry the NoDefaultArg sentinel.
        switch tdef.node_type {
        case NodeType.StructDef(walk_sdd):
            for fld : Declaration in walk_sdd.fields {
                if fld.is_priv.not() { continue }
                if fld.used { continue }
                if fld.name.len().eq(0) { continue }
                if fld.name.starts_with("_") { continue }
                mut fl_line : U32 = tdef.line
                mut fl_col : U32 = tdef.col
                if fld.default_value.is_null().not()
                    .and(fld.default_value.node_type.is(NodeType.NoDefaultArg).not()) {
                    fl_line = fld.default_value.line
                    fl_col = fld.default_value.col
                }
                type_error_at(path, fl_line, fl_col,
                    "unused priv field '".concat(owner_name).concat(".").concat(fld.name)
                        .concat("'; remove 'priv' to expose it"), ctx)
                found = found.add(1)
            }
        case:
        }
        // Namespace walk (both StructDef and EnumDef). Same
        // default_value-location strategy as fields.
        ref ns : Vec = def_ns_decls(tdef)
        for nsd : Declaration in ns {
            if nsd.is_priv.not() { continue }
            if nsd.used { continue }
            if nsd.name.len().eq(0) { continue }
            if nsd.name.starts_with("_") { continue }
            mut ns_line : U32 = tdef.line
            mut ns_col : U32 = tdef.col
            if nsd.default_value.is_null().not()
                .and(nsd.default_value.node_type.is(NodeType.NoDefaultArg).not()) {
                ns_line = nsd.default_value.line
                ns_col = nsd.default_value.col
            }
            type_error_at(path, ns_line, ns_col,
                "unused priv ns member '".concat(owner_name).concat(".").concat(nsd.name)
                    .concat("'; remove 'priv' to expose it"), ctx)
            found = found.add(1)
        }
    }
    return found
}

// Narrow a bare numeric literal return value to the function's declared
// numeric return type, mirroring validate_fcall_arg for call arguments.
// Fires for a direct Literal.Num return expression (including negative
// literals like -1, which the parser now produces as a single literal);
// any other expression is left as-is.
narrow_return_literal := proc(scope: TypeScope, mut rv: Expr, ctx: Context) {
    if ctx.typer_return_type_name.len().eq(0) { return }
    rt := type_from_name(ctx.typer_return_type_name, scope, ctx)
    if is_numeric_type(rt).not() { return }
    switch rv.node_type {
    case NodeType.Literal(Literal.Num(lit_str)):
        if literal_in_range(lit_str.literal_num_text(), rt).not() {
            rv.type_error("integer literal ".concat(lit_str.literal_num_text()).concat(" out of range for ").concat(type_to_name(rt)), ctx)
        }
        rv.set_expr_til_type(rt)
    case:
        if rv.redundant_literal_conversion(rt) {
            redundant_conversion_error(rv, rt, ctx)
        }
    }
}

infer_return_stmt := proc(scope: TypeScope, mut stmt: Expr, in_func: I32, returns_ref: I32, ctx: Context) {
    if stmt.children.len().gt(0) {
        infer_expr(scope, stmt.child(0), in_func, ctx)
        narrow_return_literal(scope, stmt.child(0), ctx)
        stmt.set_expr_til_type(stmt.child(0).expr_til_type())
        if returns_ref.eq(0) {
            switch stmt.child(0).node_type {
            case NodeType.Ident(rn):
                sf := scope.find(rn.ident_name())
                switch sf {
                case ScopeFind.Found(b):
                    if b.own_type.is(OwnType.Ref).and(b.is_alias.not()).and(b.is_param.not()) {
                        stmt.type_error("cannot return ref variable from non-ref function; use .clone() or 'returns ref'", ctx)
                    }
                        if b.own_type.is(OwnType.Ref).and(b.is_alias).or(b.is_param.and(b.own_type.is(OwnType.Own).not())) {
                            tname := type_to_name(stmt.expr_til_type())
                            if tname.len().gt(0) {
                                mc := make_clone_call(tname, stmt.expr_til_type(), stmt.child(0), stmt)
                                stmt.children.replace(0, own mc)
                            }
                        }
                case:
                }
            case:
            }
        } else {
            // #168 step 5: a ref-typed function cannot return an owned value
            // -- the heap allocation has nowhere to live in the caller.
            ref ret_expr : Expr = stmt.child(0)
            if ret_expr.node_type.is(NodeType.FCall).and(fcall_returns_own(ret_expr, scope)) {
                stmt.type_error("ref-typed function cannot return an owned value (.clone() / constructor / function returning own) -- return a borrow source directly, or change the signature to return owned", ctx)
            }
        }
    } else {
        stmt.set_expr_til_type(Type.None)
    }
}

infer_if_stmt := proc(scope: TypeScope, mut stmt: Expr, in_func: I32, in_loop: I32, returns_ref: I32, ctx: Context) {
    infer_expr(scope, stmt.child(0), in_func, ctx)
    if stmt.child(0).expr_til_type().is(Type.Bool).not().and(stmt.child(0).expr_til_type().is(Type.Unknown).not()) {
        stmt.type_error("if condition must be Bool", ctx)
    }
    then_scope := TypeScope(parent = scope)
    infer_body(then_scope, stmt.child(1), in_func, 1, in_loop, returns_ref, 0, ctx)
    garbager_destroy_body(ctx, stmt.child(1), then_scope)
    check_unused_locals(then_scope, ctx.path, ctx)
    TypeScope.delete(own then_scope)
    if stmt.children.len().gt(2) {
        else_scope := TypeScope(parent = scope)
        infer_body(else_scope, stmt.child(2), in_func, 1, in_loop, returns_ref, 0, ctx)
        garbager_destroy_body(ctx, stmt.child(2), else_scope)
        check_unused_locals(else_scope, ctx.path, ctx)
        TypeScope.delete(own else_scope)
    }
    stmt.set_expr_til_type(Type.None)
}

infer_field_access_expr := proc(scope: TypeScope, mut expr: Expr, in_func: I32, ctx: Context) {
    infer_expr(scope, expr.child(0), in_func, ctx)
    ref obj : Expr = expr.child(0)
    obj_sname := til_type_name(obj.expr_til_type())
    if obj_sname.len().gt(0) {
        ref sdef : Expr = scope.get_struct(obj_sname)
        if sdef.is_null().not() {
            mut fname := ""
            switch expr.node_type {
            case NodeType.FieldAccess(fn):
                fname = fn.field_access_name()
            case:
                UNREACHABLE(__LOC__)
                return
            }
            mut found := false
            // Search struct fields from payload
            switch sdef.node_type {
            case NodeType.StructDef(fa_sdd):
                for fld : Declaration in fa_sdd.fields {
                    if fld.name.eq(fname) {
                        expr.set_expr_til_type(fld.til_type.clone())
                        check_member_priv(expr, obj_sname, fname, fld.is_priv, ctx)
                        if ctx.auto_gen_depth.eq(0) { fld.used = true }
                        found = true
                        break
                    }
                }
            case:
            }
            // Search namespace declarations from payload ns_decls
            if found.not() {
                ref fa_ns : Vec = def_ns_decls(sdef)
                for nsd : Declaration in fa_ns {
                    if nsd.name.eq(fname) {
                        expr.set_expr_til_type(nsd.til_type.clone())
                        if sdef.node_type.is(NodeType.EnumDef).and(nsd.default_value.is_null().not()) {
                            switch nsd.default_value.node_type {
                            case NodeType.FuncDef(fd):
                                if fd.func_type.is(FuncType.ExtFunc).and(fd.return_type.len().gt(0)).and(fd.return_type.eq(obj_sname)) {
                                    expr.set_expr_til_type(Type.Enum(obj_sname.clone()))
                                }
                            case:
                                expr.set_expr_til_type(Type.Enum(obj_sname.clone()))
                            }
                        }
                        check_member_priv(expr, obj_sname, fname, nsd.is_priv, ctx)
                        if ctx.auto_gen_depth.eq(0) { nsd.used = true }
                        found = true
                        break
                    }
                }
            }
            if found.not() {
                mut kind := "struct"
                if sdef.node_type.is(NodeType.EnumDef) { kind = "enum" }
                expr.type_error(kind.concat(" '").concat(obj_sname).concat("' has no field '").concat(fname).concat("'"), ctx)
                expr.set_expr_til_type(Type.Unknown)
            }
        }
    } else {
        expr.type_error("field access on non-struct value", ctx)
        expr.set_expr_til_type(Type.Unknown)
    }
}

infer_field_assign_stmt := proc(scope: TypeScope, mut stmt: Expr, in_func: I32, ctx: Context) {
    infer_expr(scope, stmt.child(0), in_func, ctx)
    infer_expr(scope, stmt.child(1), in_func, ctx)
    ref obj : Expr = stmt.child(0)
    ref mut rhs : Expr = stmt.child(1)
    mut fname := ""
    switch stmt.node_type {
    case NodeType.FieldAssign(fad):
        fn := fad.name
        fname = fn.clone()
    case:
        UNREACHABLE(__LOC__)
        return
    }
    obj_sname := til_type_name(obj.expr_til_type())
    if obj_sname.len().gt(0) {
        ref sdef : Expr = scope.get_struct(obj_sname)
        if sdef.is_null().not() {
            mut found := false
            switch sdef.node_type {
            case NodeType.StructDef(fa_sdd):
                for fld : Declaration in fa_sdd.fields {
                    if fld.name.eq(fname) {
                        found = true
                        check_member_priv(stmt, obj_sname, fname, fld.is_priv, ctx)
                        if ctx.auto_gen_depth.eq(0) { fld.used = true }
                        if fld.is_mut.not() {
                            stmt.type_error("cannot assign to const field '".concat(fname).concat("'; remove the 'const' keyword from its declaration to make it mutable"), ctx)
                        }
                        if fld.own_type.is(OwnType.Ref) {
                            check_ref_assign_owned_rhs(stmt, fname, rhs, scope, ctx)
                        }
                        mut handled_lit := false
                        switch rhs.node_type {
                        case NodeType.Literal(Literal.Num(lit_str)):
                            if is_numeric_type(fld.til_type) {
                                if literal_in_range(lit_str.literal_num_text(), fld.til_type).not() {
                                    rhs.type_error("integer literal out of range for field '".concat(fname).concat("'"), ctx)
                                }
                                rhs.set_expr_til_type(fld.til_type.clone())
                                handled_lit = true
                            }
                        case:
                        }
                        if handled_lit.not() {
                            rhs_type := rhs.expr_til_type()
                            if rhs_type.is(fld.til_type).not() {
                                if rhs_type.is(Type.Unknown).not() {
                                    if rhs_type.is(Type.Dynamic).not() {
                                        stmt.type_error("field '".concat(fname).concat("' type mismatch"), ctx)
                                    }
                                }
                            }
                        }
                        break
                    }
                }
            case:
            }
            // Search namespace declarations from payload ns_decls
            if found.not() {
                ref fa_ns : Vec = def_ns_decls(sdef)
                for nsd : Declaration in fa_ns {
                    if nsd.name.eq(fname) {
                        found = true
                        if nsd.is_mut.not() {
                            stmt.type_error("cannot assign to immutable field '".concat(fname).concat("'"), ctx)
                        }
                        mut handled_lit2 := false
                        switch rhs.node_type {
                        case NodeType.Literal(Literal.Num(lit_str)):
                            if is_numeric_type(nsd.til_type) {
                                if literal_in_range(lit_str.literal_num_text(), nsd.til_type).not() {
                                    rhs.type_error("integer literal out of range for field '".concat(fname).concat("'"), ctx)
                                }
                                rhs.set_expr_til_type(nsd.til_type.clone())
                                handled_lit2 = true
                            }
                        case:
                        }
                        if handled_lit2.not() {
                            rhs_type := rhs.expr_til_type()
                            if rhs_type.is(nsd.til_type).not() {
                                if rhs_type.is(Type.Unknown).not() {
                                    if rhs_type.is(Type.Dynamic).not() {
                                        stmt.type_error("field '".concat(fname).concat("' type mismatch"), ctx)
                                    }
                                }
                            }
                        }
                        break
                    }
                }
            }
            if found.not() {
                stmt.type_error("struct '".concat(obj_sname).concat("' has no field '").concat(fname).concat("'"), ctx)
            }
        }
    } else {
        stmt.type_error("field assignment on non-struct value", ctx)
    }
    stmt.set_expr_til_type(Type.None)
    if stmt.fa_own_type(scope).is(OwnType.Ref).not().and(
        rhs.node_type.is(NodeType.Ident).or(
            rhs.node_type.is(NodeType.FieldAccess).and(is_aggregate(rhs.expr_til_type()))
        )
    ) {
        tname := type_to_name(rhs.expr_til_type())
        if tname.len().gt(0) {
            mc := make_clone_call(tname, rhs.expr_til_type(), rhs, rhs)
            stmt.children.replace(1, own mc)
        }
    }
}

infer_while_stmt := proc(scope: TypeScope, mut stmt: Expr, in_func: I32, returns_ref: I32, ctx: Context) {
    infer_expr(scope, stmt.child(0), in_func, ctx)
    if stmt.child(0).expr_til_type().is(Type.Bool).not().and(stmt.child(0).expr_til_type().is(Type.Unknown).not()) {
        stmt.type_error("while condition must be Bool, got ".concat(type_to_name(stmt.child(0).expr_til_type())), ctx)
    }
    if expr_contains_fcall(stmt.child(0)) {
        ref cond : Expr = stmt.child(0)
        line := cond.line
        col := cond.col
        ref body : Expr = stmt.child(1)
        wname := "_wcond_Bool_".concat(ctx.hoist_counter.to_str())
        ctx.hoist_counter++

        mut decl := Expr.new(NodeType.Decl(Declaration(name = wname.clone())), line, col)
        decl.set_expr_til_type(Type.Bool)
        decl.add_child(own cond.clone())
        ref mut decl_rhs : Expr = decl.child(0)
        decl_rhs.set_expr_til_type(Type.Bool)

        mut ident := Expr.new(ident_node(wname), line, col)
        ident.set_expr_til_type(Type.Bool)

        mut if_node := Expr.new(NodeType.If, line, col)
        if_node.set_expr_til_type(Type.None)
        if_node.add_child(own ident)

        mut then_body := Expr.new(NodeType.Body, line, col)
        then_body.set_expr_til_type(Type.None)
        if_node.add_child(own then_body)

        mut else_body := Expr.new(NodeType.Body, line, col)
        else_body.set_expr_til_type(Type.None)
        mut brk := Expr.new(NodeType.Break, line, col)
        brk.set_expr_til_type(Type.None)
        else_body.add_child(own brk)
        if_node.add_child(own else_body)

        mut true_lit := Expr.new(NodeType.Literal(Literal.Bool(true)), line, col)
        stmt.children.replace(0, own true_lit)

        mut old := Vec.new(Expr)
        old.move_from(body.children)

        mut new_ch := Vec.new(Expr)
        new_ch.push(own decl)
        new_ch.push(own if_node)
        for j in 0..old.len() {
            new_ch.push_take(old, j)
        }
        body.children.move_from(new_ch)
        Vec.delete(own new_ch, true)
        Vec.delete(own old, true)
    }
    while_scope := TypeScope(parent = scope)
    infer_body(while_scope, stmt.child(1), in_func, 1, 1, returns_ref, 0, ctx)
    garbager_destroy_body(ctx, stmt.child(1), while_scope)
    check_unused_locals(while_scope, ctx.path, ctx)
    TypeScope.delete(own while_scope)
    stmt.set_expr_til_type(Type.None)
}

infer_decl_type_def := proc(scope: TypeScope, mut stmt: Expr, ctx: Context) returns Bool {
    if is_struct_or_enum(stmt).not() { return false }
    is_enum := stmt.child(0).node_type.is(NodeType.EnumDef)
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        if sdecl.explicit_type.len().gt(0) {
            declared := type_from_name(sdecl.explicit_type, scope, ctx)
            mut expected := Type.Struct("StructDef")
            if is_enum { expected = Type.Struct("EnumDef") }
            if declared.eq(expected).not() {
                mut value_type := "StructDef"
                if is_enum { value_type = "EnumDef" }
                stmt.type_error("'".concat(sdecl.name).concat("' declared as ").concat(sdecl.explicit_type).concat(" but value is ").concat(value_type), ctx)
            }
        }
        stmt.set_expr_til_type(Type.None)
        ref sname : Str = sdecl.name
        ref existing : TypeBinding = scope.get_binding(sname)
        if existing.is_null().not() {
            if existing.struct_def.is_null().not() {
                if existing.struct_def.line.neq(stmt.child(0).line).or(
                    existing.struct_def.col.neq(stmt.child(0).col).or(
                        existing.path.eq(ctx.path).not()
                    )
                ) {
                    mut kind := "struct"
                    if is_enum { kind = "enum" }
                    stmt.type_error(kind.concat(" '").concat(sname).concat("' already declared at ")
                        .concat(existing.path).concat(":").concat(existing.line.to_str()).concat(":").concat(existing.col.to_str()), ctx)
                    return true
                }
            }
        }
        mut builtin_type := Type.Struct(sname.clone())
        mut is_builtin := false
        if is_enum { builtin_type = Type.Enum(sname.clone()) }
        if sname.eq("I64") { builtin_type = Type.I64; is_builtin = true }
        else if sname.eq("U8") { builtin_type = Type.Struct("U8"); is_builtin = true }
        else if sname.eq("I8") { builtin_type = Type.Struct("I8"); is_builtin = true }
        else if sname.eq("I16") { builtin_type = Type.Primitive(Primitive.I16); is_builtin = true }
        else if sname.eq("U16") { builtin_type = Type.Primitive(Primitive.U16); is_builtin = true }
        else if sname.eq("I32") { builtin_type = Type.Struct("I32"); is_builtin = true }
        else if sname.eq("U32") { builtin_type = Type.U32; is_builtin = true }
        else if sname.eq("U64") { builtin_type = Type.U64; is_builtin = true }
        else if sname.eq("F32") { builtin_type = Type.F32; is_builtin = true }
        else if sname.eq("Str") { is_builtin = false }
        else if sname.eq("Bool") { builtin_type = Type.Bool; is_builtin = true }
        else if sname.eq("StructDef") { is_builtin = false }
        else if sname.eq("FunctionDef") { is_builtin = false }
        else if sname.eq("Dynamic") { builtin_type = Type.Dynamic; is_builtin = true }
        scope.set(sname, builtin_type, FuncType.None, false, ctx.path, stmt.line, stmt.col, false, OwnType.Shallow)
        ref mut b : TypeBinding = scope.get_binding(sname)
        b.struct_def = stmt.child(0)
        b.is_builtin = is_builtin
        b.is_priv = sdecl.is_priv
        b.orig_name = sdecl.orig_name.clone()
        return true
    case:
        UNREACHABLE(__LOC__)
        return false
    }
}

infer_decl_func_def := proc(scope: TypeScope, mut stmt: Expr, ctx: Context) returns Bool {
    if is_func_decl(stmt).not() { return false }
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        // Issue #58: the metatype name from rstil's first_class.org is
        // ~FuncDef~; til's internal name is ~FunctionDef~ (the data
        // struct in src/core/ast.til). Accept both as the annotation
        // for a FuncDef value.
        annot_is_funcdef := sdecl.explicit_type.eq("FunctionDef").or(sdecl.explicit_type.eq("FuncDef"))
        if sdecl.explicit_type.len().gt(0).and(annot_is_funcdef.not()) {
            stmt.type_error("'".concat(sdecl.name).concat("' declared as ").concat(sdecl.explicit_type).concat(" but value is FunctionDef"), ctx)
        }
        switch stmt.child(0).node_type {
        case NodeType.FuncDef(fdef):
            mut rt := Type.None
            if fdef.return_type.len().gt(0) {
                ref resolved_return_type : Str = resolve_type_alias(scope, fdef.return_type)
                rt = type_from_name(resolved_return_type, scope, ctx)
            }
            stmt.set_expr_til_type(rt)
            // Bodyless FuncDef is a FuncSig type-alias declaration:
            // bind the name to Type.FuncPtr so dyn_type_to_str and Vec.new
            // round-trip the name through Type.FuncPtr ("Fn") instead of
            // the function's return type. Issue #58.
            is_bodyless := stmt.child(0).children.len().eq(0)
            mut binding_type := rt
            if is_bodyless { binding_type = Type.FuncPtr }
            scope.set(sdecl.name, binding_type, fdef.func_type, false, ctx.path, stmt.line, stmt.col, false, OwnType.Shallow)
            ref mut fb : TypeBinding = scope.get_binding(sdecl.name)
            fb.func_def = stmt.child(0)
            fb.is_priv = sdecl.is_priv
            fb.orig_name = sdecl.orig_name.clone()
            if fdef.func_type.is(FuncType.ExtFunc).or(fdef.func_type.is(FuncType.ExtProc)) {
                fb.is_builtin = true
            }
            return true
        case:
            UNREACHABLE(__LOC__)
            return false
        }
    case:
        UNREACHABLE(__LOC__)
        return false
    }
}

infer_decl_type_alias_passthrough := func(scope: TypeScope, mut stmt: Expr) returns Bool {
    if stmt.child(0).node_type.is(NodeType.Ident).not() { return false }
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        ref alias_b : TypeBinding = scope.get_binding(sdecl.name)
        if alias_b.is_null().not() {
            if alias_b.is_type_alias {
                stmt.set_expr_til_type(Type.None)
                return true
            }
        }
        return false
    case:
        UNREACHABLE(__LOC__)
        return false
    }
}

declared_type_for_decl := func(scope: TypeScope, stmt: Expr, ctx: Context) returns Type {
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        mut declared := stmt.expr_til_type()
        switch declared {
        case Type.Unknown:
            declared = type_from_name(sdecl.explicit_type, scope, ctx)
        case Type.Custom(cname):
            declared = type_from_name(cname, scope, ctx)
        case:
        }
        return declared
    case:
        UNREACHABLE(__LOC__)
        return Type.Unknown
    }
}

// Typed declarations can steer numeric method resolution (for example,
// `x : F32 = 1 / 2` -> `F32.div`), but explicit `to_*` conversions still need
// their literal receiver to keep the default numeric type so lookup lands on
// the source type's namespace.
pre_coerce_decl_numeric_literals := proc(mut expr: Expr, target: Type) {
    switch expr.node_type {
    case NodeType.Literal(Literal.Num):
        expr.set_expr_til_type(target)
    case NodeType.FieldAccess(fname):
        for i in 0..expr.children.len() {
            if i.eq(0).and(fname.starts_with("to_")) { continue }
            pre_coerce_decl_numeric_literals(expr.child(i), target)
        }
    case:
        for i in 0..expr.children.len() {
            pre_coerce_decl_numeric_literals(expr.child(i), target)
        }
    }
}

infer_decl_typed_value := proc(scope: TypeScope, mut stmt: Expr, ctx: Context) {
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        mut declared := declared_type_for_decl(scope, stmt, ctx)
        // #179 follow-up: explicit type annotation on a Decl
        // (e.g. ~ref x : Foo = ...~) is a use of Foo's name from
        // declaration position. Check priv across files.
        check_priv_type_name(stmt, sdecl.explicit_type, scope, ctx)
        ref mut val : Expr = stmt.child(0)
        switch val.expr_til_type() {
        case Type.Custom(alias_name):
            ref resolved_alias_name : Str = resolve_type_alias(scope, alias_name)
            resolved_alias_type := type_from_name(resolved_alias_name, scope, ctx)
            if resolved_alias_type.is(Type.Unknown).not() {
                val.set_expr_til_type(resolved_alias_type)
            }
        case:
        }
        if declared.is(Type.Unknown) {
            stmt.type_error("undefined type '".concat(sdecl.explicit_type).concat("'"), ctx)
        } else if val.redundant_literal_conversion(declared) {
            redundant_conversion_error(val, declared, ctx)
        } else if val.node_type.is_literal_num().and(is_numeric_type(declared).or(declared.is(Type.Dynamic))) {
            switch val.node_type {
            case NodeType.Literal(Literal.Num(lit_str)):
                if is_numeric_type(declared).and(literal_in_range(lit_str.literal_num_text(), declared).not()) {
                    val.type_error("integer literal ".concat(lit_str.literal_num_text()).concat(" out of range for ").concat(type_to_name(declared)), ctx)
                }
            case:
            }
            val.set_expr_til_type(declared)
        } else if val.node_type.is_literal_null().and(sdecl.own_type.is(OwnType.Ref).not()) {
            stmt.type_error("null can only be assigned to 'ref' declarations", ctx)
        } else if can_implicit_usize_coerce(val.expr_til_type(), declared, sdecl.explicit_type).not()
        .and(val.expr_til_type().is(declared).not())
        .and(val.expr_til_type().is(Type.Dynamic).not())
    .and(declared.is(Type.Dynamic).not()) {
        stmt.type_error("'".concat(sdecl.name).concat("' declared as ").concat(type_to_name(declared))
            .concat(" but value is ").concat(type_to_name(val.expr_til_type())), ctx)
    } else if is_aggregate(declared) {
        val_sname := til_type_name(val.expr_til_type())
        if val_sname.len().gt(0).and(resolve_type_alias(scope, sdecl.explicit_type).eq(val_sname).not()) {
            stmt.type_error("'".concat(sdecl.name).concat("' declared as ").concat(sdecl.explicit_type)
                .concat(" but value is ").concat(val_sname), ctx)
        }
    }
    // Resolve type alias in declared til_type so that struct/enum names match
    // the canonical target (e.g. Point2 -> Point).
    if is_aggregate(declared) {
        ref _resolved : Str = resolve_type_alias(scope, sdecl.explicit_type)
        if declared.is(Type.Struct) {
            declared = Type.Struct(_resolved.clone())
        } else {
            declared = Type.Enum(_resolved.clone())
        }
    }
    stmt.set_expr_til_type(declared)
    if can_implicit_usize_coerce(val.expr_til_type(), declared, sdecl.explicit_type) {
        val.set_expr_til_type(declared)
    }
    narrow_dynamic(val, declared)
        if is_aggregate(declared) {
            if til_type_name(val.expr_til_type()).len().gt(0) {
                ref resolved : Str = resolve_type_alias(scope, sdecl.explicit_type)
                if declared.is(Type.Struct) {
                    val.set_expr_til_type(Type.Struct(resolved.clone()))
                } else {
                    val.set_expr_til_type(Type.Enum(resolved.clone()))
                }
            }
        }
    case:
        UNREACHABLE(__LOC__)
    }
}

infer_decl_untyped_value := proc(mut stmt: Expr, ctx: Context) {
    stmt.set_expr_til_type(stmt.child(0).expr_til_type())
    if stmt.expr_til_type().is(Type.Dynamic) {
        switch stmt.node_type {
        case NodeType.Decl(sdecl):
            stmt.type_error("cannot store Dynamic in '".concat(sdecl.name)
                .concat("'; add a type annotation like '").concat(sdecl.name).concat(" : Type = ...' to specify the concrete type"), ctx)
        case:
            UNREACHABLE(__LOC__)
        }
    }
}

finalize_decl_binding := proc(scope: TypeScope, mut stmt: Expr, in_type_body: I32, ctx: Context) {
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        ref mut rhs : Expr = stmt.child(0)
        if in_type_body.eq(0).and(sdecl.own_type.is(OwnType.Own)) {
            if sdecl.is_mut {
                stmt.type_error("no need for 'own' on mutable local '".concat(sdecl.name).concat("'; write 'mut ").concat(sdecl.name).concat(" := ...'"), ctx)
            } else {
                stmt.type_error("no need for 'own' on local '".concat(sdecl.name).concat("'; locals are owned by default"), ctx)
            }
        }
        scope.set(sdecl.name, stmt.expr_til_type(), FuncType.None, sdecl.is_mut, ctx.path, stmt.line, stmt.col, false, OwnType.Shallow)
        ref mut decl_b : TypeBinding = scope.get_binding(sdecl.name)
        decl_b.used = sdecl.used
        if ctx.throw_used_local_names.has(sdecl.name) { decl_b.used = true }
        decl_b.is_priv = sdecl.is_priv
        decl_b.orig_name = sdecl.orig_name.clone()
        if stmt.expr_til_type().is(Type.FuncPtr) {
            switch rhs.node_type {
            case NodeType.Ident(rhs_id):
                ref src : TypeBinding = scope.get_binding(rhs_id.ident_name())
                if src.is_null().not() {
                    if src.func_def.is_null().not() { decl_b.func_def = src.func_def }
                }
            case NodeType.FCall:
                ref rfc_sig : Expr = resolve_fn_sig(rhs, scope)
                if rfc_sig.is_null().not() {
                    decl_b.func_def = rfc_sig
                }
            case:
            }
            if decl_b.func_def.is_null() {
                if sdecl.explicit_type.len().gt(0) {
                    ref fsb : TypeBinding = scope.get_binding(sdecl.explicit_type)
                    if fsb.is_null().not() {
                        if fsb.func_def.is_null().not() {
                            if fsb.func_def.children.len().eq(0) {
                                decl_b.func_def = fsb.func_def
                            }
                        }
                    }
                }
            }
        }
        if sdecl.own_type.is(OwnType.Ref) {
            decl_b.own_type = OwnType.Ref
            // #211: payload binding `ref T = get_payload(<ident>)` is the
            // typer-emitted shape produced by make_switch_case_condition.
            // Mark its TypeBinding as an alias so the subsequent Assign
            // check at line 6935 recognises writes to it as
            // write-through-the-payload and accepts a constructor /
            // literal RHS (the builder lowers it to `*p = *new` for
            // structs and `*p = (Str){...}` for Str literals).
            if rhs.node_type.is(NodeType.FCall).and(rhs.children.len().eq(2)) {
                ref head : Expr = rhs.child(0)
                switch head.node_type {
                case NodeType.Ident(head_id):
                    if head_id.ident_name().eq("get_payload") {
                        decl_b.is_alias = true
                    }
                case:
                }
            }
            if expr_is_ref_decl_source(rhs, scope).not() {
                stmt.type_error("'ref' declaration requires null, a ref-returning function, or ref/param variable", ctx)
            }
            if sdecl.is_mut {
                switch rhs.node_type {
                case NodeType.Ident(_rid):
                    ref _rb : TypeBinding = scope.get_binding(_rid.ident_name())
                    if _rb.is_null().not().and(_rb.is_mut.not()) {
                        stmt.type_error("'ref mut' cannot bind to an immutable source; declare the source as 'mut' or 'ref mut'", ctx)
                    }
                case:
                }
            }
        }
        if sdecl.own_type.is(OwnType.Ref).not().and(rhs.node_type.is(NodeType.FCall)).and(fcall_returns_ref(rhs, scope).neq(0)) {
            stmt.type_error("cannot own result of ref-returning function; use 'ref' or Type.clone()", ctx)
        }
        if sdecl.own_type.is(OwnType.Ref).not().and(sdecl.is_mut.not()).and(stmt.expr_til_type().is(Type.FuncPtr).not()) {
            switch rhs.node_type {
            case NodeType.Ident(rhs_id2):
                ref rb : TypeBinding = scope.get_binding(rhs_id2.ident_name())
                if rb.is_null().not() {
                    if rb.is_mut.not().and(rb.own_type.is(OwnType.Own).not()).and(rb.own_type.is(OwnType.Ref).not().or(rb.is_alias)).and(rb.is_param.not()) {
                        sdecl.own_type = OwnType.Ref
                        decl_b.own_type = OwnType.Ref
                        decl_b.is_alias = true
                    }
                }
            case:
            }
        }
        if rhs.node_type.is(NodeType.Ident).or(
            rhs.node_type.is(NodeType.FieldAccess).and(
                is_aggregate(rhs.expr_til_type())
            )
        ) {
            if sdecl.own_type.is(OwnType.Ref).not() {
                tname := type_to_name(stmt.expr_til_type())
                if tname.len().gt(0) {
                    mc := make_clone_call(tname, stmt.expr_til_type(), rhs, stmt)
                    stmt.children.replace(0, own mc)
                }
            }
        }
    case:
        UNREACHABLE(__LOC__)
    }
}

infer_decl_stmt := proc(scope: TypeScope, mut stmt: Expr, in_func: I32, in_type_body: I32, ctx: Context) {
    if stmt.children.len().eq(0) { return }
    if stmt.child(0).node_type.is(NodeType.StructDef).or(stmt.child(0).node_type.is(NodeType.EnumDef)) {
        switch stmt.node_type {
        case NodeType.Decl(td_decl):
            saved_type_name := ctx.current_type_name.clone()
            ctx.current_type_name = td_decl.name.clone()
            infer_expr(scope, stmt.child(0), in_func, ctx)
            ctx.current_type_name = saved_type_name
        case:
            UNREACHABLE(__LOC__)
        }
    } else {
        // Issue #93 follow-up: when the decl's rhs is a FuncDef body
        // (top-level after init_declarations_unit's nested-def lift),
        // set current_top_func_name so the function-scope priv check in
        // check_priv_access knows which parent we're inside while typing
        // the body.
        mut tracked_func := false
        saved_top_func := ctx.current_top_func_name.clone()
        switch stmt.node_type {
        case NodeType.Decl(sdecl):
            if sdecl.explicit_type.len().gt(0) {
                declared := declared_type_for_decl(scope, stmt, ctx)
                if is_numeric_type(declared) {
                    pre_coerce_decl_numeric_literals(stmt.child(0), declared)
                }
            }
            if stmt.child(0).node_type.is(NodeType.FuncDef) {
                if stmt.child(0).children.len().gt(0) {
                    ctx.current_top_func_name = sdecl.name.clone()
                    tracked_func = true
                }
            }
        case:
        }
        infer_expr(scope, stmt.child(0), in_func, ctx)
        if tracked_func {
            ctx.current_top_func_name = saved_top_func
        }
    }
    if infer_decl_type_def(scope, stmt, ctx) { return }
    if infer_decl_func_def(scope, stmt, ctx) { return }
    if infer_decl_type_alias_passthrough(scope, stmt) { return }
    switch stmt.node_type {
    case NodeType.Decl(sdecl):
        if sdecl.explicit_type.len().gt(0) {
            infer_decl_typed_value(scope, stmt, ctx)
        } else {
            infer_decl_untyped_value(stmt, ctx)
        }
    case:
        UNREACHABLE(__LOC__)
    }
    check_ref_decl_owned_init(stmt, scope, ctx)
    check_ref_local_null_init(stmt, ctx)
    finalize_decl_binding(scope, stmt, in_type_body, ctx)
}

is_simple_lvalue_expr := func(e: Expr) returns Bool {
    if e.node_type.is(NodeType.Ident) { return true }
    if e.node_type.is(NodeType.FieldAccess) {
        if e.children.len().eq(1) {
            return is_simple_lvalue_expr(e.child(0))
        }
    }
    return false
}

// Fold a Vec of conditions into a left-associative `.and()` chain.
// Empty -> LiteralBool(true). Otherwise read by clone (the Vec is left
// untouched for the caller to drop normally).
priv fold_and_chain := func(conds: Vec, line: U32, col: U32) returns Expr {
    if conds.len().eq(0) {
        return Expr.new(NodeType.Literal(Literal.Bool(true)), line, col)
    }
    ref first_c : Expr = conds[0]
    if conds.len().eq(1) {
        return first_c.clone()
    }
    mut acc := first_c.clone()
    for fi in 1..conds.len() {
        mut next_chain := make_method_call_fcall(own acc.clone(), "and", line, col)
        ref next_c : Expr = conds[fi]
        next_chain.add_child(own next_c.clone())
        acc = next_chain.clone()
    }
    return acc.clone()
}

make_switch_case_condition := func(scope: TypeScope, mut case_body: Expr, match_expr: Expr, sw_ref: Expr, sw_line: U32, sw_col: U32) returns Expr {
    mut condition := Expr.new(NodeType.Body, sw_line, sw_col)
    mut has_condition := false
    if match_expr.node_type.is(NodeType.FCall) {
        if match_expr.children.len().eq(3) {
            switch match_expr.child(0).node_type {
            case NodeType.FieldAccess(method_name):
                if method_name.field_access_name().eq("new") {
                    if match_expr.child(0).children.len().gt(0) {
                        switch match_expr.child(0).child(0).node_type {
                        case NodeType.Ident(range_name):
                            if range_name.ident_name().eq("Range") {
                                ref start_expr : Expr = match_expr.child(1)
                                ref end_expr : Expr = match_expr.child(2)

                                mut sw1 := sw_ref.clone()
                                mut gte_call := make_method_call_fcall(own sw1, "gte", sw_line, sw_col)
                                gte_call.add_child(own start_expr.clone())

                                mut sw2 := sw_ref.clone()
                                mut lte_call := make_method_call_fcall(own sw2, "lte", sw_line, sw_col)
                                lte_call.add_child(own end_expr.clone())

                                condition = make_method_call_fcall(own gte_call, "and", sw_line, sw_col)
                                condition.add_child(own lte_call)
                                has_condition = true
                            }
                        case:
                        }
                    }
                }
            case:
            }
        }
    }

    if has_condition.not() {
        if match_expr.node_type.is(NodeType.FCall) {
            if match_expr.children.len().eq(2) {
                if match_expr.child(0).node_type.is(NodeType.FieldAccess) {
                    if match_expr.child(0).children.len().gt(0) {
                        if match_expr.child(0).child(0).node_type.is(NodeType.Ident) {
                            if match_expr.child(1).node_type.is(NodeType.Ident) {
                                ref callee : Expr = match_expr.child(0)
                                mut type_name := ""
                                mut variant_name := ""
                                mut binding_name := ""
                                switch callee.child(0).node_type {
                                case NodeType.Ident(tn):
                                    type_name = tn.ident_name()
                                case:
                                }
                                switch callee.node_type {
                                case NodeType.FieldAccess(vn):
                                    variant_name = vn.field_access_name()
                                case:
                                }
                                switch match_expr.child(1).node_type {
                                case NodeType.Ident(bn):
                                    binding_name = bn.ident_name()
                                case:
                                }
                                ref enum_def : Expr = scope.get_struct(type_name)
                                // Nested if rather than `.and(...)`: til's
                                // `.and` is strict, so a single combined check
                                // would still deref `enum_def.node_type` when
                                // `enum_def` is NULL (e.g. cross-file priv).
                                if enum_def.is_null().not() {
                                if enum_def.node_type.is(NodeType.EnumDef) {
                                    vt_tag := enum_variant_tag(enum_def, variant_name)
                                    mut payload_type := ""
                                    if vt_tag.gte(0) {
                                        payload_type = enum_variant_type(enum_def, vt_tag)
                                    }
                                    if payload_type.len().gt(0) {
                                        mut iv_id := Expr.new(ident_node("is"), sw_line, sw_col)
                                        mut sw_id := sw_ref.clone()
                                        mut vtype_id := Expr.new(ident_node(type_name), sw_line, sw_col)
                                        mut vref := Expr.new(field_access_node(variant_name), sw_line, sw_col)
                                        vref.add_child(own vtype_id)
                                        condition = Expr.new(NodeType.FCall(FCallData()), sw_line, sw_col)
                                        condition.add_child(own iv_id)
                                        condition.add_child(own sw_id)
                                        condition.add_child(own vref)

                                        mut sw_id2 := sw_ref.clone()
                                        // #211: payload binding inherits the matched value's
                                        // mutability AND the variant's payload const-ness.
                                        // `mut e; case V(p): p = ...` works iff e is mut and the
                                        // variant payload was NOT declared `const`.
                                        mut source_mut := false
                                        switch sw_ref.node_type {
                                        case NodeType.Ident(sw_idn):
                                            ref sw_b : TypeBinding = scope.get_binding(sw_idn.ident_name())
                                            if sw_b.is_null().not() { source_mut = sw_b.is_mut }
                                        case:
                                        }
                                        payload_const := enum_variant_payload_const(enum_def, vt_tag)
                                        bind_is_mut := source_mut.and(payload_const.not())
                                        mut bind_decl := make_payload_ref_decl(own sw_id2, binding_name, payload_type, sw_line, sw_col, bind_is_mut)

                                        mut old := Vec.new(Expr)
                                        old.move_from(case_body.children)

                                        mut new_ch := Vec.new(Expr)
                                        new_ch.push(own bind_decl)
                                        for bi in 0..old.len() {
                                            new_ch.push_take(old, bi)
                                        }
                                    case_body.children.move_from(new_ch)
                                        Vec.delete(own new_ch, true)
                                        Vec.delete(own old, true)
                                        has_condition = true
                                    }
                                }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // Issue #36: nested pattern matching. `case Outer.A(Inner.B(val))` and
    // `case Outer.A(Inner.B)` desugar to a conjunction:
    //   sw.is(Outer.A).and(get_payload(sw, Inner).is(Inner.B))
    // Any deeper binding inside `inner` desugars recursively against
    // ~get_payload(sw, Inner)~ as the new sw_ref; ~.and~ is eager but
    // ~get_payload~ is pure pointer arithmetic on the enum's union storage,
    // so reading the second operand when the outer tag is wrong is harmless
    // (just garbage bytes) and the outer false short-circuits the body.
    if has_condition.not() {
        if match_expr.node_type.is(NodeType.FCall) {
            if match_expr.children.len().eq(2) {
                if match_expr.child(0).node_type.is(NodeType.FieldAccess) {
                    if match_expr.child(0).children.len().gt(0) {
                        if match_expr.child(0).child(0).node_type.is(NodeType.Ident) {
                            ref inner_pat : Expr = match_expr.child(1)
                            if inner_pat.node_type.is(NodeType.Ident).not() {
                                ref callee3 : Expr = match_expr.child(0)
                                mut type_name3 := ""
                                mut variant_name3 := ""
                                switch callee3.child(0).node_type {
                                case NodeType.Ident(tn3): type_name3 = tn3.ident_name()
                                case:
                                }
                                switch callee3.node_type {
                                case NodeType.FieldAccess(vn3): variant_name3 = vn3.field_access_name()
                                case:
                                }
                                ref enum_def3 : Expr = scope.get_struct(type_name3)
                                // Nested if rather than `.and(...)`: see the
                                // matching note in the eager-pattern branch
                                // above. til's `.and` is strict.
                                if enum_def3.is_null().not() {
                                if enum_def3.node_type.is(NodeType.EnumDef) {
                                    vt_tag3 := enum_variant_tag(enum_def3, variant_name3)
                                    mut payload_type3 := ""
                                    if vt_tag3.gte(0) {
                                        payload_type3 = enum_variant_type(enum_def3, vt_tag3)
                                    }
                                    if payload_type3.len().gt(0) {
                                        // outer condition: sw_ref.is(Type.Variant)
                                        mut iv_id3 := Expr.new(ident_node("is"), sw_line, sw_col)
                                        mut sw_id3 := sw_ref.clone()
                                        mut vtype_id3 := Expr.new(ident_node(type_name3), sw_line, sw_col)
                                        mut vref3 := Expr.new(field_access_node(variant_name3), sw_line, sw_col)
                                        vref3.add_child(own vtype_id3)
                                        mut outer_cond3 := Expr.new(NodeType.FCall(FCallData()), sw_line, sw_col)
                                        outer_cond3.add_child(own iv_id3)
                                        outer_cond3.add_child(own sw_id3)
                                        outer_cond3.add_child(own vref3)

                                        // inner sw_ref: get_payload(sw_ref, payload_type)
                                        mut sw_for_gp := sw_ref.clone()
                                        mut inner_sw_ref := make_get_payload_fcall(own sw_for_gp, til_type_from_explicit_type(payload_type3), sw_line, sw_col)

                                        // Recurse on the nested pattern; bindings prepend to case_body
                                        // and use ~get_payload(sw_ref, payload_type)~ as their root.
                                        inner_cond3 := make_switch_case_condition(scope, case_body, inner_pat, inner_sw_ref, sw_line, sw_col)

                                        // Combined: outer_cond.and(inner_cond)
                                        condition = make_method_call_fcall(own outer_cond3, "and", sw_line, sw_col)
                                        condition.add_child(own inner_cond3)
                                        has_condition = true
                                    }
                                }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    if has_condition.not() {
        if match_expr.node_type.is(NodeType.FieldAccess) {
            if match_expr.children.len().gt(0) {
                if match_expr.child(0).node_type.is(NodeType.Ident) {
                    mut type_name := ""
                    mut variant_name := ""
                    switch match_expr.child(0).node_type {
                    case NodeType.Ident(tn):
                        type_name = tn.ident_name()
                    case:
                    }
                    switch match_expr.node_type {
                    case NodeType.FieldAccess(vn):
                        variant_name = vn.field_access_name()
                    case:
                    }
                    ref enum_def : Expr = scope.get_struct(type_name)
                    // Nested if rather than `.and(...)`: see matching notes
                    // above. til's `.and` is strict.
                    if enum_def.is_null().not() {
                    if enum_def.node_type.is(NodeType.EnumDef) {
                        vt_tag2 := enum_variant_tag(enum_def, variant_name)
                        if vt_tag2.gte(0) {
                            // `case Variant` (no payload binding) -> sw.is(Type.Variant).
                            // Use .is rather than .eq so the desugared check is a
                            // tag-only comparison and never recurses through a
                            // user-defined eq (which is itself often defined as a
                            // switch -- e.g. Value.eq).
                            mut iv_id := Expr.new(ident_node("is"), sw_line, sw_col)
                            mut sw_id := sw_ref.clone()
                            mut vtype_id := Expr.new(ident_node(type_name), sw_line, sw_col)
                            mut vref := Expr.new(field_access_node(variant_name), sw_line, sw_col)
                            vref.add_child(own vtype_id)
                            condition = Expr.new(NodeType.FCall(FCallData()), sw_line, sw_col)
                            condition.add_child(own iv_id)
                            condition.add_child(own sw_id)
                            condition.add_child(own vref)
                            has_condition = true
                        }
                    }
                    }
                }
            }
        }
    }

    // Issue #36: struct field matching. `case Point(x = 0, y = ny):` desugars
    // each `field = literal` to ~sw.field.eq(literal)~ ANDed into the case
    // condition, and each `field = ident` to ~ref ident := sw.field~ prepended
    // to the body. Nested struct/enum patterns inside a field value recurse.
    // Detected by FCall with an Ident callee (a struct/type name) where every
    // non-callee child is a NamedArg or a RestPattern. `..` is required if
    // any field is omitted; without it the typer errors so callers can't
    // silently leave a field unconstrained.
    if has_condition.not() {
        if match_expr.node_type.is(NodeType.FCall) {
            if match_expr.children.len().gt(0) {
                if match_expr.child(0).node_type.is(NodeType.Ident) {
                    mut sp_type_name := ""
                    switch match_expr.child(0).node_type {
                    case NodeType.Ident(spn): sp_type_name = spn.ident_name()
                    case:
                    }
                    mut all_named := true
                    for sp_ci in 1..match_expr.children.len() {
                        ref sp_child : Expr = match_expr.child(sp_ci)
                        if sp_child.node_type.is(NodeType.RestPattern).not()
                            .and(sp_child.node_type.is(NodeType.NamedArg).not()) {
                            all_named = false
                        }
                    }
                    mut is_struct := false
                    if all_named {
                        ref sp_def : Expr = scope.get_struct(sp_type_name)
                        if sp_def.is_null().not() {
                            if sp_def.node_type.is(NodeType.StructDef) {
                                is_struct = true
                            }
                        }
                    }
                    if is_struct {
                        mut sp_conds := Vec.new(Expr)
                        mut sp_bindings := Vec.new(Expr)
                        for sp_ci2 in 1..match_expr.children.len() {
                            ref na : Expr = match_expr.child(sp_ci2)
                            if na.node_type.is(NodeType.RestPattern) { continue }
                            mut field_name := ""
                            switch na.node_type {
                            case NodeType.NamedArg(fn): field_name = fn.clone()
                            case:
                            }
                            if na.children.len().eq(0) { continue }
                            ref field_pat : Expr = na.child(0)
                            if field_pat.node_type.is(NodeType.Ident) {
                                // `field = ident` is a binding -> ref bind_name := sw.field_name
                                mut bind_name := ""
                                switch field_pat.node_type {
                                case NodeType.Ident(bn): bind_name = bn.ident_name()
                                case:
                                }
                                mut field_acc_bind := Expr.new(field_access_node(field_name), sw_line, sw_col)
                                field_acc_bind.add_child(own sw_ref.clone())
                                mut bind_decl := Expr.new(NodeType.Decl(Declaration(name = bind_name.clone(), own_type = OwnType.Ref)), sw_line, sw_col)
                                bind_decl.add_child(own field_acc_bind)
                                sp_bindings.push(own bind_decl)
                            } else {
                                // Value match (literal/expr) or nested pattern.
                                // Recurse with sw_ref = sw.field_name; the recursive
                                // call may itself prepend bindings to case_body.
                                mut field_acc_match := Expr.new(field_access_node(field_name), sw_line, sw_col)
                                field_acc_match.add_child(own sw_ref.clone())
                                sub_cond := make_switch_case_condition(scope, case_body, field_pat, field_acc_match, sw_line, sw_col)
                                sp_conds.push(own sub_cond)
                            }
                        }
                        // Prepend bindings (in source order) before any existing
                        // case_body statements -- including bindings that
                        // recursive value-match calls may have prepended for
                        // their own nested patterns.
                        if sp_bindings.len().gt(0) {
                            mut old_body := Vec.new(Expr)
                            old_body.move_from(case_body.children)
                            mut new_body := Vec.new(Expr)
                            for spi in 0..sp_bindings.len() {
                                new_body.push_take(sp_bindings, spi)
                            }
                            for obi in 0..old_body.len() {
                                new_body.push_take(old_body, obi)
                            }
                            case_body.children.move_from(new_body)
                        }
                        // Fold conds into a left-associative AND chain.
                        condition = fold_and_chain(sp_conds, sw_line, sw_col)
                        has_condition = true
                    }
                }
            }
        }
    }

    if has_condition.not() {
        mut sw_ident := sw_ref.clone()
        condition = make_method_call_fcall(own sw_ident, "eq", sw_line, sw_col)
        condition.add_child(own match_expr.clone())
    }
    return condition
}

replace_switch_stmt_with_block := func(mut body: Expr, stmt_idx: U32, mut block: Expr) {
    ref slot_sw : Expr = body.children[stmt_idx]
    slot_sw.free_expr_slot_in_place()
    move(slot_sw, block, Expr.size())
}

append_switch_else_if := proc(mut root_if: Expr, if_node: Expr) {
    if root_if.children.len().gt(2) {
        ref mut else_body : Expr = root_if.child(2)
        if else_body.children.len().gt(0) {
            if else_body.child(0).node_type.is(NodeType.If) {
                append_switch_else_if(else_body.child(0), if_node)
                return
            }
        }
    }
    mut else_body := Expr.new(NodeType.Body, if_node.line, if_node.col)
    else_body.add_child(own if_node.clone())
    root_if.add_child(own else_body)
}

attach_switch_default_body := proc(mut root_if: Expr, default_body: Expr) {
    if root_if.children.len().gt(2) {
        ref mut else_body : Expr = root_if.child(2)
        if else_body.children.len().gt(0) {
            if else_body.child(0).node_type.is(NodeType.If) {
                attach_switch_default_body(else_body.child(0), default_body)
                return
            }
        }
    }
    root_if.add_child(own default_body.clone())
}

// Issue #36: a struct pattern that omits fields needs an explicit `..`
// marker. Run on each non-default case BEFORE make_switch_case_condition
// (which is a func and can't call the proc-typed type_error). Skips
// silently for patterns that aren't struct-shaped.
priv validate_struct_pattern_rest := proc(scope: TypeScope, pattern: Expr, ctx: Context) {
    if pattern.node_type.is(NodeType.FCall).not() { return }
    if pattern.children.len().eq(0) { return }
    if pattern.child(0).node_type.is(NodeType.Ident).not() { return }
    mut vsp_type_name := ""
    switch pattern.child(0).node_type {
    case NodeType.Ident(vspn): vsp_type_name = vspn.ident_name()
    case:
    }
    mut vsp_all_named := true
    mut vsp_has_rest := false
    for vci in 1..pattern.children.len() {
        ref vsc : Expr = pattern.child(vci)
        if vsc.node_type.is(NodeType.RestPattern) {
            vsp_has_rest = true
        } else if vsc.node_type.is(NodeType.NamedArg).not() {
            vsp_all_named = false
        }
    }
    if vsp_all_named.not() { return }
    ref vsp_def : Expr = scope.get_struct(vsp_type_name)
    if vsp_def.is_null() { return }
    if vsp_def.node_type.is(NodeType.StructDef).not() { return }
    if vsp_has_rest { return }
    switch vsp_def.node_type {
    case NodeType.StructDef(vsp_sdd):
        for vfi in 0..vsp_sdd.fields.len() {
            ref vfld : Declaration = vsp_sdd.fields[vfi]
            mut vsp_found := false
            for vnai in 1..pattern.children.len() {
                ref vnac : Expr = pattern.child(vnai)
                switch vnac.node_type {
                case NodeType.NamedArg(vnan):
                    if vnan.eq(vfld.name) { vsp_found = true }
                case:
                }
            }
            if vsp_found.not() {
                pattern.type_error("struct pattern '".concat(vsp_type_name).concat("' is missing field '").concat(vfld.name).concat("'; either bind it or add '..' to allow partial matching"), ctx)
            }
        }
    case:
    }
}

infer_switch_stmt := proc(scope: TypeScope, mut body: Expr, stmt_idx: U32, in_func: I32, ctx: Context) {
    ref mut stmt : Expr = body.child(stmt_idx)
    ref mut sw_expr : Expr = stmt.child(0)
    sw_line := stmt.line
    sw_col := stmt.col
    infer_expr(scope, sw_expr, in_func, ctx)
    mut coverage := CoverageNode()
    mut has_default_case := false
    mut has_switch_enum_def := false
    sw_expr_sname := til_type_name(sw_expr.expr_til_type())
    ref switch_enum_def : Expr = scope.get_struct(sw_expr_sname)
    if sw_expr.expr_til_type().is(Type.Enum).and(sw_expr_sname.len().gt(0)) {
        if switch_enum_def.is_null().not() {
            if switch_enum_def.node_type.is(NodeType.EnumDef) {
                has_switch_enum_def = true
                init_coverage_for_enum(coverage, switch_enum_def)
            }
        }
    }

    mut sw_ref := Expr.new(NodeType.Literal(Literal.Null), sw_line, sw_col)
    mut block := Expr.new(NodeType.Body, stmt.line, stmt.col)
    // #196.B: Never hoist enum-typed subjects. A hoisted local would be
    // either a shallow value copy (whose destructor frees aliased Vec/Str
    // pointers and corrupts the source AST in compile mode) or a deep
    // clone (whose destructor frees clone-owned strings that downstream
    // case-bindings expose via CAP_VIEW pointers in callers like
    // ffi_register). Re-evaluate sw_expr per case condition instead.
    if is_simple_lvalue_expr(sw_expr).or(sw_expr.expr_til_type().is(Type.Enum)) {
        sw_ref = sw_expr.clone()
    } else {
        tp := type_prefix(sw_expr.expr_til_type())
        sw_name := "_sw_".concat(tp).concat("_").concat(ctx.hoist_counter.to_str())
        ctx.hoist_counter++
        mut decl := Expr.new(NodeType.Decl(Declaration(name = sw_name.clone())), stmt.line, stmt.col)
        decl.add_child(own sw_expr.clone())
        block.add_child(own decl)
        sw_ref = Expr.new(ident_node(sw_name), sw_line, sw_col)
    }

    // Issue #199: a Case with 3 children is `[pattern, guard, body]`; with
    // 2 children it's `[pattern, body]`. When ANY case in this switch has
    // a guard we can't use a plain if/elif chain -- a failed guard must
    // fall through to the next case, which an if/elif chain cannot model.
    // Instead we hoist a `_sw_matched_<n> := false` flag and emit each
    // case as an independent `if _sw_matched.not().and(cond) { body;
    // _sw_matched = true }`. Guards become an inner `if <guard> { ...
    // _sw_matched = true }` wrapped around the user body so a failed
    // guard leaves _sw_matched false and the next case runs. Plain
    // switches keep the cheaper if/elif chain.
    mut any_guard := false
    for ag_ci in 1..stmt.children.len() {
        ref ag_cn : Expr = stmt.child(ag_ci)
        if ag_cn.children.len().eq(3) { any_guard = true }
    }

    mut first_if := Expr.new(NodeType.Body, stmt.line, stmt.col)
    mut has_first_if := false
    mut default_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
    mut has_default_body := false
    // For an exhaustive enum switch with no `case:`, the if/elif chain
    // would have no terminal else and C's -Wreturn-type would fire on
    // value-returning funcs. Stash the last non-guarded case body so we
    // can attach it as the synthetic terminal else after the loop.
    mut last_case_body := Expr.new(NodeType.Body, stmt.line, stmt.col)
    mut has_last_case_body := false

    mut matched_name := ""
    if any_guard {
        matched_name = "_sw_matched_".concat(ctx.hoist_counter.to_str())
        ctx.hoist_counter++
        mut matched_decl := Expr.new(NodeType.Decl(Declaration(name = matched_name.clone(), is_mut = true, explicit_type = "Bool", til_type = Type.Bool, own_type = OwnType.Shallow)), stmt.line, stmt.col)
        matched_decl.add_child(own Expr.new(NodeType.Literal(Literal.Bool(false)), stmt.line, stmt.col))
        block.add_child(own matched_decl)
    }

    // Dead-arm detection: any case after a default arm is unreachable
    // (the default absorbs everything earlier cases didn't match). Tracked
    // here as a flag rather than re-scanning the case vec per case.
    mut saw_default := false
    mut default_line : U32 = 0
    mut default_col : U32 = 0

    for ci in 1..stmt.children.len() {
        ref case_node : Expr = stmt.child(ci)
        if case_node.children.len().eq(1) {
            if saw_default {
                case_node.type_error("unreachable default arm; an earlier `case:` already covers everything", ctx)
            }
            default_body = case_node.child(0).clone()
            has_default_body = true
            has_default_case = true
            saw_default = true
            default_line = case_node.line
            default_col = case_node.col
            continue
        }
        mut has_guard := false
        mut body_idx : U32 = 1
        if case_node.children.len().eq(3) {
            has_guard = true
            body_idx = 2
        }
        ref mut match_expr : Expr = case_node.child(0)
        ref mut case_body : Expr = case_node.child(body_idx)
        validate_struct_pattern_rest(scope, match_expr, ctx)
        if saw_default {
            case_node.type_error("unreachable case; an earlier `case:` default already covers everything", ctx)
        } else if has_switch_enum_def.and(has_guard.not()) {
            if is_pattern_covered(scope, coverage, sw_expr_sname, match_expr) {
                case_node.type_error("unreachable case; the variant is already fully covered by an earlier arm", ctx)
            }
        }
        // Guards may fail at runtime, so they don't mark the pattern as
        // covered for exhaustiveness.
        if has_switch_enum_def.and(has_guard.not()) {
            mark_pattern_coverage(scope, coverage, sw_expr_sname, match_expr)
        }
        user_stmt_count := case_body.children.len()
        condition := make_switch_case_condition(scope, case_body, match_expr, sw_ref, sw_line, sw_col)

        if any_guard {
            // Build the case_body for the flag-based desugar:
            //   [bindings..., if <guard> { user_stmts; _sw_matched = true }]
            //   or (no guard)
            //   [bindings..., user_stmts..., _sw_matched = true]
            total_count := case_body.children.len()
            n_bindings := total_count.sub(user_stmt_count)
            mut all_children := Vec.new(Expr)
            all_children.move_from(case_body.children)
            mut new_body := Vec.new(Expr)
            for bi in 0..n_bindings {
                new_body.push_take(all_children, bi)
            }
            mut user_stmts := Expr.new(NodeType.Body, case_node.line, case_node.col)
            for ui in 0..user_stmt_count {
                user_stmts.children.push_take(all_children, n_bindings.add(ui))
            }
            mut matched_assign := Expr.new(NodeType.Assign(AssignData(name = matched_name.clone())), case_node.line, case_node.col)
            matched_assign.add_child(own Expr.new(NodeType.Literal(Literal.Bool(true)), case_node.line, case_node.col))
            user_stmts.add_child(own matched_assign)

            if has_guard {
                ref guard_expr : Expr = case_node.child(1)
                mut guard_if := Expr.new(NodeType.If, case_node.line, case_node.col)
                guard_if.add_child(own guard_expr.clone())
                guard_if.add_child(own user_stmts)
                new_body.push(own guard_if)
            } else {
                for us_i in 0..user_stmts.children.len() {
                    new_body.push_take(user_stmts.children, us_i)
                }
            }
            case_body.children.move_from(new_body)

            // Outer condition: _sw_matched.not().and(pattern_cond)
            mut not_id := Expr.new(ident_node(matched_name), case_node.line, case_node.col)
            mut not_call := make_method_call_fcall(own not_id, "not", case_node.line, case_node.col)
            mut gated_cond := make_method_call_fcall(own not_call, "and", case_node.line, case_node.col)
            gated_cond.add_child(own condition)

            mut if_node := Expr.new(NodeType.If, case_node.line, case_node.col)
            if_node.add_child(own gated_cond)
            if_node.add_child(own case_body.clone())
            block.add_child(own if_node)
        } else {
            mut if_node := Expr.new(NodeType.If, case_node.line, case_node.col)
            if_node.add_child(own condition)
            if_node.add_child(own case_body.clone())
            if has_first_if.not() {
                first_if = if_node
                has_first_if = true
            } else {
                append_switch_else_if(first_if, if_node)
            }
            last_case_body = case_body.clone()
            has_last_case_body = true
        }
    }

    if any_guard {
        if has_default_body {
            mut nid2 := Expr.new(ident_node(matched_name), stmt.line, stmt.col)
            mut ncall2 := make_method_call_fcall(own nid2, "not", stmt.line, stmt.col)
            mut def_if := Expr.new(NodeType.If, stmt.line, stmt.col)
            def_if.add_child(own ncall2)
            def_if.add_child(own default_body.clone())
            block.add_child(own def_if)
        }
    } else {
        if has_default_body.and(has_first_if) {
            attach_switch_default_body(first_if, default_body)
        } else if has_default_body.and(has_first_if.not()) {
            first_if = default_body.clone()
            has_first_if = true
        }
    }

    if has_switch_enum_def {
        ref switch_enum_def : Expr = scope.get_struct(sw_expr_sname)
        mut missing_paths := Vec.new(Str)
        collect_missing_paths(scope, coverage, switch_enum_def, "", missing_paths, ctx)
        if has_default_case {
            if missing_paths.len().eq(0) {
                type_error_at(ctx.path, default_line, default_col, "unnecessary default `case:`; all variants of enum '".concat(sw_expr_sname).concat("' are already covered"), ctx)
            }
        } else if missing_paths.len().gt(0) {
            mut msg := "non-exhaustive switch on enum '".concat(sw_expr_sname).concat("'; missing cases:")
            for mi in 0..missing_paths.len() {
                ref mp : Str = missing_paths[mi]
                if msg.ends_with(":").not() { msg = msg.concat(",") }
                msg = msg.concat(" ").concat(mp)
            }
            stmt.type_error(msg, ctx)
        } else if any_guard.not().and(has_first_if).and(has_last_case_body) {
            // Exhaustive enum switch, no `case:`, no guards: attach a clone
            // of the last case body as the chain's terminal else so C sees
            // an unconditional return path. By exhaustiveness the duplicate
            // body never runs at the source level; it exists purely so the
            // generated C compiles under -Wreturn-type.
            attach_switch_default_body(first_if, last_case_body)
        }
    }

    if has_first_if { block.add_child(own first_if.clone()) }
    replace_switch_stmt_with_block(body, stmt_idx, block)
}

replace_body_stmt_with_block := func(mut body: Expr, stmt_idx: U32, mut block: Expr) {
    ref slot_bd : Expr = body.children[stmt_idx]
    slot_bd.free_expr_slot_in_place()
    move(slot_bd, block, Expr.size())
}

make_for_in_range_while_body := func(var_name: Str, cur_name: Str, step: Str, for_body: Expr, line: U32, col: U32, elem_type: Str, var_is_mut: Bool) returns Expr {
    mut wb := Expr.new(NodeType.Body, line, col)

    mut vd := Expr.new(NodeType.Decl(Declaration(name = var_name.clone(), explicit_type = elem_type.clone(), til_type = til_type_from_explicit_type(elem_type), is_mut = var_is_mut)), line, col)
    mut cur_ident := Expr.new(ident_node(cur_name), line, col)
    vd.add_child(own cur_ident)
    wb.add_child(own vd)

    mut step_ident := Expr.new(ident_node(cur_name), line, col)
    wb.add_child(own make_method_call_fcall(own step_ident, step, line, col))

    for e_bi : Expr in for_body.children {
        wb.add_child(own e_bi.clone())
    }
    return wb
}

desugar_for_in_range_stmt := proc(scope: TypeScope, mut body: Expr, stmt_idx: U32, in_func: I32, ctx: Context) returns Bool {
    ref mut stmt : Expr = body.child(stmt_idx)
    ref mut iter : Expr = stmt.child(0)
    if iter.node_type.is(NodeType.FCall).not() { return false }
    if iter.children.len().neq(3) { return false }
    ref callee : Expr = iter.child(0)
    switch callee.node_type {
    case NodeType.FieldAccess(callee_field):
        if callee_field.field_access_name().eq("new").not() { return false }
    case:
        return false
    }
    if callee.children.len().eq(0) { return false }
    ref callee_base : Expr = callee.child(0)
    switch callee_base.node_type {
    case NodeType.Ident(callee_name):
        if callee_name.ident_name().eq("Range").not() { return false }
    case:
        return false
    }

    ref mut start_expr : Expr = iter.child(1)
    ref mut end_expr : Expr = iter.child(2)
    infer_expr(scope, start_expr, in_func, ctx)
    infer_expr(scope, end_expr, in_func, ctx)

    mut elem_type := til_type_name(stmt.expr_til_type())
    if elem_type.len().eq(0) {
        mut type_src := start_expr
        if start_expr.node_type.is_literal_num().and(end_expr.node_type.is_literal_num().not()) {
            type_src = end_expr
        } else if end_expr.node_type.is_literal_num().and(start_expr.node_type.is_literal_num().not()) {
            type_src = start_expr
        }
        if is_aggregate(type_src.expr_til_type()) {
            ts_sname := til_type_name(type_src.expr_til_type())
            if ts_sname.len().gt(0) {
                elem_type = ts_sname
            } else {
                elem_type = type_to_name(type_src.expr_til_type())
            }
        } else {
            elem_type = type_to_name(type_src.expr_til_type())
        }
    }

    mut var_name := ""
    mut forin_is_mut := false
    switch stmt.node_type {
    case NodeType.ForIn(forin_data_r):
        var_name = forin_data_r.name.clone()
        forin_is_mut = forin_data_r.is_mut
    case:
        UNREACHABLE(__LOC__)
        return false
    }
    ref for_body : Expr = stmt.child(1)
    line := stmt.line
    col := stmt.col
    counter := ctx.hoist_counter
    ctx.hoist_counter++

    end_name := "_re_".concat(elem_type).concat("_").concat(counter.to_str())
    cur_name := "_rc_".concat(elem_type).concat("_").concat(counter.to_str())

    mut block := Expr.new(NodeType.Body, line, col)

    mut end_decl := Expr.new(NodeType.Decl(Declaration(name = end_name.clone(), explicit_type = elem_type.clone(), til_type = til_type_from_explicit_type(elem_type))), line, col)
    end_decl.add_child(own end_expr.clone())
    block.add_child(own end_decl)

    mut cur_decl := Expr.new(NodeType.Decl(Declaration(name = cur_name.clone(), explicit_type = elem_type.clone(), til_type = til_type_from_explicit_type(elem_type), is_mut = true)), line, col)
    cur_decl.add_child(own start_expr.clone())
    block.add_child(own cur_decl)

    mut cur_ident_lt := Expr.new(ident_node(cur_name), line, col)
    mut lt_call := make_method_call_fcall(own cur_ident_lt, "lt", line, col)
    mut end_ident_lt := Expr.new(ident_node(end_name), line, col)
    lt_call.add_child(own end_ident_lt)
    mut asc_while := Expr.new(NodeType.While, line, col)
    asc_while.add_child(own lt_call)
    asc_while.add_child(own make_for_in_range_while_body(var_name, cur_name, "inc", for_body, line, col, elem_type, forin_is_mut))

    mut cur_ident_gt := Expr.new(ident_node(cur_name), line, col)
    mut gt_call := make_method_call_fcall(own cur_ident_gt, "gt", line, col)
    mut end_ident_gt := Expr.new(ident_node(end_name), line, col)
    gt_call.add_child(own end_ident_gt)
    mut desc_while := Expr.new(NodeType.While, line, col)
    desc_while.add_child(own gt_call)
    desc_while.add_child(own make_for_in_range_while_body(var_name, cur_name, "dec", for_body, line, col, elem_type, forin_is_mut))

    mut if_node := Expr.new(NodeType.If, line, col)
    mut cur_ident_lte := Expr.new(ident_node(cur_name), line, col)
    mut lte_call := make_method_call_fcall(own cur_ident_lte, "lte", line, col)
    mut end_ident_lte := Expr.new(ident_node(end_name), line, col)
    lte_call.add_child(own end_ident_lte)
    if_node.add_child(own lte_call)

    mut then_body := Expr.new(NodeType.Body, line, col)
    then_body.add_child(own asc_while)
    if_node.add_child(own then_body)

    mut else_body := Expr.new(NodeType.Body, line, col)
    else_body.add_child(own desc_while)
    if_node.add_child(own else_body)
    block.add_child(own if_node)

    replace_body_stmt_with_block(body, stmt_idx, block)
    return true
}

desugar_for_in_collection_stmt := proc(scope: TypeScope, mut body: Expr, stmt_idx: U32, in_func: I32, ctx: Context) returns Bool {
    ref mut stmt : Expr = body.child(stmt_idx)
    ref mut iter : Expr = stmt.child(0)

    infer_expr(scope, iter, in_func, ctx)

    mut type_name := ""
    if is_aggregate(iter.expr_til_type()) {
        iter_sname := til_type_name(iter.expr_til_type())
        if iter_sname.len().gt(0) {
            type_name = iter_sname
        }
    }
    if type_name.len().eq(0) {
        stmt.type_error("for-in requires a collection type with get() and len() methods", ctx)
        return false
    }

    ref sdef : Expr = scope.get_struct(type_name)
    if sdef.is_null() {
        stmt.type_error("for-in requires a collection type with get() and len() methods", ctx)
        return false
    }

    ref len_func : Expr = find_namespace_func(sdef, "len", scope)
    ref get_func : Expr = find_namespace_func(sdef, "get", scope)

    if len_func.is_null() {
        stmt.type_error("type '".concat(type_name).concat("' has no 'len' method (required for for-in)"), ctx)
        return false
    }
    mut idx_type := ""
    switch len_func.node_type {
    case NodeType.FuncDef(len_def):
        if len_def.params.len().neq(1).or(len_def.return_type.len().eq(0)) {
            stmt.type_error("type '".concat(type_name).concat("' len() must take 1 param and return a scalar for for-in"), ctx)
            return false
        }
        idx_type = len_def.return_type.clone()
    case:
        UNREACHABLE(__LOC__)
        return false
    }

    if get_func.is_null() {
        stmt.type_error("type '".concat(type_name).concat("' has no 'get' method (required for for-in)"), ctx)
        return false
    }
    mut elem_type := til_type_name(stmt.expr_til_type())
    mut get_returns_ref := false
    mut get_throws := false
    mut get_throw_types := Vec.new(Str)
    switch get_func.node_type {
    case NodeType.FuncDef(get_def):
        // A throwing get gets its signature extended in place with
        // synthetic _err_kind/_err_<T> params below. Allow either
        // the original (self, idx) shape or the already-extended one
        // -- the original 2-param form is what user code wrote, and
        // any subsequent for-in over the same type sees the extended
        // shape because we mutated its FuncDef.
        if get_def.params.len().lt(2) {
            stmt.type_error("type '".concat(type_name).concat("' get() second param must match len() return type for for-in"), ctx)
            return false
        }
        ref get_idx_param : Declaration = get_def.params[1]
        if get_idx_param.explicit_type.len().eq(0).or(get_idx_param.explicit_type.eq(idx_type).not()) {
            stmt.type_error("type '".concat(type_name).concat("' get() second param must match len() return type for for-in"), ctx)
            return false
        }
        if elem_type.len().eq(0) {
            if get_def.return_type.len().eq(0).or(get_def.return_type.eq("Dynamic")) {
                stmt.type_error("cannot infer element type for '".concat(type_name).concat("', use explicit type: for x : Type in ..."), ctx)
                return false
            }
            elem_type = get_def.return_type.clone()
        }
        get_returns_ref = get_def.return_own_type.is(OwnType.Ref)
        get_throws = get_def.throw_types.len().gt(0)
        if get_throws {
            for gtn : Str in get_def.throw_types {
                get_throw_types.push(own gtn.clone())
            }
            // Extend the get FuncDef in place with the synthetic
            // _err_kind + _err_<T> out-params so the call we emit
            // below (4-arg shape for a 1-throw get) matches the
            // callee's arity. Idempotent: only extends once.
            mut already_extended := false
            for p : Declaration in get_def.params {
                if p.name.eq("_err_kind") { already_extended = true }
            }
            if already_extended.not() {
                mut kp := Declaration(name = "_err_kind",
                    explicit_type = "I64",
                    til_type = Type.I64,
                    is_mut = true,
                    own_type = OwnType.Ref,
                    used = true)
                get_def.params.push(own kp)
                for gtn : Str in get_def.throw_types {
                    mut tp := Declaration(name = err_slot_name(gtn),
                        explicit_type = gtn.clone(),
                        til_type = til_type_from_explicit_type(gtn),
                        is_mut = true,
                        own_type = OwnType.Ref,
                        used = true)
                    get_def.params.push(own tp)
                }
            }
        }
    case:
        UNREACHABLE(__LOC__)
        return false
    }

    mut var_name := ""
    mut forin_is_mut := false
    switch stmt.node_type {
    case NodeType.ForIn(forin_data_c):
        var_name = forin_data_c.name.clone()
        forin_is_mut = forin_data_c.is_mut
    case:
        UNREACHABLE(__LOC__)
        return false
    }
    ref for_body : Expr = stmt.child(1)
    line := stmt.line
    col := stmt.col

    counter := ctx.hoist_counter
    ctx.hoist_counter++
    col_name := "_fc_".concat(type_name).concat("_").concat(counter.to_str())
    idx_name := "_fi_USize_".concat(counter.to_str())

    mut block := Expr.new(NodeType.Body, line, col)

    // When iter is an lvalue (ident or field access), bind _fc as a ref to
    // alias the source instead of letting infer_decl_value insert a deep
    // .clone() that would dangle any refs taken out of the loop body.
    // For rvalues (literals, calls), keep the default Shallow so the result
    // gets stored as a value.
    mut col_own_type := OwnType.Shallow
    if iter.node_type.is(NodeType.Ident).or(iter.node_type.is(NodeType.FieldAccess)) {
        col_own_type = OwnType.Ref
    }
    mut col_decl := Expr.new(NodeType.Decl(Declaration(name = col_name.clone(), own_type = col_own_type)), line, col)
    col_decl.add_child(own iter.clone())
    block.add_child(own col_decl)

    mut idx_decl := Expr.new(NodeType.Decl(Declaration(name = idx_name.clone(), explicit_type = idx_type.clone(), til_type = til_type_from_explicit_type(idx_type), is_mut = true)), line, col)
    mut zero := Expr.new(literal_num_node("0"), line, col)
    idx_decl.add_child(own zero)
    block.add_child(own idx_decl)

    // For a throwing get, declare block-local err slots: we lower
    // the iteration access as an explicit `get(idx, mut _kind, mut _slot)`
    // followed by `if _kind != 0 { panic(...) }`, instead of routing
    // through the bang/throw-catch pipeline. Self-contained: no extra
    // pre-pass, no fdef-level slot prepend.
    fk_name := "_forin_err_kind_".concat(counter.to_str())
    if get_throws {
        mut kind_decl := Expr.new(NodeType.Decl(Declaration(name = fk_name.clone(),
            explicit_type = "I64", til_type = Type.I64, is_mut = true)), line, col)
        kind_decl.add_child(own make_int_lit(0, line, col))
        block.add_child(own kind_decl)
        for gtn : Str in get_throw_types {
            slot_name := "_forin_".concat(gtn).concat("_").concat(counter.to_str())
            mut slot_decl := Expr.new(NodeType.Decl(Declaration(name = slot_name.clone(),
                explicit_type = gtn.clone(), til_type = til_type_from_explicit_type(gtn),
                is_mut = true)), line, col)
            slot_decl.add_child(own make_default_value_expr(gtn, line, col))
            block.add_child(own slot_decl)
        }
    }

    mut while_node := Expr.new(NodeType.While, line, col)

    mut idx_ident_cond := Expr.new(ident_node(idx_name), line, col)
    mut cond_call := make_method_call_fcall(own idx_ident_cond, "lt", line, col)
    mut col_ident_len := Expr.new(ident_node(col_name), line, col)
    cond_call.add_child(own make_method_call_fcall(own col_ident_len, "len", line, col))
    while_node.add_child(own cond_call)

    mut wbody := Expr.new(NodeType.Body, line, col)

    mut forin_own := OwnType.Shallow
    if get_returns_ref { forin_own = OwnType.Ref }
    mut elem_decl := Expr.new(NodeType.Decl(Declaration(name = var_name.clone(), explicit_type = elem_type.clone(), til_type = til_type_from_explicit_type(elem_type), own_type = forin_own, is_mut = forin_is_mut)), line, col)
    mut col_ident_get := Expr.new(ident_node(col_name), line, col)
    mut get_call := make_method_call_fcall(own col_ident_get, "get", line, col)
    mut idx_ident_get := Expr.new(ident_node(idx_name), line, col)
    get_call.add_child(own idx_ident_get)
    if get_throws {
        // Pass the block-local err slots as out-args so the throwing
        // get's extended signature is satisfied without any flag-and-
        // lower roundtrip through the throw/catch pass.
        mut kind_arg := Expr.new(ident_node(fk_name), line, col)
        kind_arg.set_expr_til_type(Type.I64)
        get_call.add_child(own kind_arg)
        for gtn : Str in get_throw_types {
            slot_name := "_forin_".concat(gtn).concat("_").concat(counter.to_str())
            mut slot_arg := Expr.new(ident_node(slot_name), line, col)
            slot_arg.set_expr_til_type(til_type_from_explicit_type(gtn))
            get_call.add_child(own slot_arg)
        }
    }
    elem_decl.add_child(own get_call)
    wbody.add_child(own elem_decl)

    if get_throws {
        // if _forin_err_kind_<n>.eq(0).not() { panic(__LOC__, "<T>") }
        // for-in is the only caller of this get; on-error semantics is
        // panic-with-type-name, matching the user-visible `arr[i]`.
        mut kind_id := Expr.new(ident_node(fk_name), line, col)
        kind_id.set_expr_til_type(Type.I64)
        mut zero_lit := make_int_lit(0, line, col)
        mut eq_call := make_method_call_fcall(own kind_id, "eq", line, col)
        eq_call.add_child(own zero_lit)
        mut not_call := make_method_call_fcall(own eq_call, "not", line, col)

        loc_str := format(ctx.path, ":", line.to_str(), ":", col.to_str())
        mut panic_call := Expr.new(NodeType.FCall(FCallData()), line, col)
        panic_call.add_child(own Expr.new(ident_node("panic"), line, col))
        panic_call.add_child(own Expr.new(NodeType.Literal(Literal.Str(loc_str)), line, col))
        ref first_throw : Str = get_throw_types[0]
        panic_call.add_child(own Expr.new(NodeType.Literal(Literal.Str(first_throw.clone())), line, col))

        mut panic_body := Expr.new(NodeType.Body, line, col)
        panic_body.add_child(own panic_call)
        mut if_panic := Expr.new(NodeType.If, line, col)
        if_panic.add_child(own not_call)
        if_panic.add_child(own panic_body)
        wbody.add_child(own if_panic)
    }

    mut idx_assign := Expr.new(NodeType.Assign(AssignData(name = idx_name.clone())), line, col)
    mut idx_ident_inc := Expr.new(ident_node(idx_name), line, col)
    mut add_call := make_method_call_fcall(own idx_ident_inc, "add", line, col)
    mut one := Expr.new(literal_num_node("1"), line, col)
    add_call.add_child(own one)
    idx_assign.add_child(own add_call)
    wbody.add_child(own idx_assign)

    for e_bi : Expr in for_body.children {
        wbody.add_child(own e_bi.clone())
    }

    while_node.add_child(own wbody)
    block.add_child(own while_node)
    replace_body_stmt_with_block(body, stmt_idx, block)
    return true
}

// ---------------------------------------------------------------
// Issue #198: typer-side lowering for throw/catch.
//
// Walks a function body and rewrites Throw/Catch into plain til
// (mut _err_kind + _err_<T> slots, assignments, if-guards) so the
// interpreter and builder both run throw/catch programs without
// any new error-handling code paths. Single implementation, two
// pipelines.
//
// The lowering is conservative on what it recognises:
//  - throw <Ident>(...) -- type is the Ident text (constructor)
//  - throw "..."        -- type is "Str"
//  - throw <num>        -- type is "I64"
//  - other shapes       -- left as-is; typer's existing machinery
//                          will surface a clear error.
// Cross-call propagation (~?~ on calls) is not lowered yet -- a
// follow-up will extend this pass.
// ---------------------------------------------------------------

// Recursively walk e looking for a Decl(name=var_name) whose RHS
// looks like a constructor or typed literal we can infer from
// syntactically. Returns "" if not found. Best-effort pre-typer
// lookup so `throw my_var` can find the type of my_var from its
// declaration. Read-only; safe to call before destructive lowering.
priv guess_local_type := func(e: Expr, var_name: Str) returns Str {
    if e.node_type.is(NodeType.Decl) {
        switch e.node_type {
        case NodeType.Decl(dn):
            if dn.name.eq(var_name) {
                if dn.explicit_type.len().gt(0) { return dn.explicit_type.clone() }
                if e.children.len().gt(0) {
                    ref rhs : Expr = e.child(0)
                    switch rhs.node_type {
                    case NodeType.FCall:
                        if rhs.children.len().gt(0) {
                            switch rhs.child(0).node_type {
                            case NodeType.Ident(rhsn): return rhsn.name.clone()
                            case NodeType.FieldAccess(_rhsfa):
                                if rhs.child(0).children.len().gt(0) {
                                    switch rhs.child(0).child(0).node_type {
                                    case NodeType.Ident(rhsty): return rhsty.ident_name()
                                    case:
                                    }
                                }
                            case:
                            }
                        }
                    case NodeType.Literal(Literal.Str): return "Str"
                    case NodeType.Literal(Literal.Num): return "I64"
                    case:
                    }
                }
            }
        case:
        }
    }
    for c : Expr in e.children {
        guess := guess_local_type(c, var_name)
        if guess.len().gt(0) { return guess }
    }
    return ""
}

priv guess_prior_local_type_in_vec := func(stmts: Vec, upto: USize, var_name: Str) returns Str {
    if stmts.len().eq(0) { return "" }
    mut limit := upto
    if limit.gte(stmts.len()) {
        limit = stmts.len().sub(1)
    }
    mut i : USize = 0
    while i.lte(limit) {
        ref stmt : Expr = stmts[i]
        guess := guess_local_type(stmt, var_name)
        if guess.len().gt(0) { return guess }
        i = i.add(1)
    }
    return ""
}

priv collect_throw_ident_names := proc(e: Expr, mut names: Set) {
    if e.node_type.is(NodeType.Throw).and(e.children.len().eq(1)) {
        switch e.child(0).node_type {
        case NodeType.Ident(idn):
            names.add(own idn.name.clone())
        case:
        }
    }
    for c : Expr in e.children {
        collect_throw_ident_names(c, names)
    }
}

priv annotate_throw_ident_expr_types := proc(mut e: Expr, root_body: Expr) {
    if e.node_type.is(NodeType.Throw).and(e.children.len().eq(1)) {
        switch e.child(0).node_type {
        case NodeType.Ident(idn):
            tn := guess_local_type(root_body, idn.name)
            if tn.len().gt(0) {
                e.child(0).set_expr_til_type(Type.Custom(tn.clone()))
            }
        case:
        }
    }
    for c : Expr in e.children {
        annotate_throw_ident_expr_types(c, root_body)
    }
}

priv has_prior_throw_type := proc(e: Expr, root_body: Expr, type_name: Str, before_line: U32) returns Bool {
    if e.line.lt(before_line).and(e.node_type.is(NodeType.Throw)).and(e.children.len().eq(1)) {
        mut thrown_name := type_to_name(e.expr_til_type())
        if thrown_name.len().eq(0) {
            switch e.child(0).node_type {
            case NodeType.Ident(idn):
                thrown_name = guess_local_type(root_body, idn.name)
            case NodeType.FCall:
                if e.child(0).children.len().gt(0) {
                    switch e.child(0).child(0).node_type {
                    case NodeType.Ident(name): thrown_name = name.name.clone()
                    case:
                    }
                }
            case NodeType.Literal(Literal.Str):
                thrown_name = "Str"
            case NodeType.Literal(Literal.Num):
                thrown_name = "I64"
            case:
            }
        }
        if thrown_name.eq(type_name) { return true }
    }
    for c : Expr in e.children {
        if has_prior_throw_type(c, root_body, type_name, before_line) { return true }
    }
    return false
}

priv subtree_has_throw_type := proc(e: Expr, root_body: Expr, type_name: Str) returns Bool {
    if e.node_type.is(NodeType.Throw).and(e.children.len().eq(1)) {
        mut thrown_name := ""
        switch e.child(0).node_type {
        case NodeType.Ident(idn):
            thrown_name = guess_local_type(root_body, idn.name)
        case NodeType.FCall:
            if e.child(0).children.len().gt(0) {
                switch e.child(0).child(0).node_type {
                case NodeType.Ident(name): thrown_name = name.name.clone()
                case:
                }
            }
        case NodeType.Literal(Literal.Str):
            thrown_name = "Str"
        case NodeType.Literal(Literal.Num):
            thrown_name = "I64"
        case:
        }
        if thrown_name.eq(type_name) { return true }
    }
    for c : Expr in e.children {
        if subtree_has_throw_type(c, root_body, type_name) { return true }
    }
    return false
}

priv has_prior_throw_type_in_vec := proc(stmts: Vec, root_body: Expr, upto: USize, type_name: Str) returns Bool {
    if stmts.len().eq(0).or(upto.eq(0)) { return false }
    mut limit := upto
    if limit.gt(stmts.len()) { limit = stmts.len() }
    mut i : USize = 0
    while i.lt(limit) {
        ref stmt : Expr = stmts[i]
        if subtree_has_throw_type(stmt, root_body, type_name) { return true }
        i = i.add(1)
    }
    return false
}

priv throw_type_name_for_with_body := func(e: Expr, body: Expr) returns Str {
    switch e.node_type {
    case NodeType.Literal(Literal.Str): return "Str"
    case NodeType.Literal(Literal.Num): return "I64"
    case NodeType.FCall:
        if e.children.len().eq(0) { return "" }
        switch e.child(0).node_type {
        case NodeType.Ident(name): return name.name.clone()
        case NodeType.FieldAccess(_fa_name):
            if e.child(0).children.len().eq(0) { return "" }
            switch e.child(0).child(0).node_type {
            case NodeType.Ident(type_name): return type_name.ident_name()
            case: return ""
            }
        case: return ""
        }
    case NodeType.Ident(idn): return guess_local_type(body, idn.name)
    case: return ""
    }
}


priv subtree_has_throw_catch := func(e: Expr) returns Bool {
    if e.node_type.is(NodeType.Throw).or(e.node_type.is(NodeType.Catch)) {
        return true
    }
    if e.node_type.is(NodeType.FCall) {
        switch e.node_type {
        case NodeType.FCall(fcd):
            // does_throw OR leftover is_bang both signal that this
            // FCall is a throwing-call shape the validator should
            // inspect.
            if fcd.does_throw { return true }
            if fcd.is_bang { return true }
        case:
        }
    }
    for c : Expr in e.children {
        if subtree_has_throw_catch(c) { return true }
    }
    return false
}

// Like subtree_has_throw_catch but a bang (`f()!`) does NOT count.
// Used for the per-stmt "might _err_kind still be set after this
// stmt?" wrap decision: a bang panics-and-resets on the error path,
// so it never leaves a pending error for the following statements to
// guard against (unlike a bare throw or a propagating `?`-call). A
// bang nested in a while/if body would otherwise spuriously wrap the
// statements after the loop in `if _err_kind == 0`.
priv subtree_has_pending_throw := func(e: Expr) returns Bool {
    if e.node_type.is(NodeType.Throw).or(e.node_type.is(NodeType.Catch)) {
        return true
    }
    if e.node_type.is(NodeType.FCall) {
        switch e.node_type {
        case NodeType.FCall(fcd):
            if fcd.does_throw { return true }
        case:
        }
    }
    for c : Expr in e.children {
        if subtree_has_pending_throw(c) { return true }
    }
    return false
}

// Issue #202: any subtree FCall with is_bang flag set?
priv subtree_has_bang := func(e: Expr) returns Bool {
    if e.node_type.is(NodeType.FCall) {
        switch e.node_type {
        case NodeType.FCall(fcd_b):
            if fcd_b.is_bang { return true }
        case:
        }
    }
    for c : Expr in e.children {
        if subtree_has_bang(c) { return true }
    }
    return false
}

// Walk e and annotate each Throw node's til_type with the
// syntactically-resolved type of the thrown expression. Lookups
// run BEFORE any destructive mutation by the lowering pass, so
// the lowering can read each Throw's til_type directly. This
// also handles `throw <Ident>` by walking to the Ident's Decl.
priv annotate_throw_types_in := proc(mut e: Expr, root_body: Expr) {
    if e.node_type.is(NodeType.Body) {
        for bi in 0..e.children.len() {
            ref mut stmt : Expr = e.child(bi)
            if stmt.node_type.is(NodeType.Throw) {
                if stmt.children.len().eq(1) {
                    mut tn := throw_type_name_for_with_body(stmt.child(0), root_body)
                    switch stmt.child(0).node_type {
                    case NodeType.Ident(idn):
                        mut scan := bi
                        while true {
                            ref prior_stmt : Expr = e.child(scan)
                            if prior_stmt.node_type.is(NodeType.Decl) {
                                switch prior_stmt.node_type {
                                case NodeType.Decl(dd):
                                    if dd.name.eq(idn.name) {
                                        if dd.explicit_type.len().gt(0) {
                                            tn = dd.explicit_type.clone()
                                        } else if prior_stmt.children.len().gt(0) {
                                            switch prior_stmt.child(0).node_type {
                                            case NodeType.FCall:
                                                if prior_stmt.child(0).children.len().gt(0) {
                                                    switch prior_stmt.child(0).child(0).node_type {
                                                    case NodeType.Ident(rhsn): tn = rhsn.ident_name()
                                                    case NodeType.FieldAccess(_rhsfa3):
                                                        if prior_stmt.child(0).child(0).children.len().gt(0) {
                                                            switch prior_stmt.child(0).child(0).child(0).node_type {
                                                            case NodeType.Ident(rhsty3): tn = rhsty3.ident_name()
                                                            case:
                                                            }
                                                        }
                                                    case:
                                                    }
                                                }
                                            case NodeType.Literal(Literal.Str):
                                                tn = "Str"
                                            case NodeType.Literal(Literal.Num):
                                                tn = "I64"
                                            case:
                                            }
                                        }
                                    }
                                case:
                                }
                            }
                            if tn.len().gt(0).or(scan.eq(0)) { break }
                            scan = scan.sub(1)
                        }
                    case:
                    }
                    if tn.len().gt(0) {
                        stmt.set_expr_til_type(Type.Custom(tn.clone()))
                    }
                }
            }
            annotate_throw_types_in(stmt, root_body)
        }
        return
    }
    if e.node_type.is(NodeType.Throw) {
        if e.children.len().eq(1) {
            tn := throw_type_name_for_with_body(e.child(0), root_body)
            if tn.len().gt(0) {
                e.set_expr_til_type(Type.Custom(tn.clone()))
            }
        }
    }
    for ci in 0..e.children.len() {
        ref mut sub : Expr = e.child(ci)
        annotate_throw_types_in(sub, root_body)
    }
}

priv collect_throw_types_in := proc(e: Expr, mut out: Vec) {
    if e.node_type.is(NodeType.Throw) {
        tn := til_type_name(e.expr_til_type())
        if tn.len().gt(0) {
            mut already := false
            for existing : Str in out {
                if existing.eq(tn) { already = true }
            }
            if already.not() { out.push(own tn.clone()) }
        }
    }
    if e.node_type.is(NodeType.Catch) {
        if e.children.len().eq(3) {
            switch e.child(1).node_type {
            case NodeType.Ident(ctn):
                mut already_c := false
                for existing : Str in out {
                    if existing.eq(ctn.ident_name()) { already_c = true }
                }
                if already_c.not() { out.push(own ctn.ident_name()) }
            case:
            }
        }
    }
    for c : Expr in e.children {
        collect_throw_types_in(c, out)
    }
}


priv err_slot_name := func(t: Str) returns Str {
    return "_err_".concat(t)
}

priv make_int_lit := func(n: I64, line: U32, col: U32) returns Expr {
    return Expr.new(literal_num_node(n.to_str()), line, col)
}

priv make_typed_mut_decl := func(name: Str, type_name: Str, init: Expr, line: U32, col: U32) returns Expr {
    mut dd := Declaration(
        name = name.clone(),
        explicit_type = type_name.clone(),
        til_type = til_type_from_explicit_type(type_name),
        is_mut = true
    )
    mut decl := Expr.new(NodeType.Decl(dd), line, col)
    decl.add_child(own init.clone())
    return decl
}

priv make_assign_stmt := func(name: Str, rhs: Expr, line: U32, col: U32) returns Expr {
    mut a := Expr.new(NodeType.Assign(AssignData(name = name.clone())), line, col)
    a.add_child(own rhs.clone())
    return a
}

priv make_default_value_expr := func(type_name: Str, line: U32, col: U32) returns Expr {
    if type_name.eq("Str") { return Expr.new(NodeType.Literal(Literal.Str("")), line, col) }
    if type_name.eq("Bool") { return Expr.new(NodeType.Literal(Literal.Bool(false)), line, col) }
    if type_name.eq("I64").or(type_name.eq("U8")).or(type_name.eq("I8")).or(type_name.eq("I16"))
    .or(type_name.eq("U16")).or(type_name.eq("I32")).or(type_name.eq("U32")).or(type_name.eq("U64"))
    .or(type_name.eq("F32")) {
        return Expr.new(literal_num_node("0"), line, col)
    }
    // Pointer-shaped builtins have no constructor. Used only for the
    // (unreachable) fallback return appended to throwing functions.
    if type_name.eq("Dynamic").or(type_name.eq("Ptr")) {
        return Expr.new(NodeType.Literal(Literal.Null), line, col)
    }
    mut tident := Expr.new(ident_node(type_name), line, col)
    mut call := Expr.new(NodeType.FCall(FCallData()), line, col)
    call.add_child(own tident)
    return call
}

priv tag_for_type := func(ctx: Context, type_name: Str, _type_to_tag_names: Vec) returns I64 {
    // Issue #198: read from ctx.throw_type_registry so the tag for a
    // given type is the same in every function (caller and callee
    // agree). The local Vec param is kept for backward shape but no
    // longer consulted.
    for i in 0..ctx.throw_type_registry.len() {
        ref n : Str = ctx.throw_type_registry[i]
        if n.eq(type_name) { return i.to_i64().add(1) }
    }
    return 0
}

priv register_throw_type := func(mut ctx: Context, name: Str) {
    if name.len().eq(0) { return }
    for existing : Str in ctx.throw_type_registry {
        if existing.eq(name) { return }
    }
    ctx.throw_type_registry.push(own name.clone())
}

priv make_if_kind_eq_zero_wrap := func(stmt: Expr, line: U32, col: U32) returns Expr {
    mut wrap_body := Expr.new(NodeType.Body, line, col)
    wrap_body.add_child(own stmt.clone())
    mut kind_id := Expr.new(ident_node("_err_kind"), line, col)
    mut cond := make_method_call_fcall(own kind_id, "eq", line, col)
    mut zero_lit := make_int_lit(0, line, col)
    cond.add_child(own zero_lit)
    mut if_node := Expr.new(NodeType.If, line, col)
    if_node.add_child(own cond)
    if_node.add_child(own wrap_body)
    return if_node
}

// Recursively replace Ident(old_name) with Ident(new_name) in e.
priv rewrite_ident := proc(mut e: Expr, old_name: Str, new_name: Str) {
    switch e.node_type {
    case NodeType.Ident(ridn):
        if ridn.ident_name().eq(old_name) {
            e.node_type = ident_node(new_name)
        }
    case:
    }
    for ci in 0..e.children.len() {
        ref mut sub : Expr = e.child(ci)
        rewrite_ident(sub, old_name, new_name)
    }
}

priv lower_catch_node := proc(ctx: Context, catch_node: Expr, type_to_tag_names: Vec) returns Expr {
    line := catch_node.line
    col := catch_node.col
    mut var_name := ""
    switch catch_node.child(0).node_type {
    case NodeType.Ident(n): var_name = n.ident_name()
    case: UNREACHABLE(__LOC__)
    }
    mut type_name := ""
    switch catch_node.child(1).node_type {
    case NodeType.Ident(n): type_name = n.ident_name()
    case: UNREACHABLE(__LOC__)
    }
    tag := tag_for_type(ctx, type_name, type_to_tag_names)
    mut new_body := Expr.new(NodeType.Body, line, col)
    new_body.add_child(own make_assign_stmt("_err_kind", make_int_lit(0, line, col), line, col))
    // Rewrite references to the user's err var inside the catch body
    // to point at the _err_<T> slot directly. Avoids needing a local
    // binding (which would trip the unused-variable check when the
    // body doesn't touch err) and keeps ownership semantics simple.
    ref orig_body : Expr = catch_node.child(2)
    slot := err_slot_name(type_name)
    for cb : Expr in orig_body.children {
        mut cb_clone := cb.clone()
        rewrite_ident(cb_clone, var_name, slot)
        new_body.add_child(own cb_clone)
    }
    mut kind_id := Expr.new(ident_node("_err_kind"), line, col)
    mut cond := make_method_call_fcall(own kind_id, "eq", line, col)
    mut tag_lit := make_int_lit(tag, line, col)
    cond.add_child(own tag_lit)
    mut if_node := Expr.new(NodeType.If, line, col)
    if_node.add_child(own cond)
    if_node.add_child(own new_body)
    return if_node
}


// Issue #198: extend the signature of every throwing function in
// the program AST with synthetic err-out params:
//   mut _err_kind: I64
//   mut _err_<T>: T   -- one per declared throw type
// Cross-call propagation (~?~ at call sites) passes the caller's
// matching slots as the extra args. Idempotent: skips functions
// whose params already contain _err_kind. Recurses into nested
// FuncDef bodies so inner lambdas with throws also get extended.
priv register_func_throws := func(mut ctx: Context, name: Str, throws_list: Vec) {
    if name.len().eq(0) { return }
    if throws_list.len().eq(0) { return }
    for existing : Str in ctx.throws_names_global {
        if existing.eq(name) { return }
    }
    ctx.throws_names_global.push(own name.clone())
    mut tt := Vec.new(Str)
    for t : Str in throws_list {
        tt.push(own t.clone())
    }
    ctx.throws_per_global.push(own tt)
}

extend_throwing_func_sigs := proc(mut ctx: Context, mut e: Expr) {
    // Register Decl(name) -> FuncDef in the global throws map.
    if e.node_type.is(NodeType.Decl) {
        if e.children.len().gt(0) {
            switch e.node_type {
            case NodeType.Decl(dn):
                ref rhs : Expr = e.child(0)
                if rhs.node_type.is(NodeType.FuncDef) {
                    switch rhs.node_type {
                    case NodeType.FuncDef(rfd):
                        register_func_throws(ctx, dn.name, rfd.throw_types)
                    case:
                    }
                }
                // Namespace methods register under the type-qualified
                // key "Type.method" so the call-site lookup can tell e.g.
                // Array.get (throwing) from Vec.get (not), instead of
                // conflating them by the bare method name.
                switch rhs.node_type {
                case NodeType.StructDef(rsd):
                    for ci in 0..rsd.ns_decls.len() {
                        ref nd : Declaration = rsd.ns_decls[ci]
                        ref dv : Expr = nd.default_value
                        if dv.node_type.is(NodeType.FuncDef) {
                            switch dv.node_type {
                            case NodeType.FuncDef(mfd):
                                register_func_throws(ctx, dn.name.concat(".").concat(nd.name), mfd.throw_types)
                            case:
                            }
                        }
                    }
                case NodeType.EnumDef(red):
                    for ci in 0..red.ns_decls.len() {
                        ref nd : Declaration = red.ns_decls[ci]
                        ref dv : Expr = nd.default_value
                        if dv.node_type.is(NodeType.FuncDef) {
                            switch dv.node_type {
                            case NodeType.FuncDef(mfd):
                                register_func_throws(ctx, dn.name.concat(".").concat(nd.name), mfd.throw_types)
                            case:
                            }
                        }
                    }
                case:
                }
            case:
            }
        }
    }
    if e.node_type.is(NodeType.FuncDef) {
        switch e.node_type {
        case NodeType.FuncDef(efd):
            // Register all declared throw types in the global registry.
            for tn : Str in efd.throw_types {
                register_throw_type(ctx, tn)
            }
            if efd.throw_types.len().gt(0) {
                mut already := false
                for p : Declaration in efd.params {
                    if p.name.eq("_err_kind") { already = true }
                }
                if already.not() {
                    mut kp := Declaration(name = "_err_kind",
                        explicit_type = "I64",
                        til_type = Type.I64,
                        is_mut = true,
                        own_type = OwnType.Ref,
                        used = true)
                    efd.params.push(own kp)
                    for tn : Str in efd.throw_types {
                        mut tp := Declaration(name = err_slot_name(tn),
                            explicit_type = tn.clone(),
                            til_type = til_type_from_explicit_type(tn),
                            is_mut = true,
                            own_type = OwnType.Ref,
                            used = true)
                        efd.params.push(own tp)
                    }
                }
            }
        case:
        }
    }
    // Also register types from Throw and Catch nodes so locally-only
    // throws (not in any throws clause) still get a stable tag.
    if e.node_type.is(NodeType.Throw) {
        if e.children.len().eq(1) {
            tn := throw_type_name_for_with_body(e.child(0), e)
            if tn.len().gt(0) { register_throw_type(ctx, tn) }
        }
    }
    if e.node_type.is(NodeType.Catch) {
        if e.children.len().eq(3) {
            switch e.child(1).node_type {
            case NodeType.Ident(ctn): register_throw_type(ctx, ctn.ident_name())
            case:
            }
        }
    }
    // Also recurse into namespace method bodies (ns_decls' default_value
    // Exprs hold the method FuncDef bodies; they're not in children).
    // Recurse into namespace method bodies to extend their throwing
    // signatures with the synthetic err out-params. The throws-map
    // registration itself is type-qualified ("Type.method") and done
    // at the owning Decl above, so it is not repeated here.
    switch e.node_type {
    case NodeType.StructDef(esd_ns):
        for ci in 0..esd_ns.ns_decls.len() {
            ref mut nd : Declaration = esd_ns.ns_decls[ci]
            extend_throwing_func_sigs(ctx, nd.default_value)
        }
    case NodeType.EnumDef(eed_ns):
        for ci in 0..eed_ns.ns_decls.len() {
            ref mut nd : Declaration = eed_ns.ns_decls[ci]
            extend_throwing_func_sigs(ctx, nd.default_value)
        }
    case:
    }
    for ci in 0..e.children.len() {
        ref mut sub : Expr = e.child(ci)
        extend_throwing_func_sigs(ctx, sub)
    }
}

// Build a parallel-Vec map of FuncName -> Vec[Str] (throws) for
// every throwing top-level function in the program. Recurses into
// nested FuncDefs. Used by the call-site rewrite in
// inject_throw_args_in_body. Names is by Decl name (works for
// bare-name calls and for UFCS-rewritten calls, which look like
// bare-name FCalls after the typer's UFCS pass).

// Walk a (lowered + typed) body, find every FCall whose
// does_throw is set, and rewrite it to pass the caller's err
// slots as extra args. The slots must already exist in scope
// (as locals declared by lower_throw_catch_in_func_body or as
// params on a throwing caller). Clears does_throw on the FCall
// after rewriting so downstream stages don't act on the marker.

// ---------------------------------------------------------------
// Issue #202: bang operator (!) -- "panic on throw" sugar.
//
//   f(args)!
//
// desugars to
//
//   f(args)?
//   catch (e: T) { panic(loc(), "T") }   // one per declared throw type
//
// The user keeps the right to use the verbose ~?~ + ~catch~ form
// when they need to inspect err fields; ~!~ is for "fail loudly,
// don't care about the message" call sites.
// ---------------------------------------------------------------

// Issue #202: bang_counter previously lived here as a module-level
// mut; it moved onto Context (see initer.til) alongside the other
// throws state. Threading ctx through the bang hoisters lets a
// single ctx own all of this typer transient state.

// Walk e: for every FCall with is_bang set, clear is_bang and set
// does_throw. Idempotent; safe to call multiple times.
priv clear_bang_flag := proc(mut e: Expr) {
    switch e.node_type {
    case NodeType.FCall(fcd_clr):
        if fcd_clr.is_bang {
            fcd_clr.is_bang = false
            fcd_clr.does_throw = true
        }
    case:
    }
    for ci in 0..e.children.len() {
        ref mut sub : Expr = e.child(ci)
        clear_bang_flag(sub)
    }
}

// Find the immediate bang FCall in a stmt (direct or wrapped in
// Decl/Assign/FieldAssign/Return). Returns the callee name, or "".
priv find_bang_callee_name := func(e: Expr) returns Str {
    switch e.node_type {
    case NodeType.FCall(fcd_f):
        if fcd_f.is_bang.not() { return "" }
        if e.children.len().eq(0) { return "" }
        switch e.child(0).node_type {
        case NodeType.Ident(n): return n.ident_name()
        case NodeType.FieldAccess(fnam): return fnam.field_access_name()
        case: return ""
        }
    case NodeType.Decl:
        if e.children.len().eq(0) { return "" }
        return find_bang_callee_name(e.child(0))
    case NodeType.Assign:
        if e.children.len().eq(0) { return "" }
        return find_bang_callee_name(e.child(0))
    case NodeType.FieldAssign:
        if e.children.len().eq(0) { return "" }
        return find_bang_callee_name(e.child(0))
    case NodeType.Return:
        if e.children.len().eq(0) { return "" }
        return find_bang_callee_name(e.child(0))
    case: return ""
    }
}

// Like find_bang_callee_name but returns the bang FCall node itself
// (or NULL), so callers can resolve its type-qualified throws.
priv find_bang_fcall := func(e: Expr) returns ref Expr {
    switch e.node_type {
    case NodeType.FCall(fcd_f):
        if fcd_f.is_bang { return e }
        return NULL
    case NodeType.Decl:
        if e.children.len().eq(0) { return NULL }
        return find_bang_fcall(e.child(0))
    case NodeType.Assign:
        if e.children.len().eq(0) { return NULL }
        return find_bang_fcall(e.child(0))
    case NodeType.FieldAssign:
        if e.children.len().eq(0) { return NULL }
        return find_bang_fcall(e.child(0))
    case NodeType.Return:
        if e.children.len().eq(0) { return NULL }
        return find_bang_fcall(e.child(0))
    case: return NULL
    }
}

// Build  catch (<err_var>: <error_type>) { panic("<file>:<line>:<col>", "<error_type>") }
// We construct the location string at lowering time as a LiteralStr,
// equivalent to what the parser does for __LOC__.

// Process a Body Expr in place: for each bang-stmt, clear the bang
// flag, push the (now ?-marked) stmt, then append a catch block
// per declared throw type of the callee. Recurses into nested
// if/while/for/switch arms.
// Issue #202 follow-up: hoist a bang FCall at parent.child(child_idx)
// out into a `_bang_ret_<n> := <call>?` Decl + catch blocks pushed
// into pre_stmts. Replaces parent.child(child_idx) with an Ident
// reference to the temp. Skips nested defs and Body children (those
// are handled by desugar_bang_in_body's recursion). Postorder so an
// inner `g(f()!)!` hoists f first, then g.

// Walk stmt's expression tree, hoisting every nested bang FCall into
// pre_stmts. The stmt-root bang (if any) is intentionally NOT hoisted
// -- the existing direct handler in desugar_bang_in_body produces a
// cleaner lowering (avoids an extra temp) for that shape.


// Append a fallback `return <default(return_type)>` to body for
// throwing functions whose original body relied on the error path
// to bypass the return statement. After lowering, the return is
// guarded by `if _err_kind == 0`; the C builder needs a literal
// return on the error path so all paths return.

// Issue #198 follow-up: rstil-parity validation for throw/catch.
//
// Walks a function body in source order, tracking the list of
// types currently "pending" (thrown but not yet caught). Catches
// remove matching entries; if no entry matches, emit an error.
// FCalls with does_throw=true pull their callee's declared throws
// into pending; does_throw=false on a throwing callee (or true on
// a non-throwing one) is also an error.
//
// At end-of-body the validator:
//   - errors on any leftover pending type that isn't in the
//     function's own throws clause
//   - errors on any declared throws entry that was never raised
//     (rstil's "declared but never thrown" diagnostic)

// Map the `array(...)` / `vec(...)` builtin ctor names to the struct
// type they produce, so a `x := vec(...)` local resolves to "Vec".
priv normalize_ctor_type := func(tn: Str) returns Str {
    if tn.eq("array") { return "Array" }
    if tn.eq("vec") { return "Vec" }
    return tn
}

// Type name of a struct field, "" if unknown.
priv struct_field_type := func(ctx: Context, type_name: Str, field_name: Str) returns Str {
    ref sdef : Expr = ctx.scope.get_struct(type_name)
    if sdef.is_null() { return "" }
    switch sdef.node_type {
    case NodeType.StructDef(sd):
        for fi in 0..sd.fields.len() {
            ref fd : Declaration = sd.fields[fi]
            if fd.name.eq(field_name) {
                if fd.explicit_type.len().gt(0) { return fd.explicit_type.clone() }
                tn := til_type_name(fd.til_type)
                if tn.len().gt(0) { return tn }
                // Field declared without an explicit type AND its
                // til_type hasn't been inferred yet (extend_throwing_func_sigs
                // runs before infer_body, so init expressions like
                // `payload_types := Map.new(I64, Str)` haven't been
                // typed). Guess from the default-value Expr: a bare
                // ctor FCall like `Map.new(...)` or `Vec.new(T)` lets
                // us read the type off the callee.
                ref dv : Expr = fd.default_value
                if dv.node_type.is(NodeType.FCall).and(dv.children.len().gt(0)) {
                    ref dv_callee : Expr = dv.child(0)
                    switch dv_callee.node_type {
                    case NodeType.FieldAccess:
                        if dv_callee.children.len().gt(0) {
                            switch dv_callee.child(0).node_type {
                            case NodeType.Ident(dv_recv): return dv_recv.ident_name()
                            case:
                            }
                        }
                    case NodeType.Ident(dv_id):
                        return normalize_ctor_type(dv_id.ident_name())
                    case:
                    }
                }
                return ""
            }
        }
    case:
    }
    return ""
}

// Best-effort type of a value expression for receiver resolution.
// Handles idents (params, body-local Decls, literals) and field-access
// chains (resolve the receiver, then look up the field's declared type
// in its struct). Returns "" when it can't be determined here.
priv resolve_value_type := func(ctx: Context, e: Expr, body: Expr) returns Str {
    switch e.node_type {
    case NodeType.Ident(idn):
        nm := idn.ident_name()
        if ctx.lowering_param_types.has(nm) {
            ref pt : Str = ctx.lowering_param_types[nm]
            return normalize_ctor_type(pt)
        }
        g := guess_local_type(body, nm)
        if g.len().gt(0) {
            ng := normalize_ctor_type(g)
            // guess_local_type can return the base receiver of an FCall
            // (eg. `files := uc.split(" ")` -> "uc"), which isn't a real
            // type. Only commit to ng if it names a known struct; let the
            // caller fall back to the suffix-match path otherwise.
            if ctx.scope.get_struct(ng).is_null().not() { return ng }
            // FCall form `mut x := some_func(...)` lands here with
            // ng == "some_func". If the name resolves to a function in
            // scope, return its declared return_type instead.
            ref fb : TypeBinding = ctx.scope.get_binding(ng)
            if fb.is_null().not() {
                if fb.func_def.is_null().not() {
                    switch fb.func_def.node_type {
                    case NodeType.FuncDef(fdef):
                        if fdef.return_type.len().gt(0) {
                            return normalize_ctor_type(fdef.return_type)
                        }
                    case:
                    }
                }
            }
            return ""
        }
        return ""
    case NodeType.FieldAccess(fn):
        if e.children.len().eq(0) { return "" }
        recv_t := resolve_value_type(ctx, e.child(0), body)
        if recv_t.len().eq(0) { return "" }
        return struct_field_type(ctx, recv_t, fn.field_access_name())
    case NodeType.Literal(Literal.Num): return "I64"
    case NodeType.Literal(Literal.Str): return "Str"
    case NodeType.Literal(Literal.Bool): return "Bool"
    case:
        return ""
    }
}

// Resolve the owning type name of a method-call FCall for the
// type-qualified throws lookup. Returns "" for a free-function call or
// an unresolvable receiver (method chains etc.). For the static
// `Type.method(...)` form the receiver Ident names the struct; for
// UFCS `recv.method(...)` the receiver is resolved by resolve_value_type.
priv callee_owning_type := func(ctx: Context, fcall: Expr, body: Expr) returns Str {
    if fcall.children.len().eq(0) { return "" }
    ref callee : Expr = fcall.child(0)
    switch callee.node_type {
    case NodeType.FieldAccess(_m):
        if callee.children.len().eq(0) { return "" }
        ref recv : Expr = callee.child(0)
        switch recv.node_type {
        case NodeType.Ident(rn):
            if ctx.scope.get_struct(rn.ident_name()).is_null().not() { return rn.ident_name() }
        case:
        }
        return resolve_value_type(ctx, recv, body)
    case:
        return ""
    }
}

priv registry_exact_idx := func(ctx: Context, key: Str) returns I64 {
    for i in 0..ctx.throws_names_global.len() {
        ref n : Str = ctx.throws_names_global[i]
        if n.eq(key) { return i.to_i64().add(1) }
    }
    return 0
}

// Fallback for an unresolvable receiver: match a registry entry whose
// key is bare `method` or any `Type.method`. Conservative (treats the
// call as throwing), preserving the pre-qualification behavior for
// method-chain / literal receivers whose type we can't resolve here.
priv registry_suffix_idx := func(ctx: Context, method: Str) returns I64 {
    dotted := ".".concat(method)
    for i in 0..ctx.throws_names_global.len() {
        ref n : Str = ctx.throws_names_global[i]
        if n.eq(method) { return i.to_i64().add(1) }
        if n.ends_with(dotted) { return i.to_i64().add(1) }
    }
    return 0
}

// Look up callee throws for an FCall. Free functions match by bare
// name; method calls resolve the receiver type and match the
// type-qualified "Type.method" key, falling back to a bare/suffix
// match when the receiver type can't be resolved. Returns the entry
// index (encoded +1) into throws_names_global, or 0 for not-found.
priv find_callee_throws_idx := func(ctx: Context, fcall: Expr, body: Expr) returns I64 {
    if fcall.children.len().eq(0) { return 0 }
    ref callee : Expr = fcall.child(0)
    switch callee.node_type {
    case NodeType.Ident(n):
        return registry_exact_idx(ctx, n.ident_name())
    case NodeType.FieldAccess(fname):
        method := fname.field_access_name()
        owner := callee_owning_type(ctx, fcall, body)
        if owner.len().gt(0) {
            return registry_exact_idx(ctx, owner.concat(".").concat(method))
        }
        // Unresolvable receiver: only treat as throwing if SOME type's
        // method by this name throws AND the user marked the call with
        // ?/!. Without a ?/! marker we treat it as non-throwing to avoid
        // false positives on the common Map.get / Vec.get-on-a-field
        // patterns whose receiver type we can't resolve pre-inference.
        mut marked := false
        switch fcall.node_type {
        case NodeType.FCall(fcd_m): marked = fcd_m.does_throw.or(fcd_m.is_bang)
        case:
        }
        if marked { return registry_suffix_idx(ctx, method) }
        return 0
    case:
        return 0
    }
}

// Matches rstil: a single catch consumes EVERY pending entry of
// that type, not just one. Returns true if at least one was found.
priv pending_remove_all_matching := func(mut pending: Vec, type_name: Str) returns Bool {
    mut found := false
    // Rebuild pending in place, dropping matches.
    mut write : USize = 0
    for i in 0..pending.len() {
        ref n : Str = pending[i]
        if n.eq(type_name) {
            found = true
        } else {
            if write.lt(i) {
                pending.set(write, own n.clone())
            }
            write = write.add(1)
        }
    }
    pending.count = write
    return found
}

priv vec_str_contains := func(v: Vec, name: Str) returns Bool {
    for i in 0..v.len() {
        ref n : Str = v[i]
        if n.eq(name) { return true }
    }
    return false
}

priv vec_str_push_uniq := func(mut v: Vec, name: Str) {
    if vec_str_contains(v, name) { return }
    v.push(own name.clone())
}





// ============================================================
// Issue #198/#202 follow-up: single per-body walk that does ALL
// throw/catch work (desugar bang + validate + lower throw/catch +
// inject err args + fallback return). #158 alignment: one walk
// per phase instead of the previous five separate walks.
// ============================================================

// Per-FCall validation: emits the ? / ! error diagnostics, auto-fixes
// the FCall flags so downstream stages don't trip on a half-shaped
// signature, and updates the body-level pending / seen /
// types_to_declare lists with the callee's declared throw types.
priv validate_one_fcall_consolidated := proc(
    ctx: Context,
    mut e: Expr,
    body: Expr,
    mut pending: Vec,
    mut seen: Vec,
    mut types_to_declare: Vec,
    path: Str
) {
    if e.node_type.is(NodeType.FCall).not() { return }
    mut does_throw := false
    mut is_bang_left := false
    switch e.node_type {
    case NodeType.FCall(fcd):
        does_throw = fcd.does_throw
        is_bang_left = fcd.is_bang
    case:
    }
    if is_bang_left {
        type_error_at(path, e.line, e.col, "function does not throw, remove the '!' after the call", ctx)
        switch e.node_type {
        case NodeType.FCall(fcd_clr_b):
            fcd_clr_b.is_bang = false
            fcd_clr_b.does_throw = false
        case:
        }
    }
    idx := find_callee_throws_idx(ctx, e, body)
    callee_is_throwing := idx.gt(0)
    if does_throw {
        if callee_is_throwing.not() {
            type_error_at(path, e.line, e.col, "function does not throw, remove the '?' after the call", ctx)
            switch e.node_type {
            case NodeType.FCall(fcd_fix): fcd_fix.does_throw = false
            case:
            }
        } else {
            ref tts : Vec = ctx.throws_per_global[idx.sub(1).to_u32()]
            for tn : Str in tts {
                pending.push(own tn.clone())
                vec_str_push_uniq(seen, tn)
                vec_str_push_uniq(types_to_declare, tn)
            }
        }
    } else {
        if callee_is_throwing {
            ref tts2 : Vec = ctx.throws_per_global[idx.sub(1).to_u32()]
            mut tlist := ""
            for jj in 0..tts2.len() {
                ref tn2 : Str = tts2[jj]
                if jj.gt(0) { tlist = tlist.concat(", ") }
                tlist = tlist.concat(tn2)
            }
            type_error_at(path, e.line, e.col, format("function throws ", tlist, ", missing '?' after the call"), ctx)
            switch e.node_type {
            case NodeType.FCall(fcd_fix2): fcd_fix2.does_throw = true
            case:
            }
            for tn3 : Str in tts2 {
                pending.push(own tn3.clone())
                vec_str_push_uniq(seen, tn3)
                vec_str_push_uniq(types_to_declare, tn3)
            }
        }
    }
}

// Per-FCall: if does_throw is set and the callee is in the global
// throws map, append _err_kind + _err_<T> arg refs, then clear the
// flag so the call reaches downstream stages as a plain FCall.
priv inject_err_args_on_one_fcall_consolidated := func(ctx: Context, mut e: Expr, body: Expr) {
    if e.node_type.is(NodeType.FCall).not() { return }
    mut does_throw := false
    switch e.node_type {
    case NodeType.FCall(fcd):
        does_throw = fcd.does_throw
    case:
    }
    if does_throw.not() { return }
    if e.children.len().eq(0) { return }
    idx_enc := find_callee_throws_idx(ctx, e, body)
    if idx_enc.eq(0) { return }
    ref tts : Vec = ctx.throws_per_global[idx_enc.sub(1).to_u32()]
    mut kind_id := Expr.new(ident_node("_err_kind"), e.line, e.col)
    kind_id.set_expr_til_type(Type.I64)
    e.add_child(own kind_id)
    for tn : Str in tts {
        mut slot_id := Expr.new(ident_node(err_slot_name(tn)), e.line, e.col)
        slot_id.set_expr_til_type(til_type_from_explicit_type(tn))
        e.add_child(own slot_id)
    }
    switch e.node_type {
    case NodeType.FCall(fcd_clr): fcd_clr.does_throw = false
    case:
    }
}

// Walk e's expression subtree applying validate + inject to each
// FCall. Skips nested bodies (NodeType.Body) and nested defs --
// those are handled by the body-level walk and the typer's per
// FuncDef visit, respectively.
priv validate_and_inject_expr_consolidated := proc(
    ctx: Context,
    mut e: Expr,
    body: Expr,
    mut pending: Vec,
    mut seen: Vec,
    mut types_to_declare: Vec,
    path: Str
) {
    if e.node_type.is(NodeType.FuncDef)
        .or(e.node_type.is(NodeType.StructDef))
        .or(e.node_type.is(NodeType.EnumDef)) { return }
    if e.node_type.is(NodeType.Body) { return }
    validate_one_fcall_consolidated(ctx, e, body, pending, seen, types_to_declare, path)
    inject_err_args_on_one_fcall_consolidated(ctx, e, body)
    for ci in 0..e.children.len() {
        ref mut sub : Expr = e.child(ci)
        validate_and_inject_expr_consolidated(ctx, sub, body, pending, seen, types_to_declare, path)
    }
}

// Build the already-lowered if-block for a bang catch directly --
// avoids an intermediate NodeType.Catch that would need a separate
// lowering pass to convert. Emits:
//   if I64.eq(_err_kind, <tag>) { _err_kind = 0; panic("<loc>", "<T>") }
priv build_bang_lowered := func(ctx: Context, error_type: Str, line: U32, col: U32) returns Expr {
    tag := tag_for_type(ctx, error_type, Vec.new(Str))
    loc_str := format(ctx.path, ":", line.to_str(), ":", col.to_str())
    mut panic_call := Expr.new(NodeType.FCall(FCallData()), line, col)
    panic_call.add_child(own Expr.new(ident_node("panic"), line, col))
    panic_call.add_child(own Expr.new(NodeType.Literal(Literal.Str(loc_str)), line, col))
    panic_call.add_child(own Expr.new(NodeType.Literal(Literal.Str(error_type.clone())), line, col))
    mut blk := Expr.new(NodeType.Body, line, col)
    blk.add_child(own make_assign_stmt("_err_kind", make_int_lit(0, line, col), line, col))
    blk.add_child(own panic_call)
    mut kind_id := Expr.new(ident_node("_err_kind"), line, col)
    mut tag_lit := make_int_lit(tag, line, col)
    mut cond := make_method_call_fcall(own kind_id, "eq", line, col)
    cond.add_child(own tag_lit)
    mut if_node := Expr.new(NodeType.If, line, col)
    if_node.add_child(own cond)
    if_node.add_child(own blk)
    return if_node
}

// Recursive hoister for bangs nested inside an expression. Pushes
// _bang_ret_<n> := <call>? Decl plus lowered if-block checks into
// pre_stmts and replaces the original bang FCall position with an
// Ident reference to the temp. Postorder so the innermost bang
// hoists first. Tracks the callee's throws on types_to_declare and
// seen so the function-body wrapper later prepends the right slot
// decls.
priv hoist_walk_consolidated := proc(
    mut ctx: Context,
    mut parent: Expr,
    child_idx: USize,
    body: Expr,
    mut pre_stmts: Vec,
    mut types_to_declare: Vec,
    mut seen: Vec
) {
    ref mut child : Expr = parent.child(child_idx)
    if child.node_type.is(NodeType.FuncDef)
        .or(child.node_type.is(NodeType.StructDef))
        .or(child.node_type.is(NodeType.EnumDef)) { return }
    if child.node_type.is(NodeType.Body) { return }
    for gi in 0..child.children.len() {
        hoist_walk_consolidated(ctx, child, gi, body, pre_stmts, types_to_declare, seen)
    }
    if child.node_type.is(NodeType.FCall).not() { return }
    mut is_bang_here := false
    switch child.node_type {
    case NodeType.FCall(fcd_check): is_bang_here = fcd_check.is_bang
    case:
    }
    if is_bang_here.not() { return }
    if child.children.len().eq(0) { return }
    found_idx := find_callee_throws_idx(ctx, child, body)
    if found_idx.eq(0) { return }
    line := child.line
    col := child.col
    tmp_name := format("_bang_ret_", ctx.bang_counter.to_str())
    ctx.bang_counter = ctx.bang_counter.add(1)
    mut cloned := child.clone()
    clear_bang_flag(cloned)
    // The hoisted call won't pass through the main loop's per-stmt
    // validate+inject step (pre_stmts go straight into new_ch), so
    // inject err out-args here directly.
    inject_err_args_on_one_fcall_consolidated(ctx, cloned, body)
    mut tmp_decl := Expr.new(NodeType.Decl(Declaration(name = tmp_name.clone())), line, col)
    tmp_decl.add_child(own cloned)
    pre_stmts.push(own tmp_decl)
    ref tts : Vec = ctx.throws_per_global[found_idx.sub(1).to_u32()]
    for tn : Str in tts {
        vec_str_push_uniq(types_to_declare, tn)
        vec_str_push_uniq(seen, tn)
        pre_stmts.push(own build_bang_lowered(ctx, tn, line, col))
    }
    parent.children.replace(child_idx, own Expr.new(ident_node(tmp_name), line, col))
}

// Walk stmt's expression tree hoisting nested bangs (not the
// stmt-root bang). The stmt-root bang shape is handled by the
// main per-stmt logic in process_throw_catch_in_body so it
// produces cleaner output without an extra temp.
priv hoist_nested_bangs_consolidated := proc(
    mut ctx: Context,
    mut stmt: Expr,
    body: Expr,
    mut pre_stmts: Vec,
    mut types_to_declare: Vec,
    mut seen: Vec
) {
    cname := find_bang_callee_name(stmt)
    if cname.len().eq(0) {
        for ci in 0..stmt.children.len() {
            hoist_walk_consolidated(ctx, stmt, ci, body, pre_stmts, types_to_declare, seen)
        }
        return
    }
    if stmt.node_type.is(NodeType.FCall) {
        for ai in 1..stmt.children.len() {
            hoist_walk_consolidated(ctx, stmt, ai, body, pre_stmts, types_to_declare, seen)
        }
        return
    }
    ref mut root_fcall : Expr = stmt.child(0)
    if root_fcall.node_type.is(NodeType.FCall) {
        for ai in 1..root_fcall.children.len() {
            hoist_walk_consolidated(ctx, root_fcall, ai, body, pre_stmts, types_to_declare, seen)
        }
    }
    for ci in 1..stmt.children.len() {
        hoist_walk_consolidated(ctx, stmt, ci, body, pre_stmts, types_to_declare, seen)
    }
}

// Single per-body walk performing all throw/catch work:
//   1. hoist nested bangs (Decl + lowered if-blocks before stmt)
//   2. recurse into nested bodies (if/while/for/switch/catch arms)
//   3. clear the stmt-root bang flag (so the call below sees does_throw)
//   4. validate + inject err args on FCalls in stmt's tree
//      (skipping nested bodies, which already happened in step 2)
//   5. rewrite Throw  -> _err_<T> = expr ; _err_kind = tag
//   6. rewrite Catch  -> if I64.eq(_err_kind, tag) { _err_kind = 0; body }
//   7. append lowered bang checks for stmt-root bang; for
//      `return f()!` hoist the call into a tmp first so the checks
//      execute before the return
//   8. wrap stmt in `if I64.eq(_err_kind, 0)` when a previous stmt
//      could have set _err_kind
priv process_throw_catch_in_body := proc(
    mut ctx: Context,
    mut body: Expr,
    root_body: Expr,
    fdef_throws: Vec,
    mut pending: Vec,
    mut seen: Vec,
    mut types_to_declare: Vec,
    path: Str,
    return_type: Str,
    return_own_type: OwnType
) {
    if body.node_type.is(NodeType.Body).not() { return }
    if body.children.len().eq(0) { return }

    mut old := Vec.new(Expr)
    old.move_from(body.children)
    mut old_snapshot : Vec = old.clone()
    mut new_ch := Vec.new(Expr)
    mut seen_throwing := false

    for j in 0..old.len() {
        ref mut stmt : Expr = old[j]
        stmt_line := stmt.line
        stmt_col := stmt.col

        // Skip nested Decls whose RHS is a FuncDef/StructDef/EnumDef.
        // Those bodies get processed when the typer visits them.
        mut is_nested_def := false
        if stmt.node_type.is(NodeType.Decl) {
            if stmt.children.len().gt(0) {
                ref dr : Expr = stmt.child(0)
                if dr.node_type.is(NodeType.FuncDef)
                    .or(dr.node_type.is(NodeType.StructDef))
                    .or(dr.node_type.is(NodeType.EnumDef)) {
                    is_nested_def = true
                }
            }
        }
        if is_nested_def {
            new_ch.push_take(old, j)
            continue
        }

        // Capture pre-rewrite "could this leave _err_kind set?" for the
        // next stmt's wrap decision. Bangs don't count -- they panic and
        // reset on the error path (see subtree_has_pending_throw).
        had_throw_subtree := subtree_has_pending_throw(stmt)

        // 1. Hoist nested bangs in stmt's expression tree.
        mut pre_stmts := Vec.new(Expr)
        hoist_nested_bangs_consolidated(ctx, stmt, root_body, pre_stmts, types_to_declare, seen)
        npre := pre_stmts.len()
        for pi in 0..npre {
            new_ch.push_take(pre_stmts, pi)
        }

        // 2. Recurse into nested bodies (if / while / for / switch / catch arms).
        switch stmt.node_type {
        case NodeType.If:
            for ci in 1..stmt.children.len() {
                ref mut sub : Expr = stmt.child(ci)
                if sub.node_type.is(NodeType.Body) {
                    process_throw_catch_in_body(ctx, sub, root_body, fdef_throws, pending, seen, types_to_declare, path, return_type, return_own_type)
                }
            }
        case NodeType.While:
            if stmt.children.len().gte(2) {
                ref mut wb : Expr = stmt.child(1)
                process_throw_catch_in_body(ctx, wb, root_body, fdef_throws, pending, seen, types_to_declare, path, return_type, return_own_type)
            }
        case NodeType.ForIn:
            if stmt.children.len().gte(2) {
                ref mut fb : Expr = stmt.child(1)
                process_throw_catch_in_body(ctx, fb, root_body, fdef_throws, pending, seen, types_to_declare, path, return_type, return_own_type)
            }
        case NodeType.Switch:
            for ci in 1..stmt.children.len() {
                ref mut cn : Expr = stmt.child(ci)
                if cn.node_type.is(NodeType.Case) {
                    for cci in 0..cn.children.len() {
                        ref mut ccn : Expr = cn.child(cci)
                        if ccn.node_type.is(NodeType.Body) {
                            process_throw_catch_in_body(ctx, ccn, root_body, fdef_throws, pending, seen, types_to_declare, path, return_type, return_own_type)
                        }
                    }
                }
            }
        case NodeType.Catch:
            if stmt.children.len().eq(3) {
                ref mut cbody : Expr = stmt.child(2)
                process_throw_catch_in_body(ctx, cbody, root_body, fdef_throws, pending, seen, types_to_declare, path, return_type, return_own_type)
            }
        case:
        }

        // 3. Detect a stmt-root bang and clear the flag so step 4 sees
        // does_throw on the FCall. Bang-call-to-unknown is left in
        // place for step 4 to surface "function does not throw" via
        // validate_one_fcall_consolidated.
        ref bang_fc : Expr = find_bang_fcall(stmt)
        mut root_bang_throws := Vec.new(Str)
        if bang_fc.is_null().not() {
            found_idx_root := find_callee_throws_idx(ctx, bang_fc, root_body)
            if found_idx_root.gt(0) {
                ref tts_root : Vec = ctx.throws_per_global[found_idx_root.sub(1).to_u32()]
                for tn : Str in tts_root {
                    root_bang_throws.push(own tn.clone())
                    vec_str_push_uniq(types_to_declare, tn)
                    vec_str_push_uniq(seen, tn)
                }
                clear_bang_flag(stmt)
            }
        }

        // 4. Validate + inject err args on FCalls in stmt's tree.
        // Different stmt kinds expose their expressions in different
        // positions; recurse only into the expression slots and not
        // into nested bodies (which step 2 already covered).
        switch stmt.node_type {
        case NodeType.Decl:
            for ci in 0..stmt.children.len() {
                ref mut sub : Expr = stmt.child(ci)
                validate_and_inject_expr_consolidated(ctx, sub, root_body, pending, seen, types_to_declare, path)
            }
        case NodeType.Assign:
            for ci in 0..stmt.children.len() {
                ref mut sub : Expr = stmt.child(ci)
                validate_and_inject_expr_consolidated(ctx, sub, root_body, pending, seen, types_to_declare, path)
            }
        case NodeType.FieldAssign:
            for ci in 0..stmt.children.len() {
                ref mut sub : Expr = stmt.child(ci)
                validate_and_inject_expr_consolidated(ctx, sub, root_body, pending, seen, types_to_declare, path)
            }
        case NodeType.Return:
            if stmt.children.len().gt(0) {
                ref mut sub : Expr = stmt.child(0)
                validate_and_inject_expr_consolidated(ctx, sub, root_body, pending, seen, types_to_declare, path)
            }
        case NodeType.FCall:
            validate_and_inject_expr_consolidated(ctx, stmt, root_body, pending, seen, types_to_declare, path)
        case NodeType.If:
            if stmt.children.len().gt(0) {
                ref mut sub : Expr = stmt.child(0)
                validate_and_inject_expr_consolidated(ctx, sub, root_body, pending, seen, types_to_declare, path)
            }
        case NodeType.While:
            if stmt.children.len().gt(0) {
                ref mut sub : Expr = stmt.child(0)
                validate_and_inject_expr_consolidated(ctx, sub, root_body, pending, seen, types_to_declare, path)
            }
        case NodeType.ForIn:
            if stmt.children.len().gt(0) {
                ref mut sub : Expr = stmt.child(0)
                validate_and_inject_expr_consolidated(ctx, sub, root_body, pending, seen, types_to_declare, path)
            }
        case NodeType.Switch:
            if stmt.children.len().gt(0) {
                ref mut sub : Expr = stmt.child(0)
                validate_and_inject_expr_consolidated(ctx, sub, root_body, pending, seen, types_to_declare, path)
            }
            for ci in 1..stmt.children.len() {
                ref mut cn : Expr = stmt.child(ci)
                if cn.node_type.is(NodeType.Case) {
                    for cci in 0..cn.children.len() {
                        ref mut ccn : Expr = cn.child(cci)
                        if ccn.node_type.is(NodeType.Body).not() {
                            validate_and_inject_expr_consolidated(ctx, ccn, root_body, pending, seen, types_to_declare, path)
                        }
                    }
                }
            }
        case NodeType.Throw:
            if stmt.children.len().gt(0) {
                ref mut sub : Expr = stmt.child(0)
                validate_and_inject_expr_consolidated(ctx, sub, root_body, pending, seen, types_to_declare, path)
            }
        case:
            for ci in 0..stmt.children.len() {
                ref mut sub : Expr = stmt.child(ci)
                validate_and_inject_expr_consolidated(ctx, sub, root_body, pending, seen, types_to_declare, path)
            }
        }

        // 5. Rewrite Throw -> two assigns.
        if stmt.node_type.is(NodeType.Throw) {
            if stmt.children.len().eq(1) {
                throw_t := stmt.expr_til_type()
                mut tn := ""
                if throw_t.is(Type.Unknown).not().and(throw_t.is(Type.None).not()) {
                    tn = type_to_name(throw_t)
                }
                if tn.len().eq(0) {
                    tn = throw_type_name_for_with_body(stmt.child(0), root_body)
                }
                switch stmt.child(0).node_type {
                case NodeType.Ident(idn):
                    mut scan := j
                    while true {
                        ref prior_stmt : Expr = old_snapshot[scan]
                        if prior_stmt.node_type.is(NodeType.Decl) {
                            switch prior_stmt.node_type {
                            case NodeType.Decl(dd):
                                if dd.name.eq(idn.name) {
                                    if dd.explicit_type.len().gt(0) {
                                        tn = dd.explicit_type.clone()
                                    } else if prior_stmt.children.len().gt(0) {
                                        switch prior_stmt.child(0).node_type {
                                        case NodeType.FCall:
                                            if prior_stmt.child(0).children.len().gt(0) {
                                                switch prior_stmt.child(0).child(0).node_type {
                                                case NodeType.Ident(rhsn): tn = rhsn.ident_name()
                                                case NodeType.FieldAccess(_rhsfa2):
                                                    if prior_stmt.child(0).child(0).children.len().gt(0) {
                                                        switch prior_stmt.child(0).child(0).child(0).node_type {
                                                        case NodeType.Ident(rhsty2): tn = rhsty2.ident_name()
                                                        case:
                                                        }
                                                    }
                                                case:
                                                }
                                            }
                                        case NodeType.Literal(Literal.Str):
                                            tn = "Str"
                                        case NodeType.Literal(Literal.Num):
                                            tn = "I64"
                                        case:
                                        }
                                    }
                                }
                            case:
                            }
                        }
                        if tn.len().gt(0).or(scan.eq(0)) { break }
                        scan = scan.sub(1)
                    }
                    if tn.len().gt(0) {
                        register_throw_type(ctx, tn)
                        tag_direct := tag_for_type(ctx, tn, Vec.new(Str))
                        if tag_direct.gt(0) {
                            new_ch.push(own make_assign_stmt(err_slot_name(tn), stmt.child(0), stmt_line, stmt_col))
                            new_ch.push(own make_assign_stmt("_err_kind", make_int_lit(tag_direct, stmt_line, stmt_col), stmt_line, stmt_col))
                            vec_str_push_uniq(types_to_declare, tn)
                            vec_str_push_uniq(seen, tn)
                            pending.push(own tn.clone())
                            seen_throwing = true
                            continue
                        }
                    }
                    ctx.throw_used_local_names.add(own idn.name.clone())
                    mut scan_decl : I32 = new_ch.len().cast(I32)
                    if scan_decl.gt(0) {
                        scan_decl = scan_decl.sub(1)
                    }
                    while scan_decl.gte(0) {
                        ref prior_stmt : Expr = new_ch[scan_decl.cast(U32)]
                        switch prior_stmt.node_type {
                        case NodeType.Decl(prior_dd):
                            if prior_dd.name.eq(idn.name.clone()) {
                                prior_dd.used = true
                                if tn.len().eq(0) {
                                    if prior_dd.explicit_type.len().gt(0) {
                                        tn = prior_dd.explicit_type.clone()
                                    } else if prior_stmt.children.len().gt(0) {
                                        ref prior_rhs : Expr = prior_stmt.child(0)
                                        switch prior_rhs.node_type {
                                        case NodeType.FCall:
                                            if prior_rhs.children.len().gt(0) {
                                                switch prior_rhs.child(0).node_type {
                                                case NodeType.Ident(rhsn): tn = rhsn.name.clone()
                                                case:
                                                }
                                            }
                                        case NodeType.Literal(Literal.Str): tn = "Str"
                                        case NodeType.Literal(Literal.Num): tn = "I64"
                                        case:
                                        }
                                    }
                                }
                                scan_decl = -1
                                continue
                            }
                        case:
                        }
                        if scan_decl.eq(0) { break }
                        scan_decl = scan_decl.sub(1)
                    }
                    for nui in 0..new_ch.len() {
                        ref mut nstmt : Expr = new_ch[nui]
                        switch nstmt.node_type {
                        case NodeType.Decl(ndd):
                            if ndd.name.eq(idn.name.clone()) { ndd.used = true }
                        case:
                        }
                    }
                    if tn.len().eq(0) {
                        tn = guess_local_type(root_body, idn.name)
                    }
                case:
                }
                if tn.len().eq(0) {
                    switch stmt.child(0).node_type {
                    case NodeType.Ident(idn):
                        tn = guess_prior_local_type_in_vec(old_snapshot, j, idn.name)
                    case:
                    }
                }
                if tn.len().gt(0) { register_throw_type(ctx, tn) }
                tag := tag_for_type(ctx, tn, Vec.new(Str))
                if tn.len().gt(0).and(tag.gt(0)) {
                    new_ch.push(own make_assign_stmt(err_slot_name(tn), stmt.child(0), stmt_line, stmt_col))
                    new_ch.push(own make_assign_stmt("_err_kind", make_int_lit(tag, stmt_line, stmt_col), stmt_line, stmt_col))
                    vec_str_push_uniq(types_to_declare, tn)
                    vec_str_push_uniq(seen, tn)
                    pending.push(own tn.clone())
                    seen_throwing = true
                    continue
                }
            }
            new_ch.push_take(old, j)
            if had_throw_subtree { seen_throwing = true }
            continue
        }

        // 6. Rewrite Catch -> if-block.
        if stmt.node_type.is(NodeType.Catch) {
            if stmt.children.len().eq(3) {
                mut ctype := ""
                switch stmt.child(1).node_type {
                case NodeType.Ident(n): ctype = n.ident_name()
                case:
                }
                if ctype.len().gt(0) {
                    mut matched := pending_remove_all_matching(pending, ctype)
                    if matched.not().and(has_prior_throw_type_in_vec(old_snapshot, root_body, j, ctype)) {
                        matched = true
                    }
                    if matched.not() {
                        type_error_at(path, stmt_line, stmt_col,
                            format("trying to catch '", ctype, "', but it is not among the thrown types"), ctx)
                    }
                    vec_str_push_uniq(types_to_declare, ctype)
                }
                new_ch.push(own lower_catch_node(ctx, stmt, Vec.new(Str)))
                seen_throwing = false
                continue
            } else {
                type_error_at(path, stmt_line, stmt_col, "catch must have 3 parameters: variable, type, and body", ctx)
                new_ch.push_take(old, j)
                continue
            }
        }

        // 7. Stmt-root bang: emit the (?-call) stmt then lowered checks.
        // For `return f()!`, hoist into a temp so checks run BEFORE the
        // return (otherwise unreachable).
        if root_bang_throws.len().gt(0) {
            if stmt.node_type.is(NodeType.Return) {
                tmp_name := format("_bang_ret_", ctx.bang_counter.to_str())
                ctx.bang_counter = ctx.bang_counter.add(1)
                // Carry the function's declared return type/ownership onto
                // the hoisted temp Decl. Vec.get / Array.get return
                // ref Dynamic; without an explicit type the temp Decl
                // errors with "cannot store Dynamic". The return position's
                // expected type is the function's return_type, so use it.
                mut tmp_decl_data := Declaration(name = tmp_name.clone())
                if return_type.len().gt(0) {
                    tmp_decl_data.explicit_type = return_type.clone()
                    tmp_decl_data.til_type = til_type_from_explicit_type(return_type)
                    // Locals are owned by default; only mark Ref-returning
                    // funcs as ref so we don't trip the "no need for 'own'"
                    // diagnostic on the synthesized temp.
                    if return_own_type.is(OwnType.Ref) {
                        tmp_decl_data.own_type = return_own_type
                    }
                }
                mut tmp_decl := Expr.new(NodeType.Decl(tmp_decl_data), stmt_line, stmt_col)
                tmp_decl.add_child(own stmt.child(0).clone())
                new_ch.push(own tmp_decl)
                for tn : Str in root_bang_throws {
                    new_ch.push(own build_bang_lowered(ctx, tn, stmt_line, stmt_col))
                    _matched_b1 := pending_remove_all_matching(pending, tn)
                }
                mut new_ret := Expr.new(NodeType.Return, stmt_line, stmt_col)
                new_ret.add_child(own Expr.new(ident_node(tmp_name), stmt_line, stmt_col))
                new_ch.push(own new_ret)
                // The lowered bang checks both panic AND reset
                // _err_kind = 0 on the error path, so subsequent
                // stmts don't need wrapping.
                seen_throwing = false
                continue
            }
            if seen_throwing {
                mut wrapped := make_if_kind_eq_zero_wrap(stmt, stmt_line, stmt_col)
                new_ch.push(own wrapped)
            } else {
                new_ch.push_take(old, j)
            }
            for tn : Str in root_bang_throws {
                new_ch.push(own build_bang_lowered(ctx, tn, stmt_line, stmt_col))
                _matched_b2 := pending_remove_all_matching(pending, tn)
            }
            seen_throwing = false
            continue
        }

        // 8. Generic stmt: push (possibly wrapped in if-guard).
        if seen_throwing {
            mut wrapped := make_if_kind_eq_zero_wrap(stmt, stmt_line, stmt_col)
            new_ch.push(own wrapped)
        } else {
            new_ch.push_take(old, j)
        }
        if had_throw_subtree { seen_throwing = true }
    }

    body.children.move_from(new_ch)
    Vec.delete(own new_ch, true)
    Vec.delete(own old, true)
    Vec.delete(own old_snapshot, true)
}

// Function-body wrapper for the single-walk consolidated processing.
// Runs the per-body walk, then prepends slot decls for any throw
// types touched and (for throwing functions) appends a fallback
// return so all C paths return.
process_throw_catch_in_func_body := proc(
    mut ctx: Context,
    mut body: Expr,
    fdef_throws: Vec,
    return_type: Str,
    return_own_type: OwnType
) {
    has_body_throw_catch := subtree_has_throw_catch(body)
    has_fdef_throws := fdef_throws.len().gt(0)
    has_body_bang := subtree_has_bang(body)
    if has_body_throw_catch.not()
        .and(has_fdef_throws.not())
        .and(has_body_bang.not()) { return }

    // Pre-pass: annotate every Throw with its resolved type so the
    // body walk can read stmt.expr_til_type() directly during rewriting.
    if has_body_throw_catch { annotate_throw_types_in(body, body) }
    if has_body_throw_catch { annotate_throw_ident_expr_types(body, body) }

    mut pending := Vec.new(Str)
    mut seen := Vec.new(Str)
    mut types_to_declare := Vec.new(Str)
    ctx.throw_used_local_names = Set.new(Str)
    collect_throw_ident_names(body, ctx.throw_used_local_names)
    // Seed with declared throws so the slots exist as params even
    // when the body never references the type directly (rare, but
    // possible if a function declares `throws T` and reraises via
    // a ?-call that propagates without ever naming T literally).
    for ft : Str in fdef_throws {
        vec_str_push_uniq(types_to_declare, ft)
    }

    mut root_body := body.clone()
    process_throw_catch_in_body(ctx, body, root_body, fdef_throws, pending, seen, types_to_declare, ctx.path, return_type, return_own_type)

    // Final body-level validation: leftover pending types must be
    // declared, and every declared throws entry must have been seen.
    for tn : Str in pending {
        if vec_str_contains(fdef_throws, tn).not() {
            type_error_at(ctx.path, body.line, body.col,
                format("function may throw '", tn, "' but it is not in the throws clause; declare 'throws ", tn, "' or catch it"), ctx)
        }
    }
    for dt : Str in fdef_throws {
        if vec_str_contains(seen, dt).not() {
            type_error_at(ctx.path, body.line, body.col,
                format("'throws ", dt, "' is declared but '", dt, "' is never thrown -- remove it from the throws clause"), ctx)
        }
    }

    if types_to_declare.len().eq(0) { return }

    // Prepend slot decls and append fallback return.
    line := body.line
    col := body.col
    mut old := Vec.new(Expr)
    old.move_from(body.children)
    mut new_ch := Vec.new(Expr)

    if has_fdef_throws.not() {
        new_ch.push(own make_typed_mut_decl("_err_kind", "I64",
            make_int_lit(0, line, col), line, col))
    }
    for i in 0..types_to_declare.len() {
        ref tn : Str = types_to_declare[i]
        mut is_param := false
        for ft : Str in fdef_throws {
            if ft.eq(tn) { is_param = true }
        }
        if is_param.not() {
            new_ch.push(own make_typed_mut_decl(err_slot_name(tn), tn,
                make_default_value_expr(tn, line, col), line, col))
        }
    }
    for j in 0..old.len() {
        new_ch.push_take(old, j)
    }
    // Append a fallback return so every C path returns. Ref-returning
    // throwing fns get `return null` (no constructible borrow exists);
    // check_ref_function_returns allows that null since it is unreachable
    // on the success path and unused on the error path (the err code
    // flows out through the out-param).
    if has_fdef_throws.and(return_type.len().gt(0)) {
        mut ret := Expr.new(NodeType.Return, line, col)
        if return_own_type.is(OwnType.Ref) {
            ret.add_child(own Expr.new(NodeType.Literal(Literal.Null), line, col))
        } else {
            ret.add_child(own make_default_value_expr(return_type, line, col))
        }
        new_ch.push(own ret)
    }
    body.children.move_from(new_ch)
    Vec.delete(own new_ch, true)
    Vec.delete(own old, true)
}

is_compile_directive := func(e: Expr) returns Bool {
    if e.node_type.is(NodeType.FCall).not() { return false }
    if e.children.len().lt(1) { return false }
    switch e.child(0).node_type {
    case NodeType.Ident(name):
        name_str := name.ident_name()
        return name_str.eq("link").or(name_str.eq("link_c")).or(name_str.eq("import"))
    case:
        return false
    }
}

infer_body_stmt := proc(scope: TypeScope, mut body: Expr, mut i: U32, in_func: I32, in_loop: I32, returns_ref: I32, in_type_body: I32, ctx: Context) {
    ref mut stmt : Expr = body.child(i)
    if is_compile_directive(stmt) { stmt.set_expr_til_type(Type.None); return }
    switch stmt.node_type {
    case NodeType.Decl:
        infer_decl_stmt(scope, stmt, in_func, in_type_body, ctx)
    case NodeType.Assign:
        infer_assign_stmt(scope, stmt, in_func, ctx)
    case NodeType.FieldAssign:
        infer_field_assign_stmt(scope, stmt, in_func, ctx)
    case NodeType.FCall:
        infer_expr(scope, stmt, in_func, ctx)
    case NodeType.Return:
        infer_return_stmt(scope, stmt, in_func, returns_ref, ctx)
    case NodeType.Break:
        if in_loop.eq(0) {
            stmt.type_error("break outside loop", ctx)
        }
        stmt.set_expr_til_type(Type.None)
    case NodeType.Continue:
        if in_loop.eq(0) {
            stmt.type_error("continue outside loop", ctx)
        }
        stmt.set_expr_til_type(Type.None)
    case NodeType.If:
        infer_if_stmt(scope, stmt, in_func, in_loop, returns_ref, ctx)
    case NodeType.Body:
        block_scope := TypeScope(parent = scope)
        infer_body(block_scope, stmt, in_func, 1, in_loop, returns_ref, 0, ctx)
        garbager_destroy_body(ctx, stmt, block_scope)
        check_unused_locals(block_scope, ctx.path, ctx)
        TypeScope.delete(own block_scope)
    case NodeType.While:
        infer_while_stmt(scope, stmt, in_func, returns_ref, ctx)
    case NodeType.Switch:
        infer_switch_stmt(scope, body, i, in_func, ctx)
        i = i.sub(1)
    case NodeType.ForIn:
        if desugar_for_in_range_stmt(scope, body, i, in_func, ctx) {
            i = i.sub(1)
        } else if desugar_for_in_collection_stmt(scope, body, i, in_func, ctx) {
            i = i.sub(1)
        }
    case NodeType.Throw:
        // Issue #198 step 5a: minimal dispatch -- type-check the
        // thrown expression so it isn't silently skipped. Validation
        // (throws-set tracking) and lowering land in later steps.
        if stmt.children.len().eq(1) {
            infer_expr(scope, stmt.child(0), in_func, ctx)
        } else {
            stmt.type_error("throw must have exactly one parameter", ctx)
        }
        stmt.set_expr_til_type(Type.None)
    case NodeType.Catch:
        // Issue #198 step 5a: minimal dispatch -- type-check the
        // catch body in a child scope. The err variable binding and
        // throws-set matching land in the validation step. Body
        // statements need infer_body so var refs etc. resolve.
        if stmt.children.len().eq(3) {
            ref body_expr : Expr = stmt.child(2)
            catch_scope := TypeScope(parent = scope)
            infer_body(catch_scope, body_expr, in_func, 1, in_loop, returns_ref, 0, ctx)
            garbager_destroy_body(ctx, body_expr, catch_scope)
            check_unused_locals(catch_scope, ctx.path, ctx)
            TypeScope.delete(own catch_scope)
        } else {
            stmt.type_error("catch must have 3 children: var, type, body", ctx)
        }
        stmt.set_expr_til_type(Type.None)
    case:
        stmt.set_expr_til_type(Type.None)
    }
}

reregister_scope_defs := func(body: Expr, scope: TypeScope) {
    for rstmt : Expr in body.children {
        if rstmt.children.len().eq(0) { continue }
        switch rstmt.node_type {
        case NodeType.Decl(rdecl):
            ref mut rb : TypeBinding = scope.get_binding(rdecl.name)
            if rb.is_null().not() {
                if rb.struct_def.is_null().not().and(
                    rstmt.child(0).node_type.is(NodeType.StructDef).or(rstmt.child(0).node_type.is(NodeType.EnumDef))) {
                        ref old_sd : Expr = rb.struct_def
                        rb.struct_def = rstmt.child(0)
                        for bi in 0..scope.bindings.len() {
                            ref mut b : TypeBinding = Map.val_ptr(scope.bindings, bi)
                            if b.ptr_eq(rb).not().and(b.struct_def.ptr_eq(old_sd)) {
                                b.struct_def = rstmt.child(0)
                            }
                        }
                    }
                if rb.func_def.is_null().not().and(rstmt.child(0).node_type.is(NodeType.FuncDef)) {
                    ref old_fd : Expr = rb.func_def
                    rb.func_def = rstmt.child(0)
                    for bi in 0..scope.bindings.len() {
                        ref mut b : TypeBinding = Map.val_ptr(scope.bindings, bi)
                        if b.ptr_eq(rb).not().and(b.func_def.ptr_eq(old_fd)) {
                            b.func_def = rstmt.child(0)
                        }
                    }
                }
                if rb.alias_target.is_empty().not() {
                    switch rstmt.child(0).node_type {
                    case NodeType.Ident(target_name):
                        // Refresh just this alias's target. We deliberately
                        // do NOT broadcast to other bindings whose
                        // alias_target string happened to match the old
                        // value -- two unrelated aliases can share a target
                        // (e.g. `A := Dynamic` and `B := Dynamic`), and
                        // rewriting them in lockstep here created
                        // self-referential chains (`ffi_raw := Dynamic`
                        // followed by `ffi_java_raw := ffi_raw` used to
                        // leave ffi_raw.alias_target = "ffi_raw", and
                        // type_from_name would loop until stack overflow).
                        // The struct/func re-binding above is fine because
                        // it pivots on ptr_eq of the old Expr.
                        rb.alias_target = target_name.ident_name()
                    case:
                    }
                }
            }
        case:
        }
    }
}

// Type-inference walk for a single body. Issue #204 step 3a: this
// proc no longer runs the asap-destruction pass; the scope-management
// sites that call infer_body invoke garbager_destroy_body(body, scope)
// themselves before tearing the scope down.
infer_body := proc(scope: TypeScope, mut body: Expr, in_func: I32, owns_scope: I32, in_loop: I32, returns_ref: I32, in_type_body: I32, ctx: Context) {
    body.set_expr_til_type(Type.None)
    mut i : U32 = 0
    while i.lt(body.children.len()) {
        if scope.parent.is_null().and(in_func.eq(0)).and(in_type_body.eq(0)) {
            context_set_mode_from_path(ctx, ctx.path)
        }
        infer_body_stmt(scope, body, i, in_func, in_loop, returns_ref, in_type_body, ctx)
        i++
    }
    if body_pre_passes(ctx, body, scope, owns_scope) {
        reregister_scope_defs(body, scope)
    }
}

infer_body_unit := proc(scope: TypeScope, mut body: Expr, in_func: I32, owns_scope: I32, in_loop: I32, returns_ref: I32, in_type_body: I32, ctx: Context) {
    body.set_expr_til_type(Type.None)
    mut i : U32 = 0
    while i.lt(body.children.len()) {
        infer_body_stmt(scope, body, i, in_func, in_loop, returns_ref, in_type_body, ctx)
        // Issue #158: record foldable macro/func names as we walk the final
        // top-level decls (lambdas already lifted, methods already generated),
        // so precomp reuses ctx.precomp_macros/funcs instead of re-scanning.
        precomp_classify_stmt(body.child(i), ctx)
        i++
    }
    if body_pre_passes(ctx, body, scope, owns_scope) {
        reregister_scope_defs(body, scope)
    }
}

// Type-check a single file unit. Caller must have registered a mode for path.
// #165 step 1: post-init normalization sweep.
//
// Initer's registration helpers store user-defined-type names as
// ~Type.Custom(name)~ via the scope-free ~til_type_from_explicit_type~,
// so they don't have to read scope. This sweep -- run after every file's
// init has completed but before type_check -- walks the global bindings
// and replaces ~Custom(name)~ with ~Struct(name)~ or ~Enum(name)~ when
// the name resolves to a real struct/enum. Bindings whose type does
// not resolve are left as ~Custom~ and surface as undefined-symbol
// errors during type_check (same as today).
normalize_scope_bindings := func(scope: TypeScope) {
    for bi in 0..scope.bindings.len() {
        ref mut b : TypeBinding = Map.val_ptr(scope.bindings, bi)
        switch b.type {
        case Type.Custom(name):
            ref alias_b : TypeBinding = scope.get_binding(name)
            if alias_b.is_null().not() {
                if alias_b.is_type_alias {
                    if alias_b.type.is(Type.Custom).not() {
                        b.type = alias_b.type.clone()
                        continue
                    }
                }
            }
            ref sdef : Expr = scope.get_struct(name)
            if sdef.is_null() { continue }
            if sdef.node_type.is(NodeType.EnumDef) {
                b.type = Type.Enum(name.clone())
            } else {
                b.type = Type.Struct(name.clone())
            }
        case:
        }
    }
}

// --- Lambda lifting -----------------------------------------------------
//
// Anonymous `func(...) {...}` literals in expression positions (FCall
// args, NamedArg values, struct field defaults, etc.) are lifted out to
// the program top level as `_lambda_<N> := func(...) {...}` priv decls
// before the typer's main body walk. The original spot in the AST is
// replaced with an `Ident("_lambda_N")` reference; the typer then types
// the lifted decl as an ordinary named function.
//
// This used to live in a separate pre-typer transform file.
// Moved into the typer module so the parser stays dumb and the lift
// happens during the typer phase rather than as its own #158 pass.

priv typer_is_lambda_target := func(e: Expr) returns Bool {
    if e.is_null() { return false }
    if e.node_type.is(NodeType.FuncDef).not() { return false }
    if e.children.len().eq(0) { return false }
    return true
}

priv typer_lift_one_default_value := proc(mut dd: Declaration, mut top_level: Vec, mut counter: I64) returns I64 {
    if dd.default_value.is_null() { return counter }
    if typer_is_lambda_target(dd.default_value) {
        counter = typer_lift_lambdas_in_expr(dd.default_value, top_level, counter)
        lname := format("_lambda_", counter.to_str())
        counter = counter.add(1)
        mut decl := Expr.new(NodeType.Decl(Declaration(name = lname.clone(), is_priv = true)), dd.default_value.line, dd.default_value.col)
        decl.add_child(own dd.default_value.clone())
        top_level.push(own decl)
        mut ident := Expr.new(ident_node(lname), dd.default_value.line, dd.default_value.col)
        ident.set_expr_til_type(dd.default_value.expr_til_type())
        dd.default_value = ident
    } else {
        counter = typer_lift_lambdas_in_expr(dd.default_value, top_level, counter)
    }
    return counter
}

priv typer_lift_lambdas_in_expr := proc(mut e: Expr, mut top_level: Vec, mut counter: I64) returns I64 {
    if e.is_null() { return counter }
    // Issue #57: don't descend into template macro bodies -- a func literal
    // inside `macro(T: Type) returns FuncDef { return func(x: T) ... }` is
    // a template that initer's pre-pass substitutes and lifts at each call
    // site, not a lambda to extract here (the type-param references would
    // immediately fail under the lifted lambda's normal-typing path).
    switch e.node_type {
    case NodeType.FuncDef(lift_fd_check):
        if lift_fd_check.func_type.is(FuncType.Macro) {
            mtg_ret_lift := lift_fd_check.return_type.eq("StructDef")
                .or(lift_fd_check.return_type.eq("EnumDef"))
                .or(lift_fd_check.return_type.eq("FuncDef"))
                .or(lift_fd_check.return_type.eq("FunctionDef"))
            mut is_template_lift := mtg_ret_lift
            if is_template_lift.not() {
                for tmp_param_lift : Declaration in lift_fd_check.params {
                    if tmp_param_lift.explicit_type.eq("Type") {
                        is_template_lift = true
                    }
                }
            }
            if is_template_lift { return counter }
        }
    case:
    }
    // Visit default_value slots that live inside Declaration metadata.
    // Struct field defaults and FuncDef param defaults can carry a
    // lambda literal (`mut on_click : BinaryOp = func(...){...}`) the
    // same way an FCall arg can.  Namespace member default_values are
    // NOT lambda positions -- their FuncDef IS the named method's body,
    // so just recurse into it without lifting the outer FuncDef.
    switch e.node_type {
    case NodeType.FuncDef(fd):
        for mut pd : Declaration in fd.params {
            counter = typer_lift_one_default_value(pd, top_level, counter)
        }
    case NodeType.StructDef(sdd):
        for mut sf : Declaration in sdd.fields {
            counter = typer_lift_one_default_value(sf, top_level, counter)
        }
        for mut nd : Declaration in sdd.ns_decls {
            if nd.default_value.is_null().not() {
                counter = typer_lift_lambdas_in_expr(nd.default_value, top_level, counter)
            }
        }
    case NodeType.EnumDef(edd):
        for mut nd : Declaration in edd.ns_decls {
            if nd.default_value.is_null().not() {
                counter = typer_lift_lambdas_in_expr(nd.default_value, top_level, counter)
            }
        }
    case:
    }
    for i in 0..e.children.len() {
        ref mut c : Expr = e.child(i)
        if c.is_null() { continue }
        // The rhs slot of a NodeType.Decl is a named function definition,
        // not a lambda. Skip lifting; just recurse to find any lambdas
        // nested INSIDE that named function's body.
        is_decl_rhs := e.node_type.is(NodeType.Decl).and(i.eq(0))
        if typer_is_lambda_target(c).and(is_decl_rhs.not()) {
            counter = typer_lift_lambdas_in_expr(c, top_level, counter)
            lname := format("_lambda_", counter.to_str())
            counter = counter.add(1)
            mut decl := Expr.new(NodeType.Decl(Declaration(name = lname.clone(), is_priv = true)), c.line, c.col)
            decl.add_child(own c.clone())
            top_level.push(own decl)
            mut ident := Expr.new(ident_node(lname), c.line, c.col)
            e.children.replace(i, own ident)
        } else {
            counter = typer_lift_lambdas_in_expr(c, top_level, counter)
        }
    }
    return counter
}

// Pre-register a lifted lambda decl in scope so references to its
// synthetic _lambda_<N> name resolve even though the typer's main walk
// is in source order and may type a referencing function body before
// it reaches the lifted decl itself.
priv typer_register_lifted_lambda := func(mut scope: TypeScope, lifted: Expr, ctx: Context) {
    switch lifted.node_type {
    case NodeType.Decl(sdecl):
        ref rhs : Expr = lifted.child(0)
        switch rhs.node_type {
        case NodeType.FuncDef(fdef):
            mut rt := Type.None
            scope.set(sdecl.name, rt, fdef.func_type, false, ctx.path, lifted.line, lifted.col, false, OwnType.Shallow)
            ref mut fb : TypeBinding = scope.get_binding(sdecl.name)
            fb.func_def = lifted.child(0)
            fb.is_priv = sdecl.is_priv
        case:
        }
    case:
    }
}

priv typer_lift_lambdas := proc(mut scope: TypeScope, mut prog: Expr, ctx: Context) {
    if prog.is_null() { return }
    if prog.node_type.is(NodeType.Body).not() { return }
    mut top_level := Vec.new(Expr)
    mut ctr : I64 = 0
    ctr = typer_lift_lambdas_in_expr(prog, top_level, ctr)
    for l : Expr in top_level {
        typer_register_lifted_lambda(scope, l, ctx)
        prog.children.push(own l.clone())
    }
}

type_check_unit := proc(path: Str, program: Expr, scope: TypeScope, ctx: Context) returns I32 {
    ctx.errors = 0
    context_enter_file(ctx, path)
    // Lift anonymous func literals out of expression positions to
    // top-level _lambda_<N> priv decls. The typer then types them as
    // ordinary named functions through the normal walk below. Doing
    // this in the typer (rather than as a pre-typer pass in init_file)
    // keeps the parser dumb and avoids adding a #158-style extra walk.
    typer_lift_lambdas(scope, program, ctx)
    // Issue #198: extend signatures of throwing functions BEFORE
    // any body type-checking so call-site rewrites in
    // inject_throw_args_in_body see the post-extension param list.
    extend_throwing_func_sigs(ctx, program)
    // For per-file units, we do not switch modes per statement.
    infer_body_unit(scope, program, 0, 1, 0, 0, 0, ctx)
    // Program-scope asap runs from prepare_program via
    // garbager_destroy(ctx) once all files are typed -- see issue #204
    // step 3b.
    return ctx.errors
}

// Two-sweep typer driver (#174 / #147 step 3-4 prep). type_file calls
// type_decls_file first (decls + methodgen + layout, future home of
// init_declarations_global's scope-using work) and then
// type_bodies_file (function body type-checking). Both walks are
// rstil-style: recurse on imports in source order, then handle this
// file. The split memo Sets (imports_typer_decls_done /
// imports_typer_bodies_done) ensure each file is visited at most once
// per sweep, and the per-file ordering "imports first, then this
// file" within each sweep matches today's single-sweep behaviour.
//
// type_decls_file currently owns layout computation
// (compute_struct_layout / compute_enum_layout), the layout-dependent
// size methodgen (gen_*_size_method_for_stmt), and the scope-free
// cmp/unity derived-method helpers. Subsequent commits relocate the
// scope-using methodgen (gen_struct_clone_delete,
// gen_missing_enum_clone) the same way and eventually retire
// init_declarations_global's heavy parts entirely.
type_file := proc(path: Str, ctx: Context) returns I32 {
    mut total : I32 = 0
    total = total.add(type_decls_file(path, ctx))
    total = total.add(type_bodies_file(path, ctx))
    return total
}

// First of two typer sweeps: per file, recurse on imports first
// (matching the existing rstil-style ordering), then walk top-level
// decls and do struct/enum layout computation, layout-dependent size
// methodgen, and the scope-free cmp/unity derived-method helpers.
// Layout's nested-type lookups follow scope.get_struct /
// get_binding; the topo-ordered import recursion above guarantees
// every import's layouts are already done before the parent file's
// layouts run, and within a file compute_*_layout recurses on
// nested defs for local forward references. The remaining
// scope-using methodgen (gen_struct_clone_delete,
// gen_missing_enum_clone) and the post-init re-registration loops
// stay in init_declarations_global for now -- they hit the #174
// method-body cycle and will migrate once the second sweep takes
// over function bodies.
type_decls_file := proc(path: Str, ctx: Context) returns I32 {
    if ctx.imports_typer_decls_done.has(path) {
        return 0
    }
    ctx.imports_typer_decls_done.add(own path.clone())

    ref iu : ImportUnit = ctx.imported[path]
    mut total : I32 = 0
    ast_count : USize = count_ast_imports(iu.ast)
    auto_count : USize = iu.imports.len().sub(ast_count)
    for i in 0..auto_count {
        ref dep : Str = iu.imports[i]
        total = total.add(type_decls_file(dep, ctx))
    }
    mut import_idx : USize = auto_count
    for i in 0..iu.ast.children.len() {
        ref stmt : Expr = iu.ast.children[i]
        mut is_imp := false
        if stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0)) {
            ref imp_stmt : Expr = stmt.child(0)
            if imp_stmt.node_type.is(NodeType.FCall).and(imp_stmt.children.len().gte(2)) {
                if imp_stmt.child(1).node_type.is_literal_str() {
                    switch imp_stmt.child(0).node_type {
                    case NodeType.Ident(id):
                        if id.ident_name().eq("import") { is_imp = true }
                    case:
                    }
                }
            }
        } else {
            if stmt.node_type.is(NodeType.FCall).and(stmt.children.len().gte(2)) {
                if stmt.child(1).node_type.is_literal_str() {
                    switch stmt.child(0).node_type {
                    case NodeType.Ident(id):
                        if id.ident_name().eq("import") { is_imp = true }
                    case:
                    }
                }
            }
        }

        if is_imp {
            ref dep : Str = iu.imports[import_idx]
            total = total.add(type_decls_file(dep, ctx))
            import_idx = import_idx.add(1)
        }
    }

    // Per-decl work in source order: compute struct/enum layouts,
    // synthesize the layout-dependent size method, and run the
    // scope-free cmp/unity derived-method helpers. Layout has to run
    // before gen_*_size_method_for_stmt (which reads
    // total_struct_size / total_enum_size) and before the cmp/unity
    // helpers (which inspect the same ns_decls that size methodgen
    // may have just populated). All three steps are safe in this
    // sweep because compute_*_layout's nested-type lookups follow
    // the same scope.get_struct / scope.get_binding path that
    // init_declarations_global used today; the rstil-style
    // topo-ordered recursion above guarantees every import's
    // layouts are already done by the time we get here. Within a
    // file, compute_struct_layout / compute_enum_layout internally
    // recurse on nested defs to handle local forward references.
    for stmt : Expr in iu.ast.children {
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        if stmt.children.len().eq(0) { continue }
        ref rhs : Expr = stmt.child(0)
        if rhs.node_type.is(NodeType.StructDef) {
            compute_struct_layout(rhs, ctx.scope)
            switch stmt.node_type {
            case NodeType.Decl(d):
                record_struct_layout(ctx, d.name, rhs)
            case:
            }
            gen_struct_size_method_for_stmt(stmt)
        } else if rhs.node_type.is(NodeType.EnumDef) {
            compute_enum_layout(rhs, ctx.scope)
            switch stmt.node_type {
            case NodeType.Decl(d):
                record_enum_layout(ctx, d.name, rhs)
            case:
            }
            gen_enum_size_method_for_stmt(stmt, ctx.scope)
        } else {
            continue
        }
        gen_cmp_derived_for_stmt(stmt)
        gen_unity_derived_for_stmt(stmt)
    }
    return total
}

// Per-file body type-check sweep (the second of two). The recursion
// here is the same shape as the current single-sweep type_file: walk
// imports in source order, then type_check_unit. Renamed from
// type_file to make the two-sweep split explicit.
type_bodies_file := proc(path: Str, ctx: Context) returns I32 {
    if ctx.imports_typer_bodies_done.has(path) {
        return 0
    }
    ctx.imports_typer_bodies_done.add(own path.clone())

    ref iu : ImportUnit = ctx.imported[path]

    // Walk the AST in source order; recurse on each ~import("...")~ FCall.
    // iu.imports stays as a source-ordered side table for path resolution.
    // Loader-prepended mode auto-imports (e.g. mode gui -> gui.til) come
    // first in iu.imports without a matching AST FCall, so process those
    // leading entries before the walk. #165 step 5.
    mut total : I32 = 0
    ast_count : USize = count_ast_imports(iu.ast)
    auto_count : USize = iu.imports.len().sub(ast_count)
    for i in 0..auto_count {
        ref dep : Str = iu.imports[i]
        total = total.add(type_bodies_file(dep, ctx))
    }
    mut import_idx : USize = auto_count
    for stmt : Expr in iu.ast.children {
        if stmt.node_type.is(NodeType.FCall).not() { continue }
        if stmt.children.len().neq(2) { continue }
        if stmt.child(1).node_type.is_literal_str().not() { continue }
        switch stmt.child(0).node_type {
        case NodeType.Ident(id):
            if id.ident_name().eq("import").not() { continue }
            ref dep : Str = iu.imports[import_idx]
            total = total.add(type_bodies_file(dep, ctx))
            import_idx = import_idx.add(1)
        case:
            continue
        }
    }

    context_enter_file(ctx, path)
    if iu.mode_str.eq("mode") {
        for stmt : Expr in iu.ast.children {
            mut is_valid := false
            if stmt.node_type.is(NodeType.Decl) {
                switch stmt.node_type {
                case NodeType.Decl(_dd):
                    if stmt.children.len().gt(0) {
                        ref val : Expr = stmt.child(0)
                        if val.node_type.is(NodeType.NoDefaultArg).not() {
                            if val.node_type.is(NodeType.FCall).and(val.children.len().gt(0)) {
                                ref callee : Expr = val.child(0)
                                switch callee.node_type {
                                case NodeType.Ident(id):
                                    if id.ident_name().eq("Mode") {
                                        is_valid = true
                                    }
                                case:
                                }
                            }
                        }
                    }
                case:
                }
            } else if stmt.node_type.is(NodeType.FCall).and(stmt.children.len().eq(2)) {
                if stmt.child(1).node_type.is_literal_str() {
                    switch stmt.child(0).node_type {
                    case NodeType.Ident(id):
                        if id.ident_name().eq("import") { is_valid = true }
                    case:
                    }
                }
            }
            if is_valid.not() {
                stmt.type_error("only Mode declarations (e.g. `cli := Mode(...)`) and imports are allowed in 'mode mode'", ctx)
            }
        }
    }
    return total.add(type_check_unit(path, iu.ast, ctx.scope, ctx))
}

infer_assign_stmt := proc(scope: TypeScope, mut stmt: Expr, in_func: I32, ctx: Context) {
    infer_expr(scope, stmt.child(0), in_func, ctx)
    ref mut rhs : Expr = stmt.child(0)
    stmt.set_expr_til_type(rhs.expr_til_type())
    mut aname := ""
    switch stmt.node_type {
    case NodeType.Assign(adata):
        aname = adata.name.clone()
    case:
        UNREACHABLE(__LOC__)
        return
    }
    // A write isn't a read. Don't flip `used = true` on the assign
    // target for plain mut locals -- that's the accidental exception
    // that masks write-only locals like `mut y := x; y = 99` as
    // not-unused.
    //
    // Two carve-outs where the write IS observable:
    // - Params: a `mut foo: T` param is an output channel watched by
    //   the caller.
    // - Ref bindings: `ref mut x : T = &slot` followed by `x = v` is
    //   the explicit write-through-ref pattern -- the assign is the
    //   whole point of the binding.
    ref mut ub : TypeBinding = scope.get_binding(aname)
    if ub.is_null().not() {
        if ub.is_param.or(ub.own_type.is(OwnType.Ref)) { ub.used = true }
    }
    existing := scope.get_type(aname)
    if existing.is(Type.Unknown) {
        stmt.type_error("undefined symbol '".concat(aname).concat("'"), ctx)
    } else if rhs.redundant_literal_conversion(existing) {
        redundant_conversion_error(rhs, existing, ctx)
    } else if scope.is_mut(aname).not() {
        stmt.type_error("cannot assign to immutable variable '".concat(aname).concat("'"), ctx)
        sf := scope.find(aname)
        switch sf {
        case ScopeFind.Found(b):
            if b.is_param {
                println(ctx.path, ":", b.line.to_str(), ":", b.col.to_str(), ": note: '", aname, "' is a function parameter")
            } else {
                println(ctx.path, ":", b.line.to_str(), ":", b.col.to_str(), ": note: '", aname, "' declared here, consider adding 'mut'")
            }
        case:
        }
    } else if rhs.node_type.is_literal_num().and(is_numeric_type(existing)) {
        switch rhs.node_type {
        case NodeType.Literal(Literal.Num(lit_str)):
            if literal_in_range(lit_str.literal_num_text(), existing).not() {
                stmt.type_error("integer literal out of range for assignment to '".concat(aname).concat("'"), ctx)
            }
        case:
        }
        rhs.set_expr_til_type(existing)
        stmt.set_expr_til_type(existing)
    } else if rhs.expr_til_type().is(existing).not().and(rhs.expr_til_type().is(Type.Unknown).not()) {
        stmt.type_error("'".concat(aname).concat("' assignment type mismatch"), ctx)
    }
    sf_assign := scope.find(aname)
    mut is_ref_target := false
    mut is_payload_alias := false
    switch sf_assign {
    case ScopeFind.Found(ab):
        if ab.own_type.is(OwnType.Ref).and(ab.is_param.not()) {
            is_ref_target = true
            if ab.is_alias { is_payload_alias = true }
        }
    case:
    }
    if is_payload_alias {
        switch stmt.node_type {
        case NodeType.Assign(adata_p):
            adata_p.is_payload_alias = true
        case:
        }
    }
    if is_ref_target {
        // #211: payload aliases accept an owned-value RHS (the builder
        // lowers it to `*p = *new` for structs and `*p = (Str){...}` for
        // Str literals); only plain ref bindings still reject.
        if is_payload_alias.not() {
            check_ref_assign_owned_rhs(stmt, aname, rhs, scope, ctx)
        }
    }
    if is_ref_target.not() {
        if rhs.node_type.is(NodeType.Ident).or(
            rhs.node_type.is(NodeType.FieldAccess).and(
                is_aggregate(rhs.expr_til_type())
            )
        ) {
            tname := type_to_name(rhs.expr_til_type())
            if tname.len().gt(0) {
                mc := make_clone_call(tname, rhs.expr_til_type(), rhs, stmt)
                // (Issue #109) Use Vec.replace to drop-old: the slot at
                // index 0 held the original rhs Expr; make_clone_call
                // already cloned rhs into mc.children, so the original
                // is now unreachable and its inner heap data (NodeType
                // payload, til_type c_str, children Vec) would leak
                // with a plain .set().
                stmt.children.replace(0, own mc)
                if scope.bindings.has(aname).not() {
                    if is_aggregate(existing) {
                        if assign_target_is_func_local(scope, aname) {
                            switch stmt.node_type {
                            case NodeType.Assign(adata2):
                                adata2.save_old_delete = true
                            case:
                            }
                        }
                    }
                }
            }
        } else if rhs.node_type.is(NodeType.FCall).and(fcall_returns_own(rhs, scope)).and(
            is_aggregate(existing)
        ) {
            if scope.bindings.has(aname).not().and(assign_target_is_func_local(scope, aname)) {
                switch stmt.node_type {
                case NodeType.Assign(adata3):
                    adata3.save_old_delete = true
                case:
                }
            }
        } else if rhs.node_type.is_literal_str().and(
            is_aggregate(existing)
        ) {
            // mut X := some_str; ... X = "literal" -- the outer-scope local
            // owns a heap-allocated Str clone; the literal RHS just rebinds
            // the pointer, leaking the old clone. Same outer-scope shape as
            // the Ident/FCall branches above.
            if scope.bindings.has(aname).not().and(assign_target_is_func_local(scope, aname)) {
                switch stmt.node_type {
                case NodeType.Assign(adata4):
                    adata4.save_old_delete = true
                case:
                }
            }
        }
    }
}

rhs_is_clone_fcall := func(rhs: Expr) returns Bool {
    if rhs.node_type.is(NodeType.FCall).not() { return false }
    if rhs.children.len().lt(1) { return false }
    ref callee : Expr = rhs.child(0)
    if callee.node_type.is(NodeType.FieldAccess).not() { return false }
    switch callee.node_type {
    case NodeType.FieldAccess(method):
        return method.field_access_name().eq("clone")
    case:
        return false
    }
}

assign_target_is_func_local := func(mut scope: TypeScope, name: Str) returns Bool {
    ref mut s : TypeScope = scope
    while s.is_null().not() {
        if s.parent.is_null().not().and(s.bindings.has(name)) { return true }
        s = s.parent
    }
    return false
}

is_numeric_type := func(t: Type) returns Bool {
    switch t {
    case Type.I64: return true
    case Type.U8:  return true
    case Type.I8:  return true
    case Type.Primitive(Primitive.I16): return true
    case Type.Primitive(Primitive.U16): return true
    case Type.I32: return true
    case Type.U32: return true
    case Type.U64: return true
    case Type.F32: return true
    case Type.Struct(s):
        if s.eq("I32") { return true }
        if s.eq("U8")  { return true }
        if s.eq("I8")  { return true }
        return false
    case: return false
    }
}

is_integral_numeric_type := func(t: Type) returns Bool {
    switch t {
    case Type.I64: return true
    case Type.U8:  return true
    case Type.I8:  return true
    case Type.Primitive(Primitive.I16): return true
    case Type.Primitive(Primitive.U16): return true
    case Type.I32: return true
    case Type.U32: return true
    case Type.U64: return true
    case Type.Struct(s):
        if s.eq("I32") { return true }
        if s.eq("U8")  { return true }
        if s.eq("I8")  { return true }
        return false
    case: return false
    }
}

type_ctor_consumes := func(t: Type) returns Bool {
    // Issue #205: primitives modelled as Type.Struct("I32") / Type.Struct("U8")
    // are value types -- a ctor field default of `0` with explicit type I32
    // shouldn't trigger "own" semantics. Without this short-circuit, the
    // generic Type.Struct case below pulls them into set_own_arg in
    // infer_struct_constructor_fcall, which makes the typer's hoist pass
    // promote the LiteralNum temp to Own, which makes the builder emit
    // `I32 *t = malloc(sizeof(I32)); *t = 0;` -- a per-LocalInfo leak that
    // never gets freed. (Issue #109.)
    if is_primitive(t) { return false }
    switch t {
    case Type.Struct: return true
    case Type.Enum: return true
    case Type.Dynamic: return true
    case Type.FuncPtr: return true
    case: return false
    }
}

is_usize_name := func(name: Str) returns Bool {
    return name.eq("USize")
}

is_uptr_name := func(name: Str) returns Bool {
    return name.eq("UPtr")
}

can_implicit_usize_coerce := func(from: Type, to: Type, to_name: Str) returns Bool {
    if is_usize_name(to_name) {
        switch to {
        case Type.U32:
            return is_integral_numeric_type(from)
        case: return false
        }
    }
    if is_uptr_name(to_name) {
        switch to {
        case Type.U32:
            return is_integral_numeric_type(from)
        case Type.U64:
            return is_integral_numeric_type(from)
        case: return false
        }
    }
    return false
}

literal_in_range := func(val_str: Str, target: Type) returns Bool {
    switch target {
    case Type.I64: return true
    case Type.F32: return true
    case Type.U8:
        val := val_str.to_i64()
        return val.gte(0).and(val.lte(255))
    case Type.I8:
        val := val_str.to_i64()
        return val.gte(-128).and(val.lte(127))
    case Type.Primitive(Primitive.I16):
        val := val_str.to_i64()
        return val.gte(-32768).and(val.lte(32767))
    case Type.Primitive(Primitive.U16):
        val := val_str.to_i64()
        return val.gte(0).and(val.lte(65535))
    case Type.I32:
        val := val_str.to_i64()
        return val.gte(-2147483648).and(val.lte(2147483647))
    case Type.U32:
        val := val_str.to_i64()
        return val.gte(0).and(val.lte(4294967295))
    case Type.U64:
        val := val_str.to_i64()
        return val.gte(0)
    case Type.Struct(s):
        if s.eq("I32") {
            val := val_str.to_i64()
            return val.gte(-2147483648).and(val.lte(2147483647))
        }
        if s.eq("U8") {
            val := val_str.to_i64()
            return val.gte(0).and(val.lte(255))
        }
        if s.eq("I8") {
            val := val_str.to_i64()
            return val.gte(-128).and(val.lte(127))
        }
        return true
    case: return true
    }
}

can_implicit_widen := func(from: Type, to: Type) returns Bool {
    if from.eq(to) { return false }
    // Issue #205: a primitive may arrive as Type.Struct("<name>") or as
    // Type.<Name> during the staged migration; both must widen to I64
    // and accept widening from the smaller primitives.
    mut to_is_i32 := to.is(Type.I32)
    switch to {
    case Type.Struct(ts):
        if ts.eq("I32") { to_is_i32 = true }
    case:
    }
    to_is_i64 := to.is(Type.I64)
    to_is_u32 := to.is(Type.U32)
    to_is_u64 := to.is(Type.U64)
    to_is_i16 := to.is(Type.Primitive(Primitive.I16))
    to_is_u16 := to.is(Type.Primitive(Primitive.U16))
    mut from_is_u8 := from.is(Type.U8)
    mut from_is_i8 := from.is(Type.I8)
    switch from {
    case Type.Struct(fs):
        if fs.eq("U8") { from_is_u8 = true }
        if fs.eq("I8") { from_is_i8 = true }
    case:
    }
    if from_is_u8 {
        if to_is_i16 { return true }
        if to_is_u16 { return true }
        if to_is_i32 { return true }
        if to_is_i64 { return true }
        if to_is_u32 { return true }
        if to_is_u64 { return true }
        return false
    }
    if from_is_i8 {
        if to_is_i16 { return true }
        if to_is_i32 { return true }
        if to_is_i64 { return true }
        return false
    }
    switch from {
    case Type.I8:
        if to_is_i16 { return true }
        if to_is_i32 { return true }
        if to_is_i64 { return true }
        return false
    case Type.Primitive(Primitive.I16):
        if to_is_i32 { return true }
        if to_is_i64 { return true }
        return false
    case Type.Primitive(Primitive.U16):
        if to_is_i32 { return true }
        if to_is_i64 { return true }
        if to_is_u32 { return true }
        if to_is_u64 { return true }
        return false
    case Type.U32:
        if to_is_u64 { return true }
        if to_is_i64 { return true }
        return false
    case Type.I32:
        if to_is_i64 { return true }
        return false
    case Type.Struct(fs):
        if fs.eq("I32") {
            if to_is_i64 { return true }
        }
        return false
    case: return false
    }
}

// Type-name resolution at a user-facing site (parameter type, return
// type, ref/let decl explicit_type). Shares the single
// scope.get_binding lookup with the priv check, so user-facing
// callers don't pay for two Map traversals per declaration position.
type_from_name_at := proc(name: Str, scope: TypeScope, mut e: Expr, ctx: Context) returns Type {
    pt := type_from_name(name, scope, ctx)
    if name.len().eq(0) { return pt }
    if ctx.current_type_name.eq(name) { return pt }
    if scope.is_null() { return pt }
    ref mut b : TypeBinding = scope.get_binding(name)
    check_priv_access(e, name, b, ctx)
    return pt
}

type_from_name := func(name: Str, scope: TypeScope, ctx: Context) returns Type {
    if name.eq("I64")  { return Type.I64 }
    if name.eq("U8")   { return Type.Struct("U8") }
    if name.eq("I8")   { return Type.Struct("I8") }
    if name.eq("I16")  { return Type.Primitive(Primitive.I16) }
    if name.eq("U16")  { return Type.Primitive(Primitive.U16) }
    if name.eq("I32")  { return Type.Struct("I32") }
    if name.eq("U32")  { return Type.U32 }
    if name.eq("U64")  { return Type.U64 }
    if name.eq("F32")  { return Type.F32 }
    if name.eq("Str")  { return Type.Struct("Str") }
    if name.eq("Bool") { return Type.Bool }
    if name.eq("StructDef") { return Type.Struct("StructDef") }
    if name.eq("EnumDef")   { return Type.Struct("EnumDef") }
    if name.eq("Fn")        { return Type.FuncPtr }
    if name.eq("Dynamic")   { return Type.Dynamic }
    if scope.is_null().not() {
        ref mut b : TypeBinding = scope.get_binding(name)
        if b.is_null().not() {
            if b.is_type_alias {
                if b.alias_target.is_empty().not() {
                    return type_from_name(b.alias_target, scope, ctx)
                }
            }
            // #187: explicit type annotations (e.g. ~ref x : Foo = ...~,
            // function param/return types) count as a use of the named
            // type. Same gate as the Ident path -- skip when we're inside
            // the type's own namespace to keep auto-gen body references
            // from masking a genuinely unused priv type.
            if ctx.auto_gen_depth.eq(0).and(ctx.current_type_name.eq(name).not()) {
                b.used = true
            }
            if b.is_builtin {
                if b.struct_def.is_null().not() { return b.type }
            }
            if b.func_def.is_null().not() {
                if b.func_def.children.len().eq(0) {
                    return Type.FuncPtr
                }
            }
        }
        ref sdef : Expr = scope.get_struct(name)
        if sdef.is_null().not() {
            if sdef.node_type.is(NodeType.EnumDef) {
                return Type.Enum(name.clone())
            }
            return Type.Struct(name.clone())
        }
    }
    return Type.Unknown
}

resolve_type_alias := func(scope: TypeScope, name: Str) returns ref Str {
    ref b : TypeBinding = scope.get_binding(name)
    if b.is_null().not() {
        if b.is_type_alias {
            if b.alias_target.is_empty().not() { return b.alias_target }
        }
    }
    return name
}

usize_name := func(scope: TypeScope) returns Str {
    if scope.get_binding("USize").is_null().not() { return "USize" }
    return "U64"
}

usize_type := func(scope: TypeScope, ctx: Context) returns Type {
    return type_from_name(usize_name(scope), scope, ctx)
}

type_has_cmp := func(scope: TypeScope, type_name: Str) returns Bool {
    ref sdef : Expr = scope.get_struct(type_name)
    if sdef.is_null() { return false }
    ref cmp_ns : Vec = def_ns_decls(sdef)
    for decl : Declaration in cmp_ns {
        if decl.name.eq("cmp") { return true }
    }
    return false
}

type_has_to_str := func(scope: TypeScope, type_name: Str) returns Bool {
    ref sdef : Expr = scope.get_struct(type_name)
    if sdef.is_null() { return false }
    ref ts_ns : Vec = def_ns_decls(sdef)
    for decl : Declaration in ts_ns {
        if decl.name.eq("to_str") { return true }
    }
    return false
}

expr_contains_fcall := func(e: Expr) returns Bool {
    if e.node_type.is(NodeType.FCall) { return true }
    for e_i : Expr in e.children {
        if expr_contains_fcall(e_i) { return true }
    }
    return false
}

expr_uses_var := func(e: Expr, name: Str) returns Bool {
    if e.node_type.is(NodeType.FuncDef) { return false }
    switch e.node_type {
    case NodeType.Ident(_id):
        if _id.ident_name().eq(name) { return true }
    case NodeType.Assign(_as):
        if _as.name.eq(name) { return true }
    case:
    }
    for e_i : Expr in e.children {
        if expr_uses_var(e_i, name) { return true }
    }
    return false
}

expr_contains_decl := func(e: Expr, name: Str) returns Bool {
    if e.node_type.is(NodeType.FuncDef) { return false }
    switch e.node_type {
    case NodeType.Decl(_dd):
        if _dd.name.eq(name) { return true }
    case:
    }
    for e_i : Expr in e.children {
        if expr_contains_decl(e_i, name) { return true }
    }
    return false
}

expr_used_in_nested_func := func(e: Expr, name: Str) returns Bool {
    switch e.node_type {
    case NodeType.FuncDef(fdef):
        for p : Declaration in fdef.params {
            if p.name.eq(name) { return false }
        }
        if e.children.len().gt(0) {
            return expr_uses_var(e.child(0), name)
        }
        return false
    case:
    }
    for e_i : Expr in e.children {
        if expr_used_in_nested_func(e_i, name) { return true }
    }
    return false
}

priv find_variadic_fcall := func(e: Expr, scope: TypeScope) returns ref Expr {
    if e.is_null() { return NULL }
    if e.node_type.is(NodeType.FuncDef) { return NULL }
    if e.node_type.is(NodeType.StructDef) { return NULL }
    if e.node_type.is(NodeType.EnumDef) { return NULL }
    if e.node_type.is(NodeType.Body) { return NULL }
    switch e.node_type {
    case NodeType.FCall:
        if fcall_callee_has_variadic_via_scope(e, scope) {
            switch e.child(0).node_type {
            case NodeType.Ident(cn):
                cn_str := cn.ident_name()
                if cn_str.eq("array").or(cn_str.eq("vec")) {
                    return NULL
                }
            case:
            }
            return e
        }
    case:
    }
    for e_i : Expr in e.children {
        ref found : Expr = find_variadic_fcall(e_i, scope)
        if found.is_null().not() { return found }
    }
    return NULL
}

find_kwargs_fcall := func(e: Expr, scope: TypeScope) returns ref Expr {
    if e.is_null() { return NULL }
    if e.node_type.is(NodeType.FuncDef) { return NULL }
    if e.node_type.is(NodeType.StructDef) { return NULL }
    if e.node_type.is(NodeType.EnumDef) { return NULL }
    if e.node_type.is(NodeType.Body) { return NULL }
    switch e.node_type {
    case NodeType.FCall:
        if fcall_kwargs_index_via_scope(e, scope).gte(0) { return e }
    case:
    }
    for e_i : Expr in e.children {
        ref found : Expr = find_kwargs_fcall(e_i, scope)
        if found.is_null().not() { return found }
    }
    return NULL
}

find_array_vec_fcall := func(e: Expr) returns ref Expr {
    if e.is_null() { return NULL }
    if e.node_type.is(NodeType.FuncDef) { return NULL }
    if e.node_type.is(NodeType.StructDef) { return NULL }
    if e.node_type.is(NodeType.EnumDef) { return NULL }
    if e.node_type.is(NodeType.Body) { return NULL }
    switch e.node_type {
    case NodeType.FCall:
        if e.children.len().gt(0) {
            switch e.child(0).node_type {
            case NodeType.Ident(cn):
                cn_str := cn.ident_name()
                if cn_str.eq("array").or(cn_str.eq("vec")) { return e }
            case:
            }
        }
    case:
    }
    for e_i : Expr in e.children {
        ref found : Expr = find_array_vec_fcall(e_i)
        if found.is_null().not() { return found }
    }
    return NULL
}

type_prefix := func(t: Type) returns Str {
    switch t {
    case Type.I64: return "I64"
    case Type.U8: return "U8"
    case Type.I8: return "I8"
    case Type.Primitive(Primitive.I16): return "I16"
    case Type.Primitive(Primitive.U16): return "U16"
    case Type.I32: return "I32"
    case Type.U32: return "U32"
    case Type.U64: return "U64"
    case Type.F32: return "F32"
    case Type.Bool: return "Bool"
    case Type.None: return "None"
    case Type.Struct(s):
        if s.len().gt(0) { return s.clone() }
        return "compound"
    case Type.Enum(s):
        if s.len().gt(0) { return s.clone() }
        return "compound"
    case Type.Custom(s):
        // #165 step 1: Custom(name) is the unresolved form of
        // Struct(name)/Enum(name). Treat them the same here so type
        // comparisons (e.g. argument-type checks) see a consistent
        // prefix string.
        if s.len().gt(0) { return s.clone() }
        return "compound"
    case: return "v"
    }
}

type_to_name := func(t: Type) returns Str {
    name := til_type_name(t)
    if name.len().gt(0) { return name }
    switch t {
    case Type.I64: return I64Name.clone()
    case Type.U8: return U8Name.clone()
    case Type.I8: return I8Name.clone()
    case Type.Primitive(Primitive.I16): return I16Name.clone()
    case Type.Primitive(Primitive.U16): return U16Name.clone()
    case Type.I32: return I32Name.clone()
    case Type.U32: return U32Name.clone()
    case Type.U64: return U64Name.clone()
    case Type.F32: return F32Name.clone()
    case Type.Bool: return BoolName.clone()
    case: return ""
    }
}

make_field_delete := func(field_assign: Expr, shallow field_own_type: OwnType) returns Expr {
    ref rhs : Expr = field_assign.child(1)
    tname := type_to_name(rhs.expr_til_type())
    if tname.len().eq(0) { return NULL }

    mut call := Expr.new(NodeType.FCall(FCallData()), field_assign.line, field_assign.col)
    call.set_expr_til_type(Type.None)

    mut type_id := Expr.new(ident_node(tname), field_assign.line, field_assign.col)
    type_id.set_expr_til_type(Type.Custom(tname.clone()))

    mut fa := Expr.new(field_access_node("delete"), field_assign.line, field_assign.col)
    fa.add_child(own type_id)
    call.add_child(own fa)

    mut fa_name := ""
    switch field_assign.node_type {
    case NodeType.FieldAssign(fad):
        fn := fad.name
        fa_name = fn.clone()
    case:
        UNREACHABLE(__LOC__)
    }
    mut field_acc := Expr.new(field_access_node(fa_name), field_assign.line, field_assign.col)
    field_acc.set_expr_til_type(rhs.expr_til_type())
    field_acc.add_child(own field_assign.child(0).clone())
    call.add_child(own field_acc)

    mut cf_lit := Expr.new(NodeType.Literal(Literal.Bool(field_own_type.is(OwnType.Own))), field_assign.line, field_assign.col)
    call.add_child(own cf_lit)

    return call
}

make_delete_call := func(var_name: Str, shallow type: Type, arg_is_own: Bool, call_free: Bool, src: Expr) returns Expr {
    tname := type_to_name(type)
    if tname.len().eq(0) { return NULL }

    mut call := Expr.new(NodeType.FCall(FCallData()), src.line, src.col)
    call.set_expr_til_type(Type.None)

    mut type_id := Expr.new(ident_node(tname), src.line, src.col)
    type_id.set_expr_til_type(Type.Custom(tname.clone()))

    mut fa := Expr.new(field_access_node("delete"), src.line, src.col)
    fa.add_child(own type_id)
    call.add_child(own fa)

    mut arg := Expr.new(ident_node(var_name), src.line, src.col)
    arg.set_expr_til_type(type)
    if arg_is_own { set_own_arg(call, call.children.len()) }
    call.add_child(own arg)

    mut cf_lit := Expr.new(NodeType.Literal(Literal.Bool(call_free)), src.line, src.col)
    call.add_child(own cf_lit)

    return call
}

// True when `e` (or any sub-expression) is a struct constructor FCall of the
// shape `Type(..., var_name, ...)` where var_name is at the position of a
// field whose declared own_type is `Shallow`. In that case the constructor
// emits `dst->field = *var_name`, i.e. value-copies the inner Str/Vec/etc.
// from var_name's heap wrapper into the field; the field's own destructor
// will free the inner data when the parent struct is destroyed, but nothing
// frees var_name's wrapper, so it leaks.
//
// This is the exact shape we want `make_free_call` to follow up. Other
// transfer shapes -- own arg to a function, struct constructor with an Own
// or Ref field -- already consume the wrapper, so we must NOT emit a free.
transfer_is_shallow_field_value_copy := func(e: Expr, var_name: Str, scope: TypeScope) returns Bool {
    if e.is_null() { return false }
    if e.node_type.is(NodeType.FuncDef) { return false }
    if e.node_type.is(NodeType.FCall) {
        if e.children.len().gte(2) {
            fcall_sname := til_type_name(e.expr_til_type())
            if fcall_sname.len().gt(0) {
                switch e.child(0).node_type {
                case NodeType.Ident(_c0s):
                    if _c0s.ident_name().eq(fcall_sname) {
                        ref sdef : Expr = scope.get_struct(fcall_sname)
                        if sdef.is_null().not() {
                            switch sdef.node_type {
                            case NodeType.StructDef(tsv_sdd):
                                // Walk every constructor arg. For each
                                // arg that resolves to `Ident(var_name)`
                                // (positional or NamedArg-wrapped), look
                                // up the matching field by position
                                // (positional) or by name (NamedArg) to
                                // check its own_type. The previous loop
                                // only checked positional Ident args and
                                // missed every Type(field = local) form,
                                // so the local's wrapper leaked there.
                                for ci in 1..e.children.len() {
                                    ref arg : Expr = e.child(ci)
                                    mut inner : Expr = arg
                                    mut field_name : Str = ""
                                    switch arg.node_type {
                                    case NodeType.NamedArg(nan):
                                        field_name = nan
                                        if arg.children.len().gt(0) { inner = arg.child(0) }
                                    case:
                                    }
                                    switch inner.node_type {
                                    case NodeType.Ident(_an):
                                        if _an.ident_name().eq(var_name).not() { continue }
                                        // Resolve the receiving field.
                                        mut fd_idx : I32 = -1
                                        if field_name.is_empty() {
                                            // Positional: arg position ci-1 maps to field index.
                                            fd_idx = ci.sub(1).cast(I32)
                                        } else {
                                            for fi in 0..tsv_sdd.fields.len() {
                                                ref tfd : Declaration = tsv_sdd.fields[fi]
                                                if tfd.name.eq(field_name) { fd_idx = fi.cast(I32); break }
                                            }
                                        }
                                        if fd_idx.lt(0) { continue }
                                        if fd_idx.cast(U32).gte(tsv_sdd.fields.len()) { continue }
                                        ref fld_decl : Declaration = tsv_sdd.fields[fd_idx.cast(U32)]
                                        if fld_decl.own_type.is(OwnType.Shallow).not() { continue }
                                        if type_ctor_consumes(fld_decl.til_type) {
                                            return true
                                        }
                                    case:
                                    }
                                }
                            case:
                            }
                        }
                    }
                case:
                }
            }
        }
    }
    for ec : Expr in e.children {
        if transfer_is_shallow_field_value_copy(ec, var_name, scope) { return true }
    }
    return false
}

// `free(own var_name)`: release just the heap wrapper without invoking the
// type's destructor. Used after value-copy ownership transfer to a Shallow
// struct field, where the field's own destructor will free the inner data.
make_free_call := func(var_name: Str, shallow type: Type, src: Expr) returns Expr {
    mut call := Expr.new(NodeType.FCall(FCallData()), src.line, src.col)
    call.set_expr_til_type(Type.None)

    mut callee := Expr.new(ident_node("free"), src.line, src.col)
    call.add_child(own callee)

    mut arg := Expr.new(ident_node(var_name), src.line, src.col)
    arg.set_expr_til_type(type)
    set_own_arg(call, call.children.len())
    call.add_child(own arg)

    return call
}

make_clone_call := func(type_name: Str, shallow type: Type, arg: Expr, src: Expr) returns Expr {
    mut call := Expr.new(NodeType.FCall(FCallData()), src.line, src.col)
    call.set_expr_til_type(type)
    if type.is(Type.Struct).and(til_type_name(type).len().eq(0)) {
        call.set_expr_til_type(Type.Struct(type_name.clone()))
    } else if type.is(Type.Enum).and(til_type_name(type).len().eq(0)) {
        call.set_expr_til_type(Type.Enum(type_name.clone()))
    }

    mut type_id := Expr.new(ident_node(type_name), src.line, src.col)
    type_id.set_expr_til_type(Type.Custom(type_name.clone()))

    mut fa := Expr.new(field_access_node("clone"), src.line, src.col)
    fa.add_child(own type_id)
    call.add_child(own fa)

    call.add_child(own arg.clone())
    return call
}

// Wrap `arg` with `T.to_str(arg)`, used to auto-coerce non-Str args
// passed to a `..Str` variadic param so `print(1+1)` etc. work.
make_to_str_call := func(type_name: Str, arg: Expr) returns Expr {
    mut call := make_ns_call(type_name, "to_str", Type.Struct("Str"), arg)
    call.add_child(own arg.clone())
    return call
}

make_ns_call := func(sname: Str, method: Str, shallow ret_type: Type, src: Expr) returns Expr {
    mut call := Expr.new(NodeType.FCall(FCallData()), src.line, src.col)
    call.set_expr_til_type(ret_type)

    mut type_id := Expr.new(ident_node(sname), src.line, src.col)
    type_id.set_expr_til_type(Type.Custom(sname.clone()))

    mut fa := Expr.new(field_access_node(method), src.line, src.col)
    fa.add_child(own type_id)
    call.add_child(own fa)
    return call
}

// Set `call.own_args` to match the callee's params.own_type, for a
// namespace call built by make_ns_call (FCall whose head is
// FieldAccess(method) over Ident(type_name)). Walks the resolved
// ns_func.params and ORs bit (i+1) for each Own param -- the +1 skips
// the callee child at index 0. Caller is responsible for having pushed
// the receiver and the actual arg Exprs in the same order as the
// callee's params before calling this.
//
// Single source of truth for "which positional args are own?" -- it
// is derived from the callee's actual signature instead of being
// hardcoded per build_*_* site. Synthesized FCalls are created during
// `body_pre_passes`, AFTER the per-stmt type-check pass that runs
// `validate_fcall_own_args` / `infer_field_access_fcall`, so they
// never go through the typer's own-args consistency check; this
// helper plays the role the validator plays for user-written calls.
//
// Issue #109: the kwargs DynMap.set leak was a hardcoded set_own_arg
// for elem_type that didn't match the callee's actual `elem_type: Str`
// (borrowed) param; the helper plugs the whole bug class.
sync_own_args_from_callee := func(mut call: Expr, scope: TypeScope) {
    ref fa : Expr = call.child(0)
    mut method := ""
    switch fa.node_type {
    case NodeType.FieldAccess(m):
        method = m.field_access_name()
    case:
        return
    }
    ref obj : Expr = fa.child(0)
    mut type_name := ""
    switch obj.node_type {
    case NodeType.Ident(name):
        type_name = name.ident_name()
    case:
        return
    }
    ref sdef : Expr = scope.get_struct(type_name)
    if sdef.is_null() { return }
    ref ns_func : Expr = find_namespace_func(sdef, method, scope)
    if ns_func.is_null() { return }
    switch ns_func.node_type {
    case NodeType.FuncDef(fd):
        for i in 0..fd.params.len() {
            ref p : Declaration = fd.params[i]
            if p.own_type.is(OwnType.Own) {
                set_own_arg(call, i.add(1))
            }
        }
    case:
    }
}

build_kwargs_dynmap_decl := func(fcall: Expr, kw_name: Str) returns Expr {
    mut new_call := make_ns_call("DynMap", "new", Type.Struct("DynMap"), fcall)
    mut kw_decl := Expr.new(NodeType.Decl(Declaration()), fcall.line, fcall.col)
    switch kw_decl.node_type {
    case NodeType.Decl(dd):
        dd.name = kw_name.clone()
    case:
        UNREACHABLE(__LOC__)
    }
    kw_decl.set_expr_til_type(Type.Struct("DynMap"))
    kw_decl.add_child(own new_call)
    return kw_decl
}

build_kwargs_dynmap_set := func(fcall: Expr, scope: TypeScope, kw_name: Str, named_arg: Expr, ctx: Context) returns Expr {
    mut key_name := ""
    switch named_arg.node_type {
    case NodeType.NamedArg(kn):
        key_name = kn.clone()
    case:
        UNREACHABLE(__LOC__)
    }
    ref val : Expr = named_arg.child(0)
    mut set_call := make_ns_call("DynMap", "set", Type.None, fcall)

    mut self_id := Expr.new(ident_node(kw_name), fcall.line, fcall.col)
    self_id.set_expr_til_type(Type.Struct("DynMap"))
    set_call.add_child(own self_id)

    mut key_lit := Expr.new(NodeType.Literal(Literal.Str(key_name)), fcall.line, fcall.col)
    set_call.add_child(own key_lit)

    tname := type_to_name(val.expr_til_type())
    mut type_lit := Expr.new(NodeType.Literal(Literal.Str(tname.clone())), fcall.line, fcall.col)
    set_call.add_child(own type_lit)

    mut size_call := make_ns_call(tname, "size", usize_type(scope, ctx), fcall)
    set_call.add_child(own size_call)

    mut out_val := val.clone()
    if val.node_type.is(NodeType.Ident).or(val.node_type.is(NodeType.FieldAccess)) {
        if tname.len().gt(0) {
            out_val = make_clone_call(tname, val.expr_til_type(), val, val)
        }
    }
    set_call.add_child(own out_val)

    sync_own_args_from_callee(set_call, scope)
    return set_call
}

build_variadic_array_decl := func(fcall: Expr, scope: TypeScope, elem_type: Str, va_name: Str, vc: U32, ctx: Context) returns Expr {
    mut new_call := make_ns_call("Array", "new", Type.Struct("Array"), fcall)

    mut et := fcall.make_til_type_expr(type_from_name(elem_type, scope, ctx))
    new_call.add_child(own et)

    cap_str := vc.to_str()
    mut cap := Expr.new(literal_num_node(cap_str), fcall.line, fcall.col)
    cap.set_expr_til_type(usize_type(scope, ctx))
    new_call.add_child(own cap)

    mut va_decl := Expr.new(NodeType.Decl(Declaration()), fcall.line, fcall.col)
    switch va_decl.node_type {
    case NodeType.Decl(dd):
        dd.name = va_name.clone()
        dd.own_type = OwnType.Own
    case:
        UNREACHABLE(__LOC__)
    }
    va_decl.set_expr_til_type(Type.Struct("Array"))
    va_decl.add_child(own new_call)
    return va_decl
}

build_variadic_array_set := func(fcall: Expr, scope: TypeScope, va_name: Str, vi: I32, j: U32, ctx: Context) returns Expr {
    mut set_call := make_ns_call("Array", "set", Type.None, fcall)

    mut self_id := Expr.new(ident_node(va_name), fcall.line, fcall.col)
    self_id.set_expr_til_type(Type.Struct("Array"))
    set_call.add_child(own self_id)

    idx_str := j.to_str()
    mut idx := Expr.new(literal_num_node(idx_str), fcall.line, fcall.col)
    idx.set_expr_til_type(usize_type(scope, ctx))
    set_call.add_child(own idx)

    ref val_in : Expr = fcall.child(vi.add(j.cast(I32)).to_usize())
    mut val := val_in.clone()
    if val_in.node_type.is(NodeType.Ident).or(val_in.node_type.is(NodeType.FieldAccess)) {
        tname := type_to_name(val_in.expr_til_type())
        if tname.len().gt(0) {
            val = make_clone_call(tname, val_in.expr_til_type(), val_in, val_in)
        }
    }
    set_call.add_child(own val)

    sync_own_args_from_callee(set_call, scope)
    return set_call
}

build_builtin_vec_decl := func(fcall: Expr, scope: TypeScope, elem_type: Str, vec_name: Str, ctx: Context) returns Expr {
    mut new_call := make_ns_call("Vec", "new", Type.Struct("Vec"), fcall)

    mut et := fcall.make_til_type_expr(type_from_name(elem_type, scope, ctx))
    new_call.add_child(own et)

    mut vec_decl := Expr.new(NodeType.Decl(Declaration()), fcall.line, fcall.col)
    switch vec_decl.node_type {
    case NodeType.Decl(dd):
        dd.name = vec_name.clone()
        dd.own_type = OwnType.Own
        dd.is_mut = true
    case:
        UNREACHABLE(__LOC__)
    }
    vec_decl.set_expr_til_type(Type.Struct("Vec"))
    vec_decl.add_child(own new_call)
    return vec_decl
}

build_builtin_vec_push := func(fcall: Expr, scope: TypeScope, vec_name: Str, j: U32) returns Expr {
    mut push_call := make_ns_call("Vec", "push", Type.None, fcall)

    mut self_id := Expr.new(ident_node(vec_name), fcall.line, fcall.col)
    self_id.set_expr_til_type(Type.Struct("Vec"))
    push_call.add_child(own self_id)

    ref val_in : Expr = fcall.child(j.add(2))
    mut val := val_in.clone()
    if val_in.node_type.is(NodeType.Ident).or(val_in.node_type.is(NodeType.FieldAccess)) {
        tname := type_to_name(val_in.expr_til_type())
        if tname.len().gt(0) {
            val = make_clone_call(tname, val_in.expr_til_type(), val_in, val_in)
        }
    }
    push_call.add_child(own val)

    sync_own_args_from_callee(push_call, scope)
    return push_call
}

rewrite_collection_fcall_to_ident := func(mut fcall: Expr, coll_name: Str, coll_type: Type) {
    mut old_args := Vec.new(Expr)
    old_args.move_from(fcall.children)
    fcall.children = Vec.new(Expr)
    Vec.delete(own old_args, true)
    fcall.node_type = ident_node(coll_name)
    fcall.set_expr_til_type(coll_type)
}

desugar_array_vec_fcall := func(mut ctx: Context, mut fcall: Expr, mut new_ch: Vec, mut scope: TypeScope) returns Bool {
    switch fcall.node_type {
    case NodeType.FCall:
        if fcall.children.len().lt(2) { return false }
        ref callee : Expr = fcall.child(0)
        switch callee.node_type {
        case NodeType.Ident(cn):
            cn_str := cn.ident_name()
            if cn_str.eq("vec").or(cn_str.eq("array")).not() { return false }
            ref child1 : Expr = fcall.child(1)
            switch child1.node_type {
            case NodeType.Literal(Literal.Str(elem_type)):
                count : U32 = fcall.children.len().sub(2)
                if cn_str.eq("vec") {
                    vec_name := "_vec_".concat(ctx.coll_counter.to_str())
                    ctx.coll_counter++
                    mut vec_decl := fcall.build_builtin_vec_decl(scope, elem_type, vec_name, ctx)
                    scope.set(vec_name, Type.Struct("Vec"), FuncType.None, true, ctx.path, fcall.line, fcall.col, false, OwnType.Own)
                    new_ch.push(own vec_decl)
                    for j in 0..count {
                        mut push_call := fcall.build_builtin_vec_push(scope, vec_name, j)
                        new_ch.push(own push_call)
                    }
                    rewrite_collection_fcall_to_ident(fcall, vec_name, Type.Struct("Vec"))
                    return true
                }
                arr_name := "_array_".concat(ctx.coll_counter.to_str())
                ctx.coll_counter++
                mut arr_decl := build_variadic_array_decl(fcall, scope, elem_type, arr_name, count, ctx)
                scope.set(arr_name, Type.Struct("Array"), FuncType.None, false, ctx.path, fcall.line, fcall.col, false, OwnType.Own)
                new_ch.push(own arr_decl)
                for j in 0..count {
                    mut setter := build_variadic_array_set(fcall, scope, arr_name, 2, j, ctx)
                    new_ch.push(own setter)
                }
                rewrite_collection_fcall_to_ident(fcall, arr_name, Type.Struct("Array"))
                return true
            case:
                UNREACHABLE(__LOC__)
            }
        case:
        }
        return false
    case:
        UNREACHABLE(__LOC__)
        return false
    }
}

desugar_array_vec_decl := func(stmt: Expr, mut new_ch: Vec, mut scope: TypeScope, ctx: Context) returns Bool {
    if stmt.node_type.is(NodeType.Decl).not().or(stmt.children.len().eq(0)) { return false }
    ref rhs : Expr = stmt.child(0)
    if rhs.node_type.is(NodeType.FCall).not() { return false }

    mut var_name := ""
    switch stmt.node_type {
    case NodeType.Decl(stmt_decl):
        var_name = stmt_decl.name.clone()
    case:
        UNREACHABLE(__LOC__)
        return false
    }

    ref callee : Expr = rhs.child(0)
    switch callee.node_type {
    case NodeType.Ident(cn):
        if cn.ident_name().eq("vec") {
            if rhs.children.len().lt(2) { return false }
            ref child1 : Expr = rhs.child(1)
            switch child1.node_type {
            case NodeType.Literal(Literal.Str(elem_type)):
                count : U32 = rhs.children.len().sub(2)
                mut vec_decl := rhs.build_builtin_vec_decl(scope, elem_type, var_name, ctx)
                vec_decl.set_expr_til_type(Type.Struct("Vec"))
                switch vec_decl.node_type {
                case NodeType.Decl(dd):
                    dd.is_mut = true
                case:
                }
                scope.set(var_name, Type.Struct("Vec"), FuncType.None, true, ctx.path, stmt.line, stmt.col, false, OwnType.Shallow)
                new_ch.push(own vec_decl)
                for j in 0..count {
                    mut push_call := rhs.build_builtin_vec_push(scope, var_name, j)
                    new_ch.push(own push_call)
                }
                return true
            case:
                UNREACHABLE(__LOC__)
            }
        }
        if cn.ident_name().eq("array") {
            if rhs.children.len().lt(2) { return false }
            ref child1 : Expr = rhs.child(1)
            switch child1.node_type {
            case NodeType.Literal(Literal.Str(elem_type)):
                count : U32 = rhs.children.len().sub(2)
                mut arr_decl := build_variadic_array_decl(rhs, scope, elem_type, var_name, count, ctx)
                arr_decl.set_expr_til_type(Type.Struct("Array"))
                scope.set(var_name, Type.Struct("Array"), FuncType.None, true, ctx.path, stmt.line, stmt.col, false, OwnType.Shallow)
                new_ch.push(own arr_decl)
                for j in 0..count {
                    mut setter := build_variadic_array_set(rhs, scope, var_name, 2, j, ctx)
                    new_ch.push(own setter)
                }
                return true
            case:
                UNREACHABLE(__LOC__)
            }
        }
    case:
    }
    return false
}

// Returns true if the call constructed replacement stmts and pushed them
// to new_ch; false if the original stmt should be kept (caller pushes it).
desugar_set_literal_decl := proc(stmt: Expr, mut new_ch: Vec, mut scope: TypeScope, ctx: Context) returns Bool {
    ref set_lit : Expr = stmt.child(0)
    mut var_name := ""
    switch stmt.node_type {
    case NodeType.Decl(stmt_decl):
        var_name = stmt_decl.name.clone()
    case:
        UNREACHABLE(__LOC__)
        return false
    }

    if set_lit.children.len().eq(0) {
        set_lit.type_error("set literal must have at least one element", ctx)
        return false
    }

    ref first : Expr = set_lit.child(0)
    elem_type := type_to_name(first.expr_til_type())
    if elem_type.len().eq(0) {
        first.type_error("set literal: cannot determine element type", ctx)
        return false
    }

    if type_has_cmp(scope, elem_type).not() {
        first.type_error("set literal: element type '".concat(elem_type).concat("' must implement cmp"), ctx)
    }

    for j in 1..set_lit.children.len() {
        ref v : Expr = set_lit.child(j)
        vt := type_to_name(v.expr_til_type())
        if vt.len().eq(0).or(vt.eq(elem_type).not()) {
            v.type_error("set literal: all elements must be the same type", ctx)
        }
    }

    mut new_call := make_ns_call("Set", "new", Type.Struct("Set"), set_lit)
    mut et := set_lit.make_til_type_expr(first.expr_til_type())
    new_call.add_child(own et)

    mut decl := Expr.new(NodeType.Decl(Declaration()), stmt.line, stmt.col)
    switch decl.node_type {
    case NodeType.Decl(dd):
        dd.name = var_name.clone()
        dd.is_mut = true
    case:
        UNREACHABLE(__LOC__)
    }
    decl.set_expr_til_type(Type.Struct("Set"))
    decl.add_child(own new_call)

    scope.set(var_name, Type.Struct("Set"), FuncType.None, true, ctx.path, stmt.line, stmt.col, false, OwnType.Shallow)

    new_ch.push(own decl)

    for e_j : Expr in set_lit.children {
        mut add_call := make_ns_call("Set", "add", Type.None, set_lit)
        mut self_id := Expr.new(ident_node(var_name), set_lit.line, set_lit.col)
        self_id.set_expr_til_type(Type.Struct("Set"))
        add_call.add_child(own self_id)
        mut val := e_j.clone()
        add_call.add_child(own val)
        sync_own_args_from_callee(add_call, scope)
        new_ch.push(own add_call)
    }
    return true
}

// Returns true if the call constructed replacement stmts and pushed them
// to new_ch; false if the original stmt should be kept (caller pushes it).
desugar_map_literal_decl := proc(stmt: Expr, mut new_ch: Vec, mut scope: TypeScope, ctx: Context) returns Bool {
    ref map_lit : Expr = stmt.child(0)
    mut var_name := ""
    switch stmt.node_type {
    case NodeType.Decl(stmt_decl):
        var_name = stmt_decl.name.clone()
    case:
        UNREACHABLE(__LOC__)
        return false
    }
    n_pairs := map_lit.children.len().div(2)

    if map_lit.children.len().eq(0) {
        map_lit.type_error("map literal must have at least one entry", ctx)
        return false
    }
    if map_lit.children.len().mod(2).eq(0).not() {
        map_lit.type_error("map literal has mismatched key/value pairs", ctx)
        return false
    }

    ref first_key : Expr = map_lit.child(0)
    ref first_val : Expr = map_lit.child(1)
    key_type := type_to_name(first_key.expr_til_type())
    val_type := type_to_name(first_val.expr_til_type())

    if key_type.len().eq(0) {
        first_key.type_error("map literal: cannot determine key type", ctx)
        return false
    }
    if val_type.len().eq(0) {
        first_val.type_error("map literal: cannot determine value type", ctx)
        return false
    }

    if type_has_cmp(scope, key_type).not() {
        first_key.type_error("map literal: key type '".concat(key_type).concat("' must implement cmp"), ctx)
    }

    for j in 2..map_lit.children.len() {
        if j.mod(2).eq(0) {
            ref k : Expr = map_lit.child(j)
            kt := type_to_name(k.expr_til_type())
            if kt.len().eq(0).or(kt.eq(key_type).not()) {
                k.type_error("map literal: all keys must be the same type", ctx)
            }
        } else {
            ref v : Expr = map_lit.child(j)
            vt := type_to_name(v.expr_til_type())
            if vt.len().eq(0).or(vt.eq(val_type).not()) {
                v.type_error("map literal: all values must be the same type", ctx)
            }
        }
    }

    mut new_call := make_ns_call("Map", "new", Type.Struct("Map"), map_lit)
    mut kt := map_lit.make_til_type_expr(first_key.expr_til_type())
    new_call.add_child(own kt)
    mut vt := map_lit.make_til_type_expr(first_val.expr_til_type())
    new_call.add_child(own vt)

    mut decl := Expr.new(NodeType.Decl(Declaration()), stmt.line, stmt.col)
    switch decl.node_type {
    case NodeType.Decl(dd):
        dd.name = var_name.clone()
        dd.is_mut = true
    case:
        UNREACHABLE(__LOC__)
    }
    decl.set_expr_til_type(Type.Struct("Map"))
    decl.add_child(own new_call)

    scope.set(var_name, Type.Struct("Map"), FuncType.None, true, ctx.path, stmt.line, stmt.col, false, OwnType.Shallow)

    new_ch.push(own decl)

    for j in 0..n_pairs {
        mut set_call := make_ns_call("Map", "set", Type.None, map_lit)
        mut self_id := Expr.new(ident_node(var_name), map_lit.line, map_lit.col)
        self_id.set_expr_til_type(Type.Struct("Map"))
        set_call.add_child(own self_id)
        mut key := map_lit.child(j.mul(2)).clone()
        set_call.add_child(own key)
        mut mval := map_lit.child(j.mul(2).add(1)).clone()
        set_call.add_child(own mval)
        sync_own_args_from_callee(set_call, scope)
        new_ch.push(own set_call)
    }
    return true
}

// Combine desugar_set_literals and desugar_map_literals: both filter on
// Decl + SetLit/MapLit rhs at the body's top level, both rebuild
// body.children, and both end with reregister_scope_defs (which is O(N*K)
// over body decls and scope bindings). Sharing the prefilter, rebuild,
// and reregister halves that cost when both transformations apply, and
// drops one walk + one reregister even when only one applies.
// Apply the array/vec, variadic, and kwargs desugars to a single stmt (in
// place). Prepends helper decls/setters to new_ch as needed and rewrites the
// discovered fcall(s) in place. Caller is responsible for pushing the
// (possibly-mutated) stmt to new_ch afterwards.
// Desugar every array/vec, variadic, and kwargs fcall reachable from stmt in a
// single post-order walk. Children are processed before their parent,
// so by the time we build a parent's setter (which clones a variadic
// arg) the inner fcall has already been rewritten in place. That
// covers nested fcalls in one walk, and sibling fcalls naturally fall
// out of the children iteration -- no recursion on setters and no
// repeated find_*_fcall scans. #186 / #188 / #189 all came from the
// same root cause (single-pass-per-stmt instead of full traversal).
//
// Note: the traversal mirrors the recursion guards used by
// find_array_vec_fcall / find_variadic_fcall / find_kwargs_fcall (FuncDef / StructDef /
// EnumDef / Body) so a body-level walk doesn't dive into a nested
// function definition or nested block, which the outer body_pre_passes
// pass will reach separately.
process_call_desugars := func(mut ctx: Context, mut e: Expr, mut new_ch: Vec, mut scope: TypeScope, has_array_vec: Bool, has_variadic: Bool, has_kwargs: Bool) {
    if e.is_null() { return }
    if e.node_type.is(NodeType.FuncDef) { return }
    if e.node_type.is(NodeType.StructDef) { return }
    if e.node_type.is(NodeType.EnumDef) { return }
    if e.node_type.is(NodeType.Body) { return }

    for e_i : Expr in e.children {
        process_call_desugars(ctx, e_i, new_ch, scope, has_array_vec, has_variadic, has_kwargs)
    }

    switch e.node_type {
    case NodeType.FCall:
        if has_array_vec {
            if desugar_array_vec_fcall(ctx, e, new_ch, scope) { return }
        }
        if has_variadic.and(fcall_callee_has_variadic_via_scope(e, scope)) {
            mut skip := false
            switch e.child(0).node_type {
            case NodeType.Ident(cn):
                cn_str := cn.ident_name()
                if cn_str.eq("array").or(cn_str.eq("vec")) { skip = true }
            case:
            }
            if skip.not() {
                // Resolve callee once via scope to derive the per-call
                // variadic block position and arg count; thread them
                // into both the pure-splat detector and the
                // array-wrapping rewrite so neither needs to re-resolve.
                vi := fcall_variadic_index_via_scope(e, scope)
                vc := fcall_variadic_count_via_scope(e, scope)
                if desugar_pure_splat_variadic_call(e, vi, vc).not() {
                    line := e.line
                    col := e.col
                    ref elem_type : Str = resolve_variadic_elem_type(e, scope)
                    // elem_type-null here means the typer already
                    // reported an error upstream; just leave the
                    // fcall raw rather than emit a half-formed wrap.
                    if elem_type.is_null().not() {
                        va_name := "_va_Array_".concat(ctx.va_counter.to_str())
                        ctx.va_counter++
                        mut va_decl := build_variadic_array_decl(e, scope, elem_type, va_name, vc, ctx)
                        scope.set(va_name, Type.Struct("Array"), FuncType.None, false, ctx.path, line, col, false, OwnType.Own)
                        new_ch.push(own va_decl)
                        for j in 0..vc {
                            mut setter := build_variadic_array_set(e, scope, va_name, vi, j, ctx)
                            new_ch.push(own setter)
                        }
                        rewrite_variadic_fcall_args(e, va_name, vi, vc)
                    }
                }
            }
        }
        if has_kwargs {
            ki := fcall_kwargs_index_via_scope(e, scope)
            if ki.gte(0) {
                kc := fcall_kwargs_count(e)
                kw_name := "_kw".concat(ctx.kw_counter.to_str())
                ctx.kw_counter++
                kw_decl := build_kwargs_dynmap_decl(e, kw_name)
                scope.set(kw_name, Type.Struct("DynMap"), FuncType.None, false, ctx.path, e.line, e.col, false, OwnType.Shallow)
                new_ch.push(own kw_decl)
                for j in 0..kc {
                    ref named_arg : Expr = e.child(ki.add(j.cast(I32)).to_usize())
                    mut setter := build_kwargs_dynmap_set(e, scope, kw_name, named_arg, ctx)
                    new_ch.push(own setter)
                }
                rewrite_kwargs_fcall_args(e, kw_name, ki)
            }
        }
    case:
    }
}

// Single-walk merger of the three former pre-passes infer_body used to
// run back-to-back: desugar_body (set/map literal + array/vec/variadic/
// kwargs call), hoist_fcall_args, and insert_field_deletes. Issue #146 /
// #158: one prefilter, one move-out + rebuild + move-back, one
// reregister_scope_defs.
//
// Per stmt the order is fixed:
//   1. top-level desugar (Decl-with-SetLit/MapLit/array-vec-rhs -> N stmts)
//   2. call-level desugar (variadic/kwargs/array-vec inside an FCall;
//      prepends temp setups to new_ch)
//   3. hoist (pulls complex FCall args / RHSs into temp Decls; prepended)
//   4. field-delete (prepends a delete call before a FieldAssign whose
//      old payload owns a non-trivial type)
//
// owns_scope gates desugar and hoist (both register temp Decls in scope
// so the body must own a scope); field_delete runs unconditionally,
// matching the previous standalone insert_field_deletes pass.
//
// Compile directives (link / link_c / import) flow through untouched:
// the call-desugar walk is a no-op on them, the hoist switch's default
// case skips them, and field_delete is FieldAssign-only.
priv body_pre_passes := proc(mut ctx: Context, mut body: Expr, mut scope: TypeScope, owns_scope: I32) returns Bool {
    mut has_set_lit := false
    mut has_map_lit := false
    mut has_array_vec := false
    mut has_variadic := false
    mut has_kwargs := false
    mut needs_delete := false
    for stmt : Expr in body.children {
        if owns_scope.neq(0) {
            if stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0)) {
                ref rhs : Expr = stmt.child(0)
                if rhs.node_type.is(NodeType.SetLit) { has_set_lit = true }
                if rhs.node_type.is(NodeType.MapLit) { has_map_lit = true }
            }
            if has_array_vec.not() {
                if find_array_vec_fcall(stmt).is_null().not() { has_array_vec = true }
            }
            if has_variadic.not() {
                if find_variadic_fcall(stmt, scope).is_null().not() { has_variadic = true }
            }
            if has_kwargs.not() {
                if find_kwargs_fcall(stmt, scope).is_null().not() { has_kwargs = true }
            }
        }
        if needs_delete.not().and(stmt.node_type.is(NodeType.FieldAssign)) {
            if field_assign_needs_delete(stmt, scope) {
                ref fa_rhs : Expr = stmt.child(1)
                if type_to_name(fa_rhs.expr_til_type()).len().gt(0) {
                    needs_delete = true
                }
            }
        }
    }
    has_desugar := has_set_lit.or(has_map_lit).or(has_array_vec).or(has_variadic).or(has_kwargs)
    do_hoist := owns_scope.neq(0)
    if has_desugar.not().and(do_hoist.not()).and(needs_delete.not()) {
        return false
    }

    mut old := Vec.new(Expr)
    old.move_from(body.children)

    mut new_ch := Vec.new(Expr)
    for i in 0..old.len() {
        ref stmt : Expr = old[i]

        // (1) Top-level desugar: may emit N replacement stmts. Each
        // emitted stmt can itself contain variadic/kwargs fcalls or
        // need hoisting, so we route every emitted stmt through the
        // per-stmt pipeline below.
        mut temp_ch := Vec.new(Expr)
        mut stmt_handled := false
        if has_desugar {
            if stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0)) {
                ref rhs : Expr = stmt.child(0)
                if has_set_lit.and(rhs.node_type.is(NodeType.SetLit)) {
                    if desugar_set_literal_decl(stmt, temp_ch, scope, ctx) {
                        stmt_handled = true
                    }
                } else if has_map_lit.and(rhs.node_type.is(NodeType.MapLit)) {
                    if desugar_map_literal_decl(stmt, temp_ch, scope, ctx) {
                        stmt_handled = true
                    }
                } else if has_array_vec.and(rhs.node_type.is(NodeType.FCall)) {
                    if desugar_array_vec_decl(stmt, temp_ch, scope, ctx) {
                        stmt_handled = true
                    }
                }
            }
        }

        if stmt_handled {
            for j in 0..temp_ch.len() {
                ref ts : Expr = temp_ch[j]
                apply_call_hoist_delete(ctx, ts, new_ch, scope, has_array_vec, has_variadic, has_kwargs, do_hoist, needs_delete)
                new_ch.push_take(temp_ch, j)
            }
        } else {
            apply_call_hoist_delete(ctx, stmt, new_ch, scope, has_array_vec, has_variadic, has_kwargs, do_hoist, needs_delete)
            new_ch.push_take(old, i)
        }
        Vec.delete(own temp_ch, true)
    }
    body.children.move_from(new_ch)
    // Free the two scratch buffers (like temp_ch above). move_from zeroed
    // new_ch.count, and every slot moved out of old was zeroed by
    // push_take, so the only elements Vec.delete drops are old's
    // desugar-replaced husks -- dead AST whose contents already moved into
    // the emitted stmts. call_free is false: the Vec values are locals.
    Vec.delete(own new_ch, true)
    Vec.delete(own old, true)
    return true
}

// Apply per-stmt hoist (the body_pre_passes equivalent of the old
// hoist_fcall_args dispatch). Prepends any new temp Decls to new_ch.
apply_hoist_to_stmt := proc(mut ctx: Context, mut stmt: Expr, mut new_ch: Vec, mut scope: TypeScope) {
    mut hoisted := Vec.new(Expr)
    switch stmt.node_type {
    case NodeType.Decl:
        hoist_decl_rhs(ctx, stmt, hoisted, scope)
    case NodeType.FCall:
        hoist_stmt_fcall(ctx, stmt, hoisted, scope)
    case NodeType.Return:
        hoist_return_expr(ctx, stmt, hoisted, scope)
    case NodeType.Assign:
        hoist_assign_rhs(ctx, stmt, hoisted, scope)
        hoist_param_swap_assign(ctx, stmt, hoisted, scope)
    case NodeType.FieldAssign:
        hoist_field_assign_rhs(ctx, stmt, hoisted, scope)
    case NodeType.If:
        hoist_if_cond(ctx, stmt, hoisted, scope)
    case:
        // NodeType.While: skip condition -- hoisting changes loop semantics
    }
    new_ch.append(own hoisted)
}

// Per-stmt pipeline: call-desugar, hoist, field-delete. Each step
// prepends any helper decls/setters/deletes to new_ch; the caller is
// responsible for pushing the (possibly-rewritten) stmt itself.
//
// Setter stmts emitted by call-desugar (Array.set / DynMap.set) can
// themselves contain FCalls whose args need hoisting (e.g.
// Array.set(va, idx, I64.to_str(x.to_i64())) -- the inner I64 value
// must be hoisted into a temp Decl so the builder takes its address).
// To match the original two-pass flow, every desugar-emitted stmt is
// routed through hoist before being pushed.
apply_call_hoist_delete := proc(mut ctx: Context, mut stmt: Expr, mut new_ch: Vec, mut scope: TypeScope, has_array_vec: Bool, has_variadic: Bool, has_kwargs: Bool, do_hoist: Bool, needs_delete: Bool) {
    if is_compile_directive(stmt) { return }
    if has_array_vec.or(has_variadic).or(has_kwargs) {
        mut emitted := Vec.new(Expr)
        process_call_desugars(ctx, stmt, emitted, scope, has_array_vec, has_variadic, has_kwargs)
        for j in 0..emitted.len() {
            ref es : Expr = emitted[j]
            if do_hoist { apply_hoist_to_stmt(ctx, es, new_ch, scope) }
            new_ch.push_take(emitted, j)
        }
        Vec.delete(own emitted, true)
    }
    if do_hoist {
        apply_hoist_to_stmt(ctx, stmt, new_ch, scope)
    }
    if needs_delete.and(stmt.node_type.is(NodeType.FieldAssign)) {
        if field_assign_needs_delete(stmt, scope) {
            ref rhs : Expr = stmt.child(1)
            if type_to_name(rhs.expr_til_type()).len().gt(0) {
                switch stmt.node_type {
                case NodeType.FieldAssign(fad):
                    fad.save_old_delete = true
                case:
                }
            }
        }
    }
}

hoist_param_swap_assign := func(mut ctx: Context, mut stmt: Expr, mut hoisted: Vec, mut scope: TypeScope) {
    mut stmt_name := ""
    switch stmt.node_type {
    case NodeType.Assign(adata):
        stmt_name = adata.name.clone()
    case:
        return
    }
    sf := scope.find(stmt_name)
    switch sf {
    case ScopeFind.Found(ab):
        if ab.is_param.not() { return }
        if ab.is_mut.not() { return }
        // Issue #205: only rewrite for compound aggregates -- primitives
        // (incl. those modelled as Type.Struct("I32")) keep value semantics
        // and don't need the swap dance.
        if is_aggregate(ab.type).not() { return }

        mut call := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col)
        call.set_expr_til_type(Type.None)
        mut fn := Expr.new(ident_node("swap"), stmt.line, stmt.col)
        call.add_child(own fn)
        mut a := Expr.new(ident_node(stmt_name), stmt.line, stmt.col)
        a.set_expr_til_type(ab.type)
        call.add_child(own a)
        call.add_child(own stmt.child(0).clone())
        tname := type_to_name(ab.type)
        mut sz_call := make_ns_call(tname, "size", usize_type(scope, ctx), stmt)
        mut sz := hoist_to_temp(ctx, sz_call, hoisted, scope, false)
        call.add_child(own sz)
        stmt = call
    case:
    }
}

// Issue #109: is FCall `expr` an enum variant constructor whose param
// at arg index `i` (1-based: child(i)) is Own? The callee is a
// FieldAccess `EnumName.Variant`. Resolves the enum def, finds the
// variant ctor FuncDef in its ns_decls, and reads param[i-1].own_type.
// Used by the hoist pass to mark the hoisted-temp arg Own independently
// of the per-call own_arg bit (which the auto-own pass may not have
// reached on a synthesized/hoisted call).
fcall_variant_ctor_arg_is_own := func(expr: Expr, i: U32, scope: TypeScope) returns Bool {
    if expr.node_type.is(NodeType.FCall).not() { return false }
    if expr.children.len().lt(2) { return false }
    ref callee : Expr = expr.child(0)
    if callee.node_type.is(NodeType.FieldAccess).not() { return false }
    if callee.children.len().eq(0) { return false }
    mut method := ""
    switch callee.node_type {
    case NodeType.FieldAccess(fad): method = fad.field_access_name()
    case: return false
    }
    ref type_node : Expr = callee.child(0)
    mut tn := ""
    switch type_node.node_type {
    case NodeType.Ident(idd): tn = idd.ident_name()
    case: return false
    }
    ref sdef : Expr = scope.get_struct(tn)
    if sdef.is_null() { return false }
    if sdef.node_type.is(NodeType.EnumDef).not() { return false }
    ref vc_ns : Vec = def_ns_decls(sdef)
    for fd : Declaration in vc_ns {
        if fd.name.eq(method).not() { continue }
        if fd.default_value.is_null() { return false }
        if fd.default_value.node_type.is(NodeType.FuncDef).not() { return false }
        switch fd.default_value.node_type {
        case NodeType.FuncDef(vfd):
            if vfd.is_enum_variant_ctor.not() { return false }
            pidx := i.sub(1)
            if pidx.gte(vfd.params.len()) { return false }
            ref vp : Declaration = vfd.params[pidx]
            return vp.own_type.is(OwnType.Own)
        case: return false
        }
    }
    return false
}

hoist_expr := proc(mut ctx: Context, mut expr: Expr, mut hoisted: Vec, mut scope: TypeScope) {
    if expr.node_type.is(NodeType.FuncDef) { return }
    if expr.node_type.is(NodeType.StructDef) { return }
    if expr.node_type.is(NodeType.EnumDef) { return }
    if expr.node_type.is(NodeType.Body) { return }

    for e_i : Expr in expr.children {
        hoist_expr(ctx, e_i, hoisted, scope)
    }
    if expr.node_type.is(NodeType.FCall).not() { return }
    // Issue #57: don't hoist args of macro calls. Macro args are
    // substituted into the macro body at compile time by precomp's
    // try_eval_call; hoisting an arg into a body-local temp burys its
    // value behind a name that the macro eval's sub-scope can't resolve.
    // Match rstil's pattern: macros take args verbatim (precomp.rs 821-847
    // builds the call with Identifier args, not via the hoister).
    if is_macro_call(expr, ctx) { return }

    expr_sname := til_type_name(expr.expr_til_type())
    mut is_dyn_call := false
    mut is_array_vec := false
    mut is_ctor_call := false
    if expr.children.len().gt(0) {
        ref callee : Expr = expr.child(0)
        switch callee.node_type {
        case NodeType.Ident(cn):
            if expr_sname.len().gt(0).and(cn.ident_name().eq(expr_sname)) {
                is_ctor_call = true
            }
            cn_str := cn.ident_name()
            if cn_str.eq("dyn_call") { is_dyn_call = true }
            if cn_str.eq("dyn_call_ret") { is_dyn_call = true }
            if cn_str.eq("dyn_has_method") { is_dyn_call = true }
            if cn_str.eq("dyn_fn") { is_dyn_call = true }
            if cn_str.eq("array") { is_array_vec = true }
            if cn_str.eq("vec") { is_array_vec = true }
        case:
        }
    }
    ref hoist_sdef : Expr = scope.get_struct(expr_sname)

    mut fi : USize = 0
    for i in 1..expr.children.len() {
        if is_dyn_call {
            if i.eq(2).or(i.eq(3)) { continue }
        }
        if is_array_vec {
            if i.eq(1) { continue }
        }

        ref arg : Expr = expr.child(i)
        mut hoist_fi := fi
        if is_ctor_call.and(hoist_sdef.is_null().not()) {
        if hoist_sdef.node_type.is(NodeType.StructDef) {
            fi = fi.add(1)
        }
        }
        if arg.node_type.is(NodeType.FCall).not() {
            if arg.node_type.is_nonnull_literal().not() {
                continue
            }
        }

        mut slot_is_own := false
        if is_ctor_call.and(hoist_sdef.is_null().not()) {
        switch hoist_sdef.node_type {
        case NodeType.StructDef(h_sdd):
            mut fld_own := OwnType.Shallow
            mut field_type := Type.None
            if hoist_fi.lt(h_sdd.fields.len()) {
                ref h_fd : Declaration = h_sdd.fields[hoist_fi]
                fld_own = h_fd.own_type
                field_type = h_fd.til_type
            }
            if fld_own.is(OwnType.Own).not() {
                // Issue #201: skip hoisting a heap-returning arg into an
                // owned temp when it flows into a non-own aggregate field.
                // The builder's inline `{ T *_ca = ...; field = *_ca;
                // free(_ca); }` path transfers ownership correctly; a
                // hoisted temp would Str_delete the value AND leave the
                // field pointing at the freed storage (double-free). Check
                // both the field's static type and the arg's runtime type,
                // and treat Type.Custom (unresolved cross-file name) as
                // aggregate.
                if is_aggregate(field_type).or(field_type.is(Type.Custom)) {
                    continue
                }
                arg_type := arg.expr_til_type()
                if is_aggregate(arg_type).or(arg_type.is(Type.Custom)) {
                    continue
                }
            }
            slot_is_own = fld_own.is(OwnType.Own)
        case:
            slot_is_own = get_own_arg(expr, i)
        }
        } else if is_ctor_call {
            // Ctor for a type whose StructDef isn't reachable in this
            // scope (defined later in the same file or behind a circular
            // import). Without field metadata we can't decide ownership
            // safely; skip hoisting and let the builder's inline field
            // assign emit the ownership transfer.
            continue
        } else {
            slot_is_own = get_own_arg(expr, i)
        }
        // Issue #109: enum variant constructors (callee is a FieldAccess
        // `EnumName.Variant`, not a bare Ident, so is_ctor_call is false)
        // take their compound payload Own. The auto-own bit may not have
        // reached this synthesized/hoisted call, so resolve the variant
        // ctor's param ownership directly here rather than trusting
        // get_own_arg -- otherwise the hoisted temp stays a stack value
        // and the Own ctor body free()s a stack address.
        if slot_is_own.not().and(fcall_variant_ctor_arg_is_own(expr, i, scope)) {
            slot_is_own = true
            // Also set the call's own_arg bit -- the builder reads it
            // (not the temp's own_type) to decide malloc-wrap vs `&`.
            set_own_arg(expr, i)
        }

        expr.children.set(i, own hoist_to_temp(ctx, arg, hoisted, scope, slot_is_own))
    }
}

hoist_decl_rhs := proc(mut ctx: Context, stmt: Expr, mut hoisted: Vec, mut scope: TypeScope) {
    hoist_expr(ctx, stmt.child(0), hoisted, scope)
}

hoist_if_cond := proc(mut ctx: Context, mut stmt: Expr, mut hoisted: Vec, mut scope: TypeScope) {
    hoist_expr(ctx, stmt.child(0), hoisted, scope)
    ref cond : Expr = stmt.child(0)
    if cond.node_type.is(NodeType.FCall) {
        stmt.children.set(0, own hoist_to_temp(ctx, cond, hoisted, scope, false))
    }
}

hoist_return_expr := proc(mut ctx: Context, mut stmt: Expr, mut hoisted: Vec, mut scope: TypeScope) {
    if stmt.children.len().eq(0) { return }
    hoist_expr(ctx, stmt.child(0), hoisted, scope)
    ref rhs : Expr = stmt.child(0)
    if rhs.node_type.is(NodeType.FCall)
    .or(rhs.node_type.is_nonnull_literal()) {
        replacement := hoist_to_temp(ctx, rhs, hoisted, scope, false)
        ref slot_hoist : Expr = stmt.children[0]
        slot_hoist.free_expr_slot_in_place()
        stmt.children.set(0, own replacement)
    }
}

hoist_assign_rhs := proc(mut ctx: Context, mut stmt: Expr, mut hoisted: Vec, mut scope: TypeScope) {
    hoist_expr(ctx, stmt.child(0), hoisted, scope)
    mut do_hoist := true
    mut a_name := ""
    switch stmt.node_type {
    case NodeType.Assign(adata):
        a_name = adata.name.clone()
    case:
        UNREACHABLE(__LOC__)
    }
    sf := scope.find(a_name)
    switch sf {
    case ScopeFind.Found(ab):
        if ab.is_param.not() {
            if is_aggregate(ab.type) {
                do_hoist = false
            }
        }
    case:
    }
    ref rhs : Expr = stmt.child(0)
    if do_hoist.and(
        rhs.node_type.is(NodeType.FCall)
        .or(rhs.node_type.is_nonnull_literal())
    ) {
        stmt.children.set(0, own hoist_to_temp(ctx, rhs, hoisted, scope, false))
    }
}

hoist_field_assign_rhs := proc(mut ctx: Context, mut stmt: Expr, mut hoisted: Vec, mut scope: TypeScope) {
    hoist_expr(ctx, stmt.child(1), hoisted, scope)
    mut fa_hoist := true
    if stmt.fa_own_type(scope).is(OwnType.Shallow) {
        rhs_type := stmt.child(1).expr_til_type()
        if is_aggregate(rhs_type) {
            fa_hoist = false
        }
    }
    ref rhs : Expr = stmt.child(1)
    if fa_hoist.and(
        rhs.node_type.is(NodeType.FCall)
        .or(rhs.node_type.is_nonnull_literal())
    ) {
        stmt.children.set(1, own hoist_to_temp(ctx, rhs, hoisted, scope, false))
    }
}

hoist_stmt_fcall := proc(mut ctx: Context, mut stmt: Expr, mut hoisted: Vec, mut scope: TypeScope) {
    hoist_expr(ctx, stmt, hoisted, scope)
    // Stmt-level FCalls whose result is None or non-Own don't need the
    // hoist-into-temp dance: nothing on the heap to clean up, so the
    // call can stay as a bare FCall stmt. Only Own returns require the
    // wrap so the matching delete frees the heap box.
    if stmt.expr_til_type().is(Type.None) { return }
    if fcall_returns_own(stmt, scope).not() { return }
    hoist_to_temp(ctx, stmt, hoisted, scope, false)
    popped : Expr = hoisted.pop()
    stmt = popped
}

rewrite_variadic_fcall_args := func(mut fcall: Expr, va_name: Str, vi: I32, vc: USize) {
    switch fcall.node_type {
    case NodeType.FCall(fcall_data):
        old_own := fcall_data.own_args
        line := fcall.line
        col := fcall.col
        mut old_args := Vec.new(Expr)
        old_args.move_from(fcall.children)
        mut fcall_new_ch := Vec.new(Expr)
        mut va_inserted := false
        mut new_own : U64 = 0
        for j in 0..old_args.len() {
            if j.cast(I32).gte(vi).and(j.cast(I32).lt(vi.add(vc.cast(I32)))) {
                if va_inserted.not() {
                    mut va_id := Expr.new(ident_node(va_name), line, col)
                    va_id.set_expr_til_type(Type.Struct("Array"))
                    mut bit : U64 = 1
                    for _ in 0..fcall_new_ch.len() { bit = bit.mul(2) }
                    new_own = new_own.bor(bit)
                    fcall_new_ch.push(own va_id)
                    va_inserted = true
                }
                continue
            }
            if j.cast(I32).eq(vi).and(va_inserted.not()) {
                mut va_id := Expr.new(ident_node(va_name), line, col)
                va_id.set_expr_til_type(Type.Struct("Array"))
                mut bit : U64 = 1
                for _ in 0..fcall_new_ch.len() { bit = bit.mul(2) }
                new_own = new_own.bor(bit)
                fcall_new_ch.push(own va_id)
                va_inserted = true
            }
            // Transfer own bit from old position j to new position
            mut old_bit : U64 = 1
            for _ in 0..j { old_bit = old_bit.mul(2) }
            if old_own.band(old_bit).gt(0) {
                mut nb : U64 = 1
                for _ in 0..fcall_new_ch.len() { nb = nb.mul(2) }
                new_own = new_own.bor(nb)
            }
            fcall_new_ch.push_take(old_args, j)
        }
        if va_inserted.not() {
            mut va_id := Expr.new(ident_node(va_name), line, col)
            va_id.set_expr_til_type(Type.Struct("Array"))
            mut bit : U64 = 1
            for _ in 0..fcall_new_ch.len() { bit = bit.mul(2) }
            new_own = new_own.bor(bit)
            fcall_new_ch.push(own va_id)
        }
        fcall.children.move_from(fcall_new_ch)
        fcall_data.own_args = new_own
    case:
        UNREACHABLE(__LOC__)
    }
}

// A stmt can contain BOTH a variadic fcall and a kwargs fcall (rare,
// but legal -- e.g. f(1, 2, k=v) where 1,2 are variadic and k=v is
// kwargs); the per-stmt pipeline in body_pre_passes applies variadic
// first then kwargs to the same stmt before pushing, matching the
// original sequential order so the kwargs handling sees the
// variadic-rewritten fcall.
// Scope-resolving wrapper around fcall_variadic_count: looks up the
// callee FuncDef the same way resolve_variadic_elem_type does (Ident
// binding, or Type.method namespace lookup) to recover its param count,
// then derives the per-call variadic arg count. Used by the variadic
// desugar sites (process_call_desugars and the helpers it threads into)
// that don't have the callee fdef_data on hand the way validate/
// infer_and_validate_fcall_args do. Returns 0 if the callee can't be
// resolved -- the desugar then skips the rewrite, same as the
// elem-type-null branch a few lines below.
fcall_variadic_count_via_scope := func(fcall: Expr, scope: TypeScope) returns USize {
    if fcall.children.len().eq(0) { return 0 }
    ref callee : Expr = fcall.child(0)
    switch callee.node_type {
    case NodeType.Ident(callee_name):
        ref cb : TypeBinding = scope.get_binding(callee_name.ident_name())
        if cb.is_null().not() {
            if cb.func_def.is_null().not() {
                switch cb.func_def.node_type {
                case NodeType.FuncDef(cb_fdef):
                    return fcall_variadic_count(fcall, cb_fdef.params.len(), cb_fdef.kwargs_index.gte(0))
                case:
                }
            }
        }
    case NodeType.FieldAccess(method_name):
        if fa_is_ns(callee, scope) {
            ref type_node : Expr = callee.child(0)
            switch type_node.node_type {
            case NodeType.Ident(type_name):
                ref sdef : Expr = scope.get_struct(type_name.ident_name())
                if sdef.is_null().not() {
                    ref ns : Vec = def_ns_decls(sdef)
                    for nd : Declaration in ns {
                        if nd.name.eq(method_name.field_access_name()).not() { continue }
                        if nd.default_value.is_null() { break }
                        switch nd.default_value.node_type {
                        case NodeType.FuncDef(ffd):
                            return fcall_variadic_count(fcall, ffd.params.len(), ffd.kwargs_index.gte(0))
                        case:
                        }
                        break
                    }
                }
            case:
            }
        }
    case:
    }
    return 0
}

// True if the resolved callee declares a variadic parameter.
// Used by find_variadic_fcall and process_call_desugars as the
// per-FCall predicate "needs variadic-block rewrite". No stored
// FCallData state is needed: variadic_index has been derived away,
// and process_call_desugars is the only thing that triggers the
// rewrite, runs at most once per FCall, so distinguishing pre- vs
// post-rewrite is unnecessary at this site.
fcall_callee_has_variadic_via_scope := func(fcall: Expr, scope: TypeScope) returns Bool {
    if fcall.children.len().eq(0) { return false }
    ref callee : Expr = fcall.child(0)
    switch callee.node_type {
    case NodeType.Ident(callee_name):
        ref cb : TypeBinding = scope.get_binding(callee_name.ident_name())
        if cb.is_null().not() {
            if cb.func_def.is_null().not() {
                switch cb.func_def.node_type {
                case NodeType.FuncDef(cb_fdef):
                    return cb_fdef.variadic_index.gte(0)
                case:
                }
            }
        }
    case NodeType.FieldAccess(method_name):
        if fa_is_ns(callee, scope) {
            ref type_node : Expr = callee.child(0)
            switch type_node.node_type {
            case NodeType.Ident(type_name):
                ref sdef : Expr = scope.get_struct(type_name.ident_name())
                if sdef.is_null().not() {
                    ref ns : Vec = def_ns_decls(sdef)
                    for nd : Declaration in ns {
                        if nd.name.eq(method_name.field_access_name()).not() { continue }
                        if nd.default_value.is_null() { break }
                        switch nd.default_value.node_type {
                        case NodeType.FuncDef(ffd):
                            return ffd.variadic_index.gte(0)
                        case:
                        }
                        break
                    }
                }
            case:
            }
        }
    case:
    }
    return false
}

// Per-call position of the variadic block start in fcall.children.
// Derived from the callee: position = 1 + fdef_data.variadic_index
// (callee + params before the variadic param, each contributing one
// child). Returns -1 when the callee has no variadic param. Note this
// is the *expected* position in the post-desugar param-aligned layout;
// it stays meaningful pre-variadic-rewrite (block contains vc args)
// and as a single-child slot post-variadic-rewrite (collapsed to a
// _va_Array_N or splat ident). Caller is responsible for not querying
// after the kwargs rewrite has further shifted children.
fcall_variadic_index_via_scope := func(fcall: Expr, scope: TypeScope) returns I32 {
    if fcall.children.len().eq(0) { return -1 }
    ref callee : Expr = fcall.child(0)
    switch callee.node_type {
    case NodeType.Ident(callee_name):
        ref cb : TypeBinding = scope.get_binding(callee_name.ident_name())
        if cb.is_null().not() {
            if cb.func_def.is_null().not() {
                switch cb.func_def.node_type {
                case NodeType.FuncDef(cb_fdef):
                    fvi := cb_fdef.variadic_index
                    if fvi.lt(0) { return -1 }
                    return fvi.add(1)
                case:
                }
            }
        }
    case NodeType.FieldAccess(method_name):
        if fa_is_ns(callee, scope) {
            ref type_node : Expr = callee.child(0)
            switch type_node.node_type {
            case NodeType.Ident(type_name):
                ref sdef : Expr = scope.get_struct(type_name.ident_name())
                if sdef.is_null().not() {
                    ref ns : Vec = def_ns_decls(sdef)
                    for nd : Declaration in ns {
                        if nd.name.eq(method_name.field_access_name()).not() { continue }
                        if nd.default_value.is_null() { break }
                        switch nd.default_value.node_type {
                        case NodeType.FuncDef(ffd):
                            fvi := ffd.variadic_index
                            if fvi.lt(0) { return -1 }
                            return fvi.add(1)
                        case:
                        }
                        break
                    }
                }
            case:
            }
        }
    case:
    }
    return -1
}

// Scope-resolving derivation of an FCall's kwargs block position.
// kwargs is always the callee's last parameter (parser invariant), so
// post-desugar param-aligned children layout puts the kwargs block at
// `nparam` when the callee has a kwargs param: variadic (if any) has
// already been collapsed by the variadic rewrite that runs first in
// process_call_desugars, so this single formula covers both the
// no-variadic and the post-variadic-rewrite cases. The body-pre-pass
// caller (find_kwargs_fcall) only uses the sign of the result as a
// "has kwargs block" predicate, so the pre-variadic-rewrite position
// being "off" there is harmless. Returns -1 when the callee has no
// kwargs param. Callee resolution mirrors
// resolve_variadic_elem_type's Ident-binding / Type.method namespace
// shapes.
fcall_kwargs_index_via_scope := func(fcall: Expr, scope: TypeScope) returns I32 {
    if fcall.children.len().eq(0) { return -1 }
    ref callee : Expr = fcall.child(0)
    switch callee.node_type {
    case NodeType.Ident(callee_name):
        ref cb : TypeBinding = scope.get_binding(callee_name.ident_name())
        if cb.is_null().not() {
            if cb.func_def.is_null().not() {
                switch cb.func_def.node_type {
                case NodeType.FuncDef(cb_fdef):
                    return derive_fcall_kwargs_index(fcall, cb_fdef)
                case:
                }
            }
        }
    case NodeType.FieldAccess(method_name):
        if fa_is_ns(callee, scope) {
            ref type_node : Expr = callee.child(0)
            switch type_node.node_type {
            case NodeType.Ident(type_name):
                ref sdef : Expr = scope.get_struct(type_name.ident_name())
                if sdef.is_null().not() {
                    ref ns : Vec = def_ns_decls(sdef)
                    for nd : Declaration in ns {
                        if nd.name.eq(method_name.field_access_name()).not() { continue }
                        if nd.default_value.is_null() { break }
                        switch nd.default_value.node_type {
                        case NodeType.FuncDef(ffd):
                            return derive_fcall_kwargs_index(fcall, ffd)
                        case:
                        }
                        break
                    }
                }
            case:
            }
        }
    case:
    }
    return -1
}

// Shared derivation given a resolved callee FuncDef payload.
// Always returns the post-variadic-rewrite (or no-variadic) kwargs
// position: `nparam` when the callee has a kwargs param, else -1. The
// position is *correct* for the only site that uses it (process_call_desugars,
// which has already rewritten the variadic block by the time it
// queries kwargs). The body-pre-pass call from find_kwargs_fcall only
// uses the >= 0 sign of the result as a predicate, so the
// pre-variadic-rewrite "position would be different" is irrelevant
// there.
priv derive_fcall_kwargs_index := func(_fcall: Expr, fdef_data: FunctionDef) returns I32 {
    fkwi := fdef_data.kwargs_index
    if fkwi.lt(0) { return -1 }
    return fdef_data.params.len().cast(I32)
}

resolve_variadic_elem_type := func(fcall: Expr, scope: TypeScope) returns ref Str {
    ref callee : Expr = fcall.child(0)
    switch callee.node_type {
    case NodeType.Ident(callee_name):
        ref cb : TypeBinding = scope.get_binding(callee_name.ident_name())
        if cb.is_null().not() {
            if cb.func_def.is_null().not() {
                switch cb.func_def.node_type {
                case NodeType.FuncDef(cb_fdef):
                    fvi := cb_fdef.variadic_index
                    if fvi.gte(0) {
                        ref param : Declaration = cb_fdef.params[fvi.to_usize()]
                        return param.explicit_type
                    }
                case:
                }
            }
        }
    case NodeType.FieldAccess(method_name):
        if fa_is_ns(callee, scope) {
            ref type_node : Expr = callee.child(0)
            switch type_node.node_type {
            case NodeType.Ident(type_name):
                ref sdef : Expr = scope.get_struct(type_name.ident_name())
                if sdef.is_null().not() {
                    ref ns : Vec = def_ns_decls(sdef)
                    for nd : Declaration in ns {
                        if nd.name.eq(method_name.field_access_name()).not() { continue }
                        if nd.default_value.is_null() { break }
                        switch nd.default_value.node_type {
                        case NodeType.FuncDef(ffd):
                            fvi := ffd.variadic_index
                            if fvi.gte(0) {
                                ref param : Declaration = ffd.params[fvi.to_usize()]
                                return param.explicit_type
                            }
                        case:
                        }
                        break
                    }
                }
            case:
            }
        }
    case:
    }
    return NULL
}

// Returns true if it rewrote fcall in place. Caller is responsible for
// pushing the (now mutated) stmt into new_ch.
desugar_pure_splat_variadic_call := func(mut fcall: Expr, vi: I32, vc: USize) returns Bool {
    switch fcall.node_type {
    case NodeType.FCall(fcd):
        if vc.eq(1).not() { return false }
        if fcd.is_splat.not() { return false }

        mut old_args := Vec.new(Expr)
        old_args.move_from(fcall.children)

        ref splat_in : Expr = old_args[vi.to_usize()]
        mut splat := splat_in.clone()
        fcd.is_splat = false
        if splat_in.node_type.is(NodeType.Ident) {
            splat = make_clone_call("Array", Type.Struct("Array"), splat_in, splat_in)
        }
        mut fcall_new_ch := Vec.new(Expr)
        for j in 0..old_args.len() {
            ji := j.cast(I32)
            if ji.eq(vi) {
                fcall_new_ch.push(own splat)
            } else {
                fcall_new_ch.push_take(old_args, j)
            }
        }
        fcall.children.move_from(fcall_new_ch)
        set_own_arg(fcall, vi.to_usize())
        return true
    case:
        UNREACHABLE(__LOC__)
        return false
    }
}

rewrite_kwargs_fcall_args := func(mut fcall: Expr, kw_name: Str, ki: I32) {
    switch fcall.node_type {
    case NodeType.FCall(fcd):
        kc := fcall_kwargs_count(fcall)
        old_own := fcd.own_args
        mut old_args := Vec.new(Expr)
        old_args.move_from(fcall.children)
        mut fcall_new_ch := Vec.new(Expr)
        mut kw_inserted := false
        mut new_own : U64 = 0

        for j in 0..old_args.len() {
            ji := j.cast(I32)
            if ji.gte(ki).and(ji.lt(ki.add(kc.cast(I32)))) {
                if kw_inserted.not() {
                    mut kw_id := Expr.new(ident_node(kw_name), fcall.line, fcall.col)
                    kw_id.set_expr_til_type(Type.Struct("DynMap"))
                    mut bit : U64 = 1
                    for _ in 0..fcall_new_ch.len() { bit = bit.mul(2) }
                    new_own = new_own.bor(bit)
                    fcall_new_ch.push(own kw_id)
                    kw_inserted = true
                }
                continue
            }
            if ji.eq(ki).and(kw_inserted.not()) {
                mut kw_id := Expr.new(ident_node(kw_name), fcall.line, fcall.col)
                kw_id.set_expr_til_type(Type.Struct("DynMap"))
                mut bit : U64 = 1
                for _ in 0..fcall_new_ch.len() { bit = bit.mul(2) }
                new_own = new_own.bor(bit)
                fcall_new_ch.push(own kw_id)
                kw_inserted = true
            }
            // Transfer own bit from old position j to new position
            mut old_bit : U64 = 1
            for _ in 0..j { old_bit = old_bit.mul(2) }
            if old_own.band(old_bit).gt(0) {
                mut nb : U64 = 1
                for _ in 0..fcall_new_ch.len() { nb = nb.mul(2) }
                new_own = new_own.bor(nb)
            }
            fcall_new_ch.push_take(old_args, j)
        }
        if kw_inserted.not() {
            mut kw_id := Expr.new(ident_node(kw_name), fcall.line, fcall.col)
            kw_id.set_expr_til_type(Type.Struct("DynMap"))
            mut bit : U64 = 1
            for _ in 0..fcall_new_ch.len() { bit = bit.mul(2) }
            new_own = new_own.bor(bit)
            fcall_new_ch.push(own kw_id)
        }

        fcall.children.move_from(fcall_new_ch)
        fcd.own_args = new_own
    case:
        UNREACHABLE(__LOC__)
    }
}

check_own_args := func(fdef: Expr, fcall: Expr, var_name: Str) returns Bool {
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        if fd.params.len().eq(0) { return false }
        for i in 0..fd.params.len() {
            if i.add(1).gte(fcall.children.len()) { return false }
            ref p : Declaration = fd.params[i]
            if p.own_type.is(OwnType.Own) {
                ref arg : Expr = fcall.child(i.add(1))
                switch arg.node_type {
                case NodeType.Ident(_ai):
                    if _ai.ident_name().eq(var_name) { return true }
                case:
                }
            }
        }
        return false
    case:
        return false
    }
}

fcall_has_own_arg := func(fcall: Expr, var_name: Str, scope: TypeScope) returns Bool {
    if fcall.node_type.is(NodeType.FCall).not() { return false }
    if fcall.children.len().lt(2) { return false }
    // Struct constructor
    fcall_sname := til_type_name(fcall.expr_til_type())
    if fcall_sname.len().gt(0) {
        switch fcall.child(0).node_type {
        case NodeType.Ident(_c0s):
            if _c0s.ident_name().eq(fcall_sname) {
                ref sdef : Expr = scope.get_struct(fcall_sname)
                if sdef.is_null().not() {
                    switch sdef.node_type {
                    case NodeType.StructDef(fhoa_sdd):
                        for fi in 0..fhoa_sdd.fields.len() {
                            ref fld_decl : Declaration = fhoa_sdd.fields[fi]
                            arg_idx := fi.add(1)
                            if arg_idx.lt(fcall.children.len()) {
                                ref arg : Expr = fcall.child(arg_idx)
                                switch arg.node_type {
                                case NodeType.Ident(_an):
                                    if _an.ident_name().eq(var_name).and(fld_decl.own_type.is(OwnType.Ref).not()) {
                                        if fld_decl.own_type.is(OwnType.Own).or(type_ctor_consumes(fld_decl.til_type)) {
                                            return true
                                        }
                                    }
                                case:
                                }
                            }
                        }
                    case:
                    }
                }
            }
        case:
        }
    }
    // Direct call
    switch fcall.child(0).node_type {
    case NodeType.Ident(fn_name):
        ref fb : TypeBinding = scope.get_binding(fn_name.ident_name())
        if fb.is_null().not() {
            if fb.func_def.is_null() { return false }
            return check_own_args(fb.func_def, fcall, var_name)
        }
        return false
    case NodeType.FieldAccess(method):
        // Namespace method call
        if fa_is_ns(fcall.child(0), scope) {
            ref type_node : Expr = fcall.child(0).child(0)
            switch type_node.node_type {
            case NodeType.Ident(_tn):
                ref sdef : Expr = scope.get_struct(_tn.ident_name())
                if sdef.is_null() { return false }
                ref oa_ns : Vec = def_ns_decls(sdef)
                for fd : Declaration in oa_ns {
                    if fd.name.eq(method.field_access_name()) {
                        if fd.default_value.is_null().not().and(fd.default_value.node_type.is(NodeType.FuncDef)) {
                            return check_own_args(fd.default_value, fcall, var_name)
                        }
                    }
                }
            case:
            }
        }
    case:
    }
    return false
}

expr_transfers_own := func(e: Expr, var_name: Str, scope: TypeScope, ctx: Context) returns Bool {
    if e.node_type.is(NodeType.FuncDef) { return false }
    if fcall_has_own_arg(e, var_name, scope) { return true }
    // FieldAssign is a transfer only when the receiving field is Own --
    // Ref fields take a borrow (caller keeps ownership), Shallow fields
    // value-copy (caller keeps too). The old check `not Shallow`
    // misclassified Ref-field assignments as transfers, so a local
    // assigned into a ref-typed field never got its scope-end delete.
    // (Issue #109: test/ref.til's `a.next = b` where `next` is `ref mut
    // next : RefNode` leaked b's 16-byte wrapper.)
    if e.node_type.is(NodeType.FieldAssign).and(e.fa_own_type(scope).is(OwnType.Own)) {
        if e.children.len().gt(1) {
            switch e.child(1).node_type {
            case NodeType.Ident(_ei):
                if _ei.ident_name().eq(var_name) { return true }
            case:
            }
        }
    }
    for e_i : Expr in e.children {
        if expr_transfers_own(e_i, var_name, scope, ctx) { return true }
    }
    return false
}

expr_is_borrow_source := func(e: Expr, scope: TypeScope) returns Bool {
    if e.is_null() { return false }
    if e.node_type.is_literal_null() { return true }
    if e.node_type.is(NodeType.FCall).and(fcall_returns_ref(e, scope).neq(0)) { return true }
    switch e.node_type {
    case NodeType.Ident(id):
        sf := scope.find(id.ident_name())
        switch sf {
        case ScopeFind.Found(b):
            if b.own_type.is(OwnType.Ref).or(b.is_param) { return true }
            // Owned compound locals are pointers in C -- valid borrow source
            if is_aggregate(b.type) { return true }
        case:
        }
    case:
    }
    if e.node_type.is(NodeType.FieldAccess) {
        if fa_is_ns(e, scope) { return false }
        return expr_is_borrow_source(e.child(0), scope)
    }
    return false
}

expr_is_stable_field_base := func(e: Expr, scope: TypeScope) returns Bool {
    if e.is_null() { return false }
    if expr_is_borrow_source(e, scope) { return true }
    switch e.node_type {
    case NodeType.Ident(id):
        sf := scope.find(id.ident_name())
        switch sf {
        case ScopeFind.Found(b):
            if b.func_def.is_null().not() { return false }
            if b.struct_def.is_null().not() { return false }
            return true
        case:
            return false
        }
    case:
    }
    if e.node_type.is(NodeType.FieldAccess) {
        if fa_is_ns(e, scope) { return false }
        return expr_is_stable_field_base(e.child(0), scope)
    }
    return false
}

expr_is_ref_decl_source := func(e: Expr, scope: TypeScope) returns Bool {
    if e.is_null() { return false }
    if expr_is_borrow_source(e, scope) { return true }
    if e.node_type.is(NodeType.FieldAccess) {
        if fa_is_ns(e, scope) { return false }
        return expr_is_stable_field_base(e.child(0), scope)
    }
    return false
}

field_assign_needs_delete := func(stmt: Expr, scope: TypeScope) returns Bool {
    if stmt.fa_own_type(scope).is(OwnType.Ref) { return false }
    if stmt.fa_own_type(scope).is(OwnType.Shallow).not() { return true }
    ft := stmt.child(1).expr_til_type()
    if is_aggregate(ft) { return true }
    return false
}

// Asap-destruction helpers (LocalInfo, alias_used_in_stmts,
// collect_scope_locals, extend_ref_local_lifetimes,
// check_use_after_own_transfer, promote_own_transferred_locals,
// insert_exit_deletes / insert_nested_exit_deletes /
// insert_exit_deletes_into_stmt / insert_post_stmt_deletes /
// insert_assign_delete, insert_free_calls) moved to
// src/self/garbager.til. See issue #204 / doc/pipeline.org step 5.
// expr_til_type derives Type.Struct("Str") and Type.Bool for LiteralStr
// and LiteralBool directly from node_type, so this function only needs
// to handle the two variants with non-trivial inference: LiteralNum's
// I64-default-unless-already-narrowed (parser writes Type.U8 for char
// literals) and LiteralNull's initial Type.Dynamic (narrow_dynamic may
// mutate it post-write, so the field is still authoritative for that
// variant).
infer_literal_expr := func(mut expr: Expr) {
    switch expr.node_type {
    case NodeType.Literal(Literal.Num):
        if is_numeric_type(expr.expr_til_type()).not() {
            expr.set_expr_til_type(Type.I64)
        }
    case NodeType.Literal(Literal.Null):
        expr.set_expr_til_type(Type.Dynamic)
    case:
    }
}

narrow_dynamic := func(mut expr: Expr, target: Type) {
    if expr.expr_til_type().is(Type.Dynamic).not() { return }
    if target.is(Type.Dynamic) { return }
    if target.is(Type.Unknown) { return }
    expr.set_expr_til_type(target)
}

fcall_returns_ref := func(fcall: Expr, scope: TypeScope) returns I32 {
    if fcall.node_type.is(NodeType.FCall).not() { return 0 }
    if fcall.children.len().eq(0) { return 0 }
    ref callee : Expr = fcall.child(0)
    switch callee.node_type {
    case NodeType.Ident(_cn):
        ref cb : TypeBinding = scope.get_binding(_cn.ident_name())
        if cb.is_null().not() {
            if cb.func_def.is_null() { return 0 }
            switch cb.func_def.node_type {
            case NodeType.FuncDef(_cfd):
                return _cfd.return_own_type.is(OwnType.Ref)
            case:
                return 0
            }
        }
        return 0
    case NodeType.FieldAccess(_cfa):
        if fa_is_ns(callee, scope) {
            switch callee.child(0).node_type {
            case NodeType.Ident(_cti):
                ref sdef : Expr = scope.get_struct(_cti.ident_name())
                if sdef.is_null() { return 0 }
                ref cfa_ns : Vec = def_ns_decls(sdef)
                for fd : Declaration in cfa_ns {
                    if fd.name.eq(_cfa.field_access_name()) {
                        if fd.default_value.is_null().not() {
                            switch fd.default_value.node_type {
                            case NodeType.FuncDef(_ffd):
                                return _ffd.return_own_type.is(OwnType.Ref)
                            case:
                            }
                        }
                    }
                }
            case:
            }
        }
    case:
    }
    return 0
}

// Parallel to fcall_returns_ref: returns 1 when the FCall's callee is
// declared `returns shallow T`. Used by collect_scope_locals to keep
// the typer-emitted cleanup's call_free bool consistent with the
// builder's shallow-return stack-alloc path (no malloc, so freeing
// would touch a stack pointer).
fcall_returns_shallow := func(fcall: Expr, scope: TypeScope) returns I32 {
    if fcall.node_type.is(NodeType.FCall).not() { return 0 }
    if fcall.children.len().eq(0) { return 0 }
    ref callee : Expr = fcall.child(0)
    switch callee.node_type {
    case NodeType.Ident(_cn):
        ref cb : TypeBinding = scope.get_binding(_cn.ident_name())
        if cb.is_null().not() {
            if cb.func_def.is_null() { return 0 }
            switch cb.func_def.node_type {
            case NodeType.FuncDef(_cfd):
                return _cfd.return_own_type.is(OwnType.Shallow)
            case:
                return 0
            }
        }
        return 0
    case NodeType.FieldAccess(_cfa):
        if fa_is_ns(callee, scope) {
            switch callee.child(0).node_type {
            case NodeType.Ident(_cti):
                ref sdef : Expr = scope.get_struct(_cti.ident_name())
                if sdef.is_null() { return 0 }
                ref cfa_ns : Vec = def_ns_decls(sdef)
                for fd : Declaration in cfa_ns {
                    if fd.name.eq(_cfa.field_access_name()) {
                        if fd.default_value.is_null().not() {
                            switch fd.default_value.node_type {
                            case NodeType.FuncDef(_ffd):
                                return _ffd.return_own_type.is(OwnType.Shallow)
                            case:
                            }
                        }
                    }
                }
            case:
            }
        }
    case:
    }
    return 0
}

hoist_to_temp := func(mut ctx: Context, val: Expr, mut hoisted: Vec, mut scope: TypeScope, is_own: Bool) returns Expr {
    tp := type_prefix(val.expr_til_type())
    // Non-underscore prefix so the builder's `_x`-deliberately-unused
    // exemption doesn't free-pass these compiler temps. If a hoisted
    // temp survives DCE and goes unused, that's a DCE bug worth
    // surfacing (as a C -Werror=unused-but-set-variable) rather than
    // hiding behind a `(void)<name>;` guard.
    tname := "hoisted__".concat(tp).concat("_").concat(ctx.hoist_counter.to_str())
    ctx.hoist_counter++

    mut decl := Expr.new(NodeType.Decl(Declaration()), val.line, val.col)
    decl.set_expr_til_type(val.expr_til_type())

    mut val_is_ref := false
    if val.node_type.is(NodeType.FCall) {
        val_is_ref = fcall_returns_ref(val, scope).eq(0).not()
    }

    is_compound := is_aggregate(val.expr_til_type())
    // LiteralStr temps: the builder emits these as stack-allocated
    // compound-literal Str values (no malloc). Leaving own_type at
    // Shallow makes the typer-inserted Str.delete use call_free=false,
    // which the builder pairs with `&name` for the own-self arg.
    is_literal_str := val.node_type.is_literal_str()

    decl.add_child(own val.clone())

    mut ident := Expr.new(ident_node(tname), val.line, val.col)
    ident.set_expr_til_type(val.expr_til_type())
    scope.set(tname, val.expr_til_type(), FuncType.None, false, ctx.path, val.line, val.col, false, OwnType.Shallow)
    ref mut tb : TypeBinding = scope.get_binding(tname)
    switch decl.node_type {
    case NodeType.Decl(dd):
        dd.name = tname.clone()
        dd.is_mut = false
        if val_is_ref {
            dd.own_type = OwnType.Ref
            if tb.is_null().not() { tb.own_type = OwnType.Ref }
        } else if is_literal_str {
            // leave as Shallow -- builder emits a stack value
        } else if is_own.or(is_compound) {
            dd.own_type = OwnType.Own
            if tb.is_null().not() { tb.own_type = OwnType.Own }
        }
    case:
        UNREACHABLE(__LOC__)
    }

    hoisted.push(own decl)
    return ident
}

type_check := proc(program: Expr, scope: TypeScope, ctx: Context) returns I32 {
    ctx.errors = 0
    infer_body(scope, program, 0, 1, 0, 0, 0, ctx)
    // Program-scope asap runs from prepare_program via
    // garbager_destroy(ctx); see issue #204 step 3b.
    return ctx.errors
}
