mode lib

// --- TokenType enum ---
// Matches lexer.h TokenType (TOK_* → PascalCase)

TokenType := enum {
    Eof,

    // Single-character
    LParen, RParen,
    LBrace, RBrace,
    LBracket, RBracket,
    Comma, Colon,
    Question, Bang,
    Minus, Plus, Star, Slash,

    // One or two character
    Dot, DotDot, DotDotDot,
    Eq, EqEq,
    Neq,
    Lt, LtEq,
    Gt, GtEq,

    // Assignment
    ColonEq,

    // Literals
    Ident, StringTok, Number, Char,

    // Keywords
    KwMode,
    KwMut, KwOwn, KwRef, KwShallow,
    KwStruct, KwExtStruct, KwEnum, KwNamespace,
    KwFunc, KwProc, KwTest, KwMacro, KwExtFunc, KwExtProc,
    KwReturns, KwThrows,
    KwIf, KwElse,
    KwWhile, KwFor, KwIn,
    KwSwitch, KwMatch, KwCase, KwDefault,
    KwReturn, KwThrow, KwCatch,
    KwBreak, KwContinue, KwDefer,
    KwTrue, KwFalse, KwNull,

    // Error tokens
    Error,
}

// --- Token struct ---
// C Token uses start pointer + len (zero-copy into source buffer).
// til Token uses text: Str (copied substring). Simpler memory model.

Token := struct {
    type := TokenType.Eof
    text := ""
    line : U32 = 0
    col : U32 = 0
}

// --- Character helpers ---
// Replaces C's isdigit(), isalpha() from <ctype.h>

is_digit := func(c: U8) returns Bool {
    return c.gte('0').and(c.lte('9'))
}

is_alpha := func(c: U8) returns Bool {
    return c.gte('a').and(c.lte('z'))
        .or(c.gte('A').and(c.lte('Z')))
        .or(c.eq('_'))
}

is_alnum := func(c: U8) returns Bool {
    return is_alpha(c).or(is_digit(c))
}

// --- tok_name ---
// Returns a human-readable name for a token type.
// Matches C tok_name() output exactly.

tok_name := func(type: TokenType) returns Str {
    switch type {
    case TokenType.Eof: return "eof"
    case TokenType.LParen: return "("
    case TokenType.RParen: return ")"
    case TokenType.LBrace: return "{"
    case TokenType.RBrace: return "}"
    case TokenType.LBracket: return "["
    case TokenType.RBracket: return "]"
    case TokenType.Comma: return ","
    case TokenType.Colon: return ":"
    case TokenType.Question: return "?"
    case TokenType.Bang: return "!"
    case TokenType.Minus: return "-"
    case TokenType.Plus: return "+"
    case TokenType.Star: return "*"
    case TokenType.Slash: return "/"
    case TokenType.Dot: return "."
    case TokenType.DotDot: return ".."
    case TokenType.DotDotDot: return "..."
    case TokenType.Eq: return "="
    case TokenType.EqEq: return "=="
    case TokenType.Neq: return "!="
    case TokenType.Lt: return "<"
    case TokenType.LtEq: return "<="
    case TokenType.Gt: return ">"
    case TokenType.GtEq: return ">="
    case TokenType.ColonEq: return ":="
    case TokenType.Ident: return "identifier"
    case TokenType.StringTok: return "string"
    case TokenType.Number: return "number"
    case TokenType.Char: return "char"
    case TokenType.KwMode: return "mode"
    case TokenType.KwMut: return "mut"
    case TokenType.KwOwn: return "own"
    case TokenType.KwRef: return "ref"
    case TokenType.KwShallow: return "shallow"
    case TokenType.KwStruct: return "struct"
    case TokenType.KwExtStruct: return "ext_struct"
    case TokenType.KwEnum: return "enum"
    case TokenType.KwNamespace: return "namespace"
    case TokenType.KwFunc: return "func"
    case TokenType.KwProc: return "proc"
    case TokenType.KwTest: return "test"
    case TokenType.KwMacro: return "macro"
    case TokenType.KwExtFunc: return "ext_func"
    case TokenType.KwExtProc: return "ext_proc"
    case TokenType.KwReturns: return "returns"
    case TokenType.KwThrows: return "throws"
    case TokenType.KwIf: return "if"
    case TokenType.KwElse: return "else"
    case TokenType.KwWhile: return "while"
    case TokenType.KwFor: return "for"
    case TokenType.KwIn: return "in"
    case TokenType.KwSwitch: return "switch"
    case TokenType.KwMatch: return "match"
    case TokenType.KwCase: return "case"
    case TokenType.KwDefault: return "default"
    case TokenType.KwReturn: return "return"
    case TokenType.KwThrow: return "throw"
    case TokenType.KwCatch: return "catch"
    case TokenType.KwBreak: return "break"
    case TokenType.KwContinue: return "continue"
    case TokenType.KwDefer: return "defer"
    case TokenType.KwTrue: return "true"
    case TokenType.KwFalse: return "false"
    case TokenType.KwNull: return "NULL"
    case TokenType.Error: return "error"
    case: return "?"
    }
}

// --- Keyword lookup ---
// C version uses Keyword struct + static array with memcmp loop.
// til version uses switch on Str — functionally equivalent.

lookup_keyword := func(word: Str) returns TokenType {
    switch word {
    case "mode": return TokenType.KwMode
    case "mut": return TokenType.KwMut
    case "own": return TokenType.KwOwn
    case "ref": return TokenType.KwRef
    case "shallow": return TokenType.KwShallow
    case "struct": return TokenType.KwStruct
    case "ext_struct": return TokenType.KwExtStruct
    case "enum": return TokenType.KwEnum
    case "namespace": return TokenType.KwNamespace
    case "func": return TokenType.KwFunc
    case "proc": return TokenType.KwProc
    case "test": return TokenType.KwTest
    case "macro": return TokenType.KwMacro
    case "ext_func": return TokenType.KwExtFunc
    case "ext_proc": return TokenType.KwExtProc
    case "returns": return TokenType.KwReturns
    case "throws": return TokenType.KwThrows
    case "if": return TokenType.KwIf
    case "else": return TokenType.KwElse
    case "while": return TokenType.KwWhile
    case "for": return TokenType.KwFor
    case "in": return TokenType.KwIn
    case "switch": return TokenType.KwSwitch
    case "match": return TokenType.KwMatch
    case "case": return TokenType.KwCase
    case "default": return TokenType.KwDefault
    case "return": return TokenType.KwReturn
    case "throw": return TokenType.KwThrow
    case "catch": return TokenType.KwCatch
    case "break": return TokenType.KwBreak
    case "continue": return TokenType.KwContinue
    case "defer": return TokenType.KwDefer
    case "true": return TokenType.KwTrue
    case "false": return TokenType.KwFalse
    case "NULL": return TokenType.KwNull
    case: return TokenType.Ident
    }
}

// --- Tokenizer ---
// Strict translation of C tokenize(). Uses integer index instead of
// char pointer. Token.text is a copied Str instead of pointer+len.

tokenize := proc(src: Str, path: Str) returns Vec {
    mut tokens := Vec.new("Token", Token.size())
    mut pos : U64 = 0
    mut line : U32 = 1
    mut line_start : U64 = 0
    src_len := src.len()

    while pos.lt(src_len) {
        ref c : U8 = src.byte_at(pos)

        // Skip whitespace (spaces, tabs, \r, semicolons)
        if c.eq(' ').or(c.eq('\t')).or(c.eq('\r')).or(c.eq(';')) {
            pos = pos.inc()
            continue
        }
        if c.eq('\n') {
            pos = pos.inc()
            line = line.add(1)
            line_start = pos
            continue
        }

        col : U32 = pos.sub(line_start).add(1).to_i64().to_u32()
        start := pos

        // Line comments: // or #
        if c.eq('#') {
            while pos.lt(src_len) {
                if src.byte_at(pos).eq('\n') { break }
                pos = pos.inc()
            }
            continue
        }
        if c.eq('/').and(pos.add(1).lt(src_len)) {
            ref c2 : U8 = src.byte_at(pos.add(1))
            if c2.eq('/') {
                while pos.lt(src_len) {
                    if src.byte_at(pos).eq('\n') { break }
                    pos = pos.inc()
                }
                continue
            }
            // Block comments: /* ... */ (nestable)
            if c2.eq('*') {
                pos = pos.add(2)
                mut depth := 1
                while pos.lt(src_len) {
                    if depth.lte(0) { break }
                    if pos.add(1).lt(src_len) {
                        ref b1 : U8 = src.byte_at(pos)
                        ref b2 : U8 = src.byte_at(pos.add(1))
                        if b1.eq('/').and(b2.eq('*')) {
                            depth = depth.add(1)
                            pos = pos.add(2)
                            continue
                        }
                        if b1.eq('*').and(b2.eq('/')) {
                            depth = depth.sub(1)
                            pos = pos.add(2)
                            continue
                        }
                    }
                    if src.byte_at(pos).eq('\n') {
                        line = line.add(1)
                        line_start = pos.add(1)
                    }
                    pos = pos.inc()
                }
                if depth.gt(0) {
                    println(path, ":", line.to_str(), ":", col.to_str(), ": error: unterminated comment")
                }
                continue
            }
        }

        // Numbers
        if is_digit(c) {
            while pos.lt(src_len) {
                if is_digit(src.byte_at(pos)).not() { break }
                pos = pos.inc()
            }
            // Check for decimal point
            if pos.add(1).lt(src_len) {
                if src.byte_at(pos).eq('.').and(is_digit(src.byte_at(pos.add(1)))) {
                    pos = pos.inc()
                    while pos.lt(src_len) {
                        if is_digit(src.byte_at(pos)).not() { break }
                        pos = pos.inc()
                    }
                }
            }
            tokens.push(own Token(type = TokenType.Number,
                text = src.substr(start, pos.sub(start)),
                line = line, col = col))
            continue
        }

        // Identifiers and keywords
        if is_alpha(c) {
            while pos.lt(src_len) {
                if is_alnum(src.byte_at(pos)).not() { break }
                pos = pos.inc()
            }
            word := src.substr(start, pos.sub(start))
            type := lookup_keyword(word)
            tokens.push(own Token(type = type, text = word, line = line, col = col))
            continue
        }

        // Strings
        if c.eq('"') {
            pos = pos.inc()
            while pos.lt(src_len) {
                if src.byte_at(pos).eq('"') { break }
                if src.byte_at(pos).eq('\\').and(pos.add(1).lt(src_len)) {
                    pos = pos.inc()
                }
                if src.byte_at(pos).eq('\n') {
                    line = line.add(1)
                    line_start = pos.add(1)
                }
                pos = pos.inc()
            }
            if pos.lt(src_len).and(src.byte_at(pos).eq('"')) {
                pos = pos.inc()
                tokens.push(own Token(type = TokenType.StringTok,
                    text = src.substr(start.add(1), pos.sub(start).sub(2)),
                    line = line, col = col))
            } else {
                println(path, ":", line.to_str(), ":", col.to_str(), ": error: unterminated string")
                tokens.push(own Token(type = TokenType.Error,
                    text = src.substr(start, pos.sub(start)),
                    line = line, col = col))
            }
            continue
        }

        // Character literals: 'x' or '\x'
        if c.eq('\'') {
            pos = pos.inc()
            ch_start := pos
            if pos.lt(src_len).and(src.byte_at(pos).eq('\\').and(pos.add(1).lt(src_len))) {
                pos = pos.inc()
            }
            pos = pos.inc()
            if pos.lt(src_len).and(src.byte_at(pos).eq('\'')) {
                tokens.push(own Token(type = TokenType.Char,
                    text = src.substr(ch_start, pos.sub(ch_start)),
                    line = line, col = col))
                pos = pos.inc()
            } else {
                println(path, ":", line.to_str(), ":", col.to_str(), ": error: unterminated character literal")
                tokens.push(own Token(type = TokenType.Error,
                    text = src.substr(start, pos.sub(start)),
                    line = line, col = col))
            }
            continue
        }

        // Two-character tokens
        if pos.add(1).lt(src_len) {
            ref c2 : U8 = src.byte_at(pos.add(1))
            mut two := TokenType.Eof
            if c.eq(':').and(c2.eq('=')) { two = TokenType.ColonEq }
            else if c.eq('=').and(c2.eq('=')) { two = TokenType.EqEq }
            else if c.eq('!').and(c2.eq('=')) { two = TokenType.Neq }
            else if c.eq('<').and(c2.eq('=')) { two = TokenType.LtEq }
            else if c.eq('>').and(c2.eq('=')) { two = TokenType.GtEq }
            else if c.eq('.').and(c2.eq('.')) {
                // Check for ... (three dots) vs .. (two dots)
                if pos.add(2).lt(src_len) {
                    ref c3 : U8 = src.byte_at(pos.add(2))
                    if c3.eq('.') {
                        tokens.push(own Token(type = TokenType.DotDotDot,
                            text = src.substr(start, 3),
                            line = line, col = col))
                        pos = pos.add(3)
                        continue
                    }
                }
                two = TokenType.DotDot
            }
            if two.eq(TokenType.Eof).not() {
                tokens.push(own Token(type = two,
                    text = src.substr(start, 2),
                    line = line, col = col))
                pos = pos.add(2)
                continue
            }
        }

        // Single-character tokens
        mut single := TokenType.Eof
        switch c {
        case '(': single = TokenType.LParen
        case ')': single = TokenType.RParen
        case '{': single = TokenType.LBrace
        case '}': single = TokenType.RBrace
        case '[': single = TokenType.LBracket
        case ']': single = TokenType.RBracket
        case ',': single = TokenType.Comma
        case ':': single = TokenType.Colon
        case '.': single = TokenType.Dot
        case '?': single = TokenType.Question
        case '!': single = TokenType.Bang
        case '+': single = TokenType.Plus
        case '-': single = TokenType.Minus
        case '*': single = TokenType.Star
        case '/': single = TokenType.Slash
        case '=': single = TokenType.Eq
        case '<': single = TokenType.Lt
        case '>': single = TokenType.Gt
        }

        if single.eq(TokenType.Eof).not() {
            tokens.push(own Token(type = single,
                text = src.substr(start, 1),
                line = line, col = col))
            pos = pos.inc()
            continue
        }

        // Unknown character
        println(path, ":", line.to_str(), ":", col.to_str(), ": error: unexpected character")
        tokens.push(own Token(type = TokenType.Error,
            text = src.substr(start, 1),
            line = line, col = col))
        pos = pos.inc()
    }

    // EOF
    col := pos.sub(line_start).add(1).to_i64()
    tokens.push(own Token(type = TokenType.Eof, text = "", line = line, col = col))
    return tokens
}
