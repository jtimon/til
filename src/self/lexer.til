mode lib

// --- TokenType enum ---
// Matches lexer.h TokenType (TOK_* → PascalCase)

TokenType := enum {
    Eof,

    // Single-character
    LParen, RParen,
    LBrace, RBrace,
    LBracket, RBracket,
    Comma, Colon,
    Question, Bang,
    Minus, Plus, Star, Slash, Percent,
    Ampersand, Pipe, Caret,

    // One or two character
    Dot, DotDot, DotDotDot,
    Eq, EqEq,
    Neq,
    Lt, LtEq,
    Gt, GtEq,
    PlusPlus, MinusMinus,
    AmpAmp, PipePipe,

    // Assignment
    ColonEq,

    // Literals
    Ident, StringTok, Number, Char,

    // Doc comment: text of one /// line (leading /// + one optional space
    // stripped) or one content line of a /** ... */ block (issue #182).
    DocComment,

    // Keywords
    KwMut, KwConst, KwOwn, KwRef, KwShallow,
    KwStruct, KwEnum, KwNamespace, KwInterface, KwImplements,
    KwFunc, KwProc, KwTest, KwMacro, KwExtFunc, KwExtProc, KwExtStruct,
    KwLazyFunc, KwLazyProc,
    KwReturns, KwThrows,
    KwIf, KwElse,
    KwWhile, KwFor, KwIn,
    KwSwitch, KwMatch, KwCase, KwDefault,
    KwReturn, KwThrow, KwCatch,
    KwBreak, KwContinue, KwDefer,
    KwTrue, KwFalse, KwNull,
    KwPriv,

    // Error tokens
    Error,
}

// --- Token struct ---
// Zero-copy: a token stores the byte range [start, start+len) of its text
// within the source buffer instead of a copied Str. The parser recovers
// the text on demand as a transient view (src.substr(start, len)) from a
// source it owns, so tokens carry no heap allocation and no dangling
// pointer into the lexer's source. For literals the range is the content
// span (string contents without quotes, /// doc text without the prefix).
Token := struct {
    const type := TokenType.Eof
    const start : USize = 0
    const len : USize = 0
    const line : U32 = 0
    const col : U32 = 0
}

// --- Character helpers ---
// Replaces C's isdigit(), isalpha() from <ctype.h>

priv is_digit := func(c: I8) returns Bool {
    return c.gte('0').and(c.lte('9'))
}

priv is_alpha := func(c: I8) returns Bool {
    return c.gte('a').and(c.lte('z'))
    .or(c.gte('A').and(c.lte('Z')))
    .or(c.eq('_'))
}

is_alnum := func(c: I8) returns Bool {
    return is_alpha(c).or(is_digit(c))
}

// Digit-class helpers for base-prefixed integer literals (issue #255).
// is_digit stays decimal-only; these recognise the alphabet of each base.
priv is_hex_digit := func(c: I8) returns Bool {
    return is_digit(c)
    .or(c.gte('a').and(c.lte('f')))
    .or(c.gte('A').and(c.lte('F')))
}

priv is_bin_digit := func(c: I8) returns Bool {
    return c.eq('0').or(c.eq('1'))
}

priv is_oct_digit := func(c: I8) returns Bool {
    return c.gte('0').and(c.lte('7'))
}

// Whitespace recognised when stripping /** ... */ doc-block lines:
// spaces, tabs and a trailing '\r' (CRLF). Newlines are line separators,
// not stripped here.
priv is_doc_ws := func(c: I8) returns Bool {
    return c.eq(' ').or(c.eq('\t')).or(c.eq('\r'))
}

// --- Keyword map ---
// Single source of truth for the keyword <-> TokenType mapping. Both
// lookup_keyword (source spelling -> TokenType) and tok_name's keyword
// branch (TokenType -> source spelling) consult this one Map, so the two
// directions can never drift. A Map keeps its keys ordered, so the hot
// spelling -> TokenType lookup is a binary search rather than a linear
// scan of a Vec.

priv keyword_map := func() returns Map(Str, TokenType) {
    kw := Map(Str, TokenType).new()
    kw.set("mut", own TokenType.KwMut)
    kw.set("const", own TokenType.KwConst)
    kw.set("own", own TokenType.KwOwn)
    kw.set("ref", own TokenType.KwRef)
    kw.set("shallow", own TokenType.KwShallow)
    kw.set("struct", own TokenType.KwStruct)
    kw.set("enum", own TokenType.KwEnum)
    kw.set("namespace", own TokenType.KwNamespace)
    kw.set("interface", own TokenType.KwInterface)
    kw.set("implements", own TokenType.KwImplements)
    kw.set("func", own TokenType.KwFunc)
    kw.set("proc", own TokenType.KwProc)
    kw.set("test", own TokenType.KwTest)
    kw.set("macro", own TokenType.KwMacro)
    kw.set("ext_func", own TokenType.KwExtFunc)
    kw.set("ext_proc", own TokenType.KwExtProc)
    kw.set("ext_struct", own TokenType.KwExtStruct)
    kw.set("lazy_func", own TokenType.KwLazyFunc)
    kw.set("lazy_proc", own TokenType.KwLazyProc)
    kw.set("returns", own TokenType.KwReturns)
    kw.set("throws", own TokenType.KwThrows)
    kw.set("if", own TokenType.KwIf)
    kw.set("else", own TokenType.KwElse)
    kw.set("while", own TokenType.KwWhile)
    kw.set("for", own TokenType.KwFor)
    kw.set("in", own TokenType.KwIn)
    kw.set("switch", own TokenType.KwSwitch)
    kw.set("match", own TokenType.KwMatch)
    kw.set("case", own TokenType.KwCase)
    kw.set("default", own TokenType.KwDefault)
    kw.set("return", own TokenType.KwReturn)
    kw.set("throw", own TokenType.KwThrow)
    kw.set("catch", own TokenType.KwCatch)
    kw.set("break", own TokenType.KwBreak)
    kw.set("continue", own TokenType.KwContinue)
    kw.set("defer", own TokenType.KwDefer)
    kw.set("true", own TokenType.KwTrue)
    kw.set("false", own TokenType.KwFalse)
    kw.set("NULL", own TokenType.KwNull)
    kw.set("priv", own TokenType.KwPriv)
    return kw
}

// The keyword table, built once at startup. It is never mutated, so
// tok_name / lex read this shared map instead of rebuilding it on every
// call (keyword_map() allocates a fresh Map per invocation).
priv KEYWORDS := keyword_map()

// --- tok_name ---
// Returns a human-readable name for a token type.
// Matches C tok_name() output exactly. Keyword types resolve through the
// shared keyword_map (TokenType -> source spelling); everything else
// is a fixed punctuation/literal name.

tok_name := func(type: TokenType) returns Str {
    for k, v in KEYWORDS {
        if v.is(type) { return k.clone() }
    }
    switch type {
    case TokenType.Eof: return "eof"
    case TokenType.LParen: return "("
    case TokenType.RParen: return ")"
    case TokenType.LBrace: return "{"
    case TokenType.RBrace: return "}"
    case TokenType.LBracket: return "["
    case TokenType.RBracket: return "]"
    case TokenType.Comma: return ","
    case TokenType.Colon: return ":"
    case TokenType.Question: return "?"
    case TokenType.Bang: return "!"
    case TokenType.Minus: return "-"
    case TokenType.Plus: return "+"
    case TokenType.Star: return "*"
    case TokenType.Slash: return "/"
    case TokenType.Percent: return "%"
    case TokenType.Ampersand: return "&"
    case TokenType.Pipe: return "|"
    case TokenType.Caret: return "^"
    case TokenType.Dot: return "."
    case TokenType.DotDot: return ".."
    case TokenType.DotDotDot: return "..."
    case TokenType.Eq: return "="
    case TokenType.EqEq: return "=="
    case TokenType.Neq: return "!="
    case TokenType.Lt: return "<"
    case TokenType.LtEq: return "<="
    case TokenType.Gt: return ">"
    case TokenType.GtEq: return ">="
    case TokenType.PlusPlus: return "++"
    case TokenType.MinusMinus: return "--"
    case TokenType.AmpAmp: return "&&"
    case TokenType.PipePipe: return "||"
    case TokenType.ColonEq: return ":="
    case TokenType.Ident: return "identifier"
    case TokenType.StringTok: return "string"
    case TokenType.Number: return "number"
    case TokenType.Char: return "char"
    case TokenType.DocComment: return "doc_comment"
    case: return "error"
    }
}

// --- Single-character lookup ---
// Returns TokenType.Eof when the character is not a recognised
// single-char token (caller treats Eof as the "no match" sentinel).
// Using a func avoids the mut-reassign-then-clone pattern that leaked
// one TokenType heap allocation per case.

priv lookup_single_char := func(c: I8) returns shallow TokenType {
    switch c {
    case '(': return TokenType.LParen
    case ')': return TokenType.RParen
    case '{': return TokenType.LBrace
    case '}': return TokenType.RBrace
    case '[': return TokenType.LBracket
    case ']': return TokenType.RBracket
    case ',': return TokenType.Comma
    case ':': return TokenType.Colon
    case '.': return TokenType.Dot
    case '?': return TokenType.Question
    case '!': return TokenType.Bang
    case '+': return TokenType.Plus
    case '-': return TokenType.Minus
    case '*': return TokenType.Star
    case '/': return TokenType.Slash
    case '%': return TokenType.Percent
    case '&': return TokenType.Ampersand
    case '|': return TokenType.Pipe
    case '^': return TokenType.Caret
    case '=': return TokenType.Eq
    case '<': return TokenType.Lt
    case '>': return TokenType.Gt
    case: return TokenType.Eof
    }
}

// --- Two-character lookup ---
// Returns TokenType.Eof when (c, c2) is not a recognised two-char
// token. Same leak-avoidance rationale as lookup_single_char.

priv lookup_two_char := func(c: I8, c2: I8) returns shallow TokenType {
    if c.eq(':').and(c2.eq('=')) { return TokenType.ColonEq }
    if c.eq('=').and(c2.eq('=')) { return TokenType.EqEq }
    if c.eq('!').and(c2.eq('=')) { return TokenType.Neq }
    if c.eq('<').and(c2.eq('=')) { return TokenType.LtEq }
    if c.eq('>').and(c2.eq('=')) { return TokenType.GtEq }
    if c.eq('+').and(c2.eq('+')) { return TokenType.PlusPlus }
    if c.eq('-').and(c2.eq('-')) { return TokenType.MinusMinus }
    if c.eq('.').and(c2.eq('.')) { return TokenType.DotDot }
    if c.eq('&').and(c2.eq('&')) { return TokenType.AmpAmp }
    if c.eq('|').and(c2.eq('|')) { return TokenType.PipePipe }
    return TokenType.Eof
}

// --- Keyword lookup ---
// Looks up the shared keyword_map (source spelling -> TokenType),
// returning TokenType.Ident when the word is not a keyword. The Map does
// a binary search on its ordered keys. The caller builds the map once and
// passes it in so it is not rebuilt per identifier.

priv lookup_keyword := func(word: Str, kw: Map(Str, TokenType)) returns TokenType {
    if kw.has(word) {
        return kw[word].clone()
    }
    return TokenType.Ident
}

// --- scan_to_eol ---
// Returns the index of the next '\n' at or after `from`, or src_len if
// none. Used to skip the rest of a line (# and // comments, /// text).

priv scan_to_eol := func(src: Str, from: USize, src_len: USize) returns USize {
    mut p := from
    while p.lt(src_len) {
        if src.unsafe_get(p).eq('\n') { break }
        p++
    }
    return p
}

// --- push_tok ---
// Appends a Token to the vector. Centralises the construction so the
// line/col plumbing is written once instead of at every emit site.
// `start`/`len` record the token text's byte range in the source buffer.

priv push_tok := func(mut tokens: Vec(Token), type: TokenType, start: USize, len: USize, line: U32, col: U32) {
    tokens.push(own Token(type = type, start = start, len = len, line = line, col = col))
}

// --- emit_doc_block_lines ---
// Issue #182: turn the body of a /** ... */ doc block (the range
// [from, to) between the opening /** and the closing */) into one
// DocComment token per content line, so the parser's drain_doc_comments
// joins them with '\n' and merges them with any adjacent /// lines.
// Each line is stripped Javadoc-style: leading whitespace, then one
// optional '*', then one optional space; trailing whitespace is dropped.
// Leading and trailing blank lines are discarded; interior blank lines
// are kept (as empty DocComment tokens) so they become paragraph breaks.

priv emit_doc_block_lines := func(mut tokens: Vec(Token), src: Str, from: USize, to: USize, doc_line: U32, col: U32) {
    mut ls := from
    mut cur_line := doc_line
    mut pending_blanks : U32 = 0
    mut emitted := false
    mut p := from
    while true {
        at_end := p.gte(to)
        is_nl := at_end.not().and(src.unsafe_get(p).eq('\n'))
        if at_end.or(is_nl) {
            // Strip the line [ls, p).
            mut s := ls
            mut e := p
            while e.gt(s).and(is_doc_ws(src.unsafe_get(e.sub(1)))) { e = e.sub(1) }
            while s.lt(e).and(is_doc_ws(src.unsafe_get(s))) { s++ }
            if s.lt(e).and(src.unsafe_get(s).eq('*')) { s++ }
            if s.lt(e).and(src.unsafe_get(s).eq(' ')) { s++ }
            if e.lte(s) {
                pending_blanks++
            } else {
                // Flush interior blanks once a non-blank line follows a
                // previous one; drop blanks that lead the block.
                if emitted {
                    while pending_blanks.gt(0) {
                        push_tok(tokens, TokenType.DocComment, ls, 0, cur_line, col)
                        pending_blanks = pending_blanks.sub(1)
                    }
                }
                pending_blanks = 0
                push_tok(tokens, TokenType.DocComment, s, e.sub(s), cur_line, col)
                emitted = true
            }
            if at_end { break }
            cur_line++
            p++
            ls = p
            continue
        }
        p++
    }
}

// --- Tokenizer ---
// Strict translation of C tokenize(). Uses integer index instead of
// char pointer. Each Token records the byte range of its text within
// `src` (start/len) rather than copying it.

tokenize := proc(src: Str, path: Str) returns Vec(Token) {
    mut tokens := Vec(Token).new()
    mut pos : USize = 0
    mut line : U32 = 1
    mut line_start : USize = 0
    src_len := src.len()

    while pos.lt(src_len) {
        ref c : I8 = src.unsafe_get(pos)
        col : U32 = pos.sub(line_start).add(1)
        start := pos

        switch c {
        // Whitespace (spaces, tabs, \r, semicolons): skip
        case ' ':  pos++; continue
        case '\t': pos++; continue
        case '\r': pos++; continue
        case ';':  pos++; continue
        case '\n':
            pos++
            line++
            line_start = pos
            continue

        // Line comment: #
        case '#':
            pos = scan_to_eol(src, pos, src_len)
            continue

        // Comments (// /// /* */) or the '/' operator
        case '/':
            if pos.add(1).lt(src_len) {
                ref c2 : I8 = src.unsafe_get(pos.add(1))
                if c2.eq('/') {
                    // Check for /// doc comment
                    is_doc := pos.add(2).lt(src_len).and(src.unsafe_get(pos.add(2)).eq('/'))
                    if is_doc {
                        mut text_start := pos.add(3)
                        if text_start.lt(src_len).and(src.unsafe_get(text_start).eq(' ')) {
                            text_start++
                        }
                        text_end := scan_to_eol(src, text_start, src_len)
                        push_tok(tokens, TokenType.DocComment, text_start, text_end.sub(text_start), line, col)
                        pos = text_end
                        continue
                    }
                    pos = scan_to_eol(src, pos, src_len)
                    continue
                }
                // Block comments: /* ... */ (nestable). A /** ... */ block
                // (but not the empty /**/) is a doc-block comment (issue
                // #182): its content lines become DocComment tokens. Both
                // kinds nest the same way, so /** /* */ */ is one comment.
                if c2.eq('*') {
                    is_doc := pos.add(2).lt(src_len)
                        .and(src.unsafe_get(pos.add(2)).eq('*'))
                        .and(pos.add(3).lt(src_len))
                        .and(src.unsafe_get(pos.add(3)).eq('/').not())
                    doc_line := line
                    mut body_start := pos.add(2)
                    if is_doc { body_start = pos.add(3) }
                    pos = body_start
                    mut depth := 1
                    mut content_end := body_start
                    while pos.lt(src_len) {
                        if depth.lte(0) { break }
                        if pos.add(1).lt(src_len) {
                            ref b1 : I8 = src.unsafe_get(pos)
                            ref b2 : I8 = src.unsafe_get(pos.add(1))
                            if b1.eq('/').and(b2.eq('*')) {
                                depth++
                                pos = pos.add(2)
                                continue
                            }
                            if b1.eq('*').and(b2.eq('/')) {
                                depth--
                                if depth.lte(0) { content_end = pos }
                                pos = pos.add(2)
                                continue
                            }
                        }
                        if src.unsafe_get(pos).eq('\n') {
                            line++
                            line_start = pos.add(1)
                        }
                        pos++
                    }
                    if depth.gt(0) {
                        println(path, ":", line.to_str(), ":", col.to_str(), ": error: unterminated comment")
                    }
                    if is_doc.and(depth.lte(0)) {
                        emit_doc_block_lines(tokens, src, body_start, content_end, doc_line, col)
                    }
                    continue
                }
            }
            // Plain '/' operator (slash at EOF or not a comment)
            push_tok(tokens, lookup_single_char(c), start, 1, line, col)
            pos++
            continue

        // Strings
        case '"':
            pos++
            while pos.lt(src_len) {
                if src.unsafe_get(pos).eq('"') { break }
                if src.unsafe_get(pos).eq('\\').and(pos.add(1).lt(src_len)) {
                    pos++
                }
                if src.unsafe_get(pos).eq('\n') {
                    line++
                    line_start = pos.add(1)
                }
                pos++
            }
            if pos.lt(src_len).and(src.unsafe_get(pos).eq('"')) {
                pos++
                push_tok(tokens, TokenType.StringTok, start.add(1), pos.sub(start).sub(2), line, col)
            } else {
                println(path, ":", line.to_str(), ":", col.to_str(), ": error: unterminated string")
                push_tok(tokens, TokenType.Error, start, pos.sub(start), line, col)
            }
            continue

        // Character literals: 'x' or '\x'
        case '\'':
            pos++
            ch_start := pos
            if pos.lt(src_len).and(src.unsafe_get(pos).eq('\\').and(pos.add(1).lt(src_len))) {
                pos++
            }
            pos++
            if pos.lt(src_len).and(src.unsafe_get(pos).eq('\'')) {
                push_tok(tokens, TokenType.Char, ch_start, pos.sub(ch_start), line, col)
                pos++
            } else {
                println(path, ":", line.to_str(), ":", col.to_str(), ": error: unterminated character literal")
                push_tok(tokens, TokenType.Error, start, pos.sub(start), line, col)
            }
            continue

        // Numbers (issue #255): base-prefixed integers (0x/0b/0o), digit
        // separators ('_'), decimal fractions, and exponents (1e9, 1.5e-3).
        case '0'..'9':
            mut handled_prefix := false
            // Base-prefixed integer literal: 0x.., 0b.., 0o..
            if c.eq('0').and(pos.add(2).lt(src_len)) {
                ref p1 : I8 = src.unsafe_get(pos.add(1))
                ref p2 : I8 = src.unsafe_get(pos.add(2))
                if p1.eq('x').or(p1.eq('X')).and(is_hex_digit(p2)) {
                    pos = pos.add(2)
                    while pos.lt(src_len) {
                        ref d : I8 = src.unsafe_get(pos)
                        if is_hex_digit(d).or(d.eq('_')).not() { break }
                        pos++
                    }
                    handled_prefix = true
                } else if p1.eq('b').or(p1.eq('B')).and(is_bin_digit(p2)) {
                    pos = pos.add(2)
                    while pos.lt(src_len) {
                        ref d : I8 = src.unsafe_get(pos)
                        if is_bin_digit(d).or(d.eq('_')).not() { break }
                        pos++
                    }
                    handled_prefix = true
                } else if p1.eq('o').or(p1.eq('O')).and(is_oct_digit(p2)) {
                    pos = pos.add(2)
                    while pos.lt(src_len) {
                        ref d : I8 = src.unsafe_get(pos)
                        if is_oct_digit(d).or(d.eq('_')).not() { break }
                        pos++
                    }
                    handled_prefix = true
                }
            }
            if handled_prefix.not() {
                // Decimal integer part (with digit separators)
                while pos.lt(src_len) {
                    ref d : I8 = src.unsafe_get(pos)
                    if is_digit(d).or(d.eq('_')).not() { break }
                    pos++
                }
                // Fractional part: '.' immediately followed by a digit
                if pos.add(1).lt(src_len) {
                    if src.unsafe_get(pos).eq('.').and(is_digit(src.unsafe_get(pos.add(1)))) {
                        pos++
                        while pos.lt(src_len) {
                            ref d : I8 = src.unsafe_get(pos)
                            if is_digit(d).or(d.eq('_')).not() { break }
                            pos++
                        }
                    }
                }
                // Exponent: e/E with optional sign, then at least one digit
                if pos.lt(src_len) {
                    ref e : I8 = src.unsafe_get(pos)
                    if e.eq('e').or(e.eq('E')) {
                        mut epos := pos.add(1)
                        if epos.lt(src_len).and(src.unsafe_get(epos).eq('+').or(src.unsafe_get(epos).eq('-'))) {
                            epos++
                        }
                        if epos.lt(src_len).and(is_digit(src.unsafe_get(epos))) {
                            pos = epos
                            while pos.lt(src_len) {
                                ref d : I8 = src.unsafe_get(pos)
                                if is_digit(d).or(d.eq('_')).not() { break }
                                pos++
                            }
                        }
                    }
                }
            }
            push_tok(tokens, TokenType.Number, start, pos.sub(start), line, col)
            continue

        // Identifiers/keywords (alpha) and operators
        case:
            // Identifiers and keywords
            if is_alpha(c) {
                while pos.lt(src_len) {
                    if is_alnum(src.unsafe_get(pos)).not() { break }
                    pos++
                }
                word := src.substr(start, pos.sub(start))
                push_tok(tokens, lookup_keyword(word, KEYWORDS), start, pos.sub(start), line, col)
                continue
            }

            // Two-character tokens
            if pos.add(1).lt(src_len) {
                ref c2 : I8 = src.unsafe_get(pos.add(1))
                // Check for ... (three dots) before the two-char dispatch below
                if c.eq('.').and(c2.eq('.')).and(pos.add(2).lt(src_len)) {
                    ref c3 : I8 = src.unsafe_get(pos.add(2))
                    if c3.eq('.') {
                        push_tok(tokens, TokenType.DotDotDot, start, 3, line, col)
                        pos = pos.add(3)
                        continue
                    }
                }
                two := lookup_two_char(c, c2)
                if two.is(TokenType.Eof).not() {
                    push_tok(tokens, two, start, 2, line, col)
                    pos = pos.add(2)
                    continue
                }
            }

            // Single-character tokens
            single := lookup_single_char(c)
            if single.is(TokenType.Eof).not() {
                push_tok(tokens, single, start, 1, line, col)
                pos++
                continue
            }

            // Unknown character
            println(path, ":", line.to_str(), ":", col.to_str(), ": error: unexpected character")
            push_tok(tokens, TokenType.Error, start, 1, line, col)
            pos++
        }
    }

    // EOF
    col : U32 = pos.sub(line_start).add(1)
    push_tok(tokens, TokenType.Eof, pos, 0, line, col)
    return tokens
}
