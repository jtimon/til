// Look up a registered enum type's AST node by name, erroring out if
// the name is unknown or not an enum. Shared by the enum_variant_*
// introspection handlers (issue #57/#58).
interp_lookup_enum := proc(s: Scope, e: Expr, type_name: Str, who: Str, ctx: Context) returns ref Expr {
    ref tc : Cell = scope_get(s, type_name)
    if tc.is_null() {
        interp_error(e, who.concat(": type '").concat(type_name).concat("' not found"), ctx)
        exit(1)
    }
    switch tc.val {
    case Value.Func(fptr):
        ref node : Expr = deref(fptr)
        if node.node_type.is(NodeType.EnumDef).not() {
            interp_error(e, who.concat(": '").concat(type_name).concat("' is not an enum"), ctx)
            exit(1)
        }
        return node
    case:
        interp_error(e, who.concat(": '").concat(type_name).concat("' is not an enum"), ctx)
        exit(1)
        return NULL
    }
}

