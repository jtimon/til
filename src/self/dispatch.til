mode lib

import("../lib/libffi")

priv ExtStr := struct {
    ref mut data : U8 = NULL
    mut count : U64 = 0
    mut cap : U64 = 0
}

priv FFIEntry := struct {
    ref mut fn : U8 = NULL
    ref mut return_type : Str = NULL
    mut nparam : I32 = 0
    ref mut param_shallows : U8 = NULL
    mut return_is_shallow := false
    ref mut cif : ffi_cif = NULL
    ref mut arg_types : Dynamic = NULL
}

ExprPtrBox := struct {
    ref mut ptr : Expr = NULL
}

priv FFITypePtrBox := struct {
    ref mut ptr : ffi_type = NULL
}

mut dispatch_map := Map.new(Str, Dynamic)
mut dispatch_inited := false

mut ffi_map := Map.new(Str, FFIEntry)
mut ffi_struct_defs := Map.new(Str, Dynamic)
mut ffi_loaded := false

mut ffi_type_cache := Vec.new(FFITypePtrBox)
mut ffi_type_cache_inited := false

// Reset all FFI state so a fresh scan can run.
ffi_reset := proc() {
    if ffi_loaded {
        ffi_cleanup()
        ffi_map_inited = false
    } else if ffi_map_inited {
        Map.delete(own ffi_map, false)
        ffi_map_inited = false
    }
    // Always ensure struct defs map exists.
    ffi_struct_defs = Map.new(Str, Dynamic)
}

priv ffi_type_pointer_ref := func() returns ref ffi_type { return to_ptr(ffi_global_symbol("ffi_type_pointer")) }
priv ffi_type_sint64_ref := func() returns ref ffi_type { return to_ptr(ffi_global_symbol("ffi_type_sint64")) }
ffi_type_uint8_ref := func() returns ref ffi_type { return to_ptr(ffi_global_symbol("ffi_type_uint8")) }
ffi_type_sint8_ref := func() returns ref ffi_type { return to_ptr(ffi_global_symbol("ffi_type_sint8")) }
ffi_type_sint16_ref := func() returns ref ffi_type { return to_ptr(ffi_global_symbol("ffi_type_sint16")) }
priv ffi_type_sint32_ref := func() returns ref ffi_type { return to_ptr(ffi_global_symbol("ffi_type_sint32")) }
ffi_type_uint32_ref := func() returns ref ffi_type { return to_ptr(ffi_global_symbol("ffi_type_uint32")) }
ffi_type_uint64_ref := func() returns ref ffi_type { return to_ptr(ffi_global_symbol("ffi_type_uint64")) }
ffi_type_float_ref := func() returns ref ffi_type { return to_ptr(ffi_global_symbol("ffi_type_float")) }
ffi_type_void_ref := func() returns ref ffi_type { return to_ptr(ffi_global_symbol("ffi_type_void")) }

ffi_alloc_cif := func() returns Dynamic { return malloc(ffi_cif.size().to_u64()) }

ffi_cif_rtype_is_struct := func(cif: ffi_cif) returns shallow Bool {
    if is_null(cif.rtype) { return false }
    ref rt : ffi_type = cif.rtype
    return rt.type.eq(FFI_TYPE_STRUCT)
}

ffi_load_global_lib := ext_func(soname: Str) returns shallow Bool {}
ffi_open_user_so := ext_func(path: Str) returns shallow Bool {}
ffi_close_user_so := ext_proc() {}
ffi_user_symbol := ext_func(name: Str) returns ref U8 {}
ffi_global_symbol := ext_func(name: Str) returns ref U8 {}
ffi_last_error := ext_func() returns Str {}
stderr_print := ext_func(msg: Str) returns shallow I32 {}
system_cmd := ext_func(cmd: Str) returns shallow I32 {}
unlink_path := ext_proc(path: Str) {}
process_id := ext_func() returns shallow I32 {}

ffi_dlsym := func(name: Str) returns ref U8 {
    ref fn : U8 = ffi_user_symbol(name)
    if is_null(fn).not() {
        return fn
    }
    return ffi_global_symbol(name)
}

ffi_init_link_libs := func(link_flags: Str) {
    if is_null(link_flags) {
        return
    }
    mut i : USize = 0
    while i.add(1).lt(link_flags.len()) {
        if link_flags.byte_at(i).eq(45).and(link_flags.byte_at(i.add(1)).eq(108)) {
            i = i.add(2)
            start := i
            while i.lt(link_flags.len()) {
                if link_flags.byte_at(i).eq(32) {
                    break
                }
                i = i.add(1)
            }
            if i.gt(start) {
                lib := link_flags.substr(start, i.sub(start))
                soname := format("lib", lib, ".so")
                ffi_load_global_lib(soname)
            }
        } else {
            i = i.add(1)
        }
    }
}

ffi_init_user_so := func(fwd_path: Str, user_c_path: Str, ext_c_path: Str, link_flags: Str, mut so_path_out: Str) returns shallow I32 {
    so_path_out = Str(c_str = NULL, count = 0, cap = 0)
    if is_null(user_c_path) { return 0 }
    if user_c_path.len().eq(0) { return 0 }

    dot_str := "."
    slash := ext_c_path.rfind("/")
    mut ext_dir := dot_str
    if slash.gte(0) {
        ext_dir = ext_c_path.substr(0, slash.to_usize())
    }

    so_path_out = format("tmp/ffi_", process_id().to_str(), ".so")
    system_cmd("mkdir -p tmp")

    mut lf := ""
    if is_null(link_flags).not() {
        lf = link_flags
    }
    cmd := format("cc -Wall -Wextra -shared -fPIC -I", ext_dir,
        " -include ", fwd_path,
        " -o ", so_path_out,
        " ", user_c_path, lf)
    rc := system_cmd(cmd)
    if rc.neq(0) {
        stderr_print(format("error: failed to compile FFI library '", user_c_path, "'\n"))
        return 1
    }
    if ffi_open_user_so(so_path_out).not() {
        stderr_print(format("error: dlopen failed: ", ffi_last_error(), "\n"))
        return 1
    }
    return 0
}

ffi_init_struct_defs := func(program: Expr) {
    ffi_struct_defs = Map.new(Str, ExprPtrBox)
    ffi_init_struct_defs_append(program)
}

// Append struct defs found in program into ffi_struct_defs (does not reset).
ffi_init_struct_defs_append := func(program: Expr) {
    for stmt : Expr in program.children {
        if stmt.node_type.is(NodeType.Decl).not().or(stmt.children.len().eq(0)) {
            continue
        }
        ref sdef : Expr = stmt.child(0)
        if sdef.node_type.is(NodeType.StructDef).not() {
            continue
        }
        switch stmt.node_type {
        case NodeType.Decl(dd):
            key := Str(c_str = dd.name.c_str, count = dd.name.count, cap = CAP_VIEW)
            box := ExprPtrBox(ptr = sdef)
            ffi_struct_defs.set(own key, own box)
        case:
        }
    }
}

value_to_u64 := func(v: Value) returns U64 {
    switch v {
    case Value.Int(x):     return x.to_u64()
    case Value.Byte(x):    return x.to_u64()
    case Value.Short(x):   return x.to_u64()
    case Value.Int32(x):   return x.to_u64()
    case Value.Uint32(x):  return x.to_u64()
    case Value.Uint64(x):  return x.clone()
    case Value.Boolean(x):
        if x { return 1 }
        return 0
    case: return 0
    }
}

uptr_ffi_type := func() returns ref ffi_type {
    ref lp : LoadedProgram = codegen_lp()
    ref uptr_name : Str = resolve_type_alias(lp.ctx.scope, "UPtr")
    if uptr_name.eq("U32") { return ffi_type_uint32_ref() }
    return ffi_type_uint64_ref()
}

usize_ffi_type := func() returns ref ffi_type {
    ref lp : LoadedProgram = codegen_lp()
    ref usize_name : Str = resolve_type_alias(lp.ctx.scope, "USize")
    if usize_name.eq("U32") { return ffi_type_uint32_ref() }
    return ffi_type_uint64_ref()
}

priv value_to_f32 := func(v: Value) returns F32 {
    switch v {
    case Value.Int(x):     return x.to_f32()
    case Value.Byte(x):    return x.to_f32()
    case Value.Short(x):   return x.to_f32()
    case Value.Int32(x):   return x.to_f32()
    case Value.Uint32(x):  return x.to_f32()
    case Value.Uint64(x):  return x.to_f32()
    case Value.Float(x):   return x.clone()
    case Value.Boolean(x):
        if x { return 1.to_f32() }
        return 0.to_f32()
    case: return 0.to_f32()
    }
}

// Best-effort variant name for a Value, used in diagnostics. Value.to_str
// only handles a few variants; this covers the rest. Returns "?" if the
// tag is unrecognised (shouldn't happen, but the diagnostic shouldn't
// itself crash).
priv value_variant_name := func(v: Value) returns Str {
    if v.is(Value.None)    { return "None" }
    if v.is(Value.Int)     { return "Int" }
    if v.is(Value.Byte)    { return "Byte" }
    if v.is(Value.Short)   { return "Short" }
    if v.is(Value.Int32)   { return "Int32" }
    if v.is(Value.Uint32)  { return "Uint32" }
    if v.is(Value.Uint64)  { return "Uint64" }
    if v.is(Value.Float)   { return "Float" }
    if v.is(Value.Boolean) { return "Boolean" }
    if v.is(Value.Func)    { return "Func" }
    if v.is(Value.Struct)  { return "Struct" }
    if v.is(Value.Enum)    { return "Enum" }
    if v.is(Value.Ptr)     { return "Ptr" }
    return "?"
}

// Narrow an FCall arg to a Value.Boolean. Used by h_Bool_and/or/not to
// pull the (possibly Value.Ptr) arg out of eval_expr and route it
// through reinterpret_ptr_value -- the same helper ref bindings, param
// binding, and ext_dispatch_ffi use. Panics if the arg doesn't end up
// as a Bool (silently defaulting to false would mask cast/typer bugs;
// the Bool handlers are reached via FFI dispatch on top-level
// and/or/not, so the typer should only let Bool-shaped values through).
priv narrow_bool_arg := proc(s: Scope, e: Expr) returns Bool {
    v := reinterpret_ptr_value(eval_expr(s, e), "Bool", s)
    switch v {
    case Value.Boolean(bv):
        return bv.clone()
    case:
        panic(__LOC__, "expected Bool argument to and/or/not, got Value.", value_variant_name(v))
        return false
    }
}

h_Bool_and := proc(s: Scope, e: Expr, mut r: Value) returns shallow Bool {
    av := narrow_bool_arg(s, e.child(1))
    bv := narrow_bool_arg(s, e.child(2))
    r = val_bool(and(av, bv))
    return true
}

h_Bool_or := proc(s: Scope, e: Expr, mut r: Value) returns shallow Bool {
    av := narrow_bool_arg(s, e.child(1))
    bv := narrow_bool_arg(s, e.child(2))
    r = val_bool(or(av, bv))
    return true
}

h_Bool_not := proc(s: Scope, e: Expr, mut r: Value) returns shallow Bool {
    bv := narrow_bool_arg(s, e.child(1))
    r = val_bool(not(bv))
    return true
}

h_U8_from_i64 := proc(s: Scope, e: Expr, mut r: Value) returns shallow Bool {
    v := eval_expr(s, e.child(1))
    switch v {
    case Value.Int(i):
        r = val_u8(i)
        return true
    case:
        UNREACHABLE(__LOC__)
        return false
    }
}

