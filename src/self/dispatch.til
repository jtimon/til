mode lib

ExtStr := struct {
    ref mut data : U8 = NULL
    mut count : U64 = 0
    mut cap : U64 = 0
}

ffi_type := ext_struct("_ffi_type") {
    mut size : USize = 0
    mut alignment : I16 = 0
    mut type : I16 = 0
    ref mut elements : Dynamic = NULL
}

ffi_cif := ext_struct("") {
    mut abi : I32 = 0
    mut nargs : U32 = 0
    ref mut arg_types : Dynamic = NULL
    ref mut rtype : Dynamic = NULL
    mut bytes : U32 = 0
    mut flags : U32 = 0
}

FFI_DEFAULT_ABI := 2.to_i32()
FFI_TYPE_STRUCT := 13.to_i16()

FFIEntry := struct {
    ref mut fn : U8 = NULL
    ref mut return_type : Str = NULL
    mut nparam : I32 = 0
    ref mut param_shallows : U8 = NULL
    mut return_is_shallow := false
    ref mut cif : ffi_cif = NULL
    ref mut arg_types : Dynamic = NULL
}

ExprPtrBox := struct {
    ref mut ptr : Expr = NULL
}

FFITypePtrBox := struct {
    ref mut ptr : ffi_type = NULL
}

mut dispatch_map := Map.new("Str", Str.size(), "Dynamic", Dynamic.size())
mut dispatch_inited := false

mut ffi_map := Map.new("Str", Str.size(), "FFIEntry", FFIEntry.size())
mut ffi_struct_defs := Map.new("Str", Str.size(), "Dynamic", Dynamic.size())
mut ffi_loaded := false

mut ffi_type_cache := Vec.new("FFITypePtrBox", FFITypePtrBox.size())
mut ffi_type_cache_inited := false

ffi_type_pointer_ref := func() returns ref ffi_type { return to_ptr(ffi_global_symbol("ffi_type_pointer")) }
ffi_type_sint64_ref := func() returns ref ffi_type { return to_ptr(ffi_global_symbol("ffi_type_sint64")) }
ffi_type_uint8_ref := func() returns ref ffi_type { return to_ptr(ffi_global_symbol("ffi_type_uint8")) }
ffi_type_sint16_ref := func() returns ref ffi_type { return to_ptr(ffi_global_symbol("ffi_type_sint16")) }
ffi_type_sint32_ref := func() returns ref ffi_type { return to_ptr(ffi_global_symbol("ffi_type_sint32")) }
ffi_type_uint32_ref := func() returns ref ffi_type { return to_ptr(ffi_global_symbol("ffi_type_uint32")) }
ffi_type_uint64_ref := func() returns ref ffi_type { return to_ptr(ffi_global_symbol("ffi_type_uint64")) }
ffi_type_float_ref := func() returns ref ffi_type { return to_ptr(ffi_global_symbol("ffi_type_float")) }
ffi_type_void_ref := func() returns ref ffi_type { return to_ptr(ffi_global_symbol("ffi_type_void")) }

// Declare ffi_prep_cif and ffi_call directly from libffi
ffi_prep_cif := ext_func(cif: ffi_cif, shallow abi: I32, shallow nargs: U32, rtype: ffi_type, atypes: Dynamic) returns shallow I32 {}
ffi_call := ext_proc(cif: ffi_cif, fn: Dynamic, rvalue: Dynamic, avalue: Dynamic) {}

ffi_alloc_cif := func() returns Dynamic { return malloc(ffi_cif.size().to_u64()) }

ffi_cif_rtype_is_struct := func(cif: ffi_cif) returns shallow Bool {
    if is_null(cif.rtype) { return false }
    ref rt : ffi_type = to_ptr(cif.rtype)
    return rt.type.eq(FFI_TYPE_STRUCT)
}

ffi_load_global_lib := ext_func(soname: Str) returns shallow Bool {}
ffi_open_user_so := ext_func(path: Str) returns shallow Bool {}
ffi_close_user_so := ext_proc() {}
ffi_user_symbol := ext_func(name: Str) returns ref U8 {}
ffi_global_symbol := ext_func(name: Str) returns ref U8 {}
ffi_last_error := ext_func() returns Str {}
stderr_print := ext_func(msg: Str) returns shallow I32 {}
system_cmd := ext_func(cmd: Str) returns shallow I32 {}
unlink_path := ext_proc(path: Str) {}
process_id := ext_func() returns shallow I32 {}

ffi_dlsym := func(name: Str) returns ref U8 {
    ref fn : U8 = ffi_user_symbol(name)
    if is_null(fn).not() {
        return fn
    }
    return ffi_global_symbol(name)
}

ffi_init_link_libs := proc(link_flags: Str) {
    if is_null(link_flags) {
        return
    }
    mut i : USize = 0
    while i.add(1).lt(link_flags.len()) {
        if link_flags.byte_at(i).eq(45).and(link_flags.byte_at(i.add(1)).eq(108)) {
            i = i.add(2)
            start := i
            while i.lt(link_flags.len()) {
                if link_flags.byte_at(i).eq(32) {
                    break
                }
                i = i.add(1)
            }
            if i.gt(start) {
                lib := link_flags.substr(start, i.sub(start))
                soname := format("lib", lib, ".so")
                ffi_load_global_lib(soname)
            }
        } else {
            i = i.add(1)
        }
    }
}

ffi_init_user_so := func(fwd_path: Str, user_c_path: Str, ext_c_path: Str, link_flags: Str, mut so_path_out: Str) returns shallow I32 {
    so_path_out = Str(c_str = NULL, count = 0, cap = 0)
    if is_null(user_c_path) { return 0 }
    if user_c_path.len().eq(0) { return 0 }

    dot_str := "."
    slash := ext_c_path.rfind("/")
    mut ext_dir := dot_str
    if slash.gte(0) {
        ext_dir = ext_c_path.substr(0, slash.to_usize())
    }

    so_path_out = format("tmp/ffi_", process_id().to_str(), ".so")
    system_cmd("mkdir -p tmp")

    mut lf := ""
    if is_null(link_flags).not() {
        lf = link_flags
    }
    cmd := format("cc -Wall -Wextra -shared -fPIC -I", ext_dir,
                  " -include ", fwd_path,
                  " -o ", so_path_out,
                  " ", user_c_path, lf)
    rc := system_cmd(cmd)
    if rc.neq(0) {
        stderr_print(format("error: failed to compile FFI library '", user_c_path, "'\n"))
        return 1
    }
    if ffi_open_user_so(so_path_out).not() {
        stderr_print(format("error: dlopen failed: ", ffi_last_error(), "\n"))
        return 1
    }
    return 0
}

ffi_init_struct_defs := proc(program: Expr) {
    ffi_struct_defs = Map.new("Str", Str.size(), "ExprPtrBox", ExprPtrBox.size())
    for i in 0..program.child_count() {
        ref stmt : Expr = program.child(i)
        if stmt.data.is(NodeType.Decl).not().or(stmt.child_count().eq(0)) {
            continue
        }
        ref sdef : Expr = stmt.child(0)
        if sdef.data.is(NodeType.StructDef).not() {
            continue
        }
        ref dd : Declaration = get_payload(stmt.data)
        key := Str(c_str = dd.name.c_str, count = dd.name.count, cap = CAP_VIEW)
        box := ExprPtrBox(ptr = sdef)
        ffi_struct_defs.set(own key, own box)
    }
}

value_to_i64 := func(v: Value) returns I64 {
    if v.is(Value.Int) {
        ref x : I64 = get_payload(v)
        return x.clone()
    }
    if v.is(Value.Byte) {
        ref x : U8 = get_payload(v)
        return x.to_u64().to_i64()
    }
    if v.is(Value.Short) {
        ref x : I16 = get_payload(v)
        return x.to_i64()
    }
    if v.is(Value.Int32) {
        ref x : I32 = get_payload(v)
        return x.to_i64()
    }
    if v.is(Value.Uint32) {
        ref x : U32 = get_payload(v)
        return x.to_i64()
    }
    if v.is(Value.Uint64) {
        ref x : U64 = get_payload(v)
        return x.to_i64()
    }
    if v.is(Value.Boolean) {
        ref x : Bool = get_payload(v)
        if x { return 1 }
        return 0
    }
    return 0
}

value_to_u64 := func(v: Value) returns U64 {
    if v.is(Value.Int) {
        ref x : I64 = get_payload(v)
        return x.to_u64()
    }
    if v.is(Value.Byte) {
        ref x : U8 = get_payload(v)
        return x.to_u64()
    }
    if v.is(Value.Short) {
        ref x : I16 = get_payload(v)
        return x.to_i64().to_u64()
    }
    if v.is(Value.Int32) {
        ref x : I32 = get_payload(v)
        return x.to_i64().to_u64()
    }
    if v.is(Value.Uint32) {
        ref x : U32 = get_payload(v)
        return x.to_u64()
    }
    if v.is(Value.Uint64) {
        ref x : U64 = get_payload(v)
        return x.clone()
    }
    if v.is(Value.Boolean) {
        ref x : Bool = get_payload(v)
        if x { return 1 }
        return 0
    }
    return 0
}

value_to_f32 := func(v: Value) returns F32 {
    switch v {
    case Value.Int:
        ref x : I64 = get_payload(v)
        return x.to_f32()
    case Value.Byte:
        ref x : U8 = get_payload(v)
        return x.to_u64().to_i64().to_f32()
    case Value.Short:
        ref x : I16 = get_payload(v)
        return x.to_i64().to_f32()
    case Value.Int32:
        ref x : I32 = get_payload(v)
        return x.to_i64().to_f32()
    case Value.Uint32:
        ref x : U32 = get_payload(v)
        return x.to_i64().to_f32()
    case Value.Uint64:
        ref x : U64 = get_payload(v)
        return x.to_i64().to_f32()
    case Value.Float:
        ref x : F32 = get_payload(v)
        return x.clone()
    case Value.Boolean:
        ref x : Bool = get_payload(v)
        if x { return 1.to_f32() }
        return 0.to_f32()
    case:
        return 0.to_f32()
    }
}

eval_arg := proc(s: Scope, e: Expr) returns Value {
    v := eval_expr(s, e)
    if v.is(Value.Ptr).not().or(e.til_type.eq(TilType.Dynamic)) {
        return v
    }
    ref p : Dynamic = get_payload(v)
    switch e.til_type {
    case TilType.I64:
        ref x : I64 = p
        return val_i64(x)
    case TilType.U8:
        ref x : U8 = p
        return val_u8(x.to_i64())
    case TilType.I16:
        ref x : I16 = p
        return val_i16(x.to_i64())
    case TilType.I32:
        ref x : I32 = p
        return val_i32(x)
    case TilType.U32:
        ref x : U32 = p
        return val_u32(x.to_i64())
    case TilType.U64:
        ref x : U64 = p
        return val_u64(x)
    case TilType.F32:
        ref x : F32 = p
        return val_f32(x)
    case TilType.Bool:
        ref x : Bool = p
        return val_bool(x)
    case TilType.Struct:
        if til_type_name(e.til_type).eq("Str") {
            ref sp : ExtStr = p
            return make_str_value_own(sp.data, sp.count)
        }
        ref si : StructInstance = p
        return Value.Struct(si)
    case:
        return v
    }
}

h_Bool_and := proc(s: Scope, e: Expr, mut r: Value) returns shallow Bool {
    a := eval_arg(s, e.child(1))
    b := eval_arg(s, e.child(2))
    ref av : Bool = get_payload(a)
    ref bv : Bool = get_payload(b)
    r = val_bool(and(av, bv))
    return true
}

