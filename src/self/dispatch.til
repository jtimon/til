}

val_to_ptr := func(v: Value) returns ref Dynamic {
    switch v {
    case Value.Ptr(p):     return p
    case Value.Int(p):     return p
    case Value.Byte(p):    return p
    case Value.Short(p):   return p
    case Value.Int32(p):   return p
    case Value.Uint32(p):  return p
    case Value.Float(p):   return p
    case Value.Boolean(p): return p
    case Value.Struct(x):  return x.data
    case: return NULL
    }
}

h_dyn_has_method := proc(s: Scope, e: Expr, mut r: Value) returns shallow Bool {
    type_name_val := eval_expr(s, e.child(1))
    method_val := eval_expr(s, e.child(2))
    type_name := str_view(type_name_val)
    method := str_view(method_val)
    r = val_bool(is_null(ns_get(type_name, method)).not())
    return true
}

h_dyn_fn := proc(s: Scope, e: Expr, mut r: Value) returns shallow Bool {
    type_name_val := eval_expr(s, e.child(1))
    method_val := eval_expr(s, e.child(2))
    type_name := str_view(type_name_val)
    method := str_view(method_val)
    ref nsv : Value = ns_get(type_name, method)
    if is_null(nsv) {
        panic(__LOC__, "dyn_fn: unknown ", type_name, ".", method)
    }
    if nsv.is(Value.Func).not() {
        panic(__LOC__, "dyn_fn: unknown ", type_name, ".", method)
    }
    r = nsv.clone()
    return true
}

h_dyn_size_of := proc(s: Scope, e: Expr, mut r: Value) returns shallow Bool {
    type_name_val := eval_expr(s, e.child(1))
    type_name := str_view(type_name_val)
    sz := get_elem_size(s, type_name, e)
    r = val_u32(sz.to_i64())
    return true
}

h_dyn_type_to_str := proc(s: Scope, e: Expr, mut r: Value) returns shallow Bool {
    type_val := eval_expr(s, e.child(1))
    switch type_val {
    case Value.Enum(ei):
        ref til_type_def : Expr = lookup_interp_type_def("Type")
        if is_null(til_type_def) {
            panic(__LOC__, "dyn_type_to_str: Type definition not registered")
        }
        ref tag_ptr : Dynamic = ei.data
        ref tag_ref : I32 = tag_ptr
        tag := tag_ref
        if tag.eq(enum_variant_tag(til_type_def, "Unknown")).or(tag.eq(enum_variant_tag(til_type_def, "None"))) {
            r = make_str_value("".c_str, 0)
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "I64")) {
            r = make_str_value("I64".c_str, 3)
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "U8")) {
            r = make_str_value("U8".c_str, 2)
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "I16")) {
            r = make_str_value("I16".c_str, 3)
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "I32")) {
            r = make_str_value("I32".c_str, 3)
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "U32")) {
            r = make_str_value("U32".c_str, 3)
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "U64")) {
            r = make_str_value("U64".c_str, 3)
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "F32")) {
            r = make_str_value("F32".c_str, 3)
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "Bool")) {
            r = make_str_value("Bool".c_str, 4)
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "Struct")) {
            ref payload : Str = ptr_add(ei.data, ENUM_PAYLOAD_OFFSET.to_u64())
            r = make_str_value(payload.c_str, payload.count.to_u64())
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "StructDef")) {
            r = make_str_value("StructDef".c_str, 9)
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "Enum")) {
            ref payload2 : Str = ptr_add(ei.data, ENUM_PAYLOAD_OFFSET.to_u64())
            r = make_str_value(payload2.c_str, payload2.count.to_u64())
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "EnumDef")) {
            r = make_str_value("EnumDef".c_str, 7)
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "FuncDef")) {
            r = make_str_value("FunctionDef".c_str, 11)
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "FuncPtr")) {
            r = make_str_value("Fn".c_str, 2)
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "Dynamic")) {
            r = make_str_value("Dynamic".c_str, 7)
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "Custom")) {
            ref payload3 : Str = ptr_add(ei.data, ENUM_PAYLOAD_OFFSET.to_u64())
            r = make_str_value(payload3.c_str, payload3.count.to_u64())
            return true
        }
        panic(__LOC__, "dyn_type_to_str: unknown Type tag")
        r = make_str_value("".c_str, 0)
        return true
    case:
        panic(__LOC__, "dyn_type_to_str: expected Type enum value")
        return false
    }
}

h_check_cmd_status := proc(s: Scope, e: Expr, mut r: Value) returns shallow Bool {
