        sleep_ms(ms)
        r = val_none()
        return true
    case:
        UNREACHABLE(__LOC__)
        return false
    }
}

h_file_mtime := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    path := eval_expr(s, e.child(1), ctx)
    r = val_i64(file_mtime(str_view(path)))
