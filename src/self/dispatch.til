shallow_ffi_type := func(type_name: Str) returns ref ffi_type {
    if type_name.eq("I64")   { return ffi_type_sint64_ref() }
    if type_name.eq("U8")    { return ffi_type_uint8_ref() }
    if type_name.eq("I16")   { return ffi_type_sint16_ref() }
    if type_name.eq("I32")   { return ffi_type_sint32_ref() }
    if type_name.eq("U32")   { return ffi_type_uint32_ref() }
    if type_name.eq("U64")   { return ffi_type_uint64_ref() }
    if type_name.eq("USize") { return ffi_type_uint32_ref() }
    if type_name.eq("F32")   { return ffi_type_float_ref() }
    if type_name.eq("Bool")  { return ffi_type_uint8_ref() }
    if ffi_struct_defs.has(type_name) {
        ref box : ExprPtrBox = ffi_struct_defs.get(type_name)
        return build_struct_ffi_type(box.ptr)
    }
    return ffi_type_pointer_ref()
}

field_ffi_type := func(field: Expr) returns ref ffi_type {
    ref dd : Declaration = get_payload(field.data)
    if dd.own_type.eq(OwnType.Shallow).not() { return ffi_type_pointer_ref() }
    if dd.explicit_type.len().eq(0) { return ffi_type_sint64_ref() }
    if dd.explicit_type.eq("I64")   { return ffi_type_sint64_ref() }
    if dd.explicit_type.eq("U8")    { return ffi_type_uint8_ref() }
    if dd.explicit_type.eq("I16")   { return ffi_type_sint16_ref() }
    if dd.explicit_type.eq("I32")   { return ffi_type_sint32_ref() }
    if dd.explicit_type.eq("U32")   { return ffi_type_uint32_ref() }
    if dd.explicit_type.eq("U64")   { return ffi_type_uint64_ref() }
    if dd.explicit_type.eq("USize") { return ffi_type_uint32_ref() }
    if dd.explicit_type.eq("F32")   { return ffi_type_float_ref() }
    if dd.explicit_type.eq("Bool")  { return ffi_type_uint8_ref() }
    if is_null(dd.field_struct_def).not() {
        return build_struct_ffi_type(dd.field_struct_def)
    }
    return ffi_type_sint64_ref()
}

build_struct_ffi_type := func(struct_def: Expr) returns ref ffi_type {
    if ffi_type_cache_inited.not() {
        ffi_type_cache = Vec.new("FFITypePtrBox", FFITypePtrBox.size())
        ffi_type_cache_inited = true
    }
    ref body : Expr = struct_def.child(0)
    mut nfields : U32 = 0
    for i in 0..body.child_count() {
        ref f : Expr = body.child(i)
        if f.data.is(NodeType.Decl) {
            ref fd : Declaration = get_payload(f.data)
            if fd.is_namespace.not() {
                nfields = nfields.add(1)
            }
        }
    }
    elements : Dynamic = malloc(nfields.add(1).to_u64().mul(Dynamic.size().to_u64()))
    mut idx : U32 = 0
    for i in 0..body.child_count() {
        ref f : Expr = body.child(i)
        if f.data.is(NodeType.Decl) {
            ref fd : Declaration = get_payload(f.data)
            if fd.is_namespace.not() {
                ref ft : ffi_type = field_ffi_type(f)
                memcpy(ptr_add(elements, idx.to_u64().mul(Dynamic.size().to_u64())), ft, Dynamic.size().to_u64())
                idx = idx.add(1)
            }
        }
    }
    memset(ptr_add(elements, nfields.to_u64().mul(Dynamic.size().to_u64())), 0, Dynamic.size().to_u64())
    st : Dynamic = malloc(ffi_type.size().to_u64())
    ref mut stp : ffi_type = to_ptr(st)
    stp.size = 0
    stp.alignment = 0.to_i16()
    stp.type = FFI_TYPE_STRUCT
    stp.elements = elements
    box := FFITypePtrBox(ptr = stp)
    ffi_type_cache.push(own box)
    return stp
}

h_free := proc(s: Scope, e: Expr, mut r: Value) returns shallow Bool {
    if e.child(1).data.is(NodeType.Ident).not() {
        val := eval_expr(s, e.child(1))
        free_value(val)
        r = val_none()
        return true
    }
    ref ident : Str = get_payload(e.child(1).data)
    ref cell : Cell = scope_get(s, ident)
    free_value(cell.val)
    memcpy(cell.val, val_none(), Value.size())
    r = val_none()
    return true
}

