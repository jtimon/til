mode lib

import("../std/sys")
import("../../vendor/bindings/libffi")
link("vendor/libffi/x86_64-pc-linux-gnu/.libs/libffi.a")

priv ExtStr := struct {
    ref data : U8 = NULL
    count : USize = 0
    cap : USize = 0
}

FFIEntry := struct {
    ref fn : U8 = NULL
    ref return_type : Str = NULL
    nparam : I32 = 0
    ref param_shallows : U8 = NULL
    return_is_shallow := false
    ref cif : ffi_cif = NULL
    ref arg_types : Dynamic = NULL
}

ExprPtrBox := struct {
    ref ptr : Expr = NULL
}

FFITypePtrBox := struct {
    ref ptr : ffi_type = NULL
}

// Reset all FFI state so a fresh scan can run.
ffi_reset := proc(ctx: Context) {
    if ctx.ffi_loaded {
        ffi_cleanup(ctx)
        ctx.ffi_map_inited = false
    } else if ctx.ffi_map_inited {
        // Reset to a fresh empty map (instead of deleting it) so the
        // Context that owns ffi_map only ever auto-deletes a live map.
        ctx.ffi_map = Map.new(Str, FFIEntry)
        ctx.ffi_map_inited = false
    }
    // Always ensure struct defs map exists.
    ctx.ffi_struct_defs = Map.new(Str, Dynamic)
}

// libffi exposes its primitive ffi_type descriptors as global symbols
// (ffi_type_uint8, ffi_type_sint64, ...). Resolve one by name into a
// ref. Replaces a former family of ten near-identical
// ffi_type_<t>_ref() one-liner accessors.
priv ffi_type_ref := func(name: Str) returns ref ffi_type {
    return to_ptr(ffi_global_symbol(name))
}

ffi_alloc_cif := func() returns Dynamic { return malloc(ffi_cif.size()) }

ffi_cif_rtype_is_struct := func(cif: ffi_cif) returns Bool {
    if cif.rtype.is_null() { return false }
    ref rt : ffi_type = cif.rtype
    return rt.type.eq(FFI_TYPE_STRUCT.to_i16())
}

ffi_load_global_lib := ext_func(soname: Str) returns shallow Bool {}
ffi_open_user_so := ext_func(path: Str) returns shallow Bool {}
ffi_close_user_so := ext_proc() {}
ffi_user_symbol := ext_func(name: Str) returns ref U8 {}
ffi_global_symbol := ext_func(name: Str) returns ref U8 {}
ffi_last_error := ext_func() returns Str {}
stderr_print := ext_func(msg: Str) returns shallow I32 {}
system_cmd := ext_func(cmd: Str) returns shallow I32 {}
unlink_path := ext_proc(path: Str) {}
process_id := ext_func() returns shallow I32 {}

ffi_dlsym := func(name: Str) returns ref U8 {
    ref fn : U8 = ffi_user_symbol(name)
    if fn.is_null().not() {
        return fn
    }
    return ffi_global_symbol(name)
}

ffi_init_link_libs := func(link_flags: Str) {
    if link_flags.is_null() {
        return
    }
    mut i : USize = 0
    while i.add(1).lt(link_flags.len()) {
        if link_flags.byte_at(i).eq(45).and(link_flags.byte_at(i.add(1)).eq(108)) {
            i = i.add(2)
            start := i
            while i.lt(link_flags.len()) {
                if link_flags.byte_at(i).eq(32) {
                    break
                }
                i = i.add(1)
            }
            if i.gt(start) {
                lib := link_flags.substr(start, i.sub(start))
                soname := format("lib", lib, ".so")
                ffi_load_global_lib(soname)
            }
        } else {
            i = i.add(1)
        }
    }
}

ffi_init_user_so := func(fwd_path: Str, user_c_path: Str, ext_c_path: Str, link_flags: Str, mut so_path_out: Str) returns I32 {
    so_path_out = Str(c_str = NULL, count = 0, cap = 0)
    if user_c_path.is_null() { return 0 }
    if user_c_path.len().eq(0) { return 0 }

    dot_str := "."
    slash := ext_c_path.rfind("/")
    mut ext_dir := dot_str
    if slash.gte(0) {
        ext_dir = ext_c_path.substr(0, slash.to_usize())
    }

    so_path_out = format("tmp/ffi_", process_id().to_str(), ".so")
    system_cmd("mkdir -p tmp")

    mut lf := ""
    if link_flags.is_null().not() {
        lf = link_flags
    }
    cmd := format("cc -Wall -Wextra -shared -fPIC -I", ext_dir,
        " -include ", fwd_path,
        " -o ", so_path_out,
        " ", user_c_path, lf)
    rc := system_cmd(cmd)
    if rc.neq(0) {
        stderr_print(format("error: failed to compile FFI library '", user_c_path, "'\n"))
        return 1
    }
    if ffi_open_user_so(so_path_out).not() {
        stderr_print(format("error: dlopen failed: ", ffi_last_error(), "\n"))
        return 1
    }
    return 0
}

ffi_init_struct_defs := func(program: Expr, ctx: Context) {
    ctx.ffi_struct_defs = Map.new(Str, ExprPtrBox)
    ffi_init_struct_defs_append(program, ctx)
}

// Append struct defs found in program into ctx.ffi_struct_defs (does not reset).
ffi_init_struct_defs_append := func(program: Expr, ctx: Context) {
    for stmt : Expr in program.children {
        if stmt.node_type.is(NodeType.Decl).not().or(stmt.children.len().eq(0)) {
            continue
        }
        ref sdef : Expr = stmt.child(0)
        if sdef.node_type.is(NodeType.StructDef).not() {
            continue
        }
        switch stmt.node_type {
        case NodeType.Decl(dd):
            key := Str(c_str = dd.name.c_str, count = dd.name.count, cap = CAP_VIEW)
            box := ExprPtrBox(ptr = sdef)
            ctx.ffi_struct_defs.set(own key, own box)
        case:
        }
    }
}

value_to_u64 := func(v: Value) returns U64 {
    switch v {
    case Value.Int(x):     return x.cast(U64)
    case Value.Byte(x):    return x.cast(U64)
    case Value.Sbyte(x):   return x.to_u64()
    case Value.Short(x):   return x.to_u64()
    case Value.Ushort(x):  return x.cast(U64)
    case Value.Int32(x):   return x.to_u64()
    case Value.Uint32(x):  return x.cast(U64)
    case Value.Uint64(x):  return x.clone()
    case Value.Boolean(x):
        if x { return 1 }
        return 0
    case: return 0
    }
}

uptr_ffi_type := func(ctx: Context) returns ref ffi_type {
    ref uptr_name : Str = resolve_type_alias(ctx.scope, "UPtr")
    if uptr_name.eq("U32") { return ffi_type_ref("ffi_type_uint32") }
    return ffi_type_ref("ffi_type_uint64")
}

usize_ffi_type := func(ctx: Context) returns ref ffi_type {
    ref usize_name : Str = resolve_type_alias(ctx.scope, "USize")
    if usize_name.eq("U32") { return ffi_type_ref("ffi_type_uint32") }
    return ffi_type_ref("ffi_type_uint64")
}

priv value_to_f32 := func(v: Value) returns F32 {
    switch v {
    case Value.Int(x):     return x.to_f32()
    case Value.Byte(x):    return x.to_f32()
    case Value.Sbyte(x):   return x.cast(I64).to_f32()
    case Value.Short(x):   return x.to_f32()
    case Value.Ushort(x):  return x.to_f32()
    case Value.Int32(x):   return x.to_f32()
    case Value.Uint32(x):  return x.to_f32()
    case Value.Uint64(x):  return x.to_f32()
    case Value.Float(x):   return x.clone()
    case Value.Boolean(x):
        if x { return 1 }
        return 0
    case: return 0
    }
}

// Best-effort variant name for a Value, used in diagnostics. Value.to_str
// only handles a few variants; this covers the rest. Returns "?" if the
// tag is unrecognised (shouldn't happen, but the diagnostic shouldn't
// itself crash).
priv value_variant_name := func(v: Value) returns Str {
    if v.is(Value.None)    { return "None" }
    if v.is(Value.Int)     { return "Int" }
    if v.is(Value.Byte)    { return "Byte" }
    if v.is(Value.Short)   { return "Short" }
    if v.is(Value.Int32)   { return "Int32" }
    if v.is(Value.Uint32)  { return "Uint32" }
    if v.is(Value.Uint64)  { return "Uint64" }
    if v.is(Value.Float)   { return "Float" }
    if v.is(Value.Boolean) { return "Boolean" }
    if v.is(Value.Func)    { return "Func" }
    if v.is(Value.Struct)  { return "Struct" }
    if v.is(Value.Enum)    { return "Enum" }
    if v.is(Value.Ref)     { return "Ref" }
    if v.is(Value.Dynamic) { return "Dynamic" }
    return "?"
}

// Narrow an FCall arg to a Value.Boolean. Used by h_Bool_and/or/not to
// pull the (possibly Value.Ref/Value.Dynamic) arg out of eval_expr and route it
// through reinterpret_ptr_value -- the same helper ref bindings, param
// binding, and ext_dispatch_ffi use. Panics if the arg doesn't end up
// as a Bool (silently defaulting to false would mask cast/typer bugs;
// the Bool handlers are reached via FFI dispatch on top-level
// and/or/not, so the typer should only let Bool-shaped values through).
priv narrow_bool_arg := proc(s: Scope, e: Expr, ctx: Context) returns Bool {
    v := reinterpret_ptr_value(eval_expr(s, e, ctx), "Bool", s, ctx)
    switch v {
    case Value.Boolean(bv):
        return bv.clone()
    case:
        panic(__LOC__, "expected Bool argument to and/or/not, got Value.", value_variant_name(v))
        return false
    }
}

h_Bool_and := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    av := narrow_bool_arg(s, e.child(1), ctx)
    bv := narrow_bool_arg(s, e.child(2), ctx)
    r = val_bool(and(av, bv))
    return true
}

h_Bool_or := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    av := narrow_bool_arg(s, e.child(1), ctx)
    bv := narrow_bool_arg(s, e.child(2), ctx)
    r = val_bool(or(av, bv))
    return true
}

h_Bool_not := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    bv := narrow_bool_arg(s, e.child(1), ctx)
    r = val_bool(not(bv))
    return true
}

h_U8_from_i64 := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    v := eval_expr(s, e.child(1), ctx)
    switch v {
    case Value.Int(i):
        r = val_u8(i)
        return true
    case:
        UNREACHABLE(__LOC__)
        return false
    }
}

h_I16_from_i64 := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    v := eval_expr(s, e.child(1), ctx)
    switch v {
    case Value.Int(i):
        r = val_i16(i)
        return true
    case:
        UNREACHABLE(__LOC__)
        return false
    }
}

h_U16_from_i64 := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    v := eval_expr(s, e.child(1), ctx)
    switch v {
    case Value.Int(i):
        r = val_u16(i)
        return true
    case:
        UNREACHABLE(__LOC__)
        return false
    }
}

h_I32_from_i64 := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    v := eval_expr(s, e.child(1), ctx)
    switch v {
    case Value.Int(i):
        r = val_i32(i)
