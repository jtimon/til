}

// Look up a registered FuncSig type's bodyless FuncDef node by name,
// erroring out if the name is unknown or not a function signature.
// Shared by the func_sig_* introspection handlers (issue #58).
interp_lookup_funcsig := proc(s: Scope, e: Expr, type_name: Str, who: Str, ctx: Context) returns ref Expr {
    ref tc : Cell = scope_get(s, type_name)
    if tc.is_null() {
        interp_error(e, who.concat(": type '").concat(type_name).concat("' not found"), ctx)
        exit(1)
    }
    switch tc.val {
    case Value.Func(fptr):
        ref node : Expr = deref(fptr)
        if node.node_type.is(NodeType.FuncDef).not() {
            interp_error(e, who.concat(": '").concat(type_name).concat("' is not a function signature"), ctx)
            exit(1)
        }
        return node
    case:
        interp_error(e, who.concat(": '").concat(type_name).concat("' is not a function signature"), ctx)
        exit(1)
        return NULL
    }
}

