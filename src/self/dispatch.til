}

h_F32_from_i64 := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    v := eval_expr(s, e.child(1), ctx)
    switch v {
    case Value.Int(i):
        r = val_f32(i.to_f32())
        return true
    case:
        UNREACHABLE(__LOC__)
        return false
    }
