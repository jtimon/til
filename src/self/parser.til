mode lib

import("lexer")

// --- Parser state ---

priv Parser := struct {
    tokens := Vec.new(Token)
    pos : USize = 0
    path := ""
    fn_sig_decls := Vec.new(Expr)
    // Issue #56/#57: top-level decls synthesised for anonymous struct/enum
    // literals (`struct { ... }(args)`, `enum { ... }.V`, and inline defs in
    // type positions). anon_cache maps a literal's structural key (anon_def_key)
    // to its generated AnonStructN/AnonEnumN name so structurally-identical
    // literals in one file share a single type -- including a type-position
    // literal and the value-position literal it is assigned from. Flushed into
    // the program root by `parse`, like fn_sig_decls.
    anon_decls := Vec.new(Expr)
    anon_cache := Map.new(Str, Str)
    // Accumulates the text of leading /// doc comments. Cleared by
    // parse_statement after attaching to the next NodeType.Decl.
    pending_doc := ""
}

priv peek := func(p: Parser) returns ref Token {
    ref t : Token = p.tokens.get(p.pos)
    return t
}

advance := func(mut p: Parser) returns ref Token {
    ref t : Token = p.tokens.get(p.pos)
    if t.type.is(TokenType.Eof).not() {
        p.pos = p.pos.add(1)
    }
    return t
}

check := func(p: Parser, type: TokenType) returns shallow Bool {
    return peek(p).type.eq(type)
}

expect_token := func(mut p: Parser, type: TokenType) returns ref Token {
    ref t : Token = peek(p)
    if t.type.eq(type).not() {
        panic(__LOC__, p.path, ":", t.line.to_str(), ":", t.col.to_str(),
            ": expected '", tok_name(type), "', found '", t.text, "'")
    }
    return advance(p)
}

// Like expect but returns the text of the consumed token
expect_text := func(mut p: Parser, type: TokenType) returns Str {
    ref t : Token = peek(p)
    if t.type.eq(type).not() {
        panic(__LOC__, p.path, ":", t.line.to_str(), ":", t.col.to_str(),
            ": expected '", tok_name(type), "', found '", t.text, "'")
    }
    text := t.text.clone()
    advance(p)
    return text
}

// Save line/col before advancing
peek_line := func(p: Parser) returns shallow U32 { return peek(p).line }
peek_col := func(p: Parser) returns shallow U32 { return peek(p).col }

// Resolve an explicit type name from the source into a Type. Fixed-name
// primitives are returned directly. Empty name -> Unknown. Anything else
// (Str, user-defined structs/enums) becomes Custom(name) so the typer can
// later refine it into Struct(name) or Enum(name) via scope lookup while
// keeping the name already provided by the user.
til_type_from_explicit_type := func(name: Str) returns Type {
    if name.eq("I64")     { return Type.I64 }
    if name.eq("U8")      { return Type.Struct("U8") }
    if name.eq("I8")      { return Type.Struct("I8") }
    if name.eq("I16")     { return Type.Primitive(Primitive.I16) }
    if name.eq("U16")     { return Type.Primitive(Primitive.U16) }
    if name.eq("I32")     { return Type.Struct("I32") }
    if name.eq("U32")     { return Type.U32 }
    if name.eq("U64")     { return Type.U64 }
    if name.eq("F32")     { return Type.F32 }
    if name.eq("Bool")    { return Type.Bool }
    if name.eq("Dynamic") { return Type.Dynamic }
    if name.len().eq(0)   { return Type.Unknown }
    return Type.Custom(name.clone())
}

// --- Parsing functions ---

// Issue #56/#57: monotonic counter for generated anon type names. Module
// global (not a Parser field) so names stay unique across files in one
// compilation -- two files each lifting an anon literal get distinct names
// (AnonStruct0, AnonStruct1) rather than colliding on AnonStruct0.
mut anon_struct_counter : I64 = 0

// Canonical structural signature for a StructDef/EnumDef literal. Two
// literals produce the same key iff they would generate the same type, so
// the key drives anon_cache dedup. Folds in field/variant names, types,
// mut/own modifiers, default-value trees and namespace-method bodies (the
// latter two via Expr.to_str), so any observable difference yields a
// distinct type.
priv anon_decl_key := func(d: Declaration) returns Str {
    mut own_tag := "S"
    if d.own_type.is(OwnType.Own) { own_tag = "O" }
    if d.own_type.is(OwnType.Ref) { own_tag = "R" }
    mut mut_tag := "c"
    if d.is_mut { mut_tag = "m" }
    return format(d.name, ":", d.explicit_type, ":", mut_tag, own_tag, ":",
        d.default_value.to_str(), ";")
}

priv anon_def_key := func(def: Expr) returns Str {
    switch def.node_type {
    case NodeType.StructDef(sdd):
        mut k := "struct{"
        for f : Declaration in sdd.fields {
            k = k.concat(anon_decl_key(f))
        }
        k = k.concat("|ns:")
        for n : Declaration in sdd.ns_decls {
            k = k.concat(anon_decl_key(n))
        }
        return k.concat("}")
    case NodeType.EnumDef(edd):
        mut k := "enum{"
        for j in 0..edd.variants.len() {
            ref vn : Str = edd.variants.get(j)
            k = k.concat(vn)
            idx := j.to_i64()
            if edd.payload_types.has(idx) {
                ref pt : Str = edd.payload_types.get(idx)
                k = k.concat(":").concat(pt)
            }
            k = k.concat(";")
        }
        k = k.concat("|ns:")
        for n : Declaration in edd.ns_decls {
            k = k.concat(anon_decl_key(n))
        }
        return k.concat("}")
    case:
        return ""
    }
}

// anon_lift: register an anonymous struct/enum literal as a top-level decl
// and return its generated type name. Structurally-identical literals in
// the same file (anon_cache hit) reuse the name without emitting a second
// decl. Consumes `def`.
priv anon_lift := func(mut p: Parser, own def: Expr, shallow line: U32, shallow col: U32) returns Str {
    mut kind := "AnonStruct"
    if def.node_type.is(NodeType.EnumDef) { kind = "AnonEnum" }
    key := anon_def_key(def)
    if p.anon_cache.has(key) {
        ref hit : Str = p.anon_cache.get(key)
        return hit.clone()
    }
    name := kind.concat(anon_struct_counter.to_str())
    anon_struct_counter = anon_struct_counter.add(1)
    p.anon_cache.set(own key.clone(), own name.clone())
    mut decl := Expr.new(NodeType.Decl(Declaration(name = name.clone())), line, col)
    decl.add_child(own def)
    p.anon_decls.push(own decl)
    return name.clone()
}

// parse_type_ref: parse a type annotation. Normally a bare identifier, but
// an inline `struct { ... }` / `enum { ... }` is lifted to a generated
// AnonStructN/AnonEnumN type (issue #56/#57) and its name returned.
priv parse_type_ref := proc(mut p: Parser) returns Str {
    tr_line := peek_line(p)
    tr_col := peek_col(p)
    if check(p, TokenType.KwStruct) {
        return anon_lift(p, own parse_struct_def(p, ""), tr_line, tr_col)
    }
    if check(p, TokenType.KwEnum) {
        return anon_lift(p, own parse_enum_def(p), tr_line, tr_col)
    }
    return expect_text(p, TokenType.Ident)
}

// parse_fn_signature: parse Fn(T1, T2, ...) returns T after "Fn" has been consumed.
// Generates a synthetic type name (e.g. "_Fn_I64_I64_ret_Bool"), creates a
// bodyless FuncDef Decl, stores it in p.fn_sig_decls, and returns the name.
// Returns "" if not followed by '(' (bare "Fn" type).
priv parse_fn_signature := func(mut p: Parser, shallow line: U32, shallow col: U32) returns Str {
    if check(p, TokenType.LParen).not() {
        return ""
    }
    advance(p) // consume '('

    // Parse parameter types: [mut] Type, [mut] Type, ...
    mut ptypes := Vec.new(Str)
    mut pmuts := Vec.new(Bool)
    while check(p, TokenType.RParen).not().and(check(p, TokenType.Eof).not()) {
        mut is_mut := false
        if check(p, TokenType.KwMut) { advance(p); is_mut = true }
        ptype := expect_text(p, TokenType.Ident)
        ptypes.push(own ptype)
        pmuts.push(own is_mut)
        if check(p, TokenType.Comma) { advance(p) }
    }
    expect_token(p, TokenType.RParen)

    // Parse optional 'returns Type'
    mut return_type := ""
    if check(p, TokenType.KwReturns) {
        advance(p)
        return_type = expect_text(p, TokenType.Ident)
    }

    // Build synthetic name: _Fn_[mut_]T1_[mut_]T2_ret_R
    mut name := "_Fn"
    for i in 0..ptypes.len() {
        name = name.concat("_")
        ref m : Bool = pmuts.get(i)
        if m { name = name.concat("mut_") }
        ref t : Str = ptypes.get(i)
        name = name.concat(t)
    }
    if return_type.len().gt(0) {
        name = name.concat("_ret_")
        name = name.concat(return_type)
    }

    // Build synthetic func_def (bodyless — same as named FuncSig types)
    mut fd := FunctionDef()
    if return_type.len().gt(0) { fd.func_type = FuncType.Func }
    else { fd.func_type = FuncType.Proc }
    fd.return_type = return_type
    fd.return_own_type = OwnType.Own
    fd.variadic_index = -1
    fd.kwargs_index = -1
    for i in 0..ptypes.len() {
        ref t : Str = ptypes.get(i)
        ref m : Bool = pmuts.get(i)
        fd.params.push(own Declaration(name = "", explicit_type = t.clone(), til_type = til_type_from_explicit_type(t), is_mut = m, own_type = OwnType.Ref))
    }
    mut sig := Expr.new(NodeType.FuncDef(fd), line, col)

    // Wrap in Decl and store for later emission. The synthetic
    // ~_Fn_*~ name is only ever referenced from the parameter type
    // annotations the parser just wrote, all inside the same file --
    // mark priv so the unused-priv check would flag any leak.
    mut decl := Expr.new(NodeType.Decl(Declaration(name = name.clone(), is_priv = true)), line, col)
    decl.add_child(own sig)
    p.fn_sig_decls.push(own decl)

    return name
}

// parse_block: expects '{' already consumed, reads statements until '}'
priv parse_block := proc(mut p: Parser) returns Expr {
    // Save outer pending_doc so the surrounding Decl's leading /// survives
    // the block parse. Inner /// inside the block accumulate into pending_doc
    // and are attached to the next inner Decl by parse_statement; any
    // unconsumed inner doc text at '}' is discarded.
    saved_doc := p.pending_doc.clone()
    p.pending_doc = ""
    mut body := Expr.new(NodeType.Body, peek_line(p), peek_col(p))
    while true {
        drain_doc_comments(p)
        if check(p, TokenType.RBrace).or(check(p, TokenType.Eof)) { break }
        body.add_child(own parse_statement(p))
    }
    p.pending_doc = saved_doc.clone()
    expect_token(p, TokenType.RBrace)
    return body
}

// parse_func_def: current token is func/proc/etc keyword
parse_func_def := proc(mut p: Parser) returns Expr {
    kw_line := peek_line(p)
    kw_col := peek_col(p)
    ref kw : Token = advance(p)
    mut ft := FuncType.Func
    switch kw.type {
    case TokenType.KwFunc: ft = FuncType.Func
    case TokenType.KwProc: ft = FuncType.Proc
    case TokenType.KwTest: ft = FuncType.Test
    case TokenType.KwMacro: ft = FuncType.Macro
    case TokenType.KwExtFunc: ft = FuncType.ExtFunc
    case TokenType.KwExtProc: ft = FuncType.ExtProc
    case: panic(__LOC__, "expected function keyword")
    }

    expect_token(p, TokenType.LParen)

    mut fd := FunctionDef()
    fd.func_type = ft

    while check(p, TokenType.RParen).not().and(check(p, TokenType.Eof).not()) {
        mut own_type := OwnType.Ref
        if check(p, TokenType.KwShallow) { advance(p); own_type = OwnType.Shallow }
        if check(p, TokenType.KwOwn) { advance(p); own_type = OwnType.Own }
        mut is_mut := false
        if check(p, TokenType.KwMut) { advance(p); is_mut = true }
        if check(p, TokenType.KwRef) {
            panic(__LOC__, p.path, ":", peek_line(p).to_str(), ":", peek_col(p).to_str(),
                ": no need for 'ref' on parameter; parameters are borrowed by default")
        }

        pname := expect_text(p, TokenType.Ident)

        // Build param_decl directly; struct field assigns delete the
        // previous value cleanly, unlike `mut nm := \"\"` reassignment.
        mut param_decl := Declaration(is_mut = is_mut, own_type = own_type.clone())
        mut is_variadic := false
        mut is_kwargs := false
        if check(p, TokenType.Colon).not() {
            // Bare type (FuncSig style): name stays "", type from pname
            param_decl.explicit_type = pname.clone()
            param_decl.til_type = til_type_from_explicit_type(pname)
        } else {
            expect_token(p, TokenType.Colon)
            if check(p, TokenType.DotDotDot) {
                advance(p) // consume '...'
                if own_type.is(OwnType.Ref).not().or(is_mut) {
                    panic(__LOC__, p.path, ":", peek_line(p).to_str(), ":", peek_col(p).to_str(),
                        ": kwargs parameter cannot be own/mut/shallow")
                }
                if fd.kwargs_index.neq(-1) {
                    panic(__LOC__, "only one kwargs parameter is allowed")
                }
                fd.kwargs_index = fd.params.len().to_i32()
                is_kwargs = true
                // For regular til funcs the codegen auto-inserts a
                // DynMap.delete at the callee's scope exit, so the caller
                // can transfer ownership cleanly. ext_func/ext_proc bodies
                // are user-written C with no auto-cleanup, so the synthesized
                // DynMap would leak if ownership were transferred. Keep the
                // caller as owner for ext bindings -- its normal ASAP delete
                // at last_use will free the temp.
                if ft.is(FuncType.ExtFunc).or(ft.is(FuncType.ExtProc)) {
                    param_decl.own_type = OwnType.Ref
                } else {
                    param_decl.own_type = OwnType.Own
                }
                param_decl.name = pname.clone()
                param_decl.explicit_type = "DynMap"
                param_decl.til_type = til_type_from_explicit_type("DynMap")
            } else if check(p, TokenType.DotDot) {
                advance(p)
                if own_type.is(OwnType.Own) { panic(__LOC__, "variadic param cannot be 'own'") }
                if is_mut { panic(__LOC__, "variadic param cannot be 'mut'") }
                if own_type.is(OwnType.Shallow) { panic(__LOC__, "variadic param cannot be 'shallow'") }
                if fd.variadic_index.neq(-1) { panic(__LOC__, "only one variadic param allowed") }
                fd.variadic_index = fd.params.len().to_i32()
                is_variadic = true
                // Same as kwargs above: regular til funcs get auto-cleanup
                // via Array.delete at scope exit; ext_func/ext_proc bodies
                // (user-written C) don't, so transferring ownership leaks
                // the synthesized Array. Keep the caller as owner for ext
                // bindings (Issue #109 -- ffi_run was 228B/9 allocs from
                // exactly this).
                if ft.is(FuncType.ExtFunc).or(ft.is(FuncType.ExtProc)) {
                    param_decl.own_type = OwnType.Ref
                } else {
                    param_decl.own_type = OwnType.Own
                }
                param_decl.explicit_type = parse_type_ref(p)
                param_decl.til_type = til_type_from_explicit_type(param_decl.explicit_type)
                param_decl.name = pname.clone()
            } else {
                param_decl.explicit_type = parse_type_ref(p)
                param_decl.til_type = til_type_from_explicit_type(param_decl.explicit_type)
                param_decl.name = pname.clone()
            }
        }

        // If type is Fn, try to parse Fn(T1, T2) returns T signature
        if param_decl.explicit_type.eq("Fn") {
            syn_name := parse_fn_signature(p, peek_line(p), peek_col(p))
            if syn_name.len().gt(0) {
                param_decl.explicit_type = syn_name
                param_decl.til_type = til_type_from_explicit_type(param_decl.explicit_type)
            }
        }

        // Optional default value
        mut has_default := false
        if check(p, TokenType.Eq) {
            advance(p)
            param_decl.default_value = parse_expression(p)
            has_default = true
        }
        if fd.variadic_index.neq(-1).and(is_variadic.not()).and(is_kwargs.not()).and(has_default.not()) {
            panic(__LOC__, "positional param not allowed after variadic")
        }
        // Variadic and kwargs may coexist (Python-style *args + **kwargs);
        // when both are present, kwargs must come last so positional vs
        // named-arg slots don't get tangled at the call site.
        if fd.kwargs_index.neq(-1).and(is_kwargs.not()) {
            panic(__LOC__, "no parameter allowed after kwargs")
        }

        fd.params.push(own param_decl)
        if check(p, TokenType.Comma) { advance(p) }
    }
    expect_token(p, TokenType.RParen)

    // Parse optional 'returns [ref|shallow] Type'
    if check(p, TokenType.KwReturns) {
        advance(p)
        if check(p, TokenType.KwRef) {
            advance(p)
            fd.return_own_type = OwnType.Ref
        } else if check(p, TokenType.KwOwn) {
            panic(__LOC__, p.path, ":", peek_line(p).to_str(), ":", peek_col(p).to_str(),
                ": no need for 'own' in return type; returns are owned by default")
        } else if check(p, TokenType.KwShallow) {
            advance(p)
            fd.return_own_type = OwnType.Shallow
        }
        fd.return_type = parse_type_ref(p)
    }

    // Issue #198: optional 'throws T1, T2, ...' clause after returns.
    // Stored as a list of type-name strings on FunctionDef. Validation
    // and lowering live in the typer; the parser only collects names.
    if check(p, TokenType.KwThrows) {
        advance(p)
        tname := expect_text(p, TokenType.Ident)
        fd.throw_types.push(own tname.clone())
        while check(p, TokenType.Comma) {
            advance(p)
            next_tname := expect_text(p, TokenType.Ident)
            fd.throw_types.push(own next_tname.clone())
        }
    }

    mut def := Expr.new(NodeType.FuncDef(fd), kw_line, kw_col)

    if check(p, TokenType.LBrace) {
        expect_token(p, TokenType.LBrace)
        def.add_child(own parse_block(p))
    } else if check(p, TokenType.Eq) {
        // FuncSig form continuation: bodyless `func(Types) returns T`
        // followed by `= (names) { body }`. Wires the names into the
        // FuncSig-typed params and parses the body, producing a fully
        // formed FuncDef Expr usable anywhere a FuncDef literal is.
        if ft.is(FuncType.Func).not().and(ft.is(FuncType.Proc).not()) {
            panic(__LOC__, p.path, ":", kw_line.to_str(), ":", kw_col.to_str(),
                ": ", func_type_name(ft), " cannot use FuncSig form")
        }
        advance(p) // consume '='
        expect_token(p, TokenType.LParen)
        switch def.node_type {
        case NodeType.FuncDef(sfd):
            mut pi : USize = 0
            while check(p, TokenType.RParen).not().and(check(p, TokenType.Eof).not()) {
                pn := expect_text(p, TokenType.Ident)
                if pi.gte(sfd.params.len()) {
                    panic(__LOC__, p.path, ":", peek_line(p).to_str(), ":", peek_col(p).to_str(),
                        ": too many param names for FuncSig form (got more than ", sfd.params.len().to_str(), ")")
                }
                ref pp : Declaration = sfd.params.get(pi)
                pp.name = pn.clone()
                pi = pi.add(1)
                if check(p, TokenType.Comma) { advance(p) }
            }
            expect_token(p, TokenType.RParen)
            if pi.lt(sfd.params.len()) {
                panic(__LOC__, p.path, ":", peek_line(p).to_str(), ":", peek_col(p).to_str(),
                    ": FuncSig form expects ", sfd.params.len().to_str(), " param names, got ", pi.to_str())
            }
        case:
            UNREACHABLE(__LOC__)
        }
        expect_token(p, TokenType.LBrace)
        def.add_child(own parse_block(p))
    } else {
        // Bodyless = FuncSig type definition (only for func/proc)
        if ft.is(FuncType.Func).not().and(ft.is(FuncType.Proc).not()) {
            panic(__LOC__, p.path, ":", kw_line.to_str(), ":", kw_col.to_str(),
                ": ", func_type_name(ft), " requires a body")
        }
    }

    return def
}

// parse_struct_def: current token is 'struct' (or '{' for ext_struct)
// c_tag: "" = normal struct (advance past 'struct' keyword)
//        "@anon" = ext_struct anonymous (no struct tag)
//        other = ext_struct with custom tag
parse_struct_def := proc(mut p: Parser, c_tag: Str) returns Expr {
    kw_line := peek_line(p)
    kw_col := peek_col(p)
    is_ext := c_tag.len().gt(0)
    if is_ext.not() { advance(p) }

    mut def := Expr.new(NodeType.StructDef(StructDef()), kw_line, kw_col)
    if is_ext {
        switch def.node_type {
        case NodeType.StructDef(sdd):
            sdd.c_tag = c_tag.clone()
        case:
            UNREACHABLE(__LOC__)
        }
    }
    expect_token(p, TokenType.LBrace)

    // Save outer pending_doc so a /// run inside the struct body doesn't
    // leak past `}` to whatever statement follows. Inner /// accumulate
    // into pending_doc and attach to the next field or namespace decl.
    saved_doc := p.pending_doc.clone()
    p.pending_doc = ""

    mut in_namespace := false
    while check(p, TokenType.RBrace).not().and(check(p, TokenType.Eof).not()) {
        if check(p, TokenType.DocComment) {
            drain_doc_comments(p)
            continue
        }
        if check(p, TokenType.KwNamespace) {
            advance(p)
            expect_token(p, TokenType.Colon)
            in_namespace = true
            // Discard any pending /// before the namespace marker.
            p.pending_doc = ""
            continue
        }
        // #179 steps 4-5: priv on fields and namespace methods.
        // Allowed inside any struct body (works for both NodeType.StructDef
        // and NodeType.EnumDef -- enums share the namespace parse path).
        mut member_priv := false
        if check(p, TokenType.KwPriv) {
            advance(p)
            member_priv = true
        }
        if in_namespace {
            // Parse namespace declaration directly into sdd.ns_decls
            mut ns_name := ""
            mut ns_explicit_type := ""
            mut ns_is_mut := false
            if check(p, TokenType.KwMut) { advance(p); ns_is_mut = true }
            ns_name = expect_text(p, TokenType.Ident)
            if check(p, TokenType.ColonEq) {
                advance(p)
            } else if check(p, TokenType.Colon) {
                advance(p)
                ns_explicit_type = parse_type_ref(p)
                expect_token(p, TokenType.Eq)
            }
            ns_doc := p.pending_doc.clone()
            p.pending_doc = ""
            mut ns_value := parse_expression(p)
            mut ns_dd := Declaration(name = ns_name,
                is_mut = ns_is_mut, explicit_type = ns_explicit_type,
                til_type = til_type_from_explicit_type(ns_explicit_type),
                doc = ns_doc,
                is_priv = member_priv,
                default_value = ns_value)
            switch def.node_type {
            case NodeType.StructDef(sdd):
                sdd.ns_decls.push(own ns_dd)
            case:
                UNREACHABLE(__LOC__)
            }
        } else {
            mut f_own_type := OwnType.Shallow
            // #211: struct instance fields are mutable by default; `const`
            // opts out. An explicit `mut` is redundant -- record it so the
            // typer can reject it with a helpful message.
            mut f_is_mut := true
            mut f_redundant_mut := false
            if check(p, TokenType.KwOwn) { advance(p); f_own_type = OwnType.Own }
            if check(p, TokenType.KwRef) { advance(p); f_own_type = OwnType.Ref }
            if check(p, TokenType.KwConst) { advance(p); f_is_mut = false }
            else if check(p, TokenType.KwMut) { advance(p); f_redundant_mut = true }
            f_name := expect_text(p, TokenType.Ident)
            mut f_explicit_type := ""
            if check(p, TokenType.Colon) {
                advance(p)
                f_explicit_type = parse_type_ref(p)
                if check(p, TokenType.Eq) { advance(p) }
                else { expect_token(p, TokenType.ColonEq) }
            } else {
                expect_token(p, TokenType.ColonEq)
            }
            f_doc := p.pending_doc.clone()
            p.pending_doc = ""
            mut f_value := parse_expression(p)
            mut f_dd := Declaration(name = f_name, is_mut = f_is_mut,
                redundant_mut = f_redundant_mut,
                own_type = f_own_type, explicit_type = f_explicit_type,
                til_type = til_type_from_explicit_type(f_explicit_type),
                doc = f_doc,
                is_priv = member_priv,
                default_value = f_value)
            switch def.node_type {
            case NodeType.StructDef(sdd):
                sdd.fields.push(own f_dd)
            case:
                UNREACHABLE(__LOC__)
            }
        }
    }
    expect_token(p, TokenType.RBrace)
    p.pending_doc = saved_doc.clone()
    return def
}

// parse_enum_def: current token is 'enum'
parse_enum_def := proc(mut p: Parser) returns Expr {
    kw_line := peek_line(p)
    kw_col := peek_col(p)
    advance(p)

    mut def := Expr.new(NodeType.EnumDef(EnumDef()), kw_line, kw_col)
    expect_token(p, TokenType.LBrace)

    saved_doc := p.pending_doc.clone()
    p.pending_doc = ""

    mut in_namespace := false
    mut variant_idx : I64 = 0
    while check(p, TokenType.RBrace).not().and(check(p, TokenType.Eof).not()) {
        if check(p, TokenType.DocComment) {
            drain_doc_comments(p)
            continue
        }
        if check(p, TokenType.KwNamespace) {
            advance(p)
            expect_token(p, TokenType.Colon)
            in_namespace = true
            p.pending_doc = ""
            continue
        }
        if in_namespace {
            // #179 step 5: priv on enum namespace members. The struct
            // body in parse_struct_def already supports this; the enum
            // body has its own loop and was missing it.
            mut enum_ns_priv := false
            if check(p, TokenType.KwPriv) {
                advance(p)
                enum_ns_priv = true
            }
            mut ns_name := ""
            mut ns_explicit_type := ""
            mut ns_is_mut := false
            if check(p, TokenType.KwMut) { advance(p); ns_is_mut = true }
            ns_name = expect_text(p, TokenType.Ident)
            if check(p, TokenType.ColonEq) {
                advance(p)
            } else if check(p, TokenType.Colon) {
                advance(p)
                ns_explicit_type = parse_type_ref(p)
                expect_token(p, TokenType.Eq)
            }
            ns_doc := p.pending_doc.clone()
            p.pending_doc = ""
            mut ns_value := parse_expression(p)
            mut ns_dd := Declaration(name = ns_name,
                is_mut = ns_is_mut, explicit_type = ns_explicit_type,
                til_type = til_type_from_explicit_type(ns_explicit_type),
                doc = ns_doc,
                is_priv = enum_ns_priv,
                default_value = ns_value)
            switch def.node_type {
            case NodeType.EnumDef(edd):
                edd.ns_decls.push(own ns_dd)
            case:
                UNREACHABLE(__LOC__)
            }
        } else {
            // Variant: bare identifier or Variant: Type, comma-separated.
            // Variant docs aren't yet stored (variants are a Vec<Str>);
            // discard any leading /// so it doesn't bleed into the next
            // ns_decl.
            p.pending_doc = ""
            vname := expect_text(p, TokenType.Ident)
            mut vtype := ""
            if check(p, TokenType.Colon) {
                advance(p)
                vtype = expect_text(p, TokenType.Ident)
            }
            switch def.node_type {
            case NodeType.EnumDef(edd):
                edd.variants.push(own vname.clone())
                if vtype.len().gt(0) {
                    edd.payload_types.set(own variant_idx.clone(), own vtype.clone())
                }
            case:
                UNREACHABLE(__LOC__)
            }
            variant_idx = variant_idx.add(1)
            if check(p, TokenType.Comma) { advance(p) }
        }
    }
    expect_token(p, TokenType.RBrace)
    p.pending_doc = saved_doc.clone()
    return def
}

// parse_call: callee Expr already built, current token is '('. The callee
// is usually an Ident, but may be a StructDef literal for anonymous-struct
// instantiation (`struct { ... }(args)`).
parse_call := proc(mut p: Parser, own callee: Expr, shallow call_line: U32, shallow call_col: U32) returns Expr {
    advance(p) // consume '('

    mut call := Expr.new(NodeType.FCall(FCallData()), call_line, call_col)
    call.add_child(own callee)

    // parse arguments
    while check(p, TokenType.RParen).not().and(check(p, TokenType.Eof).not()) {
        // Named arg: IDENT '=' expr
        if check(p, TokenType.Ident) {
            if p.pos.add(1).lt(p.tokens.len()) {
                ref next_tok : Token = p.tokens.get(p.pos.add(1))
                if next_tok.type.is(TokenType.Eq) {
                    na_line := peek_line(p)
                    na_col := peek_col(p)
                    aname := expect_text(p, TokenType.Ident)
                    advance(p) // consume '='
                    mut na := Expr.new(NodeType.NamedArg(aname), na_line, na_col)
                    na.add_child(own parse_expression(p))
                    call.add_child(own na)
                    if check(p, TokenType.Comma) { advance(p) }
                    continue
                }
            }
        }
        // Splat arg: ..expr  OR  rest-pattern marker `..` (followed by
        // a comma or the closing paren, no expression). Splat sets the
        // FCall's is_splat flag and continues to parse the expression.
        // Rest-pattern emits a RestPattern child and skips to the next
        // arg.
        mut is_splat := false
        if check(p, TokenType.DotDot) {
            advance(p)
            if check(p, TokenType.Comma).or(check(p, TokenType.RParen)) {
                rp_line := peek_line(p)
                rp_col := peek_col(p)
                call.add_child(own Expr.new(NodeType.RestPattern, rp_line, rp_col))
                if check(p, TokenType.Comma) { advance(p) }
                continue
            }
            is_splat = true
        }
        // Own arg: own expr
        mut is_own_arg := false
        if check(p, TokenType.KwOwn) {
            advance(p)
            is_own_arg = true
        }
        mut arg := parse_expression(p)
        // Issue #56/#57: a bare anonymous `struct { ... }` / `enum { ... }`
        // passed as a call argument resolves through anon_lift to the
        // generated AnonStructN/AnonEnumN type. Two flavours of arg flow:
        //   * `f(enum { ... })`         -> Ident(AnonEnumN) -- a type ref,
        //     for func/macro params typed `Type` (introspection style).
        //   * `f(own struct { ... })`   -> struct_def_of("AnonStructN")
        //     -- a runtime StructDef value (issue #56). The `own` prefix
        //     is the signal that the caller wants the definition AS A
        //     VALUE (e.g. `defs.push(own struct { ... })`). Symmetric for
        //     enums via enum_def_of.
        if arg.node_type.is(NodeType.StructDef).or(arg.node_type.is(NodeType.EnumDef)) {
            arg_line := arg.line
            arg_col := arg.col
            mut helper := "struct_def_of"
            if arg.node_type.is(NodeType.EnumDef) { helper = "enum_def_of" }
            lifted_name := anon_lift(p, own arg, arg_line, arg_col)
            if is_own_arg { set_own_arg(call, call.children.len()) }
            if is_splat {
                switch call.node_type {
                case NodeType.FCall(fcd):
                    fcd.is_splat = true
                case:
                    UNREACHABLE(__LOC__)
                }
            }
            if is_own_arg {
                mut sd_callee := Expr.new(ident_node(helper), arg_line, arg_col)
                mut sd_strlit := Expr.new(NodeType.Literal(Literal.Str(lifted_name.clone())), arg_line, arg_col)
                mut sd_call := Expr.new(NodeType.FCall(FCallData()), arg_line, arg_col)
                sd_call.add_child(own sd_callee)
                sd_call.add_child(own sd_strlit)
                call.add_child(own sd_call)
            } else {
                call.add_child(own Expr.new(ident_node(lifted_name), arg_line, arg_col))
            }
        } else {
            if is_own_arg { set_own_arg(call, call.children.len()) }
            if is_splat {
                switch call.node_type {
                case NodeType.FCall(fcd):
                    fcd.is_splat = true
                case:
                    UNREACHABLE(__LOC__)
                }
            }
            call.add_child(own arg)
        }
        if check(p, TokenType.Comma) { advance(p) }
    }
    expect_token(p, TokenType.RParen)
    // Issue #198: postfix ~?~ marks a call to a throwing function.
    if check(p, TokenType.Question) {
        advance(p)
        switch call.node_type {
        case NodeType.FCall(fcd):
            fcd.does_throw = true
        case:
            UNREACHABLE(__LOC__)
        }
    }
    // Issue #202: postfix ~!~ -- panic if the call throws. The typer
    // desugars to ~?~ + auto-catch+panic per declared throw type.
    if check(p, TokenType.Bang) {
        advance(p)
        switch call.node_type {
        case NodeType.FCall(fcd_b):
            fcd_b.is_bang = true
        case:
            UNREACHABLE(__LOC__)
        }
    }
    return call
}

// make_binop_call: helper to desugar a OP b -> a.method(b)
make_binop_call := func(lhs: Expr, method: Str, shallow op_line: U32, shallow op_col: U32, rhs: Expr) returns Expr {
    mut callee := Expr.new(field_access_node(method), op_line, op_col)
    Expr.add_child(callee, own lhs.clone())
    mut call := Expr.new(NodeType.FCall(FCallData()), op_line, op_col)
    Expr.add_child(call, own callee)
    Expr.add_child(call, own rhs.clone())
    return call
}

// parse_primary: literals, identifiers, calls, field access, grouping parens
parse_primary := proc(mut p: Parser) returns Expr {
    t_line := peek_line(p)
    t_col := peek_col(p)
    ref t : Token = peek(p)
    mut e := Expr.new(NodeType.Body, 0, 0) // placeholder
    mut e_set := false

    if t.type.is(TokenType.StringTok) {
        advance(p)
        e = Expr.new(NodeType.Literal(Literal.Str(t.text.clone())), t_line, t_col)
        e_set = true
    }
    if e_set.not().and(t.type.is(TokenType.Number)) {
        advance(p)
        e = Expr.new(literal_num_node(t.text), t_line, t_col)
        e_set = true
    }
    // Unary minus: -N (literal) parses as a single negative numeric
    // literal so it narrows like any other literal (args, decls, assigns,
    // returns); -expr desugars to expr.neg().
    if e_set.not().and(t.type.is(TokenType.Minus)) {
        if p.pos.add(1).lt(p.tokens.len()) {
            ref next_tok : Token = p.tokens.get(p.pos.add(1))
            if next_tok.type.is(TokenType.Number) {
                advance(p) // consume '-'
                ref num_tok : Token = advance(p) // consume number
                e = Expr.new(literal_num_node("-".concat(num_tok.text)), t_line, t_col)
                e_set = true
            } else {
                advance(p) // consume '-'
                mut operand := parse_primary(p)
                mut neg_access := Expr.new(field_access_node("neg"), t_line, t_col)
                neg_access.add_child(own operand)
                mut neg_call := Expr.new(NodeType.FCall(FCallData()), t_line, t_col)
                neg_call.add_child(own neg_access)
                e = neg_call
                e_set = true
            }
        }
    }
    if e_set.not().and(t.type.is(TokenType.Bang)) {
        advance(p) // consume '!'
        mut operand := parse_primary(p)
        mut not_access := Expr.new(field_access_node("not"), t_line, t_col)
        not_access.add_child(own operand)
        mut not_call := Expr.new(NodeType.FCall(FCallData()), t_line, t_col)
        not_call.add_child(own not_access)
        e = not_call
        e_set = true
    }
    if e_set.not().and(t.type.is(TokenType.Char)) {
        advance(p)
        // Parse char literal to byte value
        ch := t.text
        mut byte_val := 0
        if ch.len().gt(0).and(ch.get(0).eq('\\')) {
            if ch.len().gt(1) {
                ref c2 : I8 = ch.get(1)
                if c2.eq('n') { byte_val = 10 }
                else if c2.eq('t') { byte_val = 9 }
                else if c2.eq('r') { byte_val = 13 }
                else if c2.eq('\\') { byte_val = 92 }
                else if c2.eq('\'') { byte_val = 39 }
                else if c2.eq('0') { byte_val = 0 }
                else { byte_val = c2.to_i64() }
            }
        } else {
            if ch.len().gt(0) { byte_val = ch.get(0).to_i64() }
        }
        e = Expr.new(literal_num_node(byte_val.to_str()), t_line, t_col)
        set_expr_til_type(e, Type.Struct("U8"))
        e_set = true
    }
    if e_set.not().and(t.type.is(TokenType.KwTrue).or(t.type.is(TokenType.KwFalse))) {
        advance(p)
        e = Expr.new(NodeType.Literal(Literal.Bool(t.type.is(TokenType.KwTrue))), t_line, t_col)
        e_set = true
    }
    if e_set.not().and(t.type.is(TokenType.KwNull)) {
        advance(p)
        e = Expr.new(NodeType.Literal(Literal.Null), t_line, t_col)
        e_set = true
    }
    if e_set.not().and(t.type.is(TokenType.Ident)) {
        advance(p)
        name := t.text.clone()
        // Compile-time directives
        if name.eq("__LOC__") {
            e = Expr.new(NodeType.Literal(Literal.Str(format(p.path, ":", t_line.to_str(), ":", t_col.to_str()))), t_line, t_col)
            e_set = true
        } else if name.eq("__FILE__") {
            e = Expr.new(NodeType.Literal(Literal.Str(p.path.clone())), t_line, t_col)
            e_set = true
        } else if name.eq("__LINE__") {
            e = Expr.new(literal_num_node(t_line.to_str()), t_line, t_col)
            e_set = true
        } else if name.eq("__COL__") {
            e = Expr.new(literal_num_node(t_col.to_str()), t_line, t_col)
            e_set = true
        } else if check(p, TokenType.LParen) {
            e = parse_call(p, own Expr.new(ident_node(name), t_line, t_col), t_line, t_col)
            e_set = true
        } else {
            e = Expr.new(ident_node(name), t_line, t_col)
            e_set = true
        }
    }
    if e_set.not().and(t.type.is(TokenType.KwFunc).or(t.type.is(TokenType.KwProc))
        .or(t.type.is(TokenType.KwTest)).or(t.type.is(TokenType.KwMacro))
        .or(t.type.is(TokenType.KwExtFunc)).or(t.type.is(TokenType.KwExtProc))) {
            return parse_func_def(p)
        }
    if e_set.not().and(t.type.is(TokenType.KwStruct)) {
        mut sdef := parse_struct_def(p, "")
        // Anonymous struct instantiation: `struct { ... }(args)`. Lift the
        // literal to a top-level AnonStructN decl (issue #56) and call the
        // generated constructor. A bare `struct { ... }` (no trailing `(`)
        // stays a StructDef literal as before (named struct decls, etc).
        if check(p, TokenType.LParen) {
            name := anon_lift(p, own sdef, t_line, t_col)
            e = parse_call(p, own Expr.new(ident_node(name), t_line, t_col), t_line, t_col)
            e_set = true
        } else {
            return sdef
        }
    }
    if e_set.not().and(t.type.is(TokenType.KwExtStruct)) {
        advance(p)
        mut tag := "@anon"
        if check(p, TokenType.LParen) {
            advance(p)
            ref tag_tok : Token = expect_token(p, TokenType.StringTok)
            tag = tag_tok.text.clone()
            if tag.len().eq(0) { tag = "@anon" }
            expect_token(p, TokenType.RParen)
        }
        return parse_struct_def(p, tag)
    }
    if e_set.not().and(t.type.is(TokenType.KwEnum)) {
        // Anonymous enum variant: `enum { ... }.Variant` (or
        // `.Variant(payload)`). Lift the literal to a top-level AnonEnumN
        // decl (issue #57) and let the postfix `.field` loop attach the
        // variant access to the generated name. A bare `enum { ... }` (no
        // trailing `.`) stays an EnumDef literal (named enum decls, etc).
        mut edef := parse_enum_def(p)
        if check(p, TokenType.Dot) {
            name := anon_lift(p, own edef, t_line, t_col)
            e = Expr.new(ident_node(name), t_line, t_col)
            e_set = true
        } else {
            return edef
        }
    }
    if e_set.not().and(t.type.is(TokenType.LBrace)) {
        advance(p)
        mut first := parse_expression(p)
        if check(p, TokenType.Colon) {
            // Map literal
            e = Expr.new(NodeType.MapLit, t_line, t_col)
            e.add_child(own first)
            advance(p) // consume ':'
            e.add_child(own parse_expression(p))
            if check(p, TokenType.Comma) { advance(p) }
            while check(p, TokenType.RBrace).not().and(check(p, TokenType.Eof).not()) {
                e.add_child(own parse_expression(p))
                expect_token(p, TokenType.Colon)
                e.add_child(own parse_expression(p))
                if check(p, TokenType.Comma) { advance(p) }
            }
        } else {
            // Set literal
            e = Expr.new(NodeType.SetLit, t_line, t_col)
            e.add_child(own first)
            if check(p, TokenType.Comma) { advance(p) }
            while check(p, TokenType.RBrace).not().and(check(p, TokenType.Eof).not()) {
                e.add_child(own parse_expression(p))
                if check(p, TokenType.Comma) { advance(p) }
            }
        }
        expect_token(p, TokenType.RBrace)
        e_set = true
    }
    // Grouping parentheses: (expr)
    if e_set.not().and(t.type.is(TokenType.LParen)) {
        advance(p) // consume '('
        e = parse_expression(p)
        expect_token(p, TokenType.RParen)
        e_set = true
    }

    if e_set.not() {
        panic(__LOC__, p.path, ":", t_line.to_str(), ":", t_col.to_str(),
            ": unexpected token '", t.text, "'")
    }

    // Field access chain: e.field or e.method(args)
    while check(p, TokenType.Dot) {
        advance(p) // consume '.'
        f_line := peek_line(p)
        f_col := peek_col(p)
        fname := expect_text(p, TokenType.Ident)
        if check(p, TokenType.LParen) {
            // Method call: e.method(args)
            advance(p) // consume '('
            mut callee := Expr.new(field_access_node(fname), f_line, f_col)
            callee.add_child(own e.clone())
            mut mcall := Expr.new(NodeType.FCall(FCallData()), f_line, f_col)
            mcall.add_child(own callee)
            while check(p, TokenType.RParen).not().and(check(p, TokenType.Eof).not()) {
                // Named arg check
                if check(p, TokenType.Ident) {
                    if p.pos.add(1).lt(p.tokens.len()) {
                        ref nt : Token = p.tokens.get(p.pos.add(1))
                        if nt.type.is(TokenType.Eq) {
                            na_line := peek_line(p)
                            na_col := peek_col(p)
                            aname := expect_text(p, TokenType.Ident)
                            advance(p) // consume '='
                            mut na := Expr.new(NodeType.NamedArg(aname), na_line, na_col)
                            na.add_child(own parse_expression(p))
                            mcall.add_child(own na)
                            if check(p, TokenType.Comma) { advance(p) }
                            continue
                        }
                    }
                }
                mut is_own_arg := false
                if check(p, TokenType.KwOwn) { advance(p); is_own_arg = true }
                mut marg := parse_expression(p)
                // Issue #56/#57: same anon-arg lift as parse_call (the
                // postfix method-call path duplicates the arg loop; keep
                // all three sites in sync).
                if marg.node_type.is(NodeType.StructDef).or(marg.node_type.is(NodeType.EnumDef)) {
                    marg_line := marg.line
                    marg_col := marg.col
                    mut mhelper := "struct_def_of"
                    if marg.node_type.is(NodeType.EnumDef) { mhelper = "enum_def_of" }
                    mlifted_name := anon_lift(p, own marg, marg_line, marg_col)
                    if is_own_arg { set_own_arg(mcall, mcall.children.len()) }
                    if is_own_arg {
                        mut msd_callee := Expr.new(ident_node(mhelper), marg_line, marg_col)
                        mut msd_strlit := Expr.new(NodeType.Literal(Literal.Str(mlifted_name.clone())), marg_line, marg_col)
                        mut msd_call := Expr.new(NodeType.FCall(FCallData()), marg_line, marg_col)
                        msd_call.add_child(own msd_callee)
                        msd_call.add_child(own msd_strlit)
                        mcall.add_child(own msd_call)
                    } else {
                        mcall.add_child(own Expr.new(ident_node(mlifted_name), marg_line, marg_col))
                    }
                } else {
                    if is_own_arg { set_own_arg(mcall, mcall.children.len()) }
                    mcall.add_child(own marg)
                }
                if check(p, TokenType.Comma) { advance(p) }
            }
            expect_token(p, TokenType.RParen)
            // Issue #198: postfix ~?~ on method call.
            if check(p, TokenType.Question) {
                advance(p)
                switch mcall.node_type {
                case NodeType.FCall(mcd):
                    mcd.does_throw = true
                case:
                    UNREACHABLE(__LOC__)
                }
            }
            // Issue #202: postfix ~!~ on method call.
            if check(p, TokenType.Bang) {
                advance(p)
                switch mcall.node_type {
                case NodeType.FCall(mcd_b):
                    mcd_b.is_bang = true
                case:
                    UNREACHABLE(__LOC__)
                }
            }
            e = mcall
        } else {
            mut access := Expr.new(field_access_node(fname), f_line, f_col)
            access.add_child(own e.clone())
            e = access
        }
    }
    // Postfix ++ / --: expr++ desugars to expr++, expr-- to expr--
    if check(p, TokenType.PlusPlus) {
        pp_line := peek_line(p)
        pp_col := peek_col(p)
        advance(p)
        mut inc_access := Expr.new(field_access_node("inc"), pp_line, pp_col)
        inc_access.add_child(own e.clone())
        mut inc_call := Expr.new(NodeType.FCall(FCallData()), pp_line, pp_col)
        inc_call.add_child(own inc_access)
        e = inc_call
    }
    if check(p, TokenType.MinusMinus) {
        mm_line := peek_line(p)
        mm_col := peek_col(p)
        advance(p)
        mut dec_access := Expr.new(field_access_node("dec"), mm_line, mm_col)
        dec_access.add_child(own e.clone())
        mut dec_call := Expr.new(NodeType.FCall(FCallData()), mm_line, mm_col)
        dec_call.add_child(own dec_access)
        e = dec_call
    }
    return e
}

// parse_multiplicative: * / % (highest precedence binary operators)
priv parse_multiplicative := proc(mut p: Parser) returns Expr {
    mut e := parse_primary(p)
    while check(p, TokenType.Star).or(check(p, TokenType.Slash)).or(check(p, TokenType.Percent)) {
        op_line := peek_line(p)
        op_col := peek_col(p)
        ref op : Token = advance(p)
        mut method := "mul"
        if op.type.is(TokenType.Slash) { method = "div" }
        if op.type.is(TokenType.Percent) { method = "mod" }
        mut rhs := parse_primary(p)
        e = make_binop_call(e, method, op_line, op_col, rhs)
    }
    return e
}

// parse_additive: + - (medium precedence)
parse_additive := proc(mut p: Parser) returns Expr {
    mut e := parse_multiplicative(p)
    while check(p, TokenType.Plus).or(check(p, TokenType.Minus)) {
        op_line := peek_line(p)
        op_col := peek_col(p)
        ref op : Token = advance(p)
        mut method := "add"
        if op.type.is(TokenType.Minus) { method = "sub" }
        mut rhs := parse_multiplicative(p)
        e = make_binop_call(e, method, op_line, op_col, rhs)
    }
    return e
}

// parse_comparison: == != < <= > >= (lowest precedence binary operators)
parse_comparison := proc(mut p: Parser) returns Expr {
    mut e := parse_additive(p)
    while check(p, TokenType.EqEq).or(check(p, TokenType.Neq))
    .or(check(p, TokenType.Lt)).or(check(p, TokenType.LtEq))
    .or(check(p, TokenType.Gt)).or(check(p, TokenType.GtEq)) {
        op_line := peek_line(p)
        op_col := peek_col(p)
        ref op : Token = advance(p)
        mut method := "eq"
        if op.type.is(TokenType.Neq) { method = "neq" }
        else if op.type.is(TokenType.Lt) { method = "lt" }
        else if op.type.is(TokenType.LtEq) { method = "lte" }
        else if op.type.is(TokenType.Gt) { method = "gt" }
        else if op.type.is(TokenType.GtEq) { method = "gte" }
        mut rhs := parse_additive(p)
        e = make_binop_call(e, method, op_line, op_col, rhs)
    }
    return e
}

// parse_bitand: & (below comparison)
parse_bitand := proc(mut p: Parser) returns Expr {
    mut e := parse_comparison(p)
    while check(p, TokenType.Ampersand) {
        op_line := peek_line(p)
        op_col := peek_col(p)
        advance(p)
        mut rhs := parse_comparison(p)
        e = make_binop_call(e, "and", op_line, op_col, rhs)
    }
    return e
}

// parse_bitxor: ^ (below bitand)
parse_bitxor := proc(mut p: Parser) returns Expr {
    mut e := parse_bitand(p)
    while check(p, TokenType.Caret) {
        op_line := peek_line(p)
        op_col := peek_col(p)
        advance(p)
        mut rhs := parse_bitand(p)
        e = make_binop_call(e, "xor", op_line, op_col, rhs)
    }
    return e
}

// parse_bitor: | (below bitxor)
parse_bitor := proc(mut p: Parser) returns Expr {
    mut e := parse_bitxor(p)
    while check(p, TokenType.Pipe) {
        op_line := peek_line(p)
        op_col := peek_col(p)
        advance(p)
        mut rhs := parse_bitxor(p)
        e = make_binop_call(e, "or", op_line, op_col, rhs)
    }
    return e
}

// parse_expression: top-level expression (bitor + range)
parse_expression := proc(mut p: Parser) returns Expr {
    mut e := parse_bitor(p)
    // Range expression: e..rhs → Range.new(e, rhs)
    if check(p, TokenType.DotDot) {
        dt_line := peek_line(p)
        dt_col := peek_col(p)
        advance(p)
        mut rhs := parse_expression(p)
        mut range_ident := Expr.new(ident_node("Range"), dt_line, dt_col)
        mut new_access := Expr.new(field_access_node("new"), dt_line, dt_col)
        new_access.add_child(own range_ident)
        mut rcall := Expr.new(NodeType.FCall(FCallData()), dt_line, dt_col)
        rcall.add_child(own new_access)
        rcall.add_child(own e.clone())
        rcall.add_child(own rhs)
        e = rcall
    }
    return e
}

// parse_statement_ident: identifier is current token
parse_statement_ident := proc(mut p: Parser, shallow is_mut: Bool, shallow own_type: OwnType) returns Expr {
    t_line := peek_line(p)
    t_col := peek_col(p)
    name := expect_text(p, TokenType.Ident)

    // Declaration: name := value
    if check(p, TokenType.ColonEq) {
        advance(p)

        // Namespace sugar: Name := namespace { ... }
        if check(p, TokenType.KwNamespace) {
            advance(p)
            mut def := Expr.new(NodeType.StructDef(StructDef()), t_line, t_col)
            expect_token(p, TokenType.LBrace)
            mut body := Expr.new(NodeType.Body, peek_line(p), peek_col(p))
            while check(p, TokenType.RBrace).not().and(check(p, TokenType.Eof).not()) {
                mut stmt := parse_statement(p)
                switch stmt.node_type {
                case NodeType.Decl(dd):
                    mut ns_dd := Declaration(name = dd.name.clone(), is_mut = dd.is_mut,
                        explicit_type = dd.explicit_type.clone(), til_type = dd.til_type.clone(), own_type = dd.own_type)
                    if stmt.children.len().gt(0) {
                        ns_dd.default_value = stmt.child(0).clone()
                    }
                    switch def.node_type {
                    case NodeType.StructDef(sdd):
                        sdd.ns_decls.push(own ns_dd)
                    case:
                        UNREACHABLE(__LOC__)
                    }
                case:
                }
            }
            expect_token(p, TokenType.RBrace)
            def.add_child(own body)
            mut dd := Declaration(name = name.clone(), is_mut = is_mut, own_type = own_type)
            mut decl := Expr.new(NodeType.Decl(dd), t_line, t_col)
            decl.add_child(own def)
            return decl
        }

        mut dd := Declaration(name = name.clone(), is_mut = is_mut, own_type = own_type)
        mut decl := Expr.new(NodeType.Decl(dd), t_line, t_col)
        decl.add_child(own parse_expression(p))
        return decl
    }

    // Declaration with explicit type: name : Type = value
    if check(p, TokenType.Colon) {
        advance(p)

        // FuncSig form: name : func(Types) returns T = (names) { body }
        // parse_func_def handles the full `func(...) returns T = (names) { body }`
        // continuation; the decl path just wraps the result in NODE_DECL.
        if check(p, TokenType.KwFunc).or(check(p, TokenType.KwProc)) {
            mut sig := parse_func_def(p)
            mut dd := Declaration(name = name.clone(), is_mut = is_mut, own_type = own_type)
            mut decl := Expr.new(NodeType.Decl(dd), t_line, t_col)
            decl.add_child(own sig)
            return decl
        }

        mut type_name := parse_type_ref(p)

        // If type is Fn, parse optional Fn(T1, T2) returns T signature
        if type_name.eq("Fn") {
            syn_name := parse_fn_signature(p, t_line, t_col)
            if syn_name.len().gt(0) { type_name = syn_name }
        }

        expect_token(p, TokenType.Eq)

        // Named FuncSig form: name : Type = (names) { body }
        // Lookahead: check if pattern is (ident [, ident]* [,]) {
        if check(p, TokenType.LParen) {
            saved := p.pos
            advance(p) // skip (
            mut is_fsf := true
            while check(p, TokenType.RParen).not().and(check(p, TokenType.Eof).not()) {
                if check(p, TokenType.Ident).not() { is_fsf = false; break }
                advance(p)
                if check(p, TokenType.Comma) { advance(p) }
            }
            if is_fsf.and(check(p, TokenType.RParen)) {
                advance(p) // skip )
                if check(p, TokenType.LBrace).not() { is_fsf = false }
            } else {
                is_fsf = false
            }
            p.pos = saved // restore

            if is_fsf {
                // Parse (name1, name2, ...) as param names
                expect_token(p, TokenType.LParen)
                mut pnames := Vec.new(Str)
                while check(p, TokenType.RParen).not() {
                    pn := expect_text(p, TokenType.Ident)
                    pnames.push(own pn)
                    if check(p, TokenType.Comma) { advance(p) }
                }
                expect_token(p, TokenType.RParen)
                // Parse { body }
                expect_token(p, TokenType.LBrace)
                mut body := parse_block(p)
                // Build incomplete FuncDef (types filled by initer)
                mut ffd := FunctionDef()
                ffd.func_type = FuncType.Func // placeholder
                ffd.variadic_index = -1
                ffd.kwargs_index = -1
                for pn : Str in pnames {
                    ffd.params.push(own Declaration(name = pn.clone(), own_type = OwnType.Ref))
                }
                mut fdef := Expr.new(NodeType.FuncDef(ffd), t_line, t_col)
                fdef.add_child(own body)
                // Wrap in NODE_DECL with explicit_type
                mut dd := Declaration(name = name.clone(), explicit_type = type_name.clone(), til_type = til_type_from_explicit_type(type_name), is_mut = is_mut, own_type = own_type)
                mut decl := Expr.new(NodeType.Decl(dd), t_line, t_col)
                decl.add_child(own fdef)
                return decl
            }
        }

        mut dd := Declaration(name = name.clone(), explicit_type = type_name.clone(), til_type = til_type_from_explicit_type(type_name), is_mut = is_mut, own_type = own_type)
        mut decl := Expr.new(NodeType.Decl(dd), t_line, t_col)
        decl.add_child(own parse_expression(p))
        return decl
    }

    // Field access/assign or method call: name.field...
    if check(p, TokenType.Dot) {
        mut obj := Expr.new(ident_node(name), t_line, t_col)
        mut last_field := ""
        mut last_line : U32 = 0
        mut last_col : U32 = 0
        while check(p, TokenType.Dot) {
            advance(p) // consume '.'
            last_line = peek_line(p)
            last_col = peek_col(p)
            last_field = expect_text(p, TokenType.Ident)
            if check(p, TokenType.Dot) {
                // More dots — intermediate access
                mut access := Expr.new(field_access_node(last_field), last_line, last_col)
                access.add_child(own obj.clone())
                obj = access
            }
        }
        // Method call: name.method(args)
        if check(p, TokenType.LParen) {
            advance(p) // consume '('
            mut callee := Expr.new(field_access_node(last_field), last_line, last_col)
            callee.add_child(own obj.clone())
            mut mcall := Expr.new(NodeType.FCall(FCallData()), last_line, last_col)
            mcall.add_child(own callee)
            while check(p, TokenType.RParen).not().and(check(p, TokenType.Eof).not()) {
                // Named arg check
                if check(p, TokenType.Ident) {
                    if p.pos.add(1).lt(p.tokens.len()) {
                        ref nt : Token = p.tokens.get(p.pos.add(1))
                        if nt.type.is(TokenType.Eq) {
                            na_line := peek_line(p)
                            na_col := peek_col(p)
                            aname := expect_text(p, TokenType.Ident)
                            advance(p) // consume '='
                            mut na := Expr.new(NodeType.NamedArg(aname), na_line, na_col)
                            na.add_child(own parse_expression(p))
                            mcall.add_child(own na)
                            if check(p, TokenType.Comma) { advance(p) }
                            continue
                        }
                    }
                }
                mut is_own_arg := false
                if check(p, TokenType.KwOwn) { advance(p); is_own_arg = true }
                mut marg := parse_expression(p)
                // Issue #56/#57: same anon-arg lift as parse_call (the
                // statement-level method-call path duplicates the arg loop;
                // keep all three sites in sync).
                if marg.node_type.is(NodeType.StructDef).or(marg.node_type.is(NodeType.EnumDef)) {
                    marg_line := marg.line
                    marg_col := marg.col
                    mut mhelper := "struct_def_of"
                    if marg.node_type.is(NodeType.EnumDef) { mhelper = "enum_def_of" }
                    mlifted_name := anon_lift(p, own marg, marg_line, marg_col)
                    if is_own_arg { set_own_arg(mcall, mcall.children.len()) }
                    if is_own_arg {
                        mut msd_callee := Expr.new(ident_node(mhelper), marg_line, marg_col)
                        mut msd_strlit := Expr.new(NodeType.Literal(Literal.Str(mlifted_name.clone())), marg_line, marg_col)
                        mut msd_call := Expr.new(NodeType.FCall(FCallData()), marg_line, marg_col)
                        msd_call.add_child(own msd_callee)
                        msd_call.add_child(own msd_strlit)
                        mcall.add_child(own msd_call)
                    } else {
                        mcall.add_child(own Expr.new(ident_node(mlifted_name), marg_line, marg_col))
                    }
                } else {
                    if is_own_arg { set_own_arg(mcall, mcall.children.len()) }
                    mcall.add_child(own marg)
                }
                if check(p, TokenType.Comma) { advance(p) }
            }
            expect_token(p, TokenType.RParen)
            // Chain further `.method(args)` calls: `f.write("a").write("b")`.
            // Statement-level kicks off this branch; the expression-level
            // parser (parse_primary) handles its own chain loop, but
            // statement-level used to return after the first call and reject
            // the next `.` as "expected statement". Loop here so chainable
            // procs (`File.write` etc.) work at statement scope too.
            while check(p, TokenType.Dot) {
                advance(p) // consume '.'
                chain_line := peek_line(p)
                chain_col := peek_col(p)
                chain_name := expect_text(p, TokenType.Ident)
                expect_token(p, TokenType.LParen)
                mut chain_callee := Expr.new(field_access_node(chain_name), chain_line, chain_col)
                chain_callee.add_child(own mcall.clone())
                mut next_call := Expr.new(NodeType.FCall(FCallData()), chain_line, chain_col)
                next_call.add_child(own chain_callee)
                while check(p, TokenType.RParen).not().and(check(p, TokenType.Eof).not()) {
                    if check(p, TokenType.Ident) {
                        if p.pos.add(1).lt(p.tokens.len()) {
                            ref nt2 : Token = p.tokens.get(p.pos.add(1))
                            if nt2.type.is(TokenType.Eq) {
                                na2_line := peek_line(p)
                                na2_col := peek_col(p)
                                aname2 := expect_text(p, TokenType.Ident)
                                advance(p) // consume '='
                                mut na2 := Expr.new(NodeType.NamedArg(aname2), na2_line, na2_col)
                                na2.add_child(own parse_expression(p))
                                next_call.add_child(own na2)
                                if check(p, TokenType.Comma) { advance(p) }
                                continue
                            }
                        }
                    }
                    mut is_own_arg2 := false
                    if check(p, TokenType.KwOwn) { advance(p); is_own_arg2 = true }
                    mut marg2 := parse_expression(p)
                    if is_own_arg2 { set_own_arg(next_call, next_call.children.len()) }
                    next_call.add_child(own marg2)
                    if check(p, TokenType.Comma) { advance(p) }
                }
                expect_token(p, TokenType.RParen)
                mcall = next_call
            }
            return mcall
        }
        // Postfix increment/decrement on field: obj.field++ or obj.field--
        if check(p, TokenType.PlusPlus).or(check(p, TokenType.MinusMinus)) {
            is_inc2 := check(p, TokenType.PlusPlus)
            pp2_line := peek_line(p)
            pp2_col := peek_col(p)
            advance(p)
            mut method2 := "dec"
            if is_inc2 { method2 = "inc" }
            mut facc := Expr.new(field_access_node(last_field), last_line, last_col)
            facc.add_child(own obj.clone())
            mut inc_acc := Expr.new(field_access_node(method2), pp2_line, pp2_col)
            inc_acc.add_child(own facc)
            mut inc_call := Expr.new(NodeType.FCall(FCallData()), pp2_line, pp2_col)
            inc_call.add_child(own inc_acc)
            return inc_call
        }
        // Field assignment: name.field = value
        expect_token(p, TokenType.Eq)
        mut fa := Expr.new(NodeType.FieldAssign(FieldAssignData(name=last_field)), t_line, t_col)
        fa.add_child(own obj.clone())
        fa.add_child(own parse_expression(p))
        return fa
    }

    // Assignment: name = value
    if check(p, TokenType.Eq) {
        advance(p)
        mut assign := Expr.new(NodeType.Assign(AssignData(name = name.clone())), t_line, t_col)
        assign.add_child(own parse_expression(p))
        return assign
    }

    // Function call: name(...)
    if check(p, TokenType.LParen) {
        return parse_call(p, own Expr.new(ident_node(name), t_line, t_col), t_line, t_col)
    }

    // Postfix increment/decrement: name++ or name--
    if check(p, TokenType.PlusPlus).or(check(p, TokenType.MinusMinus)) {
        is_inc := check(p, TokenType.PlusPlus)
        pp_line := peek_line(p)
        pp_col := peek_col(p)
        advance(p)
        mut method := "dec"
        if is_inc { method = "inc" }
        mut ident := Expr.new(ident_node(name), t_line, t_col)
        mut acc := Expr.new(field_access_node(method), pp_line, pp_col)
        acc.add_child(own ident)
        mut call := Expr.new(NodeType.FCall(FCallData()), pp_line, pp_col)
        call.add_child(own acc)
        return call
    }

    panic(__LOC__, p.path, ":", t_line.to_str(), ":", t_col.to_str(),
        ": expected ':=', ':', '=' or '(' after identifier '", name, "'")
    return Expr.new(NodeType.Body, 0, 0) // unreachable
}

// parse_statement
// Consume any leading DocComment tokens, accumulating their text into
// p.pending_doc (joined with '\n'). The next call to parse_statement
// attaches and clears the accumulator.
drain_doc_comments := func(mut p: Parser) {
    while check(p, TokenType.DocComment) {
        ref t : Token = peek(p)
        if p.pending_doc.is_empty() {
            p.pending_doc = t.text.clone()
        } else {
            p.pending_doc = p.pending_doc.format("\n", t.text)
        }
        advance(p)
    }
}

priv parse_statement := proc(mut p: Parser) returns Expr {
    drain_doc_comments(p)
    mut is_priv := false
    priv_line := peek_line(p)
    priv_col := peek_col(p)
    if check(p, TokenType.KwPriv) {
        advance(p)
        is_priv = true
    }
    mut stmt := parse_statement_body(p)
    if is_priv {
        switch stmt.node_type {
        case NodeType.Decl(dd):
            // #179 steps 1-3, 6: priv is allowed on any top-level
            // declaration (func/proc, struct, enum, or value/let
            // global). Steps 4-5 (struct fields, namespace methods)
            // are handled separately inside parse_struct_def.
            dd.is_priv = true
        case:
            panic(__LOC__, p.path, ":", priv_line.to_str(), ":", priv_col.to_str(),
                ": error: 'priv' must precede a declaration")
        }
    }
    if p.pending_doc.is_empty().not() {
        switch stmt.node_type {
        case NodeType.Decl(dd):
            dd.doc = p.pending_doc.clone()
        case:
        }
        p.pending_doc = ""
    }
    return stmt
}

parse_statement_body := proc(mut p: Parser) returns Expr {
    t_line := peek_line(p)
    t_col := peek_col(p)
    ref t : Token = peek(p)

    if t.type.is(TokenType.Ident) {
        return parse_statement_ident(p, false, OwnType.Shallow)
    }
    if t.type.is(TokenType.KwRef) {
        advance(p)
        mut ref_mut := false
        if check(p, TokenType.KwMut) { advance(p); ref_mut = true }
        i_line := peek_line(p)
        i_col := peek_col(p)
        iname := expect_text(p, TokenType.Ident)
        mut dd := Declaration(name = iname, own_type = OwnType.Ref)
        if ref_mut { dd.is_mut = true }
        if check(p, TokenType.Colon) {
            advance(p)
            dd.explicit_type = parse_type_ref(p)
            dd.til_type = til_type_from_explicit_type(dd.explicit_type)
            expect_token(p, TokenType.Eq)
        } else {
            expect_token(p, TokenType.ColonEq)
        }
        mut decl := Expr.new(NodeType.Decl(dd), i_line, i_col)
        decl.add_child(own parse_expression(p))
        return decl
    }
    if t.type.is(TokenType.KwMut) {
        advance(p)
        return parse_statement_ident(p, true, OwnType.Shallow)
    }
    if t.type.is(TokenType.KwShallow) {
        advance(p)
        panic(__LOC__, p.path, ":", t_line.to_str(), ":", t_col.to_str(),
            ": locals cannot use 'shallow'; locals are owned by default")
    }
    if t.type.is(TokenType.KwReturn) {
        advance(p)
        mut ret := Expr.new(NodeType.Return, t_line, t_col)
        if check(p, TokenType.RBrace).not().and(check(p, TokenType.Eof).not()).and(check(p, TokenType.KwCase).not()) {
            ret.add_child(own parse_expression(p))
        }
        return ret
    }
    if t.type.is(TokenType.KwIf) {
        advance(p)
        mut node := Expr.new(NodeType.If, t_line, t_col)
        node.add_child(own parse_expression(p))
        expect_token(p, TokenType.LBrace)
        node.add_child(own parse_block(p))
        if check(p, TokenType.KwElse) {
            advance(p)
            if check(p, TokenType.KwIf) {
                mut else_body := Expr.new(NodeType.Body, peek_line(p), peek_col(p))
                else_body.add_child(own parse_statement(p))
                node.add_child(own else_body)
            } else {
                expect_token(p, TokenType.LBrace)
                node.add_child(own parse_block(p))
            }
        }
        return node
    }
    if t.type.is(TokenType.StringTok).or(t.type.is(TokenType.Number))
    .or(t.type.is(TokenType.KwTrue)).or(t.type.is(TokenType.KwFalse))
    .or(t.type.is(TokenType.KwNull)).or(t.type.is(TokenType.LParen))
    .or(t.type.is(TokenType.Minus)) {
        return parse_expression(p)
    }
    if t.type.is(TokenType.LBrace) {
        advance(p)
        return parse_block(p)
    }
    if t.type.is(TokenType.KwWhile) {
        advance(p)
        mut node := Expr.new(NodeType.While, t_line, t_col)
        node.add_child(own parse_expression(p))
        expect_token(p, TokenType.LBrace)
        node.add_child(own parse_block(p))
        return node
    }
    if t.type.is(TokenType.KwFor) {
        advance(p)
        mut for_is_mut := false
        if check(p, TokenType.KwMut) {
            advance(p)
            for_is_mut = true
        }
        i_line := peek_line(p)
        i_col := peek_col(p)
        iname := expect_text(p, TokenType.Ident)
        mut node := Expr.new(NodeType.ForIn(ForInData(name = iname, is_mut = for_is_mut)), i_line, i_col)
        if check(p, TokenType.Colon) {
            advance(p)
            set_expr_til_type(node, Type.Custom(expect_text(p, TokenType.Ident)))
        }
        expect_token(p, TokenType.KwIn)
        node.add_child(own parse_expression(p))
        expect_token(p, TokenType.LBrace)
        node.add_child(own parse_block(p))
        return node
    }
    if t.type.is(TokenType.KwSwitch) {
        advance(p)
        mut node := Expr.new(NodeType.Switch, t_line, t_col)
        node.add_child(own parse_expression(p))
        expect_token(p, TokenType.LBrace)
        while check(p, TokenType.RBrace).not().and(check(p, TokenType.Eof).not()) {
            expect_token(p, TokenType.KwCase)
            mut cn := Expr.new(NodeType.Case, peek_line(p), peek_col(p))
            if check(p, TokenType.Colon).not() {
                cn.add_child(own parse_expression(p))
                // Issue #199: optional guard clause `case <pattern> if <expr>:`.
                // Stored as a third child of the Case node so the typer can
                // distinguish `[pattern, body]` (regular) from
                // `[pattern, guard, body]` (guarded). A bare `case if <expr>:`
                // is not allowed -- KwIf only follows a pattern.
                if check(p, TokenType.KwIf) {
                    advance(p)
                    cn.add_child(own parse_expression(p))
                }
            }
            expect_token(p, TokenType.Colon)
            mut cb := Expr.new(NodeType.Body, peek_line(p), peek_col(p))
            while check(p, TokenType.KwCase).not().and(check(p, TokenType.RBrace).not()).and(check(p, TokenType.Eof).not()) {
                cb.add_child(own parse_statement(p))
            }
            cn.add_child(own cb)
            node.add_child(own cn)
        }
        expect_token(p, TokenType.RBrace)
        return node
    }
    if t.type.is(TokenType.KwOwn) {
        advance(p)
        if check(p, TokenType.Ident).or(check(p, TokenType.KwMut)) {
            mut own_mut := false
            if check(p, TokenType.KwMut) { advance(p); own_mut = true }
            if check(p, TokenType.Ident) {
                if p.pos.add(1).lt(p.tokens.len()) {
                    ref nt : Token = p.tokens.get(p.pos.add(1))
                    if nt.type.is(TokenType.ColonEq).or(nt.type.is(TokenType.Colon)) {
                        return parse_statement_ident(p, own_mut, OwnType.Own)
                    }
                }
            }
            if own_mut {
                panic(__LOC__, p.path, ":", t_line.to_str(), ":", t_col.to_str(),
                    ": expected identifier after 'own mut'")
            }
        }
        // own expression (call-site ownership marker)
        // For UFCS method calls like 'own x.delete()', set bit 0 (callee)
        // as a signal. UFCS desugaring converts this to own on self (bit 1).
        mut expr := parse_expression(p)
        if expr.node_type.is(NodeType.FCall) {
            if expr.children.len().gt(0) {
                if expr.child(0).node_type.is(NodeType.FieldAccess) {
                    set_own_arg(expr, 0)
                }
            }
        }
        return expr
    }
    if t.type.is(TokenType.KwBreak) {
        advance(p)
        return Expr.new(NodeType.Break, t_line, t_col)
    }
    if t.type.is(TokenType.KwContinue) {
        advance(p)
        return Expr.new(NodeType.Continue, t_line, t_col)
    }
    // Issue #198: `throw <expr>`. One child = thrown expression.
    if t.type.is(TokenType.KwThrow) {
        advance(p)
        mut tn := Expr.new(NodeType.Throw, t_line, t_col)
        tn.add_child(own parse_expression(p))
        return tn
    }
    // Issue #198: `catch (err: T) { body }`.
    // Three children: Ident var name, Ident type name, Body block.
    if t.type.is(TokenType.KwCatch) {
        advance(p)
        expect_token(p, TokenType.LParen)
        v_line := peek_line(p)
        v_col := peek_col(p)
        var_name := expect_text(p, TokenType.Ident)
        expect_token(p, TokenType.Colon)
        ty_line := peek_line(p)
        ty_col := peek_col(p)
        type_name := expect_text(p, TokenType.Ident)
        expect_token(p, TokenType.RParen)
        expect_token(p, TokenType.LBrace)
        mut body := parse_block(p)
        mut cn := Expr.new(NodeType.Catch, t_line, t_col)
        cn.add_child(own Expr.new(ident_node(var_name), v_line, v_col))
        cn.add_child(own Expr.new(ident_node(type_name), ty_line, ty_col))
        cn.add_child(own body)
        return cn
    }

    panic(__LOC__, p.path, ":", t_line.to_str(), ":", t_col.to_str(),
        ": expected statement, found '", t.text, "'")
    return Expr.new(NodeType.Body, 0, 0) // unreachable
}

// parse: entry point
parse := proc(tokens: Vec, path: Str, mut mode_out: Str) returns Expr {
    mut p := Parser(tokens = tokens.clone(), pos = 0, path = path.clone())

    // Parse optional mode declaration
    if check(p, TokenType.Ident).and(peek(p).text.eq("mode")) {
        advance(p)
        if check(p, TokenType.Ident).or(check(p, TokenType.KwTest)) {
            mode_out = peek(p).text.clone()
            advance(p)
        } else {
            expect_token(p, TokenType.Ident)
        }
    }

    // Parse body. Drain leading doc comments before the EOF check so
    // trailing /// lines (e.g. a single-line REPL input) don't panic when
    // there's no following statement to attach them to.
    mut root := Expr.new(NodeType.Body, 1, 1)
    while true {
        drain_doc_comments(p)
        if check(p, TokenType.Eof) { break }
        root.add_child(own parse_statement(p))
    }
    p.pending_doc = ""
    // Append synthetic Fn type declarations (initer registers them before typer runs)
    for d : Expr in p.fn_sig_decls {
        root.add_child(own d.clone())
    }
    // Append synthetic anon struct/enum type declarations (issue #56/#57).
    for ad : Expr in p.anon_decls {
        root.add_child(own ad.clone())
    }
    // Anonymous lambdas (`func(...){...}` literals in expression positions)
    // used to be lifted here too, but they now move to top level in the
    // typer (src/self/typer.til:typer_lift_lambdas, called from
    // type_check_unit) so the parser can stay dumb. parse_block,
    // parse_expression, and friends just produce a faithful AST; the
    // typer rewrites it.
    return root
}
