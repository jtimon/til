mode lib

// EvalHeap -- the raw-bytes runtime heap (#286 commit 1, rstil model).
//
// Like rstil (github.com/jtimon/rstil), the interpreter stores a variable as
// NAME -> raw heap POINTER (kept in the scope's binding metadata), and the
// value at that pointer is just the bytes the C
// backend would emit. The type lives in the scope's symbol tables, not in
// the value; reclamation is one heap_free per block instead of a per-value
// hand-free.
//
// A handle into this heap is a REAL address, not an offset into a private
// buffer. That is essential: later commits store real C pointers INSIDE
// heap bytes -- a Str's c_str, a Vec's data buffer, an enum payload -- and
// pass them straight back to get()/set(); those same pointers are also
// handed to real C functions (c_str_len, ...) via FFI. A synthetic offset
// could not survive either path, and a growable buffer would move under
// realloc and dangle every stored pointer. So heap_alloc returns the
// address calloc gives (rstil's `alloc_zeroed(...) as usize`).
//
// In til the whole thing is a thin wrapper over calloc/free: C's free()
// needs no size (Rust's dealloc does -- that is the only reason rstil
// keeps a heap_blocks ptr->size table), so there is no size table and no
// buffer. A single live_blocks counter is the cheap balance/leak sanity
// signal; ASAN does the real leak detection.
//
// Scope owns name->pointer binding entries and Context carries the EvalHeap.
// Expression evaluation, scopes, const folding, and FFI all use these raw
// bytes directly. Exercised on its own by test/eval_heap.til.

// Inline-scalar value words (#286 perf): a primitive-typed interpreter
// value is its bytes zero-extended into the pointer-sized word itself --
// no heap block, so scalar reads/temps/results allocate nothing (the old
// Value box inlined scalars the same way; the raw model keeps that for
// scalars while aggregates stay raw heap pointers). These reinterpret a
// word's integer bits and back; implemented in src/c/ext.c.
word_bits := ext_func(w: Dynamic) returns shallow U64 {}
bits_word := ext_func(shallow b: U64) returns shallow Dynamic {}
f32_word := ext_func(shallow f: F32) returns shallow U64 {}
word_f32 := ext_func(shallow b: U64) returns shallow F32 {}
// Ownership sink for an inline-scalar word: consumes the own Dynamic
// without freeing (the word holds value bits, not a heap pointer).
word_drop := ext_func(own w: Dynamic) {}
// Fixed C-side arenas for the interpreter's scalar-word slots (stable
// addresses, no allocation, no teardown).
dispatch_scratch_base := ext_func() returns shallow Dynamic {}
word_ring_base := ext_func() returns shallow Dynamic {}

EvalHeap := struct {
    // #286: the EvalHeap is the chokepoint for value-payload memory. It holds
    // no state -- heap_alloc / heap_free are static (no self), so the whole
    // value path can route through them from a non-mut `ctx` without threading
    // `mut ctx` through 120+ functions (til has no module globals by design).
    // The balance/leak check is ASAN, not an instance counter.
    unused : U8 = 0

namespace:
    new := func() returns EvalHeap {
        return EvalHeap(unused = 0)
    }

    // Allocate a zeroed block of `size` bytes and return its real address.
    // A zero-size request still gets one byte so the address is unique
    // (mirrors rstil: distinct empty structs must not alias).
    heap_alloc := func(size: USize) returns Dynamic {
        mut sz := size
        if sz == 0 { sz = 1 }
        p : U8 = calloc(1, sz)
        if p.is_null() { panic("EvalHeap.heap_alloc: allocation failed") }
        return p
    }

    // Free a block returned by heap_alloc, taking ownership of the pointer
    // (the caller must not use it afterwards).
    heap_free := func(own ptr: Dynamic) {
        free(own ptr)
    }

    delete := func(own self: EvalHeap, call_free: Bool = true) {
        // EvalHeap owns no heap data of its own; the blocks belong to the
        // scope bindings that hold their pointers.
        if call_free { free(own self) }
    }

    // --- Raw byte access. These take a real block pointer and need no
    // EvalHeap instance, so they are static (no self): a value at a heap
    // pointer is read/written exactly like the C backend would. ---

    set_bytes := func(ptr: Dynamic, src: Dynamic, n: USize) {
        memcpy(ptr, src, n)
    }
    get_bytes := func(ptr: Dynamic, dst: Dynamic, n: USize) {
        memcpy(dst, ptr, n)
    }

    set_i64 := func(ptr: Dynamic, val: I64) { write_i64(ptr, val) }
    get_i64 := func(ptr: Dynamic) returns I64 {
        ref v : I64 = ptr
        return v.clone()
    }

    set_u64 := func(ptr: Dynamic, val: U64) { write_u64(ptr, val) }
    get_u64 := func(ptr: Dynamic) returns U64 {
        ref v : U64 = ptr
        return v.clone()
    }

    set_u8 := func(ptr: Dynamic, val: U8) { write_u8(ptr, val) }
    get_u8 := func(ptr: Dynamic) returns U8 {
        ref v : U8 = ptr
        return v.clone()
    }

    set_f32 := func(ptr: Dynamic, val: F32) { write_f32(ptr, val) }
    get_f32 := func(ptr: Dynamic) returns F32 {
        ref v : F32 = ptr
        return v.clone()
    }

    set_bool := func(ptr: Dynamic, val: Bool) { write_bool(ptr, val) }
    get_bool := func(ptr: Dynamic) returns Bool {
        ref v : Bool = ptr
        return v.clone()
    }
}
