mode lib
import("context")

// Asap destruction phase. See doc/pipeline.org step 5 and issue #204.
//
// Runs once per body after the typer's per-body work has settled
// (currently invoked from infer_body / infer_body_unit in typer.til).
// Computes per-binding live ranges and inserts Type.delete() / free()
// calls at the last use of every local, before reassignments, and on
// every early-exit edge (return / break / continue).
//
// The data model is LocalInfo (one per binding the body owns). The
// orchestrator is insert_free_calls. Everything else here is a helper
// it composes.
//
// Cross-file calls: this module reads several typer helpers that the
// asap walk needs (type_to_name, make_delete_call, make_free_call,
// fa_own_type, transfer_is_shallow_field_value_copy, is_compile_directive,
// expr_uses_var, expr_transfers_own, expr_used_in_nested_func,
// expr_contains_decl, fcall_returns_shallow, rhs_is_clone_fcall,
// free_expr_slot_in_place) and two typer state flags (typer_in_main_func,
// typer_in_shallow_return). The loader imports garbager.til right after
// typer.til so those names are in scope.

priv LocalInfo := struct {
    ref name : Str = NULL
    type := Type.Unknown
    decl_index : I32 = 0
    last_use : I32 = 0
    own_transfer : I32 = -1
    skip_scope_delete := false
    is_heap := false
}

alias_used_in_stmts := func(stmts: Vec, name: Str, expr: Expr) returns Bool {
    for d : Expr in stmts {
        switch d.node_type {
        case NodeType.Decl(dd):
            if dd.own_type.is(OwnType.Ref).and(d.children.len().gt(0)) {
                switch d.child(0).node_type {
                case NodeType.Ident(_di):
                    if _di.ident_name().eq(name) {
                        if expr_uses_var(expr, dd.name) { return true }
                    }
                case:
                }
            }
        case:
        }
    }
    return false
}

// Issue #238: the typer's hoist pass can lift a view-returning subexpression
// of an assignment's RHS (e.g. `vname.substr(...)`) into a `hoisted__` temp
// that ALIASES vname's heap buffer, emitted as a statement BEFORE the assign.
// The textual RHS then only names the temp, so expr_uses_var(rhs, vname) no
// longer sees the dependency. If we miss it, insert_assign_delete emits the
// old-value delete too early and the RHS clone copies from vname's freed
// buffer (a use-after-free; manifests as garbage bytes).
//
// Walk the already-emitted preceding statements, taint every `hoisted__`
// binding whose initializer (transitively) reads vname, then report a
// dependency if the RHS reads vname directly or any tainted temp.
// Names of `hoisted__` temps among `preceding` whose initializer
// (transitively) reads `target`. Such a temp may hold a non-owning *view*
// into target's heap buffer (e.g. `target.substr(...)`), so any later use is
// really a use of target's storage.
priv collect_hoist_taint := func(target: Str, preceding: Vec) returns Vec {
    mut tainted := Vec.new(Str)
    mut changed := true
    while changed {
        changed = false
        for pst : Expr in preceding {
            if pst.children.len().lt(1) { continue }
            mut hname := ""
            switch pst.node_type {
            case NodeType.Decl(dd): hname = dd.name
            case NodeType.Assign(ad): hname = ad.name
            case:
            }
            if hname.starts_with("hoisted__").not() { continue }
            mut already := false
            for t : Str in tainted { if t.eq(hname) { already = true } }
            if already { continue }
            ref init : Expr = pst.child(0)
            mut dep := expr_uses_var(init, target)
            if dep.not() {
                for t : Str in tainted { if expr_uses_var(init, t) { dep = true } }
            }
            if dep { tainted.push(own hname.clone()); changed = true }
        }
    }
    return tainted
}

priv rhs_depends_on_var := func(rhs: Expr, vname: Str, preceding: Vec) returns Bool {
    if expr_uses_var(rhs, vname) { return true }
    tainted := collect_hoist_taint(vname, preceding)
    for t : Str in tainted {
        if expr_uses_var(rhs, t) { return true }
    }
    return false
}

priv var_aliases_target := func(varname: Str, target: Str, preceding: Vec) returns Bool {
    if varname.starts_with("hoisted__").not() { return false }
    tainted := collect_hoist_taint(target, preceding)
    for t : Str in tainted {
        if t.eq(varname) { return true }
    }
    return false
}

// Mirrors builder.til's is_pod_enum_clone_call; resolves the enum def
// via TypeScope instead of Context.
priv is_pod_enum_clone_wrap := func(e: Expr, scope: TypeScope) returns Bool {
    tname := clone_call_type_name(e)
    if tname.len().eq(0) { return false }
    return is_pod_enum_clone_of(e, scope.get_struct(tname))
}

collect_scope_locals := func(ctx: Context, body: Expr, scope: TypeScope, is_program_scope: Bool, mut locals_vec: Vec) {
    for i in 0..scope.bindings.len() {
        ref b : TypeBinding = Map.val_ptr(scope.bindings, i)
        // main()'s non-Own params are heap-allocated by the builder's CLI
        // arg parsing (Str_clone / inline Str_from_c_str + box) and owned by
        // main itself; skip the usual is_param filter so they get a
        // scope-end delete.
        if b.is_param.and(b.own_type.is(OwnType.Own).not()).and(ctx.typer_in_main_func.not()) { continue }
        if b.struct_def.is_null().not() { continue }
        if b.func_def.is_null().not() { continue }

        mut decl_idx : I32 = -1
        for j in 0..body.children.len() {
            ref s : Expr = body.child(j)
            switch s.node_type {
            case NodeType.Decl(dd):
                if dd.name.eq(b.name) {
                    decl_idx = j.cast(I32)
                    break
                }
            case:
            }
        }
        if decl_idx.eq(-1) {
            for j in 0..body.children.len() {
                if expr_contains_decl(body.child(j), b.name) {
                    decl_idx = j.cast(I32)
                    break
                }
            }
        }

        mut last_use : I32 = -1
        mut own_transfer : I32 = -1
        mut scan_from : USize = 0
        if decl_idx.gte(0) {
            scan_from = decl_idx.add(1).to_usize()
        }
        for j in scan_from..body.children.len() {
            ref stmt : Expr = body.child(j)
            if is_compile_directive(stmt) { continue }
            if expr_uses_var(stmt, b.name) {
                last_use = j.cast(I32)
            }
            if own_transfer.eq(-1) {
                if expr_transfers_own(stmt, b.name, scope, ctx) {
                    own_transfer = j.cast(I32)
                }
            }
        }

        // Program-scope locals "live forever" so the asap pass skips
        // their cleanup. Synthesized hoist temps (`hoisted__` prefix) are
        // a separate population: the hoist pass lifts FCall args / Type
        // ctors / etc. into a Decl that is consumed by the very next stmt,
        // so they need the normal post-stmt-deletes treatment even at
        // program scope. Without this carveout, top-level `mut X := Foo()`
        // initializers leak every hoisted temp the typer emits to build
        // the constructor args (Type_Struct, Type_Enum, ...).
        mut skip_scope_delete := is_program_scope.and(decl_idx.gte(0)).and(b.name.starts_with("hoisted__").not())
        if skip_scope_delete.not() {
            for j in scan_from..body.children.len() {
                if is_compile_directive(body.child(j)) { continue }
                if expr_used_in_nested_func(body.child(j), b.name) {
                    skip_scope_delete = true
                    break
                }
            }
        }
        // Ref bindings normally don't own data and skip cleanup, except
        // main()'s non-Own params: the builder heap-allocates their
        // wrappers from argv[] and there is no caller to free them, so
        // they need a scope-end delete despite the Ref default.
        main_cli_param := ctx.typer_in_main_func.and(b.is_param)
        if b.own_type.is(OwnType.Ref).and(main_cli_param.not()) { skip_scope_delete = true }

        mut li := LocalInfo()
        li.name = b.name
        li.type = b.type
        li.decl_index = decl_idx
        li.last_use = last_use
        li.own_transfer = own_transfer
        li.skip_scope_delete = skip_scope_delete
        li.is_heap = b.own_type.is(OwnType.Own).or(main_cli_param)
        // Decls whose RHS the builder will stack-allocate must use
        // call_free=false in their cleanup or `free()` would touch a
        // stack pointer. Two flavors:
        //   - LiteralStr RHS: builder emits a stack compound literal.
        //   - FCall RHS where the callee returns `shallow T`: builder
        //     stack-allocates the value via fcall_is_shallow_return.
        // Force is_heap=false regardless of the binding's own_type
        // (which constfold may leave at Own from the original FCall
        // return, and which the typer otherwise leaves at Own for
        // Struct-returning FCalls).
        if decl_idx.gte(0) {
            ref _li_stmt : Expr = body.child(decl_idx.cast(U32))
            if _li_stmt.node_type.is(NodeType.Decl).and(_li_stmt.children.len().gt(0)) {
                ref _li_rhs : Expr = _li_stmt.child(0)
                if _li_rhs.node_type.is_literal_str() {
                    li.is_heap = false
                } else if _li_rhs.node_type.is(NodeType.FCall).and(fcall_returns_shallow(_li_rhs, scope).neq(0)) {
                    li.is_heap = false
                }
                if is_pod_enum_clone_wrap(_li_rhs, scope) {
                    // POD-enum clone wrap (`c := Color.clone(Color.Red)`):
                    // builder emits a stack value (Color c = (Color){...};)
                    // and registers the local with stack_locals. The
                    // destructor must use call_free=false so the trailing
                    // Color_delete(&c, &(Bool){0}) is a true no-op --
                    // payload-less enum delete has nothing to free.
                    // Without this, the asaper emits call_free=true on
                    // the stack value, which emit_as_ptr then wraps in
                    // a malloc-copy `({ Color *_oa = malloc(...); *_oa
                    // = c; _oa; })` to satisfy the own + free contract.
                    // Matches the same shape builder.til's POD-enum
                    // shortcut keys off of (is_pod_enum_clone_call).
                    li.is_heap = false
                }
            }
        }
        locals_vec.push(own li)
    }
}

extend_ref_local_lifetimes := func(mut body: Expr, locals: Vec, scope: TypeScope) {
    mut ref_changed := true
    while ref_changed {
        ref_changed = false
        // (a) FieldAssign-to-Ref-field: `holder.f = src` where f is declared
        // `ref mut f : T = NULL` borrows src into holder. src must outlive
        // any later access of holder (via holder.f or holder field-access
        // chains), or the borrow dangles. Extend src's last_use to match
        // holder's. Same shape as the `ref local := src` case handled below
        // (which is the `ref`-Decl form of the same borrow relationship).
        // (Issue #109: test/ref.til's test_ref_struct_field leaked b's
        // 16B RefNode wrapper because the typer treated `a.next = b` as a
        // transfer and skipped b's scope-end delete; with that
        // misclassification fixed in expr_transfers_own, b would otherwise
        // be deleted at the FieldAssign itself, dangling `a.next` for the
        // later asserts.)
        for i in 0..body.children.len() {
            ref mut stmt : Expr = body.child(i)
            if stmt.node_type.is(NodeType.FieldAssign).not() { continue }
            if stmt.fa_own_type(scope).is(OwnType.Ref).not() { continue }
            if stmt.children.len().lt(2) { continue }
            // target side: walk down the FieldAccess chain to find the
            // root Ident (the holder local's name).
            ref mut target : Expr = stmt.child(0)
            while target.node_type.is(NodeType.FieldAccess).and(target.children.len().gt(0)) {
                target = target.child(0)
            }
            mut holder_name := ""
            switch target.node_type {
            case NodeType.Ident(_hn): holder_name = _hn.ident_name()
            case:
            }
            if holder_name.len().eq(0) { continue }
            // source side: the FieldAssign RHS, if an Ident, names the
            // local whose lifetime we extend.
            ref value : Expr = stmt.child(1)
            mut src_name := ""
            switch value.node_type {
            case NodeType.Ident(_sn): src_name = _sn.ident_name()
            case:
            }
            if src_name.len().eq(0) { continue }
            // Extend src's last_use to the body's final stmt. Conservative:
            // the borrow could be propagated through shallow clones of the
            // holder (e.g. `c := a.clone()` makes c.next alias a.next ==
            // src). Without aliasing analysis we can't pin a tighter bound,
            // so keep src alive through scope exit.
            body_last := body.children.len().sub(1).cast(I32)
            for local : LocalInfo in locals {
                if local.name.eq(src_name).and(local.last_use.lt(body_last)) {
                    local.last_use = body_last
                    ref_changed = true
                }
            }
        }
        for i in 0..body.children.len() {
            ref mut stmt : Expr = body.child(i)
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            mut dd_name := ""
            mut dd_is_ref := false
            switch stmt.node_type {
            case NodeType.Decl(dd):
                dd_name = dd.name.clone()
                dd_is_ref = dd.own_type.is(OwnType.Ref)
            case:
            }
            if dd_is_ref.not() { continue }
            ref mut rhs : Expr = stmt.child(0)

            mut ref_last : I32 = -1
            for j in i.add(1)..body.children.len() {
                if expr_uses_var(body.child(j), dd_name) {
                    ref_last = j.cast(I32)
                }
            }
            if ref_last.eq(-1) { ref_last = i.cast(I32) }
            for local : LocalInfo in locals {
                if local.name.eq(dd_name).and(local.last_use.gt(ref_last)) {
                    ref_last = local.last_use
                }
            }

            switch rhs.node_type {
            case NodeType.Ident(src_name):
                for local : LocalInfo in locals {
                    if local.name.eq(src_name.ident_name()).and(local.last_use.lt(ref_last)) {
                        local.last_use = ref_last
                        ref_changed = true
                    }
                }
                continue
            case:
            }
            if rhs.node_type.is(NodeType.FieldAccess) {
                ref mut root : Expr = rhs
                while root.node_type.is(NodeType.FieldAccess).and(root.children.len().gt(0)) {
                    root = root.child(0)
                }
                switch root.node_type {
                case NodeType.Ident(src_name):
                    for local : LocalInfo in locals {
                        if local.name.eq(src_name.ident_name()).and(local.last_use.lt(ref_last)) {
                            local.last_use = ref_last
                            ref_changed = true
                        }
                    }
                case:
                }
                continue
            }
            if rhs.node_type.is(NodeType.FCall).not() { continue }
            for a in 1..rhs.children.len() {
                ref mut arg : Expr = rhs.child(a)
                while arg.node_type.is(NodeType.FieldAccess).and(arg.children.len().gt(0)) {
                    arg = arg.child(0)
                }
                switch arg.node_type {
                case NodeType.Ident(aname):
                    for local : LocalInfo in locals {
                        if local.name.eq(aname.ident_name()).and(local.last_use.lt(ref_last)) {
                            local.last_use = ref_last
                            ref_changed = true
                        }
                    }
                case:
                }
            }
        }
    }
}

check_use_after_own_transfer := proc(body: Expr, locals: Vec, ctx: Context) {
    for local : LocalInfo in locals {
        if local.own_transfer.gte(0).and(local.last_use.gt(local.own_transfer)) {
            ref stmt : Expr = body.child(local.last_use.to_usize())
            stmt.type_error("use of '".concat(local.name).concat("' after ownership transfer"), ctx)
            ref xfer : Expr = body.child(local.own_transfer.to_usize())
            println(ctx.path, ":", xfer.line.to_str(), ":", xfer.col.to_str(), ": note: ownership transferred here")
            println("  help: pass a clone instead: own ", local.name, ".clone()")
        }
    }
}

insert_exit_deletes := proc(mut body: Expr, mut live: Vec, return_only: Bool) {
    // Quick check: any returns/breaks/continues or nested if/while/body?
    mut needs_scan := false
    for s : Expr in body.children {
        if s.node_type.is(NodeType.Return).or(s.node_type.is(NodeType.If)).or(s.node_type.is(NodeType.While)).or(s.node_type.is(NodeType.Body)) {
            needs_scan = true
            break
        }
        if return_only.not().and(s.node_type.is(NodeType.Break).or(s.node_type.is(NodeType.Continue))) {
            needs_scan = true
            break
        }
    }
    if needs_scan.not() { return }

    mut old := Vec.new(Expr)
    old.move_from(body.children)

    mut new_ch := Vec.new(Expr)
    for i in 0..old.len() {
        ref stmt : Expr = old[i]
        if is_compile_directive(stmt) { continue }
        if stmt.node_type.is(NodeType.If) {
            for c in 1..stmt.children.len() {
                insert_exit_deletes(stmt.child(c), live, return_only)
            }
        }
        if stmt.node_type.is(NodeType.While) {
            insert_exit_deletes(stmt.child(1), live, true)
        }
        if stmt.node_type.is(NodeType.Body) {
            insert_exit_deletes(stmt, live, return_only)
        }
        if stmt.node_type.is(NodeType.Return).or(return_only.not().and(stmt.node_type.is(NodeType.Break).or(stmt.node_type.is(NodeType.Continue)))) {
            for local : LocalInfo in live {
                if stmt.children.len().gt(0) {
                    ref retval : Expr = stmt.child(0)
                    if expr_uses_var(retval, local.name).or(alias_used_in_stmts(old, local.name, retval)) {
                        continue
                    }
                }
                if type_to_name(local.type).len().gt(0) {
                    heap := local.is_heap
                    del := make_delete_call(local.name, local.type, heap, heap, stmt)
                    if del.is_null().not() {
                        if stmt.node_type.is(NodeType.Return).and(stmt.children.len().gt(0)) {
                            stmt.add_child(own del)
                        } else {
                            new_ch.push(own del)
                        }
                    }
                } else if local.is_heap {
                    del := make_free_call(local.name, local.type, stmt)
                    if del.is_null().not() {
                        if stmt.node_type.is(NodeType.Return).and(stmt.children.len().gt(0)) {
                            stmt.add_child(own del)
                        } else {
                            new_ch.push(own del)
                        }
                    }
                }
            }
        }
        new_ch.push_take(old, i)
    }
    body.children.move_from(new_ch)
}

insert_nested_exit_deletes := proc(stmt: Expr, locals: Vec, stmt_idx: U32) {
    if stmt.node_type.is(NodeType.If).not() {
        if stmt.node_type.is(NodeType.While).not() {
            if stmt.node_type.is(NodeType.Body).not() { return }
        }
    }
    mut live_vec := Vec.new(LocalInfo)
    for local : LocalInfo in locals {
        if local.skip_scope_delete { continue }
        if local.own_transfer.gte(0) { continue }
        if local.decl_index.lt(stmt_idx.cast(I32)) {
            if local.last_use.gte(stmt_idx.cast(I32)).or(local.last_use.eq(-1)) {
                live_vec.push(own local.clone())
            }
        }
    }
    if live_vec.len().gt(0) {
        switch stmt.node_type {
        case NodeType.If:
            for c in 1..stmt.children.len() {
                insert_exit_deletes(stmt.child(c), live_vec, false)
            }
        case NodeType.While:
            insert_exit_deletes(stmt.child(1), live_vec, true)
        case:
            // NodeType.Body -- desugared for-in wraps its decls + while in a Body block
            insert_exit_deletes(stmt, live_vec, true)
        }
    }
}

insert_exit_deletes_into_stmt := func(stmt: Expr, body_stmts: Vec, locals: Vec, stmt_idx: U32, mut new_ch: Vec) {
    if stmt.node_type.is(NodeType.Return).not() {
        if stmt.node_type.is(NodeType.Break).not() {
            if stmt.node_type.is(NodeType.Continue).not() { return }
        }
    }
    for local : LocalInfo in locals {
        if stmt.children.len().gt(0) {
            ref retval : Expr = stmt.child(0)
            if expr_uses_var(retval, local.name).or(alias_used_in_stmts(body_stmts, local.name, retval)) {
                continue
            }
        }
        if local.skip_scope_delete { continue }
        if local.own_transfer.gte(0) { continue }
        if local.decl_index.lt(stmt_idx.cast(I32)) {
            if local.last_use.gte(stmt_idx.cast(I32)).or(local.last_use.eq(-1)) {
                if type_to_name(local.type).len().gt(0) {
                    heap := local.is_heap
                    del := make_delete_call(local.name, local.type, heap, heap, stmt)
                    if del.is_null().not() { new_ch.push(own del) }
                } else if local.is_heap {
                    del := make_free_call(local.name, local.type, stmt)
                    if del.is_null().not() { new_ch.push(own del) }
                }
            }
        }
    }
}

insert_post_stmt_deletes := func(stmt: Expr, locals: Vec, stmt_idx: U32, mut new_ch: Vec, scope: TypeScope, preceding: Vec) {
    if stmt.node_type.is(NodeType.Return).or(stmt.node_type.is(NodeType.Break)).or(stmt.node_type.is(NodeType.Continue)) {
        return
    }
    for local : LocalInfo in locals {
        if local.skip_scope_delete { continue }
        if local.own_transfer.gte(0) {
            // Ownership transferred via value-copy to a Shallow struct field
            // (e.g. `Decl(name = local, ...)` where Declaration.name has the
            // default Shallow ownership) leaves the local's heap wrapper
            // orphaned: the field gets a bit-copy of *local, the field's own
            // destructor frees the inner data, but nothing frees the wrapper.
            // Skipping the delete entirely (the previous behavior) leaks the
            // wrapper. Emit a raw `free(local)` after the transfer stmt to
            // release the wrapper without touching the inner data.
            //
            // This only fires when the transfer is a struct constructor with
            // the receiving field declared Shallow. Other transfer shapes
            // (`free(own X)`, `Type.delete(own X, ...)`, `field = X` where the
            // field is Own/Ref, passing X as `own` arg to a function that
            // takes ownership of the wrapper) already consume the wrapper, so
            // adding a `free` here would double-free.
            if local.is_heap.and(is_aggregate(local.type)) {
                if local.own_transfer.eq(stmt_idx.cast(I32)) {
                    if type_to_name(local.type).len().gt(0) {
                        // Decl(field = local) where the receiving Shallow
                        // field value-copies the inner struct: the field's
                        // own destructor frees the inner data, but nothing
                        // would free the local's wrapper. Emit a raw
                        // `free(local)` after the transfer stmt to release
                        // the wrapper without touching the inner data.
                        if transfer_is_shallow_field_value_copy(stmt, local.name, scope) {
                            free_call := make_free_call(local.name, local.type, stmt)
                            if free_call.is_null().not() {
                                new_ch.push(own free_call)
                            }
                        }
                    }
                }
            }
            continue
        }
        if local.last_use.eq(stmt_idx.cast(I32)) {
            // FieldAssign with auto-cloned Ident RHS at the local's last use:
            // the clone allocates a deep copy, the field stores the copy, and
            // the local's contents would then be deleted by the normal
            // last_use destructor below -- a clone+delete roundtrip whose
            // intermediate allocation leaks its sub-pointers (Context_clone
            // via load_program, etc.). Replace clone(local) with bare local
            // so codegen emits a value-copy (`field = *local`), then free
            // only the heap wrapper. Only apply when stmt is the FieldAssign
            // itself (not a wrapping for/if -- last_use would point to the
            // outer stmt in that case, so this match implicitly excludes
            // loop/conditional bodies).
            if local.is_heap.and(is_aggregate(local.type)) {
                if stmt.node_type.is(NodeType.FieldAssign).and(stmt.children.len().gte(2)) {
                    ref _fa_rhs : Expr = stmt.child(1)
                    if rhs_is_clone_fcall(_fa_rhs).and(_fa_rhs.children.len().gte(2)) {
                        ref _clone_arg : Expr = _fa_rhs.child(1)
                        switch _clone_arg.node_type {
                        case NodeType.Ident(_clone_arg_name):
                            if _clone_arg_name.ident_name().eq(local.name) {
                                mut _bare := Expr.new(ident_node(local.name), _fa_rhs.line, _fa_rhs.col)
                                _bare.set_expr_til_type(local.type.clone())
                                ref slot_fa : Expr = stmt.children[1]
                                slot_fa.free_expr_slot_in_place()
                                stmt.children.set(1, own _bare)
                                free_call := make_free_call(local.name, local.type, stmt)
                                if free_call.is_null().not() {
                                    new_ch.push(own free_call)
                                }
                                continue
                            }
                        case:
                        }
                    }
                }
            }
            // Plain Assign with auto-cloned Ident RHS at the local's last
            // use: `lhs = local.clone()` where `local` is a dying owned
            // aggregate. The typer (infer_assign_stmt) wraps the Ident RHS
            // in .clone() for value semantics, but at the local's last use
            // the clone is a wasteful copy whose deep allocations leak --
            // the original `local` is dropped by the scope-end delete right
            // after. Replace `local.clone()` with bare `local` so codegen
            // emits a pointer move into lhs, and skip local's scope-end
            // delete: ownership transfers wholesale to the assign target
            // (whose own save_old_delete already freed lhs's prior value).
            if local.is_heap.and(is_aggregate(local.type)) {
                mut assign_saves_old := false
                switch stmt.node_type {
                case NodeType.Assign(adata): assign_saves_old = adata.save_old_delete
                case:
                }
                if stmt.node_type.is(NodeType.Assign).and(assign_saves_old).and(stmt.children.len().gte(1)) {
                    mut assign_target := ""
                    switch stmt.node_type {
                    case NodeType.Assign(adata2): assign_target = adata2.name
                    case:
                    }
                    ref assign_rhs : Expr = stmt.child(0)
                    // Guard against self-assign `e = e.clone()`: moving there
                    // would alias the just-deleted old value.
                    if assign_target.eq(local.name).not().and(rhs_is_clone_fcall(assign_rhs)).and(assign_rhs.children.len().gte(2)) {
                        ref clone_arg : Expr = assign_rhs.child(1)
                        switch clone_arg.node_type {
                        case NodeType.Ident(clone_arg_name):
                            // Issue #238: never move a clone-arg that is a
                            // hoisted view aliasing the assign target. The
                            // clone is what decouples `target = target.substr(
                            // ...).clone()` from target's own freed buffer;
                            // moving the view instead would alias the deleted
                            // old value.
                            if clone_arg_name.ident_name().eq(local.name)
                                .and(var_aliases_target(local.name, assign_target, preceding).not()) {
                                mut bare_ident := Expr.new(ident_node(local.name), assign_rhs.line, assign_rhs.col)
                                bare_ident.set_expr_til_type(local.type.clone())
                                ref slot_assign : Expr = stmt.children[0]
                                slot_assign.free_expr_slot_in_place()
                                stmt.children.set(0, own bare_ident)
                                continue
                            }
                        case:
                        }
                    }
                }
            }
            if type_to_name(local.type).len().gt(0) {
                heap := local.is_heap
                del := make_delete_call(local.name, local.type, heap, heap, stmt)
                if del.is_null().not() { new_ch.push(own del) }
            } else if local.is_heap {
                del := make_free_call(local.name, local.type, stmt)
                if del.is_null().not() { new_ch.push(own del) }
            }
        }
        if local.last_use.eq(-1).and(local.decl_index.eq(stmt_idx.cast(I32))) {
            if type_to_name(local.type).len().gt(0) {
                heap := local.is_heap
                del := make_delete_call(local.name, local.type, heap, heap, stmt)
                if del.is_null().not() { new_ch.push(own del) }
            } else if local.is_heap {
                del := make_free_call(local.name, local.type, stmt)
                if del.is_null().not() { new_ch.push(own del) }
            }
        }
    }
}

insert_assign_delete := func(mut stmt: Expr, locals: Vec, mut new_ch: Vec) {
    switch stmt.node_type {
    case NodeType.Assign(ad):
        vname := ad.name
        for local : LocalInfo in locals {
            if local.name.eq(vname).not() { continue }
            if is_aggregate(local.type) {
                ref rhs : Expr = stmt.child(0)
                if rhs_depends_on_var(rhs, vname, new_ch) {
                    ad.save_old_delete = true
                    stmt.set_expr_til_type(local.type.clone())
                } else {
                    if type_to_name(local.type).len().gt(0) {
                        heap := local.is_heap
                        del := make_delete_call(local.name, local.type, heap, heap, stmt)
                        if del.is_null().not() { new_ch.push(own del) }
                    } else if local.is_heap {
                        del := make_free_call(local.name, local.type, stmt)
                        if del.is_null().not() { new_ch.push(own del) }
                    }
                }
            }
            break
        }
    case:
    }
}

promote_own_transferred_locals := func(ctx: Context, mut body: Expr, locals: Vec) {
    for local : LocalInfo in locals {
        if local.decl_index.lt(0) { continue }
        ref stmt : Expr = body.child(local.decl_index.cast(U32))
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        // Skip LiteralStr-RHS decls (temp or user-visible): the builder
        // emits these as stack-allocated compound-literal Str values, so
        // heap-promotion would mismatch the generated delete (call_free=true
        // would free a stack pointer). Keep them Shallow so make_delete_call
        // generates call_free=false.
        if stmt.children.len().gt(0) {
            ref _rhs0 : Expr = stmt.child(0)
            if _rhs0.node_type.is_literal_str() { continue }
            // Same shape, payload-less enum case: the builder emits a
            // stack value via the is_pod_enum_clone_call shortcut, so
            // heap-promotion here would mismatch the destructor (the
            // delete-arg malloc-copy wrapper that emit_as_ptr emits for
            // own + stack_local). Keep is_heap=false so make_delete_call
            // uses call_free=false / arg_is_own=false and the destructor
            // becomes a true no-op (`Color_delete(&c, &(Bool){0});`).
            if is_pod_enum_clone_wrap(_rhs0, ctx.scope) { continue }
        }
        switch stmt.node_type {
        case NodeType.Decl(dd):
        if dd.own_type.is(OwnType.Ref) { continue }
        // Issue #205: use is_aggregate, not raw is(Type.Struct).
        // Primitives modelled as Type.Struct("I32") must NOT be
        // heap-promoted -- they live in registers and the codegen
        // emits them as value types. is(Type.Struct) alone would
        // pull them into the heap-promote branch.
        is_struct := is_aggregate(local.type)
        if local.own_transfer.lt(0).and(is_struct.not()) { continue }
        // Skip heap-promotion if the only "use" is the function's
        // shallow return: the value-copy at return is the transfer,
        // and a heap wrapper just leaks (the codegen does
        // ~return DEREF(rv)~ without freeing rv). Keeping the local
        // Shallow lets the codegen use a stack value and value-copy
        // out cleanly.
        if ctx.typer_in_shallow_return.and(local.own_transfer.lt(0)).and(is_struct) {
            if local.last_use.gte(0) {
                ref last_stmt : Expr = body.child(local.last_use.cast(U32))
                if last_stmt.node_type.is(NodeType.Return) {
                    if last_stmt.children.len().gt(0) {
                        switch last_stmt.child(0).node_type {
                        case NodeType.Ident(rname):
                            if rname.ident_name().eq(local.name) { continue }
                        case:
                        }
                    }
                }
            }
        }
        dd.own_type = OwnType.Own
        local.is_heap = true
        case:
        }
    }
}

// Asap entry point. The typer's scope-management sites call this
// once per body after the per-body in-place pass settles, just
// before they tear down the per-body scope. Issue #204 step 3b
// tracks lifting the per-site calls into a single garbager_destroy(ctx)
// walk in prepare_program once #158's per-body scope cache is in
// the Context.
// Does a branch body unconditionally transfer ownership of `name`? True iff
// a direct (top-level) statement of the branch transfers it -- a transfer
// nested inside another if/while/switch is itself conditional and doesn't
// count, so we stay conservative.
priv branch_unconditionally_transfers := func(branch: Expr, name: Str, scope: TypeScope, ctx: Context) returns Bool {
    if branch.is_null() { return false }
    if branch.node_type.is(NodeType.Body).not() { return false }
    for c : Expr in branch.children {
        if c.node_type.is(NodeType.If) { continue }
        if c.node_type.is(NodeType.While) { continue }
        if c.node_type.is(NodeType.Switch) { continue }
        if c.node_type.is(NodeType.Body) { continue }
        if expr_transfers_own(c, name, scope, ctx) { return true }
    }
    return false
}

// asap stands down on any `own` transfer (own_transfer >= 0). When the
// transfer sits inside one branch of an `if`, the other path never frees the
// local -- a leak (the conditional-transfer footgun). Fix: add the local's
// delete to the branch that does NOT transfer it. This only ever ADDS a
// delete on a path where the local is provably still owned, so it cannot
// double-free; conservative detection (exactly one branch unconditionally
// transfers, local unused after the if) leaves every other shape as-is.
//
// Restricted to body-declared LOCALS (decl_index >= 0). Params are excluded:
// a delete method's own `self` does `if call_free { free(own self) }`, a
// conditional transfer of `self`; sinking a delete into the else branch there
// re-frees self on the call_free=false path (recursive delete -> bad-free).
//
// Str is excluded: its heap/literal/view duality (CAP_LIT / CAP_VIEW) means a
// Str local can hold a borrowed view on the non-transfer path, and deleting
// that frees the source's buffer. Vec/Set/Map/struct/enum locals are always
// genuinely heap when owned, so they are safe to sink.
priv sink_conditional_transfer_deletes := func(mut body: Expr, locals: Vec, scope: TypeScope, ctx: Context) {
    for local : LocalInfo in locals {
        if local.skip_scope_delete { continue }
        if local.decl_index.lt(0) { continue }
        if local.own_transfer.lt(0) { continue }
        if local.is_heap.not() { continue }
        if is_aggregate(local.type).not() { continue }
        if type_to_name(local.type).len().eq(0) { continue }
        if type_to_name(local.type).eq("Str") { continue }
        if local.last_use.gt(local.own_transfer) { continue }
        if local.own_transfer.gte(body.children.len().cast(I32)) { continue }
        ref tstmt : Expr = body.child(local.own_transfer.cast(U32))
        if tstmt.node_type.is(NodeType.If).not() { continue }
        if tstmt.children.len().lt(2) { continue }
        ref then_body : Expr = tstmt.child(1)
        has_else := tstmt.children.len().gt(2)
        then_xfer := branch_unconditionally_transfers(then_body, local.name, scope, ctx)
        mut else_xfer := false
        if has_else {
            else_xfer = branch_unconditionally_transfers(tstmt.child(2), local.name, scope, ctx)
        }
        if then_xfer.and(else_xfer.not()) {
            del := make_delete_call(local.name, local.type, local.is_heap, local.is_heap, tstmt)
            if del.is_null() { continue }
            if has_else {
                tstmt.child(2).add_child(own del)
            } else {
                mut else_b := Expr.new(NodeType.Body, tstmt.line, tstmt.col)
                else_b.add_child(own del)
                tstmt.add_child(own else_b)
            }
        } else if else_xfer.and(then_xfer.not()) {
            del := make_delete_call(local.name, local.type, local.is_heap, local.is_heap, tstmt)
            if del.is_null() { continue }
            then_body.add_child(own del)
        }
    }
}

insert_free_calls := proc(ctx: Context, mut body: Expr, mut scope: TypeScope, scope_exit: I32) returns Bool {
    if scope_exit.eq(0) { return false }
    is_program_scope := scope.parent.is_null()

    mut locals_vec := Vec.new(LocalInfo)
    collect_scope_locals(ctx, body, scope, is_program_scope, locals_vec)
    if locals_vec.len().eq(0) { return false }

    extend_ref_local_lifetimes(body, locals_vec, scope)
    check_use_after_own_transfer(body, locals_vec, ctx)
    promote_own_transferred_locals(ctx, body, locals_vec)
    sink_conditional_transfer_deletes(body, locals_vec, scope, ctx)

    mut old := Vec.new(Expr)
    old.move_from(body.children)

    mut new_ch := Vec.new(Expr)
    for i in 0..old.len() {
        ref stmt : Expr = old[i]
        if is_compile_directive(stmt) { continue }
        insert_exit_deletes_into_stmt(stmt, old, locals_vec, i, new_ch)
        insert_nested_exit_deletes(stmt, locals_vec, i)
        insert_assign_delete(stmt, locals_vec, new_ch)
        mut post_deletes := Vec.new(Expr)
        insert_post_stmt_deletes(stmt, locals_vec, i, post_deletes, scope, new_ch)
        new_ch.push_take(old, i)
        new_ch.append(own post_deletes)
    }

    body.children.move_from(new_ch)
    return true
}

// Per-body asap entry. Called from the typer's scope-management sites
// (infer_func_def_expr, infer_if_stmt, infer_while_stmt, the Body/Catch
// arms of infer_body_stmt) after infer_body has settled and before
// TypeScope.delete. Returns true iff body.children changed, so the
// caller can decide whether to re-run reregister_scope_defs.
// See issue #204.
garbager_destroy_body := proc(ctx: Context, mut body: Expr, mut scope: TypeScope) returns Bool {
    return insert_free_calls(ctx, body, scope, 1)
}

// Post-order walk that processes every body the typer stamped
// with a body_id (FuncDef body, if then/else, while body, Body
// block, catch body). For each tracked body it pops the cached
// TypeScope from ctx.body_scopes, runs insert_free_calls, then
// deletes the scope. Post-order ensures inner bodies are
// rewritten before their enclosing body's insert_free_calls
// runs (same order the inline asap used).
// One-time fix-up of every cached scope's .parent ref to point at
// the now-stable ctx.body_scopes Vec slot for its typer-time parent
// (or at &ctx.scope when parent_body_id is 0). The typer set .parent
// to the parent's STACK address; that address is dead by the time
// this runs, so we re-resolve via parent_body_id / body_id_to_index.
// Must run before garbager_walk_subs because insert_free_calls
// chases .parent for name resolution (TypeScope.get_struct, etc.).
priv garbager_fixup_parents := func(mut ctx: Context) {
    for i in 0..ctx.body_scopes.len() {
        ref mut s : TypeScope = ctx.body_scopes[i]
        if s.parent_body_id.eq(0) {
            s.parent = ctx.scope
        } else {
            ref pidx_ref : USize = ctx.body_id_to_index[s.parent_body_id]
            pidx : USize = pidx_ref
            ref parent_scope : TypeScope = ctx.body_scopes[pidx]
            s.parent = parent_scope
        }
    }
}

priv garbager_walk_subs := proc(mut ctx: Context, mut e: Expr) {
    for i in 0..e.children.len() {
        ref mut child : Expr = e.child(i)
        garbager_walk_subs(ctx, child)
    }
    // Descend into ns_decls of struct/enum definitions (parser stores
    // these separately from Expr.children). Method func bodies (and
    // any nested if/while/block/catch inside them) are stamped with
    // body_ids that only this entry can reach.
    if e.node_type.is(NodeType.StructDef).or(e.node_type.is(NodeType.EnumDef)) {
        ref ns : Vec = def_ns_decls(e)
        for nsd : Declaration in ns {
            if nsd.default_value.is_null().not() {
                garbager_walk_subs(ctx, nsd.default_value)
            }
        }
    }
    switch e.node_type {
    case NodeType.StructDef(sdd_w):
        for sfd_w : Declaration in sdd_w.fields {
            if sfd_w.default_value.is_null().not() {
                garbager_walk_subs(ctx, sfd_w.default_value)
            }
        }
    case:
    }
    if e.body_id.eq(0) { return }
    if ctx.body_id_to_index.has(e.body_id).not() { return }
    ref idx_ref : USize = ctx.body_id_to_index[e.body_id]
    idx : USize = idx_ref
    ref mut scope : TypeScope = ctx.body_scopes[idx]
    // Restore the per-body flags collect_scope_locals reads from
    // Context (main()-param free, shallow-return semantics).
    saved_main := ctx.typer_in_main_func
    saved_sh := ctx.typer_in_shallow_return
    ctx.typer_in_main_func = scope.scope_in_main_func
    ctx.typer_in_shallow_return = scope.scope_in_shallow_return
    insert_free_calls(ctx, e, scope, 1)
    ctx.typer_in_main_func = saved_main
    ctx.typer_in_shallow_return = saved_sh
}

// Phase entry point. Runs the asap-destruction pass on every
// imported file. For each file: post-order walk that processes
// every sub-body the typer stamped with a body_id (looking the
// scope up by id on ctx.body_scopes), then asap the program body
// itself using the global TypeScope (ctx.scope). Called from the
// tail of init_and_type_program (loader.til) so both prepare_program
// (interpret/translate/build/run/test/install paths) and cmd_doc
// see the post-asap program AST.
//
// Issue #204 step 3b: the typer no longer asap's sub-bodies
// inline. It stamps a body_id on each scope-owning body and
// hands the live TypeScope to ctx.body_scopes; this proc walks
// the post-typer AST and looks each scope up by id.
garbager_destroy := proc(mut ctx: Context) {
    saved_path := ctx.path.clone()
    saved_in_main := ctx.typer_in_main_func
    saved_in_shallow := ctx.typer_in_shallow_return
    ctx.typer_in_main_func = false
    ctx.typer_in_shallow_return = false
    garbager_fixup_parents(ctx)
    for i in 0..ctx.imported.len() {
        ref path : Str = Map.key_ptr(ctx.imported, i)
        ref mut iu : ImportUnit = Map.val_ptr(ctx.imported, i)
        ctx.path = path.clone()
        garbager_walk_subs(ctx, iu.ast)
        insert_free_calls(ctx, iu.ast, ctx.scope, 1)
    }
    // Free every cached per-body TypeScope now that asap is done.
    // Vec.clear on a Vec(TypeScope) dispatches TypeScope.delete on
    // each element, so this releases all the scopes the typer stashed.
    Vec.clear(ctx.body_scopes)
    Map.clear(ctx.body_id_to_index)
    ctx.path = saved_path
    ctx.typer_in_main_func = saved_in_main
    ctx.typer_in_shallow_return = saved_in_shallow
}
