mode lib
import("context")

// Asap destruction phase. See doc/pipeline.org step 5 and issue #204.
//
// Runs once per body after the typer's per-body work has settled
// (currently invoked from infer_body / infer_body_unit in typer.til).
// Computes per-binding live ranges and inserts Type.delete() / free()
// calls at the last use of every local, before reassignments, and on
// every early-exit edge (return / break / continue).
//
// The data model is LocalInfo (one per binding the body owns). The
// orchestrator is insert_free_calls. Everything else here is a helper
// it composes.
//
// Cross-file calls: this module reads several typer helpers that the
// asap walk needs (type_to_name, make_delete_call, make_free_call,
// fa_own_type, transfer_is_shallow_field_value_copy, is_compile_directive,
// expr_uses_var, expr_transfers_own, expr_used_in_nested_func,
// expr_contains_decl, fcall_returns_shallow, rhs_is_clone_fcall)
// and two typer state flags (typer_in_main_func,
// typer_in_shallow_return). The loader imports garbager.til right after
// typer.til so those names are in scope.

priv LocalInfo := struct {
    ref name : Str = NULL
    type := Type.Unknown
    decl_index : I32 = 0
    last_use : I32 = 0
    own_transfer : I32 = -1
    skip_scope_delete := false
    is_heap := false
    // True when the stmt at own_transfer consumes this binding via a
    // DESTRUCTOR call (free(own x) / T.delete(own x, ...) /
    // til_closure_delete(x)) rather than an ordinary own-arg / own-field
    // transfer. The delete-method shape `if call_free { free(own self) }`
    // is the one case where a param's conditional transfer must keep the
    // full asap stand-down: the body's field deletes already ran, so
    // grafting a delete onto the other path double-frees. Every OTHER
    // conditionally-transferred own param was leaking under the old
    // blanket "params stand down" rule (#302).
    dtor_transfer := false
}

// True when `stmt` (or any sub-expression) destroys `name` directly:
// free(own name), T.delete(own name, ...), or til_closure_delete(name).
// Matched structurally, no name sniffing -- the shapes make_delete_call /
// make_free_call / make_closure_delete_call emit and hand-written
// destructor bodies use.
priv transfer_is_destructor_call := func(stmt: Expr, name: Str) returns Bool {
    if stmt.node_type.is(NodeType.FCall).and(stmt.children.len().gt(1)) {
        mut is_dtor := false
        switch stmt.children[0].node_type {
        case NodeType.FieldAccess(dfa):
            if dfa.field_access_name() == "delete" { is_dtor = true }
        case NodeType.Ident(dfi):
            if dfi.ident_name().eq("free").or(dfi.ident_name().eq("til_closure_delete")) { is_dtor = true }
        case:
        }
        if is_dtor {
            switch stmt.children[1].node_type {
            case NodeType.Ident(dai):
                if dai.ident_name() == name { return true }
            case:
            }
        }
    }
    for dc : Expr in stmt.children {
        if transfer_is_destructor_call(dc, name) { return true }
    }
    return false
}

// Issue #302 stage 0: decision-audit dump. TIL_GC_AUDIT=<path-substring>
// makes insert_free_calls print, for every body in a matching unit, the
// pass's final per-binding decisions (the LocalInfo table after the
// analysis phases) and the destructor sites present in the body after
// insertion. The golden test test/gc_audit.til + test/gc_audit.expected
// pins the dump so later #302 stages show their decision diffs in review
// instead of only as ASAN outcomes. See doc/garbager.org. The env read
// lives in ext.c (gc_audit_filter, "" when unset) like the TIL_LEAK_PROBE
// gate.
gc_audit_filter := ext_proc() returns Str {}

priv gc_audit_flag := func(b: Bool) returns Str {
    if b { return "1" }
    return "0"
}

// `name` with its LAST digit run removed: "hoisted__U64_7725" ->
// "hoisted__U64_", "_va_Array_217_ek" -> "_va_Array__ek". Only the last
// run goes because it is the synthesized counter; interior digits are type
// widths (the U64 in hoisted__U64_...) and must survive. The counters are
// GLOBAL (ctx.hoist_counter and friends run across every previously typed
// unit), so printing them raw would shift the whole golden whenever an
// unrelated core/std change adds or removes a hoist. Returns `name`
// unchanged when it has no digits.
priv gc_audit_strip_counter := func(name: Str) returns Str {
    mut run_start : I64 = -1
    mut run_end : I64 = -1
    mut i : USize = 0
    while i < name.len() {
        if name.get(i).gte('0').and(name.get(i).lte('9')) {
            run_start = i.to_i64()
            mut j := i
            while j.lt(name.len()).and(name.get(j).gte('0')).and(name.get(j).lte('9')) {
                j++
            }
            run_end = j.to_i64()
            i = j
        } else {
            i++
        }
    }
    if run_start < 0 { return name.clone() }
    start_u := run_start.to_usize()
    end_u := run_end.to_usize()
    return format(name.substr(0, start_u), name.substr(end_u, name.len().sub(end_u)))
}

// Stable display name: user names pass through; synthesized names (the
// hoisted__ / leading-underscore population) get their trailing counter
// replaced by a per-body ordinal in order of first appearance, so
// identical bodies dump identically regardless of the global counter
// state. Digit-less synthetic names pass through unchanged.
priv gc_audit_name := func(name: Str, mut names: Map(Str, Str), mut counts: Map(Str, I64)) returns Str {
    if name.starts_with("hoisted__").or(name.starts_with("_")).not() { return name.clone() }
    if names.has(name) { return names[name].clone() }
    key := gc_audit_strip_counter(name)
    if key == name { return name.clone() }
    mut k : I64 = 0
    if counts.has(key) { k = counts[key].clone() }
    counts.set(key, own k.add(1))
    disp := format(key, "#", k.to_str())
    names.set(name, own disp.clone())
    return disp
}

// Renders `e` when it is a destructor-shaped call -- the exact shapes
// make_delete_call / make_free_call / make_closure_delete_call emit
// (which user-written cleanup shares) -- or "" for anything else.
priv gc_audit_destructor_line := func(e: Expr, mut names: Map(Str, Str), mut counts: Map(Str, I64)) returns Str {
    if e.node_type.is(NodeType.FCall).not() { return "" }
    if e.children.len() < 2 { return "" }
    mut kind := ""
    mut tname := ""
    switch e.children[0].node_type {
    case NodeType.FieldAccess(del_fa):
        if del_fa.field_access_name() != "delete" { return "" }
        if e.children[0].children.len() < 1 { return "" }
        switch e.children[0].children[0].node_type {
        case NodeType.Ident(tid): tname = Str.clone(tid.ident_name())
        case: return ""
        }
        kind = "delete"
    case NodeType.Ident(fid):
        if fid.ident_name() == "free" {
            kind = "free"
        } else if fid.ident_name() == "til_closure_delete" {
            kind = "closure-delete"
        } else {
            return ""
        }
    case:
        return ""
    }
    mut arg_name := "<expr>"
    switch e.children[1].node_type {
    case NodeType.Ident(aid): arg_name = gc_audit_name(aid.ident_name(), names, counts)
    case:
    }
    mut own_s := ""
    if get_own_arg(e, 1) { own_s = " own=1" }
    if kind == "delete" {
        mut cf := ""
        if e.children.len() > 2 {
            switch e.children[2].node_type {
            case NodeType.Literal(Literal.Bool(cfb)): cf = format(" call_free=", gc_audit_flag(cfb))
            case:
            }
        }
        return format("delete ", tname, ".delete(", arg_name, ")", cf, own_s)
    }
    return format(kind, "(", arg_name, ")", own_s)
}

// Destructor sites present in `body` after insertion, recursively; `prefix`
// is the dotted statement path ("2.if0.1 " style) so nested sites are
// addressable. Nested if/while/block bodies are also dumped by their OWN
// insert_free_calls run (they get separate garbager_destroy_body calls
// during typing), so their sites appear twice: once standalone, once inside
// the enclosing body's walk after insert_nested_exit_deletes may have
// appended to them. Both views are wanted -- the second is where the
// enclosing body's exit deletes land.
priv gc_audit_sites := proc(body: Expr, prefix: Str, mut names: Map(Str, Str), mut counts: Map(Str, I64)) {
    for i in 0..body.children.len() {
        ref s : Expr = body.children[i]
        line := gc_audit_destructor_line(s, names, counts)
        if line.len() > 0 {
            println("GC-AUDIT site ", prefix, i.to_str(), " ", line)
        }
        switch s.node_type {
        case NodeType.Assign(ad):
            if ad.save_old_delete {
                println("GC-AUDIT site ", prefix, i.to_str(), " assign-old-delete ", gc_audit_name(ad.name, names, counts))
            }
        case NodeType.FieldAssign(fad):
            if fad.save_old_delete {
                println("GC-AUDIT site ", prefix, i.to_str(), " fieldassign-old-delete ", gc_audit_name(fad.name, names, counts))
            }
        case NodeType.Return:
            for ri in 1..s.children.len() {
                rline := gc_audit_destructor_line(s.children[ri], names, counts)
                if rline.len() > 0 {
                    println("GC-AUDIT site ", prefix, i.to_str(), " return-attached ", rline)
                }
            }
        case NodeType.If:
            for ci in 1..s.children.len() {
                gc_audit_sites(s.children[ci], format(prefix, i.to_str(), ".if", ci.sub(1).to_str(), "."), names, counts)
            }
        case NodeType.While:
            if s.children.len() > 1 {
                gc_audit_sites(s.children[1], format(prefix, i.to_str(), ".while."), names, counts)
            }
        case NodeType.Body:
            gc_audit_sites(s, format(prefix, i.to_str(), ".body."), names, counts)
        case NodeType.Switch:
            for ci in 1..s.children.len() {
                if s.children[ci].node_type.is(NodeType.Case) {
                    cbi := s.children[ci].children.len() - 1
                    gc_audit_sites(s.children[ci].children[cbi], format(prefix, i.to_str(), ".case", ci.sub(1).to_str(), "."), names, counts)
                }
            }
        case:
        }
    }
}

// A binding with no decision at all -- not declared in this body, never
// used, never transferred, not heap, not skipped. Program-scope dumps see
// the whole global namespace this way (every imported core/std name plus
// re-registered per-body temps); printing those would tie the golden to
// the global name population, so the table filters them.
priv gc_audit_local_is_noise := func(local: LocalInfo) returns Bool {
    return local.decl_index.eq(-1).and(local.last_use.eq(-1))
        .and(local.own_transfer.eq(-1))
        .and(local.is_heap.not()).and(local.skip_scope_delete.not())
}

// One body's full audit record: the settled LocalInfo table (the pass's
// decisions; decl/last_use/own_transfer are PRE-insertion statement
// indexes), then the destructor sites found in the post-insertion body.
// Called after the insertion loop so both sections share one name-ordinal
// state. The table's order is the scope-binding order, which is
// deterministic for a fixed compiler + source. locals= counts the SHOWN
// lines (no-decision bindings are filtered, see gc_audit_local_is_noise).
priv gc_audit_dump := proc(ctx: Context, body: Expr, locals: Vec(LocalInfo)) {
    mut names := Map(Str, Str).new()
    mut counts := Map(Str, I64).new()
    mut shown : I64 = 0
    for counted : LocalInfo in locals {
        if gc_audit_local_is_noise(counted).not() { shown = shown + 1 }
    }
    println("GC-AUDIT body ", ctx.path, ":", body.line.to_str(), ":", body.col.to_str(),
        " locals=", shown.to_str())
    for local : LocalInfo in locals {
        if gc_audit_local_is_noise(local) { continue }
        mut tname := type_to_name(local.type)
        if tname.len() == 0 { tname = til_type_name(local.type) }
        println("GC-AUDIT local ", gc_audit_name(local.name, names, counts),
            " type=", tname,
            " decl=", local.decl_index.to_str(),
            " last_use=", local.last_use.to_str(),
            " own_transfer=", local.own_transfer.to_str(),
            " heap=", gc_audit_flag(local.is_heap),
            " skip=", gc_audit_flag(local.skip_scope_delete))
    }
    gc_audit_sites(body, "", names, counts)
}

priv alias_used_in_stmts := func(stmts: Vec(Expr), name: Str, expr: Expr) returns Bool {
    for d : Expr in stmts {
        switch d.node_type {
        case NodeType.Decl(dd):
            if dd.own_type.is(OwnType.Ref).and(d.children.len().gt(0)) {
                switch d.children[0].node_type {
                case NodeType.Ident(di):
                    if di.ident_name() == name {
                        if expr_uses_var(expr, dd.name) { return true }
                    }
                case:
                }
            }
        case:
        }
    }
    return false
}

// Issue #238: the typer's hoist pass can lift a view-returning subexpression
// of an assignment's RHS (e.g. `vname.substr(...)`) into a `hoisted__` temp
// that ALIASES vname's heap buffer, emitted as a statement BEFORE the assign.
// The textual RHS then only names the temp, so expr_uses_var(rhs, vname) no
// longer sees the dependency. If we miss it, insert_assign_delete emits the
// old-value delete too early and the RHS clone copies from vname's freed
// buffer (a use-after-free; manifests as garbage bytes).
//
// Walk the already-emitted preceding statements, taint every `hoisted__`
// binding whose initializer (transitively) reads vname, then report a
// dependency if the RHS reads vname directly or any tainted temp.
// Names of `hoisted__` temps among `preceding` whose initializer
// (transitively) reads `target`. Such a temp may hold a non-owning *view*
// into target's heap buffer (e.g. `target.substr(...)`), so any later use is
// really a use of target's storage.
priv collect_hoist_taint := func(target: Str, preceding: Vec(Expr)) returns Vec(Str) {
    mut tainted := Vec(Str).new()
    mut changed := true
    while changed {
        changed = false
        for pst : Expr in preceding {
            if pst.children.len() < 1 { continue }
            mut hname := ""
            switch pst.node_type {
            case NodeType.Decl(dd): hname = dd.name
            case NodeType.Assign(ad): hname = ad.name
            case:
            }
            if hname.starts_with("hoisted__").not() { continue }
            mut already := false
            for t : Str in tainted { if t == hname { already = true } }
            if already { continue }
            ref init : Expr = pst.children[0]
            mut dep := expr_uses_var(init, target)
            if dep.not() {
                for t : Str in tainted { if expr_uses_var(init, t) { dep = true } }
            }
            if dep { tainted.push(own hname.clone()); changed = true }
        }
    }
    return tainted
}

priv rhs_depends_on_var := func(rhs: Expr, vname: Str, preceding: Vec(Expr)) returns Bool {
    if expr_uses_var(rhs, vname) { return true }
    tainted := collect_hoist_taint(vname, preceding)
    for t : Str in tainted {
        if expr_uses_var(rhs, t) { return true }
    }
    return false
}

priv var_aliases_target := func(varname: Str, target: Str, preceding: Vec(Expr)) returns Bool {
    if varname.starts_with("hoisted__").not() { return false }
    tainted := collect_hoist_taint(target, preceding)
    for t : Str in tainted {
        if t == varname { return true }
    }
    return false
}

// Mirrors builder.til's is_pod_enum_clone_call; resolves the enum def
// via TypeScope instead of Context.
priv is_pod_enum_clone_wrap := func(e: Expr, scope: TypeScope) returns Bool {
    tname := clone_call_type_name(e)
    if tname.len() == 0 { return false }
    return is_pod_enum_clone_of(e, scope.get_struct(tname))
}

priv collect_scope_locals := func(ctx: Context, body: Expr, scope: TypeScope, is_program_scope: Bool, mut locals_vec: Vec(LocalInfo)) {
    for b in scope.bindings.values {
        // main()'s non-Own params are heap-allocated by the builder's CLI
        // arg parsing (Str_clone / inline Str_from_c_str + box) and owned by
        // main itself; skip the usual is_param filter so they get a
        // scope-end delete.
        if b.is_param.and(b.own_type.is(OwnType.Own).not()).and(ctx.typer_in_main_func.not()) { continue }
        if scope.struct_def_of(b.name).is_null().not() { continue }
        if scope.lookup_func(b.name).is_null().not().and(b.type.is_funcptr().not()).and(b.type.is(Type.Body).not()) { continue }

        mut decl_idx : I32 = -1
        for j in 0..body.children.len() {
            ref s : Expr = body.children[j]
            switch s.node_type {
            case NodeType.Decl(dd):
                if dd.name == b.name {
                    decl_idx = j.to_i32()
                    break
                }
            case:
            }
        }
        if decl_idx == -1 {
            for j in 0..body.children.len() {
                if expr_contains_decl(body.children[j], b.name) {
                    decl_idx = j.to_i32()
                    break
                }
            }
        }

        mut last_use : I32 = -1
        mut own_transfer : I32 = -1
        mut scan_from : USize = 0
        if decl_idx >= 0 {
            scan_from = decl_idx.add(1).to_usize()
        }
        for j in scan_from..body.children.len() {
            ref stmt : Expr = body.children[j]
            if is_compile_directive(stmt) { continue }
            if expr_uses_var(stmt, b.name) {
                last_use = j.to_i32()
            }
            if own_transfer == -1 {
                if expr_transfers_own(stmt, b.name, scope, ctx) {
                    own_transfer = j.to_i32()
                }
            }
        }

        // Program-scope locals "live forever" so the asap pass skips
        // their cleanup. Synthesized hoist temps (`hoisted__` prefix) are
        // a separate population: the hoist pass lifts FCall args / Type
        // ctors / etc. into a Decl that is consumed by the very next stmt,
        // so they need the normal post-stmt-deletes treatment even at
        // program scope. Without this carveout, top-level `mut X := Foo()`
        // initializers leak every hoisted temp the typer emits to build
        // the constructor args (Type_Struct, Type_Enum, ...).
        mut skip_scope_delete := is_program_scope.and(decl_idx.gte(0)).and(b.name.starts_with("hoisted__").not())
        if skip_scope_delete.not() {
            for j in scan_from..body.children.len() {
                if is_compile_directive(body.children[j]) { continue }
                if expr_used_in_nested_func(body.children[j], b.name) {
                    skip_scope_delete = true
                    break
                }
            }
        }
        // Ref bindings normally don't own data and skip cleanup, except
        // main()'s non-Own params: the builder heap-allocates their
        // wrappers from argv[] and there is no caller to free them, so
        // they need a scope-end delete despite the Ref default.
        main_cli_param := ctx.typer_in_main_func.and(b.is_param)
        if b.own_type.is(OwnType.Ref).and(main_cli_param.not()) { skip_scope_delete = true }

        mut li := LocalInfo()
        li.name = b.name
        li.type = b.type
        li.decl_index = decl_idx
        li.last_use = last_use
        li.own_transfer = own_transfer
        li.skip_scope_delete = skip_scope_delete
        if own_transfer >= 0 {
            li.dtor_transfer = transfer_is_destructor_call(body.children[own_transfer.to_usize()], b.name)
        }
        li.is_heap = b.own_type.is(OwnType.Own).or(main_cli_param)
        if b.type.is_funcptr().or(b.type.is(Type.Body)).and(b.own_type.is(OwnType.Ref).not()) { li.is_heap = false }
        // Decls whose RHS the builder will stack-allocate must use
        // call_free=false in their cleanup or `free()` would touch a
        // stack pointer. Two flavors:
        //   - LiteralStr RHS: builder emits a stack compound literal.
        //   - FCall RHS where the callee returns `shallow T`: builder
        //     stack-allocates the value via fcall_is_shallow_return.
        // Force is_heap=false regardless of the binding's own_type
        // (which constfold may leave at Own from the original FCall
        // return, and which the typer otherwise leaves at Own for
        // Struct-returning FCalls).
        if decl_idx >= 0 {
            ref li_stmt : Expr = body.children[decl_idx.to_usize()]
            if li_stmt.node_type.is(NodeType.Decl).and(li_stmt.children.len().gt(0)) {
                ref li_rhs : Expr = li_stmt.children[0]
                if li_rhs.node_type.is_literal_str() {
                    li.is_heap = false
                } else if li_rhs.node_type.is(NodeType.FCall).and(fcall_returns_shallow(li_rhs, scope).neq(0)) {
                    li.is_heap = false
                } else {
                    switch li_rhs.node_type {
                    case NodeType.FuncDef(rhs_fd):
                        if b.type.is_funcptr().and(rhs_fd.captures.len().gt(0)).and(b.own_type.is(OwnType.Ref).not()) {
                            li.is_heap = true
                        }
                    case NodeType.BodyValue:
                        if b.type.is(Type.Body).and(b.own_type.is(OwnType.Ref).not()) {
                            li.is_heap = true
                        }
                    case NodeType.FCall:
                        if b.type.is_funcptr().or(b.type.is(Type.Body)).and(b.own_type.is(OwnType.Ref).not()) {
                            li.is_heap = true
                        }
                    case:
                    }
                }
                if is_pod_enum_clone_wrap(li_rhs, scope) {
                    // POD-enum clone wrap (`c := Color.clone(Color.Red)`):
                    // builder emits a stack value (Color c = (Color){...};)
                    // and registers the local with stack_locals. The
                    // destructor must use call_free=false so the trailing
                    // Color_delete(&c, &(Bool){0}) is a true no-op --
                    // payload-less enum delete has nothing to free.
                    // Without this, the asaper emits call_free=true on
                    // the stack value, which emit_as_ptr then wraps in
                    // a malloc-copy `({ Color *_oa = malloc(...); *_oa
                    // = c; _oa; })` to satisfy the own + free contract.
                    // Matches the same shape builder.til's POD-enum
                    // shortcut keys off of (is_pod_enum_clone_call).
                    li.is_heap = false
                }
            }
        }
        locals_vec.push(own li)
    }
}

priv extend_ref_local_lifetimes := func(mut body: Expr, locals: Vec(LocalInfo), scope: TypeScope) {
    mut ref_changed := true
    while ref_changed {
        ref_changed = false
        // (a) FieldAssign-to-Ref-field: `holder.f = src` where f is declared
        // `ref mut f : T = NULL` borrows src into holder. src must outlive
        // any later access of holder (via holder.f or holder field-access
        // chains), or the borrow dangles. Extend src's last_use to match
        // holder's. Same shape as the `ref local := src` case handled below
        // (which is the `ref`-Decl form of the same borrow relationship).
        // (Issue #109: test/ref.til's test_ref_struct_field leaked b's
        // 16B RefNode wrapper because the typer treated `a.next = b` as a
        // transfer and skipped b's scope-end delete; with that
        // misclassification fixed in expr_transfers_own, b would otherwise
        // be deleted at the FieldAssign itself, dangling `a.next` for the
        // later asserts.)
        for mut stmt : Expr in body.children {
            if stmt.node_type.is(NodeType.FieldAssign).not() { continue }
            if stmt.fa_own_type(scope).is(OwnType.Ref).not() { continue }
            if stmt.children.len() < 2 { continue }
            // target side: walk down the FieldAccess chain to find the
            // root Ident (the holder local's name).
            ref mut target : Expr = stmt.children[0]
            while target.node_type.is(NodeType.FieldAccess).and(target.children.len().gt(0)) {
                target = target.children[0]
            }
            mut holder_name := ""
            switch target.node_type {
            case NodeType.Ident(hn): holder_name = Str.clone(hn.ident_name())
            case:
            }
            if holder_name.len() == 0 { continue }
            // source side: the FieldAssign RHS, if an Ident, names the
            // local whose lifetime we extend.
            ref value : Expr = stmt.children[1]
            mut src_name := ""
            switch value.node_type {
            case NodeType.Ident(sn): src_name = Str.clone(sn.ident_name())
            case:
            }
            if src_name.len() == 0 { continue }
            // Extend src's last_use to the body's final stmt. Conservative:
            // the borrow could be propagated through shallow clones of the
            // holder (e.g. `c := a.clone()` makes c.next alias a.next ==
            // src). Without aliasing analysis we can't pin a tighter bound,
            // so keep src alive through scope exit.
            body_last := body.children.len().sub(1).to_i32()
            for local : LocalInfo in locals {
                if local.name.eq(src_name).and(local.last_use.lt(body_last)) {
                    local.last_use = body_last
                    ref_changed = true
                }
            }
        }
        for i in 0..body.children.len() {
            ref mut stmt : Expr = body.children[i]
            if stmt.node_type.is(NodeType.Decl).not() { continue }
            mut dd_name := ""
            mut dd_is_ref := false
            switch stmt.node_type {
            case NodeType.Decl(dd):
                dd_name = dd.name.clone()
                dd_is_ref = dd.own_type.is(OwnType.Ref)
            case:
            }
            if stmt.children.len() > 0 {
                switch stmt.children[0].node_type {
                case NodeType.FuncDef(fd):
                    mut closure_last : I32 = i.to_i32()
                    for local : LocalInfo in locals {
                        if local.name.eq(dd_name).and(local.last_use.gt(closure_last)) {
                            closure_last = local.last_use
                        }
                    }
                    for cap : Declaration in fd.captures {
                        if cap.own_type.is(OwnType.Ref).not() { continue }
                        for local2 : LocalInfo in locals {
                            if local2.name.eq(cap.name).and(local2.last_use.lt(closure_last)) {
                                local2.last_use = closure_last
                                ref_changed = true
                            }
                        }
                    }
                case NodeType.BodyValue(bd):
                    mut closure_last : I32 = i.to_i32()
                    for local : LocalInfo in locals {
                        if local.name.eq(dd_name).and(local.last_use.gt(closure_last)) {
                            closure_last = local.last_use
                        }
                    }
                    for cap : Declaration in bd.captures {
                        if cap.own_type.is(OwnType.Ref).not() { continue }
                        for local2 : LocalInfo in locals {
                            if local2.name.eq(cap.name).and(local2.last_use.lt(closure_last)) {
                                local2.last_use = closure_last
                                ref_changed = true
                            }
                        }
                    }
                case:
                }
            }
            if dd_is_ref.not() { continue }
            ref mut rhs : Expr = stmt.children[0]

            mut ref_last : I32 = -1
            for j in i.add(1)..body.children.len() {
                if expr_uses_var(body.children[j], dd_name) {
                    ref_last = j.to_i32()
                }
            }
            if ref_last == -1 { ref_last = i.to_i32() }
            for local : LocalInfo in locals {
                if local.name.eq(dd_name).and(local.last_use.gt(ref_last)) {
                    ref_last = local.last_use
                }
            }

            switch rhs.node_type {
            case NodeType.Ident(src_name):
                for local : LocalInfo in locals {
                    if local.name.eq(src_name.ident_name()).and(local.last_use.lt(ref_last)) {
                        local.last_use = ref_last
                        ref_changed = true
                    }
                }
                continue
            case:
            }
            if rhs.node_type.is(NodeType.FieldAccess) {
                ref mut root : Expr = rhs
                while root.node_type.is(NodeType.FieldAccess).and(root.children.len().gt(0)) {
                    root = root.children[0]
                }
                switch root.node_type {
                case NodeType.Ident(src_name):
                    for local : LocalInfo in locals {
                        if local.name.eq(src_name.ident_name()).and(local.last_use.lt(ref_last)) {
                            local.last_use = ref_last
                            ref_changed = true
                        }
                    }
                case:
                }
                continue
            }
            if rhs.node_type.is(NodeType.FCall).not() { continue }
            for a in 1..rhs.children.len() {
                ref mut arg : Expr = rhs.children[a]
                while arg.node_type.is(NodeType.FieldAccess).and(arg.children.len().gt(0)) {
                    arg = arg.children[0]
                }
                switch arg.node_type {
                case NodeType.Ident(aname):
                    for local : LocalInfo in locals {
                        if local.name.eq(aname.ident_name()).and(local.last_use.lt(ref_last)) {
                            local.last_use = ref_last
                            ref_changed = true
                        }
                    }
                case:
                }
            }
        }
    }
}

// Issue #250: a hoisted view temp (a `hoisted__` Decl whose initializer reads
// a local's heap buffer, e.g. `arg.substr(...)`) keeps that local's buffer
// live until the temp is consumed -- typically by a later `.clone()`. The
// local's last *named* mention is the view-producing statement, so without
// this the asap pass schedules the local's auto-delete right there, BEFORE the
// clone copies from the view: a use-after-free that corrupts the clone (garbage
// bytes). This is the cross-variable generalization of #238, whose
// collect_hoist_taint / var_aliases_target machinery only handled the case
// where the view aliases the *assign target*.
//
// Fix idea #2 from the issue: treat a use of a hoisted view as a use of its
// backing local. Taint the hoisted temps that (transitively) read the local,
// then extend the local's last_use to the last statement that consumes any
// such temp. Deferring an owned local's delete is always memory-safe, so the
// (slightly over-eager) transitive taint -- which also follows clone results
// that no longer alias the buffer -- only pushes the delete a touch later.
priv extend_hoist_view_lifetimes := func(body: Expr, locals: Vec(LocalInfo)) {
    for local : LocalInfo in locals {
        if local.name.starts_with("hoisted__") { continue }
        tainted := collect_hoist_taint(local.name, body.children)
        if tainted.len() == 0 { continue }
        mut view_last : I32 = -1
        for j in 0..body.children.len() {
            if is_compile_directive(body.children[j]) { continue }
            for t : Str in tainted {
                if expr_uses_var(body.children[j], t) { view_last = j.to_i32() }
            }
        }
        if view_last > local.last_use { local.last_use = view_last }
    }
}

// A while body whose UNGUARDED spine transfers `name` -- i.e. the
// transfer re-runs on every iteration. Three exemptions keep this an
// errors-only check under the index model:
//   - an If/Switch-guarded transfer is exempt: the guard may hold for
//     exactly one iteration (desugarer's `if ji == vi` splat push);
//   - a spine containing a direct Break or Return executes at most once
//     in full, so its transfer cannot re-run (Continue does NOT exempt:
//     `{ consume(own s); continue }` still re-runs);
//   - nested If/Switch bodies are skipped wholesale; a nested While's
//     condition and spine re-run, so they are checked.
priv while_spine_transfers := func(wbody: Expr, name: Str, scope: TypeScope, ctx: Context) returns Bool {
    for sp : Expr in wbody.children {
        if sp.node_type.is(NodeType.Break).or(sp.node_type.is(NodeType.Return)) { return false }
    }
    for sp : Expr in wbody.children {
        switch sp.node_type {
        case NodeType.If: continue
        case NodeType.Switch: continue
        case NodeType.While:
            if expr_transfers_own(sp.children[0], name, scope, ctx) { return true }
            if while_spine_transfers(sp.children[1], name, scope, ctx) { return true }
            continue
        case NodeType.Body:
            if while_spine_transfers(sp, name, scope, ctx) { return true }
            continue
        case:
        }
        if expr_transfers_own(sp, name, scope, ctx) { return true }
    }
    return false
}

// `stmt` contains a loop whose re-running part transfers ownership of
// `name`. The single own_transfer index cannot represent "the transfer
// statement can execute twice", so without this check a transfer inside
// a while of a binding declared outside it compiles into C whose second
// iteration consumes an already-freed value (verified: silent
// heap-use-after-free).
priv transfer_inside_loop := func(stmt: Expr, name: Str, scope: TypeScope, ctx: Context) returns Bool {
    if stmt.node_type.is(NodeType.While) {
        if expr_transfers_own(stmt.children[0], name, scope, ctx) { return true }
        return while_spine_transfers(stmt.children[1], name, scope, ctx)
    }
    for tc : Expr in stmt.children {
        if transfer_inside_loop(tc, name, scope, ctx) { return true }
    }
    return false
}

priv expr_reassigns_var := func(e: Expr, name: Str) returns Bool {
    switch e.node_type {
    case NodeType.Assign(ad):
        if ad.name == name { return true }
    case:
    }
    for rc : Expr in e.children {
        if expr_reassigns_var(rc, name) { return true }
    }
    return false
}

priv check_use_after_own_transfer := proc(body: Expr, locals: Vec(LocalInfo), scope: TypeScope, ctx: Context) {
    for local : LocalInfo in locals {
        if local.own_transfer.gte(0).and(local.last_use.gt(local.own_transfer)) {
            ref stmt : Expr = body.children[local.last_use.to_usize()]
            stmt.type_error(format("use of '", local.name, "' after ownership transfer"), ctx)
            ref xfer : Expr = body.children[local.own_transfer.to_usize()]
            println(ctx.path, ":", xfer.line.to_str(), ":", xfer.col.to_str(), ": note: ownership transferred here")
            println("  help: pass a clone instead: own ", local.name, ".clone()")
        }
        // #302: a transfer inside a loop, of a binding declared outside the
        // loop, may run on every iteration -- the second one moves an
        // already-moved value. A loop that also REASSIGNS the binding is
        // the legitimate rebind-then-transfer pattern and is skipped (the
        // index model cannot order the two within an iteration; the CFG
        // pass will).
        if local.own_transfer >= 0 {
            ref xstmt : Expr = body.children[local.own_transfer.to_usize()]
            if transfer_inside_loop(xstmt, local.name, scope, ctx).and(
                expr_reassigns_var(xstmt, local.name).not()) {
                xstmt.type_error(format("ownership of '", local.name,
                    "' transferred inside a loop; a second iteration would use a moved value"), ctx)
                println("  help: declare '", local.name, "' inside the loop, or pass a clone: own ", local.name, ".clone()")
            }
        }
    }
}

priv insert_exit_deletes := proc(mut body: Expr, mut live: Vec(LocalInfo), return_only: Bool) {
    // Quick check: any returns/breaks/continues or nested if/while/body?
    mut needs_scan := false
    for s : Expr in body.children {
        if s.node_type.is(NodeType.Return).or(s.node_type.is(NodeType.If)).or(s.node_type.is(NodeType.While)).or(s.node_type.is(NodeType.Body)).or(s.node_type.is(NodeType.Switch)) {
            needs_scan = true
            break
        }
        if return_only.not().and(s.node_type.is(NodeType.Break).or(s.node_type.is(NodeType.Continue))) {
            needs_scan = true
            break
        }
    }
    if needs_scan.not() { return }

    mut old := Vec(Expr).new()
    old.move_from(body.children)

    mut new_ch := Vec(Expr).new()
    for i in 0..old.len() {
        ref stmt : Expr = old[i]
        if is_compile_directive(stmt) { continue }
        if stmt.node_type.is(NodeType.If) {
            for c in 1..stmt.children.len() {
                insert_exit_deletes(stmt.children[c], live, return_only)
            }
        }
        if stmt.node_type.is(NodeType.While) {
            insert_exit_deletes(stmt.children[1], live, true)
        }
        if stmt.node_type.is(NodeType.Body) {
            insert_exit_deletes(stmt, live, return_only)
        }
        if stmt.node_type.is(NodeType.Switch) {
            for ci in 1..stmt.children.len() {
                if stmt.children[ci].node_type.is(NodeType.Case) {
                    cbi := stmt.children[ci].children.len() - 1
                    insert_exit_deletes(stmt.children[ci].children[cbi], live, return_only)
                }
            }
        }
        if stmt.node_type.is(NodeType.Return).or(return_only.not().and(stmt.node_type.is(NodeType.Break).or(stmt.node_type.is(NodeType.Continue)))) {
            for local : LocalInfo in live {
                if stmt.children.len() > 0 {
                    ref retval : Expr = stmt.children[0]
                    if expr_uses_var(retval, local.name).or(alias_used_in_stmts(old, local.name, retval)) {
                        continue
                    }
                }
                if type_to_name(local.type).len() > 0 {
                    del := make_delete_call(local.name, local.type, local.is_heap, local.is_heap, stmt)
                    if del.is_null().not() {
                        if stmt.node_type.is(NodeType.Return).and(stmt.children.len().gt(0)) {
                            stmt.add_child(own del)
                        } else {
                            new_ch.push(own del)
                        }
                    }
                } else if local.is_heap {
                    del := make_free_call(local.name, local.type, stmt)
                    if del.is_null().not() {
                        if stmt.node_type.is(NodeType.Return).and(stmt.children.len().gt(0)) {
                            stmt.add_child(own del)
                        } else {
                            new_ch.push(own del)
                        }
                    }
                }
            }
        }
        new_ch.push_take(old, i)
    }
    body.children.move_from(new_ch)
}

priv insert_nested_exit_deletes := proc(stmt: Expr, locals: Vec(LocalInfo), stmt_idx: USize) {
    if stmt.node_type.is(NodeType.If).not() {
        if stmt.node_type.is(NodeType.While).not() {
            if stmt.node_type.is(NodeType.Body).not() {
                if stmt.node_type.is(NodeType.Switch).not() { return }
            }
        }
    }
    mut live_vec := Vec(LocalInfo).new()
    for local : LocalInfo in locals {
        if local.skip_scope_delete { continue }
        // A transfer only consumes the local on paths that REACH it. An
        // exit edge inside a stmt strictly BEFORE the transfer stmt leaves
        // with the local still owned, so it must be freed there like any
        // non-transferred local (e.g. the parser's last_field: consumed by
        // a ctor in the final stmt, but earlier `return mcall` paths leaked
        // it). Only stand down when the transfer is at or before this stmt.
        // Own params whose transfer is their own destructor call (a delete
        // method's `if call_free { free(own self) }`) keep the full
        // stand-down: an extra delete double-frees -- the same exclusion
        // sink_conditional_transfer_deletes uses. Ordinary own params get
        // the same pre-transfer rule as locals; the old blanket param
        // stand-down leaked them on every exit edge before the transfer
        // (#302).
        if local.own_transfer >= 0 {
            if local.decl_index.lt(0).and(local.dtor_transfer) { continue }
            if local.own_transfer <= stmt_idx.to_i32() { continue }
        }
        if local.decl_index < stmt_idx.to_i32() {
            if local.last_use.gte(stmt_idx.to_i32()).or(local.last_use.eq(-1)) {
                live_vec.push(own local.clone())
            }
        }
    }
    if live_vec.len() > 0 {
        switch stmt.node_type {
        case NodeType.If:
            for c in 1..stmt.children.len() {
                insert_exit_deletes(stmt.children[c], live_vec, false)
            }
        case NodeType.While:
            insert_exit_deletes(stmt.children[1], live_vec, true)
        case NodeType.Switch:
            // #254: an un-desugared C-like switch. break/continue inside a
            // case exit the enclosing loop, so live outer locals need cleanup
            // on those edges -- pass return_only=false like the Body arm.
            for ci in 1..stmt.children.len() {
                if stmt.children[ci].node_type.is(NodeType.Case) {
                    cbi := stmt.children[ci].children.len() - 1
                    insert_exit_deletes(stmt.children[ci].children[cbi], live_vec, false)
                }
            }
        case:
            // NodeType.Body -- a plain block: a desugared for-in wrapper
            // (its decls + while), the lowered form of a switch/match
            // (infer_switch_stmt emits an if/elif chain inside a Body), or a
            // bare `{ }` scope. break/continue inside such a Body are NOT
            // captured here (only a nested While captures them, and that
            // While is recursed into with return_only=true on its own), so
            // those edges exit the enclosing loop and must free this scope's
            // live locals. Pass return_only=false so they get cleanup; a
            // for-in wrapper has no Body-level break/continue, so this is a
            // no-op for that shape.
            insert_exit_deletes(stmt, live_vec, false)
        }
    }
}

priv insert_exit_deletes_into_stmt := func(stmt: Expr, body_stmts: Vec(Expr), locals: Vec(LocalInfo), stmt_idx: USize, mut new_ch: Vec(Expr)) {
    if stmt.node_type.is(NodeType.Return).not() {
        if stmt.node_type.is(NodeType.Break).not() {
            if stmt.node_type.is(NodeType.Continue).not() { return }
        }
    }
    for local : LocalInfo in locals {
        if stmt.children.len() > 0 {
            ref retval : Expr = stmt.children[0]
            if expr_uses_var(retval, local.name).or(alias_used_in_stmts(body_stmts, local.name, retval)) {
                continue
            }
        }
        if local.skip_scope_delete { continue }
        // Same pre-transfer rule as insert_nested_exit_deletes: an exit at
        // a stmt strictly before the transfer stmt still owns the local.
        // Destructor-transferred own params keep the full stand-down (see
        // the dtor_transfer comment on LocalInfo); ordinary own params are
        // treated like locals -- the old blanket param stand-down leaked
        // them on early exits before the transfer (#302).
        if local.own_transfer >= 0 {
            if local.decl_index.lt(0).and(local.dtor_transfer) { continue }
            if local.own_transfer <= stmt_idx.to_i32() { continue }
        }
        if local.decl_index < stmt_idx.to_i32() {
            if local.last_use.gte(stmt_idx.to_i32()).or(local.last_use.eq(-1)) {
                if type_to_name(local.type).len() > 0 {
                    del := make_delete_call(local.name, local.type, local.is_heap, local.is_heap, stmt)
                    if del.is_null().not() { new_ch.push(own del) }
                } else if local.is_heap {
                    del := make_free_call(local.name, local.type, stmt)
                    if del.is_null().not() { new_ch.push(own del) }
                }
            }
        }
    }
}

priv insert_post_stmt_deletes := func(stmt: Expr, locals: Vec(LocalInfo), stmt_idx: USize, mut new_ch: Vec(Expr), scope: TypeScope, preceding: Vec(Expr)) {
    if stmt.node_type.is(NodeType.Return).or(stmt.node_type.is(NodeType.Break)).or(stmt.node_type.is(NodeType.Continue)) {
        return
    }
    for local : LocalInfo in locals {
        if local.skip_scope_delete { continue }
        if local.own_transfer >= 0 {
            // Ownership transferred via value-copy to a Shallow struct field
            // (e.g. `Decl(name = local, ...)` where Declaration.name has the
            // default Shallow ownership) leaves the local's heap wrapper
            // orphaned: the field gets a bit-copy of *local, the field's own
            // destructor frees the inner data, but nothing frees the wrapper.
            // Skipping the delete entirely (the previous behavior) leaks the
            // wrapper. Emit a raw `free(local)` after the transfer stmt to
            // release the wrapper without touching the inner data.
            //
            // This only fires when the transfer is a struct constructor with
            // the receiving field declared Shallow. Other transfer shapes
            // (`free(own X)`, `Type.delete(own X, ...)`, `field = X` where the
            // field is Own/Ref, passing X as `own` arg to a function that
            // takes ownership of the wrapper) already consume the wrapper, so
            // adding a `free` here would double-free.
            if local.is_heap.and(is_aggregate(local.type)) {
                if local.own_transfer == stmt_idx.to_i32() {
                    if type_to_name(local.type).len() > 0 {
                        // Decl(field = local) where the receiving Shallow
                        // field value-copies the inner struct: the field's
                        // own destructor frees the inner data, but nothing
                        // would free the local's wrapper. Emit a raw
                        // `free(local)` after the transfer stmt to release
                        // the wrapper without touching the inner data.
                        if transfer_is_shallow_field_value_copy(stmt, local.name, scope) {
                            free_call := make_free_call(local.name, local.type, stmt)
                            if free_call.is_null().not() {
                                new_ch.push(own free_call)
                            }
                        }
                    }
                }
            }
            continue
        }
        if local.last_use == stmt_idx.to_i32() {
            // FieldAssign with auto-cloned Ident RHS at the local's last use:
            // the clone allocates a deep copy, the field stores the copy, and
            // the local's contents would then be deleted by the normal
            // last_use destructor below -- a clone+delete roundtrip whose
            // intermediate allocation leaks its sub-pointers (Context_clone
            // via load_program, etc.). Replace clone(local) with bare local
            // so codegen emits a value-copy (`field = *local`), then free
            // only the heap wrapper. Only apply when stmt is the FieldAssign
            // itself (not a wrapping for/if -- last_use would point to the
            // outer stmt in that case, so this match implicitly excludes
            // loop/conditional bodies).
            if local.is_heap.and(is_aggregate(local.type)) {
                if stmt.node_type.is(NodeType.FieldAssign).and(stmt.children.len().gte(2)) {
                    ref fa_rhs : Expr = stmt.children[1]
                    if rhs_is_clone_fcall(fa_rhs).and(fa_rhs.children.len().gte(2)) {
                        ref clone_arg : Expr = fa_rhs.children[1]
                        switch clone_arg.node_type {
                        case NodeType.Ident(clone_arg_name):
                            if clone_arg_name.ident_name() == local.name {
                                mut bare := Expr.new(ident_node(local.name), fa_rhs.line, fa_rhs.col)
                                bare.set_expr_til_type(local.type.clone())
                                stmt.children[1] = bare
                                // A Shallow (value) field deref-copies the move
                                // source (`field = *local`), so the inner data
                                // transfers but the heap wrapper must still be
                                // freed. An Own (pointer) field instead moves the
                                // pointer itself into the field, which then owns
                                // the wrapper -- freeing it here would dangle the
                                // field (issue #256). Only emit the wrapper free
                                // for the value-field case.
                                if stmt.fa_own_type(scope).is(OwnType.Own).not() {
                                    free_call := make_free_call(local.name, local.type, stmt)
                                    if free_call.is_null().not() {
                                        new_ch.push(own free_call)
                                    }
                                }
                                continue
                            }
                        case:
                        }
                    }
                }
            }
            // Plain Assign with auto-cloned Ident RHS at the local's last
            // use: `lhs = local.clone()` where `local` is a dying owned
            // aggregate. The typer (infer_assign_stmt) wraps the Ident RHS
            // in .clone() for value semantics, but at the local's last use
            // the clone is a wasteful copy whose deep allocations leak --
            // the original `local` is dropped by the scope-end delete right
            // after. Replace `local.clone()` with bare `local` so codegen
            // emits a pointer move into lhs, and skip local's scope-end
            // delete: ownership transfers wholesale to the assign target
            // (whose own save_old_delete already freed lhs's prior value).
            if local.is_heap.and(is_aggregate(local.type)) {
                mut assign_saves_old := false
                switch stmt.node_type {
                case NodeType.Assign(adata): assign_saves_old = adata.save_old_delete
                case:
                }
                if stmt.node_type.is(NodeType.Assign).and(assign_saves_old).and(stmt.children.len().gte(1)) {
                    mut assign_target := ""
                    switch stmt.node_type {
                    case NodeType.Assign(adata2): assign_target = adata2.name
                    case:
                    }
                    ref assign_rhs : Expr = stmt.children[0]
                    // Guard against self-assign `e = e.clone()`: moving there
                    // would alias the just-deleted old value.
                    if assign_target.eq(local.name).not().and(rhs_is_clone_fcall(assign_rhs)).and(assign_rhs.children.len().gte(2)) {
                        ref clone_arg : Expr = assign_rhs.children[1]
                        switch clone_arg.node_type {
                        case NodeType.Ident(clone_arg_name):
                            // Issue #238: never move a clone-arg that is a
                            // hoisted view aliasing the assign target. The
                            // clone is what decouples `target = target.substr(
                            // ...).clone()` from target's own freed buffer;
                            // moving the view instead would alias the deleted
                            // old value.
                            if clone_arg_name.ident_name().eq(local.name)
                                .and(var_aliases_target(local.name, assign_target, preceding).not()) {
                                mut bare_ident := Expr.new(ident_node(local.name), assign_rhs.line, assign_rhs.col)
                                bare_ident.set_expr_til_type(local.type.clone())
                                stmt.children[0] = bare_ident
                                continue
                            }
                        case:
                        }
                    }
                }
            }
            if type_to_name(local.type).len() > 0 {
                del := make_delete_call(local.name, local.type, local.is_heap, local.is_heap, stmt)
                if del.is_null().not() { new_ch.push(own del) }
            } else if local.is_heap {
                del := make_free_call(local.name, local.type, stmt)
                if del.is_null().not() { new_ch.push(own del) }
            }
        }
        if local.last_use.eq(-1).and(local.decl_index.eq(stmt_idx.to_i32())) {
            if type_to_name(local.type).len() > 0 {
                del := make_delete_call(local.name, local.type, local.is_heap, local.is_heap, stmt)
                if del.is_null().not() { new_ch.push(own del) }
            } else if local.is_heap {
                del := make_free_call(local.name, local.type, stmt)
                if del.is_null().not() { new_ch.push(own del) }
            }
        }
    }
}

priv insert_assign_delete := func(mut stmt: Expr, locals: Vec(LocalInfo), mut new_ch: Vec(Expr)) {
    switch stmt.node_type {
    case NodeType.Assign(ad):
        vname := ad.name
        for local : LocalInfo in locals {
            if local.name.eq(vname).not() { continue }
            if is_aggregate(local.type) {
                if rhs_depends_on_var(stmt.children[0], vname, new_ch) {
                    ad.save_old_delete = true
                    stmt.set_expr_til_type(local.type.clone())
                } else {
                    if type_to_name(local.type).len() > 0 {
                        del := make_delete_call(local.name, local.type, local.is_heap, local.is_heap, stmt)
                        if del.is_null().not() { new_ch.push(own del) }
                    } else if local.is_heap {
                        del := make_free_call(local.name, local.type, stmt)
                        if del.is_null().not() { new_ch.push(own del) }
                    }
                }
            }
            break
        }
    case:
    }
}

priv promote_own_transferred_locals := func(ctx: Context, mut body: Expr, locals: Vec(LocalInfo)) {
    for local : LocalInfo in locals {
        if local.decl_index < 0 { continue }
        ref stmt : Expr = body.children[local.decl_index.to_usize()]
        if stmt.node_type.is(NodeType.Decl).not() { continue }
        // Skip LiteralStr-RHS decls (temp or user-visible): the builder
        // emits these as stack-allocated compound-literal Str values, so
        // heap-promotion would mismatch the generated delete (call_free=true
        // would free a stack pointer). Keep them Shallow so make_delete_call
        // generates call_free=false.
        if stmt.children.len() > 0 {
            ref rhs0 : Expr = stmt.children[0]
            if rhs0.node_type.is_literal_str() { continue }
            // Same shape, payload-less enum case: the builder emits a
            // stack value via the is_pod_enum_clone_call shortcut, so
            // heap-promotion here would mismatch the destructor (the
            // delete-arg malloc-copy wrapper that emit_as_ptr emits for
            // own + stack_local). Keep is_heap=false so make_delete_call
            // uses call_free=false / arg_is_own=false and the destructor
            // becomes a true no-op (`Color_delete(&c, &(Bool){0});`).
            if is_pod_enum_clone_wrap(rhs0, ctx.scope) { continue }
        }
        switch stmt.node_type {
        case NodeType.Decl(dd):
        if dd.own_type.is(OwnType.Ref) { continue }
        // Use is_aggregate, not raw is(Type.Struct): keeps user structs/
        // enums (which heap-promote) distinct from everything else.
        is_struct := is_aggregate(local.type)
        if local.own_transfer.lt(0).and(is_struct.not()) { continue }
        // Skip heap-promotion if the only "use" is the function's
        // shallow return: the value-copy at return is the transfer,
        // and a heap wrapper just leaks (the codegen does
        // ~return DEREF(rv)~ without freeing rv). Keeping the local
        // Shallow lets the codegen use a stack value and value-copy
        // out cleanly.
        if ctx.typer_in_shallow_return.and(local.own_transfer.lt(0)).and(is_struct) {
            if local.last_use >= 0 {
                ref last_stmt : Expr = body.children[local.last_use.to_usize()]
                if last_stmt.node_type.is(NodeType.Return) {
                    if last_stmt.children.len() > 0 {
                        switch last_stmt.children[0].node_type {
                        case NodeType.Ident(rname):
                            if rname.ident_name() == local.name { continue }
                        case:
                        }
                    }
                }
            }
        }
        dd.own_type = OwnType.Own
        local.is_heap = true
        case:
        }
    }
}

// Asap entry point. The typer's scope-management sites call this
// once per body after the per-body in-place pass settles, just
// before they tear down the per-body scope. Issue #204 step 3b
// tracks lifting the per-site calls into a single garbager_destroy(ctx)
// walk in prepare_program once #158's per-body scope cache is in
// the Context.
priv stmt_is_conditional_container := func(stmt: Expr) returns Bool {
    return stmt.node_type.is(NodeType.If)
        .or(stmt.node_type.is(NodeType.While))
        .or(stmt.node_type.is(NodeType.Switch))
        .or(stmt.node_type.is(NodeType.Body))
}

priv add_delete_to_branch := func(mut branch: Expr, local: LocalInfo, src: Expr) returns Bool {
    del := make_delete_call(local.name, local.type, local.is_heap, local.is_heap, src)
    if del.is_null() { return false }
    branch.add_child(own del)
    return true
}

priv sink_nontransfer_paths := func(mut node: Expr, local: LocalInfo, scope: TypeScope, ctx: Context) returns Bool {
    if node.is_null() { return false }
    if node.node_type.is(NodeType.If) {
        if node.children.len() < 2 { return false }

        ref mut then_body : Expr = node.children[1]
        mut then_done := sink_nontransfer_paths(then_body, local, scope, ctx)
        if then_done.not() { then_done = add_delete_to_branch(then_body, local, node) }

        mut else_done := false
        if node.children.len() > 2 {
            ref mut else_body : Expr = node.children[2]
            else_done = sink_nontransfer_paths(else_body, local, scope, ctx)
            if else_done.not() { else_done = add_delete_to_branch(else_body, local, node) }
        } else {
            mut else_body_new := Expr.new(NodeType.Body, node.line, node.col)
            else_done = add_delete_to_branch(else_body_new, local, node)
            if else_done { node.add_child(own else_body_new) }
        }

        return then_done.and(else_done)
    }

    if node.node_type.is(NodeType.Body).not() { return false }
    for mut child : Expr in node.children {
        if is_compile_directive(child) { continue }
        if child.node_type.is(NodeType.If).and(expr_transfers_own(child, local.name, scope, ctx)) {
            if sink_nontransfer_paths(child, local, scope, ctx) { return true }
            continue
        }
        if stmt_is_conditional_container(child).not() {
            if expr_transfers_own(child, local.name, scope, ctx) { return true }
        }
    }
    return false
}

// asap stands down on any `own` transfer (own_transfer >= 0). When the
// transfer sits inside one branch of an `if`, the other path never frees the
// local -- a leak (the conditional-transfer footgun). Fix: add the local's
// delete to every branch leaf that does NOT transfer it. This only ever ADDS a
// delete on a path where the local is still owned, so it cannot double-free;
// nested `else if` trees are handled recursively so a transfer in an inner
// branch is not followed by an outer-branch delete.
//
// Own params are covered too, EXCEPT when the conditional transfer is the
// param's own destructor call (dtor_transfer): a delete method's `self` does
// `if call_free { free(own self) }` after its field deletes already ran, so
// sinking a delete into the else branch there re-frees the fields (recursive
// delete -> bad-free). The old rule excluded ALL params, which leaked every
// ordinary conditionally-transferred own param (#302: 30 bytes per call on
// the non-transfer path of `if flag { return consume(own s) }`).
//
// Str is handled like any other owned local here: Str.delete knows whether its
// buffer is owned, literal, or a view. The sink must be path-sensitive instead
// of type-sensitive.
priv sink_conditional_transfer_deletes := func(mut body: Expr, locals: Vec(LocalInfo), scope: TypeScope, ctx: Context) {
    for local : LocalInfo in locals {
        if local.skip_scope_delete { continue }
        if local.decl_index.lt(0).and(local.dtor_transfer) { continue }
        if local.own_transfer < 0 { continue }
        if local.is_heap.not() { continue }
        if is_aggregate(local.type).not() { continue }
        if type_to_name(local.type).len() == 0 { continue }
        if local.last_use > local.own_transfer { continue }
        if local.own_transfer >= body.children.len().to_i32() { continue }
        ref tstmt : Expr = body.children[local.own_transfer.to_usize()]
        if tstmt.node_type.is(NodeType.If).not() { continue }
        sink_nontransfer_paths(tstmt, local, scope, ctx)
    }
}

priv insert_free_calls := proc(ctx: Context, mut body: Expr, mut scope: TypeScope, scope_exit: I32) returns Bool {
    if scope_exit == 0 { return false }
    is_program_scope := scope.parent.is_null()

    mut locals_vec := Vec(LocalInfo).new()
    collect_scope_locals(ctx, body, scope, is_program_scope, locals_vec)
    if locals_vec.len() == 0 { return false }

    extend_ref_local_lifetimes(body, locals_vec, scope)
    check_use_after_own_transfer(body, locals_vec, scope, ctx)
    promote_own_transferred_locals(ctx, body, locals_vec)
    sink_conditional_transfer_deletes(body, locals_vec, scope, ctx)
    // After the own-transfer check (so an over-eager taint can't spuriously
    // flag use-after-transfer): defer a local's auto-delete past any later
    // statement that reads a hoisted view aliasing its buffer. See #250.
    extend_hoist_view_lifetimes(body, locals_vec)

    // #302 stage 0: decision audit. The analysis above has settled every
    // per-binding decision; the dump itself runs after the insertion loop
    // so the site walk sees the final body. Cost when disabled: one env
    // read per body.
    audit_filter := gc_audit_filter()
    audit := audit_filter.len().gt(0).and(ctx.path.contains(audit_filter))

    mut old := Vec(Expr).new()
    old.move_from(body.children)

    mut new_ch := Vec(Expr).new()
    for i in 0..old.len() {
        ref stmt : Expr = old[i]
        if is_compile_directive(stmt) { continue }
        insert_exit_deletes_into_stmt(stmt, old, locals_vec, i, new_ch)
        insert_nested_exit_deletes(stmt, locals_vec, i)
        insert_assign_delete(stmt, locals_vec, new_ch)
        mut post_deletes := Vec(Expr).new()
        insert_post_stmt_deletes(stmt, locals_vec, i, post_deletes, scope, new_ch)
        new_ch.push_take(old, i)
        new_ch.append(own post_deletes)
    }

    body.children.move_from(new_ch)
    if audit { gc_audit_dump(ctx, body, locals_vec) }
    return true
}

// Per-body asap entry. Called from the typer's scope-management sites
// (infer_func_def_expr, infer_if_stmt, infer_while_stmt, the Body/Catch
// arms of infer_body_stmt) after infer_body has settled and before
// TypeScope.delete. Returns true iff body.children changed, so the
// caller can decide whether to re-run reregister_scope_defs.
// See issue #204.
garbager_destroy_body := proc(ctx: Context, mut body: Expr, mut scope: TypeScope) returns Bool {
    return insert_free_calls(ctx, body, scope, 1)
}

// Phase entry point. Runs the asap-destruction pass on every
// imported file's program body using the global TypeScope
// (ctx.scope). Called from the tail of init_and_type_program
// (loader.til) so both prepare_program (interpret/translate/
// build/run/test/install paths) and cmd_doc see the post-asap
// program AST.
//
// Sub-body asap (function bodies, if/while/block/catch scopes)
// still runs inline from the typer's scope-management sites
// because per-body scopes are stack-locals freed by
// TypeScope.delete once infer_body returns. Issue #204 step 3b
// covers lifting the inline calls into this proc; the blocker is
// per-body scope ownership, which needs either a scope cache on
// Context (#158) or an on-the-fly scope rebuild in garbager.
garbager_destroy := proc(mut ctx: Context) {
    saved_path := ctx.path.clone()
    saved_in_main := ctx.typer_in_main_func
    saved_in_shallow := ctx.typer_in_shallow_return
    ctx.typer_in_main_func = false
    ctx.typer_in_shallow_return = false
    for path, iu in ctx.imported {
        ctx.path = path.clone()
        insert_free_calls(ctx, iu.ast, ctx.scope, 1)
    }
    ctx.path = saved_path
    ctx.typer_in_main_func = saved_in_main
    ctx.typer_in_shallow_return = saved_in_shallow
}
