mode lib
import("context")

// Desugaring phase. Lowers the high-level constructs that the later
// phases (garbager / constfolder / scavenger / interpreter / builder)
// do not handle into plain til: loops to while, optional/named/default
// args, throw/catch, switch/match, collection/variadic/kwargs literals,
// and lambda lifting -- anything "not supported by later phases".
//
// Split out of typer.til. These passes are type-directed, so they run
// interleaved with type inference, driven by the typer's body walk
// (infer_body / infer_body_stmt / infer_func_def_expr). Like
// garbager.til this module imports only "context" and reaches typer and
// desugarer helpers through the merged program scope -- no import of
// typer is needed (see doc/pipeline.org).

desugar_fcall_args_for_fdef := proc(mut e: Expr, display_name: Str, fdef_data: FunctionDef, ctx: Context) returns Bool {
    nparam := fdef_data.params.len()
    vi := fdef_data.variadic_index
    kwi := fdef_data.kwargs_index
    mut fixed_count : USize = nparam
    if vi >= 0 {
        fixed_count = vi.to_usize()
    }
    mut va_args := Vec(Expr).new()
    mut kw_args := Vec(Expr).new()
    // new_args is filled with exactly nparam placeholders below; pre-size
    // it so that fill does zero reallocs (Vec grow-realloc churn).
    mut new_args := Vec(Expr).with_capacity(nparam)
    for _ in 0..nparam {
        new_args.push(own Expr.new(NodeType.NoDefaultArg, e.line, e.col))
    }
    mut pos_idx : USize = 0
    mut seen_named := false
    for i in 1..e.children.len() {
        ref arg : Expr = e.children[i]
        switch arg.node_type {
        case NodeType.NamedArg(aname):
            seen_named = true
            mut slot : I32 = -1
            for j in 0..nparam {
                if j.to_i32() == vi { continue }
                if j.to_i32() == kwi { continue }
                ref param : Declaration = fdef_data.params[j]
                if param.name == aname {
                    slot = j.to_i32()
                    break
                }
            }
            if slot < 0 {
                if kwi >= 0 {
                    kw_args.push(own arg.clone())
                } else {
                    if display_name.len() > 0 {
                        arg.type_error(format("'", display_name, "' has no parameter '", aname, "'"), ctx)
                    } else {
                        arg.type_error(format("no parameter '", aname, "'"), ctx)
                    }
                }
            } else {
                ref slot_arg : Expr = new_args[slot.to_usize()]
                if slot_arg.node_type.is(NodeType.NoDefaultArg).not() {
                    arg.type_error(format("duplicate argument for parameter '", aname, "'"), ctx)
                } else {
                    new_args[slot.to_usize()] = arg.children[0].clone()
                }
            }
        case:
            if seen_named {
                arg.type_error("positional argument after named argument", ctx)
            }
            if vi >= 0 {
                if pos_idx >= fixed_count {
                    va_args.push(own arg.clone())
                } else if pos_idx < nparam {
                    new_args[pos_idx] = arg.clone()
                }
            } else if pos_idx < nparam {
                new_args[pos_idx] = arg.clone()
            }
            pos_idx++
        }
    }
    for i in 0..nparam {
        if i.to_i32() == vi { continue }
        if i.to_i32() == kwi { continue }
        ref slot_arg : Expr = new_args[i]
        if slot_arg.node_type.is(NodeType.NoDefaultArg) {
            ref param : Declaration = fdef_data.params[i]
            if param.default_value.node_type.is(NodeType.NoDefaultArg).not() {
                new_args[i] = resolve_default_value(param.default_value, e, ctx)
            } else {
                e.type_error(format("missing argument for parameter '", param.name, "'"), ctx)
            }
        }
    }
    mut max_pos : USize = nparam
    if kwi >= 0 {
        max_pos--
    }
    if vi < 0 {
        if pos_idx > max_pos {
            e.type_error(format("too many arguments: expected ", nparam.to_str(), ", got ", pos_idx.to_str()), ctx)
        }
    }
    // Rebuilt call args: callee + (per-param) one arg, or the expanded
    // variadic / kwargs runs. Over-estimate the capacity (never under) so
    // the fill below reallocs zero times on the hot per-call path.
    mut new_ch := Vec(Expr).with_capacity(nparam + va_args.len() + kw_args.len() + 1)
    ref callee : Expr = e.children[0]
    new_ch.push(own callee.clone())
    for i in 0..nparam {
        if i.to_i32() == vi {
            va_count := va_args.len()
            for vai in 0..va_count {
                new_ch.push_take(va_args, vai)
            }
        } else if i.to_i32() == kwi {
            kw_count := kw_args.len()
            for kwi2 in 0..kw_count {
                new_ch.push_take(kw_args, kwi2)
            }
        } else {
            ref slot_arg : Expr = new_args[i]
            if slot_arg.node_type.is(NodeType.NoDefaultArg) {
                // Missing-argument case: diagnostic already emitted above.
                return false
            } else {
                new_ch.push_take(new_args, i)
            }
        }
    }
    e.children.move_from(new_ch)
    return true
}

desugar_user_func_fcall_args := proc(scope: TypeScope, mut e: Expr, name: Str, callee_bind: TypeBinding, ctx: Context) {
    ref fdef : Expr = scope.lookup_func(callee_bind.name)
    switch fdef.node_type {
    case NodeType.FuncDef(fdef_data):
        _ : Bool = desugar_fcall_args_for_fdef(e, name, fdef_data, ctx)
    case:
        UNREACHABLE()
    }
}

priv typer_is_lambda_target := func(e: Expr) returns Bool {
    expect(e.is_null().not(), "e is null")
    if e.node_type.is(NodeType.FuncDef).not() { return false }
    if e.children.len() == 0 { return false }
    // Issue #54: a capturing lambda is NOT lifted to top level -- a lifted
    // body could not resolve its captured outer locals. It stays inline so
    // its func scope chains to the enclosing scope where the captures live.
    switch e.node_type {
    case NodeType.FuncDef(litfd):
        if litfd.captures.len() > 0 { return false }
    case:
    }
    return true
}

priv typer_lift_one_default_value := proc(mut dd: Declaration, mut top_level: Vec(Expr), mut counter: I64) returns I64 {
    if dd.default_value.is_null() { return counter }
    if typer_is_lambda_target(dd.default_value) {
        counter = typer_lift_lambdas_in_expr(dd.default_value, top_level, counter)
        lname := format("_lambda_", counter.to_str())
        counter++
        mut decl := Expr.new(NodeType.Decl(Declaration(name = lname.clone(), is_priv = true)), dd.default_value.line, dd.default_value.col)
        decl.add_child(own dd.default_value.clone())
        top_level.push(own decl)
        mut ident := Expr.new(ident_node(lname), dd.default_value.line, dd.default_value.col)
        ident.set_til_type(dd.default_value.til_type())
        dd.default_value = ident
    } else {
        counter = typer_lift_lambdas_in_expr(dd.default_value, top_level, counter)
    }
    return counter
}

priv typer_lift_lambdas_in_expr := proc(mut e: Expr, mut top_level: Vec(Expr), mut counter: I64) returns I64 {
    expect(e.is_null().not(), "e is null")
    // Issue #57: don't descend into template macro bodies -- a func literal
    // inside `macro(T: Type) returns FuncDef { return func(x: T) ... }` is
    // a template that initer's pre-pass substitutes and lifts at each call
    // site, not a lambda to extract here (the type-param references would
    // immediately fail under the lifted lambda's normal-typing path).
    switch e.node_type {
    case NodeType.FuncDef(lift_fd_check):
        if lift_fd_check.captures.len().gt(0).and(lift_fd_check.closure_name.len().eq(0)) {
            lift_fd_check.closure_name = format("closure_", counter.to_str())
            counter++
        }
        if lift_fd_check.func_type.is(FuncType.Macro) {
            mtg_ret_lift := lift_fd_check.return_type.eq("StructDef")
                .or(lift_fd_check.return_type.eq("EnumDef"))
                .or(lift_fd_check.return_type.eq("FuncDef"))
                .or(lift_fd_check.return_type.eq("FunctionDef"))
            mut is_template_lift := mtg_ret_lift
            if is_template_lift.not() {
                for tmp_param_lift : Declaration in lift_fd_check.params {
                    if tmp_param_lift.explicit_type == "Type" {
                        is_template_lift = true
                    }
                }
            }
            if is_template_lift { return counter }
        }
    case:
    }
    // Visit default_value slots that live inside Declaration metadata.
    // Struct field defaults and FuncDef param defaults can carry a
    // lambda literal (`mut on_click : BinaryOp = func(...){...}`) the
    // same way an FCall arg can.  Namespace member default_values are
    // NOT lambda positions -- their FuncDef IS the named method's body,
    // so just recurse into it without lifting the outer FuncDef.
    switch e.node_type {
    case NodeType.FuncDef(fd):
        for mut pd : Declaration in fd.params {
            counter = typer_lift_one_default_value(pd, top_level, counter)
        }
    case NodeType.StructDef(sdd):
        for mut sf : Declaration in sdd.fields {
            counter = typer_lift_one_default_value(sf, top_level, counter)
        }
        for mut nd : Declaration in sdd.ns_decls {
            if nd.default_value.is_null().not() {
                counter = typer_lift_lambdas_in_expr(nd.default_value, top_level, counter)
            }
        }
    case NodeType.EnumDef(edd):
        for mut nd : Declaration in edd.ns_decls {
            if nd.default_value.is_null().not() {
                counter = typer_lift_lambdas_in_expr(nd.default_value, top_level, counter)
            }
        }
    case:
    }
    for i in 0..e.children.len() {
        ref mut c : Expr = e.children[i]
        if c.is_null() { continue }
        // The rhs slot of a NodeType.Decl is a named function definition,
        // not a lambda. Skip lifting; just recurse to find any lambdas
        // nested INSIDE that named function's body.
        is_decl_rhs := e.node_type.is(NodeType.Decl).and(i.eq(0))
        if typer_is_lambda_target(c).and(is_decl_rhs.not()) {
            counter = typer_lift_lambdas_in_expr(c, top_level, counter)
            lname := format("_lambda_", counter.to_str())
            counter++
            mut decl := Expr.new(NodeType.Decl(Declaration(name = lname.clone(), is_priv = true)), c.line, c.col)
            decl.add_child(own c.clone())
            top_level.push(own decl)
            mut ident := Expr.new(ident_node(lname), c.line, c.col)
            e.children[i] = ident
        } else {
            counter = typer_lift_lambdas_in_expr(c, top_level, counter)
        }
    }
    return counter
}

// Pre-register a lifted lambda decl in scope so references to its
// synthetic _lambda_<N> name resolve even though the typer's main walk
// is in source order and may type a referencing function body before
// it reaches the lifted decl itself.
priv typer_register_lifted_lambda := func(mut scope: TypeScope, lifted: Expr, ctx: Context) {
    switch lifted.node_type {
    case NodeType.Decl(sdecl):
        ref rhs : Expr = lifted.children[0]
        switch rhs.node_type {
        case NodeType.FuncDef:
            scope.set(sdecl.name, Type.None, false, ctx.path, lifted.line, lifted.col, false, OwnType.Shallow)
            scope.set_func_def(sdecl.name, lifted.children[0])
            ref mut fb : TypeBinding = scope.get_binding(sdecl.name)
            fb.is_func_decl = true
            fb.is_priv = sdecl.is_priv
        case:
        }
    case:
    }
}

typer_lift_lambdas := proc(mut scope: TypeScope, mut prog: Expr, ctx: Context) {
    expect(prog.is_null().not(), "prog is null")
    if prog.node_type.is(NodeType.Body).not() { return }
    mut top_level := Vec(Expr).new()
    mut ctr : I64 = 0
    ctr = typer_lift_lambdas_in_expr(prog, top_level, ctr)
    for l : Expr in top_level {
        // Push the lifted decl into the AST FIRST, then register the
        // scope's func_def pointer against the PUSHED copy. set_func_def
        // stores a raw pointer (write_ptr) into the Expr and expects it
        // to live in the AST; registering against `l` instead would
        // dangle as soon as the `top_level` Vec is freed on return,
        // causing a use-after-free when func_def_type later reads it.
        prog.children.push(own l.clone())
        ref pushed : Expr = prog.children[prog.children.len() - 1]
        typer_register_lifted_lambda(scope, pushed, ctx)
    }
}
// #282: seed the throws resolver with the in-scope type of every Ident in
// `e` (the live typer scope is the authoritative source at infer time).
// resolve_value_type checks ctx.lowering_param_types before scanning a body
// AST, so this lets find_callee_throws_key resolve a guard bang's receiver
// (a local or param) without a function-body scan. Entries are correct local
// types; they are harmless to leave (re-seeded fresh before each guard hoist).
priv seed_guard_receiver_types := proc(mut ctx: Context, e: Expr, scope: TypeScope) {
    switch e.node_type {
    case NodeType.Ident(idn):
        ref nm : Str = idn.ident_name()
        if nm.len().gt(0).and(ctx.lowering_param_types.has(nm).not()) {
            ref b : TypeBinding = scope.get_binding(nm)
            if b.is_null().not() {
                tn := til_type_name(b.type)
                if tn.len() > 0 { ctx.lowering_param_types.set(nm, own tn) }
            }
        }
    case:
    }
    for c : Expr in e.children {
        seed_guard_receiver_types(ctx, c, scope)
    }
}

// #282: lower throwing (bang) calls in a case guard. The guard is
// guard_if.children[0]; hoist_walk_consolidated pulls each bang FCall out into
// a `_bang_ret_<n> := <call>?` temp (with injected _err_kind/_err_<T> args)
// plus a panic-on-throw check, replacing the bang with the temp Ident. Those
// pre-stmts are appended to `dest` (the pattern-gated case body) BEFORE the
// guard `if`, so the call runs only when the pattern matches. The function
// already owns the _err_kind/_err_<T> slots (declared pre-infer via the guard
// discovery walk), so the throwaway types_to_declare/seen here are discarded.
lower_guard_bang_calls := proc(scope: TypeScope, mut guard_if: Expr, mut dest: Vec(Expr), resolve_body: Expr, mut ctx: Context) {
    seed_guard_receiver_types(ctx, guard_if.children[0], scope)
    mut pre := Vec(Expr).new()
    mut tmp_types := Vec(Str).new()
    mut tmp_seen := Vec(Str).new()
    hoist_walk_consolidated(ctx, guard_if, 0, resolve_body, pre, tmp_types, tmp_seen)
    npre := pre.len()
    for pi in 0..npre {
        dest.push_take(pre, pi)
    }
}

// #282: true when `e` references the throw-state slot `_err_kind`. Used by
// infer_switch_stmt to tell whether a desugared case can leave _err_kind set
// (a `?` throw, or a bang's injected call) so that the following independent
// case `if`s -- which the desugar builds AFTER the pre-infer throw pass, and
// which would otherwise run regardless -- get gated on `_err_kind == 0`.
subtree_references_name := func(e: Expr, name: Str) returns Bool {
    switch e.node_type {
    case NodeType.Ident(idn):
        if idn.ident_name() == name { return true }
    case:
    }
    for c : Expr in e.children {
        if subtree_references_name(c, name) { return true }
    }
    return false
}

priv guess_expr_type_name := func(e: Expr) returns Str {
    switch e.node_type {
    case NodeType.Literal(Literal.Str): return "Str"
    case NodeType.Literal(Literal.Num): return "I64"
    case NodeType.Literal(Literal.Bool): return "Bool"
    case NodeType.FieldAccess:
        if e.children.len() > 0 {
            switch e.children[0].node_type {
            case NodeType.Ident(type_name): return Str.clone(type_name.ident_name())
            case:
            }
        }
    case:
    }
    return ""
}

// Recursively walk e looking for a Decl(name=var_name) whose RHS
// looks like a constructor or typed literal we can infer from
// syntactically. Returns "" if not found. Best-effort pre-typer
// lookup so `throw my_var` can find the type of my_var from its
// declaration. Read-only; safe to call before destructive lowering.
priv guess_local_type := func(e: Expr, var_name: Str) returns Str {
    if e.node_type.is(NodeType.Decl) {
        switch e.node_type {
        case NodeType.Decl(dn):
            if dn.name == var_name {
                if dn.explicit_type.len() > 0 { return dn.explicit_type.clone() }
                if e.children.len() > 0 {
                    ref rhs : Expr = e.children[0]
                    switch rhs.node_type {
                    case NodeType.FCall:
                        if rhs.children.len() > 0 {
                            switch rhs.children[0].node_type {
                            case NodeType.Ident(rhsn):
                                if rhsn.name.eq("array").and(rhs.children.len().gte(2)) {
                                    et := array_vec_elem_type_name(rhs)
                                    if et.len() > 0 { return format("Array__", et) }
                                }
                                if rhsn.name.eq("vec").and(rhs.children.len().gte(2)) {
                                    et := array_vec_elem_type_name(rhs)
                                    if et.len() > 0 { return format("Vec__", et) }
                                }
                                return rhsn.name.clone()
                            case NodeType.FieldAccess(_rhsfa):
                                if rhs.children[0].children.len() > 0 {
                                    switch rhs.children[0].children[0].node_type {
                                    case NodeType.Ident(rhsty): return Str.clone(rhsty.ident_name())
                                    case:
                                    }
                                }
                            case:
                            }
                        }
                    case NodeType.Literal(Literal.Str): return "Str"
                    case NodeType.Literal(Literal.Num): return "I64"
                    case NodeType.Literal(Literal.MapLit):
                        if rhs.children.len() >= 2 {
                            key_type := guess_expr_type_name(rhs.children[0])
                            val_type := guess_expr_type_name(rhs.children[1])
                            if key_type.len().gt(0).and(val_type.len().gt(0)) {
                                return format("Map__", key_type, "_", val_type)
                            }
                        }
                    case:
                    }
                }
            }
        case:
        }
    }
    for c : Expr in e.children {
        guess := guess_local_type(c, var_name)
        if guess.len() > 0 { return guess }
    }
    return ""
}

priv guess_prior_local_type_in_vec := func(stmts: Vec(Expr), upto: USize, var_name: Str) returns Str {
    if stmts.len() == 0 { return "" }
    mut limit := upto
    if limit >= stmts.len() {
        limit = stmts.len() - 1
    }
    mut i : USize = 0
    while i <= limit {
        ref stmt : Expr = stmts[i]
        guess := guess_local_type(stmt, var_name)
        if guess.len() > 0 { return guess }
        i++
    }
    return ""
}

priv seed_prior_local_types := func(mut ctx: Context, stmts: Vec(Expr), upto: USize) {
    if stmts.len() == 0 { return }
    mut limit := upto
    if limit >= stmts.len() {
        limit = stmts.len() - 1
    }
    mut i : USize = 0
    while i <= limit {
        ref stmt : Expr = stmts[i]
        switch stmt.node_type {
        case NodeType.Decl(dd):
            mut tn := dd.explicit_type.clone()
            if tn.len().eq(0).and(stmt.children.len().gt(0)) {
                ref rhs : Expr = stmt.children[0]
                switch rhs.node_type {
                case NodeType.FCall:
                    if rhs.children.len() > 0 {
                        switch rhs.children[0].node_type {
                        case NodeType.Ident(rhsn):
                            if rhsn.name.eq("array").and(rhs.children.len().gte(2)) {
                                et := array_vec_elem_type_name(rhs)
                                if et.len() > 0 { tn = format("Array__", et) }
                            } else if rhsn.name.eq("vec").and(rhs.children.len().gte(2)) {
                                et := array_vec_elem_type_name(rhs)
                                if et.len() > 0 { tn = format("Vec__", et) }
                            } else {
                                ref fdef_expr : Expr = ctx.scope.lookup_func(rhsn.name)
                                if fdef_expr.is_null().not() {
                                    switch fdef_expr.node_type {
                                    case NodeType.FuncDef(fd): tn = fd.return_type.clone()
                                    case:
                                    }
                                }
                            }
                        case NodeType.FieldAccess(fa):
                            if rhs.children[0].children.len() > 0 {
                                owner := resolve_value_type(ctx, rhs.children[0].children[0], stmt)
                                if owner.len() > 0 {
                                    ref sdef : Expr = ctx.scope.get_struct(owner)
                                    if sdef.is_null().not() {
                                        ref mdef : Expr = find_namespace_func(sdef, fa.field_access_name(), ctx.scope)
                                        if mdef.is_null().not() {
                                            switch mdef.node_type {
                                            case NodeType.FuncDef(fd): tn = fd.return_type.clone()
                                            case:
                                            }
                                        }
                                    }
                                }
                            }
                        case:
                        }
                    }
                case NodeType.Literal(Literal.Str): tn = "Str"
                case NodeType.Literal(Literal.Num): tn = "I64"
                case NodeType.Literal(Literal.MapLit):
                    if rhs.children.len() >= 2 {
                        key_type := guess_expr_type_name(rhs.children[0])
                        val_type := guess_expr_type_name(rhs.children[1])
                        if key_type.len().gt(0).and(val_type.len().gt(0)) {
                            tn = format("Map__", key_type, "_", val_type)
                        }
                    }
                case:
                }
            }
            if tn.len() == 0 {
                i++
                continue
            }
            ctx.lowering_param_types.set(dd.name, own tn)
        case:
        }
        i++
    }
}

priv collect_throw_ident_names := proc(e: Expr, mut names: Set(Str)) {
    if e.node_type.is(NodeType.Throw).and(e.children.len().eq(1)) {
        switch e.children[0].node_type {
        case NodeType.Ident(idn):
            names.add(own idn.name.clone())
        case:
        }
    }
    for c : Expr in e.children {
        collect_throw_ident_names(c, names)
    }
}

priv annotate_throw_ident_expr_types := proc(mut e: Expr, root_body: Expr) {
    if e.node_type.is(NodeType.Throw).and(e.children.len().eq(1)) {
        switch e.children[0].node_type {
        case NodeType.Ident(idn):
            tn := guess_local_type(root_body, idn.name)
            if tn.len() > 0 {
                e.children[0].set_til_type(Type.Custom(tn.clone()))
            }
        case:
        }
    }
    for c : Expr in e.children {
        annotate_throw_ident_expr_types(c, root_body)
    }
}

priv has_prior_throw_type := proc(e: Expr, root_body: Expr, type_name: Str, before_line: U32) returns Bool {
    if e.line.lt(before_line).and(e.node_type.is(NodeType.Throw)).and(e.children.len().eq(1)) {
        mut thrown_name := type_to_name(e.til_type())
        if thrown_name.len() == 0 {
            switch e.children[0].node_type {
            case NodeType.Ident(idn):
                thrown_name = guess_local_type(root_body, idn.name)
            case NodeType.FCall:
                if e.children[0].children.len() > 0 {
                    switch e.children[0].children[0].node_type {
                    case NodeType.Ident(name): thrown_name = name.name.clone()
                    case:
                    }
                }
            case NodeType.Literal(Literal.Str):
                thrown_name = "Str"
            case NodeType.Literal(Literal.Num):
                thrown_name = "I64"
            case:
            }
        }
        if thrown_name == type_name { return true }
    }
    for c : Expr in e.children {
        if has_prior_throw_type(c, root_body, type_name, before_line) { return true }
    }
    return false
}

priv subtree_has_throw_type := proc(e: Expr, root_body: Expr, type_name: Str) returns Bool {
    if e.node_type.is(NodeType.Throw).and(e.children.len().eq(1)) {
        mut thrown_name := ""
        switch e.children[0].node_type {
        case NodeType.Ident(idn):
            thrown_name = guess_local_type(root_body, idn.name)
        case NodeType.FCall:
            if e.children[0].children.len() > 0 {
                switch e.children[0].children[0].node_type {
                case NodeType.Ident(name): thrown_name = name.name.clone()
                case:
                }
            }
        case NodeType.Literal(Literal.Str):
            thrown_name = "Str"
        case NodeType.Literal(Literal.Num):
            thrown_name = "I64"
        case:
        }
        if thrown_name == type_name { return true }
    }
    for c : Expr in e.children {
        if subtree_has_throw_type(c, root_body, type_name) { return true }
    }
    return false
}

priv has_prior_throw_type_in_vec := proc(stmts: Vec(Expr), root_body: Expr, upto: USize, type_name: Str) returns Bool {
    if stmts.len().eq(0).or(upto.eq(0)) { return false }
    mut limit := upto
    if limit > stmts.len() { limit = stmts.len() }
    mut i : USize = 0
    while i < limit {
        ref stmt : Expr = stmts[i]
        if subtree_has_throw_type(stmt, root_body, type_name) { return true }
        i++
    }
    return false
}

priv throw_type_name_for_with_body := func(e: Expr, body: Expr) returns Str {
    switch e.node_type {
    case NodeType.Literal(Literal.Str): return "Str"
    case NodeType.Literal(Literal.Num): return "I64"
    case NodeType.FCall:
        if e.children.len() == 0 { return "" }
        switch e.children[0].node_type {
        case NodeType.Ident(name): return name.name.clone()
        case NodeType.FieldAccess(_fa_name):
            if e.children[0].children.len() == 0 { return "" }
            switch e.children[0].children[0].node_type {
            case NodeType.Ident(type_name): return Str.clone(type_name.ident_name())
            case: return ""
            }
        case: return ""
        }
    case NodeType.Ident(idn): return guess_local_type(body, idn.name)
    case: return ""
    }
}


priv subtree_has_throw_catch := func(e: Expr) returns Bool {
    if e.node_type.is(NodeType.Throw).or(e.node_type.is(NodeType.Catch)) {
        return true
    }
    if e.node_type.is(NodeType.FCall) {
        switch e.node_type {
        case NodeType.FCall(fcd):
            // does_throw OR leftover is_bang both signal that this
            // FCall is a throwing-call shape the validator should
            // inspect.
            if fcd.does_throw { return true }
            if fcd.is_bang { return true }
        case:
        }
    }
    for c : Expr in e.children {
        if subtree_has_throw_catch(c) { return true }
    }
    return false
}

// Like subtree_has_throw_catch but a bang (`f()!`) does NOT count.
// Used for the per-stmt "might _err_kind still be set after this
// stmt?" wrap decision: a bang panics-and-resets on the error path,
// so it never leaves a pending error for the following statements to
// guard against (unlike a bare throw or a propagating `?`-call). A
// bang nested in a while/if body would otherwise spuriously wrap the
// statements after the loop in `if _err_kind == 0`.
//
// A `catch` also resets _err_kind (lower_catch_node sets it to 0), so a
// throwing call whose catch is in the SAME body leaves nothing pending
// once the body finishes. This is computed as a NET pending count over a
// Body's statements in order (a throwing call sets pending, a catch
// clears it), so `switch t { case X: v := f()? catch (e:T) {} ... }`
// does not spuriously wrap the statements after the switch -- the
// throw is fully handled inside the case body. Without this, the
// trailing `return` gets wrapped in `if _err_kind == 0 { return }`,
// an if with no else that check_all_paths_return correctly flags as
// able to fall through.
priv subtree_has_pending_throw := func(e: Expr) returns Bool {
    switch e.node_type {
    case NodeType.Body:
        // Net pending over the body's statements in source order: a
        // throwing statement sets pending, a catch clears it.
        mut pending := false
        for c : Expr in e.children {
            if c.node_type.is(NodeType.Catch) {
                pending = false
            } else if subtree_has_pending_throw(c) {
                pending = true
            }
        }
        return pending
    case NodeType.Throw:
        return true
    case NodeType.Catch:
        // A catch resets _err_kind; on its own it leaves nothing pending.
        return false
    case NodeType.FCall(fcd):
        if fcd.does_throw { return true }
    case:
    }
    for c : Expr in e.children {
        if subtree_has_pending_throw(c) { return true }
    }
    return false
}

// Issue #202: any subtree FCall with is_bang flag set?
subtree_has_bang := func(e: Expr) returns Bool {
    if e.node_type.is(NodeType.FCall) {
        switch e.node_type {
        case NodeType.FCall(fcd_b):
            if fcd_b.is_bang { return true }
        case:
        }
    }
    for c : Expr in e.children {
        if subtree_has_bang(c) { return true }
    }
    return false
}

// Walk e and annotate each Throw node's til_type with the
// syntactically-resolved type of the thrown expression. Lookups
// run BEFORE any destructive mutation by the lowering pass, so
// the lowering can read each Throw's til_type directly. This
// also handles `throw <Ident>` by walking to the Ident's Decl.
priv annotate_throw_types_in := proc(mut e: Expr, root_body: Expr) {
    if e.node_type.is(NodeType.Body) {
        for bi in 0..e.children.len() {
            ref mut stmt : Expr = e.children[bi]
            if stmt.node_type.is(NodeType.Throw) {
                if stmt.children.len() == 1 {
                    mut tn := throw_type_name_for_with_body(stmt.children[0], root_body)
                    switch stmt.children[0].node_type {
                    case NodeType.Ident(idn):
                        mut scan := bi
                        while true {
                            ref prior_stmt : Expr = e.children[scan]
                            if prior_stmt.node_type.is(NodeType.Decl) {
                                switch prior_stmt.node_type {
                                case NodeType.Decl(dd):
                                    if dd.name == idn.name {
                                        if dd.explicit_type.len() > 0 {
                                            tn = dd.explicit_type.clone()
                                        } else if prior_stmt.children.len() > 0 {
                                            switch prior_stmt.children[0].node_type {
                                            case NodeType.FCall:
                                                if prior_stmt.children[0].children.len() > 0 {
                                                    switch prior_stmt.children[0].children[0].node_type {
                                                    case NodeType.Ident(rhsn): tn = Str.clone(rhsn.ident_name())
                                                    case NodeType.FieldAccess(_rhsfa3):
                                                        if prior_stmt.children[0].children[0].children.len() > 0 {
                                                            switch prior_stmt.children[0].children[0].children[0].node_type {
                                                            case NodeType.Ident(rhsty3): tn = Str.clone(rhsty3.ident_name())
                                                            case:
                                                            }
                                                        }
                                                    case:
                                                    }
                                                }
                                            case NodeType.Literal(Literal.Str):
                                                tn = "Str"
                                            case NodeType.Literal(Literal.Num):
                                                tn = "I64"
                                            case:
                                            }
                                        }
                                    }
                                case:
                                }
                            }
                            if tn.len().gt(0).or(scan.eq(0)) { break }
                            scan--
                        }
                    case:
                    }
                    if tn.len() > 0 {
                        stmt.set_til_type(Type.Custom(tn.clone()))
                    }
                }
            }
            annotate_throw_types_in(stmt, root_body)
        }
        return
    }
    if e.node_type.is(NodeType.Throw) {
        if e.children.len() == 1 {
            tn := throw_type_name_for_with_body(e.children[0], root_body)
            if tn.len() > 0 {
                e.set_til_type(Type.Custom(tn.clone()))
            }
        }
    }
    for mut sub : Expr in e.children {
        annotate_throw_types_in(sub, root_body)
    }
}

priv collect_throw_types_in := proc(e: Expr, mut out: Vec(Str)) {
    if e.node_type.is(NodeType.Throw) {
        tn := til_type_name(e.til_type())
        if tn.len() > 0 {
            mut already := false
            for existing : Str in out {
                if existing == tn { already = true }
            }
            if already.not() { out.push(own tn.clone()) }
        }
    }
    if e.node_type.is(NodeType.Catch) {
        if e.children.len() == 3 {
            switch e.children[1].node_type {
            case NodeType.Ident(ctn):
                mut already_c := false
                for existing : Str in out {
                    if existing == ctn.ident_name() { already_c = true }
                }
                if already_c.not() { out.push(own Str.clone(ctn.ident_name())) }
            case:
            }
        }
    }
    for c : Expr in e.children {
        collect_throw_types_in(c, out)
    }
}


priv err_slot_name := func(t: Str) returns Str {
    return format("_err_", t)
}

// A fieldless struct carries no information beyond its stable throw tag. Keep
// non-struct and unresolved types payload-bearing: only a resolved empty
// StructDef may use the tag-only ABI.
throw_type_has_payload := func(ctx: Context, type_name: Str) returns Bool {
    ref type_def : Expr = ctx.scope.get_struct(type_name)
    if type_def.is_null() { return true }
    switch type_def.node_type {
    case NodeType.StructDef(sdd): return sdd.fields.len() > 0
    case: return true
    }
}

// Issue #198 + #281: append the synthetic _err_kind + _err_<T> out-params a
// throwing function needs. They go BEFORE any trailing defaulted params, so a
// defaulted param (e.g. `loc: Str = __LOC__`) stays last: the call site injects
// the err args positionally at the end, and they must line up with the err
// params while the defaulted param is left for the default-fill. Funcs with no
// trailing default get them appended at the end, exactly as before. Idempotent
// callers must guard on an existing _err_kind param before calling this.
append_err_out_params := func(mut params: Vec(Declaration), throw_types: Vec(Str), ctx: Context) {
    // Locate where the trailing run of defaulted params begins.
    mut split : USize = params.len()
    while split > 0 {
        ref pp : Declaration = params[split - 1]
        if pp.default_value.is_null() { break }
        if pp.default_value.node_type.is(NodeType.NoDefaultArg) { break }
        split = split - 1
    }
    // Pop the trailing defaults off (this reverses their order).
    mut tail := Vec(Declaration).new()
    while params.len() > split {
        tail.push(own params.pop())
    }
    params.push(own Declaration(name = "_err_kind", explicit_type = "I64",
        til_type = Type.Primitive(Primitive.I64), is_mut = true, own_type = OwnType.Ref, used = true))
    for tn : Str in throw_types {
        if throw_type_has_payload(ctx, tn).not() { continue }
        params.push(own decl_typed(name = err_slot_name(tn), explicit_type = tn,
            is_mut = true, own_type = OwnType.Ref, used = true))
    }
    // Restore the trailing defaults (popping again undoes the reversal).
    while tail.len() > 0 {
        params.push(own tail.pop())
    }
}

make_int_lit := func(n: I64, line: U32, col: U32) returns Expr {
    return Expr.new(literal_num_node(n.to_str()), line, col)
}

priv make_typed_mut_decl := func(name: Str, type_name: Str, init: Expr, line: U32, col: U32) returns Expr {
    mut dd := decl_typed(
        name = name,
        explicit_type = type_name,
        is_mut = true
    )
    mut decl := Expr.new(NodeType.Decl(dd), line, col)
    decl.add_child(own init.clone())
    return decl
}

priv make_assign_stmt := func(name: Str, rhs: Expr, line: U32, col: U32) returns Expr {
    mut a := Expr.new(NodeType.Assign(AssignData(name = name.clone())), line, col)
    a.add_child(own rhs.clone())
    return a
}

// A direct empty constructor has no effects and no payload to preserve. Other
// expressions can carry effects or ownership transfers, so lowering leaves
// them as a statement before setting the tag.
priv is_direct_fieldless_throw_ctor := func(e: Expr, type_name: Str) returns Bool {
    if e.node_type.is(NodeType.FCall).not() { return false }
    if e.children.len().neq(1) { return false }
    switch e.children[0].node_type {
    case NodeType.Ident(idn): return idn.ident_name() == type_name
    case: return false
    }
}

make_default_value_expr := func(type_name: Str, line: U32, col: U32) returns Expr {
    if type_name == "Str" { return Expr.new(NodeType.Literal(Literal.Str("")), line, col) }
    if type_name == "Bool" { return Expr.new(NodeType.Literal(Literal.Bool(false)), line, col) }
    if type_name.eq("I64").or(type_name.eq("U8")).or(type_name.eq("I8")).or(type_name.eq("I16"))
    .or(type_name.eq("U16")).or(type_name.eq("I32")).or(type_name.eq("U32")).or(type_name.eq("U64"))
    .or(type_name.eq("F32")) {
        return Expr.new(literal_num_node("0"), line, col)
    }
    // Pointer-shaped builtins have no constructor. Used only for the
    // (unreachable) fallback return appended to throwing functions.
    if type_name.eq("Dynamic").or(type_name.eq("Ptr")) {
        return Expr.new(NodeType.Literal(Literal.Null), line, col)
    }
    mut tident := Expr.new(ident_node(type_name), line, col)
    mut call := Expr.new(NodeType.FCall(FCallData()), line, col)
    call.add_child(own tident)
    return call
}

priv tag_for_type := func(ctx: Context, type_name: Str, _type_to_tag_names: Vec(Str)) returns I64 {
    // Issue #198: read from ctx.throw_type_registry so the tag for a
    // given type is the same in every function (caller and callee
    // agree). The local Vec param is kept for backward shape but no
    // longer consulted.
    for i in 0..ctx.throw_type_registry.len() {
        ref n : Str = ctx.throw_type_registry[i]
        if n == type_name { return i.to_i64() + 1 }
    }
    return 0
}

priv register_throw_type := func(mut ctx: Context, name: Str) {
    if name.len() == 0 { return }
    for existing : Str in ctx.throw_type_registry {
        if existing == name { return }
    }
    ctx.throw_type_registry.push(own name.clone())
}

make_if_kind_eq_zero_wrap := func(stmt: Expr, line: U32, col: U32) returns Expr {
    mut wrap_body := Expr.new(NodeType.Body, line, col)
    wrap_body.add_child(own stmt.clone())
    mut kind_id := Expr.new(ident_node("_err_kind"), line, col)
    mut cond := make_method_call_fcall(own kind_id, "eq", line, col)
    mut zero_lit := make_int_lit(0, line, col)
    cond.add_child(own zero_lit)
    mut if_node := Expr.new(NodeType.If, line, col)
    if_node.add_child(own cond)
    if_node.add_child(own wrap_body)
    return if_node
}

// Recursively replace Ident(old_name) with Ident(new_name) in e.
priv rewrite_ident := proc(mut e: Expr, old_name: Str, new_name: Str) {
    switch e.node_type {
    case NodeType.Ident(ridn):
        if ridn.ident_name() == old_name {
            e.node_type = ident_node(new_name)
        }
    case:
    }
    for mut sub : Expr in e.children {
        rewrite_ident(sub, old_name, new_name)
    }
}

priv lower_catch_node := proc(ctx: Context, catch_node: Expr, type_to_tag_names: Vec(Str)) returns Expr {
    line := catch_node.line
    col := catch_node.col
    mut var_name := ""
    switch catch_node.children[0].node_type {
    case NodeType.Ident(n): var_name = Str.clone(n.ident_name())
    case: UNREACHABLE()
    }
    mut type_name := ""
    switch catch_node.children[1].node_type {
    case NodeType.Ident(n): type_name = Str.clone(n.ident_name())
    case: UNREACHABLE()
    }
    tag := tag_for_type(ctx, type_name, type_to_tag_names)
    mut new_body := Expr.new(NodeType.Body, line, col)
    new_body.add_child(own make_assign_stmt("_err_kind", make_int_lit(0, line, col), line, col))
    ref orig_body : Expr = catch_node.children[2]
    if throw_type_has_payload(ctx, type_name) {
        // Rewrite references to the user's err var inside the catch body
        // to point at the _err_<T> slot directly. Avoids needing a local
        // binding (which would trip the unused-variable check when the
        // body doesn't touch err) and keeps ownership semantics simple.
        slot := err_slot_name(type_name)
        for cb : Expr in orig_body.children {
            mut cb_clone := cb.clone()
            rewrite_ident(cb_clone, var_name, slot)
            new_body.add_child(own cb_clone)
        }
    } else {
        // Only materialize a fieldless catch value when the source catch body
        // observes it. The tag alone is sufficient for the common case.
        if subtree_references_name(orig_body, var_name) {
            mut err_decl := Expr.new(NodeType.Decl(decl_typed(name = var_name,
                explicit_type = type_name)), line, col)
            err_decl.add_child(own make_default_value_expr(type_name, line, col))
            new_body.add_child(own err_decl)
        }
        for cb : Expr in orig_body.children {
            new_body.add_child(own cb.clone())
        }
    }
    mut kind_id := Expr.new(ident_node("_err_kind"), line, col)
    mut cond := make_method_call_fcall(own kind_id, "eq", line, col)
    mut tag_lit := make_int_lit(tag, line, col)
    cond.add_child(own tag_lit)
    mut if_node := Expr.new(NodeType.If, line, col)
    if_node.add_child(own cond)
    if_node.add_child(own new_body)
    return if_node
}


// Issue #198: extend the signature of every throwing function in
// the program AST with synthetic err-out params:
//   mut _err_kind: I64
//   mut _err_<T>: T   -- one per declared throw type
// Cross-call propagation (~?~ at call sites) passes the caller's
// matching slots as the extra args. Idempotent: skips functions
// whose params already contain _err_kind. Recurses into nested
// FuncDef bodies so inner lambdas with throws also get extended.
priv register_func_throws := func(mut ctx: Context, name: Str, throws_list: Vec(Str)) {
    if name.len() == 0 { return }
    if throws_list.len() == 0 { return }
    if ctx.throws_global.has(name) { return }
    mut tt := Vec(Str).new()
    for t : Str in throws_list {
        tt.push(own t.clone())
    }
    ctx.throws_global.set(name, own tt)
}

extend_throwing_func_sigs := proc(mut ctx: Context, mut e: Expr) {
    // Register Decl(name) -> FuncDef in the global throws map.
    if e.node_type.is(NodeType.Decl) {
        if e.children.len() > 0 {
            switch e.node_type {
            case NodeType.Decl(dn):
                ref rhs : Expr = e.children[0]
                if rhs.node_type.is(NodeType.FuncDef) {
                    switch rhs.node_type {
                    case NodeType.FuncDef(rfd):
                        register_func_throws(ctx, dn.name, rfd.throw_types)
                    case:
                    }
                }
                // Namespace methods register under the type-qualified
                // key "Type.method" so the call-site lookup can tell e.g.
                // Array.get (throwing) from Vec.get (not), instead of
                // conflating them by the bare method name.
                switch rhs.node_type {
                case NodeType.StructDef(rsd):
                    for nd : Declaration in rsd.ns_decls {
                        ref dv : Expr = nd.default_value
                        if dv.node_type.is(NodeType.FuncDef) {
                            switch dv.node_type {
                            case NodeType.FuncDef(mfd):
                                register_func_throws(ctx, format(dn.name, ".", nd.name), mfd.throw_types)
                            case:
                            }
                        }
                    }
                case NodeType.EnumDef(red):
                    for nd : Declaration in red.ns_decls {
                        ref dv : Expr = nd.default_value
                        if dv.node_type.is(NodeType.FuncDef) {
                            switch dv.node_type {
                            case NodeType.FuncDef(mfd):
                                register_func_throws(ctx, format(dn.name, ".", nd.name), mfd.throw_types)
                            case:
                            }
                        }
                    }
                case:
                }
            case:
            }
        }
    }
    if e.node_type.is(NodeType.FuncDef) {
        switch e.node_type {
        case NodeType.FuncDef(efd):
            // Register all declared throw types in the global registry.
            for tn : Str in efd.throw_types {
                register_throw_type(ctx, tn)
            }
            if efd.throw_types.len() > 0 {
                mut already := false
                for p : Declaration in efd.params {
                    if p.name == "_err_kind" { already = true }
                }
                if already.not() {
                    append_err_out_params(efd.params, efd.throw_types, ctx)
                }
            }
        case:
        }
    }
    // Also register types from Throw and Catch nodes so locally-only
    // throws (not in any throws clause) still get a stable tag.
    if e.node_type.is(NodeType.Throw) {
        if e.children.len() == 1 {
            tn := throw_type_name_for_with_body(e.children[0], e)
            if tn.len() > 0 { register_throw_type(ctx, tn) }
        }
    }
    if e.node_type.is(NodeType.Catch) {
        if e.children.len() == 3 {
            switch e.children[1].node_type {
            case NodeType.Ident(ctn): register_throw_type(ctx, ctn.ident_name())
            case:
            }
        }
    }
    // Also recurse into namespace method bodies (ns_decls' default_value
    // Exprs hold the method FuncDef bodies; they're not in children).
    // Recurse into namespace method bodies to extend their throwing
    // signatures with the synthetic err out-params. The throws-map
    // registration itself is type-qualified ("Type.method") and done
    // at the owning Decl above, so it is not repeated here.
    switch e.node_type {
    case NodeType.StructDef(esd_ns):
        for mut nd : Declaration in esd_ns.ns_decls {
            extend_throwing_func_sigs(ctx, nd.default_value)
        }
    case NodeType.EnumDef(eed_ns):
        for mut nd : Declaration in eed_ns.ns_decls {
            extend_throwing_func_sigs(ctx, nd.default_value)
        }
    case:
    }
    for mut sub : Expr in e.children {
        extend_throwing_func_sigs(ctx, sub)
    }
}

// Build a parallel-Vec map of FuncName -> Vec[Str] (throws) for
// every throwing top-level function in the program. Recurses into
// nested FuncDefs. Used by the call-site rewrite in
// inject_throw_args_in_body. Names is by Decl name (works for
// bare-name calls and for UFCS-rewritten calls, which look like
// bare-name FCalls after the typer's UFCS pass).

// Walk a (lowered + typed) body, find every FCall whose
// does_throw is set, and rewrite it to pass the caller's err
// slots as extra args. The slots must already exist in scope
// (as locals declared by lower_throw_catch_in_func_body or as
// params on a throwing caller). Clears does_throw on the FCall
// after rewriting so downstream stages don't act on the marker.

// ---------------------------------------------------------------
// Issue #202: bang operator (!) -- "panic on throw" sugar.
//
//   f(args)!
//
// desugars to
//
//   f(args)?
//   catch (e: T) { panic(loc(), "T") }   // one per declared throw type
//
// The user keeps the right to use the verbose ~?~ + ~catch~ form
// when they need to inspect err fields; ~!~ is for "fail loudly,
// don't care about the message" call sites.
// ---------------------------------------------------------------

// Issue #202: bang_counter previously lived here as a module-level
// mut; it moved onto Context (see initer.til) alongside the other
// throws state. Threading ctx through the bang hoisters lets a
// single ctx own all of this typer transient state.

// Walk e: for every FCall with is_bang set, clear is_bang and set
// does_throw. Idempotent; safe to call multiple times.
priv clear_bang_flag := proc(mut e: Expr) {
    switch e.node_type {
    case NodeType.FCall(fcd_clr):
        if fcd_clr.is_bang {
            fcd_clr.is_bang = false
            fcd_clr.does_throw = true
        }
    case:
    }
    for mut sub : Expr in e.children {
        clear_bang_flag(sub)
    }
}

// Find the immediate bang FCall in a stmt (direct or wrapped in
// Decl/Assign/FieldAssign/Return). Returns the callee name, or "".
priv find_bang_callee_name := func(e: Expr) returns Str {
    switch e.node_type {
    case NodeType.FCall(fcd_f):
        if fcd_f.is_bang.not() { return "" }
        if e.children.len() == 0 { return "" }
        switch e.children[0].node_type {
        case NodeType.Ident(n): return Str.clone(n.ident_name())
        case NodeType.FieldAccess(fnam): return Str.clone(fnam.field_access_name())
        case: return ""
        }
    case NodeType.Decl:
        if e.children.len() == 0 { return "" }
        return find_bang_callee_name(e.children[0])
    case NodeType.Assign:
        if e.children.len() == 0 { return "" }
        return find_bang_callee_name(e.children[0])
    case NodeType.FieldAssign:
        if e.children.len() == 0 { return "" }
        return find_bang_callee_name(e.children[0])
    case NodeType.Return:
        if e.children.len() == 0 { return "" }
        return find_bang_callee_name(e.children[0])
    case: return ""
    }
}

// Like find_bang_callee_name but returns the bang FCall node itself
// (or NULL), so callers can resolve its type-qualified throws.
priv find_bang_fcall := func(e: Expr) returns ref Expr {
    switch e.node_type {
    case NodeType.FCall(fcd_f):
        if fcd_f.is_bang { return e }
        return NULL
    case NodeType.Decl:
        if e.children.len() == 0 { return NULL }
        return find_bang_fcall(e.children[0])
    case NodeType.Assign:
        if e.children.len() == 0 { return NULL }
        return find_bang_fcall(e.children[0])
    case NodeType.FieldAssign:
        if e.children.len() == 0 { return NULL }
        return find_bang_fcall(e.children[0])
    case NodeType.Return:
        if e.children.len() == 0 { return NULL }
        return find_bang_fcall(e.children[0])
    case: return NULL
    }
}

// Build  catch (<err_var>: <error_type>) { panic("<file>:<line>:<col>", "<error_type>") }
// We construct the location string at lowering time as a LiteralStr,
// equivalent to what the parser does for __LOC__.

// Process a Body Expr in place: for each bang-stmt, clear the bang
// flag, push the (now ?-marked) stmt, then append a catch block
// per declared throw type of the callee. Recurses into nested
// if/while/for/switch arms.
// Issue #202 follow-up: hoist a bang FCall at parent.children[child_idx]
// out into a `_bang_ret_<n> := <call>?` Decl + catch blocks pushed
// into pre_stmts. Replaces parent.children[child_idx] with an Ident
// reference to the temp. Skips nested defs and Body children (those
// are handled by desugar_bang_in_body's recursion). Postorder so an
// inner `g(f()!)!` hoists f first, then g.

// Walk stmt's expression tree, hoisting every nested bang FCall into
// pre_stmts. The stmt-root bang (if any) is intentionally NOT hoisted
// -- the existing direct handler in desugar_bang_in_body produces a
// cleaner lowering (avoids an extra temp) for that shape.


// Append a fallback `return <default(return_type)>` to body for
// throwing functions whose original body relied on the error path
// to bypass the return statement. After lowering, the return is
// guarded by `if _err_kind == 0`; the C builder needs a literal
// return on the error path so all paths return.

// Issue #198 follow-up: rstil-parity validation for throw/catch.
//
// Walks a function body in source order, tracking the list of
// types currently "pending" (thrown but not yet caught). Catches
// remove matching entries; if no entry matches, emit an error.
// FCalls with does_throw=true pull their callee's declared throws
// into pending; does_throw=false on a throwing callee (or true on
// a non-throwing one) is also an error.
//
// At end-of-body the validator:
//   - errors on any leftover pending type that isn't in the
//     function's own throws clause
//   - errors on any declared throws entry that was never raised
//     (rstil's "declared but never thrown" diagnostic)

// Map the `array(...)` / `vec(...)` builtin ctor names to the struct
// type they produce, so a `x := vec(...)` local resolves to "Vec".
priv normalize_ctor_type := func(tn: Str) returns Str {
    if tn == "array" { return "Array" }
    if tn == "vec" { return "Vec" }
    return tn
}

// Type name of a struct field, "" if unknown.
priv struct_field_type := func(ctx: Context, type_name: Str, field_name: Str) returns Str {
    ref sdef : Expr = ctx.scope.get_struct(type_name)
    if sdef.is_null() { return "" }
    switch sdef.node_type {
    case NodeType.StructDef(sd):
        for fd : Declaration in sd.fields {
            if fd.name == field_name {
                if fd.explicit_type.len() > 0 { return fd.explicit_type.clone() }
                tn := til_type_name(fd.til_type)
                if tn.len() > 0 { return tn }
                // Field declared without an explicit type AND its
                // til_type hasn't been inferred yet (extend_throwing_func_sigs
                // runs before infer_body, so init expressions like
                // `payload_types := Map(I64, Str).new()` haven't been
                // typed). Guess from the default-value Expr: a bare
                // ctor FCall like `Map(K, V).new()` or `Vec(T).new()` lets
                // us read the type off the callee.
                ref dv : Expr = fd.default_value
                if dv.node_type.is(NodeType.FCall).and(dv.children.len().gt(0)) {
                    ref dv_callee : Expr = dv.children[0]
                    switch dv_callee.node_type {
                    case NodeType.FieldAccess:
                        if dv_callee.children.len() > 0 {
                            switch dv_callee.children[0].node_type {
                            case NodeType.Ident(dv_recv): return Str.clone(dv_recv.ident_name())
                            case:
                            }
                        }
                    case NodeType.Ident(dv_id):
                        return normalize_ctor_type(dv_id.ident_name())
                    case:
                    }
                }
                return ""
            }
        }
    case:
    }
    return ""
}

// Best-effort type of a value expression for receiver resolution.
// Handles idents (params, body-local Decls, literals) and field-access
// chains (resolve the receiver, then look up the field's declared type
// in its struct). Returns "" when it can't be determined here.
priv resolve_value_type := func(ctx: Context, e: Expr, body: Expr) returns Str {
    switch e.node_type {
    case NodeType.Ident(idn):
        ref nm : Str = idn.ident_name()
        if ctx.lowering_param_types.has(nm) {
            ref pt : Str = ctx.lowering_param_types[nm]
            return normalize_ctor_type(pt)
        }
        g := guess_local_type(body, nm)
        if g.len() > 0 {
            ng := normalize_ctor_type(g)
            // guess_local_type can return the base receiver of an FCall
            // (eg. `files := uc.split(" ")` -> "uc"), which isn't a real
            // type. Only commit to ng if it names a known struct; let the
            // caller fall back to the suffix-match path otherwise.
            if ctx.scope.get_struct(ng).is_null().not() { return ng }
            // FCall form `mut x := some_func(...)` lands here with
            // ng == "some_func". If the name resolves to a function in
            // scope, return its declared return_type instead.
            ref fb : TypeBinding = ctx.scope.get_binding(ng)
            if fb.is_null().not() {
                ref fb_fd : Expr = ctx.scope.lookup_func(fb.name)
                if fb_fd.is_null().not() {
                    switch fb_fd.node_type {
                    case NodeType.FuncDef(fdef):
                        if fdef.return_type.len() > 0 {
                            return normalize_ctor_type(fdef.return_type)
                        }
                    case:
                    }
                }
            }
            return ""
        }
        return ""
    case NodeType.FieldAccess(fn):
        if e.children.len() == 0 { return "" }
        recv_t := resolve_value_type(ctx, e.children[0], body)
        if recv_t.len() == 0 { return "" }
        return struct_field_type(ctx, recv_t, fn.field_access_name())
    case NodeType.Literal(Literal.Num): return "I64"
    case NodeType.Literal(Literal.Str): return "Str"
    case NodeType.Literal(Literal.Bool): return "Bool"
    case:
        return ""
    }
}

// Resolve the owning type name of a method-call FCall for the
// type-qualified throws lookup. Returns "" for a free-function call or
// an unresolvable receiver (method chains etc.). For the static
// `Type.method(...)` form the receiver Ident names the struct; for
// UFCS `recv.method(...)` the receiver is resolved by resolve_value_type.
priv callee_owning_type := func(ctx: Context, fcall: Expr, body: Expr) returns Str {
    if fcall.children.len() == 0 { return "" }
    ref callee : Expr = fcall.children[0]
    switch callee.node_type {
    case NodeType.FieldAccess(_m):
        if callee.children.len() == 0 { return "" }
        ref recv : Expr = callee.children[0]
        switch recv.node_type {
        case NodeType.Ident(rn):
            if ctx.scope.get_struct(rn.ident_name()).is_null().not() { return Str.clone(rn.ident_name()) }
        case:
        }
        return resolve_value_type(ctx, recv, body)
    case:
        return ""
    }
}

priv registry_exact_key := func(ctx: Context, key: Str) returns Str {
    if ctx.throws_global.has(key) { return key.clone() }
    return ""
}

priv register_method_throws_from_scope := func(mut ctx: Context, owner: Str, method: Str) returns Str {
    key := format(owner, ".", method)
    if ctx.throws_global.has(key) { return key }
    ref sdef : Expr = ctx.scope.get_struct(owner)
    if sdef.is_null() { return "" }
    ref mdef : Expr = find_namespace_func(sdef, method, ctx.scope)
    if mdef.is_null() { return "" }
    switch mdef.node_type {
    case NodeType.FuncDef(fd):
        if fd.throw_types.len() > 0 {
            register_func_throws(ctx, key, fd.throw_types)
            return key
        }
        mut derived := Vec(Str).new()
        for p : Declaration in fd.params {
            if p.name.starts_with("_err_").and(p.name.eq("_err_kind").not()) {
                if p.explicit_type.len() > 0 { derived.push(own p.explicit_type.clone()) }
            }
        }
        if derived.len() > 0 {
            register_func_throws(ctx, key, derived)
            return key
        }
    case:
    }
    return ""
}

// Fallback for an unresolvable receiver: match a registry entry whose
// key is bare `method` or any `Type.method`. Conservative (treats the
// call as throwing), preserving the pre-qualification behavior for
// method-chain / literal receivers whose type we can't resolve here.
priv registry_suffix_key := func(ctx: Context, method: Str) returns Str {
    if ctx.throws_global.has(method) { return method.clone() }
    dotted := format(".", method)
    for n : Str in ctx.throws_global.keys {
        if n.ends_with(dotted) { return n.clone() }
    }
    return ""
}

// Look up callee throws for an FCall. Free functions match by bare
// name; method calls resolve the receiver type and match the
// type-qualified "Type.method" key, falling back to a bare/suffix
// match when the receiver type can't be resolved. Returns the matching
// throws_global key, or "" for not-found.
priv find_callee_throws_key := func(ctx: Context, fcall: Expr, body: Expr) returns Str {
    if fcall.children.len() == 0 { return "" }
    ref callee : Expr = fcall.children[0]
    switch callee.node_type {
    case NodeType.Ident(n):
        return registry_exact_key(ctx, n.ident_name())
    case NodeType.FieldAccess(fname):
        ref method : Str = fname.field_access_name()
        owner := callee_owning_type(ctx, fcall, body)
        if owner.len() > 0 {
            exact_key := registry_exact_key(ctx, format(owner, ".", method))
            if exact_key.len() > 0 { return exact_key }
            scoped_key := register_method_throws_from_scope(ctx, owner, method)
            if scoped_key.len() > 0 { return scoped_key }
            marker := owner.find("__")
            if marker > 0 {
                base_owner := owner.substr(0, marker.to_usize())
                base_key := registry_exact_key(ctx, format(base_owner, ".", method))
                if base_key.len() > 0 { return base_key }
                base_scoped_key := register_method_throws_from_scope(ctx, base_owner, method)
                if base_scoped_key.len() > 0 { return base_scoped_key }
            }
            return ""
        }
        // Unresolvable receiver: only treat as throwing if SOME type's
        // method by this name throws AND the user marked the call with
        // ?/!. Without a ?/! marker we treat it as non-throwing to avoid
        // false positives on the common Map.get / Vec.get-on-a-field
        // patterns whose receiver type we can't resolve pre-inference.
        mut marked := false
        switch fcall.node_type {
        case NodeType.FCall(fcd_m): marked = fcd_m.does_throw.or(fcd_m.is_bang)
        case:
        }
        if marked { return registry_suffix_key(ctx, method) }
        return ""
    case:
        return ""
    }
}

// Matches rstil: a single catch consumes EVERY pending entry of
// that type, not just one. Returns true if at least one was found.
priv pending_remove_all_matching := func(mut pending: Vec(Str), type_name: Str) returns Bool {
    mut found := false
    mut kept := Vec(Str).new()
    for n : Str in pending {
        if n == type_name {
            found = true
        } else {
            kept.push(own n.clone())
        }
    }
    pending.move_from(kept)
    return found
}

priv vec_str_contains := func(v: Vec(Str), name: Str) returns Bool {
    for n : Str in v {
        if n == name { return true }
    }
    return false
}

priv vec_str_push_uniq := func(mut v: Vec(Str), name: Str) {
    if vec_str_contains(v, name) { return }
    v.push(own name.clone())
}





// ============================================================
// Issue #198/#202 follow-up: single per-body walk that does ALL
// throw/catch work (desugar bang + validate + lower throw/catch +
// inject err args + fallback return). #158 alignment: one walk
// per phase instead of the previous five separate walks.
// ============================================================

// Per-FCall validation: emits the ? / ! error diagnostics, auto-fixes
// the FCall flags so downstream stages don't trip on a half-shaped
// signature, and updates the body-level pending / seen /
// types_to_declare lists with the callee's declared throw types.
priv validate_one_fcall_consolidated := proc(
    ctx: Context,
    mut e: Expr,
    body: Expr,
    mut pending: Vec(Str),
    mut seen: Vec(Str),
    mut types_to_declare: Vec(Str),
    path: Str
) {
    if e.node_type.is(NodeType.FCall).not() { return }
    mut does_throw := false
    mut is_bang_left := false
    switch e.node_type {
    case NodeType.FCall(fcd):
        does_throw = fcd.does_throw
        is_bang_left = fcd.is_bang
    case:
    }
    if is_bang_left {
        type_error_at(path, e.line, e.col, "function does not throw, remove the '!' after the call", ctx)
        switch e.node_type {
        case NodeType.FCall(fcd_clr_b):
            fcd_clr_b.is_bang = false
            fcd_clr_b.does_throw = false
        case:
        }
    }
    key := find_callee_throws_key(ctx, e, body)
    callee_is_throwing := key.len() > 0
    if does_throw {
        if callee_is_throwing.not() {
            type_error_at(path, e.line, e.col, "function does not throw, remove the '?' after the call", ctx)
            switch e.node_type {
            case NodeType.FCall(fcd_fix): fcd_fix.does_throw = false
            case:
            }
        } else {
            ref tts : Vec(Str) = ctx.throws_global[key]
            for tn : Str in tts {
                pending.push(own tn.clone())
                vec_str_push_uniq(seen, tn)
                vec_str_push_uniq(types_to_declare, tn)
            }
        }
    } else {
        if callee_is_throwing {
            ref tts2 : Vec(Str) = ctx.throws_global[key]
            mut tlist := ""
            for jj in 0..tts2.len() {
                ref tn2 : Str = tts2[jj]
                if jj > 0 { tlist = format(tlist, ", ") }
                tlist = format(tlist, tn2)
            }
            type_error_at(path, e.line, e.col, format("function throws ", tlist, ", missing '?' after the call"), ctx)
            switch e.node_type {
            case NodeType.FCall(fcd_fix2): fcd_fix2.does_throw = true
            case:
            }
            for tn3 : Str in tts2 {
                pending.push(own tn3.clone())
                vec_str_push_uniq(seen, tn3)
                vec_str_push_uniq(types_to_declare, tn3)
            }
        }
    }
}

// Per-FCall: if does_throw is set and the callee is in the global
// throws map, append _err_kind + _err_<T> arg refs, then clear the
// flag so the call reaches downstream stages as a plain FCall.
priv inject_err_args_on_one_fcall_consolidated := func(ctx: Context, mut e: Expr, body: Expr) {
    if e.node_type.is(NodeType.FCall).not() { return }
    mut does_throw := false
    switch e.node_type {
    case NodeType.FCall(fcd):
        does_throw = fcd.does_throw
    case:
    }
    if does_throw.not() { return }
    if e.children.len() == 0 { return }
    key := find_callee_throws_key(ctx, e, body)
    if key.len() == 0 { return }
    ref tts : Vec(Str) = ctx.throws_global[key]
    mut kind_id := Expr.new(ident_node("_err_kind"), e.line, e.col)
    kind_id.set_til_type(Type.Primitive(Primitive.I64))
    e.add_child(own kind_id)
    for tn : Str in tts {
        if throw_type_has_payload(ctx, tn).not() { continue }
        mut slot_id := Expr.new(ident_node(err_slot_name(tn)), e.line, e.col)
        slot_id.set_til_type(til_type_from_explicit_type(tn))
        e.add_child(own slot_id)
    }
    switch e.node_type {
    case NodeType.FCall(fcd_clr): fcd_clr.does_throw = false
    case:
    }
}

// Walk e's expression subtree applying validate + inject to each
// FCall. Skips nested bodies (NodeType.Body) and nested defs --
// those are handled by the body-level walk and the typer's per
// FuncDef visit, respectively.
priv validate_and_inject_expr_consolidated := proc(
    ctx: Context,
    mut e: Expr,
    body: Expr,
    mut pending: Vec(Str),
    mut seen: Vec(Str),
    mut types_to_declare: Vec(Str),
    path: Str
) {
    if e.node_type.is(NodeType.FuncDef)
        .or(e.node_type.is(NodeType.StructDef))
        .or(e.node_type.is(NodeType.EnumDef)) { return }
    if e.node_type.is(NodeType.Body) { return }
    validate_one_fcall_consolidated(ctx, e, body, pending, seen, types_to_declare, path)
    inject_err_args_on_one_fcall_consolidated(ctx, e, body)
    if e.node_type.is(NodeType.Case) {
        // #282: a bang call in a case guard is lowered at infer time into the
        // pattern-gated case body, not here. Skip the guard child (index 1 of
        // a 3-child [pattern, guard, body] Case) so validate_one_fcall doesn't
        // flag the surviving '!' as "function does not throw". The body is a
        // Body (handled elsewhere); the pattern carries no calls.
        guard_bang := e.children.len().eq(3).and(subtree_has_bang(e.children[1]))
        for sci in 0..e.children.len() {
            if guard_bang.and(sci.eq(1)) { continue }
            ref mut sub : Expr = e.children[sci]
            validate_and_inject_expr_consolidated(ctx, sub, body, pending, seen, types_to_declare, path)
        }
        return
    }
    for mut sub : Expr in e.children {
        validate_and_inject_expr_consolidated(ctx, sub, body, pending, seen, types_to_declare, path)
    }
}

// Build the already-lowered if-block for a bang catch directly --
// avoids an intermediate NodeType.Catch that would need a separate
// lowering pass to convert. Emits:
//   if I64.eq(_err_kind, <tag>) { _err_kind = 0; panic("<loc>", "<T>") }
priv build_bang_lowered := func(ctx: Context, error_type: Str, line: U32, col: U32) returns Expr {
    tag := tag_for_type(ctx, error_type, Vec(Str).new())
    loc_str := format(ctx.path, ":", line.to_str(), ":", col.to_str())
    mut panic_call := Expr.new(NodeType.FCall(FCallData()), line, col)
    panic_call.add_child(own Expr.new(ident_node("panic"), line, col))
    panic_call.add_child(own Expr.new(NodeType.Literal(Literal.Str(loc_str)), line, col))
    panic_call.add_child(own Expr.new(NodeType.Literal(Literal.Str(error_type.clone())), line, col))
    mut blk := Expr.new(NodeType.Body, line, col)
    blk.add_child(own make_assign_stmt("_err_kind", make_int_lit(0, line, col), line, col))
    blk.add_child(own panic_call)
    mut kind_id := Expr.new(ident_node("_err_kind"), line, col)
    mut tag_lit := make_int_lit(tag, line, col)
    mut cond := make_method_call_fcall(own kind_id, "eq", line, col)
    cond.add_child(own tag_lit)
    mut if_node := Expr.new(NodeType.If, line, col)
    if_node.add_child(own cond)
    if_node.add_child(own blk)
    return if_node
}

// Recursive hoister for bangs nested inside an expression. Pushes
// _bang_ret_<n> := <call>? Decl plus lowered if-block checks into
// pre_stmts and replaces the original bang FCall position with an
// Ident reference to the temp. Postorder so the innermost bang
// hoists first. Tracks the callee's throws on types_to_declare and
// seen so the function-body wrapper later prepends the right slot
// decls.
priv hoist_walk_consolidated := proc(
    mut ctx: Context,
    mut parent: Expr,
    child_idx: USize,
    body: Expr,
    mut pre_stmts: Vec(Expr),
    mut types_to_declare: Vec(Str),
    mut seen: Vec(Str)
) {
    ref mut child : Expr = parent.children[child_idx]
    if child.node_type.is(NodeType.FuncDef)
        .or(child.node_type.is(NodeType.StructDef))
        .or(child.node_type.is(NodeType.EnumDef)) { return }
    if child.node_type.is(NodeType.Body) { return }
    // #282: a switch/match `Case` is [pattern, (guard,) body]. Its body is a
    // Body (skipped above; lowered by the step-2 case-body recursion) and its
    // guard is evaluated only on a pattern hit. A throwing (bang) call in the
    // guard must therefore NOT be hoisted out here -- that would run it
    // unconditionally before the whole switch. infer_switch_stmt lowers guard
    // bangs into the pattern-gated case body instead. Patterns carry no calls,
    // so stopping at the whole Case is safe.
    if child.node_type.is(NodeType.Case) { return }
    for gi in 0..child.children.len() {
        hoist_walk_consolidated(ctx, child, gi, body, pre_stmts, types_to_declare, seen)
    }
    if child.node_type.is(NodeType.FCall).not() { return }
    mut is_bang_here := false
    switch child.node_type {
    case NodeType.FCall(fcd_check): is_bang_here = fcd_check.is_bang
    case:
    }
    if is_bang_here.not() { return }
    if child.children.len() == 0 { return }
    found_key := find_callee_throws_key(ctx, child, body)
    if found_key.len() == 0 { return }
    line := child.line
    col := child.col
    tmp_name := format("_bang_ret_", ctx.bang_counter.to_str())
    ctx.bang_counter = ctx.bang_counter + 1
    mut cloned := child.clone()
    clear_bang_flag(cloned)
    // The hoisted call won't pass through the main loop's per-stmt
    // validate+inject step (pre_stmts go straight into new_ch), so
    // inject err out-args here directly.
    inject_err_args_on_one_fcall_consolidated(ctx, cloned, body)
    mut tmp_decl := Expr.new(NodeType.Decl(Declaration(name = tmp_name.clone())), line, col)
    if fcall_is_get_method(cloned).or(fcall_returns_ref(cloned, ctx.scope).neq(0)) {
        switch tmp_decl.node_type {
        case NodeType.Decl(dd): dd.own_type = OwnType.Ref
        case:
        }
    }
    tmp_decl.add_child(own cloned)
    pre_stmts.push(own tmp_decl)
    ref tts : Vec(Str) = ctx.throws_global[found_key]
    for tn : Str in tts {
        vec_str_push_uniq(types_to_declare, tn)
        vec_str_push_uniq(seen, tn)
        pre_stmts.push(own build_bang_lowered(ctx, tn, line, col))
    }
    parent.children[child_idx] = Expr.new(ident_node(tmp_name), line, col)
}

// Walk stmt's expression tree hoisting nested bangs (not the
// stmt-root bang). The stmt-root bang shape is handled by the
// main per-stmt logic in process_throw_catch_in_body so it
// produces cleaner output without an extra temp.
priv hoist_nested_bangs_consolidated := proc(
    mut ctx: Context,
    mut stmt: Expr,
    body: Expr,
    mut pre_stmts: Vec(Expr),
    mut types_to_declare: Vec(Str),
    mut seen: Vec(Str)
) {
    cname := find_bang_callee_name(stmt)
    if cname.len() == 0 {
        for ci in 0..stmt.children.len() {
            hoist_walk_consolidated(ctx, stmt, ci, body, pre_stmts, types_to_declare, seen)
        }
        return
    }
    if stmt.node_type.is(NodeType.FCall) {
        for ai in 1..stmt.children.len() {
            hoist_walk_consolidated(ctx, stmt, ai, body, pre_stmts, types_to_declare, seen)
        }
        return
    }
    ref mut root_fcall : Expr = stmt.children[0]
    if root_fcall.node_type.is(NodeType.FCall) {
        for ai in 1..root_fcall.children.len() {
            hoist_walk_consolidated(ctx, root_fcall, ai, body, pre_stmts, types_to_declare, seen)
        }
    }
    for ci in 1..stmt.children.len() {
        hoist_walk_consolidated(ctx, stmt, ci, body, pre_stmts, types_to_declare, seen)
    }
}

// Single per-body walk performing all throw/catch work:
//   1. hoist nested bangs (Decl + lowered if-blocks before stmt)
//   2. recurse into nested bodies (if/while/for/switch/catch arms)
//   3. clear the stmt-root bang flag (so the call below sees does_throw)
//   4. validate + inject err args on FCalls in stmt's tree
//      (skipping nested bodies, which already happened in step 2)
//   5. rewrite Throw  -> _err_<T> = expr ; _err_kind = tag
//   6. rewrite Catch  -> if I64.eq(_err_kind, tag) { _err_kind = 0; body }
//   7. append lowered bang checks for stmt-root bang; for
//      `return f()!` hoist the call into a tmp first so the checks
//      execute before the return
//   8. wrap stmt in `if I64.eq(_err_kind, 0)` when a previous stmt
//      could have set _err_kind
// A throwing call in a `match` arm value -- a subscript `v[i]` (= `get(i)!`),
// an `f()?` (may throw; the error is caught by a later `catch` in this
// function, or propagated to the caller's throws clause when uncaught), or an
// `f()!` (panics if it throws, so it needs no catch/rethrow) -- lives in a Body
// node that neither step 1 (hoist_walk returns on Body) nor step 2 (which
// descends into if/while/for/switch/catch bodies, but a `match` here is an
// expression nested in a Decl/Assign/FCall, not a statement) reaches. So the
// throwing call in a match arm is left unlowered and infer later fails with
// "missing argument for parameter '_err_kind'". `a.and(b)` / `a.or(b)` desugar
// to `match a { ... }`, so `cond.and(v[i])` hits this.
//
// Walk the statement's expression tree for nested Match nodes and run the
// throw/catch lowering on each arm Body exactly like a switch case body. That
// lowering handles both forms correctly -- it appends a panic guard for `!`
// and, for `?`, leaves the error to a local `catch` or the caller -- and
// hoists the call INTO the arm, so it only runs when that arm is taken
// (short-circuit preserved) and gets its _err_kind/_err_<T> out-args; the
// throw type lands in types_to_declare so the function-level slot decls are
// prepended as usual.

// #282: a throwing (bang) call in a switch/match case GUARD is lowered at
// infer time (infer_switch_stmt), where the guard's pattern-gated position
// finally exists. The pre-infer pass cannot place it, but it must still
// DISCOVER the guard's throw types so the function-level _err_kind / _err_<T>
// slots get declared (process_throw_catch_in_func_body prepends them from
// types_to_declare). Walk the guard for bang FCalls, resolve each callee's
// throws against the function body, and register them -- without hoisting.
priv register_bang_guard_throws := proc(
    mut ctx: Context,
    guard: Expr,
    root_body: Expr,
    mut types_to_declare: Vec(Str),
    mut seen: Vec(Str)
) {
    if guard.node_type.is(NodeType.FCall) {
        mut is_b := false
        switch guard.node_type {
        case NodeType.FCall(fcd_g): is_b = fcd_g.is_bang
        case:
        }
        if is_b.and(guard.children.len().gt(0)) {
            key := find_callee_throws_key(ctx, guard, root_body)
            if key.len() > 0 {
                ref tts : Vec(Str) = ctx.throws_global[key]
                for tn : Str in tts {
                    register_throw_type(ctx, tn)
                    vec_str_push_uniq(types_to_declare, tn)
                    vec_str_push_uniq(seen, tn)
                }
            }
        }
    }
    for c : Expr in guard.children {
        register_bang_guard_throws(ctx, c, root_body, types_to_declare, seen)
    }
}

priv process_match_arms_in := proc(
    mut ctx: Context,
    mut e: Expr,
    root_body: Expr,
    fdef_throws: Vec(Str),
    mut pending: Vec(Str),
    mut seen: Vec(Str),
    mut types_to_declare: Vec(Str),
    path: Str,
    return_type: Str,
    return_own_type: OwnType
) {
    if e.node_type.is(NodeType.FuncDef)
        .or(e.node_type.is(NodeType.StructDef))
        .or(e.node_type.is(NodeType.EnumDef)) { return }
    // Do NOT descend into a nested statement Body (an if/while/for/switch arm,
    // or a block): process_throw_catch_in_body recurses into those separately
    // and calls process_match_arms_in on their statements. Walking into them
    // here too would process any match in them twice, injecting a throwing
    // call's err out-args repeatedly ("too many arguments"). Match ARM bodies
    // are still handled -- the Match case below feeds them to
    // process_throw_catch_in_body directly, not through this generic walk.
    if e.node_type.is(NodeType.Body) { return }
    if e.node_type.is(NodeType.Match) {
        for mut child : Expr in e.children {
            if child.node_type.is(NodeType.Case) {
                // #282: discover a bang guard's throw types so the
                // function-level err slots get declared (the actual hoist
                // runs at infer time).
                if child.children.len() == 3 {
                    register_bang_guard_throws(ctx, child.children[1], root_body, types_to_declare, seen)
                }
                // Case = [pattern, (guard,) body]; process its Body arm(s).
                for mut ccn : Expr in child.children {
                    if ccn.node_type.is(NodeType.Body) {
                        process_throw_catch_in_body(ctx, ccn, root_body, fdef_throws, pending, seen, types_to_declare, path, return_type, return_own_type)
                    } else {
                        process_match_arms_in(ctx, ccn, root_body, fdef_throws, pending, seen, types_to_declare, path, return_type, return_own_type)
                    }
                }
            } else {
                // The scrutinee (child 0) may itself nest a match.
                process_match_arms_in(ctx, child, root_body, fdef_throws, pending, seen, types_to_declare, path, return_type, return_own_type)
            }
        }
        return
    }
    for mut sub : Expr in e.children {
        process_match_arms_in(ctx, sub, root_body, fdef_throws, pending, seen, types_to_declare, path, return_type, return_own_type)
    }
}

priv process_throw_catch_in_body := proc(
    mut ctx: Context,
    mut body: Expr,
    root_body: Expr,
    fdef_throws: Vec(Str),
    mut pending: Vec(Str),
    mut seen: Vec(Str),
    mut types_to_declare: Vec(Str),
    path: Str,
    return_type: Str,
    return_own_type: OwnType
) {
    if body.node_type.is(NodeType.Body).not() { return }
    if body.children.len() == 0 { return }

    mut old := Vec(Expr).new()
    old.move_from(body.children)
    mut old_snapshot : Vec(Expr) = old.clone()
    mut new_ch := Vec(Expr).new()
    mut seen_throwing := false

    for j in 0..old.len() {
        ref mut stmt : Expr = old[j]
        stmt_line := stmt.line
        stmt_col := stmt.col
        seed_prior_local_types(ctx, old_snapshot, j)

        // Once a prior statement may have set _err_kind, the rest of the
        // body runs only on the no-error path. Group ALL remaining
        // statements into ONE `if _err_kind == 0` guard, then recurse to
        // lower any throws/bangs inside it. Wrapping each statement in its
        // own guard -- the old behavior -- put every post-throw local in a
        // separate block scope, so a local declared after a guarded throw
        // was undefined in the following statement. A `catch` is exempt: it
        // runs ON the error (`_err_kind != 0`) and is lowered by step 6, so
        // grouping it under `_err_kind == 0` would wrongly skip it.
        if seen_throwing.and(stmt.node_type.is(NodeType.Catch).not()) {
            mut rest := Expr.new(NodeType.Body, stmt_line, stmt_col)
            for k in j..old.len() {
                rest.add_child(own old[k].clone())
            }
            process_throw_catch_in_body(ctx, rest, root_body, fdef_throws, pending, seen, types_to_declare, path, return_type, return_own_type)
            mut kind_id := Expr.new(ident_node("_err_kind"), stmt_line, stmt_col)
            mut guard_cond := make_method_call_fcall(own kind_id, "eq", stmt_line, stmt_col)
            guard_cond.add_child(own make_int_lit(0, stmt_line, stmt_col))
            mut guard := Expr.new(NodeType.If, stmt_line, stmt_col)
            guard.add_child(own guard_cond)
            guard.add_child(own rest)
            new_ch.push(own guard)
            break
        }

        // Skip nested Decls whose RHS is a FuncDef/StructDef/EnumDef.
        // Those bodies get processed when the typer visits them.
        mut is_nested_def := false
        if stmt.node_type.is(NodeType.Decl) {
            if stmt.children.len() > 0 {
                ref dr : Expr = stmt.children[0]
                if dr.node_type.is(NodeType.FuncDef)
                    .or(dr.node_type.is(NodeType.StructDef))
                    .or(dr.node_type.is(NodeType.EnumDef)) {
                    is_nested_def = true
                }
            }
        }
        if is_nested_def {
            new_ch.push_take(old, j)
            continue
        }

        // Capture pre-rewrite "could this leave _err_kind set?" for the
        // next stmt's wrap decision. Bangs don't count -- they panic and
        // reset on the error path (see subtree_has_pending_throw).
        had_throw_subtree := subtree_has_pending_throw(stmt)

        // 1. Hoist nested bangs in stmt's expression tree.
        mut pre_stmts := Vec(Expr).new()
        hoist_nested_bangs_consolidated(ctx, stmt, root_body, pre_stmts, types_to_declare, seen)
        npre := pre_stmts.len()
        for pi in 0..npre {
            new_ch.push_take(pre_stmts, pi)
        }

        // 2. Recurse into nested bodies (if / while / for / switch / catch arms).
        switch stmt.node_type {
        case NodeType.If:
            for ci in 1..stmt.children.len() {
                ref mut sub : Expr = stmt.children[ci]
                if sub.node_type.is(NodeType.Body) {
                    process_throw_catch_in_body(ctx, sub, root_body, fdef_throws, pending, seen, types_to_declare, path, return_type, return_own_type)
                }
            }
        case NodeType.While:
            if stmt.children.len() >= 2 {
                ref mut wb : Expr = stmt.children[1]
                process_throw_catch_in_body(ctx, wb, root_body, fdef_throws, pending, seen, types_to_declare, path, return_type, return_own_type)
            }
        case NodeType.ForIn:
            if stmt.children.len() >= 2 {
                ref mut fb : Expr = stmt.children[1]
                process_throw_catch_in_body(ctx, fb, root_body, fdef_throws, pending, seen, types_to_declare, path, return_type, return_own_type)
            }
        case NodeType.Switch:
            for ci in 1..stmt.children.len() {
                ref mut cn : Expr = stmt.children[ci]
                if cn.node_type.is(NodeType.Case) {
                    // #282: discover a bang guard's throw types so the
                    // function-level err slots get declared (the actual hoist
                    // runs at infer time).
                    if cn.children.len() == 3 {
                        register_bang_guard_throws(ctx, cn.children[1], root_body, types_to_declare, seen)
                    }
                    for mut ccn : Expr in cn.children {
                        if ccn.node_type.is(NodeType.Body) {
                            process_throw_catch_in_body(ctx, ccn, root_body, fdef_throws, pending, seen, types_to_declare, path, return_type, return_own_type)
                        }
                    }
                }
            }
        case NodeType.Catch:
            if stmt.children.len() == 3 {
                ref mut cbody : Expr = stmt.children[2]
                process_throw_catch_in_body(ctx, cbody, root_body, fdef_throws, pending, seen, types_to_declare, path, return_type, return_own_type)
            }
        case:
        }

        // 2b. Lower throwing calls in nested `match` arm bodies (an expression
        // form not covered by the statement-shaped recursion above).
        process_match_arms_in(ctx, stmt, root_body, fdef_throws, pending, seen, types_to_declare, path, return_type, return_own_type)

        // 3. Detect a stmt-root bang and clear the flag so step 4 sees
        // does_throw on the FCall. Bang-call-to-unknown is left in
        // place for step 4 to surface "function does not throw" via
        // validate_one_fcall_consolidated.
        ref bang_fc : Expr = find_bang_fcall(stmt)
        mut root_bang_throws := Vec(Str).new()
        if bang_fc.is_null().not() {
            found_key_root := find_callee_throws_key(ctx, bang_fc, root_body)
            if found_key_root.len() > 0 {
                ref tts_root : Vec(Str) = ctx.throws_global[found_key_root]
                for tn : Str in tts_root {
                    root_bang_throws.push(own tn.clone())
                    vec_str_push_uniq(types_to_declare, tn)
                    vec_str_push_uniq(seen, tn)
                }
                clear_bang_flag(stmt)
            }
        }

        // 4. Validate + inject err args on FCalls in stmt's tree.
        // Different stmt kinds expose their expressions in different
        // positions; recurse only into the expression slots and not
        // into nested bodies (which step 2 already covered).
        switch stmt.node_type {
        case NodeType.Decl:
            for mut sub : Expr in stmt.children {
                validate_and_inject_expr_consolidated(ctx, sub, root_body, pending, seen, types_to_declare, path)
            }
        case NodeType.Assign:
            for mut sub : Expr in stmt.children {
                validate_and_inject_expr_consolidated(ctx, sub, root_body, pending, seen, types_to_declare, path)
            }
        case NodeType.FieldAssign:
            for mut sub : Expr in stmt.children {
                validate_and_inject_expr_consolidated(ctx, sub, root_body, pending, seen, types_to_declare, path)
            }
        case NodeType.Return:
            if stmt.children.len() > 0 {
                ref mut sub : Expr = stmt.children[0]
                validate_and_inject_expr_consolidated(ctx, sub, root_body, pending, seen, types_to_declare, path)
            }
        case NodeType.FCall:
            validate_and_inject_expr_consolidated(ctx, stmt, root_body, pending, seen, types_to_declare, path)
        case NodeType.If:
            if stmt.children.len() > 0 {
                ref mut sub : Expr = stmt.children[0]
                validate_and_inject_expr_consolidated(ctx, sub, root_body, pending, seen, types_to_declare, path)
            }
        case NodeType.While:
            if stmt.children.len() > 0 {
                ref mut sub : Expr = stmt.children[0]
                validate_and_inject_expr_consolidated(ctx, sub, root_body, pending, seen, types_to_declare, path)
            }
        case NodeType.ForIn:
            if stmt.children.len() > 0 {
                ref mut sub : Expr = stmt.children[0]
                validate_and_inject_expr_consolidated(ctx, sub, root_body, pending, seen, types_to_declare, path)
            }
        case NodeType.Switch:
            if stmt.children.len() > 0 {
                ref mut sub : Expr = stmt.children[0]
                validate_and_inject_expr_consolidated(ctx, sub, root_body, pending, seen, types_to_declare, path)
            }
            for ci in 1..stmt.children.len() {
                ref mut cn : Expr = stmt.children[ci]
                if cn.node_type.is(NodeType.Case) {
                    // #282: a bang call in a case guard is lowered at infer
                    // time, not here -- skip the guard child so validate
                    // doesn't flag the surviving '!'.
                    guard_bang := cn.children.len().eq(3).and(subtree_has_bang(cn.children[1]))
                    for cci in 0..cn.children.len() {
                        if guard_bang.and(cci.eq(1)) { continue }
                        ref mut ccn : Expr = cn.children[cci]
                        if ccn.node_type.is(NodeType.Body).not() {
                            validate_and_inject_expr_consolidated(ctx, ccn, root_body, pending, seen, types_to_declare, path)
                        }
                    }
                }
            }
        case NodeType.Throw:
            if stmt.children.len() > 0 {
                ref mut sub : Expr = stmt.children[0]
                validate_and_inject_expr_consolidated(ctx, sub, root_body, pending, seen, types_to_declare, path)
            }
        case:
            for mut sub : Expr in stmt.children {
                validate_and_inject_expr_consolidated(ctx, sub, root_body, pending, seen, types_to_declare, path)
            }
        }

        // 5. Rewrite Throw -> two assigns.
        if stmt.node_type.is(NodeType.Throw) {
            if stmt.children.len() == 1 {
                throw_t := stmt.til_type()
                mut tn := ""
                if throw_t.is(Type.Unknown).not().and(throw_t.is(Type.None).not()) {
                    tn = type_to_name(throw_t)
                }
                if tn.len() == 0 {
                    tn = throw_type_name_for_with_body(stmt.children[0], root_body)
                }
                switch stmt.children[0].node_type {
                case NodeType.Ident(idn):
                    mut scan := j
                    while true {
                        ref prior_stmt : Expr = old_snapshot[scan]
                        if prior_stmt.node_type.is(NodeType.Decl) {
                            switch prior_stmt.node_type {
                            case NodeType.Decl(dd):
                                if dd.name == idn.name {
                                    if dd.explicit_type.len() > 0 {
                                        tn = dd.explicit_type.clone()
                                    } else if prior_stmt.children.len() > 0 {
                                        switch prior_stmt.children[0].node_type {
                                        case NodeType.FCall:
                                            if prior_stmt.children[0].children.len() > 0 {
                                                switch prior_stmt.children[0].children[0].node_type {
                                                case NodeType.Ident(rhsn): tn = Str.clone(rhsn.ident_name())
                                                case NodeType.FieldAccess(_rhsfa2):
                                                    if prior_stmt.children[0].children[0].children.len() > 0 {
                                                        switch prior_stmt.children[0].children[0].children[0].node_type {
                                                        case NodeType.Ident(rhsty2): tn = Str.clone(rhsty2.ident_name())
                                                        case:
                                                        }
                                                    }
                                                case:
                                                }
                                            }
                                        case NodeType.Literal(Literal.Str):
                                            tn = "Str"
                                        case NodeType.Literal(Literal.Num):
                                            tn = "I64"
                                        case:
                                        }
                                    }
                                }
                            case:
                            }
                        }
                        if tn.len().gt(0).or(scan.eq(0)) { break }
                        scan--
                    }
                    if tn.len() > 0 {
                        register_throw_type(ctx, tn)
                        tag_direct := tag_for_type(ctx, tn, Vec(Str).new())
                        if tag_direct > 0 {
                            if throw_type_has_payload(ctx, tn) {
                                new_ch.push(own make_assign_stmt(err_slot_name(tn), stmt.children[0], stmt_line, stmt_col))
                            } else {
                                ctx.throw_used_local_names.add(own idn.name.clone())
                                if is_direct_fieldless_throw_ctor(stmt.children[0], tn).not() {
                                    new_ch.push(own stmt.children[0].clone())
                                }
                            }
                            new_ch.push(own make_assign_stmt("_err_kind", make_int_lit(tag_direct, stmt_line, stmt_col), stmt_line, stmt_col))
                            vec_str_push_uniq(types_to_declare, tn)
                            vec_str_push_uniq(seen, tn)
                            pending.push(own tn.clone())
                            seen_throwing = true
                            continue
                        }
                    }
                    ctx.throw_used_local_names.add(own idn.name.clone())
                    mut scan_decl : I32 = new_ch.len().to_i32()
                    if scan_decl > 0 {
                        scan_decl--
                    }
                    while scan_decl >= 0 {
                        ref prior_stmt : Expr = new_ch[scan_decl.to_usize()]
                        switch prior_stmt.node_type {
                        case NodeType.Decl(prior_dd):
                            if prior_dd.name == idn.name {
                                prior_dd.used = true
                                if tn.len() == 0 {
                                    if prior_dd.explicit_type.len() > 0 {
                                        tn = prior_dd.explicit_type.clone()
                                    } else if prior_stmt.children.len() > 0 {
                                        ref prior_rhs : Expr = prior_stmt.children[0]
                                        switch prior_rhs.node_type {
                                        case NodeType.FCall:
                                            if prior_rhs.children.len() > 0 {
                                                switch prior_rhs.children[0].node_type {
                                                case NodeType.Ident(rhsn): tn = rhsn.name.clone()
                                                case:
                                                }
                                            }
                                        case NodeType.Literal(Literal.Str): tn = "Str"
                                        case NodeType.Literal(Literal.Num): tn = "I64"
                                        case:
                                        }
                                    }
                                }
                                scan_decl = -1
                                continue
                            }
                        case:
                        }
                        if scan_decl == 0 { break }
                        scan_decl--
                    }
                    for nstmt : Expr in new_ch {
                        switch nstmt.node_type {
                        case NodeType.Decl(ndd):
                            if ndd.name == idn.name { ndd.used = true }
                        case:
                        }
                    }
                    if tn.len() == 0 {
                        tn = guess_local_type(root_body, idn.name)
                    }
                case:
                }
                if tn.len() == 0 {
                    switch stmt.children[0].node_type {
                    case NodeType.Ident(idn):
                        tn = guess_prior_local_type_in_vec(old_snapshot, j, idn.name)
                    case:
                    }
                }
                if tn.len() > 0 { register_throw_type(ctx, tn) }
                tag := tag_for_type(ctx, tn, Vec(Str).new())
                if tn.len().gt(0).and(tag.gt(0)) {
                    if throw_type_has_payload(ctx, tn) {
                        new_ch.push(own make_assign_stmt(err_slot_name(tn), stmt.children[0], stmt_line, stmt_col))
                    } else if is_direct_fieldless_throw_ctor(stmt.children[0], tn).not() {
                        new_ch.push(own stmt.children[0].clone())
                    }
                    new_ch.push(own make_assign_stmt("_err_kind", make_int_lit(tag, stmt_line, stmt_col), stmt_line, stmt_col))
                    vec_str_push_uniq(types_to_declare, tn)
                    vec_str_push_uniq(seen, tn)
                    pending.push(own tn.clone())
                    seen_throwing = true
                    continue
                }
            }
            new_ch.push_take(old, j)
            if had_throw_subtree { seen_throwing = true }
            continue
        }

        // 6. Rewrite Catch -> if-block.
        if stmt.node_type.is(NodeType.Catch) {
            if stmt.children.len() == 3 {
                mut ctype := ""
                switch stmt.children[1].node_type {
                case NodeType.Ident(n): ctype = Str.clone(n.ident_name())
                case:
                }
                if ctype.len() > 0 {
                    mut matched := pending_remove_all_matching(pending, ctype)
                    if matched.not().and(has_prior_throw_type_in_vec(old_snapshot, root_body, j, ctype)) {
                        matched = true
                    }
                    if matched.not() {
                        type_error_at(path, stmt_line, stmt_col,
                            format("trying to catch '", ctype, "', but it is not among the thrown types"), ctx)
                    }
                    vec_str_push_uniq(types_to_declare, ctype)
                }
                new_ch.push(own lower_catch_node(ctx, stmt, Vec(Str).new()))
                seen_throwing = false
                continue
            } else {
                type_error_at(path, stmt_line, stmt_col, "catch must have 3 parameters: variable, type, and body", ctx)
                new_ch.push_take(old, j)
                continue
            }
        }

        // 7. Stmt-root bang: emit the (?-call) stmt then lowered checks.
        // For `return f()!`, hoist into a temp so checks run BEFORE the
        // return (otherwise unreachable).
        if root_bang_throws.len() > 0 {
            if stmt.node_type.is(NodeType.Return) {
                tmp_name := format("_bang_ret_", ctx.bang_counter.to_str())
                ctx.bang_counter = ctx.bang_counter + 1
                // Carry the function's declared return type/ownership onto
                // the hoisted temp Decl. Vec.get / Array.get return
                // ref Dynamic; without an explicit type the temp Decl
                // errors with "cannot store Dynamic". The return position's
                // expected type is the function's return_type, so use it.
                mut tmp_decl_data := Declaration(name = tmp_name.clone())
                if return_type.len() > 0 {
                    tmp_decl_data.explicit_type = return_type.clone()
                    tmp_decl_data.til_type = til_type_from_explicit_type(return_type)
                    // Locals are owned by default; only mark Ref-returning
                    // funcs as ref so we don't trip the "no need for 'own'"
                    // diagnostic on the synthesized temp.
                    if return_own_type.is(OwnType.Ref) {
                        tmp_decl_data.own_type = return_own_type
                    }
                }
                mut tmp_decl := Expr.new(NodeType.Decl(tmp_decl_data), stmt_line, stmt_col)
                tmp_decl.add_child(own stmt.children[0].clone())
                new_ch.push(own tmp_decl)
                for tn : Str in root_bang_throws {
                    new_ch.push(own build_bang_lowered(ctx, tn, stmt_line, stmt_col))
                    _matched_b1 := pending_remove_all_matching(pending, tn)
                }
                mut new_ret := Expr.new(NodeType.Return, stmt_line, stmt_col)
                new_ret.add_child(own Expr.new(ident_node(tmp_name), stmt_line, stmt_col))
                new_ch.push(own new_ret)
                // The lowered bang checks both panic AND reset
                // _err_kind = 0 on the error path, so subsequent
                // stmts don't need wrapping.
                seen_throwing = false
                continue
            }
            if seen_throwing {
                mut wrapped := make_if_kind_eq_zero_wrap(stmt, stmt_line, stmt_col)
                new_ch.push(own wrapped)
            } else {
                new_ch.push_take(old, j)
            }
            for tn : Str in root_bang_throws {
                new_ch.push(own build_bang_lowered(ctx, tn, stmt_line, stmt_col))
                _matched_b2 := pending_remove_all_matching(pending, tn)
            }
            seen_throwing = false
            continue
        }

        // 8. Generic stmt: push (possibly wrapped in if-guard).
        if seen_throwing {
            mut wrapped := make_if_kind_eq_zero_wrap(stmt, stmt_line, stmt_col)
            new_ch.push(own wrapped)
        } else {
            new_ch.push_take(old, j)
        }
        if had_throw_subtree { seen_throwing = true }
    }

    body.children.move_from(new_ch)
}

// Function-body wrapper for the single-walk consolidated processing.
// Runs the per-body walk, then prepends slot decls for any throw
// types touched and (for throwing functions) appends a fallback
// return so all C paths return.
process_throw_catch_in_func_body := proc(
    mut ctx: Context,
    mut body: Expr,
    fdef_throws: Vec(Str),
    return_type: Str,
    return_own_type: OwnType
) {
    has_body_throw_catch := subtree_has_throw_catch(body)
    has_fdef_throws := fdef_throws.len() > 0
    has_body_bang := subtree_has_bang(body)
    if has_body_throw_catch.not()
        .and(has_fdef_throws.not())
        .and(has_body_bang.not()) { return }

    // Pre-pass: annotate every Throw with its resolved type so the
    // body walk can read stmt.til_type() directly during rewriting.
    if has_body_throw_catch {
        annotate_throw_types_in(body, body)
        annotate_throw_ident_expr_types(body, body)
    }

    mut pending := Vec(Str).new()
    mut seen := Vec(Str).new()
    mut types_to_declare := Vec(Str).new()
    ctx.throw_used_local_names = Set(Str).new()
    collect_throw_ident_names(body, ctx.throw_used_local_names)
    // Seed with declared throws so the slots exist as params even
    // when the body never references the type directly (rare, but
    // possible if a function declares `throws T` and reraises via
    // a ?-call that propagates without ever naming T literally).
    for ft : Str in fdef_throws {
        vec_str_push_uniq(types_to_declare, ft)
    }

    root_body := body.clone()
    process_throw_catch_in_body(ctx, body, root_body, fdef_throws, pending, seen, types_to_declare, ctx.path, return_type, return_own_type)

    // Final body-level validation: leftover pending types must be
    // declared, and every declared throws entry must have been seen.
    for tn : Str in pending {
        if vec_str_contains(fdef_throws, tn).not() {
            type_error_at(ctx.path, body.line, body.col,
                format("function may throw '", tn, "' but it is not in the throws clause; declare 'throws ", tn, "' or catch it"), ctx)
        }
    }
    for dt : Str in fdef_throws {
        if vec_str_contains(seen, dt).not() {
            type_error_at(ctx.path, body.line, body.col,
                format("'throws ", dt, "' is declared but '", dt, "' is never thrown -- remove it from the throws clause"), ctx)
        }
    }

    if types_to_declare.len() == 0 { return }

    // Prepend slot decls and append fallback return.
    line := body.line
    col := body.col
    mut old := Vec(Expr).new()
    old.move_from(body.children)
    mut new_ch := Vec(Expr).new()

    if has_fdef_throws.not() {
        new_ch.push(own make_typed_mut_decl("_err_kind", "I64",
            make_int_lit(0, line, col), line, col))
    }
    for tn : Str in types_to_declare {
        mut is_param := false
        for ft : Str in fdef_throws {
            if ft == tn { is_param = true }
        }
        if is_param.not().and(throw_type_has_payload(ctx, tn)) {
            new_ch.push(own make_typed_mut_decl(err_slot_name(tn), tn,
                make_default_value_expr(tn, line, col), line, col))
        }
    }
    for j in 0..old.len() {
        new_ch.push_take(old, j)
    }
    // Append a fallback return so every C path returns. Ref-returning
    // throwing fns get `return null` (no constructible borrow exists);
    // check_ref_function_returns allows that null since it is unreachable
    // on the success path and unused on the error path (the err code
    // flows out through the out-param).
    if has_fdef_throws.and(return_type.len().gt(0)) {
        mut ret := Expr.new(NodeType.Return, line, col)
        if return_own_type.is(OwnType.Ref) {
            ret.add_child(own Expr.new(NodeType.Literal(Literal.Null), line, col))
        } else {
            ret.add_child(own make_default_value_expr(return_type, line, col))
        }
        new_ch.push(own ret)
    }
    body.children.move_from(new_ch)
}
// True if `e` contains a Match node reachable without crossing into a nested
// block/definition (those sub-bodies are lowered when infer_body recurses
// into them). Stops at a Match (its arms are handled by lowering, not here).
stmt_contains_match := func(e: Expr) returns Bool {
    switch e.node_type {
    case NodeType.Match:     return true
    case NodeType.Body:      return false
    case NodeType.FuncDef:   return false
    case NodeType.StructDef: return false
    case NodeType.EnumDef:   return false
    // #282: a switch/match `Case`'s guard and body are conditionally
    // evaluated -- a match there (e.g. from a lazy `&&`/`and` desugar) must
    // be lowered into the pattern-gated position by infer_switch_stmt, NOT
    // hoisted before the whole switch. The body is a Body (already skipped);
    // stop at the Case so the guard is skipped too. Scrutinee matches (child
    // 0 of the Switch/Match, not under a Case) are still hoisted.
    case NodeType.Case:      return false
    case:
    }
    for c : Expr in e.children {
        if stmt_contains_match(c) { return true }
    }
    return false
}

// Insert `pre`'s statements into body.children just before index `idx`,
// preserving order. Mirrors the rebuild used by body_pre_passes.
splice_stmts_before := func(mut body: Expr, idx: USize, mut pre: Vec(Expr)) {
    if pre.len() == 0 { return }
    mut old := Vec(Expr).new()
    old.move_from(body.children)
    mut nw := Vec(Expr).new()
    for j in 0..idx { nw.push_take(old, j) }
    for k in 0..pre.len() { nw.push_take(pre, k) }
    for j in idx..old.len() { nw.push_take(old, j) }
    body.children.move_from(nw)
}

// Look up the payload type for a variant of a named enum, by enum
// name and variant name. Returns "" if either is unknown. Used by
// collect_switch_case_bindings to translate a `case E.V(x):` pattern
// into the type that binding `x` will carry once the case-body
// payload Decl is emitted.
priv lookup_variant_payload_type := func(scope: TypeScope, enum_name: Str, variant_name: Str) returns Str {
    ref edef : Expr = scope.get_struct(enum_name)
    if edef.is_null() { return "" }
    switch edef.node_type {
    case NodeType.EnumDef(edd):
        for vd : VariantDef in edd.variants {
            if vd.name == variant_name {
                return vd.payload_type.clone()
            }
        }
    case:
    }
    return ""
}

// Walk a function body and seed ctx.lowering_param_types with the
// names + payload types bound by switch-case patterns. The
// throw/catch lowering pass runs before infer_body emits the
// case-body payload Decls (via make_switch_case_condition), so the
// body-Decl scan in resolve_value_type can't see them yet.
// Without this seeding, a `case NodeType.EnumDef(ed):` body that
// does `ed.payload_types[idx]!` resolves `ed`'s type as "" and the
// throws lookup falls back to suffix-matching ".get", picking the
// wrong throw type (Array.get's OutOfBounds instead of Map.get's
// KeyNotFound).
collect_switch_case_bindings := proc(mut ctx: Context, e: Expr) {
    if e.node_type.is(NodeType.Case).and(e.children.len().gte(1)) {
        ref pat : Expr = e.children[0]
        // Pattern shape: FCall(<EnumName>.<Variant>, <binding_ident>)
        if pat.node_type.is(NodeType.FCall).and(pat.children.len().eq(2)) {
            ref callee : Expr = pat.children[0]
            ref bind : Expr = pat.children[1]
            if callee.node_type.is(NodeType.FieldAccess).and(callee.children.len().gt(0))
              .and(bind.node_type.is(NodeType.Ident)) {
                ref enum_recv : Expr = callee.children[0]
                switch enum_recv.node_type {
                case NodeType.Ident(en_id):
                    switch callee.node_type {
                    case NodeType.FieldAccess(fa):
                        switch bind.node_type {
                        case NodeType.Ident(b_id):
                            payload_type := lookup_variant_payload_type(ctx.scope, en_id.ident_name(), fa.field_access_name())
                            if payload_type.len() > 0 {
                                ctx.lowering_param_types.set(b_id.ident_name(), own payload_type)
                            }
                        case:
                        }
                    case:
                    }
                case:
                }
            }
        }
    }
    for c : Expr in e.children {
        collect_switch_case_bindings(ctx, c)
    }
}

// Fold a Vec of conditions into a left-associative `.and()` chain.
// Empty -> LiteralBool(true). Otherwise read by clone (the Vec is left
// untouched for the caller to drop normally).
priv fold_and_chain := func(conds: Vec(Expr), line: U32, col: U32) returns Expr {
    if conds.len() == 0 {
        return Expr.new(NodeType.Literal(Literal.Bool(true)), line, col)
    }
    ref first_c : Expr = conds[0]
    if conds.len() == 1 {
        return first_c.clone()
    }
    mut acc := first_c.clone()
    for fi in 1..conds.len() {
        mut next_chain := make_method_call_fcall(own acc.clone(), "and", line, col)
        ref next_c : Expr = conds[fi]
        next_chain.add_child(own next_c.clone())
        acc = next_chain.clone()
    }
    return acc.clone()
}

make_switch_case_condition := func(scope: TypeScope, mut case_body: Expr, match_expr: Expr, sw_ref: Expr, sw_line: U32, sw_col: U32) returns Expr {
    mut condition := Expr.new(NodeType.Body, sw_line, sw_col)
    mut has_condition := false
    if match_expr.node_type.is(NodeType.FCall) {
        if match_expr.children.len() == 3 {
            switch match_expr.children[0].node_type {
            case NodeType.FieldAccess(method_name):
                if method_name.field_access_name() == "new" {
                    if match_expr.children[0].children.len() > 0 {
                        switch match_expr.children[0].children[0].node_type {
                        case NodeType.Ident(range_name):
                            if range_name.ident_name() == "Range" {
                                ref start_expr : Expr = match_expr.children[1]
                                ref end_expr : Expr = match_expr.children[2]

                                mut sw1 := sw_ref.clone()
                                mut gte_call := make_method_call_fcall(own sw1, "gte", sw_line, sw_col)
                                gte_call.add_child(own start_expr.clone())

                                mut sw2 := sw_ref.clone()
                                mut lte_call := make_method_call_fcall(own sw2, "lte", sw_line, sw_col)
                                lte_call.add_child(own end_expr.clone())

                                condition = make_method_call_fcall(own gte_call, "and", sw_line, sw_col)
                                condition.add_child(own lte_call)
                                has_condition = true
                            }
                        case:
                        }
                    }
                }
            case:
            }
        }
    }

    if has_condition.not() {
        if match_expr.node_type.is(NodeType.FCall) {
            if match_expr.children.len() == 2 {
                if match_expr.children[0].node_type.is(NodeType.FieldAccess) {
                    if match_expr.children[0].children.len() > 0 {
                        if match_expr.children[0].children[0].node_type.is(NodeType.Ident) {
                            if match_expr.children[1].node_type.is(NodeType.Ident) {
                                ref callee : Expr = match_expr.children[0]
                                mut type_name := ""
                                mut variant_name := ""
                                mut binding_name := ""
                                switch callee.children[0].node_type {
                                case NodeType.Ident(tn):
                                    type_name = Str.clone(tn.ident_name())
                                case:
                                }
                                switch callee.node_type {
                                case NodeType.FieldAccess(vn):
                                    variant_name = Str.clone(vn.field_access_name())
                                case:
                                }
                                switch match_expr.children[1].node_type {
                                case NodeType.Ident(bn):
                                    binding_name = Str.clone(bn.ident_name())
                                case:
                                }
                                ref enum_def : Expr = scope.get_struct(type_name)
                                // Nested if rather than `.and(...)`: til's
                                // `.and` is strict, so a single combined check
                                // would still deref `enum_def.node_type` when
                                // `enum_def` is NULL (e.g. cross-file priv).
                                if enum_def.is_null().not() {
                                if enum_def.node_type.is(NodeType.EnumDef) {
                                    vt_idx := enum_variant_index(enum_def, variant_name)
                                    mut payload_type := ""
                                    if vt_idx >= 0 {
                                        payload_type = enum_variant_type(enum_def, vt_idx)
                                    }
                                    if payload_type.len() > 0 {
                                        // #264: width-correct tag comparison via is_n.
                                        sw_tag_sz := enum_tag_size(enum_def)
                                        mut iv_id := Expr.new(ident_node("is_n"), sw_line, sw_col)
                                        mut sw_id := sw_ref.clone()
                                        mut vtype_id := Expr.new(ident_node(type_name), sw_line, sw_col)
                                        mut vref := Expr.new(field_access_node(variant_name), sw_line, sw_col)
                                        vref.add_child(own vtype_id)
                                        condition = Expr.new(NodeType.FCall(FCallData()), sw_line, sw_col)
                                        condition.add_child(own iv_id)
                                        condition.add_child(own sw_id)
                                        condition.add_child(own vref)
                                        mut sw_sz_lit := Expr.new(literal_num_node(sw_tag_sz.to_str()), sw_line, sw_col)
                                        condition.add_child(own sw_sz_lit)

                                        mut sw_id2 := sw_ref.clone()
                                        // #211: payload binding inherits the matched value's
                                        // mutability AND the variant's payload const-ness.
                                        // `mut e; case V(p): p = ...` works iff e is mut and the
                                        // variant payload was NOT declared `const`.
                                        mut source_mut := false
                                        switch sw_ref.node_type {
                                        case NodeType.Ident(sw_idn):
                                            ref sw_b : TypeBinding = scope.get_binding(sw_idn.ident_name())
                                            if sw_b.is_null().not() { source_mut = sw_b.is_mut }
                                        case:
                                        }
                                        payload_const := enum_variant_payload_const(enum_def, vt_idx)
                                        bind_is_mut := source_mut.and(payload_const.not())
                                        // #164: a ref-mut payload binding allows writes that
                                        // propagate back into the source's payload memory, so
                                        // treat the source as conservatively written.
                                        if bind_is_mut {
                                            switch sw_ref.node_type {
                                            case NodeType.Ident(sw_idn2):
                                                ref mut sw_b2 : TypeBinding = scope.get_binding(sw_idn2.ident_name())
                                                if sw_b2.is_null().not() { sw_b2.written = true }
                                            case:
                                            }
                                        }
                                        bind_ln := match_expr.children[1].line
                                        bind_cl := match_expr.children[1].col
                                        fresh := format("_pl_", binding_name, "_", bind_ln.to_str(), "_", bind_cl.to_str())
                                        mut bind_decls := make_payload_ref_decls(own sw_id2, binding_name, fresh, payload_type, sw_line, sw_col, bind_is_mut)

                                        mut old := Vec(Expr).new()
                                        old.move_from(case_body.children)

                                        mut new_ch := Vec(Expr).new()
                                        for bd in 0..bind_decls.len() {
                                            new_ch.push_take(bind_decls, bd)
                                        }
                                        for bi in 0..old.len() {
                                            new_ch.push_take(old, bi)
                                        }
                                    case_body.children.move_from(new_ch)
                                        has_condition = true
                                    }
                                }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // Issue #36: nested pattern matching. `case Outer.A(Inner.B(val))` and
    // `case Outer.A(Inner.B)` desugar to a conjunction:
    //   sw.is(Outer.A).and(get_payload(sw, Inner).is(Inner.B))
    // Any deeper binding inside `inner` desugars recursively against
    // ~get_payload(sw, Inner)~ as the new sw_ref; ~.and~ is eager but
    // ~get_payload~ is pure pointer arithmetic on the enum's union storage,
    // so reading the second operand when the outer tag is wrong is harmless
    // (just garbage bytes) and the outer false short-circuits the body.
    if has_condition.not() {
        if match_expr.node_type.is(NodeType.FCall) {
            if match_expr.children.len() == 2 {
                if match_expr.children[0].node_type.is(NodeType.FieldAccess) {
                    if match_expr.children[0].children.len() > 0 {
                        if match_expr.children[0].children[0].node_type.is(NodeType.Ident) {
                            ref inner_pat : Expr = match_expr.children[1]
                            if inner_pat.node_type.is(NodeType.Ident).not() {
                                ref callee3 : Expr = match_expr.children[0]
                                mut type_name3 := ""
                                mut variant_name3 := ""
                                switch callee3.children[0].node_type {
                                case NodeType.Ident(tn3): type_name3 = Str.clone(tn3.ident_name())
                                case:
                                }
                                switch callee3.node_type {
                                case NodeType.FieldAccess(vn3): variant_name3 = Str.clone(vn3.field_access_name())
                                case:
                                }
                                ref enum_def3 : Expr = scope.get_struct(type_name3)
                                // Nested if rather than `.and(...)`: see the
                                // matching note in the eager-pattern branch
                                // above. til's `.and` is strict.
                                if enum_def3.is_null().not() {
                                if enum_def3.node_type.is(NodeType.EnumDef) {
                                    vt_idx3 := enum_variant_index(enum_def3, variant_name3)
                                    mut payload_type3 := ""
                                    if vt_idx3 >= 0 {
                                        payload_type3 = enum_variant_type(enum_def3, vt_idx3)
                                    }
                                    if payload_type3.len() > 0 {
                                        // outer condition: sw_ref.is(Type.Variant)
                                        // #264: width-correct tag comparison via is_n.
                                        sw_tag_sz3 := enum_tag_size(enum_def3)
                                        mut iv_id3 := Expr.new(ident_node("is_n"), sw_line, sw_col)
                                        mut sw_id3 := sw_ref.clone()
                                        mut vtype_id3 := Expr.new(ident_node(type_name3), sw_line, sw_col)
                                        mut vref3 := Expr.new(field_access_node(variant_name3), sw_line, sw_col)
                                        vref3.add_child(own vtype_id3)
                                        mut outer_cond3 := Expr.new(NodeType.FCall(FCallData()), sw_line, sw_col)
                                        outer_cond3.add_child(own iv_id3)
                                        outer_cond3.add_child(own sw_id3)
                                        outer_cond3.add_child(own vref3)
                                        mut sw_sz_lit3 := Expr.new(literal_num_node(sw_tag_sz3.to_str()), sw_line, sw_col)
                                        outer_cond3.add_child(own sw_sz_lit3)

                                        // inner sw_ref: get_payload(sw_ref, payload_type)
                                        mut sw_for_gp := sw_ref.clone()
                                        inner_sw_ref := make_get_payload_fcall(own sw_for_gp, til_type_from_explicit_type(payload_type3), sw_line, sw_col)

                                        // Recurse on the nested pattern; bindings prepend to case_body
                                        // and use ~get_payload(sw_ref, payload_type)~ as their root.
                                        inner_cond3 := make_switch_case_condition(scope, case_body, inner_pat, inner_sw_ref, sw_line, sw_col)

                                        // Combined: outer_cond.and(inner_cond)
                                        condition = make_method_call_fcall(own outer_cond3, "and", sw_line, sw_col)
                                        condition.add_child(own inner_cond3)
                                        has_condition = true
                                    }
                                }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    if has_condition.not() {
        if match_expr.node_type.is(NodeType.FieldAccess) {
            if match_expr.children.len() > 0 {
                if match_expr.children[0].node_type.is(NodeType.Ident) {
                    mut type_name := ""
                    mut variant_name := ""
                    switch match_expr.children[0].node_type {
                    case NodeType.Ident(tn):
                        type_name = Str.clone(tn.ident_name())
                    case:
                    }
                    switch match_expr.node_type {
                    case NodeType.FieldAccess(vn):
                        variant_name = Str.clone(vn.field_access_name())
                    case:
                    }
                    ref enum_def : Expr = scope.get_struct(type_name)
                    // Nested if rather than `.and(...)`: see matching notes
                    // above. til's `.and` is strict.
                    if enum_def.is_null().not() {
                    if enum_def.node_type.is(NodeType.EnumDef) {
                        vt_idx2 := enum_variant_index(enum_def, variant_name)
                        if vt_idx2 >= 0 {
                            // `case Variant` (no payload binding) -> sw.is(Type.Variant).
                            // Use .is rather than .eq so the desugared check is a
                            // tag-only comparison and never recurses through a
                            // user-defined eq (which is itself often defined as a
                            // switch -- e.g. Value.eq).
                            // #264: width-correct tag comparison via is_n.
                            sw_tag_sz := enum_tag_size(enum_def)
                            mut iv_id := Expr.new(ident_node("is_n"), sw_line, sw_col)
                            mut sw_id := sw_ref.clone()
                            mut vtype_id := Expr.new(ident_node(type_name), sw_line, sw_col)
                            mut vref := Expr.new(field_access_node(variant_name), sw_line, sw_col)
                            vref.add_child(own vtype_id)
                            condition = Expr.new(NodeType.FCall(FCallData()), sw_line, sw_col)
                            condition.add_child(own iv_id)
                            condition.add_child(own sw_id)
                            condition.add_child(own vref)
                            mut sw_sz_lit := Expr.new(literal_num_node(sw_tag_sz.to_str()), sw_line, sw_col)
                            condition.add_child(own sw_sz_lit)
                            has_condition = true
                        }
                    }
                    }
                }
            }
        }
    }

    // Issue #36: struct field matching. `case Point(x = 0, y = ny):` desugars
    // each `field = literal` to ~sw.field.eq(literal)~ ANDed into the case
    // condition, and each `field = ident` to ~ref ident := sw.field~ prepended
    // to the body. Nested struct/enum patterns inside a field value recurse.
    // Detected by FCall with an Ident callee (a struct/type name) where every
    // non-callee child is a NamedArg or a RestPattern. `..` is required if
    // any field is omitted; without it the typer errors so callers can't
    // silently leave a field unconstrained.
    if has_condition.not() {
        if match_expr.node_type.is(NodeType.FCall) {
            if match_expr.children.len() > 0 {
                if match_expr.children[0].node_type.is(NodeType.Ident) {
                    mut sp_type_name := ""
                    switch match_expr.children[0].node_type {
                    case NodeType.Ident(spn): sp_type_name = Str.clone(spn.ident_name())
                    case:
                    }
                    mut all_named := true
                    for sp_ci in 1..match_expr.children.len() {
                        ref sp_child : Expr = match_expr.children[sp_ci]
                        if sp_child.node_type.is(NodeType.RestPattern).not()
                            .and(sp_child.node_type.is(NodeType.NamedArg).not()) {
                            all_named = false
                        }
                    }
                    mut is_struct := false
                    if all_named {
                        ref sp_def : Expr = scope.get_struct(sp_type_name)
                        if sp_def.is_null().not() {
                            if sp_def.node_type.is(NodeType.StructDef) {
                                is_struct = true
                            }
                        }
                    }
                    if is_struct {
                        mut sp_conds := Vec(Expr).new()
                        mut sp_bindings := Vec(Expr).new()
                        for sp_ci2 in 1..match_expr.children.len() {
                            ref na : Expr = match_expr.children[sp_ci2]
                            if na.node_type.is(NodeType.RestPattern) { continue }
                            mut field_name := ""
                            switch na.node_type {
                            case NodeType.NamedArg(fn): field_name = fn.clone()
                            case:
                            }
                            if na.children.len() == 0 { continue }
                            ref field_pat : Expr = na.children[0]
                            if field_pat.node_type.is(NodeType.Ident) {
                                // `field = ident` is a binding -> ref bind_name := sw.field_name
                                mut bind_name := ""
                                switch field_pat.node_type {
                                case NodeType.Ident(bn): bind_name = Str.clone(bn.ident_name())
                                case:
                                }
                                mut field_acc_bind := Expr.new(field_access_node(field_name), sw_line, sw_col)
                                field_acc_bind.add_child(own sw_ref.clone())
                                mut bind_decl := Expr.new(NodeType.Decl(Declaration(name = bind_name.clone(), own_type = OwnType.Ref)), sw_line, sw_col)
                                bind_decl.add_child(own field_acc_bind)
                                sp_bindings.push(own bind_decl)
                            } else {
                                // Value match (literal/expr) or nested pattern.
                                // Recurse with sw_ref = sw.field_name; the recursive
                                // call may itself prepend bindings to case_body.
                                mut field_acc_match := Expr.new(field_access_node(field_name), sw_line, sw_col)
                                field_acc_match.add_child(own sw_ref.clone())
                                sub_cond := make_switch_case_condition(scope, case_body, field_pat, field_acc_match, sw_line, sw_col)
                                sp_conds.push(own sub_cond)
                            }
                        }
                        // Prepend bindings (in source order) before any existing
                        // case_body statements -- including bindings that
                        // recursive value-match calls may have prepended for
                        // their own nested patterns.
                        if sp_bindings.len() > 0 {
                            mut old_body := Vec(Expr).new()
                            old_body.move_from(case_body.children)
                            mut new_body := Vec(Expr).new()
                            for spi in 0..sp_bindings.len() {
                                new_body.push_take(sp_bindings, spi)
                            }
                            for obi in 0..old_body.len() {
                                new_body.push_take(old_body, obi)
                            }
                            case_body.children.move_from(new_body)
                        }
                        // Fold conds into a left-associative AND chain.
                        condition = fold_and_chain(sp_conds, sw_line, sw_col)
                        has_condition = true
                    }
                }
            }
        }
    }

    if has_condition.not() {
        mut sw_ident := sw_ref.clone()
        condition = make_method_call_fcall(own sw_ident, "eq", sw_line, sw_col)
        condition.add_child(own match_expr.clone())
    }
    return condition
}

replace_switch_stmt_with_block := func(mut body: Expr, stmt_idx: USize, own block: Expr) {
    body.children[stmt_idx] = block
}

append_switch_else_if := proc(mut root_if: Expr, if_node: Expr) {
    if root_if.children.len() > 2 {
        ref mut else_body : Expr = root_if.children[2]
        if else_body.children.len() > 0 {
            if else_body.children[0].node_type.is(NodeType.If) {
                append_switch_else_if(else_body.children[0], if_node)
                return
            }
        }
    }
    mut else_body := Expr.new(NodeType.Body, if_node.line, if_node.col)
    else_body.add_child(own if_node.clone())
    root_if.add_child(own else_body)
}

attach_switch_default_body := proc(mut root_if: Expr, default_body: Expr) {
    if root_if.children.len() > 2 {
        ref mut else_body : Expr = root_if.children[2]
        if else_body.children.len() > 0 {
            if else_body.children[0].node_type.is(NodeType.If) {
                attach_switch_default_body(else_body.children[0], default_body)
                return
            }
        }
    }
    root_if.add_child(own default_body.clone())
}

// #254: a til `break` inside a switch case targets the ENCLOSING loop, but a
// C `switch` captures `break`. Detect a break reachable from `e` without
// crossing an inner loop boundary; such a switch must stay desugared so the
// if/elif lowering routes the break to the loop. `continue` needs no guard:
// C `continue` is not captured by `switch`.
priv expr_has_unguarded_break := func(e: Expr) returns Bool {
    if e.node_type.is(NodeType.Break) { return true }
    if e.node_type.is(NodeType.While) { return false }
    if e.node_type.is(NodeType.ForIn) { return false }
    for c : Expr in e.children {
        if expr_has_unguarded_break(c) { return true }
    }
    return false
}

// #254: a switch is "C-like" -- emittable as a real C `switch (expr) { case K:
// }` -- when the scrutinee is an integer/char and every case is a bare
// constant integer/char literal (no payload binding, range, guard, or string)
// whose body holds no loop-targeting `break`. Such switches are left as
// Switch/Case nodes for the backends; everything else desugars to if/elif.
switch_is_clike := func(scope: TypeScope, stmt: Expr, sw_expr: Expr, is_match: Bool) returns Bool {
    if is_match { return false }
    sw_type := sw_expr.til_type()
    sw_sname := til_type_name(sw_type)
    mut is_enum := false
    mut is_bool := false
    if sw_type.is(Type.Enum) {
        if sw_sname.len() == 0 { return false }
        // Only a simple lvalue scrutinee (ident / field access) emits as a
        // value whose `.tag` the C switch can read; a constructor call etc.
        // emits as a pointer, so leave those to the desugar.
        if is_simple_lvalue_expr(sw_expr).not() { return false }
        ref edef0 : Expr = scope.get_struct(sw_sname)
        if edef0.is_null() { return false }
        if edef0.node_type.is(NodeType.EnumDef).not() { return false }
        is_enum = true
    } else if type_is_primitive(sw_type, Primitive.Bool) {
        is_bool = true
    } else if is_integral_numeric_type(sw_type).not() {
        return false
    }
    mut seen_default := false
    mut labels := Vec(Str).new()
    for ci in 1..stmt.children.len() {
        ref cn : Expr = stmt.children[ci]
        if cn.node_type.is(NodeType.Case).not() { return false }
        if cn.children.len() == 1 {
            if seen_default { return false }
            seen_default = true
            if expr_has_unguarded_break(cn.children[0]) { return false }
            continue
        }
        if seen_default { return false }
        if cn.children.len() != 2 { return false }
        ref pat : Expr = cn.children[0]
        mut lit_text := ""
        mut is_range := false
        if is_enum {
            // Accept a bare variant `Type.Variant` (FieldAccess) OR a single
            // payload binding `Type.Variant(x)` (#276: FCall with a FieldAccess
            // callee and one bare-Ident arg). The base must name the
            // scrutinee's enum and the variant must exist; a payload binding
            // additionally requires the variant to carry a payload. Guards,
            // ranges, nested/struct patterns, and multi-arg payloads still fall
            // back to the desugar.
            mut vname := ""
            mut base_ok := false
            mut needs_payload := false
            switch pat.node_type {
            case NodeType.FieldAccess(fa):
                vname = Str.clone(fa.field_access_name())
                if pat.children.len() > 0 {
                    switch pat.children[0].node_type {
                    case NodeType.Ident(bn): base_ok = bn.ident_name() == sw_sname
                    case:
                    }
                }
            case NodeType.FCall:
                if pat.children.len() != 2 { return false }
                if pat.children[1].node_type.is(NodeType.Ident).not() { return false }
                ref callee : Expr = pat.children[0]
                if callee.node_type.is(NodeType.FieldAccess).not() { return false }
                switch callee.node_type {
                case NodeType.FieldAccess(fa2): vname = Str.clone(fa2.field_access_name())
                case:
                }
                if callee.children.len() > 0 {
                    switch callee.children[0].node_type {
                    case NodeType.Ident(bn2): base_ok = bn2.ident_name() == sw_sname
                    case:
                    }
                }
                needs_payload = true
            case: return false
            }
            if base_ok.not() { return false }
            ref edef1 : Expr = scope.get_struct(sw_sname)
            vidx := enum_variant_index(edef1, vname)
            if vidx < 0 { return false }
            if needs_payload.and(enum_variant_type(edef1, vidx).len().eq(0)) { return false }
            lit_text = vname.clone()
        } else if is_bool {
            switch pat.node_type {
            case NodeType.Literal(Literal.Bool(bv)):
                if bv { lit_text = "true" } else { lit_text = "false" }
            case: return false
            }
        } else {
            // int/char: a constant literal, or a `lo..hi` range (Range.new
            // FCall with int/char-literal bounds) emitted as a C case range.
            switch pat.node_type {
            case NodeType.Literal(Literal.Num(num)): lit_text = num.literal_num_text()
            case NodeType.FCall:
                if is_range_new_call(pat).not() { return false }
                if pat.children[1].node_type.is_literal_num().not() { return false }
                if pat.children[2].node_type.is_literal_num().not() { return false }
                is_range = true
            case: return false
            }
        }
        // Dedup constant labels (C rejects duplicates); ranges are left to the
        // C compiler to reject on overlap.
        if is_range.not() {
            for lbl : Str in labels {
                if lbl == lit_text { return false }
            }
            labels.push(own lit_text.clone())
        }
        if expr_has_unguarded_break(cn.children[1]) { return false }
    }
    return true
}

// #276: root Ident name of a simple lvalue (`x` -> "x", `a.b.c` -> "a"); ""
// for anything else. Used to mark a switch scrutinee's root binding written.
priv lvalue_root_name := func(e: Expr) returns Str {
    switch e.node_type {
    case NodeType.Ident(id): return Str.clone(id.ident_name())
    case NodeType.FieldAccess:
        if e.children.len() == 1 { return lvalue_root_name(e.children[0]) }
        return ""
    case: return ""
    }
}

// #276: for a payload-binding C-like enum case `Type.V(x)`, prepend the
// `ref x := get_payload(scrutinee, T)` decl to the case body (mirroring
// make_switch_case_condition's #211/#164 binding logic) so the body type-checks
// with x in scope. The C switch label stays the variant tag; the binding rides
// the case body as an ordinary statement both backends already handle.
prepend_clike_payload_binding := func(scope: TypeScope, sw_expr: Expr, mut case_node: Expr, sw_sname: Str) {
    ref pat : Expr = case_node.children[0]
    if pat.node_type.is(NodeType.FCall).not() { return }
    if pat.children.len() != 2 { return }
    ref callee : Expr = pat.children[0]
    mut variant_name := ""
    switch callee.node_type {
    case NodeType.FieldAccess(vn): variant_name = Str.clone(vn.field_access_name())
    case: return
    }
    mut binding_name := ""
    switch pat.children[1].node_type {
    case NodeType.Ident(bn): binding_name = Str.clone(bn.ident_name())
    case: return
    }
    ref enum_def : Expr = scope.get_struct(sw_sname)
    if enum_def.is_null() { return }
    vt_idx := enum_variant_index(enum_def, variant_name)
    if vt_idx < 0 { return }
    payload_type := enum_variant_type(enum_def, vt_idx)
    if payload_type.len() == 0 { return }
    mut source_mut := false
    switch sw_expr.node_type {
    case NodeType.Ident(sw_idn):
        ref sw_b : TypeBinding = scope.get_binding(sw_idn.ident_name())
        if sw_b.is_null().not() { source_mut = sw_b.is_mut }
    case:
    }
    payload_const := enum_variant_payload_const(enum_def, vt_idx)
    bind_is_mut := source_mut.and(payload_const.not())
    // Mark the scrutinee's root binding written: the case body holds a `ref`
    // into the scrutinee's payload (get_payload) and may write through it
    // (e.g. set_own_arg's `fcd.own_args = ...`). The desugar marks the source
    // written too; do it here for both `x` and `x.field` scrutinees so a `mut`
    // param/local is not wrongly flagged redundant-mut. Only mut roots are
    // marked -- an immutable root can't be written and keeps its own checks.
    root_name := lvalue_root_name(sw_expr)
    if root_name.len() > 0 {
        ref mut rb : TypeBinding = scope.get_binding(root_name)
        if rb.is_null().not() {
            if rb.is_mut { rb.written = true }
        }
    }
    bind_ln := pat.children[1].line
    bind_cl := pat.children[1].col
    fresh := format("_pl_", binding_name, "_", bind_ln.to_str(), "_", bind_cl.to_str())
    mut bind_decls := make_payload_ref_decls(own sw_expr.clone(), binding_name, fresh, payload_type, case_node.line, case_node.col, bind_is_mut)
    ref mut body : Expr = case_node.children[1]
    mut old := Vec(Expr).new()
    old.move_from(body.children)
    mut new_ch := Vec(Expr).new()
    for bd in 0..bind_decls.len() {
        new_ch.push_take(bind_decls, bd)
    }
    for bi in 0..old.len() {
        new_ch.push_take(old, bi)
    }
    body.children.move_from(new_ch)
}

replace_body_stmt_with_block := func(mut body: Expr, stmt_idx: USize, own block: Expr) {
    body.children[stmt_idx] = block
}

make_for_in_range_while_body := func(var_name: Str, cur_name: Str, step: Str, for_body: Expr, line: U32, col: U32, elem_type: Str, var_is_mut: Bool) returns Expr {
    mut wb := Expr.new(NodeType.Body, line, col)

    mut vd := Expr.new(NodeType.Decl(decl_typed(name = var_name, explicit_type = elem_type, is_mut = var_is_mut)), line, col)
    mut cur_ident := Expr.new(ident_node(cur_name), line, col)
    vd.add_child(own cur_ident)
    wb.add_child(own vd)

    mut step_ident := Expr.new(ident_node(cur_name), line, col)
    wb.add_child(own make_method_call_fcall(own step_ident, step, line, col))

    for e_bi : Expr in for_body.children {
        wb.add_child(own e_bi.clone())
    }
    return wb
}

// ---------------------------------------------------------------
// Issue #198: typer-side lowering for throw/catch.
//
// Walks a function body and rewrites Throw/Catch into plain til
// (mut _err_kind + _err_<T> slots, assignments, if-guards) so the
// interpreter and builder both run throw/catch programs without
// any new error-handling code paths. Single implementation, two
// pipelines.
//
// The lowering is conservative on what it recognises:
//  - throw <Ident>(...) -- type is the Ident text (constructor)
//  - throw "..."        -- type is "Str"
//  - throw <num>        -- type is "I64"
//  - other shapes       -- left as-is; typer's existing machinery
//                          will surface a clear error.
// Cross-call propagation (~?~ on calls) is not lowered yet -- a
// follow-up will extend this pass.
// ---------------------------------------------------------------
priv find_variadic_fcall := func(e: Expr, scope: TypeScope) returns ref Expr {
    expect(e.is_null().not(), "e is null")
    if e.node_type.is(NodeType.FuncDef) { return NULL }
    if e.node_type.is(NodeType.StructDef) { return NULL }
    if e.node_type.is(NodeType.EnumDef) { return NULL }
    if e.node_type.is(NodeType.Body) { return NULL }
    switch e.node_type {
    case NodeType.FCall:
        if fcall_callee_has_variadic_via_scope(e, scope) {
            switch e.children[0].node_type {
            case NodeType.Ident(cn):
                ref cn_str : Str = cn.ident_name()
                if cn_str.eq("array").or(cn_str.eq("vec")) {
                    return NULL
                }
            case:
            }
            return e
        }
    case:
    }
    for e_i : Expr in e.children {
        ref found : Expr = find_variadic_fcall(e_i, scope)
        if found.is_null().not() { return found }
    }
    return NULL
}

priv find_kwargs_fcall := func(e: Expr, scope: TypeScope) returns ref Expr {
    expect(e.is_null().not(), "e is null")
    if e.node_type.is(NodeType.FuncDef) { return NULL }
    if e.node_type.is(NodeType.StructDef) { return NULL }
    if e.node_type.is(NodeType.EnumDef) { return NULL }
    if e.node_type.is(NodeType.Body) { return NULL }
    switch e.node_type {
    case NodeType.FCall:
        if fcall_kwargs_index_via_scope(e, scope) >= 0 { return e }
    case:
    }
    for e_i : Expr in e.children {
        ref found : Expr = find_kwargs_fcall(e_i, scope)
        if found.is_null().not() { return found }
    }
    return NULL
}

priv find_array_vec_fcall := func(e: Expr) returns ref Expr {
    expect(e.is_null().not(), "e is null")
    if e.node_type.is(NodeType.FuncDef) { return NULL }
    if e.node_type.is(NodeType.StructDef) { return NULL }
    if e.node_type.is(NodeType.EnumDef) { return NULL }
    if e.node_type.is(NodeType.Body) { return NULL }
    switch e.node_type {
    case NodeType.FCall:
        if e.children.len() > 0 {
            switch e.children[0].node_type {
            case NodeType.Ident(cn):
                ref cn_str : Str = cn.ident_name()
                if cn_str.eq("array").or(cn_str.eq("vec")) { return e }
            case:
            }
        }
    case:
    }
    for e_i : Expr in e.children {
        ref found : Expr = find_array_vec_fcall(e_i)
        if found.is_null().not() { return found }
    }
    return NULL
}

priv set_literal_type_name := func(scope: TypeScope, elem_type: Str) returns Str {
    if scope.get_struct("Set").is_null().not() { return "Set" }
    return format("Set__", elem_type)
}

priv map_literal_type_name := func(key_type: Str, val_type: Str) returns Str {
    return format("Map__", key_type, "_", val_type)
}

// Set `call.own_args` to match the callee's params.own_type, for a
// namespace call built by make_ns_call (FCall whose head is
// FieldAccess(method) over Ident(type_name)). Walks the resolved
// ns_func.params and ORs bit (i+1) for each Own param -- the +1 skips
// the callee child at index 0. Caller is responsible for having pushed
// the receiver and the actual arg Exprs in the same order as the
// callee's params before calling this.
//
// Single source of truth for "which positional args are own?" -- it
// is derived from the callee's actual signature instead of being
// hardcoded per build_*_* site. Synthesized FCalls are created during
// `body_pre_passes`, AFTER the per-stmt type-check pass that runs
// `validate_fcall_own_args` / `infer_field_access_fcall`, so they
// never go through the typer's own-args consistency check; this
// helper plays the role the validator plays for user-written calls.
//
// Issue #109: the kwargs KwargsMap.set leak was a hardcoded set_own_arg
// for elem_type that didn't match the callee's actual `elem_type: Str`
// (borrowed) param; the helper plugs the whole bug class.
priv sync_own_args_from_callee := func(mut call: Expr, scope: TypeScope) {
    ref fa : Expr = call.children[0]
    mut method := ""
    switch fa.node_type {
    case NodeType.FieldAccess(m):
        method = Str.clone(m.field_access_name())
    case:
        return
    }
    ref obj : Expr = fa.children[0]
    mut type_name := ""
    switch obj.node_type {
    case NodeType.Ident(name):
        type_name = Str.clone(name.ident_name())
    case:
        return
    }
    ref sdef : Expr = scope.get_struct(type_name)
    if sdef.is_null() { return }
    ref ns_func : Expr = find_namespace_func(sdef, method, scope)
    if ns_func.is_null() { return }
    switch ns_func.node_type {
    case NodeType.FuncDef(fd):
        for i in 0..fd.params.len() {
            ref p : Declaration = fd.params[i]
            if p.own_type.is(OwnType.Own) {
                set_own_arg(call, i + 1)
            }
        }
    case:
    }
}

priv build_kwargs_map_decl := func(fcall: Expr, kw_name: Str) returns Expr {
    mut new_call := make_ns_call("KwargsMap", "new", Type.Struct("KwargsMap"), fcall)
    mut kw_decl := Expr.new(NodeType.Decl(Declaration()), fcall.line, fcall.col)
    switch kw_decl.node_type {
    case NodeType.Decl(dd):
        dd.name = kw_name.clone()
    case:
        UNREACHABLE()
    }
    kw_decl.set_til_type(Type.Struct("KwargsMap"))
    kw_decl.add_child(own new_call)
    return kw_decl
}

priv build_kwargs_map_set := func(fcall: Expr, scope: TypeScope, kw_name: Str, named_arg: Expr, ctx: Context) returns Expr {
    mut key_name := ""
    switch named_arg.node_type {
    case NodeType.NamedArg(kn):
        key_name = kn.clone()
    case:
        UNREACHABLE()
    }
    ref val : Expr = named_arg.children[0]
    mut set_call := make_ns_call("KwargsMap", "set", Type.None, fcall)

    mut self_id := Expr.new(ident_node(kw_name), fcall.line, fcall.col)
    self_id.set_til_type(Type.Struct("KwargsMap"))
    set_call.add_child(own self_id)

    mut key_lit := Expr.new(NodeType.Literal(Literal.Str(key_name)), fcall.line, fcall.col)
    set_call.add_child(own key_lit)

    tname := type_to_name(val.til_type())
    mut type_lit := Expr.new(NodeType.Literal(Literal.Str(tname.clone())), fcall.line, fcall.col)
    set_call.add_child(own type_lit)

    mut size_call := make_ns_call(tname, "size", usize_type(scope, ctx), fcall)
    set_call.add_child(own size_call)

    mut out_val := val.clone()
    if val.node_type.is(NodeType.Ident).or(val.node_type.is(NodeType.FieldAccess)) {
        // Issue #58 / #147 step 5: don't clone-wrap a FuncPtr/FuncPtrSig.
        if tname.len().gt(0).and(val.til_type().is_funcptr().not()).and(val.til_type().is(Type.Body).not()) {
            out_val = make_clone_call(tname, val.til_type(), val, val)
        }
    }
    set_call.add_child(own out_val)

    sync_own_args_from_callee(set_call, scope)
    return set_call
}

priv build_variadic_array_decl := func(fcall: Expr, scope: TypeScope, elem_type: Str, va_name: Str, vc: USize, ctx: Context) returns Expr {
    array_type := variadic_array_type_name(scope, elem_type)
    mut new_call := make_ns_call(array_type, "new", Type.Struct(array_type.clone()), fcall)

    if array_type == "Array" {
        mut et := fcall.make_til_type_expr(type_from_name(elem_type, scope, ctx))
        new_call.add_child(own et)
    }

    cap_str := vc.to_str()
    mut cap := Expr.new(literal_num_node(cap_str), fcall.line, fcall.col)
    cap.set_til_type(usize_type(scope, ctx))
    new_call.add_child(own cap)

    mut va_decl := Expr.new(NodeType.Decl(Declaration()), fcall.line, fcall.col)
    switch va_decl.node_type {
    case NodeType.Decl(dd):
        dd.name = va_name.clone()
        dd.own_type = OwnType.Own
    case:
        UNREACHABLE()
    }
    va_decl.set_til_type(Type.Struct(array_type.clone()))
    va_decl.add_child(own new_call)
    return va_decl
}

// Issue #225: name of an err-slot for build_variadic_array_set's throwing
// `set`. Forced to a leading underscore so the typer's unused-variable check
// (which exempts `_`-prefixed compiler temps, see infer pass) skips it: the
// slot's only uses are the post-inference set-call Idents, which never flip
// `binding.used`. The temp Array names already start with `_`; a user-named
// array (e.g. `xs := array(...)`) does not, hence the explicit prefix.
priv variadic_err_slot_name := func(va_name: Str, suffix: Str) returns Str {
    if va_name.starts_with("_") { return format(va_name, suffix) }
    return format("_", va_name, suffix)
}

// Issue #225: declare the per-Array error out-arg slots that
// build_variadic_array_set passes to the throwing `set` as its `_err_kind`
// out-arg. The fill is always in bounds, so the tag is never set; it only
// satisfies the tag-only OutOfBounds ABI.
//
// Built fully resolved (til_type + resolved init) because this desugar
// runs inside infer_body: nodes emitted here are NOT re-inferred, so an
// un-typed decl falls back to I64 in the builder. Mirrors
// build_variadic_array_decl, which likewise hand-resolves its `Array.new(...)`
// init.
priv build_variadic_err_slots := func(va_name: Str, mut new_ch: Vec(Expr), mut scope: TypeScope, ctx: Context, line: U32, col: U32) {
    // _ek : I64 = 0  -- receives the throwing set's `_err_kind` out-arg
    // (a value out-param, so the builder passes it as `&<va>_ek`).
    mut ek := Expr.new(NodeType.Decl(Declaration()), line, col)
    switch ek.node_type {
    case NodeType.Decl(ek_dd):
        ek_dd.name = variadic_err_slot_name(va_name, "_ek")
        ek_dd.is_mut = true
    case:
        UNREACHABLE()
    }
    ek.set_til_type(Type.Primitive(Primitive.I64))
    mut ek_init := Expr.new(literal_num_node("0"), line, col)
    ek_init.set_til_type(Type.Primitive(Primitive.I64))
    ek.add_child(own ek_init)
    scope.set(variadic_err_slot_name(va_name, "_ek"), Type.Primitive(Primitive.I64), true, ctx.path, line, col, false, OwnType.Shallow)
    new_ch.push(own ek)
}

priv build_variadic_array_set := func(fcall: Expr, scope: TypeScope, elem_type: Str, va_name: Str, vi: I32, j: USize, ctx: Context) returns Expr {
    array_type := variadic_array_type_name(scope, elem_type)
    // Issue #225: the variadic-arg collector fills its temp Array with the
    // throwing `set`. This desugar runs after throws-lowering, so the call
    // is not lowered automatically -- wire its error out-args by hand here:
    // pass the per-array `<va>_ek` tag slot (declared next to the Array, see
    // build_variadic_err_slots). `j` is always in bounds, so it never throws.
    mut set_call := make_ns_call(array_type, "set", Type.None, fcall)

    mut self_id := Expr.new(ident_node(va_name), fcall.line, fcall.col)
    self_id.set_til_type(Type.Struct(array_type.clone()))
    set_call.add_child(own self_id)

    idx_str := j.to_str()
    mut idx := Expr.new(literal_num_node(idx_str), fcall.line, fcall.col)
    idx.set_til_type(usize_type(scope, ctx))
    set_call.add_child(own idx)

    ref val_in : Expr = fcall.children[vi.add(j.to_i32()).to_usize()]
    mut val := val_in.clone()
    if val_in.node_type.is(NodeType.Ident).or(val_in.node_type.is(NodeType.FieldAccess)) {
        tname := type_to_name(val_in.til_type())
        // Issue #58 / #147 step 5: don't clone-wrap a FuncPtr/FuncPtrSig.
        if tname.len().gt(0).and(val_in.til_type().is_funcptr().not()).and(val_in.til_type().is(Type.Body).not()) {
            val = make_clone_call(tname, val_in.til_type(), val_in, val_in)
        }
    }
    elem_t := type_from_name(elem_type, scope, ctx)
    switch val.node_type {
    case NodeType.Literal(Literal.Num(lit_str)):
        if is_numeric_type(elem_t).and(literal_in_range(lit_str.literal_num_text(), elem_t)) {
            val.set_til_type(elem_t)
        }
    case:
    }
    set_call.add_child(own val)

    // Manually attach the throwing-set error out-args (see comment above).
    mut ek_id := Expr.new(ident_node(variadic_err_slot_name(va_name, "_ek")), fcall.line, fcall.col)
    ek_id.set_til_type(Type.Primitive(Primitive.I64))
    set_call.add_child(own ek_id)

    // Issue #281: set() may declare trailing defaulted params (e.g.
    // `loc: Str = __LOC__`, placed after the err out-args by
    // append_err_out_params). This hand-built call supplies self+idx+val and
    // the err out-args; fill anything past that from the callee's defaults,
    // with the variadic call as the caller. No-op until set carries such a
    // default. Same generic approach as the for-in get lowering.
    ref set_def : Expr = find_namespace_func(scope.get_struct(array_type), "set", scope)
    if set_def.is_null().not() {
        switch set_def.node_type {
        case NodeType.FuncDef(set_fd):
            for sp : Declaration in set_fd.params {
                if sp.default_value.node_type.is(NodeType.NoDefaultArg).not() {
                    set_call.add_child(own resolve_default_value(sp.default_value, fcall, ctx))
                }
            }
        case:
        }
    }

    sync_own_args_from_callee(set_call, scope)
    return set_call
}

priv build_builtin_vec_decl := func(fcall: Expr, elem_type: Str, vec_name: Str) returns Expr {
    vec_type := format("Vec__", elem_type)
    mut new_call := make_ns_call(vec_type, "new", Type.Struct(vec_type.clone()), fcall)

    mut vec_decl := Expr.new(NodeType.Decl(Declaration()), fcall.line, fcall.col)
    switch vec_decl.node_type {
    case NodeType.Decl(dd):
        dd.name = vec_name.clone()
        dd.own_type = OwnType.Own
        dd.is_mut = true
    case:
        UNREACHABLE()
    }
    vec_decl.set_til_type(Type.Struct(vec_type))
    vec_decl.add_child(own new_call)
    return vec_decl
}

priv build_builtin_vec_push := func(fcall: Expr, scope: TypeScope, elem_type: Str, vec_name: Str, j: USize, ctx: Context) returns Expr {
    vec_type := format("Vec__", elem_type)
    mut push_call := make_ns_call(vec_type, "push", Type.None, fcall)

    mut self_id := Expr.new(ident_node(vec_name), fcall.line, fcall.col)
    self_id.set_til_type(Type.Struct(vec_type))
    push_call.add_child(own self_id)

    ref val_in : Expr = fcall.children[j + 2]
    mut val := val_in.clone()
    if val_in.node_type.is(NodeType.Ident).or(val_in.node_type.is(NodeType.FieldAccess)) {
        tname := type_to_name(val_in.til_type())
        // Issue #58 / #147 step 5: don't clone-wrap a FuncPtr/FuncPtrSig.
        if tname.len().gt(0).and(val_in.til_type().is_funcptr().not()).and(val_in.til_type().is(Type.Body).not()) {
            val = make_clone_call(tname, val_in.til_type(), val_in, val_in)
        }
    }
    elem_t := type_from_name(elem_type, scope, ctx)
    switch val.node_type {
    case NodeType.Literal(Literal.Num(lit_str)):
        if is_numeric_type(elem_t).and(literal_in_range(lit_str.literal_num_text(), elem_t)) {
            val.set_til_type(elem_t)
        }
    case:
    }
    push_call.add_child(own val)

    sync_own_args_from_callee(push_call, scope)
    return push_call
}

priv rewrite_collection_fcall_to_ident := func(mut fcall: Expr, coll_name: Str, coll_type: Type) {
    mut old_args := Vec(Expr).new()
    old_args.move_from(fcall.children)
    fcall.children = Vec(Expr).new()
    fcall.node_type = ident_node(coll_name)
    fcall.set_til_type(coll_type)
}

priv desugar_array_vec_fcall := func(mut ctx: Context, mut fcall: Expr, mut new_ch: Vec(Expr), mut scope: TypeScope) returns Bool {
    switch fcall.node_type {
    case NodeType.FCall:
        if fcall.children.len() < 2 { return false }
        ref callee : Expr = fcall.children[0]
        switch callee.node_type {
        case NodeType.Ident(cn):
            ref cn_str : Str = cn.ident_name()
            if cn_str.eq("vec").or(cn_str.eq("array")).not() { return false }
            // Empty -> child(1) was not a bare type token; the typer already
            // reported a user-located error (infer_array_vec_fcall). Leave the
            // call raw rather than panic from inside the desugar.
            elem_type := array_vec_elem_type_name(fcall)
            if elem_type.len() == 0 { return false }
            count : USize = fcall.children.len() - 2
            if cn_str == "vec" {
                vec_name := format("_vec_", ctx.coll_counter.to_str())
                ctx.coll_counter++
                mut vec_decl := fcall.build_builtin_vec_decl(elem_type, vec_name)
                vec_type := format("Vec__", elem_type)
                scope.set(vec_name, Type.Struct(vec_type.clone()), true, ctx.path, fcall.line, fcall.col, false, OwnType.Own)
                new_ch.push(own vec_decl)
                for j in 0..count {
                    mut push_call := fcall.build_builtin_vec_push(scope, elem_type, vec_name, j, ctx)
                    new_ch.push(own push_call)
                }
                rewrite_collection_fcall_to_ident(fcall, vec_name, Type.Struct(vec_type))
                return true
            }
            arr_name := format("_array_", ctx.coll_counter.to_str())
            ctx.coll_counter++
            array_type := variadic_array_type_name(scope, elem_type)
            mut arr_decl := build_variadic_array_decl(fcall, scope, elem_type, arr_name, count, ctx)
            scope.set(arr_name, Type.Struct(array_type.clone()), false, ctx.path, fcall.line, fcall.col, false, OwnType.Own)
            new_ch.push(own arr_decl)
            build_variadic_err_slots(arr_name, new_ch, scope, ctx, fcall.line, fcall.col)
            for j in 0..count {
                mut setter := build_variadic_array_set(fcall, scope, elem_type, arr_name, 2, j, ctx)
                new_ch.push(own setter)
            }
            rewrite_collection_fcall_to_ident(fcall, arr_name, Type.Struct(array_type))
            return true
        case:
        }
        return false
    case:
        UNREACHABLE()
        return false
    }
}

priv desugar_array_vec_decl := func(stmt: Expr, mut new_ch: Vec(Expr), mut scope: TypeScope, ctx: Context) returns Bool {
    if stmt.node_type.is(NodeType.Decl).not().or(stmt.children.len().eq(0)) { return false }
    ref rhs : Expr = stmt.children[0]
    if rhs.node_type.is(NodeType.FCall).not() { return false }

    mut var_name := ""
    switch stmt.node_type {
    case NodeType.Decl(stmt_decl):
        var_name = stmt_decl.name.clone()
    case:
        UNREACHABLE()
        return false
    }

    ref callee : Expr = rhs.children[0]
    switch callee.node_type {
    case NodeType.Ident(cn):
        if cn.ident_name() == "vec" {
            if rhs.children.len() < 2 { return false }
            elem_type := array_vec_elem_type_name(rhs)
            if elem_type.len() == 0 { return false }
            count : USize = rhs.children.len() - 2
            mut vec_decl := rhs.build_builtin_vec_decl(elem_type, var_name)
            vec_type := format("Vec__", elem_type)
            vec_decl.set_til_type(Type.Struct(vec_type.clone()))
            switch vec_decl.node_type {
            case NodeType.Decl(dd):
                dd.is_mut = true
            case:
            }
            scope.set(var_name, Type.Struct(vec_type), true, ctx.path, stmt.line, stmt.col, false, OwnType.Shallow)
            new_ch.push(own vec_decl)
            for j in 0..count {
                mut push_call := rhs.build_builtin_vec_push(scope, elem_type, var_name, j, ctx)
                new_ch.push(own push_call)
            }
            return true
        }
        if cn.ident_name() == "array" {
            if rhs.children.len() < 2 { return false }
            elem_type := array_vec_elem_type_name(rhs)
            if elem_type.len() == 0 { return false }
            count : USize = rhs.children.len() - 2
            array_type := variadic_array_type_name(scope, elem_type)
            mut arr_decl := build_variadic_array_decl(rhs, scope, elem_type, var_name, count, ctx)
            arr_decl.set_til_type(Type.Struct(array_type.clone()))
            scope.set(var_name, Type.Struct(array_type), true, ctx.path, stmt.line, stmt.col, false, OwnType.Shallow)
            new_ch.push(own arr_decl)
            build_variadic_err_slots(var_name, new_ch, scope, ctx, rhs.line, rhs.col)
            for j in 0..count {
                mut setter := build_variadic_array_set(rhs, scope, elem_type, var_name, 2, j, ctx)
                new_ch.push(own setter)
            }
            return true
        }
    case:
    }
    return false
}

// Returns true if the call constructed replacement stmts and pushed them
// to new_ch; false if the original stmt should be kept (caller pushes it).
priv desugar_set_literal_decl := proc(stmt: Expr, mut new_ch: Vec(Expr), mut scope: TypeScope, ctx: Context) returns Bool {
    ref set_lit : Expr = stmt.children[0]
    mut var_name := ""
    switch stmt.node_type {
    case NodeType.Decl(stmt_decl):
        var_name = stmt_decl.name.clone()
    case:
        UNREACHABLE()
        return false
    }

    if set_lit.children.len() == 0 {
        set_lit.type_error("set literal must have at least one element", ctx)
        return false
    }

    ref first : Expr = set_lit.children[0]
    elem_type := type_to_name(first.til_type())
    if elem_type.len() == 0 {
        first.type_error("set literal: cannot determine element type", ctx)
        return false
    }

    if type_has_cmp(scope, elem_type).not() {
        first.type_error(format("set literal: element type '", elem_type, "' must implement cmp"), ctx)
    }

    for j in 1..set_lit.children.len() {
        ref v : Expr = set_lit.children[j]
        vt := type_to_name(v.til_type())
        if vt.len().eq(0).or(vt.eq(elem_type).not()) {
            v.type_error("set literal: all elements must be the same type", ctx)
        }
    }

    set_type := set_literal_type_name(scope, elem_type)
    mut new_call := make_ns_call(set_type, "new", Type.Struct(set_type.clone()), set_lit)
    if set_type == "Set" {
        mut et := set_lit.make_til_type_expr(first.til_type())
        new_call.add_child(own et)
    }

    mut decl := Expr.new(NodeType.Decl(Declaration()), stmt.line, stmt.col)
    switch decl.node_type {
    case NodeType.Decl(dd):
        dd.name = var_name.clone()
        dd.is_mut = true
    case:
        UNREACHABLE()
    }
    decl.set_til_type(Type.Struct(set_type.clone()))
    decl.add_child(own new_call)

    scope.set(var_name, Type.Struct(set_type.clone()), true, ctx.path, stmt.line, stmt.col, false, OwnType.Shallow)

    new_ch.push(own decl)

    for e_j : Expr in set_lit.children {
        mut add_call := make_ns_call(set_type, "add", Type.None, set_lit)
        mut self_id := Expr.new(ident_node(var_name), set_lit.line, set_lit.col)
        self_id.set_til_type(Type.Struct(set_type.clone()))
        add_call.add_child(own self_id)
        mut val := e_j.clone()
        add_call.add_child(own val)
        sync_own_args_from_callee(add_call, scope)
        new_ch.push(own add_call)
    }
    return true
}

// Returns true if the call constructed replacement stmts and pushed them
// to new_ch; false if the original stmt should be kept (caller pushes it).
priv desugar_map_literal_decl := proc(stmt: Expr, mut new_ch: Vec(Expr), mut scope: TypeScope, ctx: Context) returns Bool {
    ref map_lit : Expr = stmt.children[0]
    mut var_name := ""
    switch stmt.node_type {
    case NodeType.Decl(stmt_decl):
        var_name = stmt_decl.name.clone()
    case:
        UNREACHABLE()
        return false
    }
    n_pairs := map_lit.children.len() / 2

    if map_lit.children.len() == 0 {
        map_lit.type_error("map literal must have at least one entry", ctx)
        return false
    }
    if map_lit.children.len().mod(2).eq(0).not() {
        map_lit.type_error("map literal has mismatched key/value pairs", ctx)
        return false
    }

    ref first_key : Expr = map_lit.children[0]
    ref first_val : Expr = map_lit.children[1]
    key_type := type_to_name(first_key.til_type())
    val_type := type_to_name(first_val.til_type())

    if key_type.len() == 0 {
        first_key.type_error("map literal: cannot determine key type", ctx)
        return false
    }
    if val_type.len() == 0 {
        first_val.type_error("map literal: cannot determine value type", ctx)
        return false
    }

    if type_has_cmp(scope, key_type).not() {
        first_key.type_error(format("map literal: key type '", key_type, "' must implement cmp"), ctx)
    }

    for j in 2..map_lit.children.len() {
        if j % 2 == 0 {
            ref k : Expr = map_lit.children[j]
            kt := type_to_name(k.til_type())
            if kt.len().eq(0).or(kt.eq(key_type).not()) {
                k.type_error("map literal: all keys must be the same type", ctx)
            }
        } else {
            ref v : Expr = map_lit.children[j]
            vt := type_to_name(v.til_type())
            if vt.len().eq(0).or(vt.eq(val_type).not()) {
                v.type_error("map literal: all values must be the same type", ctx)
            }
        }
    }

    map_type := map_literal_type_name(key_type, val_type)
    mut new_call := make_ns_call(map_type, "new", Type.Struct(map_type.clone()), map_lit)
    if map_type == "Map" {
        mut kt := map_lit.make_til_type_expr(first_key.til_type())
        new_call.add_child(own kt)
        mut vt := map_lit.make_til_type_expr(first_val.til_type())
        new_call.add_child(own vt)
    }

    mut decl := Expr.new(NodeType.Decl(Declaration()), stmt.line, stmt.col)
    switch decl.node_type {
    case NodeType.Decl(dd):
        dd.name = var_name.clone()
        dd.is_mut = true
    case:
        UNREACHABLE()
    }
    decl.set_til_type(Type.Struct(map_type.clone()))
    decl.add_child(own new_call)

    scope.set(var_name, Type.Struct(map_type.clone()), true, ctx.path, stmt.line, stmt.col, false, OwnType.Shallow)

    new_ch.push(own decl)

    for j in 0..n_pairs {
        mut set_call := make_ns_call(map_type, "set", Type.None, map_lit)
        mut self_id := Expr.new(ident_node(var_name), map_lit.line, map_lit.col)
        self_id.set_til_type(Type.Struct(map_type.clone()))
        set_call.add_child(own self_id)
        mut key := map_lit.children[j * 2].clone()
        set_call.add_child(own key)
        mut mval := map_lit.children[j.mul(2) + 1].clone()
        set_call.add_child(own mval)
        sync_own_args_from_callee(set_call, scope)
        new_ch.push(own set_call)
    }
    return true
}

// Combine desugar_set_literals and desugar_map_literals: both filter on
// Decl + SetLit/MapLit rhs at the body's top level, both rebuild
// body.children, and both end with reregister_scope_defs (which is O(N*K)
// over body decls and scope bindings). Sharing the prefilter, rebuild,
// and reregister halves that cost when both transformations apply, and
// drops one walk + one reregister even when only one applies.
// Apply the array/vec, variadic, and kwargs desugars to a single stmt (in
// place). Prepends helper decls/setters to new_ch as needed and rewrites the
// discovered fcall(s) in place. Caller is responsible for pushing the
// (possibly-mutated) stmt to new_ch afterwards.
// Desugar every array/vec, variadic, and kwargs fcall reachable from stmt in a
// single post-order walk. Children are processed before their parent,
// so by the time we build a parent's setter (which clones a variadic
// arg) the inner fcall has already been rewritten in place. That
// covers nested fcalls in one walk, and sibling fcalls naturally fall
// out of the children iteration -- no recursion on setters and no
// repeated find_*_fcall scans. #186 / #188 / #189 all came from the
// same root cause (single-pass-per-stmt instead of full traversal).
//
// Wrap one variadic FCall `e` into its build region (Array.new + err-slots +
// per-element Array.set), prepending the temp setups to `new_ch` and rewriting
// `e`'s args to the single array. Extracted from process_call_desugars so the
// same lowering can run as a standalone post-constfold pass (see loader.til):
// the constfolder folds comptime variadic calls while they are still raw, and
// only the survivors reach this lowering. Resolves everything via `scope`
// (callee FuncDef, OutOfBounds struct, Array.set ns func), which works against
// either the per-body TypeScope (typecheck-time) or the global one (post-fold).
priv desugar_one_variadic_fcall := func(mut ctx: Context, mut e: Expr, mut new_ch: Vec(Expr), mut scope: TypeScope) {
    mut skip := false
    switch e.children[0].node_type {
    case NodeType.Ident(cn):
        ref cn_str : Str = cn.ident_name()
        if cn_str.eq("array").or(cn_str.eq("vec")) { skip = true }
    case:
    }
    if skip { return }
    // Resolve callee once via scope to derive the per-call variadic block
    // position and arg count; thread them into both the pure-splat detector
    // and the array-wrapping rewrite so neither needs to re-resolve.
    vi := fcall_variadic_index_via_scope(e, scope)
    vc := fcall_variadic_count_via_scope(e, scope)
    ref elem_type : Str = resolve_variadic_elem_type(e, scope)
    // elem_type-null here means the typer already reported an error upstream;
    // just leave the fcall raw rather than emit a half-formed wrap.
    if elem_type.is_null() { return }
    array_type := variadic_array_type_name(scope, elem_type)
    if desugar_pure_splat_variadic_call(e, array_type, vi, vc) { return }
    va_name := format("_va_Array_", ctx.va_counter.to_str())
    ctx.va_counter++
    mut va_decl := build_variadic_array_decl(e, scope, elem_type, va_name, vc, ctx)
    scope.set(va_name, Type.Struct(array_type.clone()), false, ctx.path, e.line, e.col, false, OwnType.Own)
    new_ch.push(own va_decl)
    build_variadic_err_slots(va_name, new_ch, scope, ctx, e.line, e.col)
    for j in 0..vc {
        mut setter := build_variadic_array_set(e, scope, elem_type, va_name, vi, j, ctx)
        new_ch.push(own setter)
    }
    rewrite_variadic_fcall_args(e, va_name, array_type, vi, vc)
}

// Note: the traversal mirrors the recursion guards used by
// find_array_vec_fcall / find_variadic_fcall / find_kwargs_fcall (FuncDef / StructDef /
// EnumDef / Body) so a body-level walk doesn't dive into a nested
// function definition or nested block, which the outer body_pre_passes
// pass will reach separately.
priv process_call_desugars := func(mut ctx: Context, mut e: Expr, mut new_ch: Vec(Expr), mut scope: TypeScope, has_array_vec: Bool, has_variadic: Bool, has_kwargs: Bool) {
    expect(e.is_null().not(), "e is null")
    if e.node_type.is(NodeType.FuncDef) { return }
    if e.node_type.is(NodeType.StructDef) { return }
    if e.node_type.is(NodeType.EnumDef) { return }
    if e.node_type.is(NodeType.Body) { return }

    for e_i : Expr in e.children {
        process_call_desugars(ctx, e_i, new_ch, scope, has_array_vec, has_variadic, has_kwargs)
    }

    switch e.node_type {
    case NodeType.FCall:
        if has_array_vec {
            if desugar_array_vec_fcall(ctx, e, new_ch, scope) { return }
        }
        if has_variadic.and(fcall_callee_has_variadic_via_scope(e, scope)) {
            desugar_one_variadic_fcall(ctx, e, new_ch, scope)
        }
        if has_kwargs {
            ki := fcall_kwargs_index_via_scope(e, scope)
            if ki >= 0 {
                kc := fcall_kwargs_count(e)
                kw_name := format("_kw", ctx.kw_counter.to_str())
                ctx.kw_counter++
                kw_decl := build_kwargs_map_decl(e, kw_name)
                scope.set(kw_name, Type.Struct("KwargsMap"), false, ctx.path, e.line, e.col, false, OwnType.Shallow)
                new_ch.push(own kw_decl)
                for j in 0..kc {
                    ref named_arg : Expr = e.children[ki.add(j.to_i32()).to_usize()]
                    mut setter := build_kwargs_map_set(e, scope, kw_name, named_arg, ctx)
                    new_ch.push(own setter)
                }
                rewrite_kwargs_fcall_args(e, kw_name, ki)
            }
        }
    case:
    }
}

// Single-walk merger of the three former pre-passes infer_body used to
// run back-to-back: desugar_body (set/map literal + array/vec/variadic/
// kwargs call), hoist_fcall_args, and insert_field_deletes. Issue #146 /
// #158: one prefilter, one move-out + rebuild + move-back, one
// reregister_scope_defs.
//
// Per stmt the order is fixed:
//   1. top-level desugar (Decl-with-SetLit/MapLit/array-vec-rhs -> N stmts)
//   2. call-level desugar (variadic/kwargs/array-vec inside an FCall;
//      prepends temp setups to new_ch)
//   3. hoist (pulls complex FCall args / RHSs into temp Decls; prepended)
//   4. field-delete (prepends a delete call before a FieldAssign whose
//      old payload owns a non-trivial type)
//
// owns_scope gates desugar and hoist (both register temp Decls in scope
// so the body must own a scope); field_delete runs unconditionally,
// matching the previous standalone insert_field_deletes pass.
//
// Compile directives (link / link_c / import) flow through untouched:
// the call-desugar walk is a no-op on them, the hoist switch's default
// case skips them, and field_delete is FieldAssign-only.
body_pre_passes := proc(mut ctx: Context, mut body: Expr, mut scope: TypeScope, owns_scope: I32) returns Bool {
    mut has_set_lit := false
    mut has_map_lit := false
    mut has_array_vec := false
    mut has_variadic := false
    mut has_kwargs := false
    mut needs_delete := false
    for stmt : Expr in body.children {
        if owns_scope != 0 {
            if stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0)) {
                ref rhs : Expr = stmt.children[0]
                if rhs.node_type.is_set_lit() { has_set_lit = true }
                if rhs.node_type.is_map_lit() { has_map_lit = true }
            }
            if has_array_vec.not() {
                if find_array_vec_fcall(stmt).is_null().not() { has_array_vec = true }
            }
            if has_variadic.not() {
                if find_variadic_fcall(stmt, scope).is_null().not() { has_variadic = true }
            }
            if has_kwargs.not() {
                if find_kwargs_fcall(stmt, scope).is_null().not() { has_kwargs = true }
            }
        }
        if needs_delete.not().and(stmt.node_type.is(NodeType.FieldAssign)) {
            if field_assign_needs_delete(stmt, scope) {
                ref fa_rhs : Expr = stmt.children[1]
                if type_to_name(fa_rhs.til_type()).len() > 0 {
                    needs_delete = true
                }
            }
        }
    }
    has_desugar := has_set_lit.or(has_map_lit).or(has_array_vec).or(has_variadic).or(has_kwargs)
    do_hoist := owns_scope != 0
    if has_desugar.not().and(do_hoist.not()).and(needs_delete.not()) {
        return false
    }

    mut old := Vec(Expr).new()
    old.move_from(body.children)

    mut new_ch := Vec(Expr).new()
    for i in 0..old.len() {
        ref stmt : Expr = old[i]

        // (1) Top-level desugar: may emit N replacement stmts. Each
        // emitted stmt can itself contain variadic/kwargs fcalls or
        // need hoisting, so we route every emitted stmt through the
        // per-stmt pipeline below.
        mut temp_ch := Vec(Expr).new()
        mut stmt_handled := false
        if has_desugar {
            if stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0)) {
                ref rhs : Expr = stmt.children[0]
                if has_set_lit.and(rhs.node_type.is_set_lit()) {
                    if desugar_set_literal_decl(stmt, temp_ch, scope, ctx) {
                        stmt_handled = true
                    }
                } else if has_map_lit.and(rhs.node_type.is_map_lit()) {
                    if desugar_map_literal_decl(stmt, temp_ch, scope, ctx) {
                        stmt_handled = true
                    }
                } else if has_array_vec.and(rhs.node_type.is(NodeType.FCall)) {
                    if desugar_array_vec_decl(stmt, temp_ch, scope, ctx) {
                        stmt_handled = true
                    }
                }
            }
        }

        if stmt_handled {
            for j in 0..temp_ch.len() {
                ref ts : Expr = temp_ch[j]
                apply_call_hoist_delete(ctx, ts, new_ch, scope, has_array_vec, has_variadic, has_kwargs, do_hoist, needs_delete)
                new_ch.push_take(temp_ch, j)
            }
        } else {
            apply_call_hoist_delete(ctx, stmt, new_ch, scope, has_array_vec, has_variadic, has_kwargs, do_hoist, needs_delete)
            new_ch.push_take(old, i)
        }
    }
    body.children.move_from(new_ch)
    // Free the two scratch buffers (like temp_ch above). move_from zeroed
    // new_ch.count, and every slot moved out of old was zeroed by
    // push_take, so the only elements Vec.delete drops are old's
    // desugar-replaced husks -- dead AST whose contents already moved into
    // the emitted stmts. call_free is false: the Vec values are locals.
    return true
}

// Apply per-stmt hoist (the body_pre_passes equivalent of the old
// hoist_fcall_args dispatch). Prepends any new temp Decls to new_ch.
priv apply_hoist_to_stmt := proc(mut ctx: Context, mut stmt: Expr, mut new_ch: Vec(Expr), mut scope: TypeScope) {
    mut hoisted := Vec(Expr).new()
    switch stmt.node_type {
    case NodeType.Decl:
        hoist_decl_rhs(ctx, stmt, hoisted, scope)
    case NodeType.FCall:
        hoist_stmt_fcall(ctx, stmt, hoisted, scope)
    case NodeType.Return:
        hoist_return_expr(ctx, stmt, hoisted, scope)
    case NodeType.Assign:
        hoist_assign_rhs(ctx, stmt, hoisted, scope)
        hoist_param_swap_assign(ctx, stmt, hoisted, scope)
    case NodeType.FieldAssign:
        hoist_field_assign_rhs(ctx, stmt, hoisted, scope)
    case NodeType.If:
        hoist_if_cond(ctx, stmt, hoisted, scope)
    case:
        // NodeType.While: skip condition -- hoisting changes loop semantics
    }
    new_ch.append(own hoisted)
}

// Per-stmt pipeline: call-desugar, hoist, field-delete. Each step
// prepends any helper decls/setters/deletes to new_ch; the caller is
// responsible for pushing the (possibly-rewritten) stmt itself.
//
// Setter stmts emitted by call-desugar (Array.set / KwargsMap.set) can
// themselves contain FCalls whose args need hoisting (e.g.
// Array.set(va, idx, I64.to_str(x.to_i64())) -- the inner I64 value
// must be hoisted into a temp Decl so the builder takes its address).
// To match the original two-pass flow, every desugar-emitted stmt is
// routed through hoist before being pushed.
priv apply_call_hoist_delete := proc(mut ctx: Context, mut stmt: Expr, mut new_ch: Vec(Expr), mut scope: TypeScope, has_array_vec: Bool, has_variadic: Bool, has_kwargs: Bool, do_hoist: Bool, needs_delete: Bool) {
    if is_compile_directive(stmt) { return }
    if has_array_vec.or(has_variadic).or(has_kwargs) {
        mut emitted := Vec(Expr).new()
        process_call_desugars(ctx, stmt, emitted, scope, has_array_vec, has_variadic, has_kwargs)
        for j in 0..emitted.len() {
            ref es : Expr = emitted[j]
            if do_hoist { apply_hoist_to_stmt(ctx, es, new_ch, scope) }
            new_ch.push_take(emitted, j)
        }
    }
    if do_hoist {
        apply_hoist_to_stmt(ctx, stmt, new_ch, scope)
    }
    if needs_delete.and(stmt.node_type.is(NodeType.FieldAssign)) {
        if field_assign_needs_delete(stmt, scope) {
            ref rhs : Expr = stmt.children[1]
            if type_to_name(rhs.til_type()).len() > 0 {
                switch stmt.node_type {
                case NodeType.FieldAssign(fad):
                    fad.save_old_delete = true
                case:
                }
            }
        }
    }
}

priv hoist_param_swap_assign := func(mut ctx: Context, mut stmt: Expr, mut hoisted: Vec(Expr), mut scope: TypeScope) {
    mut stmt_name := ""
    switch stmt.node_type {
    case NodeType.Assign(adata):
        stmt_name = adata.name.clone()
    case:
        return
    }
    sf := scope.find(stmt_name)
    switch sf {
    case ScopeFind.Found(ab):
        if ab.is_param.not() { return }
        if ab.is_mut.not() { return }
        if is_aggregate(ab.type).not() { return }

        call := Expr.new(NodeType.FCall(FCallData()), stmt.line, stmt.col)
        call.set_til_type(Type.None)
        fn := Expr.new(ident_node("swap_bytes"), stmt.line, stmt.col)
        call.add_child(own fn)
        a := Expr.new(ident_node(stmt_name), stmt.line, stmt.col)
        a.set_til_type(ab.type)
        call.add_child(own a)
        call.add_child(own stmt.children[0].clone())
        tname := type_to_name(ab.type)
        sz_call := make_ns_call(tname, "size", usize_type(scope, ctx), stmt)
        sz := hoist_to_temp(ctx, sz_call, hoisted, scope, false)
        call.add_child(own sz)
        // Issue #210: only use swap_replace for Str so the builder can
        // emit the explicit delete-copy-free pattern (unblocking
        // CAP_LIT-safe wrapper-free skipping in Str.delete).
        if tname == "Str" {
            switch call.node_type {
            case NodeType.FCall(fcd):
                fcd.swap_replace = true
            case:
            }
        }
        stmt = call
    case:
    }
}

// Issue #109: is FCall `expr` an enum variant constructor whose param
// at arg index `i` (1-based: child(i)) is Own? The callee is a
// FieldAccess `EnumName.Variant`. Resolves the enum def, finds the
// variant ctor FuncDef in its ns_decls, and reads param[i-1].own_type.
// Used by the hoist pass to mark the hoisted-temp arg Own independently
// of the per-call own_arg bit (which the auto-own pass may not have
// reached on a synthesized/hoisted call).
priv fcall_variant_ctor_arg_is_own := func(expr: Expr, i: USize, scope: TypeScope) returns Bool {
    if expr.node_type.is(NodeType.FCall).not() { return false }
    if expr.children.len() < 2 { return false }
    ref callee : Expr = expr.children[0]
    if callee.node_type.is(NodeType.FieldAccess).not() { return false }
    if callee.children.len() == 0 { return false }
    mut method := ""
    switch callee.node_type {
    case NodeType.FieldAccess(fad): method = Str.clone(fad.field_access_name())
    case: return false
    }
    ref type_node : Expr = callee.children[0]
    mut tn := ""
    switch type_node.node_type {
    case NodeType.Ident(idd): tn = Str.clone(idd.ident_name())
    case: return false
    }
    ref sdef : Expr = scope.get_struct(tn)
    if sdef.is_null() { return false }
    if sdef.node_type.is(NodeType.EnumDef).not() { return false }
    ref vc_ns : Vec(Declaration) = def_ns_decls(sdef)
    for fd : Declaration in vc_ns {
        if fd.name.eq(method).not() { continue }
        if fd.default_value.is_null() { return false }
        if fd.default_value.node_type.is(NodeType.FuncDef).not() { return false }
        switch fd.default_value.node_type {
        case NodeType.FuncDef(vfd):
            if vfd.is_enum_variant_ctor.not() { return false }
            pidx := i - 1
            if pidx >= vfd.params.len() { return false }
            ref vp : Declaration = vfd.params[pidx]
            return vp.own_type.is(OwnType.Own)
        case: return false
        }
    }
    return false
}

priv hoist_expr := proc(mut ctx: Context, mut expr: Expr, mut hoisted: Vec(Expr), mut scope: TypeScope) {
    if expr.node_type.is(NodeType.FuncDef) { return }
    if expr.node_type.is(NodeType.StructDef) { return }
    if expr.node_type.is(NodeType.EnumDef) { return }
    if expr.node_type.is(NodeType.Body) { return }

    for e_i : Expr in expr.children {
        hoist_expr(ctx, e_i, hoisted, scope)
    }
    // An FCall in FieldAccess BASE position (`f().field`, and the
    // receiver of a chained method call `f().method(...)`) was never
    // hoisted, so the builder emitted `((T *)f(...))->field` and the
    // owned result box leaked -- nothing ever deleted it (the
    // ctx_field_layout/StructInstance.clone leak class). Hoist the base
    // into a temp Decl so the garbager schedules its delete like any
    // other owned local. Ref-returning subscript gets are also hoisted,
    // but as Ref temps via hoist_to_temp; this lets receivers like
    // e.children[0].method() survive the throwing get(...)! lowering
    // without trying to own the borrowed result. Keep this scoped to
    // `.get(...)`: internal ref helpers such as get_payload(s) may carry
    // precise field-access context that hoisting would erase.
    // Non-ref owned results are gated on fcall_returns_own and on an
    // aggregate result type (primitives/Dynamic have no box).
    // Shallow struct returns are fine to hoist: collect_scope_locals
    // keys is_heap=false off fcall_returns_shallow for the temp.
    if expr.node_type.is(NodeType.FieldAccess).and(expr.children.len().gt(0)) {
        ref fa_base : Expr = expr.children[0]
        if fa_base.node_type.is(NodeType.FCall).and(is_macro_call(fa_base, ctx).not()) {
            if fcall_is_get_method(fa_base).or(is_aggregate(fa_base.til_type()).and(fcall_returns_own(fa_base, scope))) {
                expr.children[0] = hoist_to_temp(ctx, fa_base, hoisted, scope, false)
            }
        }
    }
    if expr.node_type.is(NodeType.FCall).not() { return }
    // Issue #57: don't hoist args of macro calls. Macro args are
    // substituted into the macro body at compile time by constfolder's
    // try_eval_call; hoisting an arg into a body-local temp burys its
    // value behind a name that the macro eval's sub-scope can't resolve.
    // Match rstil's pattern: macros take args verbatim (precomp.rs 821-847
    // builds the call with Identifier args, not via the hoister).
    // NOTE (#315): is_macro_call answers from ctx.constfolder_foldables, which
    // must be fully populated before this desugar runs. infer_body_unit
    // classifies every top-level def up front for exactly this reason -- a
    // forward-referenced macro missed here would have its args hoisted and then
    // be force-expanded against the temp.
    if is_macro_call(expr, ctx) { return }

    expr_sname := til_type_name(expr.til_type())
    mut is_dyn_call := false
    mut is_array_vec := false
    mut is_ctor_call := false
    if expr.children.len() > 0 {
        ref callee : Expr = expr.children[0]
        switch callee.node_type {
        case NodeType.Ident(cn):
            if expr_sname.len().gt(0).and(cn.ident_name().eq(expr_sname)) {
                is_ctor_call = true
            }
            ref cn_str : Str = cn.ident_name()
            if cn_str == "dyn_call" { is_dyn_call = true }
            if cn_str == "dyn_call_ret" { is_dyn_call = true }
            if cn_str == "dyn_has_method" { is_dyn_call = true }
            if cn_str == "dyn_fn" { is_dyn_call = true }
            if cn_str == "array" { is_array_vec = true }
            if cn_str == "vec" { is_array_vec = true }
        case:
        }
    }
    ref hoist_sdef : Expr = scope.get_struct(expr_sname)

    mut fi : USize = 0
    for i in 1..expr.children.len() {
        if is_dyn_call {
            if i.eq(2).or(i.eq(3)) { continue }
        }
        if is_array_vec {
            if i == 1 { continue }
        }

        ref arg : Expr = expr.children[i]
        mut hoist_fi := fi
        if is_ctor_call.and(hoist_sdef.is_null().not()) {
        if hoist_sdef.node_type.is(NodeType.StructDef) {
            fi++
        }
        }
        if arg.node_type.is(NodeType.FCall).not() {
            if arg.node_type.is_nonnull_literal().not() {
                continue
            }
        }

        mut slot_is_own := false
        if is_ctor_call.and(hoist_sdef.is_null().not()) {
        switch hoist_sdef.node_type {
        case NodeType.StructDef(h_sdd):
            mut fld_own := OwnType.Shallow
            mut field_type := Type.None
            if hoist_fi < h_sdd.fields.len() {
                ref h_fd : Declaration = h_sdd.fields[hoist_fi]
                fld_own = h_fd.own_type
                field_type = h_fd.til_type
            }
            if fld_own.is(OwnType.Own).not() {
                // Issue #201: skip hoisting a heap-returning arg into an
                // owned temp when it flows into a non-own aggregate field.
                // The builder's inline `{ T *_ca = ...; field = *_ca;
                // free(_ca); }` path transfers ownership correctly; a
                // hoisted temp would Str_delete the value AND leave the
                // field pointing at the freed storage (double-free). Check
                // both the field's static type and the arg's runtime type,
                // and treat Type.Custom (unresolved cross-file name) as
                // aggregate.
                if is_aggregate(field_type).or(field_type.is(Type.Custom)) {
                    continue
                }
                arg_type := arg.til_type()
                if is_aggregate(arg_type).or(arg_type.is(Type.Custom)) {
                    continue
                }
            }
            slot_is_own = fld_own.is(OwnType.Own)
        case:
            slot_is_own = get_own_arg(expr, i)
        }
        } else if is_ctor_call {
            // Ctor for a type whose StructDef isn't reachable in this
            // scope (defined later in the same file or behind a circular
            // import). Without field metadata we can't decide ownership
            // safely; skip hoisting and let the builder's inline field
            // assign emit the ownership transfer.
            continue
        } else {
            slot_is_own = get_own_arg(expr, i)
        }
        // Issue #109: enum variant constructors (callee is a FieldAccess
        // `EnumName.Variant`, not a bare Ident, so is_ctor_call is false)
        // take their compound payload Own. The auto-own bit may not have
        // reached this synthesized/hoisted call, so resolve the variant
        // ctor's param ownership directly here rather than trusting
        // get_own_arg -- otherwise the hoisted temp stays a stack value
        // and the Own ctor body free()s a stack address.
        if slot_is_own.not().and(fcall_variant_ctor_arg_is_own(expr, i, scope)) {
            slot_is_own = true
            // Also set the call's own_arg bit -- the builder reads it
            // (not the temp's own_type) to decide malloc-wrap vs `&`.
            set_own_arg(expr, i)
        }

        expr.children[i] = hoist_to_temp(ctx, arg, hoisted, scope, slot_is_own)
    }
}

priv hoist_decl_rhs := proc(mut ctx: Context, stmt: Expr, mut hoisted: Vec(Expr), mut scope: TypeScope) {
    hoist_expr(ctx, stmt.children[0], hoisted, scope)
}

priv hoist_if_cond := proc(mut ctx: Context, mut stmt: Expr, mut hoisted: Vec(Expr), mut scope: TypeScope) {
    hoist_expr(ctx, stmt.children[0], hoisted, scope)
    ref cond : Expr = stmt.children[0]
    if cond.node_type.is(NodeType.FCall) {
        stmt.children[0] = hoist_to_temp(ctx, cond, hoisted, scope, false)
    }
}

priv hoist_return_expr := proc(mut ctx: Context, mut stmt: Expr, mut hoisted: Vec(Expr), mut scope: TypeScope) {
    if stmt.children.len() == 0 { return }
    hoist_expr(ctx, stmt.children[0], hoisted, scope)
    ref rhs : Expr = stmt.children[0]
    if rhs.node_type.is(NodeType.FCall)
    .or(rhs.node_type.is_nonnull_literal()) {
        replacement := hoist_to_temp(ctx, rhs, hoisted, scope, false)
        stmt.children[0] = replacement
    }
}

priv hoist_assign_rhs := proc(mut ctx: Context, mut stmt: Expr, mut hoisted: Vec(Expr), mut scope: TypeScope) {
    hoist_expr(ctx, stmt.children[0], hoisted, scope)
    mut do_hoist := true
    mut a_name := ""
    switch stmt.node_type {
    case NodeType.Assign(adata):
        a_name = adata.name.clone()
    case:
        UNREACHABLE()
    }
    sf := scope.find(a_name)
    switch sf {
    case ScopeFind.Found(ab):
        if ab.is_param.not() {
            if is_aggregate(ab.type) {
                do_hoist = false
            }
        }
    case:
    }
    ref rhs : Expr = stmt.children[0]
    if do_hoist.and(
        rhs.node_type.is(NodeType.FCall)
        .or(rhs.node_type.is_nonnull_literal())
    ) {
        stmt.children[0] = hoist_to_temp(ctx, rhs, hoisted, scope, false)
    }
}

priv hoist_field_assign_rhs := proc(mut ctx: Context, mut stmt: Expr, mut hoisted: Vec(Expr), mut scope: TypeScope) {
    hoist_expr(ctx, stmt.children[1], hoisted, scope)
    mut fa_hoist := true
    if stmt.fa_own_type(scope).is(OwnType.Shallow) {
        rhs_type := stmt.children[1].til_type()
        if is_aggregate(rhs_type) {
            fa_hoist = false
        }
    }
    ref rhs : Expr = stmt.children[1]
    // Issue #256: don't hoist the typer's defensive `.clone()` of a bare
    // Ident (inserted at infer_field_assign_stmt for an owned-target
    // FieldAssign). Hoisting it into a temp hides the clone from the
    // garbager's last-use unwrap (insert_post_stmt_deletes), so a local
    // assigned into an Own field at its last use got deep-cloned-then-
    // deleted instead of moved -- the clone leaked. Keeping it inline lets
    // the garbager replace `field = T.clone(local)` with the bare `local`
    // move + wrapper free, exactly as it already does for plain Assign
    // (hoist_assign_rhs likewise skips the hoist for aggregate targets).
    // The clone arg must be a genuine user-named local, never a `hoisted__`
    // temp. A hoisted temp can be a non-owning *view* into another buffer
    // (e.g. `arg.substr(...)` lifted out of `field = arg.substr(...).clone()`);
    // there the clone is what decouples the field from the view's source, so
    // moving it instead would dangle the field once the source is freed
    // (issues #238 / #250). hoist_expr above has already lifted such inner
    // subexpressions, so by here the arg names either a user local or a temp.
    if rhs.is_clone_fcall().and(rhs.children.len().gte(2)) {
        switch rhs.children[1].node_type {
        case NodeType.Ident(clone_arg_id):
            if clone_arg_id.ident_name().starts_with("hoisted__").not() {
                fa_hoist = false
            }
        case:
        }
    }
    if fa_hoist.and(
        rhs.node_type.is(NodeType.FCall)
        .or(rhs.node_type.is_nonnull_literal())
    ) {
        stmt.children[1] = hoist_to_temp(ctx, rhs, hoisted, scope, false)
    }
}

priv hoist_stmt_fcall := proc(mut ctx: Context, mut stmt: Expr, mut hoisted: Vec(Expr), mut scope: TypeScope) {
    hoist_expr(ctx, stmt, hoisted, scope)
    // Stmt-level FCalls whose result is None or non-Own don't need the
    // hoist-into-temp dance: nothing on the heap to clean up, so the
    // call can stay as a bare FCall stmt. Only Own returns require the
    // wrap so the matching delete frees the heap box.
    if stmt.til_type().is(Type.None) { return }
    if fcall_returns_own(stmt, scope).not() { return }
    hoist_to_temp(ctx, stmt, hoisted, scope, false)
    popped : Expr = hoisted.pop()
    stmt = popped
}

priv rewrite_variadic_fcall_args := func(mut fcall: Expr, va_name: Str, array_type: Str, vi: I32, vc: USize) {
    switch fcall.node_type {
    case NodeType.FCall(fcall_data):
        old_own := fcall_data.own_args
        line := fcall.line
        col := fcall.col
        mut old_args := Vec(Expr).new()
        old_args.move_from(fcall.children)
        mut fcall_new_ch := Vec(Expr).new()
        mut va_inserted := false
        mut new_own : U64 = 0
        for j in 0..old_args.len() {
            if j.to_i32().gte(vi).and(j.to_i32().lt(vi + vc.to_i32())) {
                if va_inserted.not() {
                    mut va_id := Expr.new(ident_node(va_name), line, col)
                    va_id.set_til_type(Type.Struct(array_type.clone()))
                    mut bit : U64 = 1
                    for _ in 0..fcall_new_ch.len() { bit = bit * 2 }
                    new_own = new_own.bor(bit)
                    fcall_new_ch.push(own va_id)
                    va_inserted = true
                }
                continue
            }
            if j.to_i32().eq(vi).and(va_inserted.not()) {
                mut va_id := Expr.new(ident_node(va_name), line, col)
                va_id.set_til_type(Type.Struct(array_type.clone()))
                mut bit : U64 = 1
                for _ in 0..fcall_new_ch.len() { bit = bit * 2 }
                new_own = new_own.bor(bit)
                fcall_new_ch.push(own va_id)
                va_inserted = true
            }
            // Transfer own bit from old position j to new position
            mut old_bit : U64 = 1
            for _ in 0..j { old_bit = old_bit * 2 }
            if old_own.band(old_bit) > 0 {
                mut nb : U64 = 1
                for _ in 0..fcall_new_ch.len() { nb = nb * 2 }
                new_own = new_own.bor(nb)
            }
            fcall_new_ch.push_take(old_args, j)
        }
        if va_inserted.not() {
            mut va_id := Expr.new(ident_node(va_name), line, col)
            va_id.set_til_type(Type.Struct(array_type.clone()))
            mut bit : U64 = 1
            for _ in 0..fcall_new_ch.len() { bit = bit * 2 }
            new_own = new_own.bor(bit)
            fcall_new_ch.push(own va_id)
        }
        fcall.children.move_from(fcall_new_ch)
        fcall_data.own_args = new_own
    case:
        UNREACHABLE()
    }
}

// A stmt can contain BOTH a variadic fcall and a kwargs fcall (rare,
// but legal -- e.g. f(1, 2, k=v) where 1,2 are variadic and k=v is
// kwargs); the per-stmt pipeline in body_pre_passes applies variadic
// first then kwargs to the same stmt before pushing, matching the
// original sequential order so the kwargs handling sees the
// variadic-rewritten fcall.
// Scope-resolving wrapper around fcall_variadic_count: looks up the
// callee FuncDef the same way resolve_variadic_elem_type does (Ident
// binding, or Type.method namespace lookup) to recover its param count,
// then derives the per-call variadic arg count. Used by the variadic
// desugar sites (process_call_desugars and the helpers it threads into)
// that don't have the callee fdef_data on hand the way validate/
// infer_and_validate_fcall_args do. Returns 0 if the callee can't be
// resolved -- the desugar then skips the rewrite, same as the
// elem-type-null branch a few lines below.
priv fcall_variadic_count_via_scope := func(fcall: Expr, scope: TypeScope) returns USize {
    if fcall.children.len() == 0 { return 0 }
    ref callee : Expr = fcall.children[0]
    switch callee.node_type {
    case NodeType.Ident(callee_name):
        ref cb : TypeBinding = scope.get_binding(callee_name.ident_name())
        if cb.is_null().not() {
            ref cb_fd : Expr = scope.lookup_func(cb.name)
            if cb_fd.is_null().not() {
                switch cb_fd.node_type {
                case NodeType.FuncDef(cb_fdef):
                    return fcall_variadic_count(fcall, cb_fdef.params.len(), cb_fdef.kwargs_index >= 0)
                case:
                }
            }
        }
    case NodeType.FieldAccess(method_name):
        if fa_is_ns(callee, scope) {
            ref type_node : Expr = callee.children[0]
            switch type_node.node_type {
            case NodeType.Ident(type_name):
                ref sdef : Expr = scope.get_struct(type_name.ident_name())
                if sdef.is_null().not() {
                    ref ns : Vec(Declaration) = def_ns_decls(sdef)
                    for nd : Declaration in ns {
                        if nd.name.eq(method_name.field_access_name()).not() { continue }
                        if nd.default_value.is_null() { break }
                        switch nd.default_value.node_type {
                        case NodeType.FuncDef(ffd):
                            return fcall_variadic_count(fcall, ffd.params.len(), ffd.kwargs_index >= 0)
                        case:
                        }
                        break
                    }
                }
            case:
            }
        }
    case:
    }
    return 0
}

// True if the resolved callee declares a variadic parameter.
// Used by find_variadic_fcall and process_call_desugars as the
// per-FCall predicate "needs variadic-block rewrite". No stored
// FCallData state is needed: variadic_index has been derived away,
// and process_call_desugars is the only thing that triggers the
// rewrite, runs at most once per FCall, so distinguishing pre- vs
// post-rewrite is unnecessary at this site.
priv fcall_callee_has_variadic_via_scope := func(fcall: Expr, scope: TypeScope) returns Bool {
    if fcall.children.len() == 0 { return false }
    ref callee : Expr = fcall.children[0]
    switch callee.node_type {
    case NodeType.Ident(callee_name):
        ref cb : TypeBinding = scope.get_binding(callee_name.ident_name())
        if cb.is_null().not() {
            ref cb_fd : Expr = scope.lookup_func(cb.name)
            if cb_fd.is_null().not() {
                switch cb_fd.node_type {
                case NodeType.FuncDef(cb_fdef):
                    return cb_fdef.variadic_index >= 0
                case:
                }
            }
        }
    case NodeType.FieldAccess(method_name):
        if fa_is_ns(callee, scope) {
            ref type_node : Expr = callee.children[0]
            switch type_node.node_type {
            case NodeType.Ident(type_name):
                ref sdef : Expr = scope.get_struct(type_name.ident_name())
                if sdef.is_null().not() {
                    ref ns : Vec(Declaration) = def_ns_decls(sdef)
                    for nd : Declaration in ns {
                        if nd.name.eq(method_name.field_access_name()).not() { continue }
                        if nd.default_value.is_null() { break }
                        switch nd.default_value.node_type {
                        case NodeType.FuncDef(ffd):
                            return ffd.variadic_index >= 0
                        case:
                        }
                        break
                    }
                }
            case:
            }
        }
    case:
    }
    return false
}

// Per-call position of the variadic block start in fcall.children.
// Derived from the callee: position = 1 + fdef_data.variadic_index
// (callee + params before the variadic param, each contributing one
// child). Returns -1 when the callee has no variadic param. Note this
// is the *expected* position in the post-desugar param-aligned layout;
// it stays meaningful pre-variadic-rewrite (block contains vc args)
// and as a single-child slot post-variadic-rewrite (collapsed to a
// _va_Array_N or splat ident). Caller is responsible for not querying
// after the kwargs rewrite has further shifted children.
priv fcall_variadic_index_via_scope := func(fcall: Expr, scope: TypeScope) returns I32 {
    if fcall.children.len() == 0 { return -1 }
    ref callee : Expr = fcall.children[0]
    switch callee.node_type {
    case NodeType.Ident(callee_name):
        ref cb : TypeBinding = scope.get_binding(callee_name.ident_name())
        if cb.is_null().not() {
            ref cb_fd : Expr = scope.lookup_func(cb.name)
            if cb_fd.is_null().not() {
                switch cb_fd.node_type {
                case NodeType.FuncDef(cb_fdef):
                    fvi := cb_fdef.variadic_index
                    if fvi < 0 { return -1 }
                    return fvi + 1
                case:
                }
            }
        }
    case NodeType.FieldAccess(method_name):
        if fa_is_ns(callee, scope) {
            ref type_node : Expr = callee.children[0]
            switch type_node.node_type {
            case NodeType.Ident(type_name):
                ref sdef : Expr = scope.get_struct(type_name.ident_name())
                if sdef.is_null().not() {
                    ref ns : Vec(Declaration) = def_ns_decls(sdef)
                    for nd : Declaration in ns {
                        if nd.name.eq(method_name.field_access_name()).not() { continue }
                        if nd.default_value.is_null() { break }
                        switch nd.default_value.node_type {
                        case NodeType.FuncDef(ffd):
                            fvi := ffd.variadic_index
                            if fvi < 0 { return -1 }
                            return fvi + 1
                        case:
                        }
                        break
                    }
                }
            case:
            }
        }
    case:
    }
    return -1
}

// Scope-resolving derivation of an FCall's kwargs block position.
// kwargs is always the callee's last parameter (parser invariant), so
// post-desugar param-aligned children layout puts the kwargs block at
// `nparam` when the callee has a kwargs param: variadic (if any) has
// already been collapsed by the variadic rewrite that runs first in
// process_call_desugars, so this single formula covers both the
// no-variadic and the post-variadic-rewrite cases. The body-pre-pass
// caller (find_kwargs_fcall) only uses the sign of the result as a
// "has kwargs block" predicate, so the pre-variadic-rewrite position
// being "off" there is harmless. Returns -1 when the callee has no
// kwargs param. Callee resolution mirrors
// resolve_variadic_elem_type's Ident-binding / Type.method namespace
// shapes.
priv fcall_kwargs_index_via_scope := func(fcall: Expr, scope: TypeScope) returns I32 {
    if fcall.children.len() == 0 { return -1 }
    ref callee : Expr = fcall.children[0]
    switch callee.node_type {
    case NodeType.Ident(callee_name):
        ref cb : TypeBinding = scope.get_binding(callee_name.ident_name())
        if cb.is_null().not() {
            ref cb_fd : Expr = scope.lookup_func(cb.name)
            if cb_fd.is_null().not() {
                switch cb_fd.node_type {
                case NodeType.FuncDef(cb_fdef):
                    return derive_fcall_kwargs_index(fcall, cb_fdef)
                case:
                }
            }
        }
    case NodeType.FieldAccess(method_name):
        if fa_is_ns(callee, scope) {
            ref type_node : Expr = callee.children[0]
            switch type_node.node_type {
            case NodeType.Ident(type_name):
                ref sdef : Expr = scope.get_struct(type_name.ident_name())
                if sdef.is_null().not() {
                    ref ns : Vec(Declaration) = def_ns_decls(sdef)
                    for nd : Declaration in ns {
                        if nd.name.eq(method_name.field_access_name()).not() { continue }
                        if nd.default_value.is_null() { break }
                        switch nd.default_value.node_type {
                        case NodeType.FuncDef(ffd):
                            return derive_fcall_kwargs_index(fcall, ffd)
                        case:
                        }
                        break
                    }
                }
            case:
            }
        }
    case:
    }
    return -1
}

// Shared derivation given a resolved callee FuncDef payload.
// Always returns the post-variadic-rewrite (or no-variadic) kwargs
// position: `nparam` when the callee has a kwargs param, else -1. The
// position is *correct* for the only site that uses it (process_call_desugars,
// which has already rewritten the variadic block by the time it
// queries kwargs). The body-pre-pass call from find_kwargs_fcall only
// uses the >= 0 sign of the result as a predicate, so the
// pre-variadic-rewrite "position would be different" is irrelevant
// there.
priv derive_fcall_kwargs_index := func(_fcall: Expr, fdef_data: FunctionDef) returns I32 {
    if fdef_data.kwargs_index < 0 { return -1 }
    return fdef_data.params.len().to_i32()
}

priv resolve_variadic_elem_type := func(fcall: Expr, scope: TypeScope) returns ref Str {
    ref callee : Expr = fcall.children[0]
    switch callee.node_type {
    case NodeType.Ident(callee_name):
        ref cb : TypeBinding = scope.get_binding(callee_name.ident_name())
        if cb.is_null().not() {
            ref cb_fd : Expr = scope.lookup_func(cb.name)
            if cb_fd.is_null().not() {
                switch cb_fd.node_type {
                case NodeType.FuncDef(cb_fdef):
                    fvi := cb_fdef.variadic_index
                    if fvi >= 0 {
                        ref param : Declaration = cb_fdef.params[fvi.to_usize()]
                        return param.explicit_type
                    }
                case:
                }
            }
        }
    case NodeType.FieldAccess(method_name):
        if fa_is_ns(callee, scope) {
            ref type_node : Expr = callee.children[0]
            switch type_node.node_type {
            case NodeType.Ident(type_name):
                ref sdef : Expr = scope.get_struct(type_name.ident_name())
                if sdef.is_null().not() {
                    ref ns : Vec(Declaration) = def_ns_decls(sdef)
                    for nd : Declaration in ns {
                        if nd.name.eq(method_name.field_access_name()).not() { continue }
                        if nd.default_value.is_null() { break }
                        switch nd.default_value.node_type {
                        case NodeType.FuncDef(ffd):
                            fvi := ffd.variadic_index
                            if fvi >= 0 {
                                ref param : Declaration = ffd.params[fvi.to_usize()]
                                return param.explicit_type
                            }
                        case:
                        }
                        break
                    }
                }
            case:
            }
        }
    case:
    }
    return NULL
}

// Returns true if it rewrote fcall in place. Caller is responsible for
// pushing the (now mutated) stmt into new_ch.
priv desugar_pure_splat_variadic_call := func(mut fcall: Expr, array_type: Str, vi: I32, vc: USize) returns Bool {
    switch fcall.node_type {
    case NodeType.FCall(fcd):
        if vc.eq(1).not() { return false }
        if fcd.is_splat.not() { return false }

        mut old_args := Vec(Expr).new()
        old_args.move_from(fcall.children)

        ref splat_in : Expr = old_args[vi.to_usize()]
        mut splat := splat_in.clone()
        fcd.is_splat = false
        if splat_in.node_type.is(NodeType.Ident) {
            splat = make_clone_call(array_type, Type.Struct(array_type.clone()), splat_in, splat_in)
        }
        mut fcall_new_ch := Vec(Expr).new()
        for j in 0..old_args.len() {
            ji := j.to_i32()
            if ji == vi {
                fcall_new_ch.push(own splat)
            } else {
                fcall_new_ch.push_take(old_args, j)
            }
        }
        fcall.children.move_from(fcall_new_ch)
        set_own_arg(fcall, vi.to_usize())
        return true
    case:
        UNREACHABLE()
        return false
    }
}

priv rewrite_kwargs_fcall_args := func(mut fcall: Expr, kw_name: Str, ki: I32) {
    switch fcall.node_type {
    case NodeType.FCall(fcd):
        kc := fcall_kwargs_count(fcall)
        old_own := fcd.own_args
        mut old_args := Vec(Expr).new()
        old_args.move_from(fcall.children)
        mut fcall_new_ch := Vec(Expr).new()
        mut kw_inserted := false
        mut new_own : U64 = 0

        for j in 0..old_args.len() {
            ji := j.to_i32()
            if ji.gte(ki).and(ji.lt(ki + kc.to_i32())) {
                if kw_inserted.not() {
                    mut kw_id := Expr.new(ident_node(kw_name), fcall.line, fcall.col)
                    kw_id.set_til_type(Type.Struct("KwargsMap"))
                    mut bit : U64 = 1
                    for _ in 0..fcall_new_ch.len() { bit = bit * 2 }
                    new_own = new_own.bor(bit)
                    fcall_new_ch.push(own kw_id)
                    kw_inserted = true
                }
                continue
            }
            if ji.eq(ki).and(kw_inserted.not()) {
                mut kw_id := Expr.new(ident_node(kw_name), fcall.line, fcall.col)
                kw_id.set_til_type(Type.Struct("KwargsMap"))
                mut bit : U64 = 1
                for _ in 0..fcall_new_ch.len() { bit = bit * 2 }
                new_own = new_own.bor(bit)
                fcall_new_ch.push(own kw_id)
                kw_inserted = true
            }
            // Transfer own bit from old position j to new position
            mut old_bit : U64 = 1
            for _ in 0..j { old_bit = old_bit * 2 }
            if old_own.band(old_bit) > 0 {
                mut nb : U64 = 1
                for _ in 0..fcall_new_ch.len() { nb = nb * 2 }
                new_own = new_own.bor(nb)
            }
            fcall_new_ch.push_take(old_args, j)
        }
        if kw_inserted.not() {
            mut kw_id := Expr.new(ident_node(kw_name), fcall.line, fcall.col)
            kw_id.set_til_type(Type.Struct("KwargsMap"))
            mut bit : U64 = 1
            for _ in 0..fcall_new_ch.len() { bit = bit * 2 }
            new_own = new_own.bor(bit)
            fcall_new_ch.push(own kw_id)
        }

        fcall.children.move_from(fcall_new_ch)
        fcd.own_args = new_own
    case:
        UNREACHABLE()
    }
}

priv field_assign_needs_delete := func(stmt: Expr, scope: TypeScope) returns Bool {
    if stmt.fa_own_type(scope).is(OwnType.Ref) { return false }
    if stmt.fa_own_type(scope).is(OwnType.Shallow).not() { return true }
    ft := stmt.children[1].til_type()
    if is_aggregate(ft) { return true }
    return false
}

priv hoist_to_temp := func(mut ctx: Context, val: Expr, mut hoisted: Vec(Expr), mut scope: TypeScope, is_own: Bool) returns Expr {
    tp := type_prefix(val.til_type())
    // Non-underscore prefix so the builder's `_x`-deliberately-unused
    // exemption doesn't free-pass these compiler temps. If a hoisted
    // temp survives DCE and goes unused, that's a DCE bug worth
    // surfacing (as a C -Werror=unused-but-set-variable) rather than
    // hiding behind a `(void)<name>;` guard.
    tname := format("hoisted__", tp, "_", ctx.hoist_counter.to_str())
    ctx.hoist_counter++

    mut decl := Expr.new(NodeType.Decl(Declaration()), val.line, val.col)
    decl.set_til_type(val.til_type())

    mut val_is_ref := false
    if val.node_type.is(NodeType.FCall) {
        val_is_ref = fcall_returns_ref(val, scope).eq(0).not()
    }

    is_compound := is_aggregate(val.til_type())
    // LiteralStr temps: the builder emits these as stack-allocated
    // compound-literal Str values (no malloc). Leaving own_type at
    // Shallow makes the typer-inserted Str.delete use call_free=false,
    // which the builder pairs with `&name` for the own-self arg.
    is_literal_str := val.node_type.is_literal_str()

    decl.add_child(own val.clone())

    mut ident := Expr.new(ident_node(tname), val.line, val.col)
    ident.set_til_type(val.til_type())
    scope.set(tname, val.til_type(), false, ctx.path, val.line, val.col, false, OwnType.Shallow)
    ref mut tb : TypeBinding = scope.get_binding(tname)
    switch decl.node_type {
    case NodeType.Decl(dd):
        dd.name = tname.clone()
        dd.is_mut = false
        if val_is_ref {
            dd.own_type = OwnType.Ref
            if tb.is_null().not() { tb.own_type = OwnType.Ref }
        } else if is_literal_str {
            // leave as Shallow -- builder emits a stack value
        } else if is_own.or(is_compound) {
            dd.own_type = OwnType.Own
            if tb.is_null().not() { tb.own_type = OwnType.Own }
        }
    case:
        UNREACHABLE()
    }

    hoisted.push(own decl)
    return ident
}
