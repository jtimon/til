mode lib

import("context")
import("loader")
import("builder")
import("../std/sys")
import("../std/file")
import("../../vendor/bindings/libffi")
// No link() here: the libffi static lib is host-dependent (the
// configure triple dir only exists for the build host), so the builder
// appends the right archive per target via target_ffi_lib instead. A
// hardcoded Linux path made resolve_link_path fall back to a bogus
// src/self/-relative candidate on mac hosts (issue #25).

system_cmd := ext_proc(cmd: Str) returns shallow I32 {}

priv interp_error_path := func(ctx: Context) returns Str {
    return ctx.path.clone()
}

priv interp_error := proc(e: Expr, msg: Str, ctx: Context) {
    println(interp_error_path(ctx), ":", e.line.to_str(), ":", e.col.to_str(), ": error: ", msg)
}

priv interp_lang_error := proc(e: Expr, msg: Str, ctx: Context) {
    interp_error(e, msg, ctx)
    println("  note: this is a bug in the language, please report it")
}

// True when a struct has a byte layout that a raw memcpy clones correctly --
// i.e. no field contains an owned heap pointer that would alias. This is the
// interpreter-side POD predicate; it is
// strictly more conservative than initer's is_pod_type_for_clone
// because enum payload bytes can themselves own nested heap.
// Issue #147 step 4: replaces dd.field_struct_def reads. Returns the
// nested struct/enum def Expr for a field, or NULL when the field's
// type is a primitive (primitives are registered as ~Type := struct {}~
// in core, so a bare lookup_interp_type_def would return the primitive's
// struct shell and downstream callers would try to clone its bytes
// as a nested struct).
priv field_nested_def := func(dd: Declaration, ctx: Context) returns ref Expr {
    if is_primitive(dd.til_type) { return NULL }
    return lookup_interp_type_def(dd.explicit_type, ctx)
}

priv decl_is_funcsig := func(dd: Declaration, ctx: Context) returns Bool {
    if dd.til_type.is_funcptr() { return true }
    if dd.til_type.is(Type.Body) { return true }
    if dd.explicit_type == "Fn" { return true }
    if dd.explicit_type == "Body" { return true }
    ref tdef : Expr = lookup_interp_type_def(dd.explicit_type, ctx)
    if tdef.is_null() { return false }
    if tdef.node_type.is(NodeType.FuncDef) {
        return tdef.children.len() == 0
    }
    return false
}

priv stable_type_name := func(name: Str, ctx: Context) returns ref Str {
    for registered, _ in ctx.interp_type_defs {
        if registered == name { return registered }
    }
    panic("interpreter type name is not registered: ", name)
}

priv struct_def_shallow_safe := func(sdef_data: StructDef, ctx: Context) returns Bool {
    for dd : Declaration in sdef_data.fields {
        if dd.own_type.is(OwnType.Own) { return false }
        if dd.own_type.is(OwnType.Ref) { continue }
        if decl_is_funcsig(dd, ctx) { return false }
        if dd.explicit_type == "Str" { return false }
        ref fsd : Expr = field_nested_def(dd, ctx)
        if fsd.is_null().not() {
            switch fsd.node_type {
            case NodeType.EnumDef:
                if enum_has_payloads(fsd) { return false }
            case NodeType.StructDef(nested_sdef):
                if struct_def_shallow_safe(nested_sdef, ctx).not() { return false }
            case:
            }
        }
    }
    return true
}

priv str_owns_c_str := func(s_base: Dynamic, ctx: Context) returns Bool {
    ref s : Str = to_ptr(s_base)
    return s.c_str.is_null().not().and(str_cap_at(s_base, ctx).lt(CAP_VIEW)).and(str_cap_at(s_base, ctx).gt(0))
}

priv str_has_owned_storage := func(ptr: Dynamic, ctx: Context) returns Bool {
    ref s : Str = to_ptr(ptr)
    return s.c_str.is_null().not().and(str_cap_at(ptr, ctx).lt(CAP_VIEW)).and(str_cap_at(ptr, ctx).gt(0))
}

priv free_str_owned_storage := func(ptr: Dynamic, ctx: Context) {
    ref s : Str = to_ptr(ptr)
    if str_has_owned_storage(ptr, ctx) { free(own s.c_str) }
}

priv clone_str_storage_into := func(dst: Dynamic, src: Dynamic, ctx: Context) {
    ref s : Str = to_ptr(src)
    if str_has_owned_storage(src, ctx).not() { return }
    cnt := str_count_at(src, ctx)
    cap := str_cap_at(src, ctx)
    copy : Dynamic = malloc(cap.add(1).cast(U64))
    if cnt.gt(0) { memcpy(copy, s.c_str, cnt.cast(U64)) }
    memset(ptr_add(copy, cnt.cast(U64)), 0, 1)
    write_ptr(dst, copy)
    str_write_count_cap(dst, cnt, cap, ctx)
}

// Byte-level deep clone of a struct value at `data` of type `struct_name`.
// Returns a fresh allocation with an independent copy of every owned-pointer
// field (Str c_strs, owned struct/container fields).
priv heap_clone := func(struct_name: Str, data: Dynamic, ctx: Context) returns Dynamic {
    // Look the def up by name while the interpreted AST is live.
    ref struct_def : Expr = lookup_interp_type_def(struct_name, ctx)
    switch struct_def.node_type {
    case NodeType.StructDef(sdef_data):
        sz := ctx_total_size(struct_name, ctx)
        dst_data : Dynamic = EvalHeap.heap_alloc(sz)
        memcpy(dst_data, data, sz)
        if struct_name == "Str" {
            clone_str_storage_into(dst_data, data, ctx)
        } else if struct_name == "DynVec" {
            clone_dyn_vec_buffer(data, dst_data, ctx)
        } else if struct_name == "DynArray" {
            clone_dyn_array_buffer(data, dst_data, ctx)
        } else if struct_name == "DynSet" {
            clone_dyn_set_buffer(data, dst_data, ctx)
        } else if container_elem_type(struct_name, ctx).len() > 0 {
            clone_container_buffer(struct_name, data, dst_data, ctx)
        } else if struct_def_shallow_safe(sdef_data, ctx) {
        } else {
            for dd : Declaration in sdef_data.fields {
                foff := ctx_field_layout(struct_name, dd.name, ctx).offset
                ref ftype : Str = dd.explicit_type
                ref nested_def : Expr = field_nested_def(dd, ctx)
                if dd.own_type.is(OwnType.Own) {
                    if decl_is_funcsig(dd, ctx) {
                        ref src_callable : Dynamic = deref(ptr_add(data, foff))
                        if src_callable.is_null().not() {
                            write_ptr(ptr_add(dst_data, foff), callable_storage_clone(src_callable))
                        }
                        continue
                    }
                    ref src_ptr : Dynamic = deref(ptr_add(data, foff))
                    if src_ptr.is_null().not() {
                        if nested_def.is_null().not() {
                            ref stable_ftype : Str = stable_type_name(ftype, ctx)
                            if nested_def.node_type.is(NodeType.EnumDef) {
                                cloned_enum : Dynamic = heap_clone_enum(stable_ftype, to_ptr(src_ptr), ctx_total_size(stable_ftype, ctx), ctx)
                                write_ptr(ptr_add(dst_data, foff), cloned_enum)
                            } else {
                                cloned_struct : Dynamic = heap_clone(stable_ftype, to_ptr(src_ptr), ctx)
                                write_ptr(ptr_add(dst_data, foff), cloned_struct)
                            }
                        }
                    }
                    continue
                }
                if dd.own_type.is(OwnType.Ref) { continue }
                if decl_is_funcsig(dd, ctx) {
                    ref src_callable2 : Dynamic = deref(ptr_add(data, foff))
                    if src_callable2.is_null().not() {
                        write_ptr(ptr_add(dst_data, foff), callable_storage_clone(src_callable2))
                    }
                    continue
                }
                if ftype == "Str" {
                    clone_str_storage_into(ptr_add(dst_data, foff), ptr_add(data, foff), ctx)
                    continue
                }
                if nested_def.is_null().not() {
                    if nested_def.node_type.is(NodeType.EnumDef) {
                        if enum_has_payloads(nested_def) {
                            ref stable_enum_name : Str = stable_type_name(ftype, ctx)
                            enum_payload_deep_clone(stable_enum_name, ptr_add(dst_data, foff), ctx)
                            continue
                        }
                    }
                }
                if nested_def.is_null().not() {
                    if nested_def.node_type.is(NodeType.EnumDef).not() {
                        switch nested_def.node_type {
                        case NodeType.StructDef:
                            ref stable_ftype2 : Str = stable_type_name(ftype, ctx)
                            cloned_ptr2 : Dynamic = heap_clone(stable_ftype2, ptr_add(data, foff), ctx)
                            memcpy(ptr_add(dst_data, foff), cloned_ptr2, ctx_total_size(ftype, ctx))
                            EvalHeap.heap_free(own cloned_ptr2)
                        case:
                            UNREACHABLE()
                        }
                    }
                }
            }
        }
        if sdef_data.is_interface {
            ref owned_fl : FieldLayout = ctx_field_layout(struct_name, "iface_owned", ctx)
            ref owned : Bool = ptr_add(data, owned_fl.offset)
            if owned {
                ref type_fl : FieldLayout = ctx_field_layout(struct_name, "iface_type_name", ctx)
                ref type_name : Str = ptr_add(data, type_fl.offset)
                ref val_fl : FieldLayout = ctx_field_layout(struct_name, "iface_val", ctx)
                ref src_val : Dynamic = deref(ptr_add(data, val_fl.offset))
                cloned_val : Dynamic = heap_clone_by_type(type_from_name_init(type_name, ctx.scope), src_val, ctx)
                write_ptr(ptr_add(dst_data, val_fl.offset), cloned_val)
            }
        }
        if struct_name == "Tuple" {
            // The field walk above cloned type_names/type_sizes but left the
            // packed `own data: U8` element buffer aliased to src. Give dst its
            // own deep copy so free_tuple_data can reclaim it independently.
            clone_tuple_buffer(data, dst_data, ctx)
        }
        return dst_data
    case:
        UNREACHABLE()
        return NULL
    }
}

CALLABLE_BOX_MAGIC : U64 = 1414745932

InterpCallableBox := struct {
    magic : U64 = 0
    ref func_def : Expr = NULL
    ref env : Scope = NULL
}

HeapBinding := struct {
    // Non-owning address of the raw value block; ownership is described by
    // the flags below and discharged explicitly by scope teardown.
    ref ptr : U8 = NULL
    til_type := Type.Unknown
    own_type := OwnType.Shallow
    ref ctx : Context = NULL
    is_local := false
    is_borrowed := false
    is_erased_dynamic := false
    is_static_callable := false
    moved_out := false
    // #302: an own-primitive binding whose ptr is a BARE raw-allocation
    // pointer (malloc family), not a boxed value block. Readers that
    // collapse prim blocks to words must skip these.
    is_raw_alloc := false
}

Scope := struct {
    // Name -> raw value block pointer plus its type and ownership metadata.
    heap_bindings := Map(Str, HeapBinding).new()
    // Borrowed parameters name their source binding for write-through.
    heap_aliases := Map(Str, Str).new()
    ref parent : Scope = NULL
    is_call_scope := false
}

InterpSession := struct {
    ref global : Scope = NULL
    core_evaluated := false
    // #192: USize, not U32 -- user_argc is a count compared/combined with
    // nparam/fixed (USize) and assigned from user_argv.len() (USize). At U32
    // that matched only because USize was U32; target-dependent USize makes the
    // width mismatch a hard type error on 64-bit.
    user_argc : USize = 0
    retained_programs := Vec(DynPtrBox).new()
    // Display paths of imported (non-entry) units whose top-level globals
    // have already been evaluated into `global`. The REPL evaluates the
    // entry root incrementally but must run an imported unit's global
    // initializers once (e.g. std/doc's __til_*_blob__), the same role
    // core_evaluated plays for core_units. Keyed by path so a mid-session
    // import (added via the full-load path) is picked up on its first turn.
    evaluated_units := Set(Str).new()
}

// Return-value / control-flow state and namespace fields now live on
// Context (has_return, has_break, has_continue, return_value,
// ns_fields / ns_inited), reached in the eval functions via
// `ref mut c : Context = ctx`. During has_return, return_value is a
// non-owning pointer to the raw call result.
// Cached struct defs for
// C-side construction likewise live on Context (cached_*_def),
// populated during interpret_register_struct_defs.

// --- Type-def registry: maps struct/enum names to their AST def Expr.
// Populated by interpreter_init_ns from every struct/enum decl seen in core+user
// programs. Replaces dangerous Declaration.field_struct_def reads at use sites.
// (#147 anti-pattern catalog: layout cache on AST nodes / dangerous refs.)
// The map itself lives on Context (ctx.interp_type_defs); this reader
// reaches it through codegen_lp(), which interpret_units installs
// before any eval runs.
lookup_interp_type_def := func(name: Str, ctx: Context) returns ref Expr {
    ref slot : Dynamic = ctx.interp_type_defs.get(name)?
    catch (e: KeyNotFound) { return NULL }
    return deref(slot)
}

ENUM_PAYLOAD_OFFSET : USize = 8

priv enum_variant_index_for_tag_key := func(enum_name: Str, etag: I64, ctx: Context) returns I32 {
    ref edef : Expr = lookup_interp_type_def(enum_name, ctx)
    if edef.is_null() { return -1 }
    switch edef.node_type {
    case NodeType.EnumDef(edd):
        for i in 0..edd.variants.len() {
            mut tag_value := i.to_i64()
            if i < edd.tag_values.len() { tag_value = edd.tag_values[i].clone() }
            if tag_value == etag { return i.to_i32() }
        }
    case:
    }
    return -1
}


// Issue #272: the enum's Str payload (at ENUM_PAYLOAD_OFFSET) holds a c_str
// pointer that, post-memcpy, aliases the source Str. Replace it with an
// owned deep copy so the enum no longer shares the source's buffer.
priv enum_clone_str_payload := func(data: Dynamic, ctx: Context) {
    ref payload : Dynamic = ptr_add(data, ENUM_PAYLOAD_OFFSET)
    clone_str_storage_into(payload, payload, ctx)
}

// #286 Stage 2: byte-level enum payload clone. The enum name/context supply
// payload ownership metadata; value bytes stay raw.
priv heap_clone_enum := func(enum_name: Str, data: Dynamic, data_size: USize, ctx: Context) returns Dynamic {
    pdata : Dynamic = EvalHeap.heap_alloc(data_size)
    memcpy(pdata, data, data_size.cast(U64))
    enum_payload_deep_clone(enum_name, pdata, ctx)
    return pdata
}

// Free the owned Str-payload c_str (set up by enum_clone_str_payload).
priv enum_free_str_payload := func(data: Dynamic, ctx: Context) {
    free_str_owned_storage(ptr_add(data, ENUM_PAYLOAD_OFFSET), ctx)
}

priv enum_data_tag_key := func(data: Dynamic, enum_def: Expr) returns I64 {
    tag_w := enum_tag_size(enum_def)
    if tag_w == 1 { ref t : U8 = data; return t.to_i64() }
    if tag_w == 2 { ref t : U16 = data; return t.to_i64() }
    if tag_w == 8 { ref t : I64 = data; return t.clone() }
    ref t : I32 = data
    return t.cast(I64)
}

priv enum_payload_type_ref := func(enum_name: Str, data: Dynamic, ctx: Context) returns ref Str {
    ref edef : Expr = lookup_interp_type_def(enum_name, ctx)
    if edef.is_null() { return NULL }
    switch edef.node_type {
    case NodeType.EnumDef(edd):
        idx := enum_variant_index_for_tag_key(enum_name, enum_data_tag_key(data, edef), ctx)
        if idx < 0 { return NULL }
        idx_key := idx.cast(I64)
        if edd.payload_types.has(idx_key) { return edd.payload_types[idx_key] }
    case:
    }
    return NULL
}

priv enum_payload_deep_free := func(enum_name: Str, data: Dynamic, ctx: Context) {
    ref payload_type : Str = enum_payload_type_ref(enum_name, data, ctx)
    if payload_type.is_null() { return }
    if payload_type == "Str" { enum_free_str_payload(data, ctx); return }
    resolved := type_from_name_init(payload_type, ctx.scope)
    if resolved.is(Type.Primitive).or(resolved.is(Type.Dynamic)).or(resolved.is_funcptr()).or(resolved.is(Type.Body)) { return }
    ref payload_def : Expr = lookup_interp_type_def(payload_type, ctx)
    if payload_def.is_null() { panic("enum payload has no registered type def: ", payload_type) }
    ref payload_data : Dynamic = ptr_add(data, ENUM_PAYLOAD_OFFSET)
    switch payload_def.node_type {
    case NodeType.StructDef:
        heap_drop_struct(payload_type, payload_data, ctx)
    case NodeType.EnumDef:
        enum_payload_deep_free(payload_type, payload_data, ctx)
    case:
        panic("enum payload is not a struct or enum: ", payload_type)
    }
}

priv enum_payload_deep_clone := func(enum_name: Str, data: Dynamic, ctx: Context) {
    ref payload_type : Str = enum_payload_type_ref(enum_name, data, ctx)
    if payload_type.is_null() { return }
    if payload_type == "Str" { enum_clone_str_payload(data, ctx); return }
    resolved := type_from_name_init(payload_type, ctx.scope)
    if resolved.is(Type.Primitive).or(resolved.is(Type.Dynamic)).or(resolved.is_funcptr()).or(resolved.is(Type.Body)) { return }
    ref payload_def : Expr = lookup_interp_type_def(payload_type, ctx)
    if payload_def.is_null() { panic("enum payload has no registered type def: ", payload_type) }
    ref payload_data : Dynamic = ptr_add(data, ENUM_PAYLOAD_OFFSET)
    switch payload_def.node_type {
    case NodeType.StructDef:
        cloned_payload : Dynamic = heap_clone(payload_type, payload_data, ctx)
        memcpy(payload_data, cloned_payload, ctx_total_size(payload_type, ctx))
        EvalHeap.heap_free(own cloned_payload)
    case NodeType.EnumDef:
        enum_payload_deep_clone(payload_type, payload_data, ctx)
    case:
        panic("enum payload is not a struct or enum: ", payload_type)
    }
}

// #286 Stage 2: drop nested heap owned by an enum payload.
priv heap_drop_enum := func(enum_name: Str, data: Dynamic, ctx: Context) {
    if data.is_null() { return }
    enum_payload_deep_free(enum_name, data, ctx)
}

priv write_enum_flat := func(data: Dynamic, enum_name: Str, etag: I64, payload_data: Dynamic, payload_size: USize, str_payload: Bool, move_src: Bool, ctx: Context) {
    // The interpreter's flat enum value places the payload at the fixed
    // ENUM_PAYLOAD_OFFSET (8), independent of the C struct's tighter layout.
    // dispatch_result_alloc reserves that flat layout for every enum result.
    // #264 follow-up: write the enum's full tag width (1/2/4/8 bytes) so a
    // >32-bit U64 tag is stored intact. til's memcpy(dest, value, n) copies
    // the n low bytes of `etag`. REM: an anon / macro-generated enum is not
    // name-registered, so the lookup legitimately misses -- such enums are the
    // historical default width (4 bytes).
    ref tedef : Expr = lookup_interp_type_def(enum_name, ctx)
    mut tag_w : USize = 4
    if tedef.is_null().not() { tag_w = enum_tag_size(tedef) }
    memcpy(data, etag, tag_w.cast(UPtr))
    if payload_data.is_null().not() {
        if payload_size > 0 {
            memcpy(ptr_add(data, ENUM_PAYLOAD_OFFSET), payload_data, payload_size)
            // move_src (construction): MOVE nested ownership into the enum.
            // Non-move reads clone nested payload storage so source and value
            // each own independent buffers.
            if move_src {
                if str_payload { write_ptr(payload_data, NULL) }
            } else {
                enum_payload_deep_clone(enum_name, data, ctx)
            }
        }
    }
}

priv elem_size_for_type := func(type_name: Str, ctx: Context) returns USize {
    if type_name == "I64"  { return I64.size() }
    if type_name == "U8"   { return U8.size() }
    if type_name == "I8"   { return I8.size() }
    if type_name == "I16"  { return I16.size() }
    if type_name == "U16"  { return U16.size() }
    if type_name == "I32"  { return I32.size() }
    if type_name == "U32"  { return U32.size() }
    if type_name == "U64"  { return U64.size() }
    // Width aliases: build_argv_array runs at interpret time, where
    // host == target, so this compiler's own sizes are the right widths.
    if type_name == "USize" { return USize.size() }
    if type_name == "UPtr" { return UPtr.size() }
    // Missing F32 fell through to the old `return 8` default, so ..F32
    // variadic elems were written at stride 8 but read at stride 4:
    // every element after the first came back as garbage under interpret.
    if type_name == "F32"  { return F32.size() }
    if type_name == "Bool" { return Bool.size() }
    // #192: Str's size is target-dependent (its count/cap are USize); read it
    // from ctx so a U32-built til_boot folding U64 core uses the source width.
    if type_name == "Str"  { return ctx_total_size(ctx.cached_str_name, ctx) }
    // The loader restricts variadic main() elem types to the set above;
    // anything else here is a bug -- fail loud, not with a wrong stride.
    panic("elem_size_for_type: unhandled element type '", type_name, "'")
    return 8
}

// Parse a single CLI argument string into raw storage of the named type. Kept in
// lockstep with the builder's cli_box_expr (src/self/builder.til): same type
// set, same reject-non-true/false Bool handling, and a non-zero exit on a bad
// value or unsupported type, so `til interpret` and compiled binaries agree.
// (panic exits 1 like the compiled backend's exit(1); the diagnostic stream
// differs -- interpreter via panic, compiled via stderr -- but both bail.)
priv parse_cli_arg := func(s: Str, type_name: Str, ctx: Context) returns Dynamic {
    t := type_from_name_init(type_name, ctx.scope)
    mut result : Dynamic = dispatch_result_alloc(t, ctx)
    if type_name == "Str" { dispatch_write_str(result, s.c_str, s.count, ctx); return result }
    if type_name == "I64" { write_i64(result, s.to_i64()); return result }
    if type_name == "U8" { write_u8(result, s.to_u8()); return result }
    if type_name == "I8" { write_i8(result, s.to_i8()); return result }
    if type_name == "I16" { write_i16(result, s.to_i16()); return result }
    if type_name == "U16" { write_u16(result, s.to_u16()); return result }
    if type_name == "I32" { write_i32(result, s.to_i32()); return result }
    if type_name == "U32" { write_u32(result, s.to_u32()); return result }
    if type_name == "U64" { write_u64(result, s.to_u64()); return result }
    if type_name == "USize" {
        ref width : Str = resolve_type_alias(ctx.scope, "USize")
        if width == "U32" { write_u32(result, s.to_u32()) }
        else { write_u64(result, s.to_u64()) }
        return result
    }
    if type_name == "UPtr" {
        ref width : Str = resolve_type_alias(ctx.scope, "UPtr")
        if width == "U32" { write_u32(result, s.to_u32()) }
        else { write_u64(result, s.to_u64()) }
        return result
    }
    if type_name == "F32" { write_f32(result, s.to_f32()); return result }
    if type_name == "Bool" {
        if s == "true" { write_bool(result, true); return result }
        if s == "false" { write_bool(result, false); return result }
        panic("cannot parse '", s, "' as Bool (expected true/false)")
    }
    panic("unsupported CLI argument type '", type_name, "'")
    return result
}

priv call_result_is_ref := func(e: Expr, ctx: Context) returns Bool {
    return fcall_returns_ref(e, ctx.scope).neq(0)
}

priv call_copies_ref_str := func(scope: Scope, e: Expr, ctx: Context) returns Bool {
    if call_result_is_ref(e, ctx).not() { return false }
    switch e.til_type() {
    case Type.Struct(name):
        if name != "Str" { return false }
    case:
        return false
    }
    switch e.children[0].node_type {
    case NodeType.Ident(id):
        ref slot : Dynamic = scope_get(scope, id.ident_name())?
        catch (missing: KeyNotFound) { return false }
        ref raw : Dynamic = slot
        ref fn_def : Expr = callable_raw_func_def(raw)
        switch fn_def.node_type {
        case NodeType.FuncDef(fd): return fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc))
        case: return false
        }
    case NodeType.FieldAccess(fa):
        ref receiver : Expr = e.children[0].children[0]
        mut type_name := til_type_name(receiver.til_type())
        if type_name.len() == 0 { type_name = til_type_name_c(receiver.til_type()) }
        ref fn_raw : Dynamic = ns_get(type_name, fa.field_access_name(), ctx)
        if fn_raw.is_null() { return false }
        ref fn_def : Expr = callable_raw_func_def(fn_raw)
        switch fn_def.node_type {
        case NodeType.FuncDef(fd): return fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc))
        case: return false
        }
    case:
    }
    return false
}

priv call_raw_result_is_ref := func(scope: Scope, e: Expr, ctx: Context) returns Bool {
    return call_result_is_ref(e, ctx).and(call_copies_ref_str(scope, e, ctx).not())
}

// --- Inline-scalar value words ------------------------------------------
// A raw value word for a PRIMITIVE-typed expression holds the scalar's
// bytes zero-extended in the word itself (canonical: unused high bits
// zero, Bool is 0/1); with is_ref it holds the BARE storage ADDRESS
// instead. A None-typed result is the null word. Aggregates, Dynamic,
// and callables keep heap-pointer words. BINDINGS always keep a real
// heap block (hb.ptr) so refs share stable storage and FFI sees real
// addresses; words exist only between evals. This restores the old
// Value box's inline scalars (reads/temps/results allocate nothing)
// while aggregates stay raw.

raw_type_is_prim := func(shallow t: Type, ctx: Context) returns Bool {
    switch t {
    case Type.Primitive: return true
    case Type.Custom(name): return raw_type_is_prim(type_from_name_init(name, ctx.scope), ctx)
    case:
    }
    return false
}

// Canonicalize integer bits into a value word for primitive type `t`:
// mask to the type's width (Bool to 0/1) so compares and unsigned reads
// can trust the high bits.
priv scalar_word_encode := func(shallow t: Type, bits: U64, ctx: Context) returns Dynamic {
    switch t {
    case Type.Primitive(prim):
        switch prim {
        case Primitive.U8:  return bits_word(bits.cast(I64).to_u8().cast(U64))
        case Primitive.I8:  return bits_word(bits.cast(I64).to_u8().cast(U64))
        case Primitive.I16: return bits_word(bits.cast(I64).to_u16().cast(U64))
        case Primitive.U16: return bits_word(bits.cast(I64).to_u16().cast(U64))
        case Primitive.I32: return bits_word(bits.to_u32().cast(U64))
        case Primitive.U32: return bits_word(bits.to_u32().cast(U64))
        case Primitive.F32: return bits_word(bits.to_u32().cast(U64))
        case Primitive.Bool:
            if bits == 0 { return bits_word(0) }
            return bits_word(1)
        case: return bits_word(bits)
        }
    case Type.Custom(name): return scalar_word_encode(type_from_name_init(name, ctx.scope), bits, ctx)
    case:
    }
    panic("scalar_word_encode on non-primitive: ", til_type_name_c(t))
    return NULL
}

// Load a scalar's bytes at `addr` into a canonical inline word.
scalar_word_load := func(shallow t: Type, addr: Dynamic, ctx: Context) returns Dynamic {
    switch t {
    case Type.Primitive(prim):
        switch prim {
        case Primitive.U8:   ref v : U8 = addr;  return bits_word(v.cast(U64))
        case Primitive.I8:   ref v : U8 = addr;  return bits_word(v.cast(U64))
        case Primitive.I16:  ref v : U16 = addr; return bits_word(v.cast(U64))
        case Primitive.U16:  ref v : U16 = addr; return bits_word(v.cast(U64))
        case Primitive.I32:  ref v : U32 = addr; return bits_word(v.cast(U64))
        case Primitive.U32:  ref v : U32 = addr; return bits_word(v.cast(U64))
        case Primitive.F32:  ref v : U32 = addr; return bits_word(v.cast(U64))
        case Primitive.Bool: ref v : U8 = addr;  return bits_word(v.cast(U64))
        case: ref v : U64 = addr; return bits_word(v.clone())
        }
    case Type.Custom(name): return scalar_word_load(type_from_name_init(name, ctx.scope), addr, ctx)
    case:
    }
    panic("scalar_word_load on non-primitive: ", til_type_name_c(t))
    return NULL
}

// ctx.struct_layouts is deliberately HOST width (initer #192: the
// compile-time interpreter operates on host-laid-out struct bytes), while
// a USize/UPtr field's til_type resolves to the TARGET primitive. Field
// scalar accesses must use the LAYOUT width: an 8-byte access at a 4-byte
// host slot merges the neighbouring field (--usize=64 count/cap pairs).
// USize/UPtr are the only width-varying prims and both are unsigned, so
// the substitute type is U32/U64 by the layout size.
field_word_type := func(shallow ft: Type, field_size: USize, ctx: Context) returns Type {
    if raw_type_size(ft, ctx) == field_size { return ft.clone() }
    if field_size == 4 { return Type.Primitive(Primitive.U32) }
    if field_size == 8 { return Type.Primitive(Primitive.U64) }
    return ft.clone()
}

// Store an inline word's scalar at `addr` (the type's exact width).
priv scalar_word_store := func(shallow t: Type, addr: Dynamic, w: Dynamic, ctx: Context) {
    bits := word_bits(w)
    switch t {
    case Type.Primitive(prim):
        switch prim {
        case Primitive.U8:   write_u8(addr, bits.cast(I64).to_u8())
        case Primitive.I8:   write_u8(addr, bits.cast(I64).to_u8())
        case Primitive.I16:  write_u16(addr, bits.cast(I64).to_u16())
        case Primitive.U16:  write_u16(addr, bits.cast(I64).to_u16())
        case Primitive.I32:  write_u32(addr, bits.to_u32())
        case Primitive.U32:  write_u32(addr, bits.to_u32())
        case Primitive.F32:  write_u32(addr, bits.to_u32())
        case Primitive.Bool: write_u8(addr, bits.cast(I64).to_u8())
        case: write_u64(addr, bits)
        }
        return
    case Type.Custom(name): scalar_word_store(type_from_name_init(name, ctx.scope), addr, w, ctx); return
    case:
    }
    panic("scalar_word_store on non-primitive: ", til_type_name_c(t))
}

// Result placeholder for intercepts and value-less falls: primitive,
// None, and Unknown-typed results are the null word (no allocation);
// aggregates still get a zeroed block of their size.
priv raw_unit_result := func(shallow t: Type, ctx: Context) returns Dynamic {
    if t.is(Type.None).or(t.is(Type.Unknown)) { return NULL }
    if raw_type_is_prim(t, ctx) { return NULL }
    return dispatch_result_alloc(t, ctx)
}

// Fresh binding block holding the word's scalar: bindings need stable
// heap storage even though transient values ride inline.
scalar_block_from_word := func(shallow t: Type, w: Dynamic, ctx: Context) returns Dynamic {
    block : Dynamic = dispatch_result_alloc(t, ctx)
    scalar_word_store(t, block, w, ctx)
    return block
}

// True when a decl's RHS is a #302 raw-allocation call: the allocator
// trio declares `own Dynamic` but the typer re-stamps the call to the
// decl's primitive, so the eval value is a BARE pointer (the same
// malloc/calloc/realloc name set the garbager's LocalInfo model keys on).
priv rhs_is_raw_alloc_call := func(rhs: Expr) returns Bool {
    switch rhs.node_type {
    case NodeType.FCall:
        if rhs.children.len() == 0 { return false }
        switch rhs.children[0].node_type {
        case NodeType.Ident(cid):
            return cid.ident_name().eq("malloc").or(cid.ident_name().eq("calloc")).or(cid.ident_name().eq("realloc"))
        case:
        }
    case:
    }
    return false
}

// Value-word -> binding-slot boundary: primitive VALUES box into a fresh
// block; a #302 raw-alloc POINTER (an allocator call, whatever the decl's
// own-ness, or an own-consumed rhs still stamped Dynamic) already IS a
// bare pointer and stays the slot itself. An own-consumed prim VALUE
// local (`x := 42` later passed `own`) is still a value: decide by the
// RHS, not own_type alone.
priv binding_block_from_word := func(shallow t: Type, w: Dynamic, rhs_is_pointer: Bool, ctx: Context) returns Dynamic {
    if raw_type_is_prim(t, ctx).and(rhs_is_pointer.not()) { return scalar_block_from_word(t, w, ctx) }
    return w
}

// Depth-stack of 8-byte result slots for ext/builtin dispatch with a
// primitive or None result type: handlers keep their write-into-buffer
// contract, but the buffer is a reusable stack slot instead of a heap
// block per call. Push/pop are balanced inside the dispatching frame,
// so arbitrarily nested dispatches each see their own live slot.
// The slot arenas live in fixed C-side static storage (ext.c): slot
// addresses are immortal, so no allocation, growth, or teardown can
// invalidate one while a dispatch is in flight.
DISPATCH_SCRATCH_SLOTS : USize = 4096
priv mut dispatch_scratch_depth : USize = 0

priv dispatch_scratch_push := func() returns Dynamic {
    if dispatch_scratch_depth == DISPATCH_SCRATCH_SLOTS { panic("dispatch scratch overflow") }
    off := dispatch_scratch_depth.mul(8)
    dispatch_scratch_depth = dispatch_scratch_depth + 1
    return ptr_add(dispatch_scratch_base(), off)
}

priv dispatch_scratch_pop := func() {
    dispatch_scratch_depth = dispatch_scratch_depth - 1
}

// Rotating ring of 8-byte slots that give a WORD a real address for the
// raw-memory builtins (memcmp operands, enum payload sources). Slots stay
// valid until the ring wraps; callers must take their pointers only after
// every nested eval of the same call is done (evaluate size args first).
WORD_RING_SLOTS : USize = 4096
priv mut word_ring_idx : USize = 0

priv word_ring_slot := func(shallow t: Type, w: Dynamic, ctx: Context) returns Dynamic {
    off := word_ring_idx.mul(8)
    word_ring_idx = word_ring_idx + 1
    if word_ring_idx == WORD_RING_SLOTS { word_ring_idx = 0 }
    write_u64(ptr_add(word_ring_base(), off), 0)
    scalar_word_store(t, ptr_add(word_ring_base(), off), w, ctx)
    return ptr_add(word_ring_base(), off)
}

// True when the eval of `e` yields an INLINE WORD (a prim-stamped
// literal, call result, or dispatch result); false when it yields an
// address or a heap block. An IDENT eval is always the bare binding
// address (expr_raw_is_ref is true for every non-callable Ident), so
// Idents are never word-shaped.
priv expr_word_shaped := func(_s: Scope, e: Expr, ctx: Context) returns Bool {
    switch e.node_type {
    case NodeType.Ident: return false
    case:
    }
    return raw_type_is_prim(e.til_type(), ctx)
}

// Collapse an already-evaluated raw for the scalar-typed expr `e` into an
// inline word, whatever the eval produced: a word passes through, a ref
// (a BARE borrowed target address) or an erased Dynamic slot loads
// through its address. Frees an owned block raw; refs stay borrowed.
priv scalar_word_of_raw := func(s: Scope, e: Expr, raw: Dynamic, shallow decode_type: Type, ctx: Context) returns Dynamic {
    if expr_raw_is_ref(s, e, ctx) {
        // A ref raw is the bare target address: load through it; the
        // target still owns its storage.
        return scalar_word_load(decode_type, raw, ctx)
    }
    if expr_word_shaped(s, e, ctx).not() {
        // A non-ref non-word prim-decoded eval is a Dynamic slot (a
        // prim-stamped erased result): load through its pointer and
        // reclaim the slot. (Idents never reach here -- they are refs.)
        ref addr : Dynamic = deref(raw)
        loaded : Dynamic = scalar_word_load(decode_type, addr, ctx)
        mut owned_raw : Dynamic = raw
        EvalHeap.heap_free(own owned_raw)
        return loaded
    }
    return raw
}

// Evaluate a scalar-typed argument down to an inline word.
priv eval_scalar_arg_word := proc(s: Scope, e: Expr, shallow decode_type: Type, mut ctx: Context) returns Dynamic {
    raw : Dynamic = eval_expr_raw(s, e, ctx)
    return scalar_word_of_raw(s, e, raw, decode_type, ctx)
}

// Evaluate a Bool-typed argument to a til-level truth value.
priv eval_bool_arg := proc(s: Scope, e: Expr, mut ctx: Context) returns Bool {
    return word_bits(eval_scalar_arg_word(s, e, Type.Primitive(Primitive.Bool), ctx)) != 0
}

priv expr_raw_is_ref := func(scope: Scope, e: Expr, ctx: Context) returns Bool {
    if e.node_type.is(NodeType.FCall) { return call_raw_result_is_ref(scope, e, ctx) }
    if e.node_type.is(NodeType.FieldAccess) { return field_access_returns_ref(scope, e, ctx) }
    switch e.node_type {
    case NodeType.Ident(id):
        ref hb : HeapBinding = scope_lookup_heap_binding(scope, id.ident_name())
        if hb.is_null() { panic("reference query binding not found: ", id.ident_name()) }
        if heap_type_is_callable(hb.til_type) { return false }
        return true
    case:
    }
    return false
}

priv raw_block_free := func(raw: Dynamic) {
    mut owned_raw : Dynamic = raw
    EvalHeap.heap_free(own owned_raw)
}

priv raw_result_reframe := func(shallow t: Type, raw: Dynamic, from_ref: Bool, to_ref: Bool, ctx: Context) returns Dynamic {
    if from_ref == to_ref { return raw }
    if from_ref {
        // A ref result is a BARE target address; converting to a value
        // loads the primitive inline instead of cloning a block.
        if raw_type_is_prim(t, ctx) { return scalar_word_load(t, raw, ctx) }
        return heap_clone_by_type(t, raw, ctx)
    }
    if raw_type_is_prim(t, ctx) { panic("cannot reframe a primitive value as a ref: ", til_type_name_c(t)) }
    return raw
}

priv raw_result_move_into := proc(shallow t: Type, dst: Dynamic, src: Dynamic, return_is_ref: Bool, ctx: Context) {
    mut size : USize = 0
    switch t {
    case Type.None: return
    case Type.Primitive(prim):
        // A ref result is a BARE target address: deref-copy the scalar
        // out; the target still owns its block. A value result is the
        // inline word itself.
        if return_is_ref {
            mut align : USize = 0
            builtin_primitive_size_align(prim, size, align)
            memcpy(dst, src, size)
            return
        }
        scalar_word_store(t, dst, src, ctx)
        return
    case Type.Struct(name):
        if return_is_ref { size = Dynamic.size() }
        else { size = ctx_total_size(name, ctx) }
    case Type.Enum(name):
        if return_is_ref { size = Dynamic.size() }
        else { size = dispatch_enum_size(name, ctx) }
    case Type.Dynamic: size = Dynamic.size()
    case Type.FuncPtr: size = Dynamic.size()
    case Type.FuncPtrSig: size = Dynamic.size()
    case Type.Body: size = Dynamic.size()
    case Type.Custom(name):
        raw_result_move_into(type_from_name_init(name, ctx.scope), dst, src, return_is_ref, ctx)
        return
    case:
        panic("cannot move raw call result for type ", til_type_name_c(t))
    }
    memcpy(dst, src, size)
    raw_block_free(src)
}

priv raw_result_finish := proc(shallow t: Type, raw: Dynamic, destination: Dynamic, return_is_ref: Bool, ctx: Context) returns Dynamic {
    if destination.is_null().or(return_is_ref).or(raw.ptr_eq(destination)) { return raw }
    raw_result_move_into(t, destination, raw, false, ctx)
    return destination
}

priv raw_result_drop_nested := proc(shallow t: Type, raw: Dynamic, return_is_ref: Bool, ctx: Context) {
    switch t {
    case Type.Struct(name):
        if return_is_ref.not() { heap_drop_struct(name, raw, ctx) }
    case Type.Enum(name):
        if return_is_ref.not() { heap_drop_enum(name, raw, ctx) }
    case Type.FuncPtr:
        heap_drop_by_type(t, raw, ctx)
    case Type.FuncPtrSig:
        heap_drop_by_type(t, raw, ctx)
    case Type.Body:
        heap_drop_by_type(t, raw, ctx)
    case Type.Custom(name):
        raw_result_drop_nested(type_from_name_init(name, ctx.scope), raw, return_is_ref, ctx)
    case:
    }
}

raw_result_drop := proc(shallow t: Type, raw: Dynamic, return_is_ref: Bool, ctx: Context) {
    if return_is_ref { return }
    // A non-ref primitive or None result is an inline word: nothing was
    // allocated, nothing to free.
    if raw_type_is_prim(t, ctx).or(t.is(Type.None)) { return }
    raw_result_drop_nested(t, raw, return_is_ref, ctx)
    mut owned_raw : Dynamic = raw
    EvalHeap.heap_free(own owned_raw)
}

priv raw_result_drop_ptr := proc(shallow t: Type, raw: Dynamic, return_is_ref: Bool, ctx: Context) {
    mut owned_raw : Dynamic = raw
    raw_result_drop(t, owned_raw, return_is_ref, ctx)
}

scope_set_raw_owned := func(scope: Scope, name: Str, raw: Dynamic, shallow t: Type, own_type: OwnType, ctx: Context, borrowed: Bool = false) {
    if t.is(Type.Unknown) { panic("cannot bind raw value with unknown type: ", name) }
    scope_set_heap_owned(scope, name, raw, t, own_type, ctx, true, borrowed)
}

priv raw_widen_numeric := func(raw: Dynamic, shallow source_type: Type, target_name: Str, ctx: Context) returns Dynamic {
    if target_name.len() == 0 { return raw }
    source_name := til_type_name_c(source_type)
    ref resolved_target : Str = resolve_type_alias(ctx.scope, target_name)
    if resolved_target == source_name { return raw }
    // Pure word-to-word conversion: decode the source scalar (with sign
    // extension) from the inline word, re-encode at the target's width.
    mut signed_value : I64 = 0
    mut unsigned_value : U64 = 0
    bits := word_bits(raw)
    mut is_unsigned := false
    switch source_type {
    case Type.Primitive(prim):
        switch prim {
        case Primitive.U8: unsigned_value = bits; is_unsigned = true
        case Primitive.I8: signed_value = bits.cast(I64).to_u8().cast(I8).cast(I64)
        case Primitive.I16: signed_value = bits.cast(I64).to_u16().cast(I16).cast(I64)
        case Primitive.U16: unsigned_value = bits; is_unsigned = true
        case Primitive.I32: signed_value = bits.cast(I64).to_u32().cast(I32).cast(I64)
        case Primitive.U32: unsigned_value = bits; is_unsigned = true
        case:
            return raw
        }
    case:
        return raw
    }
    if is_unsigned.not() { unsigned_value = signed_value.cast(U64) }
    else { signed_value = unsigned_value.cast(I64) }
    if resolved_target == "I64" { return bits_word(signed_value.cast(U64)) }
    if resolved_target == "U64" { return bits_word(unsigned_value) }
    if resolved_target == "I32" { return scalar_word_encode(Type.Primitive(Primitive.I32), signed_value.cast(U64), ctx) }
    if resolved_target == "U32" { return scalar_word_encode(Type.Primitive(Primitive.U32), unsigned_value, ctx) }
    return raw
}

priv raw_coerce_value := func(raw: Dynamic, shallow source_type: Type, shallow target_type: Type, ctx: Context, target_own_type: OwnType = OwnType.Shallow) returns Dynamic {
    if target_type.is(Type.Dynamic).and(source_type.is(Type.Dynamic).not()) {
        if heap_type_is_callable(source_type) { return raw }
        // A primitive word has no storage yet: box the scalar into a real
        // block first so the Dynamic slot can point at bytes (C's &x).
        mut boxed : Dynamic = raw
        if raw_type_is_prim(source_type, ctx) { boxed = scalar_block_from_word(source_type, raw, ctx) }
        wrapper : Dynamic = EvalHeap.heap_alloc(Dynamic.size())
        write_ptr(wrapper, boxed)
        return wrapper
    }
    switch source_type {
    case Type.Custom(name):
        return raw_coerce_value(raw, type_from_name_init(name, ctx.scope), target_type, ctx, target_own_type)
    case Type.Dynamic:
        if target_type.is(Type.Dynamic).not() {
            if heap_type_is_callable(target_type).and(callable_box_is(deref(raw))) { return raw }
            ref pointed : Dynamic = deref(raw)
            // Unboxing to a SHALLOW primitive loads the scalar inline; the
            // pointed block stays owned by whoever boxed it. An own/ref
            // primitive target keeps the pointer-transfer below (#302
            // raw-alloc params take the block pointer itself as the datum).
            if raw_type_is_prim(target_type, ctx).and(target_own_type.is(OwnType.Shallow)) {
                loaded : Dynamic = scalar_word_load(target_type, pointed, ctx)
                raw_block_free(raw)
                return loaded
            }
            mut result : Dynamic = pointed
            if target_own_type.is(OwnType.Shallow) {
                result = heap_clone_by_type(target_type, pointed, ctx)
            }
            raw_block_free(raw)
            return result
        }
    case:
    }
    return raw_widen_numeric(raw, source_type, til_type_name_c(target_type), ctx)
}

priv raw_type_size := func(shallow t: Type, ctx: Context) returns USize {
    switch t {
    case Type.None: return 1
    case Type.Primitive(prim):
        mut size : USize = 0
        mut align : USize = 0
        builtin_primitive_size_align(prim, size, align)
        return size
    case Type.Struct(name): return ctx_total_size(name, ctx)
    case Type.Enum(name): return dispatch_enum_size(name, ctx)
    case Type.Dynamic: return Dynamic.size()
    case Type.FuncPtr: return Dynamic.size()
    case Type.FuncPtrSig: return Dynamic.size()
    case Type.Body: return Dynamic.size()
    case Type.Custom(name): return raw_type_size(type_from_name_init(name, ctx.scope), ctx)
    case:
        panic("cannot size raw type ", til_type_name_c(t))
        return 0
    }
}

priv raw_to_u64 := func(shallow t: Type, raw: Dynamic, ctx: Context) returns U64 {
    // The scalar rides inline in the word (canonical, zero-extended);
    // signed types re-extend from their width.
    bits := word_bits(raw)
    switch t {
    case Type.Primitive(prim):
        switch prim {
        case Primitive.I64: return bits
        case Primitive.U8: return bits
        case Primitive.I8: return bits.cast(I64).to_u8().cast(I8).cast(I64).cast(U64)
        case Primitive.I16: return bits.cast(I64).to_u16().cast(I16).cast(I64).cast(U64)
        case Primitive.U16: return bits
        case Primitive.I32: return bits.cast(I64).to_u32().cast(I32).cast(I64).cast(U64)
        case Primitive.U32: return bits
        case Primitive.U64: return bits
        case Primitive.F32: panic("cannot convert F32 raw bits to U64")
        case Primitive.Bool: return bits
        }
    case Type.Custom(name): return raw_to_u64(type_from_name_init(name, ctx.scope), raw, ctx)
    case:
    }
    panic("raw value is not numeric: ", til_type_name_c(t))
    return 0
}

priv raw_to_i64 := func(shallow t: Type, raw: Dynamic, ctx: Context) returns I64 {
    return raw_to_u64(t, raw, ctx).cast(I64)
}

priv raw_to_f32 := func(shallow t: Type, raw: Dynamic, ctx: Context) returns F32 {
    switch t {
    case Type.Primitive(Primitive.F32): return word_f32(word_bits(raw))
    case:
        return raw_to_i64(t, raw, ctx).to_f32()
    }
}

priv raw_arg_pointer := func(scope: Scope, e: Expr, raw: Dynamic, ctx: Context) returns Dynamic {
    if expr_raw_is_ref(scope, e, ctx) {
        switch e.node_type {
        case NodeType.Ident(id):
            ref hb : HeapBinding = scope_lookup_heap_binding(scope, id.ident_name())
            if hb.is_null() { panic("argument binding not found: ", id.ident_name()) }
            if hb.til_type.is(Type.Dynamic).and(hb.is_erased_dynamic.not()) {
                ref dynamic_value_ref : Dynamic = deref(raw)
                dynamic_value : Dynamic = dynamic_value_ref
                return dynamic_value
            }
        case:
        }
        return raw
    }
    mut value_raw : Dynamic = raw
    mut value_type := e.til_type()
    switch e.node_type {
    case NodeType.Ident(id):
        ref hb : HeapBinding = scope_lookup_heap_binding(scope, id.ident_name())
        if hb.is_null() { panic("argument binding not found: ", id.ident_name()) }
        value_raw = to_ptr(hb.ptr)
        value_type = hb.til_type
    case:
        // A primitive temp's word has no storage: park the scalar in a
        // ring slot so raw-memory builtins get a real address.
        if raw_type_is_prim(value_type, ctx) { return word_ring_slot(value_type, raw, ctx) }
    }
    switch value_type {
    case Type.Dynamic: return deref(value_raw)
    case Type.FuncPtr: return deref(value_raw)
    case Type.FuncPtrSig: return deref(value_raw)
    case Type.Body: return deref(value_raw)
    case Type.Custom(name):
        alias_type := type_from_name_init(name, ctx.scope)
        switch alias_type {
        case Type.Dynamic: return deref(value_raw)
        case Type.FuncPtr: return deref(value_raw)
        case Type.FuncPtrSig: return deref(value_raw)
        case Type.Body: return deref(value_raw)
        case:
        }
        return value_raw
    case:
        return value_raw
    }
}

priv callable_raw_func_def := func(raw: Dynamic) returns ref Expr {
    ref stored : Dynamic = deref(raw)
    if callable_box_is(stored) {
        ref box : InterpCallableBox = to_ptr(stored)
        return box.func_def
    }
    return to_ptr(stored)
}

priv callable_raw_env := func(raw: Dynamic, fallback: Scope) returns ref Scope {
    ref stored : Dynamic = deref(raw)
    if callable_box_is(stored) {
        ref box : InterpCallableBox = to_ptr(stored)
        return box.env
    }
    return fallback
}

priv callable_raw_free := func(raw: Dynamic, ctx: Context) {
    heap_drop_by_type(Type.FuncPtr, raw, ctx)
    raw_block_free(raw)
}

priv init_field_raw := func(inst_data: Dynamic, dd: Declaration, field_offset: USize, field_size: USize, raw: Dynamic, shallow raw_type: Type, raw_is_ref: Bool, raw_is_place: Bool, ctx: Context) {
    ref dst : Dynamic = ptr_add(inst_data, field_offset)
    if decl_is_funcsig(dd, ctx) {
        ref stored : Dynamic = deref(raw)
        if raw_is_ref.or(raw_is_place) {
            write_ptr(dst, callable_storage_clone(stored))
        } else {
            write_ptr(dst, stored)
            write_ptr(raw, NULL)
            raw_block_free(raw)
        }
        return
    }
    switch dd.til_type {
    case Type.Struct(name):
        if dd.own_type.is(OwnType.Own) {
            if raw_is_ref.or(raw_is_place) {
                write_ptr(dst, heap_clone(name, raw, ctx))
            } else {
                write_ptr(dst, raw)
            }
        } else if dd.own_type.is(OwnType.Ref) {
            write_ptr(dst, raw)
        } else {
            if raw_is_ref.or(raw_is_place) {
                copied : Dynamic = heap_clone(name, raw, ctx)
                memcpy(dst, copied, field_size)
                raw_block_free(copied)
            } else {
                memcpy(dst, raw, field_size)
                raw_block_free(raw)
            }
        }
        return
    case Type.Enum(name):
        if dd.own_type.is(OwnType.Own) {
            if raw_is_ref.or(raw_is_place) {
                write_ptr(dst, heap_clone_enum(name, raw, dispatch_enum_size(name, ctx), ctx))
            } else {
                write_ptr(dst, raw)
            }
        } else if dd.own_type.is(OwnType.Ref) {
            write_ptr(dst, raw)
        } else {
            enum_size := dispatch_enum_size(name, ctx)
            if raw_is_ref.or(raw_is_place) {
                copied : Dynamic = heap_clone_enum(name, raw, enum_size, ctx)
                memcpy(dst, copied, enum_size)
                raw_block_free(copied)
            } else {
                memcpy(dst, raw, enum_size)
                raw_block_free(raw)
            }
        }
        return
    case:
    }
    if dd.own_type.is(OwnType.Own).or(dd.own_type.is(OwnType.Ref)) {
        if raw_is_ref {
            write_ptr(dst, raw)
        } else if raw_is_place.or(raw_type.is(Type.Dynamic)) {
            ref pointed : Dynamic = deref(raw)
            write_ptr(dst, pointed)
            if raw_is_place.not() { raw_block_free(raw) }
        } else {
            write_ptr(dst, raw)
        }
        return
    }
    // Shallow primitive field init from an inline word, at the layout
    // width (host struct bytes; see field_word_type). A ref or place
    // arg is a BARE address into the source's storage (an Ident eval,
    // a field ref): load the scalar out at the SOURCE type's width
    // first.
    if raw_type_is_prim(dd.til_type, ctx) {
        mut field_w : Dynamic = raw
        if raw_is_ref.or(raw_is_place) { field_w = scalar_word_load(raw_type, raw, ctx) }
        scalar_word_store(field_word_type(dd.til_type, field_size, ctx), dst, field_w, ctx)
        return
    }
    memcpy(dst, raw, field_size)
    if raw_is_place.not() { raw_block_free(raw) }
}

priv context_return_set := func(mut ctx: Context, raw: Dynamic) {
    if ctx.has_return { panic("return result already set") }
    ctx.return_value = raw
    ctx.has_return = true
}

priv context_return_take := func(mut ctx: Context) returns Dynamic {
    if ctx.has_return.not() { panic("return result is not set") }
    result : Dynamic = ctx.return_value
    ctx.return_value = NULL
    ctx.has_return = false
    return result
}

priv field_access_sname := func(e: Expr) returns Str {
    mut sname := til_type_name(e.children[0].til_type())
    if sname.len() > 0 { return sname }
    switch e.children[0].node_type {
    case NodeType.Ident(id): return Str.clone(id.ident_name())
    case: return til_type_name_c(e.children[0].til_type())
    }
}

priv field_access_decl := func(e: Expr, ctx: Context) returns ref Declaration {
    sname := field_access_sname(e)
    ref sdef : Expr = lookup_interp_type_def(sname, ctx)
    if sdef.is_null() { return NULL }
    switch e.node_type {
    case NodeType.FieldAccess(fa): return find_field_decl(sdef, fa.field_access_name())
    case: return NULL
    }
}

priv scalar_raw_source_type := func(scope: Scope, e: Expr, ctx: Context) returns Type {
    switch e.node_type {
    case NodeType.Ident(id):
        ref hb : HeapBinding = scope_lookup_heap_binding(scope, id.ident_name())
        if hb.is_null() { panic("scalar source binding not found: ", id.ident_name()) }
        if hb.til_type.is(Type.Dynamic).and(e.til_type().is(Type.Dynamic).not()) { return e.til_type() }
        return hb.til_type.clone()
    case NodeType.FieldAccess(fa):
        if interp_fa_is_ns(scope, e, ctx) {
            return ns_field_type(field_access_sname(e), fa.field_access_name(), ctx)
        }
        ref fdecl : Declaration = field_access_decl(e, ctx)
        if fdecl.is_null() { panic("scalar source field not found: ", fa.field_access_name()) }
        if (fdecl.explicit_type == "USize").or(fdecl.explicit_type == "UPtr") {
            sname := field_access_sname(e)
            ref fl : FieldLayout = ctx_field_layout(sname, fa.field_access_name(), ctx)
            if fl.size == 4 {
                if (sname == ctx.cached_str_name).and(fa.field_access_name() == "cap") {
                    return Type.Primitive(Primitive.I32)
                }
                return Type.Primitive(Primitive.U32)
            }
            return Type.Primitive(Primitive.U64)
        }
        return fdecl.til_type.clone()
    case:
        return e.til_type()
    }
}

// Resolve storage for an identifier-rooted struct field chain without
// evaluating or copying its intermediate aggregates.
priv field_access_base := proc(scope: Scope, obj: Expr, ctx: Context) returns ref Dynamic {
    switch obj.node_type {
    case NodeType.Ident: return resolve_field_assign_base(scope, obj)
    case NodeType.FieldAccess(fa):
        ref parent : Dynamic = field_access_base(scope, obj.children[0], ctx)
        if parent.is_null() { return NULL }
        sname := field_access_sname(obj)
        ref fdecl : Declaration = field_access_decl(obj, ctx)
        if fdecl.is_null() { return NULL }
        ref fl : FieldLayout = ctx_field_layout(sname, fa.field_access_name(), ctx)
        ref slot : Dynamic = ptr_add(parent, fl.offset)
        if fdecl.own_type.is(OwnType.Shallow) { return slot }
        return deref(slot)
    case NodeType.FCall:
        if call_raw_result_is_ref(scope, obj, ctx) {
            raw_base : Dynamic = eval_expr_raw(scope, obj, ctx)
            return to_ptr(raw_base)
        }
        panic("field access call base is not a reference")
        return NULL
    case: return NULL
    }
}

priv field_access_returns_ref := func(scope: Scope, e: Expr, ctx: Context) returns Bool {
    if interp_fa_is_ns(scope, e, ctx) { return false }
    ref fdecl : Declaration = field_access_decl(e, ctx)
    if fdecl.is_null() { return false }
    if decl_is_funcsig(fdecl, ctx) { return false }
    return true
}

priv eval_expr_field_raw := proc(scope: Scope, e: Expr, ctx: Context, destination: Dynamic = NULL) returns Dynamic {
    switch e.node_type {
    case NodeType.FieldAccess(fa):
        if interp_fa_is_ns(scope, e, ctx) {
            sname := field_access_sname(e)
            ref namespace_def : Expr = lookup_interp_type_def(sname, ctx)
            if namespace_def.is_null().not().and(namespace_def.node_type.is(NodeType.EnumDef)) {
                variant_idx := enum_variant_index(namespace_def, fa.field_access_name())
                if variant_idx >= 0 {
                    mut result : Dynamic = destination
                    if result.is_null() { result = dispatch_result_alloc(Type.Enum(sname.clone()), ctx) }
                    tag := enum_variant_tag(namespace_def, fa.field_access_name())
                    memcpy(result, tag, enum_tag_size(namespace_def))
                    return result
                }
            }
            ref stored : Dynamic = ns_get(sname, fa.field_access_name(), ctx)
            if stored.is_null() {
                interp_error(e, format("no namespace field '", Str.clone(fa.field_access_name()), "'"), ctx)
                exit(1)
            }
            stored_type := ns_field_type(sname, fa.field_access_name(), ctx)
            if raw_type_is_prim(stored_type, ctx) {
                ns_word : Dynamic = scalar_word_load(stored_type, stored, ctx)
                return raw_result_finish(stored_type, ns_word, destination, false, ctx)
            }
            cloned : Dynamic = heap_clone_by_type(stored_type, stored, ctx)
            return raw_result_finish(stored_type, cloned, destination, false, ctx)
        }
        ref fdecl : Declaration = field_access_decl(e, ctx)
        if fdecl.is_null() {
            interp_error(e, format("no field '", Str.clone(fa.field_access_name()), "'"), ctx)
            exit(1)
        }
        sname := field_access_sname(e)
        ref fl : FieldLayout = ctx_field_layout(sname, fa.field_access_name(), ctx)
        ref base : Dynamic = field_access_base(scope, e.children[0], ctx)
        if base.is_null().not() {
            if field_access_returns_ref(scope, e, ctx) {
                if fdecl.own_type.is(OwnType.Shallow).not() { return deref(ptr_add(base, fl.offset)) }
                return ptr_add(base, fl.offset)
            }
            return read_field(base, fdecl, fl.offset, fl.size, ctx)
        }

        panic("field access base is not a place")
        return NULL
    case:
        interp_lang_error(e, "cannot evaluate node as field expression", ctx)
        exit(1)
        return NULL
    }
}

priv write_runtime_type := func(result: Dynamic, shallow t: Type, ctx: Context) {
    ref type_def : Expr = lookup_interp_type_def("Type", ctx)
    if type_def.is_null() { panic("runtime Type definition not registered") }
    mut variant := ""
    switch t {
    case Type.Unknown: variant = "Unknown"
    case Type.None: variant = "None"
    case Type.Struct(name):
        variant = "Struct"
        dispatch_write_str(ptr_add(result, ENUM_PAYLOAD_OFFSET), name.c_str, name.count, ctx)
    case Type.StructDef: variant = "StructDef"
    case Type.Enum(name):
        variant = "Enum"
        dispatch_write_str(ptr_add(result, ENUM_PAYLOAD_OFFSET), name.c_str, name.count, ctx)
    case Type.EnumDef: variant = "EnumDef"
    case Type.FuncDef: variant = "FuncDef"
    case Type.FuncPtr: variant = "FuncPtr"
    case Type.Dynamic: variant = "Dynamic"
    case Type.Custom(name):
        variant = "Custom"
        dispatch_write_str(ptr_add(result, ENUM_PAYLOAD_OFFSET), name.c_str, name.count, ctx)
    case Type.Primitive(prim):
        variant = "Primitive"
        ref primitive_def : Expr = lookup_interp_type_def("Primitive", ctx)
        if primitive_def.is_null() { panic("runtime Primitive definition not registered") }
        mut primitive_variant := ""
        switch prim {
        case Primitive.I16: primitive_variant = "I16"
        case Primitive.U16: primitive_variant = "U16"
        case Primitive.I8: primitive_variant = "I8"
        case Primitive.U8: primitive_variant = "U8"
        case Primitive.U32: primitive_variant = "U32"
        case Primitive.I32: primitive_variant = "I32"
        case Primitive.U64: primitive_variant = "U64"
        case Primitive.I64: primitive_variant = "I64"
        case Primitive.F32: primitive_variant = "F32"
        case Primitive.Bool: primitive_variant = "Bool"
        }
        write_i32(ptr_add(result, ENUM_PAYLOAD_OFFSET), enum_variant_tag(primitive_def, primitive_variant).to_i32())
    case Type.FuncPtrSig(name):
        variant = "FuncPtrSig"
        dispatch_write_str(ptr_add(result, ENUM_PAYLOAD_OFFSET), name.c_str, name.count, ctx)
    case Type.Body: variant = "Body"
    }
    write_i32(result, enum_variant_tag(type_def, variant).to_i32())
}

eval_expr_raw := proc(scope: Scope, e: Expr, mut ctx: Context, destination: Dynamic = NULL) returns Dynamic {
    switch e.node_type {
    case NodeType.Literal(Literal.Str(text)):
        mut result : Dynamic = destination
        if result.is_null() { result = dispatch_result_alloc(e.til_type(), ctx) }
        buf : Dynamic = malloc(text.count.add(1))
        mut j : USize = 0
        mut i : USize = 0
        while i < text.count {
            ref ch : I8 = text.unsafe_get(i)
            if ch == 92 {
                if i + 1 < text.count {
                    ref next : I8 = text.unsafe_get(i + 1)
                    if next == 110 { memset(ptr_add(buf, j), 10, 1); j = j + 1; i = i + 2; continue }
                    if next == 116 { memset(ptr_add(buf, j), 9, 1); j = j + 1; i = i + 2; continue }
                    if next == 92 { memset(ptr_add(buf, j), 92, 1); j = j + 1; i = i + 2; continue }
                    if next == 34 { memset(ptr_add(buf, j), 34, 1); j = j + 1; i = i + 2; continue }
                    if next == 48 { memset(ptr_add(buf, j), 0, 1); j = j + 1; i = i + 2; continue }
                }
            }
            memcpy(ptr_add(buf, j), ptr_add(text.c_str, i), 1)
            j++
            i++
        }
        mut pooled_i : USize = 0
        mut found_literal := false
        for lit_i in 0..ctx.builder_str_lit_values.len() {
            ref pooled : Str = ctx.builder_str_lit_values[lit_i]
            if pooled.count == j {
                if j == 0 { found_literal = true }
                else if memcmp(pooled.c_str, buf, j) == 0 { found_literal = true }
                if found_literal { pooled_i = lit_i; break }
            }
        }
        if found_literal.not() {
            ctx.builder_str_lit_values.push(own Str(c_str = to_ptr(buf), count = j, cap = j))
            pooled_i = ctx.builder_str_lit_values.len().sub(1)
        } else {
            free(own buf)
        }
        ref pooled2 : Str = ctx.builder_str_lit_values[pooled_i]
        write_ptr(result, pooled2.c_str)
        str_write_count_cap(result, j, CAP_LIT, ctx)
        return result
    case NodeType.Literal(Literal.Num(num_str)):
        // Numeric literals are inline words: parse, canonicalize, done --
        // no allocation. A caller-provided destination gets the scalar
        // stored at its width instead.
        mut num_word : Dynamic = 0
        switch e.til_type() {
        case Type.Primitive(Primitive.U8):  num_word = bits_word(num_str.to_u8().cast(U64))
        case Type.Primitive(Primitive.I8):  num_word = scalar_word_encode(e.til_type(), num_str.to_i8().cast(U8).cast(U64), ctx)
        case Type.Primitive(Primitive.I16): num_word = scalar_word_encode(e.til_type(), num_str.to_i16().cast(U16).cast(U64), ctx)
        case Type.Primitive(Primitive.U16): num_word = bits_word(num_str.to_u16().cast(U64))
        case Type.Primitive(Primitive.I32): num_word = scalar_word_encode(e.til_type(), num_str.to_i32().cast(U32).cast(U64), ctx)
        case Type.Primitive(Primitive.U32): num_word = bits_word(num_str.to_u32().cast(U64))
        case Type.Primitive(Primitive.U64): num_word = bits_word(num_str.to_u64())
        case Type.Primitive(Primitive.F32): num_word = bits_word(f32_word(num_str.to_f32()))
        case: num_word = bits_word(num_str.to_i64().cast(U64))
        }
        if destination.is_null() { return num_word }
        scalar_word_store(e.til_type(), destination, num_word, ctx)
        return destination
    case NodeType.Literal(Literal.Bool(b)):
        if destination.is_null().not() {
            write_bool(destination, b)
            return destination
        }
        if b { return bits_word(1) }
        return bits_word(0)
    case NodeType.Literal(Literal.Null):
        // A primitive-typed null is the zero word; other classes keep a
        // zeroed block of the type's size (a Dynamic null slot, a zeroed
        // aggregate).
        if destination.is_null().not() { return destination }
        if raw_type_is_prim(e.til_type(), ctx) { return bits_word(0) }
        return raw_unit_result(e.til_type(), ctx)
    case NodeType.Ident(ident):
        ref hb : HeapBinding = scope_lookup_heap_binding(scope, ident.ident_name())
        if hb.is_null() { panic("expression binding not found: ", ident.ident_name()) }
        mut expr_type := e.til_type()
        switch expr_type {
        case Type.Custom(expr_type_name): expr_type = type_from_name_init(expr_type_name, ctx.scope)
        case:
        }
        switch expr_type {
        case Type.Enum(type_name):
            if (type_name == "Type").and(hb.is_static_callable) {
                mut result : Dynamic = destination
                if result.is_null() { result = dispatch_result_alloc(e.til_type(), ctx) }
                mut runtime_type_name := ident.ident_name().clone()
                ref binding_scope : Scope = scope_get_binding_scope(scope, ident.ident_name())
                if binding_scope.heap_aliases.has(ident.ident_name()) {
                    runtime_type_name = binding_scope.heap_aliases[ident.ident_name()].clone()
                }
                write_runtime_type(result, type_from_name_init(runtime_type_name, ctx.scope), ctx)
                return result
            }
        case:
        }
        ref place : Dynamic = to_ptr(hb.ptr)
        if heap_type_is_callable(hb.til_type) {
            cloned : Dynamic = heap_clone_by_type(hb.til_type, place, hb.ctx)
            return raw_result_finish(hb.til_type, cloned, destination, false, ctx)
        }
        result : Dynamic = place
        return result
    case NodeType.FCall:
        return eval_call(scope, e, ctx, destination)
    case NodeType.FuncDef(fd):
        if fd.captures.len().gt(0) {
            closure : Dynamic = make_interp_closure(e, scope, ctx)
            return raw_result_finish(e.til_type(), closure, destination, false, ctx)
        }
        mut result : Dynamic = destination
        if result.is_null() { result = EvalHeap.heap_alloc(Dynamic.size()) }
        write_ptr(result, e)
        return result
    case NodeType.BodyValue:
        closure : Dynamic = make_interp_closure(e, scope, ctx)
        return raw_result_finish(e.til_type(), closure, destination, false, ctx)
    case NodeType.StructDef:
        mut result : Dynamic = destination
        if result.is_null() { result = EvalHeap.heap_alloc(Dynamic.size()) }
        write_ptr(result, e)
        return result
    case NodeType.EnumDef:
        mut result : Dynamic = destination
        if result.is_null() { result = EvalHeap.heap_alloc(Dynamic.size()) }
        write_ptr(result, e)
        return result
    case NodeType.FieldAccess:
        return eval_expr_field_raw(scope, e, ctx, destination)
    case:
        interp_lang_error(e, "cannot evaluate node as expression", ctx)
        exit(1)
        return raw_unit_result(e.til_type(), ctx)
    }
}

priv lookup_type_def_helper := func(type_name: Str, scope: Scope, ctx: Context) returns ref Expr {
    // Probe: type_name is empty for a primitive scrutinee (switch on I64)
    // and unbound for a builtin; the absent case falls through to the
    // interp type-def registry.
    ref slot : Dynamic = scope_get(scope, type_name)?
    catch (e: KeyNotFound) { return lookup_interp_type_def(type_name, ctx) }
    ref raw : Dynamic = slot
    return callable_raw_func_def(raw)
}

priv resolve_field_assign_base := func(scope: Scope, obj_expr: Expr) returns ref Dynamic {
    switch obj_expr.node_type {
    case NodeType.Ident(ident):
        ref hb : HeapBinding = scope_lookup_heap_binding(scope, ident.ident_name())
        if hb.is_null() { return NULL }
        switch hb.til_type {
        case Type.Struct:
            if hb.moved_out { panic("field assign on moved binding: ", ident.ident_name()) }
            return to_ptr(hb.ptr)
        case: return NULL
        }
    case:
        return NULL
    }
}

priv resolve_field_assign_sname := func(scope: Scope, obj_expr: Expr) returns Str {
    switch obj_expr.node_type {
    case NodeType.Ident(ident):
        ref hb : HeapBinding = scope_lookup_heap_binding(scope, ident.ident_name())
        if hb.is_null() { return "" }
        switch hb.til_type {
        case Type.Struct(sname):
            if hb.moved_out { panic("field assign on moved binding: ", ident.ident_name()) }
            return sname.clone()
        case: return ""
        }
    case:
        return ""
    }
}

priv resolve_field_assign_sdef := func(scope: Scope, obj_expr: Expr, ctx: Context) returns ref Expr {
    sname := resolve_field_assign_sname(scope, obj_expr)
    if sname.len() == 0 { return NULL }
    return lookup_interp_type_def(sname, ctx)
}

priv raw_switch_key := proc(scope: Scope, e: Expr, ctx: Context) returns I64 {
    raw_type := scalar_raw_source_type(scope, e, ctx)
    switch raw_type {
    case Type.Custom(name):
        mut resolved := e.clone()
        resolved.set_til_type(type_from_name_init(name, ctx.scope))
        return raw_switch_key(scope, resolved, ctx)
    case:
    }
    switch raw_type {
    case Type.Enum(enum_name):
        raw : Dynamic = eval_expr_raw(scope, e, ctx)
        tag_ptr : Dynamic = raw_arg_pointer(scope, e, raw, ctx)
        ref enum_def : Expr = lookup_interp_type_def(enum_name, ctx)
        if enum_def.is_null() { panic("switch enum definition not found: ", enum_name) }
        result := enum_data_tag_key(tag_ptr, enum_def)
        raw_result_drop(raw_type, raw, expr_raw_is_ref(scope, e, ctx), ctx)
        return result
    case Type.Primitive:
        return raw_to_i64(raw_type, eval_scalar_arg_word(scope, e, raw_type, ctx), ctx)
    case Type.Dynamic:
        // An erased scalar subject: the value is a Dynamic slot; read the
        // pointed scalar as I64 (the pre-word behavior read through the
        // arg pointer the same way).
        raw : Dynamic = eval_expr_raw(scope, e, ctx)
        result := raw_to_i64(Type.Primitive(Primitive.I64), scalar_word_load(Type.Primitive(Primitive.I64), raw_arg_pointer(scope, e, raw, ctx), ctx), ctx)
        raw_result_drop(raw_type, raw, expr_raw_is_ref(scope, e, ctx), ctx)
        return result
    case:
        panic("unsupported switch key type ", til_type_name_c(raw_type))
    }
    return 0
}

// #254: execute a switch the typer left un-desugared (C-like). Evaluate the
// scrutinee once, run the first case whose constant label compares equal, else
// the default. break/continue/return propagate via Context flags (eval_body
// returns early when one is set), so a case-body `continue`/`return` reaches
// the enclosing loop/function unchanged.
// #276: the variant name of a case pattern -- a bare `Type.V` (FieldAccess) or
// a payload binding `Type.V(x)` (FCall whose FieldAccess callee names V).
priv clike_case_variant_name := func(pat: Expr) returns Str {
    switch pat.node_type {
    case NodeType.FieldAccess(fa): return Str.clone(fa.field_access_name())
    case NodeType.FCall:
        if pat.children.len() > 0 {
            switch pat.children[0].node_type {
            case NodeType.FieldAccess(fa2): return Str.clone(fa2.field_access_name())
            case:
            }
        }
        return ""
    case: return ""
    }
}

priv eval_switch := proc(scope: Scope, stmt: Expr, mut ctx: Context) {
    subj_i := raw_switch_key(scope, stmt.children[0], ctx)
    // For an enum scrutinee, resolve each case label by its variant TAG via the
    // enum def: a bare payload variant (`Type.V`) evaluates to its constructor,
    // not a tagged value, so it can't be eval'd for the key. int/char/bool
    // labels are constant expressions and evaluate directly.
    is_enum_subj := stmt.children[0].til_type().is(Type.Enum)
    sname := til_type_name(stmt.children[0].til_type())
    ref enum_def : Expr = lookup_type_def_helper(sname, scope, ctx)
    mut has_default := false
    mut default_idx : USize = 0
    for ci in 1..stmt.children.len() {
        ref cn : Expr = stmt.children[ci]
        if cn.children.len() == 1 {
            has_default = true
            default_idx = ci
            continue
        }
        mut matched := false
        if is_enum_subj.and(enum_def.is_null().not()) {
            matched = enum_variant_tag(enum_def, clike_case_variant_name(cn.children[0])) == subj_i
        } else if is_range_new_call(cn.children[0]) {
            // #254 range case `lo..hi`: match lo <= subj <= hi.
            lo := raw_switch_key(scope, cn.children[0].children[1], ctx)
            hi := raw_switch_key(scope, cn.children[0].children[2], ctx)
            matched = subj_i.gte(lo).and(subj_i.lte(hi))
        } else {
            matched = raw_switch_key(scope, cn.children[0], ctx) == subj_i
        }
        if matched {
        case_scope := scope_new(scope)
            eval_body(case_scope, cn.children[1], ctx)
            scope_free(own case_scope)
            return
        }
    }
    if has_default {
        def_scope := scope_new(scope)
        eval_body(def_scope, stmt.children[default_idx].children[0], ctx)
        scope_free(own def_scope)
    }
}

priv eval_declaration := proc(scope: Scope, stmt: Expr, dd: Declaration, mut ctx: Context) {
    ref rhs : Expr = stmt.children[0]
    rhs_type := scalar_raw_source_type(scope, rhs, ctx)
    mut decl_type := rhs_type.clone()
    if dd.explicit_type.len() > 0 { decl_type = type_from_name_init(dd.explicit_type, ctx.scope) }
    if decl_type.is(Type.Body).and(rhs_type.is(Type.Enum)) { decl_type = rhs_type.clone() }
    if rhs.node_type.is(NodeType.FuncDef).or(rhs.node_type.is(NodeType.StructDef)).or(rhs.node_type.is(NodeType.EnumDef)) {
        decl_type = Type.Body
    }
    if stmt.til_type().is(Type.None) {
        if rhs.node_type.is(NodeType.Ident) { return }
    }
    switch rhs.node_type {
    case NodeType.Ident(rhs_ident):
        ref source_hb : HeapBinding = scope_lookup_heap_binding(scope, rhs_ident.ident_name())
        if source_hb.is_null() { panic("declaration source not found: ", rhs_ident.ident_name()) }
        if source_hb.moved_out { panic("declaration from moved binding: ", rhs_ident.ident_name()) }
        ref source_scope : Scope = scope_get_binding_scope(scope, rhs_ident.ident_name())
        ref source_raw : Dynamic = to_ptr(source_hb.ptr)
        switch decl_type {
        case Type.Enum(type_name):
            if (type_name == "Type").and(source_hb.is_static_callable) {
                runtime_type : Dynamic = eval_expr_raw(scope, rhs, ctx)
                scope_set_raw_owned(scope, dd.name, runtime_type, decl_type, dd.own_type, ctx)
                return
            }
        case:
        }
        if dd.own_type.is(OwnType.Ref) {
            if source_hb.til_type.is(Type.Dynamic).and(decl_type.is(Type.Dynamic).not()) {
                mut pointed : Dynamic = source_raw
                if source_hb.is_erased_dynamic.not() { pointed = deref(source_raw) }
                scope_set_heap_owned(scope, dd.name, pointed, decl_type, dd.own_type, source_hb.ctx, false, true)
            } else {
                scope_set_borrowed(scope, dd.name, decl_type, dd.own_type, rhs_ident.ident_name(), source_scope)
            }
            return
        }
        // A SHALLOW primitive source COPIES by value (C scalar semantics):
        // load the scalar (through the Dynamic box for an erased source),
        // widen, and give the new binding its own block. The source
        // binding keeps its storage untouched. Own-primitive sources
        // (#302 raw allocations) keep the block-transfer paths below.
        mut prim_value_type := source_hb.til_type.clone()
        if source_hb.til_type.is(Type.Dynamic) { prim_value_type = decl_type.clone() }
        if source_hb.own_type.is(OwnType.Shallow).not().and(source_hb.til_type.is(Type.Dynamic).not()) { prim_value_type = Type.Unknown }
        if raw_type_is_prim(prim_value_type, ctx).and(decl_type.is(Type.Dynamic).not()).and(dd.own_type.is(OwnType.Own).not()) {
            mut prim_src : Dynamic = source_raw
            if source_hb.til_type.is(Type.Dynamic) { prim_src = deref(source_raw) }
            mut w : Dynamic = scalar_word_load(prim_value_type, prim_src, ctx)
            w = raw_widen_numeric(w, prim_value_type, dd.explicit_type, ctx)
            scope_set_raw_owned(scope, dd.name, scalar_block_from_word(decl_type, w, ctx), decl_type, dd.own_type, ctx)
            return
        }
        if dd.name.starts_with("hoisted__").or(source_hb.is_borrowed).or(heap_slot_is_static_callable(source_hb.til_type, source_raw)) {
            mut copied : Dynamic = source_raw
            if source_hb.til_type.is(Type.Dynamic).and(decl_type.is(Type.Dynamic).not()) {
                ref dynamic_data : Dynamic = deref(source_raw)
                copied = heap_clone_by_type(decl_type, dynamic_data, source_hb.ctx)
            } else {
                copied = heap_clone_by_type(source_hb.til_type, source_raw, source_hb.ctx)
            }
            if source_hb.til_type.is(Type.Dynamic).not().and(decl_type.is(Type.Dynamic)) {
                if heap_type_is_callable(source_hb.til_type).not() {
                    // Box the cloned BLOCK into a Dynamic slot directly
                    // (raw_coerce_value's boxing arm now takes value words).
                    wrapper : Dynamic = EvalHeap.heap_alloc(Dynamic.size())
                    write_ptr(wrapper, copied)
                    copied = wrapper
                }
                scope_set_heap_owned(scope, dd.name, copied, decl_type, dd.own_type, source_hb.ctx, true)
                return
            }
            copied = raw_widen_numeric(copied, source_hb.til_type, dd.explicit_type, ctx)
            scope_set_raw_owned(scope, dd.name, copied, decl_type, dd.own_type, source_hb.ctx)
        } else {
            mut moved : Dynamic = source_raw
            if source_hb.til_type.is(Type.Dynamic).and(decl_type.is(Type.Dynamic).not()) {
                ref dynamic_data2 : Dynamic = deref(source_raw)
                moved = dynamic_data2
                owned_holder : Dynamic = source_raw
                EvalHeap.heap_free(own owned_holder)
            }
            source_hb.ptr = NULL
            source_hb.moved_out = true
            if source_hb.til_type.is(Type.Dynamic).not().and(decl_type.is(Type.Dynamic)) {
                if heap_type_is_callable(source_hb.til_type).not() {
                    // Box the moved BLOCK into a Dynamic slot directly
                    // (raw_coerce_value's boxing arm now takes value words).
                    wrapper : Dynamic = EvalHeap.heap_alloc(Dynamic.size())
                    write_ptr(wrapper, moved)
                    moved = wrapper
                }
                scope_set_heap_owned(scope, dd.name, moved, decl_type, dd.own_type, source_hb.ctx, true)
                return
            }
            moved = raw_widen_numeric(moved, source_hb.til_type, dd.explicit_type, ctx)
            scope_set_raw_owned(scope, dd.name, moved, decl_type, dd.own_type, source_hb.ctx)
        }
        return
    case:
        is_ref := expr_raw_is_ref(scope, rhs, ctx)
        mut destination : Dynamic = 0
        mut destination_is_raw_block := false
        switch decl_type {
        case Type.Primitive: destination_is_raw_block = dd.own_type.is(OwnType.Own).or(rhs_is_raw_alloc_call(rhs))
        case:
        }
        if is_ref.not().and(destination_is_raw_block.not()).and(til_type_name_c(rhs_type) == til_type_name_c(decl_type)) {
            destination = dispatch_result_alloc(decl_type, ctx)
        }
        mut raw : Dynamic = eval_expr_raw(scope, rhs, ctx, destination)
        if is_ref {
            pointed : Dynamic = raw
            mut borrowed_pointer_field := false
            switch rhs.node_type {
            case NodeType.FieldAccess:
                ref source_field : Declaration = field_access_decl(rhs, ctx)
                if source_field.is_null().not() {
                    borrowed_pointer_field = source_field.own_type.is(OwnType.Shallow).not().and(source_field.til_type.is(Type.Primitive))
                }
            case:
            }
            if borrowed_pointer_field {
                scope_set_heap_owned(scope, dd.name, pointed, decl_type, dd.own_type, ctx, false, true)
            } else if dd.own_type.is(OwnType.Ref) {
                scope_set_heap_owned(scope, dd.name, pointed, decl_type, dd.own_type, ctx, false, true, decl_type.is(Type.Dynamic))
            } else if decl_type.is(Type.Dynamic) {
                dynamic_slot : Dynamic = EvalHeap.heap_alloc(Dynamic.size())
                write_ptr(dynamic_slot, pointed)
                scope_set_raw_owned(scope, dd.name, dynamic_slot, decl_type, dd.own_type, ctx)
            } else if raw_type_is_prim(rhs_type, ctx) {
                // A ref prim rhs is a bare source address: load the scalar
                // word, widen, and give the binding its own block.
                prim_w : Dynamic = raw_widen_numeric(scalar_word_load(rhs_type, pointed, ctx), rhs_type, dd.explicit_type, ctx)
                scope_set_raw_owned(scope, dd.name, scalar_block_from_word(decl_type, prim_w, ctx), decl_type, dd.own_type, ctx)
            } else {
                mut copied : Dynamic = heap_clone_by_type(rhs_type, pointed, ctx)
                copied = raw_coerce_value(copied, rhs_type, decl_type, ctx, dd.own_type)
                scope_set_raw_owned(scope, dd.name, copied, decl_type, dd.own_type, ctx)
            }
        } else {
            if dd.own_type.is(OwnType.Ref).and(decl_type.is(Type.Dynamic)) {
                ref pointed : Dynamic = deref(raw)
                scope_set_heap_owned(scope, dd.name, pointed, decl_type, dd.own_type, ctx, false, true, true)
                EvalHeap.heap_free(own raw)
                return
            }
            rhs_is_pointer := rhs.til_type().is(Type.Dynamic).and(dd.own_type.is(OwnType.Own)).or(rhs_is_raw_alloc_call(rhs))
            if rhs_is_pointer.and(rhs_type.is(Type.Dynamic)).and(raw_type_is_prim(decl_type, ctx)) {
                // #302 raw-alloc bind from a Dynamic-slot eval: the POINTER
                // is the binding datum -- raw_coerce_value's shallow value
                // unbox would read the box's bytes as the value and drop
                // the allocation on the floor.
                ref alloc_pointed : Dynamic = deref(raw)
                alloc_ptr : Dynamic = alloc_pointed
                EvalHeap.heap_free(own raw)
                raw = alloc_ptr
            } else {
                raw = raw_coerce_value(raw, rhs_type, decl_type, ctx, dd.own_type)
            }
            if destination.is_null().not() {
                raw = raw_result_finish(decl_type, raw, destination, false, ctx)
            } else {
                raw = binding_block_from_word(decl_type, raw, rhs_is_pointer, ctx)
            }
            scope_set_raw_owned(scope, dd.name, raw, decl_type, dd.own_type, ctx)
            if raw_type_is_prim(decl_type, ctx).and(rhs_is_pointer) {
                ref pointer_hb : HeapBinding = scope_lookup_heap_binding(scope, dd.name)
                pointer_hb.is_raw_alloc = true
            }
        }
    }
}

priv eval_fcall := proc(scope: Scope, stmt: Expr, fcd: FCallData, mut ctx: Context) {
    // #272 step 3: a swap_replace FCall is hoist_param_swap_assign's
    // lowering of `param = rhs` for a mut aggregate param. The
    // compiled backend emits delete-copy-free (a MOVE: delete the
    // target's old value, value-copy the temp in, free the temp
    // wrapper; the garbager's swap_freed accounting assumes the
    // temp was consumed). Running the literal byte swap here
    // instead left the target and the temp aliasing one payload,
    // which blocks deep scope teardown (UAF). Mirror the move:
    // deep-delete the target's old raw value, move the temp's bytes in, and
    // null the temp slot so its teardown is a no-op.
    mut did_swap_replace := false
    if fcd.swap_replace.and(stmt.children.len().gte(3)) {
        mut sw_target := ""
        mut sw_src := ""
        switch stmt.children[1].node_type {
        case NodeType.Ident(sw_t): sw_target = Str.clone(sw_t.ident_name())
        case:
        }
        switch stmt.children[2].node_type {
        case NodeType.Ident(sw_s): sw_src = Str.clone(sw_s.ident_name())
        case:
        }
        if sw_target.len().gt(0).and(sw_src.len().gt(0)) {
            ref sw_hb : HeapBinding = scope_lookup_heap_binding(scope, sw_target)
            ref sw_src_hb : HeapBinding = scope_lookup_heap_binding(scope, sw_src)
            if sw_hb.is_null().or(sw_src_hb.is_null()) { panic("swap_replace binding not found") }
            if sw_src_hb.moved_out { panic("swap_replace from moved source: ", sw_src) }
            if sw_src_hb.is_borrowed { panic("swap_replace from borrowed source: ", sw_src) }
            ref sw_data : Dynamic = to_ptr(sw_hb.ptr)
            ref sw_src_data : Dynamic = to_ptr(sw_src_hb.ptr)
            _ := heap_move_ptr_into_slot(sw_hb.til_type, sw_data, sw_src_data, sw_hb.ctx)
            sw_src_hb.ptr = NULL
            sw_src_hb.moved_out = true
            did_swap_replace = true
        }
    }
    if did_swap_replace { return }
    // A bare call-statement discards its typed raw result.
    discard : Dynamic = eval_call(scope, stmt, ctx)
    raw_result_drop(stmt.til_type(), discard, call_raw_result_is_ref(scope, stmt, ctx), ctx)
}

priv eval_if := proc(scope: Scope, stmt: Expr, mut ctx: Context) {
    cv := eval_bool_arg(scope, stmt.children[0], ctx)
    if cv {
        then_scope := scope_new(scope)
        eval_body(then_scope, stmt.children[1], ctx)
        scope_free(own then_scope)
    } else if stmt.children.len() > 2 {
        else_scope := scope_new(scope)
        eval_body(else_scope, stmt.children[2], ctx)
        scope_free(own else_scope)
    }
}

priv eval_while := proc(scope: Scope, stmt: Expr, mut ctx: Context) {
    ref mut c : Context = ctx
    while true {
        if c.has_return { break }
        // A const-folder abort inside the loop body stops iteration (the
        // body's eval_body already bailed); don't re-evaluate the condition.
        if c.constfold_aborted { break }
        cv := eval_bool_arg(scope, stmt.children[0], ctx)
        if cv.not() { break }
        while_scope := scope_new(scope)
        eval_body(while_scope, stmt.children[1], ctx)
        scope_free(own while_scope)
        if c.has_break { c.has_break = false; break }
        if c.has_continue { c.has_continue = false }
    }
}

priv eval_body := proc(scope: Scope, body: Expr, mut ctx: Context) {
    ref mut c : Context = ctx
    for mut e_i : Expr in body.children {
        if c.has_return { return }
        if c.has_break { return }
        if c.has_continue { return }
        // A const-folder abort unwinds every enclosing body like an early
        // return until try_eval_call observes it.
        if c.constfold_aborted { return }
        ref mut stmt : Expr = e_i
        switch stmt.node_type {
        case NodeType.Decl(dd):
            eval_declaration(scope, stmt, dd, ctx)
        case NodeType.Assign(ad):
            ref rhs : Expr = stmt.children[0]
            ref assign_hb : HeapBinding = scope_lookup_heap_binding(scope, ad.name)
            if assign_hb.is_null() { panic("assignment binding not found: ", ad.name) }
            mut new_raw : Dynamic = 0
            if stmt.til_type().is(Type.Dynamic).and(rhs.node_type.is(NodeType.Ident)) {
                switch rhs.node_type {
                case NodeType.Ident(rhs_ident): new_raw = scope_move_bound_raw(scope, rhs_ident.ident_name(), ctx)
                case:
                }
            } else {
                new_raw = eval_expr_raw(scope, rhs, ctx)
                if expr_raw_is_ref(scope, rhs, ctx) {
                    // A ref raw is the bare target address: load the scalar
                    // inline / clone the aggregate; the target keeps its
                    // storage.
                    if raw_type_is_prim(assign_hb.til_type, ctx) {
                        new_raw = scalar_word_load(assign_hb.til_type, new_raw, ctx)
                    } else {
                        copied : Dynamic = heap_clone_by_type(assign_hb.til_type, new_raw, assign_hb.ctx)
                        new_raw = copied
                    }
                } else {
                    new_raw = raw_coerce_value(new_raw, rhs.til_type(), assign_hb.til_type, ctx, assign_hb.own_type)
                }
            }
            if raw_type_is_prim(assign_hb.til_type, ctx).and(assign_hb.own_type.is(OwnType.Own).not()).and(stmt.til_type().is(Type.Dynamic).not()) {
                // Primitive assignment writes the scalar into the existing
                // block in place (C's x = v) -- for a ref/borrowed binding
                // the block IS the target storage, so this is write-through.
                // No drop, no allocation. Own-primitives (#302 raw-alloc
                // pointers) keep the pointer-transfer path below. A
                // consumed raw-alloc binding (own-arg freed + reassigned)
                // has no block left -- give it a fresh one.
                if assign_hb.ptr.is_null() {
                    fresh_block : Dynamic = scalar_block_from_word(assign_hb.til_type, new_raw, ctx)
                    assign_hb.ptr = to_ptr(fresh_block)
                }
                else { scalar_word_store(assign_hb.til_type, to_ptr(assign_hb.ptr), new_raw, ctx) }
            } else if assign_hb.is_borrowed {
                ref assign_data : Dynamic = to_ptr(assign_hb.ptr)
                _ := heap_move_ptr_into_slot(assign_hb.til_type, assign_data, new_raw, assign_hb.ctx)
            } else {
                scope_drop_existing_heap_slot(scope_get_binding_scope(scope, ad.name), ad.name, ad.save_old_delete)
                assign_hb.ptr = to_ptr(new_raw)
            }
            assign_hb.moved_out = false
        case NodeType.FieldAssign(fad):
            fname := fad.name
            ref val_expr : Expr = stmt.children[1]
            mut val_raw : Dynamic = 0
            mut val_is_ref := false
            if fad.transfers_own {
                switch val_expr.node_type {
                case NodeType.Ident(val_id):
                    val_raw = scope_move_bound_raw(scope, val_id.ident_name(), ctx)
                case:
                    val_raw = eval_expr_raw(scope, val_expr, ctx)
                    val_is_ref = expr_raw_is_ref(scope, val_expr, ctx)
                }
            } else {
                switch val_expr.node_type {
                case NodeType.Ident(val_id):
                    ref source_hb : HeapBinding = scope_lookup_heap_binding(scope, val_id.ident_name())
                    if source_hb.is_null() { panic("field assignment source not found: ", val_id.ident_name()) }
                    if source_hb.moved_out { panic("field assignment source moved: ", val_id.ident_name()) }
                    ref source_raw : Dynamic = to_ptr(source_hb.ptr)
                    val_raw = source_raw
                    val_is_ref = true
                case:
                    val_raw = eval_expr_raw(scope, val_expr, ctx)
                    val_is_ref = expr_raw_is_ref(scope, val_expr, ctx)
                }
            }
            if interp_fa_is_ns(scope, stmt, ctx) {
                mut sname := til_type_name(stmt.children[0].til_type())
                if sname.len() == 0 {
                    switch stmt.children[0].node_type {
                    case NodeType.Ident(oi): sname = Str.clone(oi.ident_name())
                    case:
                    }
                }
                target_type := ns_field_type(sname, fname, ctx)
                if val_is_ref {
                    owned : Dynamic = heap_clone_by_type(target_type, val_raw, ctx)
                    val_raw = owned
                } else {
                    val_raw = raw_coerce_value(val_raw, val_expr.til_type(), target_type, ctx)
                    // ns storage is a binding: a scalar word needs a block.
                    val_raw = binding_block_from_word(target_type, val_raw, false, ctx)
                }
                ns_set(sname, fname, val_raw, target_type, ctx)
            } else {
                ref mut base : Dynamic = resolve_field_assign_base(scope, stmt.children[0])
                ref mut cur_sdef : Expr = resolve_field_assign_sdef(scope, stmt.children[0], ctx)
                mut cur_sname : Str = resolve_field_assign_sname(scope, stmt.children[0])
                // Chain walking for nested field access (e.g. a.b.c = val).
                // Collect the chain's field names outer-to-inner (for
                // `c.b.a`: [a, b]) while descending to the root Ident, then
                // apply them root-to-leaf so `base` ends at the struct whose
                // field `fname` is assigned. Previously only depth==1 was
                // handled, so `c.b.a.x = 42` left base/cur_sdef pointing at
                // `c`/C; find_field_decl(C, "x") then returned NULL and
                // write_field dereferenced the null Declaration (a segfault
                // in field_nested_def -> is_primitive).
                if stmt.children[0].node_type.is(NodeType.FieldAccess) {
                    mut chain_names := Vec(Str).new()
                    ref mut cur : Expr = stmt.children[0]
                    while cur.node_type.is(NodeType.FieldAccess) {
                        switch cur.node_type {
                        case NodeType.FieldAccess(fa_link):
                            chain_names.push(own Str.clone(fa_link.field_access_name()))
                        case:
                        }
                        cur = cur.children[0]
                    }
                    switch cur.node_type {
                    case NodeType.Ident:
                        base = resolve_field_assign_base(scope, cur)
                        cur_sdef = resolve_field_assign_sdef(scope, cur, ctx)
                        cur_sname = resolve_field_assign_sname(scope, cur)
                        mut step_i : USize = chain_names.len()
                        while step_i > 0 {
                            step_i--
                            ref step_name : Str = chain_names[step_i]
                            ref step_fd : Declaration = find_field_decl(cur_sdef, step_name)
                            if step_fd.is_null() { break }
                            step_off := ctx_field_layout(cur_sname, step_name, ctx).offset
                            if step_fd.own_type.is(OwnType.Shallow).not() {
                                base = deref(ptr_add(base, step_off))
                            } else {
                                base = ptr_add(base, step_off)
                            }
                            cur_sdef = field_nested_def(step_fd, ctx)
                            cur_sname = step_fd.explicit_type
                        }
                    case:
                    }
                }
                if base.is_null() {
                    interp_error(stmt, "field assign on non-struct", ctx)
                    exit(1)
                }
                if cur_sdef.is_null() {
                    interp_error(stmt, "field assign on non-struct", ctx)
                    exit(1)
                }
                ref fdecl : Declaration = find_field_decl(cur_sdef, fname)
                ref wf_fl : FieldLayout = ctx_field_layout(cur_sname, fname, ctx)
                write_field(base, fdecl, wf_fl.offset, wf_fl.size, val_raw, val_expr.til_type(), val_is_ref, fad.save_old_delete, ctx)
            }
        case NodeType.FCall(fcd):
            eval_fcall(scope, stmt, fcd, ctx)
        case NodeType.Body:
            block_scope := scope_new(scope)
            eval_body(block_scope, stmt, ctx)
            scope_free(own block_scope)
        case NodeType.CaptureBlock:
            // Issue #54: a capture block runs its body inline -- the typer
            // already enforced the capture restriction, so at runtime it
            // behaves exactly like a bare `{ ... }` block.
            cb_scope := scope_new(scope)
            eval_body(cb_scope, stmt.children[0], ctx)
            scope_free(own cb_scope)
        case NodeType.If:
            eval_if(scope, stmt, ctx)
        case NodeType.While:
            eval_while(scope, stmt, ctx)
        case NodeType.Break:
            c.has_break = true
        case NodeType.Continue:
            c.has_continue = true
        case NodeType.Return:
            if stmt.children.len() > 0 {
                ref ret_expr : Expr = stmt.children[0]
                mut return_raw : Dynamic = 0
                mut return_source_type := ret_expr.til_type()
                mut return_source_is_ref := false
                switch ret_expr.node_type {
                case NodeType.Ident(ret_ident):
                    ref return_hb : HeapBinding = scope_lookup_heap_binding(scope, ret_ident.ident_name())
                    if return_hb.is_null() { panic("return binding not found: ", ret_ident.ident_name()) }
                    return_source_type = return_hb.til_type.clone()
                    return_source_is_ref = return_hb.own_type.is(OwnType.Ref)
                    // A SHALLOW primitive return reads the scalar word; the
                    // binding keeps its block (nothing inner to move).
                    if scope_return_move_is_local(scope, ret_ident.ident_name()).and(raw_type_is_prim(return_hb.til_type, ctx).and(return_hb.own_type.is(OwnType.Shallow)).not()) {
                        return_raw = scope_move_bound_raw(scope, ret_ident.ident_name(), ctx)
                        // An own-prim VALUE binding's moved block collapses to
                        // the inline word callers expect from a prim-stamped
                        // call; a #302 raw-alloc POINTER binding keeps its
                        // bare pointer (which already travels as word bits) --
                        // unless the fn's declared return type is Dynamic, in
                        // which case callers expect the Dynamic wrapper shape
                        // (slot -> value storage): box the bare pointer.
                        if raw_type_is_prim(return_hb.til_type, ctx).and(return_source_is_ref.not()) {
                            if return_hb.is_raw_alloc.and(type_from_name_init(c.interp_ret_type, ctx.scope).is(Type.Dynamic)) {
                                // A #302 raw-alloc pointer returned at a
                                // Dynamic-declared type: callers expect the
                                // Dynamic wrapper shape (slot -> value
                                // storage), so box the bare pointer.
                                alloc_wrap : Dynamic = EvalHeap.heap_alloc(Dynamic.size())
                                write_ptr(alloc_wrap, return_raw)
                                return_raw = alloc_wrap
                                // The value is now Dynamic-shaped; the prim
                                // source stamp would make raw_result_reframe
                                // re-read the wrapper's low bytes.
                                return_source_type = Type.Dynamic
                            } else {
                                // The moved block (an own-prim VALUE binding's
                                // block, or a #302 raw-alloc VALUE box such as
                                // Vec.pop's malloc'd `out`) collapses to the
                                // inline word callers expect from a
                                // prim-stamped call, and the block is
                                // reclaimed here -- the block model's
                                // move_into copied-and-freed the same way.
                                moved_word : Dynamic = scalar_word_load(return_hb.til_type, return_raw, ctx)
                                EvalHeap.heap_free(own return_raw)
                                return_raw = moved_word
                            }
                        }
                    } else {
                        return_raw = scope_read_bound_raw(scope, ret_ident.ident_name(), ctx)
                    }
                    return_raw = raw_result_reframe(return_source_type, return_raw, return_source_is_ref, c.interp_ret_is_ref, ctx)
                case NodeType.FCall:
                    return_raw = eval_call(scope, ret_expr, ctx, c.interp_ret_dest)
                    inner_is_ref := call_raw_result_is_ref(scope, ret_expr, ctx)
                    return_raw = raw_result_reframe(ret_expr.til_type(), return_raw, inner_is_ref, c.interp_ret_is_ref, ctx)
                case NodeType.FieldAccess:
                    if c.interp_ret_is_ref {
                        ref field_ptr : Dynamic = field_access_base(scope, ret_expr, ctx)
                        return_raw = field_ptr
                        return_source_is_ref = true
                    } else {
                        return_source_type = scalar_raw_source_type(scope, ret_expr, ctx)
                        return_raw = eval_expr_raw(scope, ret_expr, ctx, c.interp_ret_dest)
                        inner_is_ref := expr_raw_is_ref(scope, ret_expr, ctx)
                        return_raw = raw_result_reframe(return_source_type, return_raw, inner_is_ref, false, ctx)
                    }
                case:
                    if ret_expr.node_type.is_literal_null().and(c.interp_ret_is_ref) {
                        return_raw = NULL
                        return_source_is_ref = true
                    } else {
                        return_raw = eval_expr_raw(scope, ret_expr, ctx, c.interp_ret_dest)
                        inner_is_ref := expr_raw_is_ref(scope, ret_expr, ctx)
                        return_raw = raw_result_reframe(ret_expr.til_type(), return_raw, inner_is_ref, c.interp_ret_is_ref, ctx)
                    }
                }
                target_return_type := type_from_name_init(c.interp_ret_type, ctx.scope)
                if c.interp_ret_is_ref.not() {
                    return_raw = raw_coerce_value(return_raw, return_source_type, target_return_type, ctx, c.interp_ret_own_type)
                    return_raw = raw_result_finish(target_return_type, return_raw, c.interp_ret_dest, false, ctx)
                }
                context_return_set(c, return_raw)
            } else {
                // A bare return carries the null None word: no allocation.
                context_return_set(c, NULL)
            }
        case NodeType.Switch:
            eval_switch(scope, stmt, ctx)
        case:
            interp_lang_error(stmt, "unexpected statement type", ctx)
            exit(1)
        }
    }
}

priv eval_user_func_call := proc(caller_scope: Scope, e: Expr, func_def: Expr, parent_scope: Scope, mut ctx: Context, destination: Dynamic = NULL) returns Dynamic {
    ref mut c : Context = ctx
    if func_def.children.len() == 0 {
        interp_error(e, "cannot call an interface method through the interface: it has no implementation", ctx)
        exit(1)
    }
    ref body : Expr = func_def.children[0]

    call_scope := scope_new(parent_scope)
    call_scope.is_call_scope = true
    switch func_def.node_type {
    case NodeType.FuncDef(fdef_params):
        for pi in 0..fdef_params.params.len() {
            ref param : Declaration = fdef_params.params[pi]
            ref arg_expr : Expr = e.children[pi + 1]
            arg_transfers := get_own_arg(e, pi + 1).and(get_keep_outer_arg(e, pi + 1).not())
            is_variadic_param := fdef_params.variadic_index == pi.to_i32()
            switch arg_expr.node_type {
            case NodeType.Ident(arg_ident):
                ref source_hb : HeapBinding = scope_lookup_heap_binding(caller_scope, arg_ident.ident_name())
                if source_hb.is_null() { panic("argument binding not found: ", arg_ident.ident_name()) }
                if source_hb.moved_out { panic("argument from moved binding: ", arg_ident.ident_name()) }
                ref source_raw : Dynamic = to_ptr(source_hb.ptr)
                if is_variadic_param.not().and(param.explicit_type.eq("Dynamic")).and(source_hb.til_type.is(Type.Dynamic).not()) {
                    mut dynamic_data : Dynamic = source_raw
                    if arg_transfers {
                        if source_hb.is_borrowed {
                            scope_set_heap_owned(call_scope, param.name, dynamic_data, Type.Dynamic, param.own_type, ctx, false, true, true)
                            continue
                        } else if heap_slot_is_static_callable(source_hb.til_type, source_raw) {
                            dynamic_data = heap_clone_by_type(source_hb.til_type, source_raw, source_hb.ctx)
                        } else {
                            source_hb.ptr = NULL
                            source_hb.moved_out = true
                        }
                        if raw_type_is_prim(source_hb.til_type, ctx) {
                            // The moved/cloned prim BLOCK is already the value
                            // storage: the Dynamic slot points AT it. The
                            // word-based prim->Dynamic coerce would box the
                            // block ADDRESS as the scalar.
                            prim_dyn_slot : Dynamic = EvalHeap.heap_alloc(Dynamic.size())
                            write_ptr(prim_dyn_slot, dynamic_data)
                            dynamic_data = prim_dyn_slot
                        } else {
                            dynamic_data = raw_coerce_value(dynamic_data, source_hb.til_type, Type.Dynamic, ctx, param.own_type)
                        }
                        scope_set_heap_owned(call_scope, param.name, dynamic_data, Type.Dynamic, param.own_type, ctx, true)
                    } else if param.own_type.is(OwnType.Ref) {
                        scope_set_heap_owned(call_scope, param.name, dynamic_data, Type.Dynamic, param.own_type, ctx, false, true, true)
                    } else {
                        dynamic_slot : Dynamic = EvalHeap.heap_alloc(Dynamic.size())
                        write_ptr(dynamic_slot, dynamic_data)
                        scope_set_heap_owned(call_scope, param.name, dynamic_slot, Type.Dynamic, param.own_type, ctx, true)
                    }
                } else if arg_transfers {
                    mut owned_raw : Dynamic = source_raw
                    mut bind_type := source_hb.til_type.clone()
                    if is_variadic_param.not().and(param.explicit_type.len().gt(0)) { bind_type = type_from_name_init(param.explicit_type, ctx.scope) }
                    if source_hb.is_borrowed {
                        scope_set_heap_owned(call_scope, param.name, owned_raw, bind_type, param.own_type, source_hb.ctx, false, true, source_hb.is_erased_dynamic)
                        continue
                    } else if heap_slot_is_static_callable(source_hb.til_type, source_raw) {
                        owned_raw = heap_clone_by_type(source_hb.til_type, source_raw, source_hb.ctx)
                    } else {
                        source_hb.ptr = NULL
                        source_hb.moved_out = true
                    }
                    if raw_type_is_prim(source_hb.til_type, ctx).and(source_hb.is_raw_alloc.not()).and(til_type_name_c(source_hb.til_type) != til_type_name_c(bind_type)) {
                        // Width-converting prim move: re-box at the param
                        // width (a narrow block bound under a wider type
                        // over-reads on the word load).
                        own_src_w : Dynamic = scalar_word_load(source_hb.til_type, owned_raw, ctx)
                        EvalHeap.heap_free(own owned_raw)
                        owned_raw = scalar_block_from_word(bind_type, raw_widen_numeric(own_src_w, source_hb.til_type, param.explicit_type, ctx), ctx)
                    } else {
                        owned_raw = raw_coerce_value(owned_raw, source_hb.til_type, bind_type, ctx, param.own_type)
                    }
                    scope_set_raw_owned(call_scope, param.name, owned_raw, bind_type, param.own_type, ctx)
                } else {
                    mut bind_type := source_hb.til_type.clone()
                    if is_variadic_param.not().and(param.explicit_type.len().gt(0)) { bind_type = type_from_name_init(param.explicit_type, ctx.scope) }
                    if source_hb.til_type.is(Type.Dynamic).and(bind_type.is(Type.Dynamic).not()) {
                        mut pointed : Dynamic = source_raw
                        if source_hb.is_erased_dynamic.not() { pointed = deref(source_raw) }
                        scope_set_heap_owned(call_scope, param.name, pointed, bind_type, param.own_type, source_hb.ctx, false, true)
                    } else if heap_type_is_callable(source_hb.til_type).and(heap_type_is_callable(bind_type)) {
                        ref arg_source_scope : Scope = scope_get_binding_scope(caller_scope, arg_ident.ident_name())
                        scope_set_borrowed(call_scope, param.name, bind_type, param.own_type, arg_ident.ident_name(), arg_source_scope)
                    } else if til_type_name_c(source_hb.til_type) != til_type_name_c(bind_type) {
                        if raw_type_is_prim(source_hb.til_type, ctx).and(raw_type_is_prim(bind_type, ctx)).and(source_hb.is_raw_alloc.not()) {
                            // Width-converting prim copy: load the scalar at
                            // the SOURCE width, widen, and box at the param
                            // width (a narrow clone bound under a wider type
                            // over-reads on the word load).
                            src_w : Dynamic = scalar_word_load(source_hb.til_type, source_raw, ctx)
                            widened_w : Dynamic = raw_widen_numeric(src_w, source_hb.til_type, param.explicit_type, ctx)
                            scope_set_raw_owned(call_scope, param.name, scalar_block_from_word(bind_type, widened_w, ctx), bind_type, param.own_type, ctx)
                        } else {
                            mut converted : Dynamic = heap_clone_by_type(source_hb.til_type, source_raw, source_hb.ctx)
                            converted = raw_coerce_value(converted, source_hb.til_type, bind_type, ctx, param.own_type)
                            scope_set_raw_owned(call_scope, param.name, converted, bind_type, param.own_type, ctx)
                        }
                    } else {
                        ref arg_source_scope : Scope = scope_get_binding_scope(caller_scope, arg_ident.ident_name())
                        scope_set_borrowed(call_scope, param.name, bind_type, param.own_type, arg_ident.ident_name(), arg_source_scope)
                    }
                }
            case:
                mut arg_raw : Dynamic = eval_expr_raw(caller_scope, arg_expr, ctx)
                arg_is_ref := expr_raw_is_ref(caller_scope, arg_expr, ctx)
                if is_variadic_param.not().and(param.explicit_type == "Dynamic") {
                    if arg_expr.til_type().is(Type.Dynamic) {
                        if param.own_type.is(OwnType.Ref) {
                            scope_set_heap_owned(call_scope, param.name, arg_raw, Type.Dynamic, param.own_type, ctx, false, true, true)
                        } else {
                            scope_set_heap_owned(call_scope, param.name, arg_raw, Type.Dynamic, param.own_type, ctx, true)
                        }
                    } else if param.own_type.is(OwnType.Ref) {
                        mut pointed : Dynamic = arg_raw
                        if arg_is_ref.not().and(expr_word_shaped(caller_scope, arg_expr, ctx)) {
                            // A scalar word has no storage: box it so the
                            // borrowed Dynamic view has bytes to point at.
                            pointed = scalar_block_from_word(arg_expr.til_type(), arg_raw, ctx)
                        }
                        scope_set_heap_owned(call_scope, param.name, pointed, Type.Dynamic, param.own_type, ctx, false, true, true)
                    } else {
                        dynamic_slot : Dynamic = EvalHeap.heap_alloc(Dynamic.size())
                        if arg_is_ref { write_ptr(dynamic_slot, arg_raw) }
                        else if expr_word_shaped(caller_scope, arg_expr, ctx) {
                            // Box the scalar word: the Dynamic slot points at
                            // real bytes (C's &x), as the block model did.
                            write_ptr(dynamic_slot, scalar_block_from_word(arg_expr.til_type(), arg_raw, ctx))
                        }
                        else { write_ptr(dynamic_slot, arg_raw) }
                        scope_set_heap_owned(call_scope, param.name, dynamic_slot, Type.Dynamic, param.own_type, ctx, true)
                    }
                } else {
                    mut bind_type := param.til_type.clone()
                    if is_variadic_param.not().and(param.explicit_type.len().gt(0)) { bind_type = type_from_name_init(param.explicit_type, ctx.scope) }
                    mut borrowed := false
                    if arg_is_ref {
                        borrowed = true
                    } else {
                        arg_raw = raw_coerce_value(arg_raw, arg_expr.til_type(), bind_type, ctx, param.own_type)
                        if param.own_type.is(OwnType.Ref) {
                            switch arg_expr.node_type {
                            case NodeType.Literal(Literal.Null): borrowed = true
                            case:
                            }
                        }
                        // A scalar word needs real storage to become a
                        // binding slot. The Dynamic-source own/ref-target
                        // coercion transfers a pointer (#302) and stays.
                        mut arg_word := raw_type_is_prim(bind_type, ctx).and(borrowed.not())
                        if arg_expr.til_type().is(Type.Dynamic).and(param.own_type.is(OwnType.Shallow).not()) { arg_word = false }
                        // A prim-stamped eval can still be a BLOCK (an Own-prim
                        // binding read: a #302 raw-alloc pointer datum). That is
                        // already storage-shaped; boxing it would store the
                        // block ADDRESS as the scalar.
                        if raw_type_is_prim(arg_expr.til_type(), ctx).and(expr_word_shaped(caller_scope, arg_expr, ctx).not()) { arg_word = false }
                        if arg_word { arg_raw = scalar_block_from_word(bind_type, arg_raw, ctx) }
                    }
                    scope_set_raw_owned(call_scope, param.name, arg_raw, bind_type, param.own_type, ctx, borrowed)
                }
            }
        }
    case:
        UNREACHABLE()
    }
    c.has_return = false
    c.return_value = NULL
    saved_ret_is_ref := c.interp_ret_is_ref
    ref saved_ret_dest : Dynamic = c.interp_ret_dest
    ref saved_ret_type : Str = c.interp_ret_type
    saved_ret_own_type := c.interp_ret_own_type
    mut callee_ret_is_ref := false
    mut use_return_destination := true
    switch func_def.node_type {
    case NodeType.FuncDef(ret_fd):
        callee_ret_is_ref = ret_fd.return_own_type.is(OwnType.Ref)
        c.interp_ret_type = ret_fd.return_type
        c.interp_ret_own_type = ret_fd.return_own_type
        if ret_fd.return_type.len() > 0 {
            declared_return_type := type_from_name_init(ret_fd.return_type, ctx.scope)
            if til_type_name_c(declared_return_type) != til_type_name_c(e.til_type()) { use_return_destination = false }
        }
        if e.til_type().is(Type.Unknown).and(ret_fd.return_type.len() > 0) {
            e.set_til_type(type_from_name_init(ret_fd.return_type, ctx.scope))
        }
    case:
    }
    c.interp_ret_is_ref = callee_ret_is_ref
    c.interp_ret_dest = destination
    if use_return_destination.not() { c.interp_ret_dest = NULL }
    eval_body(call_scope, body, ctx)
    c.interp_ret_is_ref = saved_ret_is_ref
    c.interp_ret_dest = saved_ret_dest
    c.interp_ret_type = saved_ret_type
    c.interp_ret_own_type = saved_ret_own_type
    mut result : Dynamic = 0
    if c.has_return {
        result = context_return_take(c)
    } else {
        result = destination
        if result.is_null() { result = raw_unit_result(e.til_type(), ctx) }
    }
    switch func_def.node_type {
    case NodeType.FuncDef(result_fd):
        if result_fd.return_type.len() > 0 {
            source_result_type := type_from_name_init(result_fd.return_type, ctx.scope)
            if callee_ret_is_ref.not() {
                if source_result_type.is(Type.Dynamic).and(raw_type_is_prim(e.til_type(), ctx)) {
                    // A Dynamic-declared result re-stamped primitive by the
                    // typer: the caller consumes the VALUE word. Unbox
                    // through the wrapper and reclaim the owned storage.
                    ref unbox_pointed : Dynamic = deref(result)
                    unboxed_w : Dynamic = scalar_word_load(e.til_type(), unbox_pointed, ctx)
                    if result_fd.return_own_type.is(OwnType.Own) {
                        mut owned_pointed : Dynamic = unbox_pointed
                        EvalHeap.heap_free(own owned_pointed)
                    }
                    EvalHeap.heap_free(own result)
                    result = unboxed_w
                } else {
                    result = raw_coerce_value(result, source_result_type, e.til_type(), ctx, result_fd.return_own_type)
                }
            }
        }
    case:
    }
    // A by-value Str result must outlive any temporary receiver hidden by the
    // typer's argument hoisting, so materialize views before returning them.
    if callee_ret_is_ref.not() {
        mut return_type := e.til_type()
        switch return_type {
        case Type.Custom(return_type_name): return_type = type_from_name_init(return_type_name, ctx.scope)
        case:
        }
        switch return_type {
        case Type.Struct(return_sname):
            if return_sname == "Str" {
                ref returned_str : Str = to_ptr(result)
                if str_cap_at(result, ctx).gte(CAP_VIEW) {
                    return_count := str_count_at(result, ctx)
                    if return_count > 0 {
                        copy : Dynamic = EvalHeap.heap_alloc(return_count.add(1))
                        memcpy(copy, returned_str.c_str, return_count)
                        memset(ptr_add(copy, return_count), 0, 1)
                        write_ptr(result, copy)
                        str_write_count_cap(result, return_count, return_count, ctx)
                    }
                }
            }
        case:
        }
    }
    result = raw_result_finish(e.til_type(), result, destination, callee_ret_is_ref, ctx)
    scope_free(own call_scope)
    return result
}

priv eval_callable_call := proc(caller_scope: Scope, e: Expr, callable: Dynamic, mut ctx: Context, destination: Dynamic = NULL) returns Dynamic {
    ref func_def : Expr = callable_raw_func_def(callable)
    ref parent_scope : Scope = callable_raw_env(callable, caller_scope)
    switch func_def.node_type {
    case NodeType.BodyValue:
        body_scope := scope_new(parent_scope)
        eval_body(body_scope, func_def.children[0], ctx)
        scope_free(own body_scope)
        if destination.is_null().not() { return destination }
        return raw_unit_result(e.til_type(), ctx)
    case NodeType.FuncDef:
        return eval_user_func_call(caller_scope, e, func_def, parent_scope, ctx, destination)
    case:
        interp_error(e, "callee did not evaluate to a function", ctx)
        exit(1)
        return raw_unit_result(e.til_type(), ctx)
    }
}

priv eval_call := proc(scope: Scope, e: Expr, mut ctx: Context, destination: Dynamic = NULL) returns Dynamic {
    ref c : Context = ctx
    ref callee_expr : Expr = e.children[0]

    // Namespace method call: Struct.method(args)
    if callee_expr.node_type.is(NodeType.FieldAccess) {
        switch callee_expr.node_type {
        case NodeType.FieldAccess(callee_field):
            enum_name := field_access_sname(callee_expr)
            ref enum_def : Expr = lookup_interp_type_def(enum_name, ctx)
            if enum_def.is_null().not().and(enum_def.node_type.is(NodeType.EnumDef)) {
                mut enum_raw : Dynamic = destination
                if enum_raw.is_null() { enum_raw = dispatch_result_alloc(e.til_type(), ctx) }
                if enum_method_dispatch(callee_field.field_access_name(), scope, enum_def, enum_name, e, enum_raw, ctx) {
                    // A prim-stamped result (is() -> Bool) collapses to an
                    // inline word; enum values stay blocks. A caller-provided
                    // destination stays the caller's storage -- free only a
                    // block this call allocated itself.
                    if raw_type_is_prim(e.til_type(), ctx) {
                        prim_w : Dynamic = scalar_word_load(e.til_type(), enum_raw, ctx)
                        if destination.is_null() { EvalHeap.heap_free(own enum_raw) }
                        return prim_w
                    }
                    return enum_raw
                }
                if destination.is_null() { EvalHeap.heap_free(own enum_raw) }
            }
        case:
        }
        fn_raw : Dynamic = eval_expr_raw(scope, callee_expr, ctx)
        if callable_box_is(deref(fn_raw)) {
            result : Dynamic = eval_callable_call(scope, e, fn_raw, ctx, destination)
            callable_raw_free(fn_raw, ctx)
            return result
        }
        ref func_def : Expr = callable_raw_func_def(fn_raw)

            // FuncPtr field: stored function may be ext_func from another type
            if callee_expr.til_type().is_funcptr() {
                mut fp_func_type := FuncType.Func
                switch func_def.node_type {
                case NodeType.FuncDef(fp_fdef):
                    fp_func_type = fp_fdef.func_type
                case:
                    UNREACHABLE()
                }
                if fp_func_type.is(FuncType.ExtFunc).or(fp_func_type.is(FuncType.ExtProc)) {
                    for qn, nsv_hb in c.ns_fields.heap_bindings {
                        if heap_type_is_callable(nsv_hb.til_type).not() { continue }
                        ref nsv : Dynamic = to_ptr(nsv_hb.ptr)
                        ref nsv_fdef : Expr = callable_raw_func_def(nsv)
                        if nsv_fdef.ptr_eq(func_def) {
                            fp_flat := qn.replace(".", "_")
                            orig_callee := callee_expr.clone()
                            orig_result_type := e.til_type()
                            mut concrete_result_type := Type.None
                            mut concrete_return_own_type := OwnType.Shallow
                            switch nsv_fdef.node_type {
                            case NodeType.FuncDef(concrete_fd):
                                concrete_return_own_type = concrete_fd.return_own_type
                                if concrete_fd.return_type.len() > 0 { concrete_result_type = type_from_name_init(concrete_fd.return_type, ctx.scope) }
                            case:
                                UNREACHABLE()
                            }
                            mut flat_ident := callee_expr.clone()
                            flat_ident.node_type = ident_node(fp_flat)
                            e.children[0] = flat_ident
                            e.set_til_type(concrete_result_type)
                            mut concrete_destination : Dynamic = 0
                            if til_type_name_c(concrete_result_type) == til_type_name_c(orig_result_type) { concrete_destination = destination }
                            mut result : Dynamic = eval_call(scope, e, ctx, concrete_destination)
                            e.set_til_type(orig_result_type)
                            e.children[0] = orig_callee
                            callable_raw_free(fn_raw, ctx)
                            if concrete_return_own_type.is(OwnType.Ref).not() {
                                result = raw_coerce_value(result, concrete_result_type, orig_result_type, ctx, concrete_return_own_type)
                                result = raw_result_finish(orig_result_type, result, destination, false, ctx)
                            }
                            return result
                        }
                    }
                }
            }
            // Direct ext_func namespace method -- dispatch by flat name
            mut fdef_func_type := FuncType.Func
            mut direct_result_type := Type.None
            mut direct_return_own_type := OwnType.Shallow
            switch func_def.node_type {
            case NodeType.FuncDef(fdef_ns):
                fdef_func_type = fdef_ns.func_type
                direct_return_own_type = fdef_ns.return_own_type
                if fdef_ns.return_type.len() > 0 { direct_result_type = type_from_name_init(fdef_ns.return_type, ctx.scope) }
            case:
                UNREACHABLE()
            }
            if fdef_func_type.is(FuncType.ExtFunc).or(fdef_func_type.is(FuncType.ExtProc)).or(fdef_func_type.is(FuncType.CoreFunc)).or(fdef_func_type.is(FuncType.CoreProc)).or(fdef_func_type.is(FuncType.CoreLazyFunc)) {
                parent_sname := til_type_name(callee_expr.children[0].til_type())
                ref tc : Dynamic = scope_get(scope, parent_sname)? catch (e: KeyNotFound) {
                    // REM: parent_sname is unbound for a primitive receiver
                    // (til_type_name returns "" for primitives) -- an expected miss.
                    // tc stays NULL, the guard below skips namespace-method dispatch,
                    // and control falls through to the flat-name dispatch.
                }
                if tc.is_null().not() {
                    ref tc_raw : Dynamic = tc
                    ref tc_edef : Expr = callable_raw_func_def(tc_raw)
                        if tc_edef.node_type.is(NodeType.EnumDef) {
                            switch callee_expr.node_type {
                            case NodeType.FieldAccess(callee_ident):
                                mut enum_raw : Dynamic = destination
                                if enum_raw.is_null() { enum_raw = dispatch_result_alloc(e.til_type(), ctx) }
                                if enum_method_dispatch(callee_ident.field_access_name(), scope, tc_edef, parent_sname, e, enum_raw, ctx) {
                                    callable_raw_free(fn_raw, ctx)
                                    // A prim-stamped result (is() -> Bool)
                                    // collapses to an inline word.
                                    if raw_type_is_prim(e.til_type(), ctx) {
                                        prim_w2 : Dynamic = scalar_word_load(e.til_type(), enum_raw, ctx)
                                        EvalHeap.heap_free(own enum_raw)
                                        return prim_w2
                                    }
                                    return enum_raw
                                }
                                if destination.is_null() { EvalHeap.heap_free(own enum_raw) }
                            case:
                                UNREACHABLE()
                            }
                        }
                }
                mut sn := til_type_name(callee_expr.children[0].til_type())
                // til_type_name returns "" for primitives. For ext_func
                // dispatch on a primitive receiver (e.g. `0.sub(1)` ->
                // `I64_sub(0, 1)`), fall back to til_type_name_c.
                if sn.is_empty() {
                    tn := til_type_name_c(callee_expr.children[0].til_type())
                    if tn.eq("unknown").not().and(tn.eq("?").not()).and(tn.eq("Dynamic").not()) {
                        sn = tn
                    }
                }
                switch callee_expr.node_type {
                case NodeType.FieldAccess(fn_name):
                    // If the receiver type is unknown (eg Dynamic), fall back to
                    // the unqualified top-level name. Required for and/or/not.
                    mut flat_str := Str.clone(fn_name.field_access_name())
                    if sn.len() > 0 {
                        flat_str = sn.concat3("_", fn_name.field_access_name())
                    }
                    orig_callee_val := callee_expr.clone()
                    orig_direct_result_type := e.til_type()
                    mut flat_ident2 := callee_expr.clone()
                    flat_ident2.node_type = ident_node(flat_str)
                    e.children[0] = flat_ident2
                    e.set_til_type(direct_result_type)
                    mut direct_destination : Dynamic = 0
                    if til_type_name_c(direct_result_type) == til_type_name_c(orig_direct_result_type) { direct_destination = destination }
                    mut result : Dynamic = eval_call(scope, e, ctx, direct_destination)
                    e.set_til_type(orig_direct_result_type)
                    e.children[0] = orig_callee_val
                    callable_raw_free(fn_raw, ctx)
                    if direct_return_own_type.is(OwnType.Ref).not() {
                        result = raw_coerce_value(result, direct_result_type, orig_direct_result_type, ctx, direct_return_own_type)
                        result = raw_result_finish(orig_direct_result_type, result, destination, false, ctx)
                    }
                    return result
                case:
                    UNREACHABLE()
                }
            }

        result : Dynamic = eval_callable_call(scope, e, fn_raw, ctx, destination)
        callable_raw_free(fn_raw, ctx)
        return result
    }

    // Direct ident call
    switch callee_expr.node_type {
    case NodeType.Ident(name):

        // Ext/core dispatch writes raw bytes sized by this call's result Type.
        ref ext_slot : Dynamic = scope_get(scope, name.ident_name())?
        catch (e: KeyNotFound) {
            // REM: a pure builtin (U64_bnot, ...) has no FuncDef cell -- an
            // expected miss. ext_cell stays NULL and the is_null guard below
            // skips return/param ownership checks.
        }
        mut ext_result_type := e.til_type()
        mut ext_return_own_type := OwnType.Shallow
        mut ext_variadic_index : I32 = -1
        ext_result_is_ref := call_raw_result_is_ref(scope, e, ctx)
        if ext_slot.is_null().not() {
            ref ext_binding_raw : Dynamic = ext_slot
            ref ext_def : Expr = callable_raw_func_def(ext_binding_raw)
            switch ext_def.node_type {
            case NodeType.FuncDef(ext_fd):
                if ext_fd.return_type.len() == 0 { ext_result_type = Type.None }
                else { ext_result_type = type_from_name_init(ext_fd.return_type, ctx.scope) }
                ext_return_own_type = ext_fd.return_own_type
                ext_variadic_index = ext_fd.variadic_index
            case NodeType.BodyValue:
                ext_result_type = Type.None
            case NodeType.StructDef:
            case NodeType.EnumDef:
            case:
                UNREACHABLE()
            }
        }
        // `cast(e, T)` and dyn_call_ret declare Dynamic because til has no
        // dependent return types; the typer places the concrete result on the
        // call expression. Allocate dispatch storage at that contextual type.
        contextual_dynamic_result := ext_return_own_type.is(OwnType.Shallow).or(name.ident_name() == "dyn_call_ret")
        if ext_result_type.is(Type.Dynamic).and(contextual_dynamic_result).and(e.til_type().is(Type.Dynamic).not()) {
            ext_result_type = e.til_type()
        }
        mut ext_storage_type := ext_result_type.clone()
        if ext_result_is_ref { ext_storage_type = Type.Dynamic }
        // Primitive/None dispatch results use a reusable scratch slot and
        // come back as inline words: no allocation per scalar op.
        ext_prim_result := raw_type_is_prim(ext_storage_type, ctx).or(ext_storage_type.is(Type.None))
        mut ext_raw : Dynamic = 0
        if ext_prim_result { ext_raw = dispatch_scratch_push() }
        else if ext_result_is_ref.not().and(destination.is_null().not()).and(til_type_name_c(ext_result_type) == til_type_name_c(e.til_type())) {
            ext_raw = destination
        } else {
            ext_raw = dispatch_result_alloc(ext_storage_type, ctx)
        }
        if ext_function_dispatch(name.ident_name(), scope, e, ext_raw, ctx) {
            for oi in 1..e.children.len() {
                if get_own_arg(e, oi) {
                    if oi.sub(1).to_i32() == ext_variadic_index { continue }
                    switch e.children[oi].node_type {
                    case NodeType.Ident(oa_ident):
                        ref arg_hb : HeapBinding = scope_lookup_heap_binding(scope, oa_ident.ident_name())
                        if arg_hb.is_null().not() {
                            // An own arg whose CALLEE PARAM is `own` was genuinely
                            // handed to C, which owns (and may free) its buffer:
                            // The typed AST's own-argument bit is the transfer
                            // decision. Dispatch consumes the value; scope teardown
                            // must not reclaim it a second time.
                            arg_hb.ptr = NULL
                            arg_hb.moved_out = true
                        }
                    case:
                    }
                }
            }
            if ext_prim_result {
                mut ext_word : Dynamic = 0
                if ext_storage_type.is(Type.None).not() { ext_word = scalar_word_load(ext_storage_type, ext_raw, ctx) }
                dispatch_scratch_pop()
                // The scratch slot is borrowed storage: consume the local
                // without freeing.
                word_drop(own ext_raw)
                ext_word = raw_coerce_value(ext_word, ext_result_type, e.til_type(), ctx, ext_return_own_type)
                return ext_word
            }
            if ext_result_is_ref {
                ref ext_ref_result : Dynamic = deref(ext_raw)
                direct_ref_result : Dynamic = ext_ref_result
                EvalHeap.heap_free(own ext_raw)
                return direct_ref_result
            }
            ext_raw = raw_coerce_value(ext_raw, ext_result_type, e.til_type(), ctx, ext_return_own_type)
            ext_raw = raw_result_finish(e.til_type(), ext_raw, destination, false, ctx)
            return ext_raw
        }
        if ext_prim_result { dispatch_scratch_pop(); word_drop(own ext_raw) }
        else if ext_raw.ptr_eq(destination).not() { EvalHeap.heap_free(own ext_raw) }

        // User-defined function or struct instantiation
        // A miss means the callee name is bound nowhere -- undefined. The typer
        // rejects undefined names, so this only fires under the constfolder's
        // speculative eval, where the exit is caught via ctx.constfold_active in
        // h_exit. The ext dispatch probe above already walked the scope chain
        // for this exact name; reuse its result instead of a second walk.
        if ext_slot.is_null() {
            interp_error(e, format(Str.clone(name.ident_name()), " is undefined"), ctx)
            exit(1)
        }
        fn_raw : Dynamic = eval_expr_raw(scope, callee_expr, ctx)
        ref fn_def : Expr = callable_raw_func_def(fn_raw)

        // An ext_func reaching here did not dispatch above (not a builtin and
        // not FFI-registered -- e.g. a user .so not dlopen'd at constfolder time).
        // It has no body to execute. During speculative folding, mark the
        // evaluation aborted so try_eval_call leaves the call for runtime;
        // outside constfold, reaching an unregistered ext_func is invalid.
        switch fn_def.node_type {
            case NodeType.FuncDef(ext_fd):
                if ext_fd.func_type.is(FuncType.ExtFunc) {
                    callable_raw_free(fn_raw, ctx)
                    if ctx.constfold_active.not() { panic("ext_func is not registered: ", name.ident_name()) }
                    ctx.constfold_aborted = true
                    if destination.is_null().not() { return destination }
                    return raw_unit_result(e.til_type(), ctx)
                }
            case:
        }

        // Struct instantiation
        if fn_def.node_type.is(NodeType.StructDef) {
                switch fn_def.node_type {
                case NodeType.StructDef(sdd):
                    mut inst_data : Dynamic = destination
                    if inst_data.is_null() { inst_data = EvalHeap.heap_alloc(ctx_total_size(name.ident_name(), ctx)) }
                        mut arg_idx : USize = 1
                        for fdd : Declaration in sdd.fields {
                            cur_idx := arg_idx
                            ref arg : Expr = e.children[cur_idx]
                            arg_idx++
                            mut arg_raw : Dynamic = 0
                            mut arg_is_ref := false
                            mut arg_is_place := false
                            switch arg.node_type {
                            case NodeType.Ident(arg_ident):
                                ref source_hb : HeapBinding = scope_lookup_heap_binding(scope, arg_ident.ident_name())
                                mut move_iface_val := false
                                if sdd.is_interface.and(fdd.name == "iface_val") {
                                    for owned_i in 0..sdd.fields.len() {
                                        if sdd.fields[owned_i].name == "iface_owned" {
                                            switch e.children[owned_i + 1].node_type {
                                            case NodeType.Literal(Literal.Bool(owned_flag)): move_iface_val = owned_flag
                                            case NodeType.Ident(owned_id):
                                                ref owned_hb : HeapBinding = scope_lookup_heap_binding(scope, owned_id.ident_name())
                                                ref owned_raw : Dynamic = to_ptr(owned_hb.ptr)
                                                ref owned_flag2 : Bool = owned_raw
                                                move_iface_val = owned_flag2
                                            case:
                                            }
                                            break
                                        }
                                    }
                                }
                                if get_own_arg(e, cur_idx).or(move_iface_val) {
                                    if source_hb.moved_out { panic("struct init from moved heap binding: ", arg_ident.ident_name()) }
                                    ref source_ptr : Dynamic = to_ptr(source_hb.ptr)
                                    mut preserve_outer := get_keep_outer_arg(e, cur_idx)
                                    if fdd.own_type.is(OwnType.Shallow) {
                                        switch source_hb.til_type {
                                        case Type.Struct: preserve_outer = true
                                        case Type.Enum: preserve_outer = true
                                        case:
                                        }
                                    }
                                    if preserve_outer {
                                        arg_raw = EvalHeap.heap_alloc(raw_type_size(source_hb.til_type, ctx))
                                        memcpy(arg_raw, source_ptr, raw_type_size(source_hb.til_type, ctx))
                                    } else if source_hb.is_borrowed.and(source_hb.is_erased_dynamic) {
                                        arg_raw = EvalHeap.heap_alloc(Dynamic.size())
                                        write_ptr(arg_raw, source_ptr)
                                    } else {
                                        mut clone_source := source_hb.is_borrowed.or(heap_slot_is_static_callable(source_hb.til_type, source_ptr))
                                        mut promote_str_view := false
                                        switch source_hb.til_type {
                                        case Type.Struct(source_name):
                                            if (source_name == "Str").and(str_cap_at(source_ptr, ctx).gte(CAP_VIEW)) {
                                                clone_source = true
                                                promote_str_view = true
                                            }
                                        case:
                                        }
                                        if clone_source {
                                            arg_raw = heap_clone_by_type(source_hb.til_type, source_ptr, source_hb.ctx)
                                            switch source_hb.til_type {
                                            case Type.Struct(source_name2):
                                                if (source_name2 == "Str").and(promote_str_view) {
                                                    cnt := str_count_at(source_ptr, ctx)
                                                    if cnt == 0 {
                                                        str_write_count_cap(arg_raw, 0, CAP_VIEW, ctx)
                                                    } else {
                                                        ref source_str : Str = to_ptr(source_ptr)
                                                        copy : Dynamic = malloc(cnt.add(1).cast(U64))
                                                        memcpy(copy, source_str.c_str, cnt.cast(U64))
                                                        memset(ptr_add(copy, cnt.cast(U64)), 0, 1)
                                                        write_ptr(arg_raw, copy)
                                                        str_write_count_cap(arg_raw, cnt, cnt, ctx)
                                                    }
                                                }
                                            case:
                                            }
                                        } else {
                                            arg_raw = source_ptr
                                            source_hb.ptr = NULL
                                            source_hb.moved_out = true
                                        }
                                    }
                                    // An own-prim VALUE binding's moved/cloned
                                    // block collapses to its inline word; the
                                    // field writer would store the block
                                    // ADDRESS as the scalar. #302 raw-alloc
                                    // pointer bindings keep the bare pointer.
                                    if raw_type_is_prim(source_hb.til_type, ctx).and(source_hb.own_type.is(OwnType.Shallow).not()).and(source_hb.is_raw_alloc.not()).and(arg_is_ref.not()) {
                                        ctor_prim_word : Dynamic = scalar_word_load(source_hb.til_type, arg_raw, ctx)
                                        EvalHeap.heap_free(own arg_raw)
                                        arg_raw = ctor_prim_word
                                    }
                                } else if fdd.own_type.is(OwnType.Ref) {
                                    ref source_ptr : Dynamic = to_ptr(source_hb.ptr)
                                    arg_raw = source_ptr
                                    arg_is_ref = true
                                    arg_is_place = true
                                } else {
                                    arg_raw = eval_expr_raw(scope, arg, ctx)
                                    arg_is_ref = source_hb.own_type.is(OwnType.Ref)
                                    arg_is_place = heap_type_is_callable(source_hb.til_type).not()
                                }
                            case:
                                arg_raw = eval_expr_raw(scope, arg, ctx)
                                arg_is_ref = expr_raw_is_ref(scope, arg, ctx)
                                arg_is_place = arg_is_ref
                            }
                            // A SHALLOW prim field takes a value WORD: a
                            // ref/place arg is a bare source address, so load
                            // the scalar out first (the source keeps its
                            // storage), then widen like any value word.
                            if raw_type_is_prim(fdd.til_type, ctx).and(fdd.own_type.is(OwnType.Shallow)).and(arg_is_ref.or(arg_is_place)) {
                                arg_raw = scalar_word_load(arg.til_type(), arg_raw, ctx)
                                arg_is_ref = false
                                arg_is_place = false
                            }
                            arg_raw = raw_widen_numeric(arg_raw, arg.til_type(), fdd.explicit_type, ctx)
                            ref ctor_fl : FieldLayout = ctx_field_layout(name.ident_name(), fdd.name, ctx)
                            mut arg_is_null := false
                            switch arg.node_type {
                            case NodeType.Literal(Literal.Null): arg_is_null = true
                            case:
                            }
                            if fdd.own_type.is(OwnType.Ref).and(arg_is_null) {
                                raw_block_free(arg_raw)
                                write_ptr(ptr_add(inst_data, ctor_fl.offset), NULL)
                                continue
                            }
                            init_field_raw(inst_data, fdd, ctor_fl.offset, ctor_fl.size, arg_raw, arg.til_type(), arg_is_ref, arg_is_place, ctx)
                        }
                    callable_raw_free(fn_raw, ctx)
                    return inst_data
                case:
                    UNREACHABLE()
                }
        }

        result : Dynamic = eval_callable_call(scope, e, fn_raw, ctx, destination)
        callable_raw_free(fn_raw, ctx)
        return result
    case NodeType.FCall:
        // Issue #58: postfix call on a sub-expression callee, e.g.
        // `cast(raw, BinaryOp)(3, 4)`. Eval the callee (the cast) to
        // get the function pointer, then dispatch with the call's args.
        cast_raw : Dynamic = eval_expr_raw(scope, callee_expr, ctx)
        result : Dynamic = eval_callable_call(scope, e, cast_raw, ctx, destination)
        callable_raw_free(cast_raw, ctx)
        return result
    case:
        UNREACHABLE()
        if destination.is_null().not() { return destination }
        return raw_unit_result(e.til_type(), ctx)
    }
}

// Single owning-pointer box for side tables that need to own raw Dynamic
// pointers.
priv DynPtrBox := struct {
    own p : U8 = 0
}

// Issue #275, generalized after #58: Array/Vec/Set keep elements in an
// `own data` heap buffer. heap_drop_struct skips the `own data : U8` field
// itself, and heap_clone's initial memcpy only shallow-copies the data pointer.
// Clone/free the backing buffer here so interpreted containers have
// the same ownership as their generated delete/clone methods.

// Element type of a monomorphized container ("Array__Str" -> "Str",
// "Vec__I64" -> "I64"); "" for a non-container struct name.
priv container_elem_type := func(struct_name: Str, ctx: Context) returns Str {
    array_prefix := "Array__"
    if struct_name.starts_with(array_prefix) {
        return struct_name.substr(array_prefix.count, struct_name.count - array_prefix.count)
    }
    vec_prefix := "Vec__"
    if struct_name.starts_with(vec_prefix) {
        return struct_name.substr(vec_prefix.count, struct_name.count - vec_prefix.count)
    }
    set_prefix := "Set__"
    if struct_name.starts_with(set_prefix) {
        return struct_name.substr(set_prefix.count, struct_name.count - set_prefix.count)
    }
    sep := struct_name.find("__")
    if sep >= 0 {
        ref data_fl : FieldLayout = ctx_field_layout(struct_name, "data", ctx)
        ref count_fl : FieldLayout = ctx_field_layout(struct_name, "count", ctx)
        ref cap_fl : FieldLayout = ctx_field_layout(struct_name, "cap", ctx)
        if data_fl.size.gt(0).and(count_fl.size.gt(0)).and(cap_fl.size.gt(0)) {
            if data_fl.own_type.is(OwnType.Own).and(data_fl.struct_name.len().eq(0)).and(data_fl.is_enum.not()).and(data_fl.is_funcptr.not()) {
                start := sep.add(2).to_usize()
                rest := struct_name.substr(start, struct_name.count.sub(start))
                next_sep := rest.find("__")
                if next_sep >= 0 { return rest.substr(0, next_sep.to_usize()) }
                return rest
            }
        }
    }
    return ""
}

priv container_elem_size := func(elem_type: Str, ctx: Context) returns USize {
    resolved := type_from_name_init(elem_type, ctx.scope)
    switch resolved {
    case Type.Primitive(p):
        mut sz : USize = 0
        mut al : USize = 0
        builtin_primitive_size_align(p, sz, al)
        return sz
    case Type.Dynamic:
        return 8
    case Type.FuncPtr:
        return 8
    case Type.FuncPtrSig:
        return 8
    case:
    }
    sz2 := ctx_total_size(elem_type, ctx)
    if sz2 == 0 { panic("container element has no registered size: ", elem_type) }
    return sz2
}

priv type_name_is_funcsig := func(type_name: Str, ctx: Context) returns Bool {
    if type_from_name_init(type_name, ctx.scope).is_funcptr() { return true }
    ref tdef : Expr = lookup_interp_type_def(type_name, ctx)
    if tdef.is_null() { return false }
    if tdef.node_type.is(NodeType.FuncDef) {
        return tdef.children.len() == 0
    }
    return false
}

priv container_live_count := func(struct_name: Str, data: Dynamic, ctx: Context) returns USize {
    mut count_field := "count"
    if struct_name.starts_with("Array__") { count_field = "cap" }
    ref fl : FieldLayout = ctx_field_layout(struct_name, count_field, ctx)
    ref n : USize = ptr_add(data, fl.offset)
    return n.clone()
}

priv container_capacity := func(struct_name: Str, data: Dynamic, ctx: Context) returns USize {
    ref fl : FieldLayout = ctx_field_layout(struct_name, "cap", ctx)
    ref n : USize = ptr_add(data, fl.offset)
    return n.clone()
}

priv container_elem_deep_free := func(elem_type: Str, slot: Dynamic, ctx: Context) {
    if type_name_is_funcsig(elem_type, ctx) {
        ref stored_callable : Dynamic = deref(slot)
        if stored_callable.is_null().not() { callable_storage_free(stored_callable) }
        return
    }
    resolved := type_from_name_init(elem_type, ctx.scope)
    if resolved.is(Type.Primitive).or(resolved.is(Type.Dynamic)) { return }
    ref elem_def : Expr = lookup_interp_type_def(elem_type, ctx)
    if elem_def.is_null() { panic("container element has no registered type def: ", elem_type) }
    switch elem_def.node_type {
    case NodeType.StructDef:
        heap_drop_struct(elem_type, slot, ctx)
    case NodeType.EnumDef:
        if enum_has_payloads(elem_def) {
            enum_payload_deep_free(elem_type, slot, ctx)
        }
    case:
        panic("container element is not a struct or enum: ", elem_type)
    }
}

priv container_elem_clone_into := func(elem_type: Str, dst: Dynamic, src: Dynamic, elem_size: USize, ctx: Context) {
    if type_name_is_funcsig(elem_type, ctx) {
        ref stored_callable : Dynamic = deref(src)
        if stored_callable.is_null().not() { write_ptr(dst, callable_storage_clone(stored_callable)) }
        return
    }
    resolved := type_from_name_init(elem_type, ctx.scope)
    if resolved.is(Type.Primitive).or(resolved.is(Type.Dynamic)) {
        memcpy(dst, src, elem_size)
        return
    }
    ref elem_def : Expr = lookup_interp_type_def(elem_type, ctx)
    if elem_def.is_null() { panic("container element has no registered type def: ", elem_type) }
    switch elem_def.node_type {
    case NodeType.StructDef:
        cloned_ptr : Dynamic = heap_clone(elem_type, src, ctx)
        memcpy(dst, cloned_ptr, elem_size)
        EvalHeap.heap_free(own cloned_ptr)
    case NodeType.EnumDef:
        memcpy(dst, src, elem_size)
        if enum_has_payloads(elem_def) {
            enum_payload_deep_clone(elem_type, dst, ctx)
        }
    case:
        panic("container element is not a struct or enum: ", elem_type)
    }
}

priv free_tuple_data := func(data: Dynamic, ctx: Context) {
    ref data_fl : FieldLayout = ctx_field_layout("Tuple", "data", ctx)
    ref type_names_fl : FieldLayout = ctx_field_layout("Tuple", "type_names", ctx)
    ref type_sizes_fl : FieldLayout = ctx_field_layout("Tuple", "type_sizes", ctx)
    ref hdr : DynPtrBox = ptr_add(data, data_fl.offset)
    if hdr.p.is_null() { return }
    ref type_names : Vec(Str) = ptr_add(data, type_names_fl.offset)
    ref type_sizes : Vec(USize) = ptr_add(data, type_sizes_fl.offset)
    mut offset : USize = 0
    for i in 0..type_names.len() {
        ref elem_type : Str = type_names[i]
        ref elem_size : USize = type_sizes[i]
        container_elem_deep_free(elem_type, ptr_add(hdr.p, offset), ctx)
        offset = offset + elem_size
    }
    free(own hdr.p)
}

// Symmetric to free_tuple_data: heap_clone's generic field walk deep-clones a
// Tuple's type_names/type_sizes Vecs but leaves the packed `own data: U8`
// buffer SHARED -- a primitive field has no nested_def, so the walk's own-field
// branch skips it and dst keeps src's data pointer (the shallow struct memcpy).
// Without this, a cloned Tuple aliases the original's element buffer, so freeing
// either (free_tuple_data) dangles the other. Allocate a fresh buffer and
// deep-copy each heterogeneous element by its parallel type metadata (mirroring
// Tuple.clone's dyn_call loop), then repoint dst's data field at it.
priv clone_tuple_buffer := func(src_tuple: Dynamic, dst_tuple: Dynamic, ctx: Context) {
    ref data_fl : FieldLayout = ctx_field_layout("Tuple", "data", ctx)
    ref names_fl : FieldLayout = ctx_field_layout("Tuple", "type_names", ctx)
    ref sizes_fl : FieldLayout = ctx_field_layout("Tuple", "type_sizes", ctx)
    ref cap_fl : FieldLayout = ctx_field_layout("Tuple", "cap", ctx)
    ref src_hdr : DynPtrBox = ptr_add(src_tuple, data_fl.offset)
    if src_hdr.p.is_null() { return }
    ref cap : USize = ptr_add(src_tuple, cap_fl.offset)
    ref names : Vec(Str) = ptr_add(src_tuple, names_fl.offset)
    ref sizes : Vec(USize) = ptr_add(src_tuple, sizes_fl.offset)
    mut alloc_cap := cap.clone()
    if alloc_cap == 0 { alloc_cap = 8 }
    new_buf : Dynamic = malloc(alloc_cap)
    mut off : USize = 0
    for i in 0..names.len() {
        ref tn : Str = names[i]
        ref ts : USize = sizes[i]
        container_elem_clone_into(tn, ptr_add(new_buf, off), ptr_add(src_hdr.p, off), ts.clone(), ctx)
        off = off + ts
    }
    write_ptr(ptr_add(dst_tuple, data_fl.offset), new_buf)
}

// #286: cache-driven deep free of a struct value's nested heap. Reads
// ctx.struct_layouts (a name-keyed cache that outlives the AST) instead of the
// dangling struct_def, so it is safe at scope teardown. Frees own struct
// fields' blocks (recursing first), Str fields' c_strs, recurses into inline
// nested structs, and reclaims container data buffers. Enum
// fields and own non-struct pointers stay shallow (their construction can
// share a pointer, so freeing here would risk a double-free).
priv heap_drop_struct := func(struct_name: Str, data: Dynamic, ctx: Context) {
    if data.is_null() { return }
    if struct_name == "Str" {
        ref s_str : Str = to_ptr(data)
        if str_owns_c_str(data, ctx) {
            if s_str.c_str.is_null().not() { free(own s_str.c_str) }
        }
        return
    }
    if ctx.struct_layouts.has(struct_name).not() { return }
    if struct_name == "Expr" {
        ref node_fl : FieldLayout = ctx_field_layout("Expr", "node_type", ctx)
        if node_fl.size.eq(0) { panic("struct_deep_free Expr missing node_type layout") }
        NodeType.delete(own ptr_add(data, node_fl.offset), false)
        ref children_fl : FieldLayout = ctx_field_layout("Expr", "children", ctx)
        if children_fl.size.eq(0).or(children_fl.struct_name.len().eq(0)) {
            panic("struct_deep_free Expr missing children layout")
        }
        heap_drop_struct(children_fl.struct_name, ptr_add(data, children_fl.offset.cast(U64)), ctx)
        return
    }
    if struct_name == "Tuple" {
        // Free the packed heterogeneous element heap + the `own data: U8`
        // buffer BEFORE the field loop reclaims the type_names/type_sizes
        // metadata that walk reads. Both standalone owned Tuples and Tuples
        // nested in a container (reached via
        // container_elem_deep_free) funnel through here, so this is the single
        // Tuple teardown path -- the cache walk never runs Tuple.delete's
        // custom dyn_call body, and the type-erased U8 buffer is invisible to
        // a generic field walk.
        free_tuple_data(data, ctx)
    }
    ref sl : StructLayout = ctx.struct_layouts[struct_name]
    if sl.is_interface {
        ref owned_fl : FieldLayout = ctx_field_layout(struct_name, "iface_owned", ctx)
        ref owned : Bool = ptr_add(data, owned_fl.offset)
        if owned {
            ref type_fl : FieldLayout = ctx_field_layout(struct_name, "iface_type_name", ctx)
            ref type_name : Str = ptr_add(data, type_fl.offset)
            ref val_fl : FieldLayout = ctx_field_layout(struct_name, "iface_val", ctx)
            ref iface_val : Dynamic = deref(ptr_add(data, val_fl.offset))
            heap_drop_by_type(type_from_name_init(type_name, ctx.scope), iface_val, ctx)
            mut owned_iface_val : Dynamic = iface_val
            EvalHeap.heap_free(own owned_iface_val)
            write_ptr(ptr_add(data, val_fl.offset), NULL)
        }
    }
    for i in 0..sl.fields.len() {
        ref fl : FieldLayout = sl.fields[i]
        if fl.own_type.is(OwnType.Ref) { continue }
        foff := fl.offset
        if fl.is_funcptr {
            ref stored_callable : Dynamic = deref(ptr_add(data, foff))
            if stored_callable.is_null().not() { callable_storage_free(stored_callable) }
            continue
        }
        if fl.own_type.is(OwnType.Own) {
            if fl.is_enum {
                free_owned_enum_slot(ptr_add(data, foff), fl.struct_name, ctx)
                continue
            }
            if fl.struct_name.len().gt(0).and(fl.is_enum.not()) {
                ref own_hdr : DynPtrBox = ptr_add(data, foff)
                if own_hdr.p.is_null().not() {
                    heap_drop_struct(fl.struct_name, own_hdr.p, ctx)
                    EvalHeap.heap_free(own own_hdr.p)
                }
            }
            continue
        }
        if fl.is_str {
            ref s : Str = ptr_add(data, foff.cast(U64))
            if str_owns_c_str(ptr_add(data, foff.cast(U64)), ctx) {
                if s.c_str.is_null().not() { free(own s.c_str) }
            }
            continue
        }
        // Inline (shallow) enum field: the payload buffer lives in the
        // struct bytes and owns its nested heap (write_field deep-clones
        // it in); free any nested Str storage by tag. Skipping this
        // orphaned the payload once write_field stopped aliasing the
        // ctor temp's storage.
        if fl.is_enum {
            enum_payload_deep_free(fl.struct_name, ptr_add(data, foff), ctx)
            continue
        }
        if fl.struct_name.len().gt(0).and(fl.is_enum.not()) {
            heap_drop_struct(fl.struct_name, ptr_add(data, foff.cast(U64)), ctx)
        }
    }
    if struct_name == "DynVec" {
        free_dyn_vec_buffer(data, ctx)
    } else if struct_name == "DynArray" {
        free_dyn_array_buffer(data, ctx)
    } else if struct_name == "DynSet" {
        free_dyn_set_buffer(data, ctx)
    } else if container_elem_type(struct_name, ctx).len() > 0 {
        free_container_data(struct_name, data, ctx)
    }
}

priv free_container_data := func(struct_name: Str, data: Dynamic, ctx: Context) {
    elem_type := container_elem_type(struct_name, ctx)
    if elem_type.len() == 0 { panic("free_container_data: not a container: ", struct_name) }
    ref data_fl : FieldLayout = ctx_field_layout(struct_name, "data", ctx)
    ref hdr : DynPtrBox = ptr_add(data, data_fl.offset)
    if hdr.p.is_null() { return }
    n := container_live_count(struct_name, data, ctx)
    esz := container_elem_size(elem_type, ctx)
    for i in 0..n {
        container_elem_deep_free(elem_type, ptr_add(hdr.p, i.mul(esz)), ctx)
    }
    EvalHeap.heap_free(own hdr.p)
}

priv clone_container_buffer := func(struct_name: Str, src_data: Dynamic, dst_data: Dynamic, ctx: Context) {
    elem_type := container_elem_type(struct_name, ctx)
    if elem_type.len() == 0 { panic("clone_container_buffer: not a container: ", struct_name) }
    ref data_fl : FieldLayout = ctx_field_layout(struct_name, "data", ctx)
    ref src_hdr : DynPtrBox = ptr_add(src_data, data_fl.offset)
    if src_hdr.p.is_null() { return }
    cap := container_capacity(struct_name, src_data, ctx)
    esz := container_elem_size(elem_type, ctx)
    new_buf : Dynamic = EvalHeap.heap_alloc(cap.mul(esz))
    n := container_live_count(struct_name, src_data, ctx)
    for i in 0..n {
        elem_off := i.mul(esz)
        container_elem_clone_into(elem_type, ptr_add(new_buf, elem_off), ptr_add(src_hdr.p, elem_off), esz, ctx)
    }
    write_ptr(ptr_add(dst_data, data_fl.offset), new_buf)
}

priv dyn_vec_count := func(data: Dynamic, ctx: Context) returns USize {
    ref fl : FieldLayout = ctx_field_layout("DynVec", "count", ctx)
    ref n : USize = ptr_add(data, fl.offset)
    return n.clone()
}

priv dyn_vec_cap := func(data: Dynamic, ctx: Context) returns USize {
    ref fl : FieldLayout = ctx_field_layout("DynVec", "cap", ctx)
    ref n : USize = ptr_add(data, fl.offset)
    return n.clone()
}

priv dyn_vec_elem_size := func(data: Dynamic, ctx: Context) returns USize {
    ref fl : FieldLayout = ctx_field_layout("DynVec", "elem_size", ctx)
    ref n : USize = ptr_add(data, fl.offset)
    return n.clone()
}

priv dyn_vec_elem_kind := func(data: Dynamic, ctx: Context) returns USize {
    ref fl : FieldLayout = ctx_field_layout("DynVec", "elem_kind", ctx)
    ref n : USize = ptr_add(data, fl.offset)
    return n.clone()
}

priv erased_elem_delete_type := func(struct_name: Str, data: Dynamic, ctx: Context) returns Str {
    ref fl : FieldLayout = ctx_field_layout(struct_name, "elem_delete", ctx)
    ref stored : Dynamic = deref(ptr_add(data, fl.offset))
    delete_suffix := ".delete"
    for qn, nsv_hb in ctx.ns_fields.heap_bindings {
        ref nsv : Dynamic = to_ptr(nsv_hb.ptr)
        if qn.ends_with(delete_suffix).not() { continue }
        ref expected : Expr = callable_raw_func_def(nsv)
        mut matches := stored.ptr_eq(expected)
        if callable_box_is(stored) {
            ref stored_box : InterpCallableBox = to_ptr(stored)
            matches = stored_box.func_def.ptr_eq(expected)
        }
        if matches {
            return qn.substr(0, qn.count - delete_suffix.count)
        }
    }
    panic("erased elem_delete type not found for ", struct_name)
    return ""
}

priv free_dyn_vec_buffer := func(data: Dynamic, ctx: Context) {
    ref data_fl : FieldLayout = ctx_field_layout("DynVec", "data", ctx)
    ref hdr : DynPtrBox = ptr_add(data, data_fl.offset)
    if hdr.p.is_null() { return }
    count := dyn_vec_count(data, ctx)
    elem_size := dyn_vec_elem_size(data, ctx)
    elem_kind := dyn_vec_elem_kind(data, ctx)
    if elem_kind == ELEM_FN {
        for i in 0..count {
            ref stored : Dynamic = deref(ptr_add(hdr.p, i.mul(elem_size)))
            if stored.is_null().not() { callable_storage_free(stored) }
        }
    } else if elem_kind == ELEM_BOXED {
        elem_type := erased_elem_delete_type("DynVec", data, ctx)
        if elem_type.len() > 0 {
            for i in 0..count {
                container_elem_deep_free(elem_type, ptr_add(hdr.p, i.mul(elem_size)), ctx)
            }
        }
    }
    EvalHeap.heap_free(own hdr.p)
}

priv free_dyn_array_buffer := func(data: Dynamic, ctx: Context) {
    ref data_fl : FieldLayout = ctx_field_layout("DynArray", "data", ctx)
    ref hdr : DynPtrBox = ptr_add(data, data_fl.offset)
    if hdr.p.is_null() { return }
    ref cap_fl : FieldLayout = ctx_field_layout("DynArray", "cap", ctx)
    ref elem_size_fl : FieldLayout = ctx_field_layout("DynArray", "elem_size", ctx)
    ref cap : USize = ptr_add(data, cap_fl.offset)
    ref elem_size : USize = ptr_add(data, elem_size_fl.offset)
    elem_type := erased_elem_delete_type("DynArray", data, ctx)
    if elem_type.len() > 0 {
        for i in 0..cap {
            container_elem_deep_free(elem_type, ptr_add(hdr.p, i.mul(elem_size)), ctx)
        }
    }
    EvalHeap.heap_free(own hdr.p)
}

priv free_dyn_set_buffer := func(data: Dynamic, ctx: Context) {
    ref data_fl : FieldLayout = ctx_field_layout("DynSet", "data", ctx)
    ref hdr : DynPtrBox = ptr_add(data, data_fl.offset)
    if hdr.p.is_null() { return }
    ref count_fl : FieldLayout = ctx_field_layout("DynSet", "count", ctx)
    ref elem_size_fl : FieldLayout = ctx_field_layout("DynSet", "elem_size", ctx)
    ref count : USize = ptr_add(data, count_fl.offset)
    ref elem_size : USize = ptr_add(data, elem_size_fl.offset)
    elem_type := erased_elem_delete_type("DynSet", data, ctx)
    if elem_type.len() > 0 {
        for i in 0..count {
            container_elem_deep_free(elem_type, ptr_add(hdr.p, i.mul(elem_size)), ctx)
        }
    }
    EvalHeap.heap_free(own hdr.p)
