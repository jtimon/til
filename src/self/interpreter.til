mode lib

StructInstance := struct {
    ref mut struct_name : Str = NULL
    ref mut struct_def : Expr = NULL
    own mut data : U8 = 0
    mut borrowed := false
    namespace:
    eq := func(a: StructInstance, b: StructInstance) returns shallow Bool {
        return a.struct_name.eq(b.struct_name)
    }
    to_str := func(self: StructInstance) returns Str {
        if is_null(self.struct_name) { return "StructInstance" }
        return self.struct_name.clone()
    }
    clone := func(self: StructInstance) returns StructInstance {
        return clone_struct_instance(self)
    }
    delete := func(own self: StructInstance, call_free: Bool = true) {
        if call_free { free(own self) }
    }
}

EnumInstance := struct {
    ref mut enum_name : Str = NULL
    ref mut enum_def : Expr = NULL
    own mut data : U8 = 0
    mut data_size : I32 = 0
    namespace:
    eq := func(a: EnumInstance, b: EnumInstance) returns shallow Bool {
        return is_variant(a, b)
    }
    to_str := func(self: EnumInstance) returns Str {
        if is_null(self.enum_name) { return "EnumInstance" }
        return self.enum_name.clone()
    }
    clone := func(self: EnumInstance) returns EnumInstance {
        if is_null(self.data) {
            return EnumInstance(enum_name = self.enum_name,
                               enum_def = self.enum_def,
                               data = NULL,
                               data_size = self.data_size)
        }
        buf : Dynamic = malloc(self.data_size.to_i64().to_usize())
        memcpy(buf, self.data, self.data_size.to_i64().to_usize())
        return EnumInstance(enum_name = self.enum_name,
                           enum_def = self.enum_def,
                           data = buf,
                           data_size = self.data_size)
    }
    delete := func(own self: EnumInstance, call_free: Bool = true) {
        if call_free { free(own self) }
    }
}

Value := enum {
    None,
    Int: I64,
    Byte: U8,
    Short: I16,
    Int32: I32,
    Uint32: U32,
    Uint64: U64,
    Float: F32,
    Boolean: Bool,
    Func: Dynamic,
    Struct: StructInstance,
    Enum: EnumInstance,
    Ptr: Dynamic
    namespace:
    eq := func(a: Value, b: Value) returns Bool {
        if is_variant(a, Value.None).and(is_variant(b, Value.None)) { return true }
        if is_variant(a, Value.Int).and(is_variant(b, Value.Int)) {
            ref _ai : I64 = get_payload(a)
            ref _bi : I64 = get_payload(b)
            return _ai.eq(_bi)
        }
        if is_variant(a, Value.Boolean).and(is_variant(b, Value.Boolean)) {
            ref _ab : Bool = get_payload(a)
            ref _bb : Bool = get_payload(b)
            return _ab.eq(_bb)
        }
        return false
    }
    to_str := func(self: Value) returns Str {
        if is_variant(self, Value.None) { return "None" }
        if is_variant(self, Value.Int) {
            ref _si : I64 = get_payload(self)
            return _si.to_str()
        }
        if is_variant(self, Value.Boolean) {
            ref _sb : Bool = get_payload(self)
            return _sb.to_str()
        }
        return "Value"
    }
    clone := func(self: Value) returns Value {
        if is_variant(self, Value.Struct) {
            ref si : StructInstance = get_payload(self)
            return Value.Struct(si.clone())
        }
        if is_variant(self, Value.Enum) {
            ref ei : EnumInstance = get_payload(self)
            return Value.Enum(ei.clone())
        }
        if is_variant(self, Value.Int) {
            ref v : I64 = get_payload(self)
            return Value.Int(v)
        }
        if is_variant(self, Value.Byte) {
            ref v : U8 = get_payload(self)
            return Value.Byte(v)
        }
        if is_variant(self, Value.Short) {
            ref v : I16 = get_payload(self)
            return Value.Short(v)
        }
        if is_variant(self, Value.Int32) {
            ref v : I32 = get_payload(self)
            return Value.Int32(v)
        }
        if is_variant(self, Value.Uint32) {
            ref v : U32 = get_payload(self)
            return Value.Uint32(v)
        }
        if is_variant(self, Value.Uint64) {
            ref v : U64 = get_payload(self)
            return Value.Uint64(v)
        }
        if is_variant(self, Value.Float) {
            ref v : F32 = get_payload(self)
            return Value.Float(v)
        }
        if is_variant(self, Value.Boolean) {
            ref v : Bool = get_payload(self)
            return Value.Boolean(v)
        }
        if is_variant(self, Value.None) {
            return Value.None
        }
        // Func, Ptr: read void* payload via U64 reinterpret (both 8 bytes)
        ref payload : Dynamic = get_payload(self)
        ref raw : U64 = payload
        if is_variant(self, Value.Func) {
            return Value.Func(ptr_add(NULL, raw))
        }
        return Value.Ptr(ptr_add(NULL, raw))
    }
}

Cell := struct {
    mut val := Value.None
}

Binding := struct {
    ref mut name : Str = NULL
    ref mut cell : Cell = NULL
    mut cell_is_local := false
}

Scope := struct {
    mut bindings := Map.new("Str", Str.size(), "Binding", Binding.size())
    ref mut parent : Scope = NULL
}

// --- Return value mechanism ---
mut has_return := false
mut has_break := false
mut has_continue := false
mut return_value := Value.None

// --- Namespace fields (static struct fields) ---
mut ns_fields := Map.new("Str", Str.size(), "Value", Value.size())
mut ns_keys := Vec.new("Dynamic", Dynamic.size())

val_none := func() returns shallow Value {
    return Value.None
}
val_i64 := func(shallow v: I64) returns shallow Value {
    return Value.Int(v)
}
val_u8 := func(shallow v: I64) returns shallow Value {
    return Value.Byte(v.to_u8())
}
val_i16 := func(shallow v: I64) returns shallow Value {
    return Value.Short(v.to_i16())
}
val_i32 := func(shallow v: I64) returns shallow Value {
    return Value.Int32(v.to_i32())
}
val_u32 := func(shallow v: I64) returns shallow Value {
    return Value.Uint32(v.to_u32())
}
val_u64 := func(shallow v: U64) returns shallow Value {
    return Value.Uint64(v)
}
val_f32 := func(shallow v: F32) returns shallow Value {
    return Value.Float(v)
}
val_bool := func(shallow v: Bool) returns shallow Value {
    return Value.Boolean(v)
}

ENUM_PAYLOAD_OFFSET := 8.to_i32()

val_enum_flat := func(enum_name: Str, enum_def: Expr, shallow etag: I32, payload_data: Dynamic, shallow payload_size: I32) returns shallow Value {
    mut total := ENUM_PAYLOAD_OFFSET.add(payload_size)
    if total.lt(8.to_i32()) {
        total = 8.to_i32()
    }
    mut data : U8 = calloc(1, total.to_i64().to_u64())
    memcpy(data, etag, 4)
    if is_null(payload_data).not() {
        if payload_size.gt(0.to_i32()) {
            memcpy(ptr_add(data, ENUM_PAYLOAD_OFFSET.to_i64().to_u64()), payload_data, payload_size.to_i64().to_u64())
        }
    }
    return Value.Enum(EnumInstance(enum_name = enum_name, enum_def = enum_def, data = data, data_size = total))
}

val_enum_simple := func(enum_name: Str, shallow etag: I32) returns shallow Value {
    return val_enum_flat(enum_name, NULL, etag, NULL, 0.to_i32())
}

elem_size_for_type := func(type_name: Str) returns shallow I32 {
    if type_name.eq("I64") { return I64.size().to_i64().to_i32() }
    if type_name.eq("U8") { return U8.size().to_i64().to_i32() }
    if type_name.eq("I16") { return I16.size().to_i64().to_i32() }
    if type_name.eq("I32") { return I32.size().to_i64().to_i32() }
    if type_name.eq("U32") { return U32.size().to_i64().to_i32() }
    if type_name.eq("Bool") { return Bool.size().to_i64().to_i32() }
    if type_name.eq("Str") { return 24.to_i32() }
    return 8.to_i32()
}

eval_expr := ext_func(scope: Scope, e: Expr) returns shallow Value {}
eval_call := ext_func(scope: Scope, e: Expr) returns shallow Value {}
clone_struct_instance := ext_func(src: StructInstance) returns StructInstance {}
free_value := proc(shallow v: Value) {
    if is_variant(v, Value.Struct) {
        ref si : StructInstance = get_payload(v)
        if si.borrowed.not() {
            if is_null(si.data).not() { free(own si.data) }
        }
    }
    if is_variant(v, Value.Enum) {
        ref ei : EnumInstance = get_payload(v)
        if is_null(ei.data).not() { free(own ei.data) }
    }
}

needs_widen := func(val: Value, ptype: Str) returns shallow Bool {
    if is_null(ptype) { return false }
    if ptype.len().eq(0) { return false }
    if is_variant(val, Value.Byte) {
        return ptype.eq("U8").not()
    }
    if is_variant(val, Value.Short) {
        return ptype.eq("I16").not()
    }
    if is_variant(val, Value.Int32) {
        return ptype.eq("I32").not()
    }
    if is_variant(val, Value.Uint32) {
        return ptype.eq("U32").not()
    }
    return false
}

shallow_copy_value := func(v: Value) returns shallow Value {
    mut r := Value.None
    memcpy(r, v, Value.size())
    return r
}

widen_numeric := func(v: Value, ptype: Str) returns Value {
    if is_null(ptype) { return shallow_copy_value(v) }
    if ptype.len().eq(0) { return shallow_copy_value(v) }
    mut ival : I64 = 0
    mut uval : U64 = 0
    mut is_unsigned := false
    if is_variant(v, Value.Byte) {
        ref bv : U8 = get_payload(v)
        uval = bv.to_u64()
        is_unsigned = true
    } else if is_variant(v, Value.Short) {
        ref sv : I16 = get_payload(v)
        ival = sv.to_i64()
    } else if is_variant(v, Value.Int32) {
        ref iv : I32 = get_payload(v)
        ival = iv.to_i64()
    } else if is_variant(v, Value.Uint32) {
        ref uv : U32 = get_payload(v)
        uval = uv.to_u64()
        is_unsigned = true
    } else {
        return shallow_copy_value(v)
    }
    if is_unsigned.not() { uval = ival.to_u64() }
    else { ival = uval.to_i64() }
    if ptype.eq("I64") {
        if is_unsigned { return val_i64(uval.to_i64()) }
        return val_i64(ival)
    }
    if ptype.eq("U64") { return val_u64(uval) }
    if ptype.eq("USize") { return val_u32(uval.to_i64()) }
    if ptype.eq("U32") {
        if is_variant(v, Value.Byte) { return val_u32(uval.to_i64()) }
    }
    if ptype.eq("I32") {
        if is_variant(v, Value.Byte) { return val_i32(ival) }
        if is_variant(v, Value.Short) { return val_i32(ival) }
    }
    if ptype.eq("I16") {
        if is_variant(v, Value.Byte) { return val_i16(ival) }
    }
    return shallow_copy_value(v)
}

scope_get := func(s: Scope, name: Str) returns ref Cell {
    ref mut cur : Scope = s
    while true {
        if is_null(cur) { return NULL }
        if cur.bindings.has(name) {
            ref b : Binding = cur.bindings.get(name)
            return b.cell
        }
        cur = cur.parent
    }
    return NULL
}
scope_new := ext_func(parent: Scope) returns ref Scope {}
scope_set_owned := ext_proc(mut s: Scope, name: Str, val: Value) {}
scope_free := ext_proc(own s: Scope) {}
interp_fa_is_ns := ext_func(scope: Scope, e: Expr) returns shallow Bool {}

interpreter_init_ns := ext_proc(mut global: Scope, program: Expr) {}

ns_qname := func(sname: Str, fname: Str) returns Str {
    return sname.concat(".").concat(fname)
}

ns_get := func(sname: Str, fname: Str) returns ref Value {
    qn := ns_qname(sname, fname)
    if ns_fields.has(qn).not() { return NULL }
    ref v : Value = ns_fields.get(qn)
    return v
}

ns_set := proc(sname: Str, fname: Str, shallow val: Value) {
    qn := ns_qname(sname, fname)
    mut vcopy := val
    ns_fields.set(own qn, own vcopy)
}

make_str_value := ext_func(data: Dynamic, shallow len: U64) returns shallow Value {}
make_str_value_own := ext_func(data: Dynamic, shallow len: U64) returns shallow Value {}
str_view := ext_func(shallow v: Value) returns shallow Str {}

find_field_decl := func(struct_def: Expr, fname: Str) returns ref Expr {
    ref body : Expr = struct_def.child(0)
    for i in 0..body.child_count() {
        ref f : Expr = body.child(i)
        if f.data.is(NodeType.Decl) {
            ref dd : Declaration = get_payload(f.data)
            if dd.is_namespace.not() {
                if dd.name.eq(fname) {
                    return f
                }
            }
        }
    }
    return NULL
}
write_field := ext_proc(mut inst: StructInstance, fdecl: Expr, val: Value) {}
