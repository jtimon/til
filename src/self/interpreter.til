mode lib

StructInstance := struct {
    ref mut struct_name : Str = NULL
    ref mut struct_def : Expr = NULL
    own mut data : U8 = 0
    mut borrowed := false
    namespace:
    eq := func(a: StructInstance, b: StructInstance) returns shallow Bool {
        return a.struct_name.eq(b.struct_name)
    }
    to_str := func(self: StructInstance) returns Str {
        if is_null(self.struct_name) { return "StructInstance" }
        return self.struct_name.clone()
    }
    clone := func(self: StructInstance) returns StructInstance {
        return clone_struct_instance(self)
    }
    delete := func(own self: StructInstance, call_free: Bool = true) {
        if call_free { free(own self) }
    }
}

EnumInstance := struct {
    ref mut enum_name : Str = NULL
    ref mut enum_def : Expr = NULL
    own mut data : U8 = 0
    mut data_size : I32 = 0
    namespace:
    eq := func(a: EnumInstance, b: EnumInstance) returns shallow Bool {
        return is_variant(a, b)
    }
    to_str := func(self: EnumInstance) returns Str {
        if is_null(self.enum_name) { return "EnumInstance" }
        return self.enum_name.clone()
    }
    clone := func(self: EnumInstance) returns EnumInstance {
        if is_null(self.data) {
            return EnumInstance(enum_name = self.enum_name,
                               enum_def = self.enum_def,
                               data = NULL,
                               data_size = self.data_size)
        }
        buf : Dynamic = malloc(self.data_size.to_i64().to_usize())
        memcpy(buf, self.data, self.data_size.to_i64().to_usize())
        return EnumInstance(enum_name = self.enum_name,
                           enum_def = self.enum_def,
                           data = buf,
                           data_size = self.data_size)
    }
    delete := func(own self: EnumInstance, call_free: Bool = true) {
        if call_free { free(own self) }
    }
}

Value := enum {
    None,
    Int: I64,
    Byte: U8,
    Short: I16,
    Int32: I32,
    Uint32: U32,
    Uint64: U64,
    Float: F32,
    Boolean: Bool,
    Func: Dynamic,
    Struct: StructInstance,
    Enum: EnumInstance,
    Ptr: Dynamic
    namespace:
    eq := func(a: Value, b: Value) returns Bool {
        if is_variant(a, Value.None).and(is_variant(b, Value.None)) { return true }
        if is_variant(a, Value.Int).and(is_variant(b, Value.Int)) {
            ref _ai : I64 = get_payload(a)
            ref _bi : I64 = get_payload(b)
            return _ai.eq(_bi)
        }
        if is_variant(a, Value.Boolean).and(is_variant(b, Value.Boolean)) {
            ref _ab : Bool = get_payload(a)
            ref _bb : Bool = get_payload(b)
            return _ab.eq(_bb)
        }
        return false
    }
    to_str := func(self: Value) returns Str {
        if is_variant(self, Value.None) { return "None" }
        if is_variant(self, Value.Int) {
            ref _si : I64 = get_payload(self)
            return _si.to_str()
        }
        if is_variant(self, Value.Boolean) {
            ref _sb : Bool = get_payload(self)
            return _sb.to_str()
        }
        return "Value"
    }
    clone := func(self: Value) returns Value {
        if is_variant(self, Value.Struct) {
            ref si : StructInstance = get_payload(self)
            return Value.Struct(si.clone())
        }
        if is_variant(self, Value.Enum) {
            ref ei : EnumInstance = get_payload(self)
            return Value.Enum(ei.clone())
        }
        if is_variant(self, Value.Int) {
            ref v : I64 = get_payload(self)
            return Value.Int(v)
        }
        if is_variant(self, Value.Byte) {
            ref v : U8 = get_payload(self)
            return Value.Byte(v)
        }
        if is_variant(self, Value.Short) {
            ref v : I16 = get_payload(self)
            return Value.Short(v)
        }
        if is_variant(self, Value.Int32) {
            ref v : I32 = get_payload(self)
            return Value.Int32(v)
        }
        if is_variant(self, Value.Uint32) {
            ref v : U32 = get_payload(self)
            return Value.Uint32(v)
        }
        if is_variant(self, Value.Uint64) {
            ref v : U64 = get_payload(self)
            return Value.Uint64(v)
        }
        if is_variant(self, Value.Float) {
            ref v : F32 = get_payload(self)
            return Value.Float(v)
        }
        if is_variant(self, Value.Boolean) {
            ref v : Bool = get_payload(self)
            return Value.Boolean(v)
        }
        if is_variant(self, Value.None) {
            return Value.None
        }
        // Func, Ptr: read void* payload via U64 reinterpret (both 8 bytes)
        ref payload : Dynamic = get_payload(self)
        ref raw : U64 = payload
        if is_variant(self, Value.Func) {
            return Value.Func(ptr_add(NULL, raw))
        }
        return Value.Ptr(ptr_add(NULL, raw))
    }
}

Cell := struct {
    mut val := Value.None
}

Binding := struct {
    ref mut name : Str = NULL
    ref mut cell : Cell = NULL
    mut cell_is_local := false
}

Scope := struct {
    mut bindings := Map.new("Str", Str.size(), "Binding", Binding.size())
    ref mut parent : Scope = NULL
}

// --- Return value mechanism ---
mut has_return := false
mut has_break := false
mut has_continue := false
mut return_value := Value.None

// --- Cached struct defs for C-side construction ---
ref mut cached_str_def : Expr = NULL
ref mut cached_str_name : Str = NULL
ref mut cached_array_def : Expr = NULL
ref mut cached_array_name : Str = NULL
ref mut cached_vec_def : Expr = NULL
ref mut cached_vec_name : Str = NULL

// --- Namespace fields (static struct fields) ---
mut ns_fields := Map.new("Str", Str.size(), "Value", Value.size())
mut ns_keys := Vec.new("Dynamic", Dynamic.size())

val_none := func() returns shallow Value {
    return Value.None
}
val_i64 := func(shallow v: I64) returns shallow Value {
    return Value.Int(v)
}
val_u8 := func(shallow v: I64) returns shallow Value {
    return Value.Byte(v.to_u8())
}
val_i16 := func(shallow v: I64) returns shallow Value {
    return Value.Short(v.to_i16())
}
val_i32 := func(shallow v: I64) returns shallow Value {
    return Value.Int32(v.to_i32())
}
val_u32 := func(shallow v: I64) returns shallow Value {
    return Value.Uint32(v.to_u32())
}
val_u64 := func(shallow v: U64) returns shallow Value {
    return Value.Uint64(v)
}
val_f32 := func(shallow v: F32) returns shallow Value {
    return Value.Float(v)
}
val_bool := func(shallow v: Bool) returns shallow Value {
    return Value.Boolean(v)
}

ENUM_PAYLOAD_OFFSET := 8.to_i32()

val_enum_flat := func(enum_name: Str, enum_def: Expr, shallow etag: I32, payload_data: Dynamic, shallow payload_size: I32) returns shallow Value {
    mut total := ENUM_PAYLOAD_OFFSET.add(payload_size)
    if total.lt(8.to_i32()) {
        total = 8.to_i32()
    }
    mut data : U8 = calloc(1, total.to_i64().to_u64())
    memcpy(data, etag, 4)
    if is_null(payload_data).not() {
        if payload_size.gt(0.to_i32()) {
            memcpy(ptr_add(data, ENUM_PAYLOAD_OFFSET.to_i64().to_u64()), payload_data, payload_size.to_i64().to_u64())
        }
    }
    return Value.Enum(EnumInstance(enum_name = enum_name, enum_def = enum_def, data = data, data_size = total))
}

val_enum_simple := func(enum_name: Str, shallow etag: I32) returns shallow Value {
    return val_enum_flat(enum_name, NULL, etag, NULL, 0.to_i32())
}

elem_size_for_type := func(type_name: Str) returns shallow I32 {
    if type_name.eq("I64") { return I64.size().to_i64().to_i32() }
    if type_name.eq("U8") { return U8.size().to_i64().to_i32() }
    if type_name.eq("I16") { return I16.size().to_i64().to_i32() }
    if type_name.eq("I32") { return I32.size().to_i64().to_i32() }
    if type_name.eq("U32") { return U32.size().to_i64().to_i32() }
    if type_name.eq("Bool") { return Bool.size().to_i64().to_i32() }
    if type_name.eq("Str") { return 24.to_i32() }
    return 8.to_i32()
}

eval_expr := ext_func(scope: Scope, e: Expr) returns shallow Value {}
eval_call := ext_func(scope: Scope, e: Expr) returns shallow Value {}
clone_struct_instance := ext_func(src: StructInstance) returns StructInstance {}
free_value := proc(shallow v: Value) {
    if is_variant(v, Value.Struct) {
        ref si : StructInstance = get_payload(v)
        if si.borrowed.not() {
            if is_null(si.data).not() { free(own si.data) }
        }
    }
    if is_variant(v, Value.Enum) {
        ref ei : EnumInstance = get_payload(v)
        if is_null(ei.data).not() { free(own ei.data) }
    }
}

needs_widen := func(val: Value, ptype: Str) returns shallow Bool {
    if is_null(ptype) { return false }
    if ptype.len().eq(0) { return false }
    if is_variant(val, Value.Byte) {
        return ptype.eq("U8").not()
    }
    if is_variant(val, Value.Short) {
        return ptype.eq("I16").not()
    }
    if is_variant(val, Value.Int32) {
        return ptype.eq("I32").not()
    }
    if is_variant(val, Value.Uint32) {
        return ptype.eq("U32").not()
    }
    return false
}

shallow_copy_value := func(v: Value) returns shallow Value {
    mut r := Value.None
    memcpy(r, v, Value.size())
    return r
}

make_struct_value := func(sname: Str, sdef: Expr, data: Dynamic, shallow borrowed: Bool) returns shallow Value {
    // Build Value.Struct in place without triggering clone/destructor
    // Value layout: tag (I32, 4b) + padding (4b) + StructInstance payload
    mut r := Value.None
    // Set tag to Value_TAG_Struct
    mut tag : I32 = 10.to_i32()
    memcpy(r, tag, 4)
    // StructInstance at offset 8: struct_name (8b) + struct_def (8b) + data (8b) + borrowed (1b)
    ref payload : Dynamic = get_payload(r)
    write_ptr(payload, sname)
    write_ptr(ptr_add(payload, 8), sdef)
    write_ptr(ptr_add(payload, 16), data)
    ref mut bflag : Bool = ptr_add(payload, 24)
    bflag = borrowed
    return shallow_copy_value(r)
}

widen_numeric := func(v: Value, ptype: Str) returns Value {
    if is_null(ptype) { return shallow_copy_value(v) }
    if ptype.len().eq(0) { return shallow_copy_value(v) }
    mut ival : I64 = 0
    mut uval : U64 = 0
    mut is_unsigned := false
    if is_variant(v, Value.Byte) {
        ref bv : U8 = get_payload(v)
        uval = bv.to_u64()
        is_unsigned = true
    } else if is_variant(v, Value.Short) {
        ref sv : I16 = get_payload(v)
        ival = sv.to_i64()
    } else if is_variant(v, Value.Int32) {
        ref iv : I32 = get_payload(v)
        ival = iv.to_i64()
    } else if is_variant(v, Value.Uint32) {
        ref uv : U32 = get_payload(v)
        uval = uv.to_u64()
        is_unsigned = true
    } else {
        return shallow_copy_value(v)
    }
    if is_unsigned.not() { uval = ival.to_u64() }
    else { ival = uval.to_i64() }
    if ptype.eq("I64") {
        if is_unsigned { return val_i64(uval.to_i64()) }
        return val_i64(ival)
    }
    if ptype.eq("U64") { return val_u64(uval) }
    if ptype.eq("USize") { return val_u32(uval.to_i64()) }
    if ptype.eq("U32") {
        if is_variant(v, Value.Byte) { return val_u32(uval.to_i64()) }
    }
    if ptype.eq("I32") {
        if is_variant(v, Value.Byte) { return val_i32(ival) }
        if is_variant(v, Value.Short) { return val_i32(ival) }
    }
    if ptype.eq("I16") {
        if is_variant(v, Value.Byte) { return val_i16(ival) }
    }
    return shallow_copy_value(v)
}

scope_get := func(s: Scope, name: Str) returns ref Cell {
    ref mut cur : Scope = s
    while true {
        if is_null(cur) { return NULL }
        if cur.bindings.has(name) {
            ref b : Binding = cur.bindings.get(name)
            return b.cell
        }
        cur = cur.parent
    }
    return NULL
}
scope_new := func(parent: Scope) returns ref Scope {
    s : Dynamic = malloc(Scope.size().to_u64())
    memset(s, 0, Scope.size().to_u64())
    mut bindings := Map.new("Str", Str.size(), "Binding", Binding.size())
    memcpy(s, bindings, Map.size().to_u64())
    memset(bindings, 0, Map.size().to_u64())
    write_ptr(ptr_add(s, Map.size().to_u64()), parent)
    ref result : Scope = ptr_add(s, 0)
    return result
}
scope_set_owned := ext_proc(mut s: Scope, name: Str, val: Value) {}
scope_free := ext_proc(own s: Scope) {}
interp_fa_is_ns_inner := func(scope: Scope, e: Expr, sname: Str) returns shallow Bool {
    ref obj_expr : Expr = e.child(0)
    ref tc : Cell = scope_get(scope, sname)
    if is_null(tc) { return false }
    if is_variant(tc.val, Value.Func).not() { return false }
    ref fptr : Dynamic = get_payload(tc.val)
    ref sdef : Expr = read_ptr(fptr)
    if is_variant(sdef.data, NodeType.StructDef).not() {
        if is_variant(sdef.data, NodeType.EnumDef).not() { return false }
    }
    ref mut fname : Str = get_payload(e.data)
    ref body : Expr = sdef.child(0)
    mut has_ns := false
    mut has_inst := false
    for i in 0..body.child_count() {
        ref f : Expr = body.child(i)
        ref dd : Declaration = get_payload(f.data)
        if dd.name.eq(fname) {
            if dd.is_namespace { has_ns = true }
            else { has_inst = true }
        }
    }
    if has_ns {
        if has_inst.not() { return true }
    }
    if has_ns.not() {
        if has_inst.not() {
            if is_variant(obj_expr.data, NodeType.Ident) {
                ref ident : Str = get_payload(obj_expr.data)
                if ident.eq(sname) { return true }
                if ident.len().gt(0) {
                    if ident.byte_at(0).gte(65) {
                        if ident.byte_at(0).lte(90) { return true }
                    }
                }
            }
            return false
        }
    }
    if has_ns {
        if has_inst {
            if is_variant(obj_expr.data, NodeType.Ident).not() { return false }
            ref ident : Str = get_payload(obj_expr.data)
            if ident.eq(sname) { return true }
            if ident.len().gt(0) {
                if ident.byte_at(0).gte(65) {
                    if ident.byte_at(0).lte(90) { return true }
                }
            }
        }
    }
    return false
}

interp_fa_is_ns := func(scope: Scope, e: Expr) returns shallow Bool {
    ref obj_expr : Expr = e.child(0)
    ref sname : Str = obj_expr.struct_name
    if sname.len().gt(0) { return interp_fa_is_ns_inner(scope, e, sname) }
    if is_variant(obj_expr.data, NodeType.Ident) {
        ref ident : Str = get_payload(obj_expr.data)
        return interp_fa_is_ns_inner(scope, e, ident)
    }
    return false
}

interpreter_init_ns := ext_proc(mut global: Scope, program: Expr) {}

ns_qname := func(sname: Str, fname: Str) returns Str {
    return sname.concat(".").concat(fname)
}

ns_get := func(sname: Str, fname: Str) returns ref Value {
    qn := ns_qname(sname, fname)
    if ns_fields.has(qn).not() { return NULL }
    ref v : Value = ns_fields.get(qn)
    return v
}

ns_set := proc(sname: Str, fname: Str, shallow val: Value) {
    qn := ns_qname(sname, fname)
    mut vcopy := val
    ns_fields.set(own qn, own vcopy)
}

make_str_value := func(data: Dynamic, shallow len: U64) returns shallow Value {
    inst_data : Dynamic = malloc(Str.size())
    copy : Dynamic = malloc(len.add(1))
    memcpy(copy, data, len)
    memset(ptr_add(copy, len), 0, 1)
    write_ptr(inst_data, copy)
    ref mut count_slot : U32 = ptr_add(inst_data, 8)
    count_slot = len.to_i64().to_i32().to_u32()
    memcpy(ptr_add(inst_data, 12), CAP_LIT, U32.size().to_u64())
    return make_struct_value(cached_str_name, cached_str_def, inst_data, false)
}

make_str_value_own := func(data: Dynamic, shallow len: U64) returns shallow Value {
    inst_data : Dynamic = malloc(Str.size())
    write_ptr(inst_data, data)
    ref mut count_slot : U32 = ptr_add(inst_data, 8)
    count_slot = len.to_i64().to_i32().to_u32()
    memcpy(ptr_add(inst_data, 12), count_slot, U32.size().to_u64())
    return make_struct_value(cached_str_name, cached_str_def, inst_data, false)
}
str_view := func(shallow v: Value) returns shallow Str {
    ref si : StructInstance = get_payload(v)
    // Str layout in si.data: c_str (8b), count (8b), cap (8b)
    // Copy it out, then override cap with CAP_VIEW
    mut result := ""
    memcpy(result, si.data, Str.size())
    result.cap = CAP_VIEW
    return result
}

find_field_decl := func(struct_def: Expr, fname: Str) returns ref Expr {
    ref body : Expr = struct_def.child(0)
    for i in 0..body.child_count() {
        ref f : Expr = body.child(i)
        if f.data.is(NodeType.Decl) {
            ref dd : Declaration = get_payload(f.data)
            if dd.is_namespace.not() {
                if dd.name.eq(fname) {
                    return f
                }
            }
        }
    }
    return NULL
}

ENUM_PAYLOAD_OFFSET : I32 = 8

read_field := func(inst: StructInstance, fdecl: Expr) returns shallow Value {
    ref dd : Declaration = get_payload(fdecl.data)
    ref ftype : Str = dd.explicit_type
    ref ptr : Dynamic = ptr_add(inst.data, dd.field_offset.to_i64().to_u64())
    if is_variant(dd.own_type, OwnType.Own) {
        if is_null(dd.field_struct_def).not() {
            ref owned : Dynamic = read_ptr(ptr)
            return make_struct_value(ftype, dd.field_struct_def, owned, true)
        }
        ref owned2 : Dynamic = read_ptr(ptr)
        return Value.Ptr(owned2)
    }
    if is_variant(dd.own_type, OwnType.Ref) {
        if is_null(read_ptr(ptr)) { return Value.Ptr(NULL) }
        if is_null(dd.field_struct_def).not() {
            ref rp : Dynamic = read_ptr(ptr)
            return make_struct_value(ftype, dd.field_struct_def, rp, true)
        }
        ref rp2 : Dynamic = read_ptr(ptr)
        return Value.Ptr(rp2)
    }
    if ftype.eq("I64") { ref v : I64 = ptr; return val_i64(v) }
    if ftype.eq("U8") { ref v : U8 = ptr; return val_u8(v.to_i64()) }
    if ftype.eq("I16") { ref v : I16 = ptr; return val_i16(v.to_i64()) }
    if ftype.eq("I32") { ref v : I32 = ptr; return val_i32(v.to_i64()) }
    if ftype.eq("U32") { ref v : U32 = ptr; return val_u32(v.to_i64()) }
    if ftype.eq("U64") { ref v : U64 = ptr; return val_u64(v) }
    if ftype.eq("USize") { ref v : U32 = ptr; return val_u32(v.to_i64()) }
    if ftype.eq("F32") { ref v : F32 = ptr; return val_f32(v) }
    if ftype.eq("Bool") { ref v : Bool = ptr; return val_bool(v) }
    // Enum field
    if is_null(dd.field_struct_def).not() {
        if is_variant(dd.field_struct_def.data, NodeType.EnumDef) {
            ref edef : Expr = dd.field_struct_def
            if enum_has_payloads(edef) {
                ref ei : EnumInstance = read_ptr(ptr)
                if is_null(ei) { return val_enum_simple(ftype, 0.to_i32()) }
                ref etag_ref : Dynamic = ei.data
                ref etag : I32 = etag_ref
                psz := ei.data_size.sub(ENUM_PAYLOAD_OFFSET)
                mut psz_final := psz
                if psz.to_i64().lt(0) { psz_final = 0.to_i32() }
                return val_enum_flat(ei.enum_name, edef, etag, ptr_add(ei.data, ENUM_PAYLOAD_OFFSET.to_i64().to_u64()), psz_final)
            }
            ref itag : I32 = ptr
            return val_i32(itag.to_i64())
        }
    }
    // Inline struct
    if is_null(dd.field_struct_def).not() {
        return make_struct_value(ftype, dd.field_struct_def, ptr, true)
    }
    // FuncSig-typed field or fallback -- re-read ptr since ownership may have transferred
    ref ptr2 : Dynamic = ptr_add(inst.data, dd.field_offset.to_i64().to_u64())
    if ftype.len().gt(0) {
        ref stored : Dynamic = read_ptr(ptr2)
        if is_null(stored).not() { return Value.Func(stored) }
    }
    // Fallback
    ref ptr3 : Dynamic = ptr_add(inst.data, dd.field_offset.to_i64().to_u64())
    ref fi : I64 = ptr3
    return val_i64(fi)
}

write_field := proc(mut inst: StructInstance, fdecl: Expr, val: Value) {
    ref dd : Declaration = get_payload(fdecl.data)
    ref ptr : Dynamic = ptr_add(inst.data, dd.field_offset.to_i64().to_u64())
    fsz := dd.field_size
    if is_variant(dd.own_type, OwnType.Own) {
        if is_variant(val, Value.Struct) {
            ref si : StructInstance = get_payload(val)
            write_ptr(ptr, si.data)
        } else {
            ref pv : Dynamic = get_payload(val)
            write_ptr(ptr, read_ptr(pv))
        }
        return
    }
    if is_variant(dd.own_type, OwnType.Ref) {
        if is_variant(val, Value.Ptr) {
            ref pv : Dynamic = get_payload(val)
            write_ptr(ptr, read_ptr(pv))
        } else if is_variant(val, Value.Struct) {
            ref si : StructInstance = get_payload(val)
            write_ptr(ptr, si.data)
        } else {
            write_ptr(ptr, NULL)
        }
        return
    }
    if is_variant(val, Value.Int) { ref v : I64 = get_payload(val); memcpy(ptr, v, I64.size().to_u64()); return }
    if is_variant(val, Value.Byte) { ref v : U8 = get_payload(val); memcpy(ptr, v, U8.size().to_u64()); return }
    if is_variant(val, Value.Short) { ref v : I16 = get_payload(val); memcpy(ptr, v, I16.size().to_u64()); return }
    if is_variant(val, Value.Int32) { ref v : I32 = get_payload(val); memcpy(ptr, v, I32.size().to_u64()); return }
    if is_variant(val, Value.Uint32) { ref v : U32 = get_payload(val); memcpy(ptr, v, U32.size().to_u64()); return }
    if is_variant(val, Value.Uint64) { ref v : U64 = get_payload(val); memcpy(ptr, v, U64.size().to_u64()); return }
    if is_variant(val, Value.Float) { ref v : F32 = get_payload(val); memcpy(ptr, v, F32.size().to_u64()); return }
    if is_variant(val, Value.Boolean) { ref v : Bool = get_payload(val); memcpy(ptr, v, Bool.size().to_u64()); return }
    if is_variant(val, Value.Struct) {
        ref si : StructInstance = get_payload(val)
        if si.borrowed {
            mut cloned := val.clone()
            ref mut csi : StructInstance = get_payload(cloned)
            memcpy(ptr, csi.data, fsz.to_i64().to_u64())
            free(own csi.data)
            csi.data = NULL
        } else {
            memcpy(ptr, si.data, fsz.to_i64().to_u64())
        }
        return
    }
    if is_variant(val, Value.Enum) {
        ref ei : EnumInstance = get_payload(val)
        mut total := ei.data_size
        if total.to_i64().lt(8) { total = 8.to_i32() }
        heap_ei : Dynamic = malloc(EnumInstance.size().to_u64())
        memcpy(heap_ei, ei, EnumInstance.size().to_u64())
        // Deep-copy the data buffer
        new_data : Dynamic = malloc(total.to_i64().to_u64())
        memcpy(new_data, ei.data, total.to_i64().to_u64())
        // Write data pointer into the heap EnumInstance
        write_ptr(ptr_add(heap_ei, 16), new_data)
        write_ptr(ptr, heap_ei)
        return
    }
    if is_variant(val, Value.Ptr) { ref pv : Dynamic = get_payload(val); write_ptr(ptr, read_ptr(pv)); return }
    if is_variant(val, Value.Func) { ref fv : Dynamic = get_payload(val); write_ptr(ptr, read_ptr(fv)); return }
}
