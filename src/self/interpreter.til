        if idx >= fd.params.len() {
            interp_error(e, "func_sig_param_type: index out of bounds", ctx)
            exit(1)
        }
        ref pd : Declaration = fd.params[idx]
        r = str_to_owned_value(pd.explicit_type, ctx)
    case:
