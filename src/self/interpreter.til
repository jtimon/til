    switch node.node_type {
    case NodeType.FuncDef(fd):
        r = Value.Int(fd.params.len().to_i64())
    case:
        UNREACHABLE()
    }
    return true
}

priv h_func_sig_param_type := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    idx := eval_index_arg(s, e, ctx)
    ref node : Expr = interp_lookup_funcsig(s, e, type_name, "func_sig_param_type", ctx)
    switch node.node_type {
    case NodeType.FuncDef(fd):
        if idx.gte(fd.params.len()) {
            interp_error(e, "func_sig_param_type: index out of bounds", ctx)
            exit(1)
        }
        ref pd : Declaration = fd.params[idx]
        r = str_to_owned_value(pd.explicit_type, ctx)
    case:
