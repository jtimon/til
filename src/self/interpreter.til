priv DispatchFn := proc(Scope, Expr, mut Value, Context) returns Bool

priv reg_dispatch := func(name: Str, handler: DispatchFn, ctx: Context) {
    v : Dynamic = malloc(8)
    write_ptr(v, handler)
    ctx.dispatch_map.set(name, own v)
}

priv dispatch_init := func(ctx: Context) {
    ctx.dispatch_map = Map(Str, Dynamic).new()
    reg_dispatch("print_single", h_print_single, ctx)
    reg_dispatch("print_flush", h_print_flush, ctx)
    reg_dispatch("and", h_Bool_and, ctx)
    reg_dispatch("or", h_Bool_or, ctx)
    reg_dispatch("not", h_Bool_not, ctx)
    reg_dispatch("U8_from_i64", h_U8_from_i64, ctx)
    reg_dispatch("U8_from_i64_ext", h_U8_from_i64, ctx)
    reg_dispatch("I16_from_i64", h_I16_from_i64, ctx)
    reg_dispatch("I16_from_i64_ext", h_I16_from_i64, ctx)
    reg_dispatch("U16_from_i64", h_U16_from_i64, ctx)
    reg_dispatch("U16_from_i64_ext", h_U16_from_i64, ctx)
    reg_dispatch("I32_from_i64", h_I32_from_i64, ctx)
    reg_dispatch("I32_from_i64_ext", h_I32_from_i64, ctx)
    reg_dispatch("F32_from_i64", h_F32_from_i64, ctx)
    reg_dispatch("F32_from_i64_ext", h_F32_from_i64, ctx)
    reg_dispatch("U32_from_i64", h_U32_from_i64, ctx)
    reg_dispatch("U32_from_i64_ext", h_U32_from_i64, ctx)
    reg_dispatch("cast", h_cast, ctx)
    reg_dispatch("exit", h_exit, ctx)
    reg_dispatch("free", h_free, ctx)
    reg_dispatch("til_closure_delete", h_til_closure_delete, ctx)
    reg_dispatch("til_closure_slot_delete", h_til_closure_slot_delete, ctx)
    reg_dispatch("ptr_add", h_ptr_add, ctx)
    reg_dispatch("dyn_call", h_dyn_call, ctx)
    reg_dispatch("dyn_call_ret", h_dyn_call, ctx)
    reg_dispatch("dyn_has_method", h_dyn_has_method, ctx)
    reg_dispatch("dyn_fn", h_dyn_fn, ctx)
    reg_dispatch("dyn_size_of", h_dyn_size_of, ctx)
    reg_dispatch("struct_field_count", h_struct_field_count, ctx)
    reg_dispatch("struct_field_name", h_struct_field_name, ctx)
    reg_dispatch("struct_field_is_mut", h_struct_field_is_mut, ctx)
    reg_dispatch("struct_field_type", h_struct_field_type, ctx)
    reg_dispatch("enum_variant_count", h_enum_variant_count, ctx)
    reg_dispatch("enum_variant_name", h_enum_variant_name, ctx)
    reg_dispatch("enum_variant_has_payload", h_enum_variant_has_payload, ctx)
    reg_dispatch("enum_variant_payload_type", h_enum_variant_payload_type, ctx)
    reg_dispatch("func_sig_param_count", h_func_sig_param_count, ctx)
    reg_dispatch("func_sig_param_type", h_func_sig_param_type, ctx)
    reg_dispatch("func_sig_return_count", h_func_sig_return_count, ctx)
    reg_dispatch("func_sig_return_type", h_func_sig_return_type, ctx)
    reg_dispatch("func_sig_throw_count", h_func_sig_throw_count, ctx)
    reg_dispatch("func_sig_throw_type", h_func_sig_throw_type, ctx)
    reg_dispatch("dyn_type_to_str", h_dyn_type_to_str, ctx)
    reg_dispatch("File_readfile", h_readfile, ctx)
    reg_dispatch("File_writefile", h_writefile, ctx)
    reg_dispatch("spawn_cmd", h_spawn_cmd, ctx)
    reg_dispatch("check_cmd_status", h_check_cmd_status, ctx)
    reg_dispatch("sleep", h_sleep, ctx)
    reg_dispatch("file_mtime", h_file_mtime, ctx)
    reg_dispatch("str_parse_f32", h_str_parse_f32, ctx)
    reg_dispatch("clock_ms", h_clock_ms, ctx)
    reg_dispatch("get_thread_count", h_get_thread_count, ctx)
    reg_dispatch("cfile_open", h_cfile_open, ctx)
    reg_dispatch("cfile_open_update", h_cfile_open_update, ctx)
    reg_dispatch("cfile_close", h_cfile_close, ctx)
    reg_dispatch("cfile_write_str", h_cfile_write_str, ctx)
    reg_dispatch("cfile_read_all", h_cfile_read_all, ctx)
    reg_dispatch("cfile_tell", h_cfile_tell, ctx)
    reg_dispatch("cfile_seek", h_cfile_seek, ctx)
    reg_dispatch("cfile_seek_cur", h_cfile_seek_cur, ctx)
    reg_dispatch("cfile_seek_end", h_cfile_seek_end, ctx)
    reg_dispatch("cfile_read_n", h_cfile_read_n, ctx)
    ctx.dispatch_inited = true
}

priv ext_dispatch_builtin := func(name: Str, scope: Scope, e: Expr, mut result: Value, ctx: Context) returns Bool {
    ref dm : Map(Str, Dynamic) = ctx.dispatch_map
    if dm.has(name) {
        ref slot : Dynamic = dm[name]
        ref fp : DispatchFn = to_ptr(slot)
        return fp(scope, e, result, ctx)
    }
    return false
}

priv h_dyn_call := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    method := eval_str_owned(s, e.children[2], ctx)

    // Build fake AST: Type.method(args...)
    mut type_ident := Expr.new(ident_node(type_name), e.line, e.col)
    type_ident.set_expr_til_type(Type.Struct(type_name.clone()))

    mut field_access := Expr.new(field_access_node(method), e.line, e.col)
    field_access.add_child(own type_ident)
    // Critical: NodeType.FCall must have an initialized FCallData payload.
    mut fake_call := Expr.new(NodeType.FCall(FCallData()), e.line, e.col)
    fake_call.add_child(own field_access)

    // child 3 is arity literal, actual args start at child 4
    ref arity_expr : Expr = e.children[3]
    mut nargs : U32 = 0
    switch arity_expr.node_type {
    case NodeType.Literal(Literal.Num(arity_str)): nargs = arity_str.literal_num_text().to_u32()
    case:
        UNREACHABLE()
    }
    for ai in 0..nargs {
        fake_call.push_child_clone(e.children[ai + 4])
    }

    r = eval_call(s, fake_call, ctx)
    return true
}

priv get_elem_size := proc(s: Scope, type_name: Str, src: Expr, ctx: Context) returns USize {
    ref size_fn : Value = ns_get(type_name, "size", ctx)
    if size_fn.is_null() {
        interp_error(src, format(type_name, " has no size() method"), ctx)
        exit(1)
    }
    // Build fake call: Type.size()
    mut type_ident := Expr.new(ident_node(type_name), src.line, src.col)
    type_ident.set_expr_til_type(Type.Struct(type_name.clone()))

    mut field_access := Expr.new(field_access_node("size"), src.line, src.col)
    field_access.add_child(own type_ident)

    // Critical: NodeType.FCall must have an initialized FCallData payload.
    mut fake_call := Expr.new(NodeType.FCall(FCallData()), src.line, src.col)
    fake_call.add_child(own field_access)

    result := eval_call(s, fake_call, ctx)
    return value_to_u64(result).to_u32()
}

priv enum_method_dispatch := proc(method: Str, scope: Scope, enum_def: Expr, enum_name: Str, e: Expr, mut result: Value, ctx: Context) returns Bool {
    if enum_has_payloads(enum_def) {
        ctor_tag := enum_variant_tag(enum_def, method)
        // Payload lookup is index-keyed; construction (val_enum_flat below)
        // needs the tag VALUE -- keep both distinct.
        ctor_idx := enum_variant_index(enum_def, method)
        if ctor_tag >= 0 {
            vtype := enum_variant_type(enum_def, ctor_idx)
            has_payload := vtype.len() > 0
            if has_payload {
                mut payload := eval_expr(scope, e.children[1], ctx)
                mut pdata : Dynamic = 0
                mut psz : USize = 0
                mut must_free_pdata := false
                switch payload {
                case Value.Int(x):     pdata = to_ptr(x); psz = 8
                case Value.Byte(x):    pdata = to_ptr(x); psz = 1
                case Value.Sbyte(x):   pdata = to_ptr(x); psz = 1
                case Value.Short(x):   pdata = to_ptr(x); psz = 2
                case Value.Ushort(x):  pdata = to_ptr(x); psz = 2
                case Value.Int32(x):   pdata = to_ptr(x); psz = 4
                case Value.Uint32(x):  pdata = to_ptr(x); psz = 4
                case Value.Uint64(x):  pdata = to_ptr(x); psz = 8
                case Value.Float(x):   pdata = to_ptr(x); psz = 4
                case Value.Boolean(x): pdata = to_ptr(x); psz = 1
                case Value.Struct(si):
                    if lookup_interp_type_def(si.struct_name(), si.ctx).is_null().not() {
                        switch lookup_interp_type_def(si.struct_name(), si.ctx).node_type {
                        case NodeType.StructDef:
                            psz = ctx_total_size(si.struct_name(), si.ctx)
                        case:
                        }
                    }
                    pdata = to_ptr(si.data)
                    // Issue #109: val_enum_flat memcpy-copies psz bytes out
                    // of si.data into the enum's own buffer (any nested heap
                    // pointers, e.g. a Str payload's c_str, are shared into
                    // the enum and outlive this free). The payload Value is a
                    // temporary from eval_expr that nothing else frees, so we
                    // free its buffer below. Skip borrowed payloads -- their
                    // data belongs to a live variable.
                    if si.borrowed.not() {
                        must_free_pdata = true
                        // Hand off to the manual free below: mark borrowed so
                        // the garbager's deep Value.delete(payload) -- which
                        // fires at payload's last use, before val_enum_flat
                        // reads pdata -- becomes a no-op and does not free
                        // (UAF) or double-free this buffer.
                        si.borrowed = true
                    }
                case Value.Enum(ei):
                    mut cloned_ei := ei.clone()
                    // Same hand-off: the garbager would deep-delete this fresh
                    // clone at its last use (the to_ptr); mark borrowed so the
                    // manual EvalHeap.heap_free(own pdata) below is the sole owner.
                    cloned_ei.borrowed = true
                    pdata = to_ptr(cloned_ei.data)
                    psz = cloned_ei.data_size
                    must_free_pdata = true
                case Value.Ref(p):     pdata = to_ptr(p); psz = 8
                case Value.Dynamic(p): pdata = to_ptr(p); psz = 8
                case Value.Func(f):    pdata = to_ptr(f); psz = 8
                case:
                }
                total_size : USize = ctx_total_size(enum_name, ctx)
                tmp := val_enum_flat(enum_name, ctor_tag, pdata, psz, total_size, vtype == "Str", true, ctx)
                // The h_* out-param `result` arrives empty (Value.None, no
                // heap), so a raw byte move into it loses nothing. Spelled
                // memcpy+memset because move() onto a managed destination
                // is a type error (it leaks the old contents in general).
                memcpy(result, tmp, Value.size().cast(U64))
                memset(tmp, 0, Value.size().cast(U64))
                if must_free_pdata {
                    // val_enum_flat MOVED the Str payload's c_str into the enum
                    // (nulling pdata's c_str), so freeing pdata releases only
                    // the now-empty Str struct box.
                    EvalHeap.heap_free(own pdata)
                }
            } else {
                total_size : USize = ctx_total_size(enum_name, ctx)
                tmp := val_enum_flat(enum_name, ctor_tag, NULL, 0, total_size, false, false, ctx)
                memcpy(result, tmp, Value.size().cast(U64))
                memset(tmp, 0, Value.size().cast(U64))
            }
            return true
        }
    }
    return false
}

priv ffi_decode_scalar := func(rtype: Str, p: Dynamic, mut result: Value, ctx: Context) returns Bool {
    if rtype == "I64"        { ref rv : I64 = p;   result = Value.Int(rv);            return true }
    else if rtype == "U8"    { ref rv : U8 = p;    result = Value.Byte(rv);    return true }
    else if rtype == "I16"   { ref rv : I16 = p;   result = Value.Short(rv);   return true }
    else if rtype == "U16"   { ref rv : U16 = p;   result = Value.Ushort(rv);   return true }
    else if rtype == "I32"   { ref rv : I32 = p;   result = Value.Int32(rv);   return true }
    else if rtype == "U32"   { ref rv : U32 = p;   result = Value.Uint32(rv);   return true }
    else if rtype == "U64"   { ref rv : U64 = p;   result = Value.Uint64(rv);            return true }
    else if rtype == "USize" {
        ref usize_name : Str = resolve_type_alias(ctx.scope, "USize")
        if usize_name == "U32" { ref rv : U32 = p; result = Value.Uint32(rv); return true }
        ref rv : U64 = p
        result = Value.Uint64(rv)
        return true
    }
    else if rtype == "UPtr" {
        ref uptr_name : Str = resolve_type_alias(ctx.scope, "UPtr")
        if uptr_name == "U32" { ref rv : U32 = p; result = Value.Uint32(rv); return true }
        ref rv : U64 = p
        result = Value.Uint64(rv)
        return true
    }
    else if rtype == "F32"   { ref rv : F32 = p;   result = Value.Float(rv);            return true }
    else if rtype == "Bool"  { ref rv : Bool = p;  result = Value.Boolean(rv);           return true }
    return false
}

// Look up the StructDef Expr for fe's shallow-struct return type, or
// NULL if the return type isn't a known shallow struct.
priv ffi_call_ret_struct_def := func(fe: FFIEntry, ctx: Context) returns ref Expr {
    if fe.return_is_shallow.not() { return NULL }
    expect(fe.return_type.is_null().not(), "fe.return_type is null")
    if ffi_cif_rtype_is_struct(fe.cif).not() { return NULL }
    if ctx.ffi_struct_defs.has(fe.return_type).not() { return NULL }
    ref box : ExprPtrBox = ctx.ffi_struct_defs[fe.return_type]
    return box.ptr
}

// ffi_type -> (type_name, size). Inverse mapping of shallow_ffi_type;
// keep the two in sync if a new shallow primitive type lands. Returns
// false for ffi_types that don't correspond to a primitive shallow
// value (struct/pointer/etc., caller falls back to the Ptr-default
// path). type_name is what reinterpret_ptr_value understands.
priv ffi_shallow_type_info := func(atype: Dynamic, mut type_name: Str, mut size: USize) returns Bool {
    if atype.ptr_eq(ffi_type_ref("ffi_type_sint64")) { type_name = "I64"; size = 8; return true }
    if atype.ptr_eq(ffi_type_ref("ffi_type_uint8"))  { type_name = "U8";  size = 1; return true }
    if atype.ptr_eq(ffi_type_ref("ffi_type_sint8"))  { type_name = "I8";  size = 1; return true }
    if atype.ptr_eq(ffi_type_ref("ffi_type_sint16")) { type_name = "I16"; size = 2; return true }
    if atype.ptr_eq(ffi_type_ref("ffi_type_uint16")) { type_name = "U16"; size = 2; return true }
    if atype.ptr_eq(ffi_type_ref("ffi_type_sint32")) { type_name = "I32"; size = 4; return true }
    if atype.ptr_eq(ffi_type_ref("ffi_type_uint32")) { type_name = "U32"; size = 4; return true }
    if atype.ptr_eq(ffi_type_ref("ffi_type_uint64")) { type_name = "U64"; size = 8; return true }
    if atype.ptr_eq(ffi_type_ref("ffi_type_float"))  { type_name = "F32"; size = 4; return true }
    return false
}

// Write a shallow primitive arg into the FFI args buffer at `dst`.
// Returns false if `atype` isn't a known primitive (caller falls back to
// the Ptr-default path).
//
// For pointer-like args (Value.Ref/Value.Dynamic slot pointers from Vec/Array/Map.get etc.) the
// narrowing is delegated to reinterpret_ptr_value -- the same helper
// ref bindings, param binding, and eval_arg use -- so the four paths
// can't drift apart and re-introduce #166 on the FFI side.
//
// Non-Ptr args go through value_to_f32 (cross-kind I64->F32 needs a real
// numeric conversion) or value_to_u64 (all integer-shaped ffi_types,
// truncated by memcpy'ing only `size` bytes -- equivalent to the old
// to_i16/to_u8/etc. casts on x86-64 little-endian).
priv ffi_write_shallow_arg := func(scope: Scope, v: Value, atype: Dynamic, dst: Dynamic, ctx: Context) returns Bool {
    mut tn := ""
    mut sz : USize = 0
    if ffi_shallow_type_info(atype, tn, sz).not() { return false }
    if is_value_ptr(v) {
        narrowed := reinterpret_ptr_value(v, tn, scope, ctx, false)
        ref payload : Dynamic = val_to_ptr(narrowed)
        memcpy(dst, payload, sz.cast(U64))
    } else if tn == "F32" {
        tmp : F32 = value_to_f32(v)
        memcpy(dst, tmp, 4)
    } else {
        tmp : U64 = value_to_u64(v)
        memcpy(dst, tmp, sz.cast(U64))
    }
    return true
}

priv ext_dispatch_ffi := proc(name: Str, scope: Scope, e: Expr, mut result: Value, ctx: Context) returns Bool {
    if ctx.ffi_loaded.not() { return false }
    if ctx.ffi_map.has(name).not() { return false }

    ref fe : FFIEntry = ctx.ffi_map[name]
    nargs := e.children.len() - 1
    mut alloc_n := nargs
    if alloc_n == 0 { alloc_n = 1 }
    // args[i] = void* for each arg, arg_ptrs[i] = &args[i]
    args : Dynamic = malloc(alloc_n.mul(8).cast(U64))
    arg_ptrs : Dynamic = malloc(alloc_n.mul(8).cast(U64))
    // Per-arg flag: true when args[i] holds a scalar box WE malloc'd on
    // the deep path below. No ext callee takes `own` scalars (the C side
    // only borrows these boxes), so they must be freed after ffi_call --
    // skipping that leaked one box per non-shallow scalar arg per call.
    boxed_flags : Dynamic = calloc(alloc_n.cast(U64), 1)
    // args / arg_ptrs hold RAW pointers into each arg Value's payload
    // (si.data / ei.data). Those Values must outlive ffi_call, but they are
    // per-iteration locals the garbager would delete (deep) at the end of
    // each iteration. Keep them in this Vec (push = own transfer, so the
    // garbager hands off) and free them only after ffi_call + result decode.
    mut arg_vals := Vec(Value).new()

    for i in 0..nargs {
        v := eval_expr(scope, e.children[i + 1], ctx)
        mut is_shallow := fe.param_shallows.is_null().not()
        .and(i.lt(fe.nparam))
        if is_shallow {
            ref ps : Bool = ptr_add(fe.param_shallows, i.cast(U64))
            is_shallow = ps
        }
        if is_shallow {
            // Shallow: store dereferenced value directly
            switch v {
            case Value.Struct(si):
                write_ptr(ptr_add(arg_ptrs, i.mul(8).cast(U64)), si.data)
            case:
                ref at : Dynamic = ptr_add(fe.arg_types, i.mul(8).cast(U64))
                ref atype : Dynamic = deref(at)
                ref dst : Dynamic = ptr_add(args, i.mul(8).cast(U64))
                if ffi_write_shallow_arg(scope, v, atype, dst, ctx).not() {
                    // Default: pointer-like value
                    switch v {
                    case Value.Ref(pv):
                        write_ptr(dst, deref(pv))
                    case Value.Dynamic(pv):
                        write_ptr(dst, deref(pv))
                    case Value.Func(fv):
                        write_ptr(dst, deref(fv))
                    case Value.Closure:
                        panic("FFI cannot receive captured closures")
                    case:
                        write_ptr(dst, NULL)
                    }
                }
                write_ptr(ptr_add(arg_ptrs, i.mul(8).cast(U64)), dst)
            }
        } else {
            // Deep: pass heap-allocated pointer (FFI callee may free it)
            mut dp : Dynamic = 0
            switch v {
            case Value.Int(p):     dp = malloc(8); memcpy(dp, p, 8)
            case Value.Byte(p):    dp = malloc(1); memcpy(dp, p, 1)
            case Value.Sbyte(p):   dp = malloc(1); memcpy(dp, p, 1)
            case Value.Short(p):   dp = malloc(2); memcpy(dp, p, 2)
            case Value.Ushort(p):  dp = malloc(2); memcpy(dp, p, 2)
            case Value.Int32(p):   dp = malloc(4); memcpy(dp, p, 4)
            case Value.Uint32(p):  dp = malloc(4); memcpy(dp, p, 4)
            case Value.Uint64(p):  dp = malloc(8); memcpy(dp, p, 8)
            case Value.Float(p):   dp = malloc(4); memcpy(dp, p, 4)
            case Value.Boolean(p): dp = malloc(1); memcpy(dp, p, 1)
            case Value.Ref(pv):
                write_ptr(ptr_add(args, i.mul(8).cast(U64)), deref(pv))
            case Value.Dynamic(pv):
                write_ptr(ptr_add(args, i.mul(8).cast(U64)), deref(pv))
            case Value.Func(fv):
                // Issue #58: pass through function pointer (Value.Func payload
                // is the function pointer itself, deref reads the actual ptr).
                write_ptr(ptr_add(args, i.mul(8).cast(U64)), deref(fv))
            case Value.Closure:
                panic("FFI cannot receive captured closures")
            case Value.Struct(si):
                write_ptr(ptr_add(args, i.mul(8).cast(U64)), si.data)
            case Value.Enum(ei):
                write_ptr(ptr_add(args, i.mul(8).cast(U64)), ei.data)
            case:
                write_ptr(ptr_add(args, i.mul(8).cast(U64)), NULL)
            }
            if dp.is_null().not() {
                write_ptr(ptr_add(args, i.mul(8).cast(U64)), dp)
                ref mut bf : Bool = ptr_add(boxed_flags, i.cast(U64))
                bf = true
            }
            write_ptr(ptr_add(arg_ptrs, i.mul(8).cast(U64)), ptr_add(args, i.mul(8).cast(U64)))
        }
        // Keep this arg Value alive (and its payload, which args/arg_ptrs
        // point into) until after ffi_call; arg_vals owns it now.
        arg_vals.push(own v)
    }

    // Check if return is a shallow struct
    ref ret_sdef : Expr = ffi_call_ret_struct_def(fe, ctx)

    // raw: 16-byte buffer for return value
    raw : Dynamic = calloc(1, 16)
    mut ret_buf : Dynamic = 0
    if ret_sdef.is_null().not() {
        switch ret_sdef.node_type {
        case NodeType.StructDef:
            ret_buf = malloc(ctx_total_size(fe.return_type, ctx).cast(U64))
            ffi_call(fe.cif, fe.fn, ret_buf, arg_ptrs)
        case:
            ffi_call(fe.cif, fe.fn, raw, arg_ptrs)
        }
    } else {
        ffi_call(fe.cif, fe.fn, raw, arg_ptrs)
    }

    // Decode return value
    if fe.return_type.is_null() {
        result = val_none()
    } else if ret_sdef.is_null().not() {
        result = make_struct_value(fe.return_type, ret_buf, false, ctx)
    } else if fe.return_is_shallow {
        if ffi_decode_scalar(fe.return_type, to_ptr(raw), result, ctx).not() {
            result = val_none()
        }
    } else {
        ref rtype : Str = fe.return_type
        ref raw_ptr : Dynamic = deref(raw)
        if rtype == "Str" {
            ref sp : ExtStr = raw_ptr
            // A `returns ref Str` borrows the C buffer (caller must not free
            // it); copy into an independent owned Str rather than claiming the
            // foreign buffer with make_str_value_own (whose deep delete would
            // free memory we do not own).
            if fe.return_is_ref { result = make_str_value(sp.data, sp.count, ctx) }
            else {
                // Issue #275: ADOPT the ext_func's whole Str* as the Value's
                // data -- a single owner of both the 16-byte struct AND the
                // c_str. make_str_value_own used to malloc a SECOND Str and copy
                // the c_str pointer into it, orphaning the ext_func's struct (a
                // transient double-ownership that then needed a manual free).
                // Reusing raw_ptr directly is one move: no re-wrap, no orphaned
                // wrapper, no manual free -- the garbager's deep Str delete frees
                // the struct and the c_str together at teardown. Force cap=count
                // so delete reclaims the c_str (mirrors make_str_value_own;
                // ExtStr and Str share the {ptr, count, cap} layout).
                write_u32(ptr_add(raw_ptr, 12), sp.count)
                result = make_struct_value(ctx.cached_str_name, raw_ptr, false, ctx)
            }
        } else if rtype == "Dynamic" {
            result = Value.Dynamic(raw_ptr)
        } else if ffi_decode_scalar(rtype, raw_ptr, result, ctx) {
        } else if ctx.ffi_struct_defs.has(fe.return_type) {
            // `returns ref T` hands back a borrowed pointer into foreign / C
            // memory; flag the wrapper borrowed so the garbager's deep delete
            // does not free a buffer the runtime never malloc'd (ext_libc:
            // getenv returns a pointer into libc's environ).
            result = make_struct_value(fe.return_type, raw_ptr, fe.return_is_ref, ctx)
        } else {
            result = val_none()
        }
    }
    // ffi_call + result decode are done, so the arg payloads the FFI buffers
    // pointed into are no longer needed. Keep arg_vals visibly live until
    // here; arg_ptrs holds raw aliases the garbager cannot see.
    if arg_vals.len() != nargs { UNREACHABLE() }
    for i in 0..nargs {
        ref bf : Bool = ptr_add(boxed_flags, i.cast(U64))
        if bf {
            mut box_ptr : Dynamic = 0
            box_ptr = deref(ptr_add(args, i.mul(8).cast(U64)))
            free(own box_ptr)
        }
    }
    free(own boxed_flags)
    free(own args)
    free(own arg_ptrs)
    free(own raw)
    return true
}

// #288 Stage 4: native interpreter evaluation of the scalar primitive ISA.
// A scalar op call like `a.mul(b)` reaches ext_function_dispatch as the flat
// name "U32_mul". Rather than dlsym'ing the ext.c symbol (a slow libffi round
// trip) we compute the result directly on the operand Values, matching the
// exact C semantics in src/c/ext.c: modular wrapping at the type width and
// signed-vs-unsigned shifts. This is the interpreter half of the core_func
// ISA -- once src/core's scalar ops migrate ext_func -> core_func and their
// ext.c symbols are deleted, this is the ONLY path. It is already live for the
// ext_func ops, so the whole suite (interpret + both-mode compare) proves it
// matches ext.c. div/mod (zero-guarded), the to_* conversions, cmp and clone
// are NOT handled here and keep dispatching to their ext.c symbols.

// Category of a scalar type name: "u" unsigned int, "i" signed int, "f" F32;
// "" for anything that is not one of the nine numeric primitives.
priv scalar_op_cat := func(t: Str) returns Str {
    switch t {
    case "U8":  return "u"
    case "U16": return "u"
    case "U32": return "u"
    case "U64": return "u"
    case "I8":  return "i"
    case "I16": return "i"
    case "I32": return "i"
    case "I64": return "i"
    case "F32": return "f"
    }
    return ""
}

priv scalar_is_binop := func(op: Str) returns Bool {
    switch op {
    case "add": return true
    case "sub": return true
    case "mul": return true
    case "band": return true
    case "bor": return true
    case "bxor": return true
    case "shl": return true
    case "shr": return true
    case "div": return true
    case "mod": return true
    }
    return false
}

// Compute the binary op at U64 width (unsigned ops: the low bits are correct
// for every narrower unsigned type after truncation in scalar_build).
priv scalar_apply_u64 := func(op: Str, a: U64, b: U64) returns U64 {
    switch op {
    case "add": return a.add(b)
    case "sub": return a.sub(b)
    case "mul": return a.mul(b)
    case "band": return a.band(b)
    case "bor": return a.bor(b)
    case "bxor": return a.bxor(b)
    case "shl": return a.shl(b)
    case "shr": return a.shr(b)
    case "div": return a.div(b)
    case "mod": return a.mod(b)
    }
    panic(__LOC__, ": scalar_apply_u64: unhandled op ", op)
    return a
}

// Compute the binary op at I64 width (signed: arithmetic shr sign-extends;
// scalar_build truncates to the narrower signed type).
priv scalar_apply_i64 := func(op: Str, a: I64, b: I64) returns I64 {
    switch op {
    case "add": return a.add(b)
    case "sub": return a.sub(b)
    case "mul": return a.mul(b)
    case "band": return a.band(b)
    case "bor": return a.bor(b)
    case "bxor": return a.bxor(b)
    case "shl": return a.shl(b)
    case "shr": return a.shr(b)
    case "div": return a.div(b)
    case "mod": return a.mod(b)
    }
    panic(__LOC__, ": scalar_apply_i64: unhandled op ", op)
    return a
}

priv scalar_apply_f32 := func(op: Str, a: F32, b: F32) returns F32 {
    switch op {
    case "add": return a.add(b)
    case "sub": return a.sub(b)
    case "mul": return a.mul(b)
    case "div": return a.div(b)
    }
    panic(__LOC__, ": scalar_apply_f32: unhandled op ", op)
    return a
}

// True for the six comparison ops that return Bool (eq/neq + the four
// ordering ops). Separate from scalar_is_binop because these build a
// Value.Boolean, not a width-truncated scalar.
priv scalar_is_cmp := func(op: Str) returns Bool {
    switch op {
    case "eq":  return true
    case "neq": return true
    case "lt":  return true
    case "gt":  return true
    case "lte": return true
    case "gte": return true
    }
    return false
}

// Apply a comparison at U64 width (unsigned operands: eq/neq are bit-equal,
// the ordering ops use unsigned comparison).
priv scalar_cmp_u64 := func(op: Str, a: U64, b: U64) returns Bool {
    switch op {
    case "eq":  return a.eq(b)
    case "neq": return a.neq(b)
    case "lt":  return a.lt(b)
    case "gt":  return a.gt(b)
    case "lte": return a.lte(b)
    case "gte": return a.gte(b)
    }
    panic(__LOC__, ": scalar_cmp_u64: unhandled op ", op)
    return false
}

// Apply a comparison at I64 width (signed operands).
priv scalar_cmp_i64 := func(op: Str, a: I64, b: I64) returns Bool {
    switch op {
    case "eq":  return a.eq(b)
    case "neq": return a.neq(b)
    case "lt":  return a.lt(b)
    case "gt":  return a.gt(b)
    case "lte": return a.lte(b)
    case "gte": return a.gte(b)
    }
    panic(__LOC__, ": scalar_cmp_i64: unhandled op ", op)
    return false
}

// Apply a comparison on F32 operands.
priv scalar_cmp_f32 := func(op: Str, a: F32, b: F32) returns Bool {
    switch op {
    case "eq":  return a.eq(b)
    case "neq": return a.neq(b)
    case "lt":  return a.lt(b)
    case "gt":  return a.gt(b)
    case "lte": return a.lte(b)
    case "gte": return a.gte(b)
    }
    panic(__LOC__, ": scalar_cmp_f32: unhandled op ", op)
    return false
}

// Truncate an integer result to `t`'s width and box it. The unsigned ops
// compute at U64 and pass the result reinterpreted as I64 (`.cast(I64)`):
// truncation to a narrower width is sign-agnostic, and U64 round-trips back
// through `v.cast(U64)`. One builder for both signednesses (the two apply_*
// helpers stay split because shr is logical vs arithmetic).
priv scalar_build := func(t: Str, v: I64) returns shallow Value {
    switch t {
    case "U8":  return val_u8(v)
    case "I8":  return val_i8(v)
    case "U16": return val_u16(v)
    case "I16": return val_i16(v)
    case "U32": return val_u32(v)
    case "I32": return val_i32(v)
    case "U64": return Value.Uint64(v.cast(U64))
    }
    return Value.Int(v)
}

// Evaluate `arg` and, if it is a borrowed Value.Ref (e.g. an unsafe_get
// element view or a `ref` binding), narrow it to the scalar Value for
// `type_str` -- the same deref the dlsym path did for by-value ext params. A
// non-ref scalar Value passes through unchanged.
priv scalar_read_arg := proc(scope: Scope, arg: Expr, type_str: Str, ctx: Context) returns shallow Value {
    return reinterpret_ptr_value(eval_expr(scope, arg, ctx), type_str, scope, ctx, false)
}

priv scalar_core_op_eval := proc(name: Str, scope: Scope, e: Expr, mut result: Value, ctx: Context) returns Bool {
    // Cheap reject: every scalar primitive type name starts with U, I or F.
    // This skips the find/substr parse for the common non-scalar dispatch
    // names (Str_*, Vec_*, Map_*, ...) before any allocation.
    if name.len() == 0 { return false }
    ref c0 : I8 = name.unsafe_get(0)
    if (c0 == 'U').not().and((c0 == 'I').not()).and((c0 == 'F').not()) { return false }
    us := name.find("_")
    if us < 0 { return false }
    u_pos : USize = us.to_usize()
    zero : USize = 0
    type_str := name.substr(zero, u_pos)
    cat := scalar_op_cat(type_str)
    if cat == "" { return false }
    op_start := u_pos.add(1)
    op_str := name.substr(op_start, name.len().sub(op_start))

    // eq/neq/lt/gt/lte/gte: binary comparison -> Bool. eq/neq are bit-equal
    // for both signednesses; the ordering ops use the category's signed,
    // unsigned, or float comparison.
    if scalar_is_cmp(op_str) {
        av := scalar_read_arg(scope, e.children[1], type_str, ctx)
        bv := scalar_read_arg(scope, e.children[2], type_str, ctx)
        if cat == "u" { result = Value.Boolean(scalar_cmp_u64(op_str, value_to_u64(av), value_to_u64(bv))); return true }
        if cat == "i" { result = Value.Boolean(scalar_cmp_i64(op_str, value_as_i64(av), value_as_i64(bv))); return true }
        result = Value.Boolean(scalar_cmp_f32(op_str, value_to_f32(av), value_to_f32(bv)))
        return true
    }

    // bnot: unary bitwise complement (integer only).
    if op_str == "bnot" {
        av := scalar_read_arg(scope, e.children[1], type_str, ctx)
        if cat == "u" { result = scalar_build(type_str, value_to_u64(av).bnot().cast(I64)); return true }
        if cat == "i" { result = scalar_build(type_str, value_as_i64(av).bnot()); return true }
        return false
    }

    if scalar_is_binop(op_str) {
        av := scalar_read_arg(scope, e.children[1], type_str, ctx)
        bv := scalar_read_arg(scope, e.children[2], type_str, ctx)
        if cat == "u" {
            result = scalar_build(type_str, scalar_apply_u64(op_str, value_to_u64(av), value_to_u64(bv)).cast(I64))
            return true
        }
        if cat == "i" {
            result = scalar_build(type_str, scalar_apply_i64(op_str, value_as_i64(av), value_as_i64(bv)))
            return true
        }
        // cat == "f": only add/sub/mul/div exist on F32 (no bitwise/shift/mod).
        if (op_str == "add").or(op_str == "sub").or(op_str == "mul").or(op_str == "div") {
            result = Value.Float(scalar_apply_f32(op_str, value_to_f32(av), value_to_f32(bv)))
            return true
        }
        return false
    }

    return false
}

priv ext_function_dispatch := proc(name: Str, scope: Scope, e: Expr, mut result: Value, ctx: Context) returns Bool {
    if ctx.dispatch_inited.not() { dispatch_init(ctx) }
    if ext_dispatch_builtin(name, scope, e, result, ctx) { return true }
    if scalar_core_op_eval(name, scope, e, result, ctx) { return true }
    return ext_dispatch_ffi(name, scope, e, result, ctx)
}
priv ffi_register := proc(name: Str, fn: Dynamic, fdef: Expr, ctx: Context) {
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        np := fd.params.len()
        mut alloc_np := np
        if alloc_np == 0 { alloc_np = 1 }
        // Build ffi_type* array (each element is a pointer = 8 bytes)
        atypes : Dynamic = malloc(alloc_np.mul(8).cast(U64))
        mut pshallows : Dynamic = 0
        mut has_shallow := false
        for k in 0..np {
            ref pk : Declaration = fd.params[k]
            if pk.own_type.is(OwnType.Shallow) {
                write_ptr(ptr_add(atypes, k.mul(8).cast(U64)), shallow_ffi_type(pk.explicit_type, ctx))
                has_shallow = true
            } else {
                write_ptr(ptr_add(atypes, k.mul(8).cast(U64)), ffi_type_ref("ffi_type_pointer"))
            }
        }
        if has_shallow {
            pshallows = malloc(np.cast(U64))
            for k in 0..np {
                ref pk : Declaration = fd.params[k]
                ref mut slot : Bool = ptr_add(pshallows, k.cast(U64))
                slot = pk.own_type.is(OwnType.Shallow)
            }
        }
        ret_shallow := fd.return_own_type.is(OwnType.Shallow)
        cif : Dynamic = ffi_alloc_cif()

        // Build FFIEntry
        mut entry := FFIEntry()
        entry.fn = fn
        if fd.return_type.len() > 0 { entry.return_type = fd.return_type }
        entry.nparam = np
        entry.param_shallows = pshallows
        entry.return_is_shallow = ret_shallow
        entry.return_is_ref = fd.return_own_type.is(OwnType.Ref)
        entry.cif = cif
        entry.arg_types = atypes

        // Resolve return ffi_type
        ref mut rtype : Dynamic = ffi_type_ref("ffi_type_void")
        if entry.return_type.is_null().not() {
            if ret_shallow {
                rtype = to_ptr(shallow_ffi_type(entry.return_type, ctx))
            } else {
                rtype = to_ptr(ffi_type_ref("ffi_type_pointer"))
            }
        }
        ffi_prep_cif(entry.cif, FFI_DEFAULT_ABI, np, rtype, entry.arg_types)

        // Store in ctx.ffi_map. Map.set borrows the key and deep-clones it
        // internally (ELEM_BOXED), so `name` can be passed directly; the
        // old clone+box dance here leaked both the box and the cloned Str.
        // The value box is a transient that Map.set consumes.
        val : Dynamic = malloc(FFIEntry.size().cast(U64))
        move(val, entry, FFIEntry.size().cast(U64))
        ctx.ffi_map.set(name, own val)
    case:
        UNREACHABLE()
    }
}


ffi_init_scan_program := proc(program: Expr, ctx: Context) {
    if ctx.ffi_map_inited.not() {
        ctx.ffi_map = Map(Str, FFIEntry).new()
        ctx.ffi_map_inited = true
    }
    for stmt : Expr in program.children {
        if stmt.node_type.is(NodeType.Decl).not() { }
        else if stmt.children.len() == 0 { }
        else {
            // Top-level ext_func/ext_proc
            if stmt.children[0].node_type.is(NodeType.FuncDef) {
                ref fdef : Expr = stmt.children[0]
                switch fdef.node_type {
                case NodeType.FuncDef(fd):
                    if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)) {
                        switch stmt.node_type {
                        case NodeType.Decl(dname):
                            ref fn_ptr : U8 = ffi_dlsym(dname.name)
                            if fn_ptr.is_null().not() {
                                ffi_register(dname.name, fn_ptr, fdef, ctx)
                            }
                        case:
                        }
                    }
                case:
                }
            }
            // Struct namespace ext_func/ext_proc
            if stmt.children[0].node_type.is(NodeType.StructDef) {
                switch stmt.node_type {
                case NodeType.Decl(sdd):
                    switch stmt.children[0].node_type {
                    case NodeType.StructDef(sdd_data):
                        for d_j : Declaration in sdd_data.ns_decls {
                        ref fdd : Declaration = d_j
                        ref fdef : Expr = fdd.default_value
                        if fdef.is_null() { continue }
                        mut fd_func_type := FuncType.Func
                        switch fdef.node_type {
                        case NodeType.FuncDef(fd):
                            fd_func_type = fd.func_type
                        case:
                            continue
                        }
                        if fd_func_type.is(FuncType.ExtFunc).or(fd_func_type.is(FuncType.ExtProc)) {
                            flat_name := sdd.name.concat3("_", fdd.name)
                            ref fn_ptr : U8 = ffi_dlsym(flat_name)
                            if fn_ptr.is_null().not() {
                                ffi_register(flat_name, fn_ptr, fdef, ctx)
                            }
                        } else if fd_func_type.is(FuncType.Func).or(fd_func_type.is(FuncType.Proc)) {
                            // Scan function body for nested ext_func/ext_proc.
                            // A bodyless namespace signature (interface
                            // method, issue #251) has no body to scan.
                            if fdef.children.len() == 0 { continue }
                            ref fbody : Expr = fdef.children[0]
                            for inner : Expr in fbody.children {
                                if inner.node_type.is(NodeType.Decl).and(inner.children.len().gt(0)) {
                                    ref idef : Expr = inner.children[0]
                                    switch idef.node_type {
                                    case NodeType.FuncDef(ifd):
                                        if ifd.func_type.is(FuncType.ExtFunc).or(ifd.func_type.is(FuncType.ExtProc)) {
                                            switch inner.node_type {
                                            case NodeType.Decl(iname):
                                                ref ifn : U8 = ffi_dlsym(iname.name)
                                                if ifn.is_null().not() {
                                                    ffi_register(iname.name, ifn, idef, ctx)
                                                }
                                            case:
                                                UNREACHABLE()
                                            }
                                        }
                                    case:
                                    }
                                }
                            }
                        }
                    }
                    case:
                        UNREACHABLE()
                    }
                case:
                    UNREACHABLE()
                }
            }
        }
    }
}

priv ffi_init := proc(program: Expr, fwd_path: Str, user_c_path: Str, ext_c_path: Str, link_flags: Str, ctx: Context) returns I32 {
    if ctx.ffi_loaded {
        ffi_cleanup(ctx)
        ctx.ffi_map_inited = false
    }
    mut so_path := ""
    if ffi_init_user_so(fwd_path, user_c_path, ext_c_path, link_flags, so_path).eq(0).not() {
        return 1
    }
    ffi_init_link_libs(link_flags)
    ffi_init_struct_defs(program, ctx)
    ffi_init_scan_program(program, ctx)
    ctx.ffi_loaded = true
    if so_path.len() > 0 { unlink_path(so_path) }
    return 0
}
ffi_cleanup := proc(ctx: Context) {
    ffi_close_user_so()
    if ctx.ffi_loaded {
        for fe : FFIEntry in ctx.ffi_map.values {
            free(own fe.param_shallows)
            free(own fe.arg_types)
            free(own fe.cif)
        }
        // Inner C-heap pointers freed above; reset the maps to fresh
        // empties so the owning Context auto-deletes live containers
        // rather than double-freeing what we just tore down.
        ctx.ffi_map = Map(Str, FFIEntry).new()
        ctx.ffi_struct_defs = Map(Str, ExprPtrBox).new()
        ctx.ffi_loaded = false
    }
    if ctx.ffi_type_cache_inited {
        for box : FFITypePtrBox in ctx.ffi_type_cache {
            if box.ptr.is_null().not() {
                free(own box.ptr.elements)
                free(own box.ptr)
            }
        }
        ctx.ffi_type_cache = Vec(FFITypePtrBox).new()
        ctx.ffi_type_cache_inited = false
    }
}
