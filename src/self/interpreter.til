mode lib

import("loader")
import("builder")

system_cmd := ext_func(cmd: Str) returns shallow I32 {}

interp_error_path := func() returns Str {
    if is_null(codegen_lp_slot).not() {
        return codegen_lp().ctx.path.clone()
    }
    return ""
}

interp_error := proc(e: Expr, msg: Str) {
    println(interp_error_path(), ":", e.line.to_str(), ":", e.col.to_str(), ": error: ", msg)
}

interp_lang_error := proc(e: Expr, msg: Str) {
    interp_error(e, msg)
    println("  note: this is a bug in the language, please report it")
}

// True when a StructInstance with this StructDef has a byte layout
// that the outer memcpy in StructInstance.clone already clones
// correctly -- i.e. no field contains an owned heap pointer that
// would alias.  This is the interpreter-side POD predicate; it is
// strictly more conservative than initer's is_pod_type_for_clone
// because the interpreter stores enum-with-payloads fields as heap
// pointers (EnumInstance.data), so even a "POD enum" needs the
// per-field deep clone here.
priv struct_def_shallow_safe := func(sdef_data: StructDef) returns shallow Bool {
    for dd : Declaration in sdef_data.fields {
        if dd.own_type.is(OwnType.Own) { return false }
        if dd.own_type.is(OwnType.Ref) { continue }
        ref ftype : Str = dd.explicit_type
        if ftype.eq("Str") { return false }
        if is_null(dd.field_struct_def).not() {
            ref fsd : Expr = dd.field_struct_def
            switch fsd.node_type {
            case NodeType.EnumDef:
                if enum_has_payloads(fsd) { return false }
            case NodeType.StructDef(nested_sdef):
                if struct_def_shallow_safe(nested_sdef).not() { return false }
            case:
            }
        }
    }
    return true
}

StructInstance := struct {
    ref mut struct_name : Str = NULL
    ref mut struct_def : Expr = NULL
    own mut data : U8 = 0
    mut borrowed := false
namespace:
    eq := func(a: StructInstance, b: StructInstance) returns shallow Bool {
        return a.struct_name.eq(b.struct_name)
    }
    to_str := func(self: StructInstance) returns Str {
        if is_null(self.struct_name) { return "StructInstance" }
        return self.struct_name.clone()
    }
    clone := func(self: StructInstance) returns StructInstance {
        ref src_sdef : Expr = self.struct_def
        switch src_sdef.node_type {
        case NodeType.StructDef(sdef_data):
            sz := sdef_data.total_struct_size
            dst_data : Dynamic = malloc(sz.to_u64())
            memcpy(dst_data, self.data, sz.to_u64())
            if self.struct_name.eq("Str") {
                ref s : Str = to_ptr(self.data)
                if s.count.to_i64().gt(0) {
                    if is_null(s.c_str).not() {
                        mut cloned_str := s.clone()
                        // Replace c_str with the freshly malloc'd clone
                        // and update cap so the clone OWNS its buffer.
                        // Preserving the original cap (e.g. CAP_VIEW from
                        // a view-typed value) leaked the new buffer
                        // because cleanup_value_payload / Str.delete
                        // skip free for cap >= CAP_VIEW.
                        write_ptr(dst_data, cloned_str.c_str)
                        ref mut dst_cap : U32 = ptr_add(dst_data, 12)
                        dst_cap = s.count.clone()
                        // Prevent cloned_str destructor from freeing the new c_str
                        memset(cloned_str, 0, Str.size().to_u64())
                    }
                }
            } else if struct_def_shallow_safe(sdef_data) {
                // POD shortcut: every field is either a primitive,
                // a ref (skipped anyway), or a nested shallow-safe
                // struct stored inline.  The outer memcpy already
                // cloned the bytes correctly; no per-field work
                // needed.
            } else {
                for dd : Declaration in sdef_data.fields {
                    foff := dd.field_offset
                    ref ftype : Str = dd.explicit_type
                    if dd.own_type.is(OwnType.Own) {
                        ref src_ptr : Dynamic = deref(ptr_add(self.data, foff.to_u64()))
                        if is_null(src_ptr).not() {
                            if is_null(dd.field_struct_def).not() {
                                mut tmp := StructInstance(struct_name = ftype, struct_def = dd.field_struct_def, data = to_ptr(src_ptr), borrowed = true)
                                mut cloned := tmp.clone()
                                tmp.data = NULL
                                write_ptr(ptr_add(dst_data, foff.to_u64()), cloned.data)
                                cloned.data = NULL
                            }
                        }
                        continue
                    }
                    if dd.own_type.is(OwnType.Ref) { continue }
                    if ftype.eq("Str") {
                        ref s : Str = ptr_add(self.data, foff.to_u64())
                        if s.count.to_i64().gt(0) {
                            if is_null(s.c_str).not() {
                                mut cloned_str := s.clone()
                                write_ptr(ptr_add(dst_data, foff.to_u64()), cloned_str.c_str)
                                // Update cap to count so the clone owns
                                // its freshly malloc'd buffer (mirrors
                                // the Str-payload branch above).
                                ref mut dst_cap : U32 = ptr_add(ptr_add(dst_data, foff.to_u64()), 12)
                                dst_cap = s.count.clone()
                                memset(cloned_str, 0, Str.size().to_u64())
                            }
                        }
                        continue
                    }
                    if is_null(dd.field_struct_def).not() {
                        if dd.field_struct_def.node_type.is(NodeType.EnumDef) {
                            if enum_has_payloads(dd.field_struct_def) {
                                ref ei_ref : Dynamic = deref(ptr_add(self.data, foff.to_u64()))
                                if is_null(ei_ref).not() {
                                    ref ei : EnumInstance = ei_ref
                                    mut cloned_ei := ei.clone()
                                    heap_ei : Dynamic = malloc(EnumInstance.size().to_u64())
                                    move(heap_ei, cloned_ei, EnumInstance.size().to_u64())
                                    write_ptr(ptr_add(dst_data, foff.to_u64()), heap_ei)
                                }
                                continue
                            }
                        }
                    }
                    if is_null(dd.field_struct_def).not() {
                        if dd.field_struct_def.node_type.is(NodeType.EnumDef).not() {
                            ref nested : Expr = dd.field_struct_def
                            switch nested.node_type {
                            case NodeType.StructDef(nested_sdef):
                                mut tmp := StructInstance(struct_name = ftype, struct_def = nested, data = ptr_add(self.data, foff.to_u64()), borrowed = true)
                                mut cloned := tmp.clone()
                                tmp.data = NULL
                                memcpy(ptr_add(dst_data, foff.to_u64()), cloned.data, nested_sdef.total_struct_size.to_u64())
                                free(own cloned.data)
                                cloned.data = NULL
                            case:
                                UNREACHABLE(__LOC__)
                            }
                        }
                    }
                }
            }
            return StructInstance(struct_name = self.struct_name, struct_def = self.struct_def, data = dst_data, borrowed = false)
        case:
            UNREACHABLE(__LOC__)
            return StructInstance()
        }
    }
    delete := func(own self: StructInstance, call_free: Bool = true) {
        // TODO: this delete leaks `own self.data` (and the inline Str's
        // c_str). Making it deep -- the right thing per the field's
        // `own` qualifier and what Vec.delete does -- segfaults the
        // self-host build because several interpreter sites (notably
        // shallow_copy_value, scope_set_owned, and the various
        // memcpy(dst, val, Value.size()) operations) lean on the
        // current no-op contract: source and destination share the
        // .data pointer and both have a destructor scheduled, so a
        // deep delete on the alias double-frees. Closing this needs a
        // coordinated audit of every memcpy-aliasing site to either
        // flip self.borrowed = true on the alias or move() the bytes.
        // For now, the no-op read of self.data below satisfies the
        // typer's "delete must reference every own field" rule; the
        // leak persists and continues to be patched at end-of-life
        // sites by cleanup_value_payload.
        if is_null(self.data) { /* leak acknowledged */ }
        if call_free { free(own self) }
    }
}

EnumInstance := struct {
    ref mut enum_name : Str = NULL
    own mut data : U8 = 0
    mut data_size : I32 = 0
namespace:
    eq := func(a: EnumInstance, b: EnumInstance) returns shallow Bool {
        return a.is(b)
    }
    to_str := func(self: EnumInstance) returns Str {
        if is_null(self.enum_name) { return "EnumInstance" }
        return self.enum_name.clone()
    }
    clone := func(self: EnumInstance) returns EnumInstance {
        if is_null(self.data) {
            return EnumInstance(enum_name = self.enum_name,
                data = NULL,
                data_size = self.data_size)
        }
        buf : Dynamic = malloc(self.data_size.to_usize())
        memcpy(buf, self.data, self.data_size.to_usize())
        return EnumInstance(enum_name = self.enum_name,
            data = buf,
            data_size = self.data_size)
    }
    delete := func(own self: EnumInstance, call_free: Bool = true) {
        // TODO: this delete leaks `own self.data`. Making it deep
        // (free-on-not-NULL like Vec.delete does) is the right fix,
        // but needs a `borrowed` field on EnumInstance to handle the
        // shallow_copy_value aliasing path (the same pattern
        // StructInstance.borrowed solves) -- and adding the field
        // grows EnumInstance past the current Value payload union
        // size (40 bytes), rippling through sites that hardcode the
        // layout. The no-op read of self.data below satisfies the
        // typer's "delete must reference every own field" rule;
        // continue to leak until the layout audit lands.
        if is_null(self.data) { /* leak acknowledged */ }
        if call_free { free(own self) }
    }
}

Value := enum {
    None,
    Int: I64,
    Byte: U8,
    Short: I16,
    Int32: I32,
    Uint32: U32,
    Uint64: U64,
    Float: F32,
    Boolean: Bool,
    Func: Dynamic,
    Struct: StructInstance,
    Enum: EnumInstance,
    Ref: Dynamic,
    Dynamic: Dynamic
namespace:
    eq := func(a: Value, b: Value) returns Bool {
        switch a {
        case Value.None:
            return b.is(Value.None)
        case Value.Int(ai):
            switch b {
            case Value.Int(bi):
                return ai.eq(bi)
            case:
                return false
            }
        case Value.Boolean(ab):
            switch b {
            case Value.Boolean(bb):
                return ab.eq(bb)
            case:
                return false
            }
        case:
            return false
        }
    }
    to_str := func(self: Value) returns Str {
        switch self {
        case Value.None:       return "None"
        case Value.Int(v):     return v.to_str()
        case Value.Boolean(v): return v.to_str()
        case:                  return "Value"
        }
    }
    clone := func(self: Value) returns Value {
        switch self {
        case Value.Struct(si):
            // Value_Struct's body in generated C calls
            // StructInstance_clone(val) again, so the returned Value
            // owns a fresh data buffer independent of `tmp`. tmp.data
            // is orphaned at function return because
            // StructInstance.delete is a no-op (acknowledged leak in
            // the destructor TODO); free it explicitly here.
            // For Str payloads, only free the inner c_str when the
            // clone allocated a fresh one (count > 0 and cap < CAP_VIEW);
            // count == 0 keeps the source's c_str shared.
            mut tmp := si.clone()
            out := Value.Struct(tmp.clone())
            if is_null(tmp.data).not() {
                if tmp.struct_name.eq("Str") {
                    ref s_str : Str = to_ptr(tmp.data)
                    if s_str.count.to_i64().gt(0).and(s_str.cap.lt(CAP_VIEW)) {
                        if is_null(s_str.c_str).not() { free(own s_str.c_str) }
                    }
                }
                free(own tmp.data)
                tmp.data = NULL
            }
            return out
        case Value.Enum(ei):
            // Same shape: Value_Enum deep-clones via EnumInstance_clone,
            // so the returned Value's payload owns a fresh buffer.
            // tmp.data is orphaned and leaks under the no-op delete.
            mut tmp := ei.clone()
            out := Value.Enum(tmp.clone())
            if is_null(tmp.data).not() {
                free(own tmp.data)
                tmp.data = NULL
            }
            return out
        case Value.Int(v):     return Value.Int(v)
        case Value.Byte(v):    return Value.Byte(v)
        case Value.Short(v):   return Value.Short(v)
        case Value.Int32(v):   return Value.Int32(v)
        case Value.Uint32(v):  return Value.Uint32(v)
        case Value.Uint64(v):  return Value.Uint64(v)
        case Value.Float(v):   return Value.Float(v)
        case Value.Boolean(v): return Value.Boolean(v)
        case Value.None:       return Value.None
        case Value.Func(payload):
            // void* payload reinterpreted via U64 (both 8 bytes)
            ref raw : U64 = payload
            return Value.Func(ptr_add(NULL, raw))
        case Value.Ref(payload):
            ref raw : U64 = payload
            return Value.Ref(ptr_add(NULL, raw))
        case Value.Dynamic(payload):
            ref raw : U64 = payload
            return Value.Dynamic(ptr_add(NULL, raw))
        }
    }
}

Cell := struct {
    mut val := Value.None
}

Binding := struct {
    ref mut name : Str = NULL
    ref mut cell : Cell = NULL
    mut cell_is_local := false
}

Scope := struct {
    mut bindings := Map.new(Str, Binding)
    ref mut parent : Scope = NULL
}

// Return-value / control-flow state and namespace fields now live on
// Context (has_return, has_break, has_continue, return_value,
// ns_fields, ns_keys, ns_inited), reached in the eval functions via
// `ref mut c : Context = codegen_lp().ctx`. Cached struct defs for
// C-side construction likewise live on Context (cached_*_def),
// populated during interpret_register_struct_defs.

// --- Type-def registry: maps struct/enum names to their AST def Expr.
// Populated by interpreter_init_ns from every struct/enum decl seen in core+user
// programs. Replaces dangerous Declaration.field_struct_def reads at use sites.
// (#147 anti-pattern catalog: layout cache on AST nodes / dangerous refs.)
// The map itself lives on Context (ctx.interp_type_defs); this reader
// reaches it through codegen_lp(), which interpret_units installs
// before any eval runs.
lookup_interp_type_def := func(name: Str) returns ref Expr {
    ref m : Map = codegen_lp().ctx.interp_type_defs
    if m.has(name).not() { return NULL }
    return deref(m.get(name))
}

val_none := func() returns shallow Value {
    return Value.None
}
val_i64 := func(shallow v: I64) returns shallow Value {
    return Value.Int(v)
}
val_u8 := func(shallow v: I64) returns shallow Value {
    return Value.Byte(v.to_u8())
}
val_i16 := func(shallow v: I64) returns shallow Value {
    return Value.Short(v.to_i16())
}
val_i32 := func(shallow v: I64) returns shallow Value {
    return Value.Int32(v.to_i32())
}
val_u32 := func(shallow v: I64) returns shallow Value {
    return Value.Uint32(v.to_u32())
}
val_u64 := func(shallow v: U64) returns shallow Value {
    return Value.Uint64(v)
}
val_f32 := func(shallow v: F32) returns shallow Value {
    return Value.Float(v)
}
val_bool := func(shallow v: Bool) returns shallow Value {
    return Value.Boolean(v)
}

ENUM_PAYLOAD_OFFSET := 8.to_i32()

val_enum_flat := func(enum_name: Str, shallow etag: I32, payload_data: Dynamic, shallow payload_size: I32) returns shallow Value {
    mut total := ENUM_PAYLOAD_OFFSET.add(payload_size)
    if total.lt(8) {
        total = 8
    }
    mut data : U8 = calloc(1, total.to_u64())
    memcpy(data, etag, 4)
    if is_null(payload_data).not() {
        if payload_size.gt(0) {
            memcpy(ptr_add(data, ENUM_PAYLOAD_OFFSET.to_u64()), payload_data, payload_size.to_u64())
        }
    }
    return Value.Enum(EnumInstance(enum_name = enum_name, data = data, data_size = total))
}

val_enum_simple := func(enum_name: Str, shallow etag: I32) returns shallow Value {
    return val_enum_flat(enum_name, etag, NULL, 0)
}

elem_size_for_type := func(type_name: Str) returns shallow I32 {
    if type_name.eq("I64") { return I64.size().to_i32() }
    if type_name.eq("U8") { return U8.size().to_i32() }
    if type_name.eq("I16") { return I16.size().to_i32() }
    if type_name.eq("I32") { return I32.size().to_i32() }
    if type_name.eq("U32") { return U32.size().to_i32() }
    if type_name.eq("Bool") { return Bool.size().to_i32() }
    if type_name.eq("Str") { return 24 }
    return 8
}

parse_cli_arg := func(s: Str, type_name: Str) returns shallow Value {
    if type_name.eq("Str") { return make_str_value(s.c_str, s.count.to_u64()) }
    if type_name.eq("I64") { return val_i64(s.to_i64()) }
    if type_name.eq("U8") { return val_u8(s.to_i64()) }
    if type_name.eq("I16") { return val_i16(s.to_i64()) }
    if type_name.eq("I32") { return val_i32(s.to_i64()) }
    if type_name.eq("U32") { return val_u32(s.to_i64()) }
    if type_name.eq("Bool") {
        if s.eq("true") { return val_bool(true) }
        if s.eq("false") { return val_bool(false) }
    }
    return val_none()
}

// Borrowed pointer-view accessor: returns the slot ref backing a
// Value.Ref (borrowed view) or Value.Dynamic (owning opaque pointer).
// Neither variant is freed here; this is a read-only view helper.
value_ptr_view := func(v: Value) returns ref Dynamic {
    switch v {
    case Value.Ref(p):     return p
    case Value.Dynamic(p): return p
    case: return NULL
    }
}

is_value_ptr := func(v: Value) returns shallow Bool {
    return v.is(Value.Ref).or(v.is(Value.Dynamic))
}

// For pointer-like objects (Value.Ref / Value.Dynamic) whose static type
// is Struct/Enum/Custom, look up the type's def in scope and reinterpret
// the pointer as a struct value so subsequent field-access has a struct
// to read from.
priv resolve_ptr_to_struct := func(mut obj: Value, scope: Scope, obj_sname: Str) {
    if obj_sname.len().eq(0) { return }
    ref tc : Cell = scope_get(scope, obj_sname.clone())
    if is_null(tc) { return }
    switch tc.val {
    case Value.Func(tptr):
        ref tdef : Expr = deref(tptr)
        if tdef.node_type.is(NodeType.StructDef) {
            if is_value_ptr(obj) {
                ref pv : Dynamic = value_ptr_view(obj)
                obj = make_struct_value(obj_sname, tdef, deref(pv), true)
            }
        }
    case:
    }
}

eval_expr := proc(scope: Scope, e: Expr) returns shallow Value {
    switch e.node_type {
    case NodeType.Literal(Literal.Str(raw)):
        buf : Dynamic = malloc(raw.count.to_u64().add(1))
        mut j : U64 = 0
        mut i : U64 = 0
        while i.lt(raw.count.to_u64()) {
            ref ch : I8 = raw.byte_at(i.to_usize())
            if ch.eq(92) {
                if i.add(1).lt(raw.count.to_u64()) {
                    ref next : I8 = raw.byte_at(i.add(1).to_usize())
                    if next.eq(110) { memset(ptr_add(buf, j), 10, 1); j = j.add(1); i = i.add(2); continue }
                    if next.eq(116) { memset(ptr_add(buf, j), 9, 1); j = j.add(1); i = i.add(2); continue }
                    if next.eq(92) { memset(ptr_add(buf, j), 92, 1); j = j.add(1); i = i.add(2); continue }
                    if next.eq(34) { memset(ptr_add(buf, j), 34, 1); j = j.add(1); i = i.add(2); continue }
                    if next.eq(48) { memset(ptr_add(buf, j), 0, 1); j = j.add(1); i = i.add(2); continue }
                }
            }
            memcpy(ptr_add(buf, j), ptr_add(raw.c_str, i), 1)
            j = j.add(1)
            i = i.add(1)
        }
        memset(ptr_add(buf, j), 0, 1)
        v := make_str_value(buf, j)
        free(own buf)
        return v
    case NodeType.Literal(Literal.Num(num_str)):
        lit_t := expr_til_type(e)
        switch lit_t {
        case Type.U8:  return val_u8(num_str.to_i64())
        case Type.U32: return val_u32(num_str.to_i64())
        case Type.U64: return val_u64(num_str.to_u64())
        case Type.Primitive(Primitive.I16): return val_i16(num_str.to_i64())
        case Type.I32: return val_i32(num_str.to_i64())
        case Type.F32: return val_f32(num_str.to_f32())
        case Type.Struct(s):
            if s.eq("I32") { return val_i32(num_str.to_i64()) }
            if s.eq("U8")  { return val_u8(num_str.to_i64()) }
            return val_i64(num_str.to_i64())
        case: return val_i64(num_str.to_i64())
        }
    case NodeType.Literal(Literal.Bool(b)):
        return val_bool(b)
    case NodeType.Literal(Literal.Null):
        return Value.Ref(NULL)
    case NodeType.Ident(ident):
        ref cell : Cell = scope_get(scope, ident_name(ident))
        if is_null(cell) {
            interp_error(e, format("undefined variable '", ident_name(ident), "'"))
            exit(1)
        }
        return shallow_copy_value(cell.val)
    case NodeType.FCall:
        return eval_call(scope, e)
    case NodeType.FuncDef:
        return Value.Func(e)
    case NodeType.StructDef:
        return Value.Func(e)
    case NodeType.EnumDef:
        return Value.Func(e)
    case NodeType.FieldAccess(fname):
        mut obj := eval_expr(scope, e.child(0))
        if interp_fa_is_ns(scope, e) {
            mut sname := ""
            switch obj {
            case Value.Struct(si):
                sname = si.struct_name
            case:
                switch e.child(0).node_type {
                case NodeType.Ident(ident):
                    sname = ident_name(ident)
                case:
                    // Primitive receiver (LiteralNum I64, etc.).
                    sname = til_type_name_c(expr_til_type(e.child(0)))
                }
            }
            ref nsv : Value = ns_get(sname, field_access_name(fname))
            if is_null(nsv).not() {
                switch nsv {
                case Value.Int(iv):     return val_i64(iv)
                case Value.Int32(iv):   return val_i32(iv.to_i64())
                case Value.Func(fptr):
                    if expr_til_type(e).is(Type.Enum) {
                        ref fdef : Expr = deref(fptr)
                        switch fdef.node_type {
                        case NodeType.FuncDef(fd):
                            if fd.func_type.is(FuncType.ExtFunc) {
                                ref tc : Cell = scope_get(scope, sname.clone())
                                if is_null(tc).not() {
                                    switch tc.val {
                                    case Value.Func(eptr):
                                        ref edef : Expr = deref(eptr)
                                        if edef.node_type.is(NodeType.EnumDef) {
                                            tag := enum_variant_tag(edef, field_access_name(fname))
                                            if tag.to_i64().gte(0) {
                                                if enum_has_payloads(edef) {
                                                    return val_enum_flat(sname, tag, NULL, 0)
                                                } else {
                                                    return val_i32(tag.to_i64())
                                                }
                                            }
                                        }
                                    case:
                                    }
                                }
                            }
                        case:
                        }
                    }
                case:
                }
                return shallow_copy_value(nsv)
            }
            interp_error(e, format("no namespace field '", field_access_name(fname), "'"))
            exit(1)
        }
        if is_value_ptr(obj) {
            ref obj_expr : Expr = e.child(0)
            obj_t := expr_til_type(obj_expr)
            switch obj_t {
            case Type.Struct(obj_sname):
                resolve_ptr_to_struct(obj, scope, obj_sname)
            case Type.Enum(obj_sname):
                resolve_ptr_to_struct(obj, scope, obj_sname)
            case Type.Custom(obj_sname):
                resolve_ptr_to_struct(obj, scope, obj_sname)
            case:
            }
        }
        if obj.is(Value.Struct).not() {
            interp_error(e, "field access on non-struct")
            exit(1)
        }
        switch obj {
        case Value.Struct(si):
            ref fdecl : Declaration = find_field_decl(si.struct_def, field_access_name(fname))
            if is_null(fdecl) {
                interp_error(e, format("no field '", field_access_name(fname), "'"))
                exit(1)
            }
            return read_field(si.data, fdecl)
        case:
            UNREACHABLE(__LOC__)
            return val_none()
        }
    case:
        interp_lang_error(e, "cannot evaluate node as expression")
        exit(1)
        return val_none()
    }
}

// Reinterpret a pointer-like Value (Value.Ref / Value.Dynamic) to the
// appropriate scalar/struct/enum Value based on a type name. Used by
// eval_call (param binding) and eval_body (ref decl).
reinterpret_ptr_value := func(val: Value, type_name: Str, scope: Scope) returns Value {
    if is_value_ptr(val) {
        ref pv : Dynamic = value_ptr_view(val)
        ref p : Dynamic = deref(pv)
        if is_null(p) { return shallow_copy_value(val) }
        if type_name.len().eq(0) { return shallow_copy_value(val) }
        // Dynamic is a void-pointer type; the slot pointer IS the value, no
        // narrowing needed. Without this early-return the generic StructDef
        // lookup below would match Dynamic (registered as StructDef in
        // src/core/dyn.til) and wrap the pointer into a Value.Struct, which
        // breaks downstream code that expects ref-Dynamic bindings to stay
        // as Value.Ref/Value.Dynamic (#180).
        if type_name.eq("Dynamic") { return shallow_copy_value(val) }
        if type_name.eq("I64") { ref v : I64 = p; return val_i64(v) }
        if type_name.eq("U8") { ref v : U8 = p; return val_u8(v.to_i64()) }
        if type_name.eq("I16") { ref v : I16 = p; return val_i16(v.to_i64()) }
        if type_name.eq("I32") { ref v : I32 = p; return val_i32(v.to_i64()) }
        if type_name.eq("U32") { ref v : U32 = p; return val_u32(v.to_i64()) }
        if type_name.eq("U64") { ref v : U64 = p; return val_u64(v) }
        if type_name.eq("USize") { ref v : U32 = p; return val_u32(v.to_i64()) }
        if type_name.eq("UPtr") {
            ref lp : LoadedProgram = codegen_lp()
            ref uptr_name : Str = resolve_type_alias(lp.ctx.scope, "UPtr")
            if uptr_name.eq("U32") { ref v : U32 = p; return val_u32(v.to_i64()) }
            ref v : U64 = p
            return val_u64(v)
        }
        if type_name.eq("F32") { ref v : F32 = p; return val_f32(v) }
        if type_name.eq("Bool") { ref v : Bool = p; return val_bool(v) }
        if type_name.eq("Str") {
            ref sp : Str = p
            return make_str_value_own(sp.c_str, sp.count.to_u64())
        }
        ref tc : Cell = scope_get(scope, type_name.clone())
        if is_null(tc).not() {
            switch tc.val {
            case Value.Func(fptr):
                ref tdef : Expr = deref(fptr)
                if tdef.node_type.is(NodeType.FuncDef) {
                    if tdef.children.len().eq(0) {
                        // FuncSig: dereference to get function pointer
                        ref fp : Dynamic = deref(p)
                        return Value.Func(fp)
                    }
                }
                if tdef.node_type.is(NodeType.EnumDef) {
                    ref etag : I32 = p
                    if enum_has_payloads(tdef) {
                        ecopy : Dynamic = malloc(8)
                        memcpy(ecopy, ptr_add(p, ENUM_PAYLOAD_OFFSET.to_u64()), 8)
                        return val_enum_flat(type_name, etag, ecopy, 8)
                    }
                    return val_i32(etag.to_i64())
                }
                if tdef.node_type.is(NodeType.StructDef) {
                    return make_struct_value(type_name, tdef, p, true)
                }
            case:
            }
        }
        return shallow_copy_value(val)
    }
    return shallow_copy_value(val)
}

// Check if call should be skipped because first own param is None/borrowed/pointer-like.
// Returns true if call should be skipped (caller returns val_none).
guard_own_param_skip := func(scope: Scope, e: Expr, func_def: Expr) returns shallow Bool {
    switch func_def.node_type {
    case NodeType.FuncDef(fd):
        if fd.params.len().eq(0) { return false }
        ref p0 : Declaration = fd.params.get(0)
        if p0.own_type.is(OwnType.Own).not() { return false }
        if e.children.len().lte(1) { return false }
        switch e.child(1).node_type {
        case NodeType.Ident(arg_ident):
            ref fc : Cell = scope_get(scope, ident_name(arg_ident))
            if is_null(fc) { return false }
            if fc.val.is(Value.None) { return true }
            switch fc.val {
            case Value.Struct(si):
                if si.borrowed { memcpy(fc.val, val_none(), Value.size()); return true }
            case:
            }
            if is_value_ptr(fc.val) { memcpy(fc.val, val_none(), Value.size()); return true }
            return false
        case:
            return false
        }
    case:
        UNREACHABLE(__LOC__)
        return false
    }
}

resolve_field_assign_base := func(scope: Scope, obj_expr: Expr) returns ref Dynamic {
    switch obj_expr.node_type {
    case NodeType.Ident(ident):
        ref cell : Cell = scope_get(scope, ident_name(ident))
        if is_null(cell) { return NULL }
        switch cell.val {
        case Value.Struct(si):
            return si.data
        case:
            return NULL
        }
    case:
        return NULL
    }
}

resolve_field_assign_sdef := func(scope: Scope, obj_expr: Expr) returns ref Expr {
    switch obj_expr.node_type {
    case NodeType.Ident(ident):
        ref cell : Cell = scope_get(scope, ident_name(ident))
        if is_null(cell) { return NULL }
        switch cell.val {
        case Value.Struct(si):
            return si.struct_def
        case:
            return NULL
        }
    case:
        return NULL
    }
}

eval_body := proc(scope: Scope, mut body: Expr) {
    ref mut c : Context = codegen_lp().ctx
    for mut e_i : Expr in body.children {
        if c.has_return { return }
        if c.has_break { return }
        if c.has_continue { return }
        ref mut stmt : Expr = e_i
        switch stmt.node_type {
        case NodeType.Decl(dd):
            ref rhs : Expr = stmt.child(0)
            if expr_til_type(stmt).is(Type.None) {
                if rhs.node_type.is(NodeType.Ident) { continue }
            }
            if dd.own_type.is(OwnType.Ref) {
                switch rhs.node_type {
                case NodeType.Ident(rhs_ident):
                    ref src : Cell = scope_get(scope, ident_name(rhs_ident))
                    scope_set_borrowed(scope, dd.name, src)
                    continue
                case:
                }
            }
            mut val := val_none()
            switch rhs.node_type {
            case NodeType.Ident(rhs_ident):
                ref src : Cell = scope_get(scope, ident_name(rhs_ident))
                if is_null(src) {
                    interp_error(rhs, "undefined variable '".concat(ident_name(rhs_ident)).concat("'"))
                    exit(1)
                }
                val = shallow_copy_value(src.val)
                if val.is(Value.Func).not() {
                    memcpy(src.val, val_none(), Value.size())
                }
            case:
                val = eval_expr(scope, rhs)
            }
            if dd.own_type.is(OwnType.Ref) {
                if dd.explicit_type.len().gt(0) {
                    val = reinterpret_ptr_value(val, dd.explicit_type, scope)
                }
            }
            scope_set_owned(scope, dd.name, val)
        case NodeType.Assign(ad):
            ref rhs : Expr = stmt.child(0)
            ref cell : Cell = scope_get(scope, ad.name.clone())
            if is_null(cell) {
                interp_error(stmt, "undefined variable '".concat(ad.name).concat("'"))
                exit(1)
            }
            if expr_til_type(stmt).is(Type.Dynamic) {
                if rhs.node_type.is(NodeType.Ident) {
                    switch rhs.node_type {
                    case NodeType.Ident(rhs_ident):
                        ref src : Cell = scope_get(scope, ident_name(rhs_ident))
                        memcpy(cell.val, src.val, Value.size())
                        if src.val.is(Value.Func).not() {
                            memcpy(src.val, val_none(), Value.size())
                        }
                    case:
                    }
                    continue
                }
            }
            new_val := eval_expr(scope, rhs)
            memcpy(cell.val, new_val, Value.size())
        case NodeType.FieldAssign(fname):
            ref val_expr : Expr = stmt.child(1)
            mut val := val_none()
            ref move_src : Cell = field_assign_dyn_move_src(scope, val_expr)
            if is_null(move_src).not() {
                val = shallow_copy_value(move_src.val)
            } else {
                val = eval_expr(scope, val_expr)
            }
            if interp_fa_is_ns(scope, stmt) {
                obj := eval_expr(scope, stmt.child(0))
                mut sname := ""
                switch obj {
                case Value.Struct(si):
                    sname = si.struct_name
                case:
                    switch stmt.child(0).node_type {
                    case NodeType.Ident(oi):
                        sname = ident_name(oi)
                    case:
                    }
                }
                ns_set(sname, fname.clone(), val)
                if is_null(move_src).not() { memcpy(move_src.val, val_none(), Value.size()) }
            } else {
                ref mut base : Dynamic = resolve_field_assign_base(scope, stmt.child(0))
                ref mut cur_sdef : Expr = resolve_field_assign_sdef(scope, stmt.child(0))
                // Chain walking for nested field access (e.g. a.b.c = val)
                if stmt.child(0).node_type.is(NodeType.FieldAccess) {
                    ref mut cur : Expr = stmt.child(0)
                    mut depth : I32 = 0
                    while cur.node_type.is(NodeType.FieldAccess) {
                        depth = depth.add(1)
                        cur = cur.child(0)
                    }
                    switch cur.node_type {
                    case NodeType.Ident(root_ident):
                        ref cell : Cell = scope_get(scope, ident_name(root_ident))
                        if is_null(cell).not() {
                            switch cell.val {
                            case Value.Struct(si):
                                base = to_ptr(si.data)
                                cur_sdef = si.struct_def
                                // For simplicity, handle depth=1 (most common: a.field = val)
                                if depth.eq(1) {
                                    switch stmt.child(0).node_type {
                                    case NodeType.FieldAccess(fa_name):
                                            ref fd : Declaration = find_field_decl(cur_sdef, field_access_name(fa_name))
                                        if is_null(fd).not() {
                                            if fd.own_type.is(OwnType.Shallow).not() {
                                                base = deref(ptr_add(base, fd.field_offset.to_u64()))
                                            } else {
                                                base = ptr_add(base, fd.field_offset.to_u64())
                                            }
                                            cur_sdef = fd.field_struct_def
                                        }
                                    case:
                                    }
                                }
                            case:
                            }
                        }
                    case:
                    }
                }
                if is_null(base) {
                    interp_error(stmt, "field assign on non-struct")
                    exit(1)
                }
                if is_null(cur_sdef) {
                    interp_error(stmt, "field assign on non-struct")
                    exit(1)
                }
                ref fdecl : Declaration = find_field_decl(cur_sdef, fname.clone())
                write_field(base, fdecl, val)
                if is_null(move_src).not() {
                    if move_src.val.is(Value.Func).not() {
                        memcpy(move_src.val, val_none(), Value.size())
                    }
                }
            }
        case NodeType.FCall:
            eval_call(scope, stmt)
        case NodeType.Body:
            block_scope := scope_new(scope)
            eval_body(block_scope, stmt)
            if c.has_return {
                c.return_value = c.return_value.clone()
            }
            scope_free(own block_scope)
        case NodeType.If:
            cond := eval_expr(scope, stmt.child(0))
            mut cv := false
            switch cond {
            case Value.Boolean(b):
                cv = b
            case:
                UNREACHABLE(__LOC__)
            }
            if cv {
                then_scope := scope_new(scope)
                eval_body(then_scope, stmt.child(1))
                if c.has_return { c.return_value = c.return_value.clone() }
                scope_free(own then_scope)
            } else if stmt.children.len().gt(2) {
                else_scope := scope_new(scope)
                eval_body(else_scope, stmt.child(2))
                if c.has_return { c.return_value = c.return_value.clone() }
                scope_free(own else_scope)
            }
        case NodeType.While:
            while true {
                if c.has_return { break }
                cond := eval_expr(scope, stmt.child(0))
                mut cv := false
                switch cond {
                case Value.Boolean(b):
                    cv = b
                case:
                    UNREACHABLE(__LOC__)
                }
                if cv.not() { break }
                while_scope := scope_new(scope)
                eval_body(while_scope, stmt.child(1))
                if c.has_return { c.return_value = c.return_value.clone() }
                scope_free(own while_scope)
                if c.has_break { c.has_break = false; break }
                if c.has_continue { c.has_continue = false }
            }
        case NodeType.Break:
            c.has_break = true
        case NodeType.Continue:
            c.has_continue = true
        case NodeType.Return:
            if stmt.children.len().gt(0) {
                c.return_value = eval_expr(scope, stmt.child(0))
            } else {
                c.return_value = val_none()
            }
            c.has_return = true
        case:
            interp_lang_error(stmt, "unexpected statement type")
            exit(1)
        }
    }
}

eval_call := proc(scope: Scope, e: Expr) returns shallow Value {
    ref mut c : Context = codegen_lp().ctx
    ref callee_expr : Expr = e.child(0)

    // Namespace method call: Struct.method(args)
    if callee_expr.node_type.is(NodeType.FieldAccess) {
        fn_val := eval_expr(scope, callee_expr)
        switch fn_val {
        case Value.Func(fn_ptr):
        ref func_def : Expr = deref(fn_ptr)

        // FuncPtr field: stored function may be ext_func from another type
        if expr_til_type(callee_expr).is(Type.FuncPtr) {
            mut fp_func_type := FuncType.None
            switch func_def.node_type {
            case NodeType.FuncDef(fp_fdef):
                fp_func_type = fp_fdef.func_type
            case:
                UNREACHABLE(__LOC__)
            }
            if fp_func_type.is(FuncType.ExtFunc).or(fp_func_type.is(FuncType.ExtProc)) {
                for ki in 0..c.ns_fields.len() {
                    ref qn : Str = Map.key_ptr(c.ns_fields, ki)
                    ref nsv : Value = Map.val_ptr(c.ns_fields, ki)
                    switch nsv {
                    case Value.Func(nsv_fptr):
                        ref nsv_fdef : Expr = deref(nsv_fptr)
                        if ptr_eq(nsv_fdef, func_def) {
                            fp_flat := qn.replace(".", "_")
                            orig_callee := callee_expr.clone()
                            mut flat_ident := callee_expr.clone()
                            flat_ident.node_type = ident_node(fp_flat.clone())
                            // Replace the inline Expr slot through Vec so the
                            // old callee gets dropped before we swap in the
                            // flattened Ident.
                            e.children.replace(0, own flat_ident)
                            result := eval_call(scope, e)
                            e.children.replace(0, own orig_callee)
                            return result
                        }
                    case:
                    }
                }
            }
        }
        // Direct ext_func namespace method -- dispatch by flat name
        mut fdef_func_type := FuncType.None
        switch func_def.node_type {
        case NodeType.FuncDef(fdef_ns):
            fdef_func_type = fdef_ns.func_type
        case:
            UNREACHABLE(__LOC__)
        }
        if fdef_func_type.is(FuncType.ExtFunc).or(fdef_func_type.is(FuncType.ExtProc)) {
            parent_sname := til_type_name(expr_til_type(callee_expr.child(0)))
            ref tc : Cell = scope_get(scope, parent_sname.clone())
            if is_null(tc).not() {
                switch tc.val {
                case Value.Func(tc_fptr):
                    ref tc_edef : Expr = deref(tc_fptr)
                    if tc_edef.node_type.is(NodeType.EnumDef) {
                        switch callee_expr.node_type {
                        case NodeType.FieldAccess(callee_ident):
                            mut eresult := val_none()
                            if enum_method_dispatch(field_access_name(callee_ident), scope, tc_edef, parent_sname, e, eresult) {
                                for oi in 1..e.children.len() {
                                    ref oa : Expr = e.child(oi)
                                    if oa.node_type.is(NodeType.Ident).and(get_own_arg(e, oi)) {
                                        switch oa.node_type {
                                        case NodeType.Ident(oa_ident):
                                            ref oc : Cell = scope_get(scope, ident_name(oa_ident))
                                            if is_null(oc).not() { oc.val = val_none() }
                                        case:
                                            UNREACHABLE(__LOC__)
                                        }
                                    }
                                }
                                return eresult
                            }
                        case:
                            UNREACHABLE(__LOC__)
                        }
                    }
                case:
                }
            }
            mut sn := til_type_name(expr_til_type(callee_expr.child(0)))
            // til_type_name returns "" for primitives. For ext_func
            // dispatch on a primitive receiver (e.g. `0.sub(1)` ->
            // `I64_sub(0, 1)`), fall back to til_type_name_c.
            if sn.is_empty() {
                tn := til_type_name_c(expr_til_type(callee_expr.child(0)))
                if tn.eq("unknown").not().and(tn.eq("?").not()).and(tn.eq("Dynamic").not()) {
                    sn = tn
                }
            }
            switch callee_expr.node_type {
            case NodeType.FieldAccess(fn_name):
                // If the receiver type is unknown (eg Dynamic), fall back to
                // the unqualified top-level name. Required for and/or/not.
                mut flat_str := field_access_name(fn_name)
                if sn.len().gt(0) {
                    flat_str = sn.format("_", field_access_name(fn_name))
                }
                orig_callee_val := callee_expr.clone()
                mut flat_ident2 := callee_expr.clone()
                flat_ident2.node_type = ident_node(flat_str.clone())
                // Replace the inline Expr slot through Vec so the old callee
                // gets dropped before we swap in the flattened Ident.
                e.children.replace(0, own flat_ident2)
                result := eval_call(scope, e)
                e.children.replace(0, own orig_callee_val)
                return result
            case:
                UNREACHABLE(__LOC__)
            }
        }

        // Regular function body call
        ref body_ns : Expr = func_def.child(0)
        if guard_own_param_skip(scope, e, func_def) { return val_none() }
        call_scope := scope_new(scope)
        switch func_def.node_type {
        case NodeType.FuncDef(fdef_params):
            for pi in 0..fdef_params.params.len() {
                ref param : Declaration = fdef_params.params.get(pi)
                ref arg_expr : Expr = e.child(pi.add(1))
                switch arg_expr.node_type {
                case NodeType.Ident(arg_ident):
                    ref arg_cell : Cell = scope_get(scope, ident_name(arg_ident))
                    if is_null(arg_cell) {
                        interp_error(arg_expr, "undefined variable '".concat(ident_name(arg_ident)).concat("'"))
                        exit(1)
                    }
                    if is_value_ptr(arg_cell.val).and(param.explicit_type.len().gt(0)) {
                        mut arg := reinterpret_ptr_value(arg_cell.val, param.explicit_type, scope)
                        arg = widen_numeric(arg, param.explicit_type)
                        scope_set_owned(call_scope, param.name, arg)
                    } else if needs_widen(arg_cell.val, param.explicit_type) {
                        mut arg := arg_cell.val.clone()
                        arg = widen_numeric(arg, param.explicit_type)
                        scope_set_owned(call_scope, param.name, arg)
                    } else {
                        scope_set_borrowed(call_scope, param.name, arg_cell)
                    }
                case:
                    mut arg := eval_expr(scope, arg_expr)
                    if is_value_ptr(arg).and(param.explicit_type.len().gt(0)) {
                        arg = reinterpret_ptr_value(arg, param.explicit_type, scope)
                    }
                    arg = widen_numeric(arg, param.explicit_type)
                    scope_set_owned(call_scope, param.name, arg)
                }
            }
        case:
        }
        c.has_return = false
        eval_body(call_scope, body_ns)
        mut result := val_none()
        if c.has_return {
            result = c.return_value.clone()
            c.has_return = false
        }
        scope_free(own call_scope)
        return result
        case:
            interp_error(e, "namespace field is not a function")
            exit(1)
            return val_none()
        }
    }

    // Direct ident call
    switch callee_expr.node_type {
    case NodeType.Ident(name):

    // Ext function dispatch
    mut ext_result := val_none()
    if ext_function_dispatch(ident_name(name), scope, e, ext_result) {
        for oi in 1..e.children.len() {
            ref oa : Expr = e.child(oi)
            if get_own_arg(e, oi) {
                switch oa.node_type {
                case NodeType.Ident(oa_ident):
                    ref oc : Cell = scope_get(scope, ident_name(oa_ident))
                    if is_null(oc).not() { oc.val = val_none() }
                case:
                }
            }
        }
        return ext_result
    }

    // User-defined function or struct instantiation
    ref fn_cell : Cell = scope_get(scope, ident_name(name))
    if is_null(fn_cell) {
        interp_error(e, ident_name(name).concat(" is undefined"))
        exit(1)
    }

    // Struct instantiation
    switch fn_cell.val {
    case Value.Func(si_fptr):
        ref si_edef : Expr = deref(si_fptr)
        if si_edef.node_type.is(NodeType.StructDef) {
            switch si_edef.node_type {
            case NodeType.StructDef(sdd):
                inst_data : Dynamic = calloc(1, sdd.total_struct_size.to_usize())
                mut inst := val_none()
                switch e.node_type {
                case NodeType.FCall(fcd_ctor):
                    switch fcd_ctor.til_type {
                    case Type.Struct(es):
                        if es.len().gt(0) { inst = make_struct_value(es, si_edef, inst_data, false) }
                        else              { inst = make_struct_value(ident_name(name), si_edef, inst_data, false) }
                    case Type.Enum(es):
                        if es.len().gt(0) { inst = make_struct_value(es, si_edef, inst_data, false) }
                        else              { inst = make_struct_value(ident_name(name), si_edef, inst_data, false) }
                    case Type.Custom(es):
                        if es.len().gt(0) { inst = make_struct_value(es, si_edef, inst_data, false) }
                        else              { inst = make_struct_value(ident_name(name), si_edef, inst_data, false) }
                    case:
                        inst = make_struct_value(ident_name(name), si_edef, inst_data, false)
                    }
                case:
                    inst = make_struct_value(ident_name(name), si_edef, inst_data, false)
                }
                switch inst {
                case Value.Struct(si_inst):
                    mut arg_idx : U32 = 1
                    for fdd : Declaration in sdd.fields {
                        ref arg : Expr = e.child(arg_idx)
                        arg_idx = arg_idx.add(1)
                        mut val := val_none()
                        switch arg.node_type {
                        case NodeType.Ident(arg_ident):
                            ref src : Cell = scope_get(scope, ident_name(arg_ident))
                            if is_null(src) {
                                interp_error(arg, "undefined variable '".concat(ident_name(arg_ident)).concat("'"))
                                exit(1)
                            }
                            val = shallow_copy_value(src.val)
                            if get_own_arg(e, arg_idx).and(val.is(Value.Func).not()) {
                                src.val = val_none()
                            }
                        case:
                            val = eval_expr(scope, arg)
                        }
                        write_field(si_inst.data, fdd, val)
                    }
                case:
                    UNREACHABLE(__LOC__)
                }
                return inst
            case:
                UNREACHABLE(__LOC__)
            }
        }
    case:
    }

    if fn_cell.val.is(Value.Func).not() {
        interp_error(e, name.clone().concat(" is not a function"))
        exit(1)
    }

    switch fn_cell.val {
    case Value.Func(fc_fptr):
        ref func_def2 : Expr = deref(fc_fptr)
        ref body2 : Expr = func_def2.child(0)

        // Guard: skip call if first 'own' param is val_none, borrowed struct, or Ptr
        switch func_def2.node_type {
        case NodeType.FuncDef(fdef2):
            if fdef2.params.len().gt(0).and(e.children.len().gt(1)) {
                ref first_param : Declaration = fdef2.params.get(0)
                if first_param.own_type.is(OwnType.Own) {
                    ref first_arg : Expr = e.child(1)
                    switch first_arg.node_type {
                    case NodeType.Ident(fa_ident):
                        ref fc : Cell = scope_get(scope, ident_name(fa_ident))
                        if is_null(fc).not() {
                            if fc.val.is(Value.None) { return val_none() }
                            switch fc.val {
                            case Value.Struct(fsi):
                                if fsi.borrowed {
                                    fc.val = val_none()
                                    return val_none()
                                }
                            case:
                            }
                            if is_value_ptr(fc.val) {
                                fc.val = val_none()
                                return val_none()
                            }
                        }
                    case:
                    }
                }
            }

            call_scope2 := scope_new(scope)
            nparam2 := fdef2.params.len()
            for pi in 0..nparam2 {
                ref arg_expr : Expr = e.child(pi.add(1))
                ref param : Declaration = fdef2.params.get(pi)
                switch arg_expr.node_type {
                case NodeType.Ident(arg_ident):
                    ref arg_cell : Cell = scope_get(scope, ident_name(arg_ident))
                    if is_null(arg_cell) {
                        interp_error(arg_expr, "undefined variable '".concat(ident_name(arg_ident)).concat("'"))
                        exit(1)
                    }
                    if needs_widen(arg_cell.val, param.explicit_type) {
                        mut arg := arg_cell.val.clone()
                        arg = widen_numeric(arg, param.explicit_type)
                        scope_set_owned(call_scope2, param.name, arg)
                    } else {
                        scope_set_borrowed(call_scope2, param.name, arg_cell)
                    }
                case:
                    mut arg := eval_expr(scope, arg_expr)
                    arg = widen_numeric(arg, param.explicit_type)
                    scope_set_owned(call_scope2, param.name, arg)
                }
            }

            c.has_return = false
            eval_body(call_scope2, body2)
            mut result := val_none()
            if c.has_return {
                result = c.return_value.clone()
                c.has_return = false
            }
            scope_free(own call_scope2)
            return result
        case:
            UNREACHABLE(__LOC__)
            return val_none()
        }
    case:
        UNREACHABLE(__LOC__)
        return val_none()
    }
    case:
        UNREACHABLE(__LOC__)
        return val_none()
    }
}

free_value := func(shallow v: Value) {
    switch v {
    case Value.Struct(si):
        if si.borrowed.not() {
            if is_null(si.data).not() { free(own si.data) }
        }
    case Value.Enum(ei):
        if is_null(ei.data).not() { free(own ei.data) }
    case:
    }
}

// End-of-lifetime cleanup for a Value's heap payload. Goes deeper than
// free_value: also frees the c_str of a Value.Struct whose name is "Str".
// Used by scope_free and precomp's known-map teardown, where the Value
// genuinely owns the payload.
cleanup_value_payload := func(shallow v: Value) {
    switch v {
    case Value.Struct(si):
        if si.borrowed.not() {
            if is_null(si.data).not() {
                if si.struct_name.eq("Str") {
                    ref s_str : Str = to_ptr(si.data)
                    // Only free c_str when count > 0: StructInstance.clone
                    // for "Str" memcpy-shares c_str when count == 0.
                    if s_str.count.to_i64().gt(0).and(s_str.cap.lt(CAP_VIEW)) {
                        if is_null(s_str.c_str).not() { free(own s_str.c_str) }
                    }
                }
                free(own si.data)
            }
        }
    case Value.Enum(ei):
        if is_null(ei.data).not() { free(own ei.data) }
    case:
    }
}

needs_widen := func(val: Value, ptype: Str) returns shallow Bool {
    if is_null(ptype) { return false }
    if ptype.len().eq(0) { return false }
    if val.is(Value.Byte) {
        return ptype.eq("U8").not()
    }
    if val.is(Value.Short) {
        return ptype.eq("I16").not()
    }
    if val.is(Value.Int32) {
        return ptype.eq("I32").not()
    }
    if val.is(Value.Uint32) {
        return ptype.eq("U32").not()
    }
    return false
}

shallow_copy_value := func(v: Value) returns shallow Value {
    mut r := Value.None
    memcpy(r, v, Value.size())
    return r
}

make_struct_value := func(sname: Str, sdef: Expr, data: Dynamic, shallow borrowed: Bool) returns shallow Value {
    mut r := Value.None
    mut tag : I32 = 10
    memcpy(r, tag, 4)
    switch r {
    case Value.Struct(payload):
        payload.struct_name = sname
        payload.struct_def = sdef
        payload.data = data
        payload.borrowed = borrowed
    case:
        UNREACHABLE(__LOC__)
    }
    return shallow_copy_value(r)
}

widen_numeric := func(v: Value, ptype: Str) returns Value {
    if is_null(ptype) { return shallow_copy_value(v) }
    if ptype.len().eq(0) { return shallow_copy_value(v) }
    mut ival : I64 = 0
    mut uval : U64 = 0
    mut is_unsigned := false
    switch v {
    case Value.Byte(bv):
        uval = bv.to_u64()
        is_unsigned = true
    case Value.Short(sv):
        ival = sv.to_i64()
    case Value.Int32(iv):
        ival = iv.to_i64()
    case Value.Uint32(uv):
        uval = uv.to_u64()
        is_unsigned = true
    case:
        return shallow_copy_value(v)
    }
    if is_unsigned.not() { uval = ival.to_u64() }
    else { ival = uval.to_i64() }
    if ptype.eq("I64") {
        if is_unsigned { return val_i64(uval.to_i64()) }
        return val_i64(ival)
    }
    if ptype.eq("U64") { return val_u64(uval) }
    if ptype.eq("USize") { return val_u32(uval.to_i64()) }
    if ptype.eq("UPtr") {
        ref lp : LoadedProgram = codegen_lp()
        ref uptr_name : Str = resolve_type_alias(lp.ctx.scope, "UPtr")
        if uptr_name.eq("U32") { return val_u32(uval.to_i64()) }
        return val_u64(uval)
    }
    if ptype.eq("U32") {
        if v.is(Value.Byte) { return val_u32(uval.to_i64()) }
    }
    if ptype.eq("I32") {
        if v.is(Value.Byte) { return val_i32(ival) }
        if v.is(Value.Short) { return val_i32(ival) }
    }
    if ptype.eq("I16") {
        if v.is(Value.Byte) { return val_i16(ival) }
    }
    return shallow_copy_value(v)
}

scope_get := func(mut s: Scope, name: Str) returns ref Cell {
    ref mut cur : Scope = s
    while true {
        if is_null(cur) { return NULL }
        if cur.bindings.has(name) {
            ref b : Binding = cur.bindings.get(name)
            return b.cell
        }
        cur = cur.parent
    }
    return NULL
}

scope_new := func(parent: Scope) returns Scope {
    return Scope(parent = parent)
}
scope_set_owned := func(mut s: Scope, name: Str, val: Value) {
    if s.bindings.has(name) {
        ref b : Binding = s.bindings.get(name)
        free_value(b.cell.val)
        memcpy(b.cell.val, val, Value.size())
        return
    }
    cell : Dynamic = malloc(Cell.size().to_u64())
    memcpy(cell, val, Value.size())
    // Build Str view key: copy name then set cap to CAP_VIEW
    k : Dynamic = malloc(Str.size().to_u64())
    memcpy(k, name, Str.size().to_u64())
    memcpy(ptr_add(k, 12), CAP_VIEW, U32.size().to_u64())
    // Build Binding: {name_ptr, cell_ptr, cell_is_local=1}
    v : Dynamic = malloc(Binding.size().to_u64())
    memset(v, 0, Binding.size().to_u64())
    write_ptr(v, name)
    write_ptr(ptr_add(v, 8), cell)
    mut local_flag := true
    memcpy(ptr_add(v, 16), local_flag, Bool.size().to_u64())
    s.bindings.set(own k, own v)
}

scope_set_borrowed := func(mut s: Scope, name: Str, cell: Cell) {
    k : Dynamic = malloc(Str.size().to_u64())
    memcpy(k, name, Str.size().to_u64())
    memcpy(ptr_add(k, 12), CAP_VIEW, U32.size().to_u64())
    v : Dynamic = malloc(Binding.size().to_u64())
    memset(v, 0, Binding.size().to_u64())
    write_ptr(v, name)
    write_ptr(ptr_add(v, 8), cell)
    // cell_is_local = false (already zeroed by memset)
    s.bindings.set(own k, own v)
}
scope_free := func(own s: Scope) {
    for i in 0..s.bindings.len() {
        ref b : Binding = Map.val_ptr(s.bindings, i)
        if b.cell_is_local {
            switch b.cell.val {
            case Value.Enum(ei):
                if is_null(ei.data).not() { free(own ei.data) }
            case:
            }
            free(own b.cell)
        }
    }
    // Delete Map contents but not the Map struct (it's inline in Scope)
    own s.bindings.delete(false)
    // Zero out bindings so Scope destructor doesn't double-free
    memset(s.bindings, 0, Map.size().to_u64())
    free(own s)
}
// Body of interp_fa_is_ns_inner pulled out so both FieldAccess and
// FieldAssign cases (which share an Str payload) can switch-destructure
// `e.node_type` without duplicating ~50 lines of logic.
priv interp_fa_is_ns_with_fname := func(obj_expr: Expr, sname: Str, sdef: Expr, fname: Str) returns shallow Bool {
    mut has_ns := false
    mut has_inst := false
    ref ins_ns : Vec = def_ns_decls(sdef)
    for ins_d : Declaration in ins_ns {
        if ins_d.name.eq(fname) { has_ns = true }
    }
    switch sdef.node_type {
    case NodeType.StructDef(ins_sdd):
        for dd : Declaration in ins_sdd.fields {
            if dd.name.eq(fname) { has_inst = true }
        }
    case NodeType.EnumDef(ins_edd):
        for vn : Str in ins_edd.variants {
            if vn.eq(fname) { has_inst = true }
        }
    case:
    }
    if has_ns {
        if has_inst.not() { return true }
    }
    if has_ns.not() {
        if has_inst.not() {
            switch obj_expr.node_type {
            case NodeType.Ident(ident):
                if ident_name(ident).eq(sname) { return true }
                if ident.len().gt(0) {
                    if ident.byte_at(0).gte(65) {
                        if ident.byte_at(0).lte(90) { return true }
                    }
                }
            case:
            }
            return false
        }
    }
    if has_ns {
        if has_inst {
            switch obj_expr.node_type {
            case NodeType.Ident(ident):
                if ident_name(ident).eq(sname) { return true }
                if ident.len().gt(0) {
                    if ident.byte_at(0).gte(65) {
                        if ident.byte_at(0).lte(90) { return true }
                    }
                }
            case:
                return false
            }
        }
    }
    return false
}

interp_fa_is_ns_inner := func(scope: Scope, e: Expr, sname: Str) returns shallow Bool {
    ref obj_expr : Expr = e.child(0)
    ref tc : Cell = scope_get(scope, sname.clone())
    if is_null(tc) { return false }
    switch tc.val {
    case Value.Func(fptr):
        ref sdef : Expr = deref(fptr)
        if sdef.node_type.is(NodeType.StructDef).not() {
            if sdef.node_type.is(NodeType.EnumDef).not() { return false }
        }
        switch e.node_type {
        case NodeType.FieldAccess(fname):
            return interp_fa_is_ns_with_fname(obj_expr, sname, sdef, field_access_name(fname))
        case NodeType.FieldAssign(fname):
            return interp_fa_is_ns_with_fname(obj_expr, sname, sdef, fname)
        case:
            return false
        }
    case:
        return false
    }
}

// For FieldAssign rhs: when the value is a Dynamic Ident, return the
// source Cell so the caller can shallow-copy its value (move semantics
// for Dynamic). Returns NULL when the rhs isn't an Ident or isn't
// Dynamic, signalling "evaluate the expression normally".
field_assign_dyn_move_src := func(mut scope: Scope, val_expr: Expr) returns ref Cell {
    if expr_til_type(val_expr).is(Type.Dynamic).not() { return NULL }
    switch val_expr.node_type {
    case NodeType.Ident(vi): return scope_get(scope, ident_name(vi))
    case:
        return NULL
    }
}

interp_fa_is_ns := func(scope: Scope, e: Expr) returns shallow Bool {
    ref obj_expr : Expr = e.child(0)
    sname := til_type_name(expr_til_type(obj_expr))
    if sname.len().gt(0) { return interp_fa_is_ns_inner(scope, e, sname) }
    switch obj_expr.node_type {
    case NodeType.Ident(ident): return interp_fa_is_ns_inner(scope, e, ident_name(ident))
    case:
    }
    // Primitive receivers (`0.sub(1)`, recv = LiteralNum I64): til_type_name
    // returns "" for I64/U8/etc, fall back to til_type_name_c.
    tn := til_type_name_c(expr_til_type(obj_expr))
    if tn.eq("unknown").not().and(tn.eq("?").not()).and(tn.eq("Dynamic").not()) {
        return interp_fa_is_ns_inner(scope, e, tn)
    }
    return false
}

value_to_buf := func(dest: Dynamic, val: Value, type_name: Str) {
    switch val {
    case Value.Int(v):     if type_name.eq("I64")  { memcpy(dest, v, 8); return }
    case Value.Byte(v):    if type_name.eq("U8")   { memcpy(dest, v, 1); return }
    case Value.Short(v):   if type_name.eq("I16")  { memcpy(dest, v, 2); return }
    case Value.Int32(v):   if type_name.eq("I32")  { memcpy(dest, v, 4); return }
    case Value.Uint32(v):  if type_name.eq("U32")  { memcpy(dest, v, 4); return }
    case Value.Boolean(v): if type_name.eq("Bool") { memcpy(dest, v, 1); return }
    case Value.Struct(si):
        switch si.struct_def.node_type {
        case NodeType.StructDef(sd):
            sz := sd.total_struct_size
            if si.borrowed {
                mut cloned := val.clone()
                switch cloned {
                case Value.Struct(csi):
                    memcpy(dest, csi.data, sz.to_u64())
                    free(own csi.data)
                    csi.data = NULL
                case:
                }
            } else {
                memcpy(dest, si.data, sz.to_u64())
            }
        case:
        }
    case:
    }
}

build_argv_array := func(argv: Vec, shallow offset: U32, shallow count: U32, elem_type: Str) returns shallow Value {
    esz := elem_size_for_type(elem_type)
    mut alloc_count := count
    if alloc_count.eq(0) { alloc_count = 1 }
    data : Dynamic = calloc(alloc_count.to_u64(), esz.to_u64())
    for i in 0..count {
        ref s : Str = argv.get(offset.add(i))
        v := parse_cli_arg(s, elem_type)
        value_to_buf(ptr_add(data, i.to_u64().mul(esz.to_u64())), v, elem_type)
    }
    ref lp : LoadedProgram = codegen_lp()
    mut sz : I32 = 0
    switch lp.ctx.cached_array_def.node_type {
    case NodeType.StructDef(asd):
        sz = asd.total_struct_size
    case:
        UNREACHABLE(__LOC__)
    }
    inst_data : Dynamic = calloc(1, sz.to_u64())
    ref ba_data_d : Declaration = find_field_decl(lp.ctx.cached_array_def, "data")
    write_field(inst_data, ba_data_d, Value.Ref(data))
    ref ba_cap_d : Declaration = find_field_decl(lp.ctx.cached_array_def, "cap")
    write_field(inst_data, ba_cap_d, val_u32(count.to_i64()))
    ref ba_esz_d : Declaration = find_field_decl(lp.ctx.cached_array_def, "elem_size")
    write_field(inst_data, ba_esz_d, val_u32(esz.to_i64()))
    ref clone_fn : Value = ns_get(elem_type.clone(), "clone")
    if is_null(clone_fn).not() { ref ba_ec_d : Declaration = find_field_decl(lp.ctx.cached_array_def, "elem_clone"); write_field(inst_data, ba_ec_d, shallow_copy_value(clone_fn)) }
    ref delete_fn : Value = ns_get(elem_type.clone(), "delete")
    if is_null(delete_fn).not() { ref ba_ed_d : Declaration = find_field_decl(lp.ctx.cached_array_def, "elem_delete"); write_field(inst_data, ba_ed_d, shallow_copy_value(delete_fn)) }
    return make_struct_value(lp.ctx.cached_array_name, lp.ctx.cached_array_def, to_ptr(inst_data), false)
}

interpreter_init_ns := proc(mut ctx: Context, mut global: Scope, program: Expr) {
    if ctx.ns_inited.not() {
        ctx.ns_fields = Map.new(Str, Value)
        ctx.ns_keys = Vec.new(Dynamic)
        ctx.ns_inited = true
    }
    for stmt : Expr in program.children {
        switch stmt.node_type {
        case NodeType.Decl(dd):
            if stmt.children.len().eq(0) { continue }
            ref sdef : Expr = stmt.child(0)
            if sdef.node_type.is(NodeType.StructDef).not() {
                if sdef.node_type.is(NodeType.EnumDef).not() { continue }
            }
            if sdef.node_type.is(NodeType.StructDef) {
                if dd.name.eq("Str")   { ctx.cached_str_def   = stmt.child(0); ctx.cached_str_name   = dd.name }
                if dd.name.eq("Array") { ctx.cached_array_def = stmt.child(0); ctx.cached_array_name = dd.name }
                if dd.name.eq("Vec")   { ctx.cached_vec_def   = stmt.child(0); ctx.cached_vec_name   = dd.name }
            }
            // Register every struct/enum AST in the comprehensive type-def map
            // so readers can replace Declaration.field_struct_def with a name lookup.
            // Clone the name for owned-key safety -- a CAP_VIEW key dangles if the
            // AST gets rebuilt later in the run. The map value is a malloc'd cell
            // holding the Expr pointer (same encoding as ctx.struct_def_exprs).
            _tdv : Dynamic = malloc(I64.size())
            write_ptr(_tdv, sdef)
            ctx.interp_type_defs.set(own dd.name.clone(), own _tdv)
            ref ien_ns : Vec = def_ns_decls(sdef)
            for d_j : Declaration in ien_ns {
                ref nsd : Declaration = d_j
                if is_null(nsd.default_value) { continue }
                mut fval := eval_expr(global, nsd.default_value)
                if sdef.node_type.is(NodeType.EnumDef) {
                    if enum_has_payloads(sdef).not() {
                        switch fval {
                        case Value.Int(iv):
                            fval = val_i32(iv)
                        case:
                        }
                    }
                }
                ns_set(dd.name, nsd.name, fval)
            }
        case:
        }
    }
}

priv ns_qname := func(sname: Str, fname: Str) returns Str {
    return sname.format(".", fname)
}

ns_get := func(sname: Str, fname: Str) returns ref Value {
    ref mut c : Context = codegen_lp().ctx
    qn := ns_qname(sname, fname)
    if c.ns_fields.has(qn).not() { return NULL }
    ref v : Value = c.ns_fields.get(qn)
    return v
}


ns_set := func(sname: Str, fname: Str, shallow val: Value) {
    ref mut c : Context = codegen_lp().ctx
    qn := ns_qname(sname, fname)
    mut vcopy := val
    c.ns_fields.set(own qn, own vcopy)
}

make_str_value := func(data: Dynamic, shallow len: U64) returns shallow Value {
    inst_data : Dynamic = malloc(Str.size())
    copy : Dynamic = malloc(len.add(1))
    memcpy(copy, data, len)
    memset(ptr_add(copy, len), 0, 1)
    write_ptr(inst_data, copy)
    ref mut count_slot : U32 = ptr_add(inst_data, 8)
    count_slot = len.to_u32()
    // cap = count so Str.delete frees the malloc'd buffer (was CAP_LIT,
    // which left the buffer alive forever -- a per-call leak that
    // multiplied with every Str-typed precomp fold).
    memcpy(ptr_add(inst_data, 12), count_slot, U32.size().to_u64())
    ref lp : LoadedProgram = codegen_lp()
    return make_struct_value(lp.ctx.cached_str_name, lp.ctx.cached_str_def, inst_data, false)
}

// Like make_str_value but builds a Value.Struct(Str) that VIEWS into
// the caller's buffer (cap=CAP_VIEW) rather than copying. The caller
// MUST guarantee `data` outlives every consumer of the returned Value.
// Used by precomp to track LiteralStr Decls without copying the buffer:
// the LiteralStr's c_str is stable for the entire precomp lifetime.
make_str_value_view := func(data: Dynamic, shallow len: U64) returns shallow Value {
    inst_data : Dynamic = malloc(Str.size())
    write_ptr(inst_data, data)
    ref mut count_slot : U32 = ptr_add(inst_data, 8)
    count_slot = len.to_u32()
    memcpy(ptr_add(inst_data, 12), CAP_VIEW, U32.size().to_u64())
    ref lp : LoadedProgram = codegen_lp()
    return make_struct_value(lp.ctx.cached_str_name, lp.ctx.cached_str_def, inst_data, false)
}

make_str_value_own := func(data: Dynamic, shallow len: U64) returns shallow Value {
    inst_data : Dynamic = malloc(Str.size())
    write_ptr(inst_data, data)
    ref mut count_slot : U32 = ptr_add(inst_data, 8)
    count_slot = len.to_u32()
    memcpy(ptr_add(inst_data, 12), count_slot, U32.size().to_u64())
    ref lp : LoadedProgram = codegen_lp()
    return make_struct_value(lp.ctx.cached_str_name, lp.ctx.cached_str_def, inst_data, false)
}
str_view := func(shallow v: Value) returns shallow Str {
    // Top-level Decl + Return so the typer's
    // skip-promote-shallow-return optimization (in
    // promote_own_transferred_locals) fires and the result stays on
    // the stack. Putting the Decl inside the switch case hid it from
    // the optimization (decl_idx fell back to the switch itself, not
    // the inner Return), so codegen malloc'd the wrapper just to
    // DEREF it on return -- 16 bytes leak per call.
    mut result := ""
    switch v {
    case Value.Struct(si):
        ref s : Str = to_ptr(si.data)
        result = Str(c_str = s.c_str, count = s.count, cap = CAP_VIEW)
    case:
        UNREACHABLE(__LOC__)
    }
    return result
}

find_field_decl := func(struct_def: Expr, fname: Str) returns ref Declaration {
    switch struct_def.node_type {
    case NodeType.StructDef(ffd_sdd):
        for dd : Declaration in ffd_sdd.fields {
            if dd.name.eq(fname) {
                return dd
            }
        }
        return NULL
    case:
        return NULL
    }
}

ENUM_PAYLOAD_OFFSET : I32 = 8

read_field := func(inst_data: Dynamic, dd: Declaration) returns shallow Value {
    ref ptr : Dynamic = ptr_add(inst_data, dd.field_offset.to_u64())
    // Resolve the field's type name. For own/ref enum fields the typer
    // sometimes leaves explicit_type empty -- recover the enum name from
    // til_type when available so the enum branch below applies regardless
    // of own_type.
    mut ftype := dd.explicit_type
    if ftype.len().eq(0) {
        switch dd.til_type {
        case Type.Enum(ename):
            ftype = ename
        case:
        }
    }
    mut is_enum_field := false
    if is_null(dd.field_struct_def).not() {
        if dd.field_struct_def.node_type.is(NodeType.EnumDef) {
            is_enum_field = true
        }
    }
    if dd.til_type.is(Type.Enum) { is_enum_field = true }
    if dd.own_type.is(OwnType.Own).and(is_enum_field.not()) {
        if is_null(dd.field_struct_def).not() {
            ref owned : Dynamic = deref(ptr)
            return make_struct_value(ftype, dd.field_struct_def, owned, true)
        }
        ref owned2 : Dynamic = deref(ptr)
        return Value.Dynamic(owned2)
    }
    if dd.own_type.is(OwnType.Ref).and(is_enum_field.not()) {
        if is_null(deref(ptr)) { return Value.Ref(NULL) }
        if is_null(dd.field_struct_def).not() {
            ref rp : Dynamic = deref(ptr)
            return make_struct_value(ftype, dd.field_struct_def, rp, true)
        }
        ref rp2 : Dynamic = deref(ptr)
        return Value.Ref(rp2)
    }
    if ftype.eq("I64") { ref v : I64 = ptr; return val_i64(v) }
    if ftype.eq("U8") { ref v : U8 = ptr; return val_u8(v.to_i64()) }
    if ftype.eq("I16") { ref v : I16 = ptr; return val_i16(v.to_i64()) }
    if ftype.eq("I32") { ref v : I32 = ptr; return val_i32(v.to_i64()) }
    if ftype.eq("U32") { ref v : U32 = ptr; return val_u32(v.to_i64()) }
    if ftype.eq("U64") { ref v : U64 = ptr; return val_u64(v) }
    if ftype.eq("USize") { ref v : U32 = ptr; return val_u32(v.to_i64()) }
    if ftype.eq("UPtr") {
        ref lp : LoadedProgram = codegen_lp()
        ref uptr_name : Str = resolve_type_alias(lp.ctx.scope, "UPtr")
        if uptr_name.eq("U32") { ref v : U32 = ptr; return val_u32(v.to_i64()) }
        ref v : U64 = ptr
        return val_u64(v)
    }
    if ftype.eq("F32") { ref v : F32 = ptr; return val_f32(v) }
    if ftype.eq("Bool") { ref v : Bool = ptr; return val_bool(v) }
    // Enum field
    ref mut edef_lookup : Expr = lookup_interp_type_def(ftype)
    if is_null(edef_lookup) {
        if is_null(dd.field_struct_def).not() {
            if dd.field_struct_def.node_type.is(NodeType.EnumDef) {
                edef_lookup = dd.field_struct_def
            }
        }
    }
    if is_null(edef_lookup).not() {
        if edef_lookup.node_type.is(NodeType.EnumDef) {
            ref edef : Expr = edef_lookup
            if enum_has_payloads(edef) {
                ref ei : EnumInstance = deref(ptr)
                if is_null(ei) { return val_enum_simple(ftype, 0) }
                ref etag_ref : Dynamic = ei.data
                ref etag : I32 = etag_ref
                psz := ei.data_size.sub(ENUM_PAYLOAD_OFFSET)
                mut psz_final := psz
                if psz.to_i64().lt(0) { psz_final = 0 }
                return val_enum_flat(ei.enum_name, etag, ptr_add(ei.data, ENUM_PAYLOAD_OFFSET.to_u64()), psz_final)
            }
            ref itag : I32 = ptr
            return val_i32(itag.to_i64())
        }
    }
    // Inline struct
    ref sdef3 : Expr = lookup_interp_type_def(ftype)
    if is_null(sdef3).not() {
        if sdef3.node_type.is(NodeType.StructDef) {
            // Use the scope binding's owned `name` rather than the
            // local `ftype` -- ftype is a clone whose destructor runs
            // at function return, and make_struct_value stores the
            // pointer in StructInstance.struct_name (a `ref` field).
            // The binding lives in scope.bindings for the program's
            // lifetime, so its name is a stable long-lived source.
            ref lp : LoadedProgram = codegen_lp()
            ref bnd : TypeBinding = lp.ctx.scope.get_binding(ftype)
            if is_null(bnd).not() {
                return make_struct_value(bnd.name, sdef3, ptr, true)
            }
            return make_struct_value(ftype, sdef3, ptr, true)
        }
    }
    // FuncSig-typed field or fallback -- re-read ptr since ownership may have transferred
    ref ptr2 : Dynamic = ptr_add(inst_data, dd.field_offset.to_u64())
    if ftype.len().gt(0) {
        ref stored : Dynamic = deref(ptr2)
        if is_null(stored).not() { return Value.Func(stored) }
    }
    // Fallback
    ref ptr3 : Dynamic = ptr_add(inst_data, dd.field_offset.to_u64())
    ref fi : I64 = ptr3
    return val_i64(fi)
}

write_field := func(mut inst_data: Dynamic, dd: Declaration, val: Value) {
    ref ptr : Dynamic = ptr_add(inst_data, dd.field_offset.to_u64())
    fsz := dd.field_size
    // Enum-typed fields use the same heap-EnumInstance encoding regardless
    // of own_type; let the unified switch below allocate the heap instance.
    mut is_enum_field := false
    if is_null(dd.field_struct_def).not() {
        if dd.field_struct_def.node_type.is(NodeType.EnumDef) {
            is_enum_field = true
        }
    }
    if dd.til_type.is(Type.Enum) { is_enum_field = true }
    if val.is(Value.Enum) { is_enum_field = true }
    if dd.own_type.is(OwnType.Own).and(is_enum_field.not()) {
        switch val {
        case Value.Struct(si):
            write_ptr(ptr, si.data)
        case Value.Ref(pv):
            write_ptr(ptr, deref(pv))
        case Value.Dynamic(pv):
            write_ptr(ptr, deref(pv))
        case Value.Func(fv):
            write_ptr(ptr, deref(fv))
        case:
            UNREACHABLE(__LOC__)
        }
        return
    }
    if dd.own_type.is(OwnType.Ref).and(is_enum_field.not()) {
        switch val {
        case Value.Ref(pv):
            write_ptr(ptr, deref(pv))
        case Value.Dynamic(pv):
            write_ptr(ptr, deref(pv))
        case Value.Struct(si):
            write_ptr(ptr, si.data)
        case:
            write_ptr(ptr, NULL)
        }
        return
    }
    switch val {
    case Value.Int(v):     memcpy(ptr, v, fsz.to_u64())
    case Value.Byte(v):    memcpy(ptr, v, fsz.to_u64())
    case Value.Short(v):   memcpy(ptr, v, fsz.to_u64())
    case Value.Int32(v):   memcpy(ptr, v, fsz.to_u64())
    case Value.Uint32(v):  memcpy(ptr, v, fsz.to_u64())
    case Value.Uint64(v):  memcpy(ptr, v, fsz.to_u64())
    case Value.Float(v):   memcpy(ptr, v, fsz.to_u64())
    case Value.Boolean(v): memcpy(ptr, v, fsz.to_u64())
    case Value.Struct(si):
        if si.borrowed {
            mut cloned := val.clone()
            switch cloned {
            case Value.Struct(csi):
                memcpy(ptr, csi.data, fsz.to_u64())
                free(own csi.data)
                csi.data = NULL
            case:
            }
        } else {
            memcpy(ptr, si.data, fsz.to_u64())
        }
    case Value.Enum(ei):
        mut total := ei.data_size
        if total.to_i64().lt(8) { total = 8 }
        heap_ei : Dynamic = malloc(EnumInstance.size().to_u64())
        memcpy(heap_ei, ei, EnumInstance.size().to_u64())
        // Deep-copy the data buffer
        new_data : Dynamic = malloc(total.to_u64())
        memcpy(new_data, ei.data, total.to_u64())
        // Write data pointer into the heap EnumInstance. After dropping the
        // dead enum_def field, EnumInstance is { enum_name(0..8),
        // data(8..16), data_size(16..) } so the data slot is at offset 8.
        write_ptr(ptr_add(heap_ei, 8), new_data)
        write_ptr(ptr, heap_ei)
    case Value.Ref(pv):     write_ptr(ptr, deref(pv))
    case Value.Dynamic(pv): write_ptr(ptr, deref(pv))
    case Value.Func(fv):    write_ptr(ptr, deref(fv))
    case:
    }
}

interpret_register_defs := func(mut global: Scope, prog: Expr) {
    for stmt : Expr in prog.children {
        if stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0)) {
            if stmt.child(0).node_type.is(NodeType.FuncDef)
            .or(stmt.child(0).node_type.is(NodeType.StructDef))
            .or(stmt.child(0).node_type.is(NodeType.EnumDef)) {
                switch stmt.node_type {
                case NodeType.Decl(dd):
                    mut val := val_none()
                    memcpy(val, 9, 4)
                    write_ptr(ptr_add(val, 8), stmt.child(0))
                    scope_set_owned(global, dd.name, val)
                case:
                }
            }
        }
    }
}

interpret_register_aliases := func(mut global: Scope, prog: Expr) {
    for stmt : Expr in prog.children {
        if stmt.node_type.is(NodeType.Decl).not() { }
        else if expr_til_type(stmt).is(Type.None).not() { }
        else if stmt.children.len().eq(0) { }
        else {
            ref rhs : Expr = stmt.child(0)
            switch rhs.node_type {
            case NodeType.Ident(rhs_ident):
                ref src : Cell = scope_get(global, ident_name(rhs_ident))
                if is_null(src).not() {
                    switch src.val {
                    case Value.Func(fptr):
                        ref sdef : Expr = deref(fptr)
                        if sdef.node_type.is(NodeType.StructDef).or(sdef.node_type.is(NodeType.EnumDef)) {
                            switch stmt.node_type {
                            case NodeType.Decl(dd):
                                mut val := val_none()
                                memcpy(val, 9, 4)
                                write_ptr(ptr_add(val, 8), sdef)
                                scope_set_owned(global, dd.name, val)
                            case:
                            }
                        }
                    case:
                    }
                }
            case:
            }
        }
    }
}

interpret_copy_alias_ns := func(prog: Expr, global: Scope) {
    for stmt : Expr in prog.children {
        if stmt.node_type.is(NodeType.Decl).not() { }
        else if expr_til_type(stmt).is(Type.None).not() { }
        else if stmt.children.len().eq(0) { }
        else {
            ref rhs : Expr = stmt.child(0)
            switch rhs.node_type {
            case NodeType.Ident(rhs_ident):
                switch stmt.node_type {
                case NodeType.Decl(dd):
                    ref tc : Cell = scope_get(global, ident_name(rhs_ident))
                    if is_null(tc).not() {
                        switch tc.val {
                        case Value.Func(fptr):
                            ref sdef : Expr = deref(fptr)
                            if sdef.node_type.is(NodeType.StructDef).or(sdef.node_type.is(NodeType.EnumDef)) {
                                ref ica_ns : Vec = def_ns_decls(sdef)
                                for d_j : Declaration in ica_ns {
                                    ref nsd : Declaration = d_j
                                    ref v : Value = ns_get(ident_name(rhs_ident), nsd.name)
                                    if is_null(v).not() { ns_set(dd.name, nsd.name, v) }
                                }
                            }
                        case:
                        }
                    }
                case:
                }
            case:
            }
        }
    }
}

interpret := proc(core_program: Expr, program: Expr, mode: Mode, shallow run_tests: Bool, path: Str, user_c: Str, ext_c: Str, link_flags: Str, user_argv: Vec, fwd_path: Str) returns shallow I32 {
    mut lp := LoadedProgram()
    ref mut c : Context = lp.ctx
    context_enter_file(lp.ctx, path)
    mut user_argc : U32 = 0
    if is_null(user_argv).not() { user_argc = user_argv.len() }

    ffi_rc := ffi_init(program, fwd_path, user_c, ext_c, link_flags)
    if ffi_rc.to_i64().eq(0).not() { return ffi_rc }
    if is_null(core_program).not() { ffi_init_scan_program(core_program) }
    codegen_set_lp(lp)

    global := scope_new(NULL)

    // Pre-register func/struct/enum definitions
    if is_null(core_program).not() { interpret_register_defs(global, core_program) }
    interpret_register_defs(global, program)

    // Pre-register type aliases
    if is_null(core_program).not() { interpret_register_aliases(global, core_program) }
    interpret_register_aliases(global, program)

    // Initialize namespace fields
    if is_null(core_program).not() { interpreter_init_ns(lp.ctx, global, core_program) }
    interpreter_init_ns(lp.ctx, global, program)

    // Copy namespace entries for type aliases
    if is_null(core_program).not() { interpret_copy_alias_ns(core_program, global) }
    interpret_copy_alias_ns(program, global)

    // Evaluate top-level declarations
    if is_null(core_program).not() { eval_body(global, core_program) }
    eval_body(global, program)

    // Run tests
    if run_tests {
        mut test_count : I32 = 0
        mut pass_count : I32 = 0
        for stmt : Expr in program.children {
            if is_func_decl(stmt) {
                switch stmt.child(0).node_type {
                case NodeType.FuncDef(fd):
                    if fd.func_type.is(FuncType.Test) {
                        switch stmt.node_type {
                        case NodeType.Decl(dd):
                            test_count = test_count.add(1)
                            test_scope := scope_new(global)
                            eval_body(test_scope, stmt.child(0).child(0))
                            if c.has_return {
                                c.return_value = c.return_value.clone()
                            }
                            scope_free(own test_scope)
                            pass_count = pass_count.add(1)
                            eprint_single("  pass: ")
                            eprint_single(dd.name)
                            eprint_single("\n")
                        case:
                        }
                    }
                case:
                }
            }
        }
        if test_count.eq(0) {
            eprint_single("no tests found\n")
        } else {
            eprint_single(pass_count.to_str())
            eprint_single("/")
            eprint_single(test_count.to_str())
            eprint_single(" tests passed\n")
        }
        ffi_cleanup()
        if pass_count.eq(test_count).not() { exit(1) }
        // Fall through to final cleanup
    }

    // In needs_main mode, call main()
    if is_null(mode).not() { if mode.needs_main {
        ref main_cell : Cell = scope_get(global, "main")
        if is_null(main_cell).or(main_cell.val.is(Value.Func).not()) {
            eprint_single(path)
            eprint_single(": error: this mode requires a 'main' proc\n")
            exit(1)
        }
        switch main_cell.val {
        case Value.Func(fptr):
            ref func_def : Expr = deref(fptr)
            switch func_def.node_type {
            case NodeType.FuncDef(fd):
                nparam := fd.params.len()
                vi := fd.variadic_index
                ref body : Expr = func_def.child(0)
                main_scope := scope_new(global)

                if nparam.gt(0) {
                    mut fixed := nparam
                    if vi.to_i64().gte(0) { fixed = nparam.sub(1) }
                    if vi.to_i64().gte(0) {
                        if user_argc.lt(fixed) {
                            eprint_single("error: main expects at least ")
                            eprint_single(fixed.to_str())
                            eprint_single(" argument(s), got ")
                            eprint_single(user_argc.to_str())
                            eprint_single("\n")
                            exit(1)
                        }
                    } else {
                        if user_argc.eq(nparam).not() {
                            eprint_single("error: main expects ")
                            eprint_single(nparam.to_str())
                            eprint_single(" argument(s), got ")
                            eprint_single(user_argc.to_str())
                            eprint_single("\n")
                            exit(1)
                        }
                    }
                    mut argi : I32 = 0
                    for pi in 0..nparam {
                        ref param : Declaration = fd.params.get(pi)
                        if pi.to_i64().eq(vi.to_i64()) {
                            va_count := user_argc.sub(fixed)
                            ref va_param : Declaration = fd.params.get(vi.to_usize())
                            arr := build_argv_array(user_argv, argi.to_u32(), va_count, va_param.explicit_type)
                            scope_set_owned(main_scope, param.name, arr)
                            argi = argi.add(va_count.to_i32())
                        } else {
                            ref arg_s : Str = user_argv.get(argi.to_usize())
                            v := parse_cli_arg(arg_s, param.explicit_type)
                            scope_set_owned(main_scope, param.name, v)
                            argi = argi.add(1)
                        }
                    }
                } else if user_argc.gt(0) {
                    eprint_single("error: main expects no arguments, got ")
                    eprint_single(user_argc.to_str())
                    eprint_single("\n")
                    exit(1)
                }

                eval_body(main_scope, body)
                scope_free(own main_scope)
            case:
                UNREACHABLE(__LOC__)
            }
        case:
            UNREACHABLE(__LOC__)
        }
    } }

    scope_free(own global)
    ffi_cleanup()
    c.ns_inited = false
    codegen_clear_lp()
    return 0
}

// Per-file interpreter entrypoint (rstil-style): uses the canonical per-file
// ASTs stored in lp.ctx.imported, but preserves the original overall
// registration/eval ordering.
priv interpret_units := proc(mut lp: LoadedProgram, user_argv: Vec, fwd_path: Str) returns shallow I32 {
    // Ensure codegen_lp() is available throughout interpretation so
    // interpreter helpers can read shared Context fields (#177/#178).
    codegen_set_lp(lp)
    ref mut c : Context = lp.ctx
    // Ensure builtin dispatch table is initialized deterministically.
    if dispatch_inited.not() { dispatch_init() }

    mut user_argc : U32 = 0
    if is_null(user_argv).not() { user_argc = user_argv.len() }

    // FFI init: reset, load the shared lib, then scan per-file ASTs.
    ffi_reset()
    mut empty := Expr.new(NodeType.Body, 0, 0)
    ffi_rc := ffi_init(empty, fwd_path, lp.link_c_paths, lp.ext_c_path, lp.link_flags)
    if ffi_rc.to_i64().eq(0).not() { return ffi_rc }
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            ffi_init_struct_defs_append(iu.ast)
            ffi_init_scan_program(iu.ast)
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        ffi_init_struct_defs_append(iu.ast)
        ffi_init_scan_program(iu.ast)
    }

    global := scope_new(NULL)

    // 1) Pre-register func/struct/enum definitions
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            interpret_register_defs(global, iu.ast)
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        interpret_register_defs(global, iu.ast)
    }

    // 2) Pre-register type aliases
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            interpret_register_aliases(global, iu.ast)
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        interpret_register_aliases(global, iu.ast)
    }

    // 3) Initialize namespace fields
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            interpreter_init_ns(lp.ctx, global, iu.ast)
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        interpreter_init_ns(lp.ctx, global, iu.ast)
    }

    // 4) Copy namespace entries for type aliases
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            interpret_copy_alias_ns(iu.ast, global)
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        interpret_copy_alias_ns(iu.ast, global)
    }

    // 5) Evaluate top-level declarations
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            context_enter_file(lp.ctx, u.path)
            eval_body(global, iu.ast)
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported.get(u.path)
        context_enter_file(lp.ctx, u.path)
        eval_body(global, iu.ast)
    }

    // Run tests (scan per-file user ASTs).  Picks up both top-level
    // test() decls and test() decls inside struct/enum namespaces so
    // tests can live next to the code they exercise.
    if lp.run_tests {
        mut test_count : I32 = 0
        mut pass_count : I32 = 0
        for u : ProgramUnit in lp.units {
            ref iu : ImportUnit = lp.ctx.imported.get(u.path)
            for stmt : Expr in iu.ast.children {
                if is_func_decl(stmt) {
                    switch stmt.child(0).node_type {
                    case NodeType.FuncDef(fd):
                        if fd.func_type.is(FuncType.Test) {
                            switch stmt.node_type {
                            case NodeType.Decl(dd):
                                test_count = test_count.add(1)
                                test_scope := scope_new(global)
                                context_enter_file(lp.ctx, u.path)
                                eval_body(test_scope, stmt.child(0).child(0))
                                if c.has_return {
                                    c.return_value = c.return_value.clone()
                                }
                                scope_free(own test_scope)
                                pass_count = pass_count.add(1)
                                eprint_single("  pass: ")
                                eprint_single(dd.name)
                                eprint_single("\n")
                            case:
                            }
                        }
                    case:
                    }
                }
                if stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0)) {
                    ref rhs : Expr = stmt.child(0)
                    if rhs.node_type.is(NodeType.StructDef).or(rhs.node_type.is(NodeType.EnumDef)) {
                        switch stmt.node_type {
                        case NodeType.Decl(sdd):
                            ref ns : Vec = def_ns_decls(rhs)
                            for nsd : Declaration in ns {
                                ref nsfdef : Expr = nsd.default_value
                                if is_null(nsfdef) { continue }
                                switch nsfdef.node_type {
                                case NodeType.FuncDef(nsfd):
                                    if nsfd.func_type.is(FuncType.Test).not() { continue }
                                    test_count = test_count.add(1)
                                    test_scope := scope_new(global)
                                    context_enter_file(lp.ctx, u.path)
                                    eval_body(test_scope, nsfdef.child(0))
                                    if c.has_return {
                                        c.return_value = c.return_value.clone()
                                    }
                                    scope_free(own test_scope)
                                    pass_count = pass_count.add(1)
                                    eprint_single("  pass: ")
                                    eprint_single(sdd.name)
                                    eprint_single(".")
                                    eprint_single(nsd.name)
                                    eprint_single("\n")
                                case:
                                }
                            }
                        case:
                        }
                    }
                }
            }
        }
        if test_count.eq(0) {
            eprint_single("no tests found\n")
        } else {
            eprint_single(pass_count.to_str())
            eprint_single("/")
            eprint_single(test_count.to_str())
            eprint_single(" tests passed\n")
        }
        ffi_cleanup()
        if pass_count.eq(test_count).not() { exit(1) }
    }

    // In needs_main mode, call main() (same logic as interpret()).  When
    // run_tests is set, tests are the entry points -- skip main() so a
    // mode cli/gui file with inline test() decls runs only its tests.
    if lp.run_tests.not() { if is_null(lp.cur_mode).not() { if lp.cur_mode.needs_main {
        ref main_cell : Cell = scope_get(global, "main")
        if is_null(main_cell).or(main_cell.val.is(Value.Func).not()) {
            eprint_single(lp.path)
            eprint_single(": error: this mode requires a 'main' proc\n")
            exit(1)
        }
        switch main_cell.val {
        case Value.Func(fptr):
            ref func_def : Expr = deref(fptr)
            switch func_def.node_type {
            case NodeType.FuncDef(fd):
                nparam := fd.params.len()
                vi := fd.variadic_index
                ref body : Expr = func_def.child(0)
                main_scope := scope_new(global)

                if nparam.gt(0) {
                    mut fixed := nparam
                    if vi.to_i64().gte(0) { fixed = nparam.sub(1) }
                    if vi.to_i64().gte(0) {
                        if user_argc.lt(fixed) {
                            eprint_single("error: main expects at least ")
                            eprint_single(fixed.to_str())
                            eprint_single(" argument(s), got ")
                            eprint_single(user_argc.to_str())
                            eprint_single("\n")
                            exit(1)
                        }
                    } else {
                        if user_argc.eq(nparam).not() {
                            eprint_single("error: main expects ")
                            eprint_single(nparam.to_str())
                            eprint_single(" argument(s), got ")
                            eprint_single(user_argc.to_str())
                            eprint_single("\n")
                            exit(1)
                        }
                    }
                    mut argi : I32 = 0
                    for pi in 0..nparam {
                        ref param : Declaration = fd.params.get(pi)
                        if pi.to_i64().eq(vi.to_i64()) {
                            va_count := user_argc.sub(fixed)
                            ref va_param : Declaration = fd.params.get(vi.to_usize())
                            arr := build_argv_array(user_argv, argi.to_u32(), va_count, va_param.explicit_type)
                            scope_set_owned(main_scope, param.name, arr)
                            argi = argi.add(va_count.to_i32())
                        } else {
                            ref arg_s : Str = user_argv.get(argi.to_usize())
                            v := parse_cli_arg(arg_s, param.explicit_type)
                            scope_set_owned(main_scope, param.name, v)
                            argi = argi.add(1)
                        }
                    }
                } else if user_argc.gt(0) {
                    eprint_single("error: main expects no arguments, got ")
                    eprint_single(user_argc.to_str())
                    eprint_single("\n")
                    exit(1)
                }

                eval_body(main_scope, body)
                scope_free(own main_scope)
            case:
                UNREACHABLE(__LOC__)
            }
        case:
            UNREACHABLE(__LOC__)
        }
    } } }

    scope_free(own global)
    ffi_cleanup()
    c.ns_inited = false
    codegen_clear_lp()
    return 0
}

cmd_interpret := proc(lp: LoadedProgram, user_argv: Vec) returns shallow I32 {
    mut interpret_fwd_path := ""
    mut result : I32 = 0
    if lp.link_c_paths.len().gt(0) {
        system_cmd("mkdir -p tmp")
        interpret_fwd_path = format("tmp/ffi_", clock_ms().to_str(), "_forward.h")
        codegen_set_lp(lp)
        result = build_forward_header_lp(interpret_fwd_path)
    }
    if result.eq(0) {
        result = interpret_units(lp, user_argv, interpret_fwd_path)
    }
    return result
}
