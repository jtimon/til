    type_name := eval_str_owned(s, e.children[1], ctx)
    ref node : Expr = interp_lookup_funcsig(s, e, type_name, "func_sig_throw_count", ctx)
    switch node.node_type {
    case NodeType.FuncDef(fd):
        r = Value.Int(fd.throw_types.len().to_i64())
    case:
        UNREACHABLE()
    }
    return true
}

priv h_func_sig_throw_type := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    idx := eval_index_arg(s, e, ctx)
    ref node : Expr = interp_lookup_funcsig(s, e, type_name, "func_sig_throw_type", ctx)
    switch node.node_type {
    case NodeType.FuncDef(fd):
        if idx >= fd.throw_types.len() {
            interp_error(e, "func_sig_throw_type: index out of bounds", ctx)
            exit(1)
        }
        ref tt : Str = fd.throw_types[idx]
        r = str_to_owned_value(tt, ctx)
    case:
        UNREACHABLE()
    }
    return true
}

priv h_dyn_type_to_str := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    type_val := eval_expr(s, e.children[1], ctx)
    switch type_val {
    case Value.Enum(ei):
        ref til_type_def : Expr = lookup_interp_type_def("Type", ctx)
        if til_type_def.is_null() {
            panic("dyn_type_to_str: Type definition not registered")
        }
        ref tag_ptr : Dynamic = ei.data
        ref tag_ref : I32 = tag_ptr
        tag := tag_ref.cast(I64)
        if tag.eq(enum_variant_tag(til_type_def, "Unknown")).or(tag.eq(enum_variant_tag(til_type_def, "None"))) {
            r = make_str_value("".c_str, 0, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "I64") {
            r = make_str_value("I64".c_str, 3, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "U8") {
            r = make_str_value("U8".c_str, 2, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "I8") {
            r = make_str_value("I8".c_str, 2, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "I16") {
            r = make_str_value("I16".c_str, 3, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "U16") {
            r = make_str_value("U16".c_str, 3, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "I32") {
            r = make_str_value("I32".c_str, 3, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "U32") {
            r = make_str_value("U32".c_str, 3, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "U64") {
            r = make_str_value("U64".c_str, 3, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "F32") {
            r = make_str_value("F32".c_str, 3, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "Bool") {
            r = make_str_value("Bool".c_str, 4, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "Struct") {
            ref payload : Str = ptr_add(ei.data, ENUM_PAYLOAD_OFFSET.cast(U64))
            r = make_str_value(payload.c_str, payload.count, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "StructDef") {
            r = make_str_value("StructDef".c_str, 9, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "Enum") {
            ref payload2 : Str = ptr_add(ei.data, ENUM_PAYLOAD_OFFSET.cast(U64))
            r = make_str_value(payload2.c_str, payload2.count, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "EnumDef") {
            r = make_str_value("EnumDef".c_str, 7, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "FuncDef") {
            r = make_str_value("FunctionDef".c_str, 11, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "FuncPtr") {
            r = make_str_value("Fn".c_str, 2, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "Body") {
            r = make_str_value("Body".c_str, 4, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "Dynamic") {
            r = make_str_value("Dynamic".c_str, 7, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "Custom") {
            ref payload3 : Str = ptr_add(ei.data, ENUM_PAYLOAD_OFFSET.cast(U64))
            r = make_str_value(payload3.c_str, payload3.count, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "Primitive") {
            // Type.Primitive(p) carries a Primitive enum value inline at
            // ENUM_PAYLOAD_OFFSET (its tag is the first I32). Decode it to
            // the primitive's name -- mirrors the data-driven nested switch
            // that emit_dyn_type_to_str_body generates for compiled code.
            ref prim_def : Expr = lookup_interp_type_def("Primitive", ctx)
            if prim_def.is_null() {
                panic("dyn_type_to_str: Primitive definition not registered")
            }
            ref prim_tag_ref : I32 = ptr_add(ei.data, ENUM_PAYLOAD_OFFSET.cast(U64))
            ptag := prim_tag_ref.cast(I64)
            if ptag == enum_variant_tag(prim_def, "I16") { r = make_str_value("I16".c_str, 3, ctx); return true }
            if ptag == enum_variant_tag(prim_def, "U16") { r = make_str_value("U16".c_str, 3, ctx); return true }
            if ptag == enum_variant_tag(prim_def, "I8")  { r = make_str_value("I8".c_str, 2, ctx); return true }
            if ptag == enum_variant_tag(prim_def, "U8")  { r = make_str_value("U8".c_str, 2, ctx); return true }
            if ptag == enum_variant_tag(prim_def, "U32") { r = make_str_value("U32".c_str, 3, ctx); return true }
            if ptag == enum_variant_tag(prim_def, "I32") { r = make_str_value("I32".c_str, 3, ctx); return true }
            if ptag == enum_variant_tag(prim_def, "U64") { r = make_str_value("U64".c_str, 3, ctx); return true }
            if ptag == enum_variant_tag(prim_def, "I64") { r = make_str_value("I64".c_str, 3, ctx); return true }
            if ptag == enum_variant_tag(prim_def, "F32") { r = make_str_value("F32".c_str, 3, ctx); return true }
            if ptag == enum_variant_tag(prim_def, "Bool") { r = make_str_value("Bool".c_str, 4, ctx); return true }
            panic("dyn_type_to_str: unknown Primitive tag")
        }
        panic("dyn_type_to_str: unknown Type tag")
        r = make_str_value("".c_str, 0, ctx)
        return true
    case:
        panic("dyn_type_to_str: expected Type enum value")
        return false
    }
}

priv h_check_cmd_status := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    pidv := eval_expr(s, e.children[1], ctx)
    switch pidv {
    case Value.Int(pid):
        r = Value.Int(check_cmd_status(pid))
        return true
    case:
        UNREACHABLE()
        return false
    }
}

priv h_sleep := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    msv := eval_expr(s, e.children[1], ctx)
    switch msv {
    case Value.Int(ms):
        sleep_ms(ms)
        r = val_none()
        return true
    case:
        UNREACHABLE()
        return false
    }
}

priv h_file_mtime := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    path := eval_expr(s, e.children[1], ctx)
    r = Value.Int(file_mtime(str_view(path)))
    return true
}

priv h_str_parse_f32 := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    arg := eval_expr(s, e.children[1], ctx)
    r = Value.Float(str_parse_f32(str_view(arg)))
    return true
}

priv h_clock_ms := proc(_s: Scope, _e: Expr, mut r: Value) returns Bool {
    r = Value.Int(clock_ms())
    return true
}

priv h_get_thread_count := proc(_s: Scope, _e: Expr, mut r: Value) returns Bool {
    r = Value.Int(get_thread_count())
    return true
}

priv h_cfile_open := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    path := eval_str_owned(s, e.children[1], ctx)
    is_write_v := eval_expr(s, e.children[2], ctx)
    switch is_write_v {
    case Value.Boolean(is_write):
        // FILE* handle: closed via cfile_close (fclose), never free()'d,
        // so it is a borrowed view from the runtime's perspective, not a
        // free()-owned Value.Dynamic.
        r = Value.Ref(cfile_open(path, is_write))
        return true
    case:
        UNREACHABLE()
        return false
    }
}

// til primitive/struct type name -> ffi_type, or NULL when `type_name`
// is neither a known primitive nor a registered struct.  Shared by
// shallow_ffi_type and field_ffi_type, which differ only in the
// fallback they pick for an unknown type.
priv known_ffi_type := func(type_name: Str, ctx: Context) returns ref ffi_type {
    if type_name == "I64"   { return ffi_type_ref("ffi_type_sint64") }
    if type_name == "U8"    { return ffi_type_ref("ffi_type_uint8") }
    if type_name == "I8"    { return ffi_type_ref("ffi_type_sint8") }
    if type_name == "I16"   { return ffi_type_ref("ffi_type_sint16") }
    if type_name == "U16"   { return ffi_type_ref("ffi_type_uint16") }
    if type_name == "I32"   { return ffi_type_ref("ffi_type_sint32") }
    if type_name == "U32"   { return ffi_type_ref("ffi_type_uint32") }
    if type_name == "U64"   { return ffi_type_ref("ffi_type_uint64") }
    if type_name == "USize" { return usize_ffi_type(ctx) }
    if type_name == "UPtr"  { return uptr_ffi_type(ctx) }
    if type_name == "F32"   { return ffi_type_ref("ffi_type_float") }
    if type_name == "Bool"  { return ffi_type_ref("ffi_type_uint8") }
    if ctx.ffi_struct_defs.has(type_name) {
        ref box : ExprPtrBox = ctx.ffi_struct_defs[type_name]
        return build_struct_ffi_type(box.ptr, ctx)
    }
    return NULL
}

// type_name -> ffi_type. Inverse mapping in ffi_shallow_type_info; keep
// the two in sync if a new shallow primitive type lands.  Unknown
// types are passed as opaque pointers.
priv shallow_ffi_type := func(type_name: Str, ctx: Context) returns ref ffi_type {
    ref t : ffi_type = known_ffi_type(type_name, ctx)
    if t.is_null().not() { return t }
    return ffi_type_ref("ffi_type_pointer")
}

priv field_ffi_type := func(dd: Declaration, ctx: Context) returns ref ffi_type {
    if dd.own_type.is(OwnType.Shallow).not() { return ffi_type_ref("ffi_type_pointer") }
    if dd.explicit_type.len() == 0 { return ffi_type_ref("ffi_type_sint64") }
    ref t : ffi_type = known_ffi_type(dd.explicit_type, ctx)
    if t.is_null().not() { return t }
    return ffi_type_ref("ffi_type_sint64")
}

priv build_struct_ffi_type := func(struct_def: Expr, ctx: Context) returns ref ffi_type {
    if ctx.ffi_type_cache_inited.not() {
        ctx.ffi_type_cache = Vec(FFITypePtrBox).new()
        ctx.ffi_type_cache_inited = true
    }
    switch struct_def.node_type {
    case NodeType.StructDef(bsf_sdd):
        nfields := bsf_sdd.fields.len()
        elements : Dynamic = malloc(nfields.add(1).cast(U64) * Dynamic.size().cast(U64))
        for i in 0..nfields {
            ref fd : Declaration = bsf_sdd.fields[i]
            ref ft : ffi_type = field_ffi_type(fd, ctx)
            memcpy(ptr_add(elements, i.cast(U64) * Dynamic.size().cast(U64)), ft, Dynamic.size().cast(U64))
        }
        memset(ptr_add(elements, nfields.cast(U64) * Dynamic.size().cast(U64)), 0, Dynamic.size().cast(U64))
        st : Dynamic = malloc(ffi_type.size().cast(U64))
        ref mut stp : ffi_type = to_ptr(st)
        stp.size = 0
        stp.alignment = 0
        stp.type = FFI_TYPE_STRUCT.to_i16()
        stp.elements = elements
        box := FFITypePtrBox(ptr = stp)
        ctx.ffi_type_cache.push(own box)
        return stp
    case:
        UNREACHABLE()
        return NULL
    }
}

priv h_free := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    switch e.children[1].node_type {
    case NodeType.Ident(ident):
        ref cell : Cell = scope_get(s, ident.ident_name())
        free_value_full(cell.val)
        memcpy(cell.val, val_none(), Value.size().cast(U64))
    case NodeType.FieldAccess(fa):
        // Issue #275: `free(own self.c_str)` in Str.delete on an OWNED Str.
        // read_field yields a Value.Ref(c_str) for the Str's own c_str field;
        // free_value_full has no Ref case, so this leaked whenever an interpreted
        // Str.delete ran on an owned Str -- e.g. `x := f()` returning an owned
        // Str, then `x.delete()` (the dominant constfolder Str_clone leak: folds
        // clone Str return values). Gated on a NON-borrowed Str receiver: a
        // borrowed view (the field read inside an auto-gen delete, or a Vec/Map
        // element view) does NOT own its c_str, and Str.delete reaches the free
        // only when the Str owns the buffer (cap < CAP_VIEW guard) -- so this is
        // single-owner-correct. Null the c_str slot (Str's first field) so a
        // later teardown of the same Str sees NULL and cannot double-free.
        base := eval_expr(s, e.children[1].children[0], ctx)
        mut free_owned_cstr := false
        switch base {
        case Value.Struct(bsi):
            if bsi.struct_name().eq("Str").and(bsi.borrowed.not()).and(fa.field_access_name().eq("c_str")) {
                free_owned_cstr = true
            }
        case:
        }
        val := eval_expr(s, e.children[1], ctx)
        if free_owned_cstr {
            switch val {
            case Value.Ref(rp):
                if rp.is_null().not() {
                    mut owned_ptr : Dynamic = rp
                    free(own owned_ptr)
                    switch base {
                    case Value.Struct(bsi2):
                        if bsi2.data.is_null().not() { write_ptr(bsi2.data, NULL) }
                    case:
                    }
                }
            case:
                free_value_full(val)
            }
        } else {
            free_value_full(val)
        }
        memcpy(val, val_none(), Value.size().cast(U64))
    case:
        val := eval_expr(s, e.children[1], ctx)
        free_value_full(val)
        // val is a garbager-tracked local whose deep Value.delete would
        // re-free the payload free_value_full just released; null it so the
        // scope-end delete is a no-op.
        memcpy(val, val_none(), Value.size().cast(U64))
    }
    r = val_none()
    return true
}

priv free_callable_storage := func(mut v: Value) {
    switch v {
    case Value.Closure(cl):
        interp_closure_free(cl)
    case Value.Dynamic(pv):
        if callable_box_is(deref(pv)) {
            ref stored_dyn : Dynamic = deref(pv)
            callable_storage_free(stored_dyn)
            write_ptr(pv, NULL)
        }
    case Value.Ref(pv):
        ref stored_ref : Dynamic = deref(pv)
        if callable_box_is(stored_ref) {
            callable_storage_free(stored_ref)
            write_ptr(pv, NULL)
        }
    case:
    }
}

priv h_til_closure_delete := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    switch e.children[1].node_type {
    case NodeType.Ident(id):
        ref cell : Cell = scope_get(s, id.ident_name())
        if cell.is_null() { panic("til_closure_delete: undefined ", Str.clone(id.ident_name())) }
        free_callable_storage(cell.val)
        memcpy(cell.val, val_none(), Value.size().cast(U64))
    case NodeType.FieldAccess(fa):
        if e.children[1].children.len().gt(0) {
            ref obj_expr : Expr = e.children[1].children[0]
            switch obj_expr.node_type {
            case NodeType.Ident(obj_id):
                ref obj_cell : Cell = scope_get(s, obj_id.ident_name())
                if obj_cell.is_null().not() {
                    switch obj_cell.val {
                    case Value.Struct(si):
                        ref sdef : Expr = lookup_interp_type_def(si.struct_name(), si.ctx)
                        ref fdecl : Declaration = find_field_decl(sdef, fa.field_access_name())
                        if fdecl.is_null().not() {
                            if decl_is_funcsig(fdecl, ctx) {
                                fl := ctx_field_layout(si.struct_name(), fa.field_access_name(), ctx)
                                ref slot : Dynamic = ptr_add(si.data, fl.offset.cast(U64))
                                ref stored : Dynamic = deref(slot)
                                if stored.is_null().not() { callable_storage_free(stored) }
                                write_ptr(slot, NULL)
                                r = val_none()
                                return true
                            }
                        }
                    case:
                    }
                }
            case:
            }
        }
        val := eval_expr(s, e.children[1], ctx)
        free_callable_storage(val)
        memcpy(val, val_none(), Value.size().cast(U64))
    case:
        val := eval_expr(s, e.children[1], ctx)
        free_callable_storage(val)
        memcpy(val, val_none(), Value.size().cast(U64))
    }
    r = val_none()
    return true
}

priv h_til_closure_slot_delete := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    slot := eval_expr(s, e.children[1], ctx)
    switch slot {
    case Value.Ref(pv):
        ref stored : Dynamic = deref(pv)
        if stored.is_null().not() {
            callable_storage_free(stored)
            write_ptr(pv, NULL)
        }
    case Value.Dynamic(pv):
        ref stored2 : Dynamic = deref(pv)
        if stored2.is_null().not() {
            callable_storage_free(stored2)
            write_ptr(pv, NULL)
        }
    case:
        panic("til_closure_slot_delete: expected pointer slot, got Value.", value_variant_name(slot))
    }
    r = val_none()
    return true
}

priv h_cfile_close := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    handle_v := eval_expr(s, e.children[1], ctx)
    ref hp : Dynamic = val_to_ptr(handle_v)
    cfile_close(deref(hp))
    r = val_none()
    return true
}

priv h_cfile_write_str := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    handle_v := eval_expr(s, e.children[1], ctx)
    sv := eval_str_owned(s, e.children[2], ctx)
    ref hp : Dynamic = val_to_ptr(handle_v)
    cfile_write_str(deref(hp), sv)
    r = val_none()
    return true
}

priv h_ptr_add := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    buf := eval_expr(s, e.children[1], ctx)
    offset := eval_expr(s, e.children[2], ctx)
    ref base : Dynamic = val_to_ptr(buf)
    off := value_to_u64(offset)
    r = Value.Ref(ptr_add(deref(base), off))
    return true
}

priv h_cfile_read_all := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    handle_v := eval_expr(s, e.children[1], ctx)
    ref hp : Dynamic = val_to_ptr(handle_v)
    content := cfile_read_all(deref(hp))
    r = make_str_value(content.c_str, content.count, ctx)
    return true
}

priv h_cfile_open_update := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    path := eval_str_owned(s, e.children[1], ctx)
    // FILE* handle: closed via cfile_close (fclose), never free()'d, so
    // it is a borrowed view, not a free()-owned Value.Dynamic.
    r = Value.Ref(cfile_open_update(path))
    return true
}

priv h_cfile_tell := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    handle_v := eval_expr(s, e.children[1], ctx)
