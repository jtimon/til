priv clone_dyn_vec_buffer := func(src_data: Dynamic, dst_data: Dynamic, ctx: Context) {
    ref data_fl : FieldLayout = ctx_field_layout("DynVec", "data", ctx)
    ref src_hdr : DynPtrBox = ptr_add(src_data, data_fl.offset)
    if src_hdr.p.is_null() { return }
    cap := dyn_vec_cap(src_data, ctx)
    count := dyn_vec_count(src_data, ctx)
    elem_size := dyn_vec_elem_size(src_data, ctx)
    elem_kind := dyn_vec_elem_kind(src_data, ctx)
    new_buf : Dynamic = EvalHeap.heap_alloc(cap.mul(elem_size))
    if elem_kind == ELEM_FN {
        for i in 0..count {
            elem_off := i.mul(elem_size)
            ref stored : Dynamic = deref(ptr_add(src_hdr.p, elem_off))
            if stored.is_null().not() { write_ptr(ptr_add(new_buf, elem_off), callable_storage_clone(stored)) }
        }
    } else {
        memcpy(new_buf, src_hdr.p, cap.mul(elem_size))
        if elem_kind == ELEM_BOXED {
            elem_type := erased_elem_delete_type("DynVec", src_data, ctx)
            if elem_type.len() > 0 {
                for i in 0..count {
                    elem_off := i.mul(elem_size)
                    container_elem_clone_into(elem_type, ptr_add(new_buf, elem_off), ptr_add(src_hdr.p, elem_off), elem_size, ctx)
                }
            }
        }
    }
    write_ptr(ptr_add(dst_data, data_fl.offset), new_buf)
}

priv clone_dyn_array_buffer := func(src_data: Dynamic, dst_data: Dynamic, ctx: Context) {
    ref data_fl : FieldLayout = ctx_field_layout("DynArray", "data", ctx)
    ref src_hdr : DynPtrBox = ptr_add(src_data, data_fl.offset)
    if src_hdr.p.is_null() { return }
    ref cap_fl : FieldLayout = ctx_field_layout("DynArray", "cap", ctx)
    ref elem_size_fl : FieldLayout = ctx_field_layout("DynArray", "elem_size", ctx)
    ref cap : USize = ptr_add(src_data, cap_fl.offset)
    ref elem_size : USize = ptr_add(src_data, elem_size_fl.offset)
    new_buf : Dynamic = EvalHeap.heap_alloc(cap.mul(elem_size))
    memcpy(new_buf, src_hdr.p, cap.mul(elem_size))
    elem_type := erased_elem_delete_type("DynArray", src_data, ctx)
    if elem_type.len() > 0 {
        for i in 0..cap {
            elem_off := i.mul(elem_size)
            container_elem_clone_into(elem_type, ptr_add(new_buf, elem_off), ptr_add(src_hdr.p, elem_off), elem_size, ctx)
        }
    }
    write_ptr(ptr_add(dst_data, data_fl.offset), new_buf)
}

priv clone_dyn_set_buffer := func(src_data: Dynamic, dst_data: Dynamic, ctx: Context) {
    ref data_fl : FieldLayout = ctx_field_layout("DynSet", "data", ctx)
    ref src_hdr : DynPtrBox = ptr_add(src_data, data_fl.offset)
    if src_hdr.p.is_null() { return }
    ref cap_fl : FieldLayout = ctx_field_layout("DynSet", "cap", ctx)
    ref count_fl : FieldLayout = ctx_field_layout("DynSet", "count", ctx)
    ref elem_size_fl : FieldLayout = ctx_field_layout("DynSet", "elem_size", ctx)
    ref cap : USize = ptr_add(src_data, cap_fl.offset)
    ref count : USize = ptr_add(src_data, count_fl.offset)
    ref elem_size : USize = ptr_add(src_data, elem_size_fl.offset)
    new_buf : Dynamic = EvalHeap.heap_alloc(cap.mul(elem_size))
    memcpy(new_buf, src_hdr.p, count.mul(elem_size))
