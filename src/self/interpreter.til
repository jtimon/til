mode lib
import("context")

import("loader")
import("builder")
import("../std/sys")
import("../../vendor/bindings/libffi")
link("vendor/libffi/x86_64-pc-linux-gnu/.libs/libffi.a")

system_cmd := ext_proc(cmd: Str) returns shallow I32 {}

priv interp_error_path := func(ctx: Context) returns Str {
    return ctx.path.clone()
}

priv interp_error := proc(e: Expr, msg: Str, ctx: Context) {
    println(interp_error_path(ctx), ":", e.line.to_str(), ":", e.col.to_str(), ": error: ", msg)
}

priv interp_lang_error := proc(e: Expr, msg: Str, ctx: Context) {
    interp_error(e, msg, ctx)
    println("  note: this is a bug in the language, please report it")
}

// True when a StructInstance with this StructDef has a byte layout
// that the outer memcpy in StructInstance.clone already clones
// correctly -- i.e. no field contains an owned heap pointer that
// would alias.  This is the interpreter-side POD predicate; it is
// strictly more conservative than initer's is_pod_type_for_clone
// because the interpreter stores enum-with-payloads fields as heap
// pointers (EnumInstance.data), so even a "POD enum" needs the
// per-field deep clone here.
// Issue #147 step 4: replaces dd.field_struct_def reads. Returns the
// nested struct/enum def Expr for a field, or NULL when the field's
// type is a primitive (primitives are registered as ~Type := struct {}~
// in core, so a bare lookup_interp_type_def would return the primitive's
// struct shell and downstream callers would try to clone its bytes
// as a nested struct).
priv field_nested_def := func(dd: Declaration, ctx: Context) returns ref Expr {
    if is_primitive(dd.til_type) { return NULL }
    return lookup_interp_type_def(dd.explicit_type, ctx)
}

priv decl_is_funcsig := func(dd: Declaration, ctx: Context) returns Bool {
    if dd.til_type.is_funcptr() { return true }
    if dd.til_type.is(Type.Body) { return true }
    if dd.explicit_type == "Fn" { return true }
    if dd.explicit_type == "Body" { return true }
    ref tdef : Expr = lookup_interp_type_def(dd.explicit_type, ctx)
    if tdef.is_null() { return false }
    if tdef.node_type.is(NodeType.FuncDef) {
        return tdef.children.len() == 0
    }
    return false
}

priv stable_type_name := func(name: Str, ctx: Context) returns ref Str {
    ref b : TypeBinding = ctx.scope.get_binding(name)
    if b.is_null().not() { return b.name }
    return name
}

priv struct_def_shallow_safe := func(sdef_data: StructDef, ctx: Context) returns Bool {
    for dd : Declaration in sdef_data.fields {
        if dd.own_type.is(OwnType.Own) { return false }
        if dd.own_type.is(OwnType.Ref) { continue }
        if decl_is_funcsig(dd, ctx) { return false }
        if dd.explicit_type == "Str" { return false }
        ref fsd : Expr = field_nested_def(dd, ctx)
        if fsd.is_null().not() {
            switch fsd.node_type {
            case NodeType.EnumDef:
                if enum_has_payloads(fsd) { return false }
            case NodeType.StructDef(nested_sdef):
                if struct_def_shallow_safe(nested_sdef, ctx).not() { return false }
            case:
            }
        }
    }
    return true
}

priv str_owns_c_str := func(shallow s: Str) returns Bool {
    return s.count.gt(0).and(s.c_str.is_null().not()).and(s.cap.lt(CAP_VIEW))
}

// #286 commit 2: byte-level deep-CLONE of a struct value at `data` of type
// `struct_name`. Returns a fresh malloc'd buffer with an independent copy of
// every owned-pointer field (Str c_strs, owned struct / container fields) --
// the offset+type+ctx form of StructInstance.clone's body, so eval can clone
// a struct by its heap_index pointer. The nested recursions still build a
// temporary StructInstance and call .clone(), which now delegates back here.
priv heap_clone := func(struct_name: Str, data: Dynamic, ctx: Context) returns Dynamic {
    // #286: look the def up by name (ctx.interp_type_defs) rather than taking
    // it as a ref param -- heap_clone only runs during eval (cloning a live
    // value), when the AST is still live, so the lookup is safe and the
    // dangling struct_def ref on StructInstance is no longer needed.
    ref struct_def : Expr = lookup_interp_type_def(struct_name, ctx)
    switch struct_def.node_type {
    case NodeType.StructDef(sdef_data):
        sz := ctx_total_size(struct_name, ctx)
        dst_data : Dynamic = EvalHeap.heap_alloc(sz)
        memcpy(dst_data, data, sz.cast(U64))
        if struct_name == "Str" {
            ref s : Str = to_ptr(data)
            if str_owns_c_str(s) {
                cloned_str := s.clone()
                write_ptr(dst_data, cloned_str.c_str)
                ref mut dst_cap : U32 = ptr_add(dst_data, 12)
                dst_cap = s.count.clone()
                memset(cloned_str, 0, Str.size().cast(U64))
            }
        } else if struct_name == "DynVec" {
            clone_dyn_vec_buffer(data, dst_data, ctx)
        } else if container_elem_type(struct_name).len() > 0 {
            clone_container_buffer(struct_name, data, dst_data, ctx)
        } else if struct_def_shallow_safe(sdef_data, ctx) {
        } else {
            for dd : Declaration in sdef_data.fields {
                foff := ctx_field_layout(struct_name, dd.name, ctx).offset
                ref ftype : Str = dd.explicit_type
                ref nested_def : Expr = field_nested_def(dd, ctx)
                if dd.own_type.is(OwnType.Own) {
                    if decl_is_funcsig(dd, ctx) {
                        ref src_callable : Dynamic = deref(ptr_add(data, foff.cast(U64)))
                        if src_callable.is_null().not() {
                            write_ptr(ptr_add(dst_data, foff.cast(U64)), callable_storage_clone(src_callable))
                        }
                        continue
                    }
                    ref src_ptr : Dynamic = deref(ptr_add(data, foff.cast(U64)))
                    if src_ptr.is_null().not() {
                        if nested_def.is_null().not() {
                            ref stable_ftype : Str = stable_type_name(ftype, ctx)
                            cloned_ptr : Dynamic = heap_clone(stable_ftype, to_ptr(src_ptr), ctx)
                            write_ptr(ptr_add(dst_data, foff.cast(U64)), cloned_ptr)
                        }
                    }
                    continue
                }
                if dd.own_type.is(OwnType.Ref) { continue }
                if decl_is_funcsig(dd, ctx) {
                    ref src_callable2 : Dynamic = deref(ptr_add(data, foff.cast(U64)))
                    if src_callable2.is_null().not() {
                        write_ptr(ptr_add(dst_data, foff.cast(U64)), callable_storage_clone(src_callable2))
                    }
                    continue
                }
                if ftype == "Str" {
                    ref s : Str = ptr_add(data, foff.cast(U64))
                    if str_owns_c_str(s) {
                        cloned_str := s.clone()
                        write_ptr(ptr_add(dst_data, foff.cast(U64)), cloned_str.c_str)
                        ref mut dst_cap : U32 = ptr_add(ptr_add(dst_data, foff.cast(U64)), 12)
                        dst_cap = s.count.clone()
                        memset(cloned_str, 0, Str.size().cast(U64))
                    }
                    continue
                }
                if nested_def.is_null().not() {
                    if nested_def.node_type.is(NodeType.EnumDef) {
                        if enum_has_payloads(nested_def) {
                            if dd.own_type.is(OwnType.Own).or(dd.own_type.is(OwnType.Ref)) {
                                ref ei_ref : Dynamic = deref(ptr_add(data, foff.cast(U64)))
                                if ei_ref.is_null().not() {
                                    ref ei : EnumInstance = ei_ref
                                    cloned_ei := ei.clone()
                                    heap_ei : Dynamic = EvalHeap.heap_alloc(EnumInstance.size())
                                    move(heap_ei, cloned_ei, EnumInstance.size().cast(U64))
                                    write_ptr(ptr_add(dst_data, foff.cast(U64)), heap_ei)
                                }
                            } else {
                                mut temp_decl := dd
                                temp_decl.own_type = OwnType.Shallow
                                val := read_field(data, temp_decl, foff, ctx)
                                mut cloned_val := val.clone()
                                switch cloned_val {
                                case Value.Enum(cei):
                                    memcpy(ptr_add(dst_data, foff.cast(U64)), cei.data, cei.data_size.cast(U64))
                                    free(own cei.data)
                                    cei.data = NULL
                                case:
                                }
                                switch val {
                                case Value.Enum(cei):
                                    if cei.borrowed.not() {
                                        free(own cei.data)
                                    }
                                    cei.data = NULL
                                case:
                                }
                            }
                            continue
                        }
                    }
                }
                if nested_def.is_null().not() {
                    if nested_def.node_type.is(NodeType.EnumDef).not() {
                        switch nested_def.node_type {
                        case NodeType.StructDef:
                            ref stable_ftype2 : Str = stable_type_name(ftype, ctx)
                            cloned_ptr2 : Dynamic = heap_clone(stable_ftype2, ptr_add(data, foff.cast(U64)), ctx)
                            memcpy(ptr_add(dst_data, foff.cast(U64)), cloned_ptr2, ctx_total_size(ftype, ctx).cast(U64))
                            EvalHeap.heap_free(own cloned_ptr2)
                        case:
                            UNREACHABLE()
                        }
                    }
                }
            }
        }
        return dst_data
    case:
        UNREACHABLE()
        return NULL
    }
}

StructInstance := struct {
    // Issue #239 / #286: the type name is no longer a `ref` into the AST (which
    // dangled once the AST Expr was freed -- the #239 UAF). It is DERIVED from
    // `layout`, a stable borrow of the frozen struct_layouts cache that outlives
    // the AST, via the struct_name() accessor below.
    is_str := false
    is_str_container := false
    // Issue #147 step 4: reference to the running Context so the
    // fixed-signature clone path can reach the type-def registry
    // (lookup_interp_type_def) and struct_layouts for nested-field lookup.
    ref ctx : Context = NULL
    // #286: borrow of this struct's StructLayout (from the frozen struct_layouts
    // cache). The value's sole source of its type name. Set by make_struct_value;
    // NULL only for empty/sentinel instances.
    ref layout : StructLayout = NULL
    own data : U8 = 0
    borrowed := false
namespace:
    // #286: type name derived from the stable layout (no AST-lifetime ref).
    struct_name := func(self: StructInstance) returns ref Str {
        return self.layout.name
    }
    eq := func(a: StructInstance, b: StructInstance) returns Bool {
        return a.struct_name() == b.struct_name()
    }
    to_str := func(self: StructInstance) returns Str {
        expect(self.layout.is_null().not(), "self.layout is null")
        return self.struct_name().clone()
    }
    clone := func(self: StructInstance) returns StructInstance {
        dst_data : Dynamic = heap_clone(self.struct_name(), self.data, self.ctx)
        is_str_container := self.is_str_container.or(container_elem_type(self.struct_name()) == "Str")
        return StructInstance(is_str = self.is_str, is_str_container = is_str_container, ctx = self.ctx, layout = self.layout, data = dst_data, borrowed = false)
    }
    delete := func(own self: StructInstance, call_free: Bool = true) {
        // Deep delete: free the struct payload buffer (and, for a Str
        // payload, its c_str) unless this is a borrowed alias. Read sites
        // mark their copy borrowed = true; sites that hand a raw .data
        // pointer to a manual free likewise mark borrowed so this delete
        // hands off. Ordinary moves null their source. The garbager inserts
        // Value.delete -> StructInstance.delete at every owned struct
        // value's last use, so this is where the payload is reclaimed.
        if self.borrowed.not() {
            if self.data.is_null().not() {
                // #286 Stage 2: deep-free the contents through the canonical
                // heap_drop (dual of heap_clone) when the layout is known, then
                // free the owning block. A layout-less sentinel just frees block.
                if self.layout.is_null().not() {
                    heap_drop(self.struct_name(), self.data, self.ctx)
                }
                EvalHeap.heap_free(own self.data)
            }
        }
        if call_free { free(own self) }
    }
}

EnumInstance := struct {
    // Issue #239 / #286: no AST-lifetime enum_name ref. The type name is DERIVED
    // from `layout`, a stable borrow of the frozen struct_layouts cache, via the
    // enum_name() accessor below.
    ref layout : StructLayout = NULL
    own data : U8 = 0
    data_size : USize = 0
    borrowed := false
    // Issue #272: true when the active variant's payload is a Str whose c_str
    // this enum OWNS (cloned at construction). delete frees it; clone deep-
    // copies it. Without it the payload c_str was shared with the source Str,
    // leaking (shallow scopes) or dangling (deep scopes) once the source died.
    is_str := false
namespace:
    // #286: type name derived from the stable layout (no AST-lifetime ref).
    enum_name := func(self: EnumInstance) returns ref Str {
        return self.layout.name
    }
    eq := func(a: EnumInstance, b: EnumInstance) returns Bool {
        return a.enum_name == b.enum_name
    }
    to_str := func(self: EnumInstance) returns Str {
        expect(self.layout.is_null().not(), "self.layout is null")
        return self.enum_name().clone()
    }
    clone := func(self: EnumInstance) returns EnumInstance {
        if self.data.is_null() {
            return EnumInstance(layout = self.layout,
                                data = NULL, data_size = self.data_size, borrowed = false, is_str = self.is_str)
        }
        pdata : Dynamic = EvalHeap.heap_alloc(self.data_size)
        memcpy(pdata, self.data, self.data_size.cast(U64))
        // Issue #272: the memcpy shared the Str-payload c_str; deep-copy it so
        // the clone owns an independent buffer (mirrors StructInstance.clone).
        if self.is_str { enum_clone_str_payload(pdata) }
        return EnumInstance(layout = self.layout,
                            data = pdata, data_size = self.data_size, borrowed = false, is_str = self.is_str)
    }
    delete := func(own self: EnumInstance, call_free: Bool = true) {
        // Deep delete: free the payload buffer unless this is a borrowed
        // alias (read sites mark the copy borrowed = true; raw-pointer
        // hand-off sites likewise). The garbager inserts Value.delete ->
        // EnumInstance.delete at every owned enum value's last use, so this
        // is where the payload is reclaimed. enum_name is a ref (Issue #239)
        // -- never freed here, never read here.
        if self.data.is_null().not().and(self.borrowed.not()) {
            // Issue #272: free the owned Str-payload c_str before the buffer.
            if self.is_str { enum_free_str_payload(self.data) }
            EvalHeap.heap_free(own self.data)
        }
        if call_free { free(own self) }
    }
}

InterpClosure := struct {
    ref func_def : Expr = NULL
    ref env : Scope = NULL
    borrowed := false
}

Value := enum {
    None,
    Int: I64,
    Byte: U8,
    Short: I16,
    Int32: I32,
    Uint32: U32,
    Uint64: U64,
    Float: F32,
    Boolean: Bool,
    Func: Dynamic,
    Struct: StructInstance,
    Enum: EnumInstance,
    Ref: Dynamic,
    Dynamic: Dynamic,
    // Sbyte / Ushort appended at the end (rather than next to Byte /
    // Short) so existing variant tag values stay stable: master's
    // til_boot has the integer tags baked into its compiled C, and
    // inserting a variant in the middle would mis-decode Value tags
    // during bootstrap.
    Sbyte: I8,
    Ushort: U16,
    Closure: InterpClosure
namespace:
    eq := func(a: Value, b: Value) returns Bool {
        switch a {
        case Value.None:
            return b.is(Value.None)
        case Value.Int(ai):
            switch b {
            case Value.Int(bi):
                return ai == bi
            case:
                return false
            }
        case Value.Boolean(ab):
            switch b {
            case Value.Boolean(bb):
                return ab == bb
            case:
                return false
            }
        case:
            return false
        }
    }
    to_str := func(self: Value) returns Str {
        switch self {
        case Value.None:       return "None"
        case Value.Int(v):     return v.to_str()
        case Value.Boolean(v): return v.to_str()
        case:                  return "Value"
        }
    }
    clone := func(self: Value) returns Value {
        switch self {
        case Value.Struct(si):
            // Value_Struct deep-clones via StructInstance_clone, so the
            // returned Value owns a fresh data buffer. The intermediate
            // clone is reclaimed by the garbager (StructInstance.delete is
            // deep), so no manual free here.
            return Value.Struct(si.clone())
        case Value.Enum(ei):
            // Value_Enum deep-clones via EnumInstance_clone, so the returned
            // Value owns a fresh buffer. The intermediate clone is reclaimed
            // by the garbager (EnumInstance.delete is deep), so no manual
            // free here.
            return Value.Enum(ei.clone())
        case Value.Int(v):     return Value.Int(v)
        case Value.Byte(v):    return Value.Byte(v)
        case Value.Sbyte(v):   return Value.Sbyte(v)
        case Value.Short(v):   return Value.Short(v)
        case Value.Ushort(v):  return Value.Ushort(v)
        case Value.Int32(v):   return Value.Int32(v)
        case Value.Uint32(v):  return Value.Uint32(v)
        case Value.Uint64(v):  return Value.Uint64(v)
        case Value.Float(v):   return Value.Float(v)
        case Value.Boolean(v): return Value.Boolean(v)
        case Value.None:       return Value.None
        case Value.Func(payload):
            // void* payload reinterpreted via U64 (both 8 bytes)
            ref raw : U64 = payload
            return Value.Func(ptr_add(NULL, raw))
        case Value.Closure(cl):
            return Value.Closure(interp_closure_clone(cl))
        case Value.Ref(payload):
            ref raw : U64 = payload
            return Value.Ref(ptr_add(NULL, raw))
        case Value.Dynamic(payload):
            ref raw : U64 = payload
            return Value.Dynamic(ptr_add(NULL, raw))
        }
    }
}

CALLABLE_BOX_MAGIC : U64 = 1414745932

InterpCallableBox := struct {
    magic : U64 = 0
    val := Value.None
}

Cell := struct {
    val := Value.None
}

Binding := struct {
    ref name : Str = NULL
    ref cell : Cell = NULL
    cell_is_local := false
}

HeapBinding := struct {
    til_type := Type.Unknown
    own_type := OwnType.Shallow
    is_local := false
    is_borrowed := false
    moved_out := false
}

Scope := struct {
    bindings := Map(Str, Binding).new()
    // #286: name -> raw heap pointer (rstil's heap_index), added alongside
    // `bindings` so eval can migrate value-kind by value-kind onto the
    // EvalHeap. A stored Dynamic is the block's real address (from
    // EvalHeap.heap_alloc); the value bytes live there.
    heap_index := Map(Str, Dynamic).new()
    // #286: metadata for heap_index entries. Values must not carry their
    // type/ownership inside the heap bytes; this map is the transition bridge
    // from boxed Value cells to the final raw-heap scope model.
    heap_bindings := Map(Str, HeapBinding).new()
    ref parent : Scope = NULL
    // #211 follow-up: payload bindings that alias an enum's payload memory.
    // Key: binding name (the case-binding identifier). Value: encoded as
    // "<enum_var_name>|<payload_type>" so writes can find the source enum
    // and mirror the assignment into ei.data + ENUM_PAYLOAD_OFFSET. An
    // empty map (the default) means "no aliases" and assignment behaves
    // exactly like before.
    payload_aliases := Map(Str, Str).new()
    // #227: ref-bindings to primitive scalars at a raw pointer
    // (`ref mut x : U32 = ptr_add(...)`) need to write back through the
    // original pointer on assignment. reinterpret_ptr_value collapses
    // val into a Value.<Primitive>(value) so the ptr is otherwise lost.
    // This side table keeps the source pointer so the Assign handler
    // can dispatch through the matching write_* primitive. Key: binding
    // name. Value: raw Dynamic pointer to the original storage cell.
    ref_primitive_ptrs := Map(Str, Dynamic).new()
    // Issue #217 follow-up: heap allocations created by
    // box_scalar_to_dynamic at this scope's call binding sites. Each
    // entry is a raw `Dynamic` pointer that scope_free must reclaim
    // (the matching Value.Dynamic in a binding cell only stores the
    // pointer; nothing else owns it, and the user has no name to
    // `free(own ...)` it explicitly). Empty by default -- only call
    // scopes whose params took scalar-to-Dynamic args populate it.
    //
    box_owned_dynamics := Vec(DynPtrBox).new()
    box_owned_callables := Vec(DynPtrBox).new()
}

InterpSession := struct {
    ref global : Scope = NULL
    core_evaluated := false
    user_argc : U32 = 0
}

// Return-value / control-flow state and namespace fields now live on
// Context (has_return, has_break, has_continue, return_value,
// ns_fields, ns_keys, ns_inited), reached in the eval functions via
// `ref mut c : Context = ctx`. Cached struct defs for
// C-side construction likewise live on Context (cached_*_def),
// populated during interpret_register_struct_defs.

// --- Type-def registry: maps struct/enum names to their AST def Expr.
// Populated by interpreter_init_ns from every struct/enum decl seen in core+user
// programs. Replaces dangerous Declaration.field_struct_def reads at use sites.
// (#147 anti-pattern catalog: layout cache on AST nodes / dangerous refs.)
// The map itself lives on Context (ctx.interp_type_defs); this reader
// reaches it through codegen_lp(), which interpret_units installs
// before any eval runs.
lookup_interp_type_def := func(name: Str, ctx: Context) returns ref Expr {
    ref slot : Dynamic = ctx.interp_type_defs.get(name)?
    catch (e: KeyNotFound) { return NULL }
    return deref(slot)
}

val_none := func() returns shallow Value {
    return Value.None
}
priv val_u8 := func(v: I64) returns shallow Value {
    return Value.Byte(v.to_u8())
}
priv val_i8 := func(v: I64) returns shallow Value {
    return Value.Sbyte(v.to_i8())
}
priv val_i16 := func(v: I64) returns shallow Value {
    return Value.Short(v.to_i16())
}
priv val_u16 := func(v: I64) returns shallow Value {
    return Value.Ushort(v.to_u16())
}
priv val_i32 := func(v: I64) returns shallow Value {
    return Value.Int32(v.to_i32())
}
priv val_u32 := func(v: I64) returns shallow Value {
    return Value.Uint32(v.to_u32())
}

ENUM_PAYLOAD_OFFSET : USize = 8

priv make_enum_value := func(enum_name: Str, data: Dynamic, data_size: USize, borrowed: Bool, is_str: Bool, ctx: Context) returns shallow Value {
    // #286: borrow the enum's layout from the frozen cache as the value's type-
    // name source (enum_name()); NULL only when no layout is computed.
    ref stable_enum_name : Str = stable_type_name(enum_name, ctx)
    if ctx.struct_layouts.has(stable_enum_name) {
        ref elayout : StructLayout = ctx.struct_layouts[stable_enum_name]
        return Value.Enum(EnumInstance(layout = elayout, data = data, data_size = data_size, borrowed = borrowed, is_str = is_str))
    }
    return Value.Enum(EnumInstance(data = data, data_size = data_size, borrowed = borrowed, is_str = is_str))
}

// Issue #272: does enum `enum_name`'s variant `etag` carry a Str payload?
priv enum_variant_is_str := func(enum_name: Str, etag: I32, ctx: Context) returns Bool {
    ref edef : Expr = lookup_interp_type_def(enum_name, ctx)
    if edef.is_null() { return false }
    switch edef.node_type {
    case NodeType.EnumDef(edd):
        if edd.payload_types.has(etag.cast(I64)) {
            return edd.payload_types[etag.cast(I64)] == "Str"
        }
    case:
    }
    return false
}

// Issue #272: the enum's Str payload (at ENUM_PAYLOAD_OFFSET) holds a c_str
// pointer that, post-memcpy, aliases the source Str. Replace it with an
// owned deep copy so the enum no longer shares the source's buffer.
priv enum_clone_str_payload := func(data: Dynamic) {
    ref pstr : Str = ptr_add(data, ENUM_PAYLOAD_OFFSET.cast(U64))
    if str_owns_c_str(pstr) {
        new_buf : Dynamic = EvalHeap.heap_alloc(pstr.count.add(1))
        memcpy(new_buf, pstr.c_str, pstr.count.cast(U64))
        memset(ptr_add(new_buf, pstr.count.cast(U64)), 0, 1)
        // The Str's c_str is the first field (offset 0); write the owned copy
        // directly. A `ref mut pstr; pstr.c_str = ...` did not write through.
        write_ptr(ptr_add(data, ENUM_PAYLOAD_OFFSET.cast(U64)), new_buf)
    }
}

// Free the owned Str-payload c_str (set up by enum_clone_str_payload).
priv enum_free_str_payload := func(data: Dynamic) {
    ref s_str : Str = ptr_add(data, ENUM_PAYLOAD_OFFSET.cast(U64))
    if str_owns_c_str(s_str) {
        free(own s_str.c_str)
    }
}

priv val_enum_flat := func(enum_name: Str, etag: I64, payload_data: Dynamic, payload_size: USize, total_enum_size: USize, str_payload: Bool, move_src: Bool, ctx: Context) returns shallow Value {
    mut alloc_size : USize = total_enum_size
    if alloc_size < 8 {
        alloc_size = 8
    }
    data : Dynamic = EvalHeap.heap_alloc(alloc_size)
    // #264 follow-up: write the enum's full tag width (1/2/4/8 bytes) so a
    // >32-bit U64 tag is stored intact. til's memcpy(dest, value, n) copies
    // the n low bytes of `etag`. REM: an anon / macro-generated enum is not
    // name-registered, so the lookup legitimately misses -- such enums are the
    // historical default width (4 bytes).
    ref tedef : Expr = lookup_interp_type_def(enum_name, ctx)
    mut tag_w : USize = 4
    if tedef.is_null().not() { tag_w = enum_tag_size(tedef) }
    memcpy(data, etag, tag_w.cast(UPtr))
    mut is_str := false
    if payload_data.is_null().not() {
        if payload_size > 0 {
            memcpy(ptr_add(data, ENUM_PAYLOAD_OFFSET.cast(U64)), payload_data, payload_size.cast(U64))
            if str_payload {
                is_str = true
                // Issue #272: the enum OWNS its Str payload c_str.
                //   move_src (construction): MOVE -- the source gives up the
                //   c_str (null it), so there is a single owner and no clone.
                //   else (reading an enum out of a pointer): CLONE, so the
                //   borrowed source and this enum each own an independent c_str.
                if move_src { write_ptr(payload_data, NULL) }
                else        { enum_clone_str_payload(data) }
            }
        }
    }
    return make_enum_value(enum_name, data, alloc_size, false, is_str, ctx)
}

priv val_enum_simple := func(enum_name: Str, etag: I64, total_enum_size: USize, ctx: Context) returns shallow Value {
    return val_enum_flat(enum_name, etag, NULL, 0, total_enum_size, false, false, ctx)
}

// #264: read a no-payload enum's discriminant from `p` at the enum's actual
// tag width (1/2/4/8 bytes) and box it. Reading a fixed I32 over-reads a
// 1/2-byte tag (e.g. the default U8 enum behind a Map slot -- bug150) and
// truncates an 8-byte one. The boxed width must also cover what the auto-
// generated is/eq pass to is_n (= enum_tag_size): a U64 tag stays a full
// 8-byte Value.Int so is_n(8) does not over-read the box.
priv read_enum_tag_value := func(p: Dynamic, tdef: Expr) returns Value {
    tag_w := enum_tag_size(tdef)
    if tag_w == 1 { ref t : U8 = p;  return Value.Int32(t.cast(U32).cast(I32)) }
    if tag_w == 2 { ref t : U16 = p; return Value.Int32(t.cast(U32).cast(I32)) }
    if tag_w == 8 { ref t : I64 = p; return Value.Int(t) }
    ref t : I32 = p
    return Value.Int32(t)
}

priv elem_size_for_type := func(type_name: Str) returns USize {
    if type_name == "I64"  { return I64.size() }
    if type_name == "U8"   { return U8.size() }
    if type_name == "I16"  { return I16.size() }
    if type_name == "U16"  { return U16.size() }
    if type_name == "I32"  { return I32.size() }
    if type_name == "U32"  { return U32.size() }
    if type_name == "Bool" { return Bool.size() }
    if type_name == "Str"  { return Str.size() }
    return 8
}

// Parse a single CLI argument string into a Value of the named type. Kept in
// lockstep with the builder's cli_box_expr (src/self/builder.til): same type
// set, same reject-non-true/false Bool handling, and a non-zero exit on a bad
// value or unsupported type, so `til interpret` and compiled binaries agree.
// (panic exits 1 like the compiled backend's exit(1); the diagnostic stream
// differs -- interpreter via panic, compiled via stderr -- but both bail.)
priv parse_cli_arg := func(s: Str, type_name: Str, ctx: Context) returns shallow Value {
    if type_name == "Str" { return make_str_value(s.c_str, s.count, ctx) }
    if type_name == "I64" { return Value.Int(s.to_i64()) }
    if type_name == "U8" { return Value.Byte(s.to_u8()) }
    if type_name == "I8" { return Value.Sbyte(s.to_i8()) }
    if type_name == "I16" { return Value.Short(s.to_i16()) }
    if type_name == "U16" { return Value.Ushort(s.to_u16()) }
    if type_name == "I32" { return Value.Int32(s.to_i32()) }
    if type_name == "U32" { return Value.Uint32(s.to_u32()) }
    if type_name == "U64" { return Value.Uint64(s.to_u64()) }
    if type_name == "USize" { return Value.Uint32(s.to_u32()) }
    if type_name == "UPtr" { return Value.Uint64(s.to_u64()) }
    if type_name == "F32" { return Value.Float(s.to_f32()) }
    if type_name == "Bool" {
        if s == "true" { return Value.Boolean(true) }
        if s == "false" { return Value.Boolean(false) }
        panic("cannot parse '", s, "' as Bool (expected true/false)")
    }
    panic("unsupported CLI argument type '", type_name, "'")
    return val_none()
}

// Borrowed pointer-view accessor: returns the slot ref backing a
// Value.Ref (borrowed view) or Value.Dynamic (owning opaque pointer).
// Neither variant is freed here; this is a read-only view helper.
priv value_ptr_view := func(v: Value) returns ref Dynamic {
    switch v {
    case Value.Ref(p):     return p
    case Value.Dynamic(p): return p
    case: return NULL
    }
}

priv is_value_ptr := func(v: Value) returns Bool {
    return v.is(Value.Ref).or(v.is(Value.Dynamic))
}

// For pointer-like objects (Value.Ref / Value.Dynamic) whose static type
// is Struct/Enum/Custom, look up the type's def in scope and reinterpret
// the pointer as a struct value so subsequent field-access has a struct
// to read from.
priv resolve_ptr_to_struct := func(mut obj: Value, scope: Scope, obj_sname: Str, ctx: Context) {
    if obj_sname.len() == 0 { return }
    ref tc : Cell = scope_get(scope, obj_sname)
    if tc.is_null() { return }
    switch tc.val {
    case Value.Func(tptr):
        ref tdef : Expr = deref(tptr)
        if tdef.node_type.is(NodeType.StructDef) {
            if is_value_ptr(obj) {
                ref pv : Dynamic = value_ptr_view(obj)
                obj = make_struct_value(obj_sname, deref(pv), true, ctx)
            }
        }
    case:
    }
}

eval_expr := proc(scope: Scope, e: Expr, mut ctx: Context) returns shallow Value {
    switch e.node_type {
    case NodeType.Literal(Literal.Str(raw)):
        buf : Dynamic = malloc(raw.count.add(1).cast(U64))
        mut j : USize = 0
        mut i : USize = 0
        while i < raw.count {
            ref ch : I8 = raw.unsafe_get(i)
            if ch == 92 {
                if i + 1 < raw.count {
                    ref next : I8 = raw.unsafe_get(i + 1)
                    if next == 110 { memset(ptr_add(buf, j.cast(U64)), 10, 1); j = j + 1; i = i + 2; continue }
                    if next == 116 { memset(ptr_add(buf, j.cast(U64)), 9, 1); j = j + 1; i = i + 2; continue }
                    if next == 92 { memset(ptr_add(buf, j.cast(U64)), 92, 1); j = j + 1; i = i + 2; continue }
                    if next == 34 { memset(ptr_add(buf, j.cast(U64)), 34, 1); j = j + 1; i = i + 2; continue }
                    if next == 48 { memset(ptr_add(buf, j.cast(U64)), 0, 1); j = j + 1; i = i + 2; continue }
                }
            }
            memcpy(ptr_add(buf, j.cast(U64)), ptr_add(raw.c_str, i.cast(U64)), 1)
            j++
            i++
        }
        memset(ptr_add(buf, j.cast(U64)), 0, 1)
        v := make_str_value(buf, j, ctx)
        free(own buf)
        return v
    case NodeType.Literal(Literal.Num(num_str)):
        lit_t := e.expr_til_type()
        switch lit_t {
        case Type.Primitive(Primitive.U8):  return Value.Byte(num_str.to_u8())
        case Type.Primitive(Primitive.I8):  return Value.Sbyte(num_str.to_i8())
        case Type.Primitive(Primitive.U32): return Value.Uint32(num_str.to_u32())
        case Type.Primitive(Primitive.U64): return Value.Uint64(num_str.to_u64())
        case Type.Primitive(Primitive.I16): return Value.Short(num_str.to_i16())
        case Type.Primitive(Primitive.U16): return Value.Ushort(num_str.to_u16())
        case Type.Primitive(Primitive.I32): return Value.Int32(num_str.to_i32())
        case Type.Primitive(Primitive.F32): return Value.Float(num_str.to_f32())
        case: return Value.Int(num_str.to_i64())
        }
    case NodeType.Literal(Literal.Bool(b)):
        return Value.Boolean(b)
    case NodeType.Literal(Literal.Null):
        return Value.Ref(NULL)
    case NodeType.Ident(ident):
        ref cell : Cell = scope_get(scope, ident.ident_name())
        if cell.is_null() {
            interp_error(e, format("undefined variable '", Str.clone(ident.ident_name()), "'"), ctx)
            exit(1)
        }
        return borrow_value(cell.val)
    case NodeType.FCall:
        return eval_call(scope, e, ctx)
    case NodeType.FuncDef(fd):
        if fd.captures.len().gt(0) { return make_interp_closure(e, scope) }
        return Value.Func(e)
    case NodeType.BodyValue:
        return make_interp_closure(e, scope)
    case NodeType.StructDef:
        return Value.Func(e)
    case NodeType.EnumDef:
        return Value.Func(e)
    case NodeType.FieldAccess(fname):
        mut obj := eval_expr(scope, e.children[0], ctx)
        if interp_fa_is_ns(scope, e) {
            mut sname := ""
            switch obj {
            case Value.Struct(si):
                sname = si.struct_name().clone()
            case Value.Enum(ei):
                // Issue: variant access on an enum instance (`v.Some`)
                // resolves through the enum's type name, not the variable
                // name. Prefer the typer-set til_type (always reliable);
                // fall back to the EnumInstance's own enum_name if for
                // some reason the obj_expr is type-stripped.
                sname = til_type_name(e.children[0].expr_til_type())
                if sname.len() == 0 {
                    sname = ei.enum_name().clone()
                }
            case:
                // Issue #297: prefer the typer-set til_type (reliable, and
                // for an alias receiver it already holds the resolved target
                // struct name); fall back to the literal Ident name, then to
                // til_type_name_c for primitive receivers (LiteralNum I64).
                sname = til_type_name(e.children[0].expr_til_type())
                if sname.len() == 0 {
                    switch e.children[0].node_type {
                    case NodeType.Ident(ident):
                        sname = Str.clone(ident.ident_name())
                    case:
                        // Primitive receiver (LiteralNum I64, etc.).
                        sname = til_type_name_c(e.children[0].expr_til_type())
                    }
                }
            }
            ref nsv : Value = ns_get(sname, fname.field_access_name(), ctx)
            if nsv.is_null().not() {
                switch nsv {
                case Value.Int(iv):     return Value.Int(iv)
                case Value.Int32(iv):   return Value.Int32(iv)
                case Value.Func(fptr):
                    if e.expr_til_type().is(Type.Enum) {
                        ref fdef : Expr = deref(fptr)
                        switch fdef.node_type {
                        case NodeType.FuncDef(fd):
                            if fd.func_type.is(FuncType.ExtFunc) {
                                ref tc : Cell = scope_get(scope, sname)
                                if tc.is_null().not() {
                                    switch tc.val {
                                    case Value.Func(eptr):
                                        ref edef : Expr = deref(eptr)
                                        if edef.node_type.is(NodeType.EnumDef) {
                                            total_size : USize = ctx_total_size(sname, ctx)
                                            tag := enum_variant_tag(edef, fname.field_access_name())
                                            if tag >= 0 {
                                                if enum_has_payloads(edef) {
                                                    return val_enum_flat(sname, tag, NULL, 0, total_size, false, false, ctx)
                                                } else {
                                                    // #264 follow-up: a U64 (8-byte) tag may exceed I32,
                                                    // so carry it as a full I64; narrower tags stay Int32.
                                                    if enum_tag_size(edef) > 4 { return Value.Int(tag) }
                                                    return Value.Int32(tag.to_i32())
                                                }
                                            }
                                        }
                                    case:
                                    }
                                }
                            }
                        case:
                        }
                    }
                case:
                }
                return borrow_value(nsv)
            }
            interp_error(e, format("no namespace field '", Str.clone(fname.field_access_name()), "'"), ctx)
            exit(1)
        }
        if is_value_ptr(obj) {
            obj_t := e.children[0].expr_til_type()
            switch obj_t {
            case Type.Struct(obj_sname):
                resolve_ptr_to_struct(obj, scope, obj_sname, ctx)
            case Type.Enum(obj_sname):
                resolve_ptr_to_struct(obj, scope, obj_sname, ctx)
            case Type.Custom(obj_sname):
                resolve_ptr_to_struct(obj, scope, obj_sname, ctx)
            case:
            }
        }
        if obj.is(Value.Struct).not() {
            interp_error(e, "field access on non-struct", ctx)
            exit(1)
        }
        switch obj {
        case Value.Struct(si):
            ref fdecl : Declaration = find_field_decl(lookup_interp_type_def(si.struct_name(), si.ctx), fname.field_access_name())
            if fdecl.is_null() {
                interp_error(e, format("no field '", Str.clone(fname.field_access_name()), "'"), ctx)
                exit(1)
            }
            fl := ctx_field_layout(si.struct_name(), fname.field_access_name(), ctx)
            return read_field(si.data, fdecl, fl.offset, ctx)
        case:
            UNREACHABLE()
            return val_none()
        }
    case:
        interp_lang_error(e, "cannot evaluate node as expression", ctx)
        exit(1)
        return val_none()
    }
}

priv lookup_type_def_helper := func(type_name: Str, scope: Scope, ctx: Context) returns ref Expr {
    ref tc : Cell = scope_get(scope, type_name)
    if tc.is_null().not() {
        switch tc.val {
        case Value.Func(fptr):
            return deref(fptr)
        case:
        }
    }
    return lookup_interp_type_def(type_name, ctx)
}

// Reinterpret a pointer-like Value (Value.Ref / Value.Dynamic) to the
// appropriate scalar/struct/enum Value based on a type name. Used by
// eval_call (param binding) and eval_body (ref decl).
priv reinterpret_ptr_value := func(val: Value, type_name: Str, scope: Scope, ctx: Context, borrow: Bool) returns Value {
    if is_value_ptr(val) {
        ref pv : Dynamic = value_ptr_view(val)
        ref p : Dynamic = deref(pv)
        if p.is_null() { return shallow_copy_value(val) }
        if type_name.len() == 0 { return shallow_copy_value(val) }
        // Dynamic is a void-pointer type; the slot pointer IS the value, no
        // narrowing needed. Without this early-return the generic StructDef
        // lookup below would match Dynamic (registered as StructDef in
        // src/core/dyn.til) and wrap the pointer into a Value.Struct, which
        // breaks downstream code that expects ref-Dynamic bindings to stay
        // as Value.Ref/Value.Dynamic (#180).
        if type_name == "Dynamic" { return shallow_copy_value(val) }
        if type_name == "I64" { ref v : I64 = p; return Value.Int(v) }
        if type_name == "U8" { ref v : U8 = p; return Value.Byte(v) }
        if type_name == "I8" { ref v : I8 = p; return Value.Sbyte(v) }
        if type_name == "I16" { ref v : I16 = p; return Value.Short(v) }
        if type_name == "U16" { ref v : U16 = p; return Value.Ushort(v) }
        if type_name == "I32" { ref v : I32 = p; return Value.Int32(v) }
        if type_name == "U32" { ref v : U32 = p; return Value.Uint32(v) }
        if type_name == "U64" { ref v : U64 = p; return Value.Uint64(v) }
        if type_name == "USize" { ref v : U32 = p; return Value.Uint32(v) }
        if type_name == "UPtr" {
            ref uptr_name : Str = resolve_type_alias(ctx.scope, "UPtr")
            if uptr_name == "U32" { ref v : U32 = p; return Value.Uint32(v) }
            ref v : U64 = p
            return Value.Uint64(v)
        }
        if type_name == "F32" { ref v : F32 = p; return Value.Float(v) }
        if type_name == "Bool" { ref v : Bool = p; return Value.Boolean(v) }
        if type_name == "Str" {
            if borrow {
                // Issue #272: a `ref` binding VIEWS the Str at p (e.g. the
                // payload alias `ref p : Str = get_payload(c)` aliases the enum
                // payload's c_str). Return a BORROWED view -- there is no owned
                // copy to leak, and the always-deep teardown skips it. (The
                // value-binding path below still COPIES: see its comment.)
                ref str_sdef : Expr = lookup_interp_type_def("Str", ctx)
                if str_sdef.is_null().not() {
                    return make_struct_value("Str", p, true, ctx)
                }
            }
            ref sp : Str = p
            // COPY (not _own): sp.c_str belongs to the underlying value the
            // pointer references, not to us. make_str_value_own would claim
            // ownership of a shared buffer, so the caller's save-old-delete
            // (arg = widen_numeric(arg)) or scope_set_owned would free the
            // source's c_str and dangle it. Copying yields an independent
            // owned Str.
            return make_str_value(sp.c_str, sp.count, ctx)
        }
        ref tdef : Expr = lookup_type_def_helper(type_name, scope, ctx)
        if tdef.is_null().not() {
            if tdef.node_type.is(NodeType.FuncDef) {
                if tdef.children.len() == 0 {
                    // Dynamic params can carry either a callable box or a slot.
                    return callable_box_or_slot_read(p)
                }
            }
            if tdef.node_type.is(NodeType.EnumDef) {
                if enum_has_payloads(tdef) {
                    total_size : USize = ctx_total_size(type_name, ctx)
                    ref inline_etag : I32 = p
                    mut inline_psz : USize = 0
                    if total_size >= ENUM_PAYLOAD_OFFSET {
                        inline_psz = total_size - ENUM_PAYLOAD_OFFSET
                    }
                    return val_enum_flat(type_name, inline_etag.cast(I64), ptr_add(p, ENUM_PAYLOAD_OFFSET.cast(U64)), inline_psz, total_size, enum_variant_is_str(type_name, inline_etag, ctx), false, ctx)
                }
                return read_enum_tag_value(p, tdef)
            }
            if tdef.node_type.is(NodeType.StructDef) {
                return make_struct_value(type_name, p, true, ctx)
            }
        }
        // Independent clone, not a borrow: callers use `val = reinterpret_
        // ptr_value(val, ...)`, whose save_old_delete frees the old val after
        // evaluating the rhs -- a borrow aliasing that (non-borrowed) val
        // would dangle. The value_ptr branches above already return fresh
        // values; only these fall-throughs aliased the input.
        return val.clone()
    }
    return val.clone()
}

// Check if call should be skipped because first own param is None/borrowed/pointer-like.
// Returns true if call should be skipped (caller returns val_none).
priv guard_own_param_skip := func(scope: Scope, e: Expr, func_def: Expr) returns Bool {
    switch func_def.node_type {
    case NodeType.FuncDef(fd):
        if fd.params.len() == 0 { return false }
        if fd.params[0].own_type.is(OwnType.Own).not() { return false }
        if e.children.len() <= 1 { return false }
        switch e.children[1].node_type {
        case NodeType.Ident(arg_ident):
            ref fc : Cell = scope_get(scope, arg_ident.ident_name())
            if fc.is_null() { return false }
            if fc.val.is(Value.None) { return true }
            switch fc.val {
            case Value.Struct(si):
                if si.borrowed { memcpy(fc.val, val_none(), Value.size().cast(U64)); return true }
            case:
            }
            if is_value_ptr(fc.val) { memcpy(fc.val, val_none(), Value.size().cast(U64)); return true }
            return false
        case:
            return false
        }
    case:
        UNREACHABLE()
        return false
    }
}

priv resolve_field_assign_base := func(scope: Scope, obj_expr: Expr) returns ref Dynamic {
    switch obj_expr.node_type {
    case NodeType.Ident(ident):
        ref cell : Cell = scope_get(scope, ident.ident_name())
        if cell.is_null() { return NULL }
        switch cell.val {
        case Value.Struct(si):
            return si.data
        case:
            return NULL
        }
    case:
        return NULL
    }
}

priv resolve_field_assign_sdef := func(scope: Scope, obj_expr: Expr) returns ref Expr {
    switch obj_expr.node_type {
    case NodeType.Ident(ident):
        ref cell : Cell = scope_get(scope, ident.ident_name())
        if cell.is_null() { return NULL }
        switch cell.val {
        case Value.Struct(si):
            return lookup_interp_type_def(si.struct_name(), si.ctx)
        case:
            return NULL
        }
    case:
        return NULL
    }
}

// #254: normalize any integer/char Value to I64 so a switch scrutinee and its
// constant labels compare numerically even when they decode to different Value
// variants (e.g. a U8 label vs an I8 scrutinee).
priv value_as_i64 := func(v: Value) returns I64 {
    switch v {
    case Value.Int(x):    return x
    case Value.Byte(x):   return x.to_i64()
    case Value.Short(x):  return x.cast(I64)
    case Value.Int32(x):  return x.cast(I64)
    case Value.Uint32(x): return x.to_i64()
    case Value.Uint64(x): return x.cast(I64)
    case Value.Sbyte(x):  return x.cast(I64)
    case Value.Ushort(x): return x.to_i64()
    case Value.Boolean(x):
        if x { return 1 }
        return 0
    case: return 0
    }
}

// #254: the comparison key for a switch scrutinee or case label. For an enum
// the discriminant is the tag (first I32 of the flat EnumInstance data); a
// no-payload enum decodes as Value.Int32(tag) and a bare `Type.Variant` label
// of a payload enum decodes as a flat Value.Enum -- both reduce to the tag.
priv value_switch_key := func(v: Value) returns I64 {
    switch v {
    case Value.Enum(ei):
        expect(ei.data.is_null().not(), "ei.data is null")
        ref tag_ptr : Dynamic = ei.data
        ref tag_ref : I32 = tag_ptr
        return tag_ref.cast(I64)
    case: return value_as_i64(v)
    }
}

// #254: execute a switch the typer left un-desugared (C-like). Evaluate the
// scrutinee once, run the first case whose constant label compares equal, else
// the default. break/continue/return propagate via Context flags (eval_body
// returns early when one is set), so a case-body `continue`/`return` reaches
// the enclosing loop/function unchanged.
// #276: the variant name of a case pattern -- a bare `Type.V` (FieldAccess) or
// a payload binding `Type.V(x)` (FCall whose FieldAccess callee names V).
priv clike_case_variant_name := func(pat: Expr) returns Str {
    switch pat.node_type {
    case NodeType.FieldAccess(fa): return Str.clone(fa.field_access_name())
    case NodeType.FCall:
        if pat.children.len() > 0 {
            switch pat.children[0].node_type {
            case NodeType.FieldAccess(fa2): return Str.clone(fa2.field_access_name())
            case:
            }
        }
        return ""
    case: return ""
    }
}

priv eval_switch := proc(scope: Scope, stmt: Expr, mut ctx: Context) {
    ref mut c : Context = ctx
    subj := eval_expr(scope, stmt.children[0], ctx)
    subj_i := value_switch_key(subj)
    // For an enum scrutinee, resolve each case label by its variant TAG via the
    // enum def: a bare payload variant (`Type.V`) evaluates to its constructor,
    // not a tagged value, so it can't be eval'd for the key. int/char/bool
    // labels are constant expressions and evaluate directly.
    is_enum_subj := subj.is(Value.Enum)
    mut sname := til_type_name(stmt.children[0].expr_til_type())
    if sname.is_empty() {
        switch subj {
        case Value.Enum(ei): sname = ei.enum_name().clone()
        case:
        }
    }
    ref enum_def : Expr = lookup_type_def_helper(sname, scope, ctx)
    mut has_default := false
    mut default_idx : U32 = 0
    for ci in 1..stmt.children.len() {
        ref cn : Expr = stmt.children[ci]
        if cn.children.len() == 1 {
            has_default = true
            default_idx = ci
            continue
        }
        mut matched := false
        if is_enum_subj.and(enum_def.is_null().not()) {
            matched = enum_variant_tag(enum_def, clike_case_variant_name(cn.children[0])) == subj_i
        } else if is_range_new_call(cn.children[0]) {
            // #254 range case `lo..hi`: match lo <= subj <= hi.
            lo := value_switch_key(eval_expr(scope, cn.children[0].children[1], ctx))
            hi := value_switch_key(eval_expr(scope, cn.children[0].children[2], ctx))
            matched = subj_i.gte(lo).and(subj_i.lte(hi))
        } else {
            matched = value_switch_key(eval_expr(scope, cn.children[0], ctx)) == subj_i
        }
        if matched {
            case_scope := scope_new(scope)
            eval_body(case_scope, cn.children[1], ctx)
            reclone_return(c)
            scope_free(own case_scope)
            return
        }
    }
    if has_default {
        def_scope := scope_new(scope)
        eval_body(def_scope, stmt.children[default_idx].children[0], ctx)
        reclone_return(c)
        scope_free(own def_scope)
    }
}

priv eval_declaration := proc(scope: Scope, stmt: Expr, dd: Declaration, mut ctx: Context) {
    ref rhs : Expr = stmt.children[0]
    if stmt.expr_til_type().is(Type.None) {
        if rhs.node_type.is(NodeType.Ident) { return }
    }
    if dd.own_type.is(OwnType.Ref) {
        switch rhs.node_type {
        case NodeType.Ident(rhs_ident):
            ref src : Cell = scope_get(scope, rhs_ident.ident_name())
            scope_set_borrowed(scope, dd.name, src)
            return
        case:
        }
    }
    mut val := val_none()
    switch rhs.node_type {
    case NodeType.Ident(rhs_ident):
        ref src : Cell = scope_get(scope, rhs_ident.ident_name())
        if src.is_null() {
            interp_error(rhs, format("undefined variable '", Str.clone(rhs_ident.ident_name()), "'"), ctx)
            exit(1)
        }
        val = shallow_copy_value(src.val)
        if val.is(Value.Func).not() {
            memcpy(src.val, val_none(), Value.size().cast(U64))
        }
    case:
        val = eval_expr(scope, rhs, ctx)
    }
    if dd.own_type.is(OwnType.Ref) {
        // Only a POINTER rhs is a genuine view (e.g. the ref-mut payload
        // alias `ref p : Str = get_payload(c)` aliases the enum payload's
        // c_str): reinterpret it to the declared type and mark it
        // borrowed so the always-deep teardown never frees the aliased
        // buffer (a later read would be a use-after-free). A VALUE rhs
        // (e.g. `ref s : Str = f()`) instead binds -- and extends the
        // lifetime of -- a temporary: fall through and let the cell OWN
        // it (preserving val's real borrowed flag). Issue #272: the old
        // code reinterpret-cloned AND force-borrowed every ref binding,
        // so a value-rhs ref leaked the owned clone (the cell skipped it
        // as "borrowed") -- the dominant constfolder ref-binding leak.
        if is_value_ptr(val) {
            if dd.explicit_type.len() > 0 {
                // #227: for ref-mut bindings to primitive scalars at a
                // raw pointer, save the source ptr so a later Assign
                // can write back through it. reinterpret_ptr_value
                // collapses val into a Value.<Primitive>(scalar)
                // immediately below, which would otherwise lose the
                // address.
                if interp_is_primitive_type_name(dd.explicit_type) {
                    ref ptr_view : Dynamic = value_ptr_view(val)
                    ref source_addr : Dynamic = deref(ptr_view)
                    if source_addr.is_null().not() {
                        holder : Dynamic = malloc(8)
                        write_ptr(holder, source_addr)
                        scope.ref_primitive_ptrs.set(dd.name, own holder)
                    }
                }
                val = reinterpret_ptr_value(val, dd.explicit_type, scope, ctx, true)
            }
            switch val {
            case Value.Struct(rsi): rsi.borrowed = true
            case Value.Enum(rei):   rei.borrowed = true
            case:
            }
        }
    }
    scope_set_owned(scope, dd.name, val)
    // #211 follow-up: register an alias for `ref T = get_payload(<ident>)`.
    // When the user later assigns to dd.name, we'll mirror the write into
    // the source enum's payload memory so the change is visible after
    // the case body (matching the compile backend).
    if dd.own_type.is(OwnType.Ref) {
        switch rhs.node_type {
        case NodeType.FCall:
            if rhs.children.len() == 2 {
                switch rhs.children[0].node_type {
                case NodeType.Ident(head_id):
                    if head_id.ident_name() == "get_payload" {
                        switch rhs.children[1].node_type {
                        case NodeType.Ident(enum_id):
                            enc := format(Str.clone(enum_id.ident_name()), "|", dd.explicit_type)
                            scope.payload_aliases.set(dd.name, own enc.clone())
                        case:
                        }
                    }
                case:
                }
            }
        case:
        }
    }
}

priv eval_fcall := proc(scope: Scope, stmt: Expr, fcd: FCallData, mut ctx: Context) {
    // #272 step 3: a swap_replace FCall is hoist_param_swap_assign's
    // lowering of `param = rhs` for a mut aggregate param. The
    // compiled backend emits delete-copy-free (a MOVE: delete the
    // target's old value, value-copy the temp in, free the temp
    // wrapper; the garbager's swap_freed accounting assumes the
    // temp was consumed). Running the literal byte swap here
    // instead left the target and the temp aliasing one payload,
    // which blocks deep scope teardown (UAF). Mirror the move:
    // deep-delete the target cell's old value, move the temp's
    // Value in, null the temp cell so its teardown is a no-op.
    mut did_swap_replace := false
    if fcd.swap_replace.and(stmt.children.len().gte(3)) {
        mut sw_target := ""
        mut sw_src := ""
        switch stmt.children[1].node_type {
        case NodeType.Ident(sw_t): sw_target = Str.clone(sw_t.ident_name())
        case:
        }
        switch stmt.children[2].node_type {
        case NodeType.Ident(sw_s): sw_src = Str.clone(sw_s.ident_name())
        case:
        }
        if sw_target.len().gt(0).and(sw_src.len().gt(0)) {
            ref sw_tcell : Cell = scope_get(scope, sw_target)
            ref sw_scell : Cell = scope_get(scope, sw_src)
            if sw_tcell.is_null().not().and(sw_scell.is_null().not()) {
                sw_tcell.val = val_none()
                memcpy(sw_tcell.val, sw_scell.val, Value.size().cast(U64))
                memcpy(sw_scell.val, val_none(), Value.size().cast(U64))
                did_swap_replace = true
            }
        }
    }
    if did_swap_replace { return }
    // Issue #109: a bare call-statement discards its result Value.
    // The garbager inserts a deep Value.delete for this discarded
    // result at its last use, reclaiming any heap payload. Borrowed
    // results carry borrowed = true, so the deep delete skips them.
    _ := eval_call(scope, stmt, ctx)
}

priv eval_if := proc(scope: Scope, stmt: Expr, mut ctx: Context) {
    ref mut c : Context = ctx
    cond := eval_expr(scope, stmt.children[0], ctx)
    mut cv := false
    switch cond {
    case Value.Boolean(b):
        cv = b
    case:
        UNREACHABLE()
    }
    if cv {
        then_scope := scope_new(scope)
        eval_body(then_scope, stmt.children[1], ctx)
        reclone_return(c)
        scope_free(own then_scope)
    } else if stmt.children.len() > 2 {
        else_scope := scope_new(scope)
        eval_body(else_scope, stmt.children[2], ctx)
        reclone_return(c)
        scope_free(own else_scope)
    }
}

priv eval_while := proc(scope: Scope, stmt: Expr, mut ctx: Context) {
    ref mut c : Context = ctx
    while true {
        if c.has_return { break }
        // A const-folder abort inside the loop body stops iteration (the
        // body's eval_body already bailed); don't re-evaluate the condition.
        if c.constfold_aborted { break }
        cond := eval_expr(scope, stmt.children[0], ctx)
        mut cv := false
        switch cond {
        case Value.Boolean(b):
            cv = b
        case:
            UNREACHABLE()
        }
        if cv.not() { break }
        while_scope := scope_new(scope)
        eval_body(while_scope, stmt.children[1], ctx)
        reclone_return(c)
        scope_free(own while_scope)
        if c.has_break { c.has_break = false; break }
        if c.has_continue { c.has_continue = false }
    }
}

priv eval_body := proc(scope: Scope, body: Expr, mut ctx: Context) {
    ref mut c : Context = ctx
    for mut e_i : Expr in body.children {
        if c.has_return { return }
        if c.has_break { return }
        if c.has_continue { return }
        // A const-folder abort unwinds every enclosing body like an early
        // return until try_eval_call observes it.
        if c.constfold_aborted { return }
        ref mut stmt : Expr = e_i
        switch stmt.node_type {
        case NodeType.Decl(dd):
            eval_declaration(scope, stmt, dd, ctx)
        case NodeType.Assign(ad):
            ref rhs : Expr = stmt.children[0]
            ref cell : Cell = scope_get(scope, ad.name)
            if cell.is_null() {
                interp_error(stmt, format("undefined variable '", ad.name, "'"), ctx)
                exit(1)
            }
            if stmt.expr_til_type().is(Type.Dynamic) {
                if rhs.node_type.is(NodeType.Ident) {
                    switch rhs.node_type {
                    case NodeType.Ident(rhs_ident):
                        ref src : Cell = scope_get(scope, rhs_ident.ident_name())
                        memcpy(cell.val, src.val, Value.size().cast(U64))
                        if src.val.is(Value.Func).not() {
                            memcpy(src.val, val_none(), Value.size().cast(U64))
                        }
                    case:
                    }
                    continue
                }
            }
            new_val := eval_expr(scope, rhs, ctx)
            // Free the cell's previous payload before the overwrite -- the
            // interp-mode mirror of the compiled backend's save_old_delete.
            // The FieldAssign emits the deep delete of the old Value (the
            // insert_field_deletes pre-pass); borrowed payloads are skipped
            // by the deep delete itself. The raw memcpy alone leaked every
            // reassigned value (the dominant interpret-mode leak). Aliasing
            // is safe: the typed AST's value semantics make any rhs that
            // reads the old value a clone by the time it gets here.
            cell.val = val_none()
            assign_is_alias := scope_get_payload_alias(scope, ad.name).len() > 0
            // Issue #275: value semantics -- a normal owning cell must OWN its
            // payload. read_field returns a BORROW for inline-struct/Str fields
            // (e.g. a caught error's `err.msg`); storing that borrow aliases the
            // source, which the always-deep teardown frees out from under the
            // owner. Clone borrowed rhs into an independent owner and move it in
            // (null the temp so the cell is the sole owner, no double-free). A
            // payload-alias binding is exempt: it is a VIEW whose write is
            // mirrored into the enum's payload below, so its cell stays borrowed.
            if value_is_borrowed(new_val).and(assign_is_alias.not()) {
                mut owned_copy := new_val.clone()
                memcpy(cell.val, owned_copy, Value.size().cast(U64))
                memcpy(owned_copy, val_none(), Value.size().cast(U64))
            } else {
                memcpy(cell.val, new_val, Value.size().cast(U64))
            }
            if assign_is_alias {
                switch cell.val {
                case Value.Struct(pasi): pasi.borrowed = true
                case Value.Enum(paei):   paei.borrowed = true
                case:
                }
            }
            // #227: for ref-mut bindings to a primitive scalar at a raw
            // pointer (`ref mut x : U32 = ptr_add(...)`), also write the
            // new value back through the saved source pointer so the
            // underlying storage actually changes. Without this, the
            // memcpy above just updates the cell's local Value, leaving
            // the original ptr_add target unmodified -- the compile-path
            // equivalent of issue #226's pointer-rebind bug.
            ref ref_ptr : Dynamic = scope_get_ref_primitive_ptr(scope, ad.name)
            if ref_ptr.is_null().not() {
                switch new_val {
                case Value.Int(iv):     write_i64(ref_ptr, iv)
                case Value.Byte(u8v):   write_u8(ref_ptr, u8v)
                case Value.Sbyte(i8v):  write_i8(ref_ptr, i8v)
                case Value.Short(i16v): write_i16(ref_ptr, i16v)
                case Value.Ushort(u16v): write_u16(ref_ptr, u16v)
                case Value.Int32(i32v): write_i32(ref_ptr, i32v)
                case Value.Uint32(u32v): write_u32(ref_ptr, u32v)
                case Value.Uint64(u64v): write_u64(ref_ptr, u64v)
                case Value.Boolean(bv): write_bool(ref_ptr, bv)
                case Value.Float(fv):   write_f32(ref_ptr, fv)
                case:
                }
            }
            // #211 follow-up: if this binding aliases an enum's payload
            // memory, mirror the write into ei.data + ENUM_PAYLOAD_OFFSET
            // so the change is visible after the case body. Primitives
            // dispatch through typed write_* primitives; Str and user
            // struct payloads memcpy the struct bytes (same shape as
            // write_field). Nested-enum payloads are still TODO.
            payload_alias := scope_get_payload_alias(scope, ad.name)
            if payload_alias.len() > 0 {
                pipe_pos := payload_alias.find("|")
                if pipe_pos >= 0 {
                    pipe_u := pipe_pos.to_u32()
                    enum_var_name := payload_alias.substr(0, pipe_u)
                    type_name := payload_alias.substr(pipe_u + 1, payload_alias.len().sub(pipe_u) - 1)
                    ref enum_cell : Cell = scope_get(scope, enum_var_name)
                    if enum_cell.is_null().not() {
                        switch enum_cell.val {
                        case Value.Enum(ei):
                            if ei.data.is_null().not() {
                                ref dest : Dynamic = ptr_add(ei.data, ENUM_PAYLOAD_OFFSET.cast(U64))
                                switch new_val {
                                case Value.Int(iv):
                                    if type_name == "I64" { write_i64(dest, iv) }
                                case Value.Byte(bv):
                                    if type_name == "U8" { write_u8(dest, bv) }
                                case Value.Sbyte(i8v):
                                    if type_name == "I8" { write_i8(dest, i8v) }
                                case Value.Short(i16v):
                                    if type_name == "I16" { write_i16(dest, i16v) }
                                case Value.Ushort(u16v):
                                    if type_name == "U16" { write_u16(dest, u16v) }
                                case Value.Int32(i32v):
                                    if type_name == "I32" { write_i32(dest, i32v) }
                                case Value.Uint32(u32v):
                                    if type_name == "U32" { write_u32(dest, u32v) }
                                case Value.Uint64(u64v):
                                    if type_name == "U64" { write_u64(dest, u64v) }
                                case Value.Float(fv):
                                    if type_name == "F32" { write_f32(dest, fv) }
                                case Value.Boolean(boov):
                                    if type_name == "Bool" { write_bool(dest, boov) }
                                case Value.Struct(si):
                                    // Compound payload (Str or user struct). Look up the
                                    // payload type's def to get its total struct size and
                                    // memcpy the struct bytes -- same approach write_field
                                    // takes for struct-typed fields. If the new value is a
                                    // borrowed view, clone it first so the enum's payload
                                    // owns its own copy of the bytes.
                                    mut sz : USize = 0
                                    if type_name == "Str" {
                                        sz = Str.size()
                                    } else {
                                        ref tdef : Expr = lookup_interp_type_def(type_name, ctx)
                                        if tdef.is_null().not() {
                                            switch tdef.node_type {
                                            case NodeType.StructDef:
                                                sz = ctx_total_size(type_name, ctx)
                                            case:
                                            }
                                        }
                                    }
                                    if sz > 0 {
                                        // #221 paired: for Str payloads the old payload's
                                        // c_str may own heap (cap < CAP_VIEW);
                                        // free it before overwriting the bytes so the
                                        // writeback doesn't leak. Literal sources have
                                        // cap == CAP_LIT and are skipped.
                                        if type_name == "Str" {
                                            ref old_str : Str = to_ptr(dest)
                                            if str_owns_c_str(old_str) {
                                                if old_str.c_str.is_null().not() { free(own old_str.c_str) }
                                            }
                                        }
                                        if si.borrowed {
                                            mut cloned := new_val.clone()
                                            switch cloned {
                                            case Value.Struct(csi):
                                                memcpy(dest, csi.data, sz.cast(U64))
                                                free(own csi.data)
                                                csi.data = NULL
                                            case:
                                            }
                                        } else {
                                            memcpy(dest, si.data, sz.cast(U64))
                                        }
                                    }
                                case Value.Enum(new_ei):
                                    // Nested-enum payload (Variant: SomeOtherEnum).
                                    // Enum payload constructors store nested enum bytes
                                    // inline at dest, so assignment must preserve that
                                    // representation for later payload extraction.
                                    if new_ei.data.is_null().not() {
                                        mut copy_sz := ctx_total_size(type_name, ctx)
                                        if new_ei.data_size < copy_sz { copy_sz = new_ei.data_size }
                                        if copy_sz > 0 { memcpy(dest, new_ei.data, copy_sz.cast(U64)) }
                                    }
                                case:
                                }
                            }
                        case:
                        }
                    }
                }
            }
            // new_val was memcpy'd into cell.val above (a MOVE): the cell now
            // owns the payload. Null new_val so the garbager's deep
            // Value.delete at its last use is a no-op and does not free the
            // cell's data out from under later reads.
            memcpy(new_val, val_none(), Value.size().cast(U64))
        case NodeType.FieldAssign(fad):
            fname := fad.name
            ref val_expr : Expr = stmt.children[1]
            mut val := val_none()
            ref move_src : Cell = field_assign_dyn_move_src(scope, val_expr)
            if move_src.is_null().not() {
                val = shallow_copy_value(move_src.val)
            } else {
                val = eval_expr(scope, val_expr, ctx)
            }
            if interp_fa_is_ns(scope, stmt) {
                obj := eval_expr(scope, stmt.children[0], ctx)
                mut sname := ""
                switch obj {
                case Value.Struct(si):
                    sname = si.struct_name().clone()
                case:
                    switch stmt.children[0].node_type {
                    case NodeType.Ident(oi):
                        sname = Str.clone(oi.ident_name())
                    case:
                    }
                }
                ns_set(sname, fname, val, ctx)
                if move_src.is_null().not() { memcpy(move_src.val, val_none(), Value.size().cast(U64)) }
            } else {
                ref mut base : Dynamic = resolve_field_assign_base(scope, stmt.children[0])
                ref mut cur_sdef : Expr = resolve_field_assign_sdef(scope, stmt.children[0])
                mut cur_sname : Str = ""
                switch stmt.children[0].node_type {
                case NodeType.Ident(obj_ident):
                    ref obj_cell : Cell = scope_get(scope, obj_ident.ident_name())
                    if obj_cell.is_null().not() {
                        switch obj_cell.val {
                        case Value.Struct(obj_si):
                            cur_sname = obj_si.struct_name().clone()
                        case:
                        }
                    }
                case:
                }
                // Chain walking for nested field access (e.g. a.b.c = val)
                if stmt.children[0].node_type.is(NodeType.FieldAccess) {
                    ref mut cur : Expr = stmt.children[0]
                    mut depth : I32 = 0
                    while cur.node_type.is(NodeType.FieldAccess) {
                        depth++
                        cur = cur.children[0]
                    }
                    switch cur.node_type {
                    case NodeType.Ident(root_ident):
                        ref cell : Cell = scope_get(scope, root_ident.ident_name())
                        if cell.is_null().not() {
                            switch cell.val {
                            case Value.Struct(si):
                                base = to_ptr(si.data)
                                cur_sdef = lookup_interp_type_def(si.struct_name(), si.ctx)
                                cur_sname = si.struct_name().clone()
                                // For simplicity, handle depth=1 (most common: a.field = val)
                                if depth == 1 {
                                    switch stmt.children[0].node_type {
                                    case NodeType.FieldAccess(fa_name):
                                            ref fd : Declaration = find_field_decl(cur_sdef, fa_name.field_access_name())
                                        if fd.is_null().not() {
                                            fa_off := ctx_field_layout(si.struct_name(), fa_name.field_access_name(), ctx).offset
                                            if fd.own_type.is(OwnType.Shallow).not() {
                                                base = deref(ptr_add(base, fa_off.cast(U64)))
                                            } else {
                                                base = ptr_add(base, fa_off.cast(U64))
                                            }
                                            cur_sdef = field_nested_def(fd, ctx)
                                            cur_sname = fd.explicit_type
                                        }
                                    case:
                                    }
                                }
                            case:
                            }
                        }
                    case:
                    }
                }
                if base.is_null() {
                    interp_error(stmt, "field assign on non-struct", ctx)
                    exit(1)
                }
                if cur_sdef.is_null() {
                    interp_error(stmt, "field assign on non-struct", ctx)
                    exit(1)
                }
                ref fdecl : Declaration = find_field_decl(cur_sdef, fname)
                wf_fl := ctx_field_layout(cur_sname, fname, ctx)
                write_field(base, fdecl, wf_fl.offset, wf_fl.size, val, ctx)
                if move_src.is_null().not() {
                    if move_src.val.is(Value.Func).not() {
                        memcpy(move_src.val, val_none(), Value.size().cast(U64))
                    }
                }
            }
        case NodeType.FCall(fcd):
            eval_fcall(scope, stmt, fcd, ctx)
        case NodeType.Body:
            block_scope := scope_new(scope)
            eval_body(block_scope, stmt, ctx)
            reclone_return(c)
            scope_free(own block_scope)
        case NodeType.CaptureBlock:
            // Issue #54: a capture block runs its body inline -- the typer
            // already enforced the capture restriction, so at runtime it
            // behaves exactly like a bare `{ ... }` block.
            cb_scope := scope_new(scope)
            eval_body(cb_scope, stmt.children[0], ctx)
            reclone_return(c)
            scope_free(own cb_scope)
        case NodeType.If:
            eval_if(scope, stmt, ctx)
        case NodeType.While:
            eval_while(scope, stmt, ctx)
        case NodeType.Break:
            c.has_break = true
        case NodeType.Continue:
            c.has_continue = true
        case NodeType.Return:
            if stmt.children.len() > 0 {
                c.return_value = eval_expr(scope, stmt.children[0], ctx)
            } else {
                c.return_value = val_none()
            }
            c.has_return = true
        case NodeType.Switch:
            eval_switch(scope, stmt, ctx)
        case:
            interp_lang_error(stmt, "unexpected statement type", ctx)
            exit(1)
        }
    }
}


priv materialize_str_result := func(mut v: Value) {
    switch v {
    case Value.Struct(si):
        if si.is_str {
            ref s : Str = to_ptr(si.data)
            if s.count.gt(0).and(s.cap.gte(CAP_VIEW)) {
                copy : Dynamic = EvalHeap.heap_alloc(s.count.add(1))
                memcpy(copy, s.c_str, s.count.cast(U64))
                memset(ptr_add(copy, s.count.cast(U64)), 0, 1)
                write_ptr(si.data, copy)
                ref mut dst_cap : U32 = ptr_add(si.data, 12)
                dst_cap = s.count.clone()
            }
        }
    case:
    }
}

priv free_struct_contents_keep_outer := func(si: StructInstance) {
    if si.data.is_null() { return }
    if si.is_str {
        ref s_str : Str = to_ptr(si.data)
        if str_owns_c_str(s_str) {
            if s_str.c_str.is_null().not() { free(own s_str.c_str) }
        }
        memset(si.data, 0, Str.size().cast(U64))
    } else if si.is_str_container {
        free_container_str_data_cached(si.data)
        if si.ctx.is_null().not() {
            memset(si.data, 0, ctx_total_size(si.struct_name(), si.ctx).cast(U64))
        }
    } else if si.ctx.is_null().not() {
        struct_deep_free(si.struct_name(), si.data, si.ctx)
        memset(si.data, 0, ctx_total_size(si.struct_name(), si.ctx).cast(U64))
    }
}

// True iff a struct delete body does anything beyond PURE FIELD CLEANUP, in
// which case the interpreter must run the body rather than substitute the
// cache-driven deep teardown (struct_deep_free reclaims memory but cannot
// reproduce side effects). Pure field cleanup -- what an auto-generated delete,
// and a hand-written one like DynHashMap's, does -- is zero or more
// `<field>.delete(...)` / `til_closure_delete(...)` calls plus a final
// `free(own self)`. Anything else is custom:
//   - an Assign / FieldAssign (a side effect, e.g. DeleteCustom's counter);
//   - a `free(own self.field)` (a manual own-raw-field free struct_deep_free
//     does NOT perform);
//   - any other call: a method that is not `.delete(...)` (e.g. File.delete's
//     `File.close(self)`, which flushes/closes a fd), or a free function other
//     than `free` / `til_closure_delete`.
// Survives the typer's desugaring (Decl temporaries + method-call FCalls) and
// recurses into call arguments and the `if call_free` arm.
priv delete_body_has_custom_logic := func(e: Expr) returns Bool {
    switch e.node_type {
    case NodeType.Assign:
        return true
    case NodeType.FieldAssign:
        return true
    case NodeType.FCall:
        if e.children.len() >= 1 {
            switch e.children[0].node_type {
            case NodeType.Ident(fid):
                ref cname : Str = fid.ident_name()
                if cname == "free" {
                    // free(own self) is cleanup; free(own self.field) is a manual
                    // own-raw-field free struct_deep_free would skip.
                    if e.children.len() >= 2 {
                        if e.children[1].node_type.is(NodeType.FieldAccess) { return true }
                    }
                } else if cname == "til_closure_delete" {
                } else if cname.ends_with("_delete") {
                } else {
                    return true
                }
            case NodeType.FieldAccess(fa):
                // Only `<receiver>.delete(...)` is field cleanup.
                if fa.field_access_name() != "delete" { return true }
            case:
                return true
            }
        }
    case:
    }
    for c : Expr in e.children {
        if delete_body_has_custom_logic(c) { return true }
    }
    return false
}

priv interp_concrete_expr_type_name := func(e: Expr) returns Str {
    expr_type := til_type_name(e.expr_til_type())
    if expr_type.len().gt(0).and(expr_type.eq("unknown").not()).and(expr_type.eq("?").not()).and(expr_type.eq("Dynamic").not()).and(expr_type.eq("None").not()) { return expr_type }
    expr_type_c := til_type_name_c(e.expr_til_type())
    if expr_type_c.eq("unknown").not().and(expr_type_c.eq("?").not()).and(expr_type_c.eq("Dynamic").not()).and(expr_type_c.eq("None").not()) {
        return expr_type_c
    }
    return ""
}

priv delete_ptr_receiver_type := func(e: Expr) returns Str {
    direct_type := interp_concrete_expr_type_name(e)
    if direct_type.len().gt(0) { return direct_type }
    switch e.node_type {
    case NodeType.FCall:
        if e.children.len().gt(1) {
            mut callee_name := ""
            switch e.children[0].node_type {
            case NodeType.Ident(fn_id): callee_name = fn_id.ident_name()
            case:
            }
            if callee_name == "ptr_add" { return delete_ptr_receiver_type(e.children[1]) }
        }
    case NodeType.FieldAccess(fa):
        if fa.field_access_name() == "data" {
            if e.children.len().gt(0) {
                container_type := interp_concrete_expr_type_name(e.children[0])
                elem_type := container_elem_type(container_type)
                if elem_type.len().gt(0) { return elem_type }
            }
        }
    case:
    }
    return ""
}

priv delete_ptr_receiver_type_known := func(type_name: Str, ctx: Context) returns Bool {
    if type_name.len().eq(0) { return false }
    if type_from_name_init(type_name, ctx.scope).is(Type.Unknown).not() { return true }
    return lookup_interp_type_def(type_name, ctx).is_null().not()
}

priv eval_user_func_call := proc(caller_scope: Scope, e: Expr, func_def: Expr, parent_scope: Scope, mut ctx: Context) returns shallow Value {
    ref mut c : Context = ctx
    ref callee_expr : Expr = e.children[0]
    if func_def.children.len() == 0 {
        interp_error(e, "cannot call an interface method through the interface: it has no implementation", ctx)
        exit(1)
    }
    ref body : Expr = func_def.children[0]

    // Issue #275: bypass an auto-generated struct delete's body and run the
    // deep Value teardown directly. The generated body is
    // `self.field.delete(false)` per field + `free(own self)`; in the
    // interpreter the field-deletes dispatch onto a BORROWED view (Str.delete
    // reads self.c_str as a Ref -> no-op) and `free(own self)` is a shallow
    // box-only release, so a plain struct's nested Str-field c_strs leaked at
    // its delete -- the dominant constfolder Str_clone leak (folding clones
    // such values then deletes them). free_temp_arg_value reclaims them
    // (is_str c_str / struct_deep_free + the buffer). Scoped to top-level
    // deletes (method form or flattened *_delete) whose receiver is an Ident;
    // call_free=false also handles pointer receivers such as
    // `T.delete(own ptr_add(vec.data, off), false)` by freeing the inline slot
    // contents in place. call_free=false frees nested contents but keeps the
    // outer slot valid for callers that immediately memset/free it. Containers
    // are also intercepted: their Vec/Array/Set delete bodies call T.delete on
    // borrowed element views, which cannot free nested element ownership.
    mut del_method := false
    switch callee_expr.node_type {
    case NodeType.FieldAccess(del_fn):
        if del_fn.field_access_name() == "delete" { del_method = true }
    case NodeType.Ident(del_ident):
        if del_ident.ident_name().ends_with("_delete") { del_method = true }
    case:
    }
    if del_method.and(e.children.len().gt(1)) {
        switch e.children[1].node_type {
        case NodeType.Ident(recv_id):
            mut call_free := true
            if e.children.len().gt(2) {
                cf_v := eval_expr(caller_scope, e.children[2], ctx)
                switch cf_v {
                case Value.Boolean(cfb): call_free = cfb
                case:
                }
            }
            ref recv_cell : Cell = scope_get(caller_scope, recv_id.ident_name())
            if recv_cell.is_null().not() {
                if call_free.not().and(get_own_arg(e, 1)).and(is_value_ptr(recv_cell.val)) {
                    mut recv_type0 := delete_ptr_receiver_type(e.children[1])
                    switch func_def.node_type {
                    case NodeType.FuncDef(fd_del0):
                        if recv_type0.len().eq(0).and(fd_del0.params.len().gt(0)) { recv_type0 = fd_del0.params[0].explicit_type }
                    case:
                    }
                    if delete_ptr_receiver_type_known(recv_type0, ctx) {
                        ref recv_ptr_slot0 : Dynamic = val_to_ptr(recv_cell.val)
                        ref recv_ptr0 : Dynamic = deref(recv_ptr_slot0)
                        if recv_ptr0.is_null() { panic("delete pointer receiver is null") }
                        container_elem_deep_free(recv_type0, recv_ptr0, ctx)
                        memset(recv_ptr0, 0, container_elem_size(recv_type0, ctx).cast(U64))
                        memcpy(recv_cell.val, val_none(), Value.size().cast(U64))
                        return val_none()
                    }
                }
                mut do_intercept := false
                switch func_def.node_type {
                case NodeType.FuncDef(fd_ag):
                    if fd_ag.auto_generated { do_intercept = true }
                case:
                }
                switch recv_cell.val {
                case Value.Struct(rsi):
                    if rsi.struct_name() == "Str" { do_intercept = true }
                    if rsi.struct_name() == "DynVec" { do_intercept = true }
                    if rsi.is_str_container { do_intercept = true }
                    if container_elem_type(rsi.struct_name()).len() > 0 { do_intercept = true }
                    // A delete whose body is pure field cleanup -- no Assign/
                    // FieldAssign side effect and no manual `free(own self.x)` --
                    // is safe to replace with the cache-driven deep teardown:
                    // struct_deep_free reclaims exactly what the field deletes
                    // would, and never less. The interpreter cannot run those
                    // bodies correctly anyway -- a `self.f.delete(...)` or a
                    // `Type.delete(own self.f)` dispatches on the borrowed
                    // self/field view and no-ops (read_field hands an own field
                    // back as a borrowed Ref), so a HashMap's Vec or a
                    // DynHashMap's DynVec buffers leak and `free(own self)` frees
                    // only the top block. fd_ag.auto_generated catches the common
                    // case but is lost on monomorphized generics; the body shape
                    // is the robust signal (no fragile name sniffing). A
                    // hand-written delete with side effects (DeleteCustom's
                    // counter) or an own-raw-field free keeps running its body.
                    if delete_body_has_custom_logic(func_def).not() { do_intercept = true }
                case:
                }
                if do_intercept {
                    if call_free {
                        // #286 Stage 3: a peeled plain struct's payload is owned
                        // by its heap_bindings marker, not the borrowed Cell.val
                        // view -- free_temp_arg_value below no-ops on the view, so
                        // reclaim the marker's payload here (heap_drop + heap_free)
                        // before nulling the cell. Mirrors scope_free's reclaim;
                        // the marker is flagged moved_out so scope_free won't
                        // double-reclaim.
                        scope_reclaim_peeled_at_binding(caller_scope, recv_id.ident_name())
                        free_temp_arg_value(recv_cell.val)
                        memcpy(recv_cell.val, val_none(), Value.size().cast(U64))
                    } else {
                        switch recv_cell.val {
                        case Value.Struct(rsi2): free_struct_contents_keep_outer(rsi2)
                        case:
                        }
                    }
                    return val_none()
                }
            }
        case:
            mut call_free3 := true
            if e.children.len().gt(2) {
                cf_v3 := eval_expr(caller_scope, e.children[2], ctx)
                switch cf_v3 {
                case Value.Boolean(cfb3): call_free3 = cfb3
                case:
                }
            }
            if call_free3.not().and(get_own_arg(e, 1)) {
                mut recv_type := delete_ptr_receiver_type(e.children[1])
                switch func_def.node_type {
                case NodeType.FuncDef(fd_del):
                    if recv_type.len().eq(0).and(fd_del.params.len().gt(0)) { recv_type = fd_del.params[0].explicit_type }
                case:
                }
                if delete_ptr_receiver_type_known(recv_type, ctx) {
                    recv_ptr_val := eval_expr(caller_scope, e.children[1], ctx)
                    if is_value_ptr(recv_ptr_val) {
                        ref recv_ptr_slot : Dynamic = val_to_ptr(recv_ptr_val)
                        ref recv_ptr : Dynamic = deref(recv_ptr_slot)
                        if recv_ptr.is_null() { panic("delete pointer receiver is null") }
                        container_elem_deep_free(recv_type, recv_ptr, ctx)
                        memset(recv_ptr, 0, container_elem_size(recv_type, ctx).cast(U64))
                        return val_none()
                    }
                }
            }
        }
    }

    if callee_expr.expr_til_type().is_funcptr().not() {
        if guard_own_param_skip(caller_scope, e, func_def) { return val_none() }
    }
    call_scope := scope_new(parent_scope)
    switch func_def.node_type {
    case NodeType.FuncDef(fdef_params):
        for pi in 0..fdef_params.params.len() {
            ref param : Declaration = fdef_params.params[pi]
            ref arg_expr : Expr = e.children[pi + 1]
            switch arg_expr.node_type {
            case NodeType.Ident(arg_ident):
                ref arg_cell : Cell = scope_get(caller_scope, arg_ident.ident_name())
                if arg_cell.is_null() {
                    interp_error(arg_expr, format("undefined variable '", Str.clone(arg_ident.ident_name()), "'"), ctx)
                    exit(1)
                }
                if is_value_ptr(arg_cell.val).and(param.explicit_type.len().gt(0)) {
                    mut arg := reinterpret_ptr_value(arg_cell.val, param.explicit_type, caller_scope, ctx, false)
                    arg = widen_numeric(arg, param.explicit_type, ctx)
                    scope_set_owned(call_scope, param.name, arg)
                } else if needs_widen(arg_cell.val, param.explicit_type) {
                    mut arg := arg_cell.val.clone()
                    arg = widen_numeric(arg, param.explicit_type, ctx)
                    scope_set_owned(call_scope, param.name, arg)
                } else if param.explicit_type.eq("Dynamic").and(is_value_ptr(arg_cell.val).not()).and(arg_cell.val.is(Value.None).not()) {
                    arg := box_scalar_to_dynamic(call_scope, arg_cell.val, param.own_type.is(OwnType.Own).not())
                    scope_set_owned(call_scope, param.name, arg)
                } else {
                    scope_set_borrowed(call_scope, param.name, arg_cell)
                }
            case:
                mut arg := eval_expr(caller_scope, arg_expr, ctx)
                if is_value_ptr(arg).and(param.explicit_type.len().gt(0)) {
                    arg = reinterpret_ptr_value(arg, param.explicit_type, caller_scope, ctx, false)
                }
                arg = widen_numeric(arg, param.explicit_type, ctx)
                if param.explicit_type.eq("Dynamic").and(is_value_ptr(arg).not()) {
                    arg = box_scalar_to_dynamic(call_scope, arg, param.own_type.is(OwnType.Own).not())
                }
                scope_set_owned(call_scope, param.name, arg)
            }
        }
    case:
        UNREACHABLE()
    }
    c.has_return = false
    eval_body(call_scope, body, ctx)
    mut result := val_none()
    if c.has_return {
        // #286: the box model's implicit clone-on-return is what materialises a
        // returned value into caller-owned storage before scope_free reclaims
        // call_scope. A BORROWED return (`return x` / `return self.field`, a
        // view into call_scope produced by borrow_value / read_field) must
        // still be deep-cloned so the caller gets an independent copy. But an
        // OWNED (non-borrowed) return owns its payload and aliases no live
        // binding -- borrow_value flags every Ident/field return borrowed, so a
        // non-borrowed return can only be a fresh owned temp -- so MOVE it to
        // the caller instead of cloning then freeing the original. This is the
        // raw-heap "returns move, they do not copy" step toward dropping the
        // interpreter's implicit clones. materialize_str_result still runs to
        // copy a cap-encoded Str view (get_char et al.) into owned bytes.
        if value_is_borrowed(c.return_value) {
            result = c.return_value.clone()
            materialize_str_result(result)
            free_temp_arg_value(c.return_value)
        } else {
            memcpy(result, c.return_value, Value.size().cast(U64))
            materialize_str_result(result)
        }
        memcpy(c.return_value, val_none(), Value.size().cast(U64))
        c.has_return = false
    }
    free_non_own_temp_args(call_scope, e, func_def)
    scope_free(own call_scope)
    return result
}

priv eval_callable_call := proc(caller_scope: Scope, e: Expr, callable: Value, mut ctx: Context) returns shallow Value {
    switch callable {
    case Value.Func(fp):
        ref func_def : Expr = deref(fp)
        return eval_user_func_call(caller_scope, e, func_def, caller_scope, ctx)
    case Value.Closure(cl):
        switch cl.func_def.node_type {
        case NodeType.BodyValue:
            body_scope := scope_new(cl.env)
            eval_body(body_scope, cl.func_def.children[0], ctx)
            scope_free(own body_scope)
            return val_none()
        case:
        }
        return eval_user_func_call(caller_scope, e, cl.func_def, cl.env, ctx)
    case:
        interp_error(e, "callee did not evaluate to a function", ctx)
        exit(1)
        return val_none()
    }
}


priv eval_call := proc(scope: Scope, e: Expr, mut ctx: Context) returns shallow Value {
    ref c : Context = ctx
    ref callee_expr : Expr = e.children[0]

    // Namespace method call: Struct.method(args)
    if callee_expr.node_type.is(NodeType.FieldAccess) {
        fn_val := eval_expr(scope, callee_expr, ctx)
        switch fn_val {
        case Value.Closure:
            return eval_callable_call(scope, e, fn_val, ctx)
        case Value.Func(fn_ptr):
        ref func_def : Expr = deref(fn_ptr)

        // FuncPtr field: stored function may be ext_func from another type
        if callee_expr.expr_til_type().is_funcptr() {
            mut fp_func_type := FuncType.Func
            switch func_def.node_type {
            case NodeType.FuncDef(fp_fdef):
                fp_func_type = fp_fdef.func_type
            case:
                UNREACHABLE()
            }
            if fp_func_type.is(FuncType.ExtFunc).or(fp_func_type.is(FuncType.ExtProc)) {
                for qn, nsv in c.ns_fields {
                    switch nsv {
                    case Value.Func(nsv_fptr):
                        ref nsv_fdef : Expr = deref(nsv_fptr)
                        if nsv_fdef.ptr_eq(func_def) {
                            fp_flat := qn.replace(".", "_")
                            orig_callee := callee_expr.clone()
                            mut flat_ident := callee_expr.clone()
                            flat_ident.node_type = ident_node(fp_flat)
                            e.children[0] = flat_ident
                            result := eval_call(scope, e, ctx)
                            e.children[0] = orig_callee
                            return result
                        }
                    case:
                    }
                }
            }
        }
        // Direct ext_func namespace method -- dispatch by flat name
        mut fdef_func_type := FuncType.Func
        switch func_def.node_type {
        case NodeType.FuncDef(fdef_ns):
            fdef_func_type = fdef_ns.func_type
        case:
            UNREACHABLE()
        }
        if fdef_func_type.is(FuncType.ExtFunc).or(fdef_func_type.is(FuncType.ExtProc)).or(fdef_func_type.is(FuncType.CoreFunc)).or(fdef_func_type.is(FuncType.CoreProc)) {
            parent_sname := til_type_name(callee_expr.children[0].expr_til_type())
            ref tc : Cell = scope_get(scope, parent_sname)
            if tc.is_null().not() {
                switch tc.val {
                case Value.Func(tc_fptr):
                    ref tc_edef : Expr = deref(tc_fptr)
                    if tc_edef.node_type.is(NodeType.EnumDef) {
                        switch callee_expr.node_type {
                        case NodeType.FieldAccess(callee_ident):
                            mut eresult := val_none()
                            if enum_method_dispatch(callee_ident.field_access_name(), scope, tc_edef, parent_sname, e, eresult, ctx) {
                                for oi in 1..e.children.len() {
                                    ref oa : Expr = e.children[oi]
                                    if oa.node_type.is(NodeType.Ident).and(get_own_arg(e, oi)) {
                                        switch oa.node_type {
                                        case NodeType.Ident(oa_ident):
                                            ref oc : Cell = scope_get(scope, oa_ident.ident_name())
                                            if oc.is_null().not() {
                                                // enum_method_dispatch byte-copied this own arg's
                                                // WHOLE payload (psz = ctx_total_size) into
                                                // eresult's own buffer, sharing every inlined
                                                // nested heap pointer -- a nested Str's c_str, not
                                                // just a top-level one (Issue #109/#299). A deep
                                                // delete of oc.val recurses through struct_deep_free
                                                // and frees those shared pointers, dangling eresult
                                                // (a heap-use-after-free read in the constfolder's
                                                // value_to_expr / needs_source_escape). Clearing the
                                                // top is_str only covered a DIRECT Str arg, whose
                                                // c_str val_enum_flat already moved out. Free only
                                                // this now-redundant wrapper buffer (the bytes live
                                                // in eresult's copy) and leave the shared inlined
                                                // pointers for eresult to own.
                                                switch oc.val {
                                                case Value.Struct(osi):
                                                    if osi.borrowed.not().and(osi.data.is_null().not()) {
                                                        EvalHeap.heap_free(own osi.data)
                                                    }
                                                    memcpy(oc.val, val_none(), Value.size().cast(U64))
                                                case:
                                                    oc.val = val_none()
                                                }
                                            }
                                        case:
                                            UNREACHABLE()
                                        }
                                    }
                                }
                                return eresult
                            }
                        case:
                            UNREACHABLE()
                        }
                    }
                case:
                }
            }
            mut sn := til_type_name(callee_expr.children[0].expr_til_type())
            // til_type_name returns "" for primitives. For ext_func
            // dispatch on a primitive receiver (e.g. `0.sub(1)` ->
            // `I64_sub(0, 1)`), fall back to til_type_name_c.
            if sn.is_empty() {
                tn := til_type_name_c(callee_expr.children[0].expr_til_type())
                if tn.eq("unknown").not().and(tn.eq("?").not()).and(tn.eq("Dynamic").not()) {
                    sn = tn
                }
            }
            switch callee_expr.node_type {
            case NodeType.FieldAccess(fn_name):
                // If the receiver type is unknown (eg Dynamic), fall back to
                // the unqualified top-level name. Required for and/or/not.
                mut flat_str := Str.clone(fn_name.field_access_name())
                if sn.len() > 0 {
                    flat_str = sn.concat3("_", fn_name.field_access_name())
                }
                orig_callee_val := callee_expr.clone()
                mut flat_ident2 := callee_expr.clone()
                flat_ident2.node_type = ident_node(flat_str)
                e.children[0] = flat_ident2
                result := eval_call(scope, e, ctx)
                e.children[0] = orig_callee_val
                return result
            case:
                UNREACHABLE()
            }
        }

        return eval_user_func_call(scope, e, func_def, scope, ctx)
        case:
            interp_error(e, "namespace field is not a function", ctx)
            exit(1)
            return val_none()
        }
    }

    // Direct ident call
    switch callee_expr.node_type {
    case NodeType.Ident(name):

    // Ext function dispatch
    mut ext_result := val_none()
    if ext_function_dispatch(name.ident_name(), scope, e, ext_result, ctx) {
        for oi in 1..e.children.len() {
            if get_own_arg(e, oi) {
                switch e.children[oi].node_type {
                case NodeType.Ident(oa_ident):
                    ref oc : Cell = scope_get(scope, oa_ident.ident_name())
                    if oc.is_null().not() {
                        // The ext_func took ownership of this own arg: its
                        // data buffer was passed raw to C, which owns (and may
                        // free) it. MOVE the cell to None WITHOUT deep-deleting
                        // -- `oc.val = val_none()` would free the buffer C
                        // already owns (double-free, e.g. `Pair.delete(own self)`).
                        memcpy(oc.val, val_none(), Value.size().cast(U64))
                    }
                case:
                }
            }
        }
        return ext_result
    }

    // User-defined function or struct instantiation
    ref fn_cell : Cell = scope_get(scope, name.ident_name())
    if fn_cell.is_null() {
        interp_error(e, format(Str.clone(name.ident_name()), " is undefined"), ctx)
        exit(1)
    }

    // An ext_func reaching here did not dispatch above (not a builtin and
    // not FFI-registered -- e.g. a user .so not dlopen'd at constfolder time).
    // It has no body to execute, so refuse rather than falling through to
    // the bodyless-func path. Lets constfolder's try_eval_call bail cleanly via
    // can_convert.not() instead of crashing.
    switch fn_cell.val {
    case Value.Func(ext_fp):
        ref ext_def : Expr = deref(ext_fp)
        switch ext_def.node_type {
        case NodeType.FuncDef(ext_fd):
            if ext_fd.func_type.is(FuncType.ExtFunc) { return val_none() }
        case:
        }
    case:
    }

    // Struct instantiation
    switch fn_cell.val {
    case Value.Func(si_fptr):
        ref si_edef : Expr = deref(si_fptr)
        if si_edef.node_type.is(NodeType.StructDef) {
            switch si_edef.node_type {
            case NodeType.StructDef(sdd):
                inst_data : Dynamic = EvalHeap.heap_alloc(ctx_total_size(name.ident_name(), ctx))
                mut inst := val_none()
                switch e.node_type {
                case NodeType.FCall(fcd_ctor):
                    switch fcd_ctor.til_type {
                    case Type.Struct(es):
                        if es.len() > 0 { inst = make_struct_value(es, inst_data, false, ctx) }
                        else              { inst = make_struct_value(name.name, inst_data, false, ctx) }
                    case Type.Enum(es):
                        if es.len() > 0 { inst = make_struct_value(es, inst_data, false, ctx) }
                        else              { inst = make_struct_value(name.name, inst_data, false, ctx) }
                    case Type.Custom(es):
                        if es.len() > 0 { inst = make_struct_value(es, inst_data, false, ctx) }
                        else              { inst = make_struct_value(name.name, inst_data, false, ctx) }
                    case:
                        inst = make_struct_value(name.name, inst_data, false, ctx)
                    }
                case:
                    inst = make_struct_value(name.name, inst_data, false, ctx)
                }
                switch inst {
                case Value.Struct(si_inst):
                    mut arg_idx : U32 = 1
                    for fdd : Declaration in sdd.fields {
                        cur_idx := arg_idx
                        ref arg : Expr = e.children[cur_idx]
                        arg_idx++
                        mut val := val_none()
                        switch arg.node_type {
                        case NodeType.Ident(arg_ident):
                            ref src : Cell = scope_get(scope, arg_ident.ident_name())
                            if src.is_null() {
                                interp_error(arg, format("undefined variable '", Str.clone(arg_ident.ident_name()), "'"), ctx)
                                exit(1)
                            }
                            // Null the source only when THIS arg (cur_idx) is
                            // marked own. Using the post-increment arg_idx here
                            // tested the next arg's own-bit, which nulled the
                            // wrong source cell -- e.g. a global constant like
                            // ELEM_BOXED passed for `elem_kind` got cleared
                            // because the following `elem_clone` arg was own,
                            // leaving every later Vec.new with elem_kind == 0
                            // (issue #213).
                            if get_own_arg(e, cur_idx).and(src.val.is(Value.Func).not()) {
                                // MOVE: take ownership of the source payload and
                                // null the cell WITHOUT freeing (memcpy, not
                                // `= val_none()` which save-old-deletes the
                                // payload val now owns -> double-free).
                                val = shallow_copy_value(src.val)
                                memcpy(src.val, val_none(), Value.size().cast(U64))
                            } else {
                                // BORROW: val aliases src.val for the field
                                // write (write_field clones); its deep delete
                                // must skip the payload the source still owns.
                                val = borrow_value(src.val)
                            }
                        case:
                            val = eval_expr(scope, arg, ctx)
                        }
                        ctor_fl := ctx_field_layout(si_inst.struct_name(), fdd.name, ctx)
                        write_field(si_inst.data, fdd, ctor_fl.offset, ctor_fl.size, val, ctx)
                    }
                case:
                    UNREACHABLE()
                }
                return inst
            case:
                UNREACHABLE()
            }
        }
    case:
    }

    if fn_cell.val.is(Value.Func).not().and(fn_cell.val.is(Value.Closure).not()) {
        interp_error(e, format(Str.clone(name.ident_name()), " is not a function"), ctx)
        exit(1)
    }

    return eval_callable_call(scope, e, fn_cell.val, ctx)
    case NodeType.FCall:
        // Issue #58: postfix call on a sub-expression callee, e.g.
        // `cast(raw, BinaryOp)(3, 4)`. Eval the callee (the cast) to
        // get the function pointer, then dispatch with the call's args.
        cast_val := eval_expr(scope, callee_expr, ctx)
        if cast_val.is(Value.Func).not().and(cast_val.is(Value.Closure).not()) {
            interp_error(e, "function-pointer call: callee did not evaluate to a function", ctx)
            exit(1)
        }
        return eval_callable_call(scope, e, cast_val, ctx)
    case:
        UNREACHABLE()
        return val_none()
    }
}

priv free_value := func(shallow v: Value) {
    switch v {
    case Value.Struct(si):
        if si.borrowed.not() {
            if si.data.is_null().not() {
                if si.is_str_container { free_container_str_data_cached(si.data) }
                EvalHeap.heap_free(own si.data)
            }
        }
    case Value.Enum(ei):
        if ei.data.is_null().not().and(ei.borrowed.not()) {
            if ei.is_str { enum_free_str_payload(ei.data) }
            EvalHeap.heap_free(own ei.data)
        }
    case Value.Closure(cl):
        interp_closure_free(cl)
    case:
    }
}

// End-of-lifetime cleanup for a Value's heap payload. Goes deeper than
// free_value: also frees the c_str of a Value.Struct whose name is "Str".
// Used by scope_free and constfolder's known-map teardown, where the Value
// genuinely owns the payload.

// Single owning-pointer box for side tables that need to own raw Dynamic
// pointers. free_value_full frees a Value.Dynamic payload directly; it must not
// reinterpret the pointee as this box because Dynamic can point at a 1/2/4-byte
// scalar allocation.
priv DynPtrBox := struct {
    own p : U8 = 0
}

priv dynamic_value_payload_copy := func(v: Value) returns Dynamic {
    switch v {
    case Value.Dynamic(p):
        ref raw : U64 = p
        return ptr_add(NULL, raw)
    case:
        UNREACHABLE()
        return NULL
    }
}

// Destroy a binding that is the real owner being explicitly deleted: frees
// managed payloads (via free_value) AND the raw heap pointer behind an
// owning Value.Dynamic. Used only by the `free(own x)` builtin -- NOT on
// scope overwrite, because a reassignment may consume the old pointer
// (e.g. realloc(own p, n)), so overwriting must not free it.
priv free_value_full := func(shallow v: Value) {
    free_value(v)
    switch v {
    case Value.Dynamic(slot):
        ref box : DynPtrBox = slot
        if box.p.is_null().not() {
            free(own box.p)
        }
    case:
    }
}

// Issue #275, generalized after #58: Array/Vec/Set keep elements in an
// `own data` heap buffer. struct_deep_free skips the `own data : U8` field
// itself, and StructInstance.clone's outer memcpy only shallow-copies the data
// pointer. Clone/free the backing buffer here so interpreted containers have
// the same ownership as their generated delete/clone methods.

// Element type of a monomorphized container ("Array__Str" -> "Str",
// "Vec__I64" -> "I64"); "" for a non-container struct name.
priv container_elem_type := func(struct_name: Str) returns Str {
    array_prefix := "Array__"
    if struct_name.starts_with(array_prefix) {
        return struct_name.substr(array_prefix.count, struct_name.count - array_prefix.count)
    }
    vec_prefix := "Vec__"
    if struct_name.starts_with(vec_prefix) {
        return struct_name.substr(vec_prefix.count, struct_name.count - vec_prefix.count)
    }
    set_prefix := "Set__"
    if struct_name.starts_with(set_prefix) {
        return struct_name.substr(set_prefix.count, struct_name.count - set_prefix.count)
    }
    return ""
}

priv container_elem_size := func(elem_type: Str, ctx: Context) returns USize {
    resolved := type_from_name_init(elem_type, ctx.scope)
    switch resolved {
    case Type.Primitive(p):
        mut sz : USize = 0
        mut al : USize = 0
        builtin_primitive_size_align(p, sz, al)
        return sz
    case Type.Dynamic:
        return 8
    case Type.FuncPtr:
        return 8
    case Type.FuncPtrSig:
        return 8
    case:
    }
    sz2 := ctx_total_size(elem_type, ctx)
    if sz2 == 0 { panic("container element has no registered size: ", elem_type) }
    return sz2
}

priv type_name_is_funcsig := func(type_name: Str, ctx: Context) returns Bool {
    if type_from_name_init(type_name, ctx.scope).is_funcptr() { return true }
    ref tdef : Expr = lookup_interp_type_def(type_name, ctx)
    if tdef.is_null() { return false }
    if tdef.node_type.is(NodeType.FuncDef) {
        return tdef.children.len() == 0
    }
    return false
}

priv container_live_count := func(struct_name: Str, data: Dynamic, ctx: Context) returns USize {
    mut count_field := "count"
    if struct_name.starts_with("Array__") { count_field = "cap" }
    fl := ctx_field_layout(struct_name, count_field, ctx)
    ref n : USize = ptr_add(data, fl.offset.cast(U64))
    return n.clone()
}

priv container_capacity := func(struct_name: Str, data: Dynamic, ctx: Context) returns USize {
    fl := ctx_field_layout(struct_name, "cap", ctx)
    ref n : USize = ptr_add(data, fl.offset.cast(U64))
    return n.clone()
}

priv container_elem_deep_free := func(elem_type: Str, slot: Dynamic, ctx: Context) {
    if type_name_is_funcsig(elem_type, ctx) {
        ref stored_callable : Dynamic = deref(slot)
        if stored_callable.is_null().not() { callable_storage_free(stored_callable) }
        return
    }
    resolved := type_from_name_init(elem_type, ctx.scope)
    if resolved.is(Type.Primitive).or(resolved.is(Type.Dynamic)) { return }
    ref elem_def : Expr = lookup_interp_type_def(elem_type, ctx)
    if elem_def.is_null() { panic("container element has no registered type def: ", elem_type) }
    switch elem_def.node_type {
    case NodeType.StructDef:
        if elem_type == "Str" {
            ref s : Str = slot
            if str_owns_c_str(s) {
                if s.c_str.is_null().not() { free(own s.c_str) }
            }
        } else {
            struct_deep_free(elem_type, slot, ctx)
        }
    case NodeType.EnumDef:
        if enum_has_payloads(elem_def) {
            ref tag : I32 = slot
            if enum_variant_is_str(elem_type, tag, ctx) { enum_free_str_payload(slot) }
        }
    case:
        panic("container element is not a struct or enum: ", elem_type)
    }
}

priv container_elem_clone_into := func(elem_type: Str, dst: Dynamic, src: Dynamic, elem_size: USize, ctx: Context) {
    if type_name_is_funcsig(elem_type, ctx) {
        ref stored_callable : Dynamic = deref(src)
        if stored_callable.is_null().not() { write_ptr(dst, callable_storage_clone(stored_callable)) }
        return
    }
    resolved := type_from_name_init(elem_type, ctx.scope)
    if resolved.is(Type.Primitive).or(resolved.is(Type.Dynamic)) {
        memcpy(dst, src, elem_size.cast(U64))
        return
    }
    ref elem_def : Expr = lookup_interp_type_def(elem_type, ctx)
    if elem_def.is_null() { panic("container element has no registered type def: ", elem_type) }
    switch elem_def.node_type {
    case NodeType.StructDef:
        cloned_ptr : Dynamic = heap_clone(elem_type, src, ctx)
        memcpy(dst, cloned_ptr, elem_size.cast(U64))
        EvalHeap.heap_free(own cloned_ptr)
    case NodeType.EnumDef:
        memcpy(dst, src, elem_size.cast(U64))
        if enum_has_payloads(elem_def) {
            ref tag : I32 = dst
            if enum_variant_is_str(elem_type, tag, ctx) { enum_clone_str_payload(dst) }
        }
    case:
        panic("container element is not a struct or enum: ", elem_type)
    }
}

// #286: cache-driven deep free of a struct value's nested heap. Reads
// ctx.struct_layouts (a name-keyed cache that outlives the AST) instead of the
// dangling struct_def, so it is safe at scope teardown. Frees own struct
// fields' blocks (recursing first), Str fields' c_strs, recurses into inline
// nested structs, and reclaims container data buffers. Enum
// fields and own non-struct pointers stay shallow (their construction can
// share a pointer, so freeing here would risk a double-free).
priv struct_deep_free := func(struct_name: Str, data: Dynamic, ctx: Context) {
    if data.is_null() { return }
    if ctx.struct_layouts.has(struct_name).not() { return }
    ref sl : StructLayout = ctx.struct_layouts[struct_name]
    for i in 0..sl.fields.len() {
        ref fl : FieldLayout = sl.fields[i]
        if fl.own_type.is(OwnType.Ref) { continue }
        foff := fl.offset
        if fl.is_funcptr {
            ref stored_callable : Dynamic = deref(ptr_add(data, foff.cast(U64)))
            if stored_callable.is_null().not() { callable_storage_free(stored_callable) }
            continue
        }
        if fl.own_type.is(OwnType.Own) {
            if fl.struct_name.len().gt(0).and(fl.is_enum.not()) {
                ref own_hdr : DynPtrBox = ptr_add(data, foff.cast(U64))
                if own_hdr.p.is_null().not() {
                    if fl.struct_name == "Str" {
                        // own Str: recursing into "Str" would NOT free the
                        // c_str (that is the is_str special case, not a struct
                        // field). Free it here before the buffer.
                        ref os : Str = to_ptr(own_hdr.p)
                        if str_owns_c_str(os) {
                            if os.c_str.is_null().not() { free(own os.c_str) }
                        }
                    } else {
                        struct_deep_free(fl.struct_name, own_hdr.p, ctx)
                    }
                    EvalHeap.heap_free(own own_hdr.p)
                }
            }
            continue
        }
        if fl.is_str {
            ref s : Str = ptr_add(data, foff.cast(U64))
            if str_owns_c_str(s) {
                if s.c_str.is_null().not() { free(own s.c_str) }
            }
            continue
        }
        if fl.struct_name.len().gt(0).and(fl.is_enum.not()) {
            struct_deep_free(fl.struct_name, ptr_add(data, foff.cast(U64)), ctx)
        }
    }
    if struct_name == "DynVec" {
        free_dyn_vec_buffer(data, ctx)
    } else if container_elem_type(struct_name).len() > 0 {
        free_container_data(struct_name, data, ctx)
    }
}

// #286 Stage 2: canonical typed deep-free of a value's CONTENTS -- the dual of
// heap_clone. Frees the deep heap owned by a value of type `struct_name` at
// `data` (its Str c_str, nested own/inline struct fields, container element
// buffers, and callable boxes via struct_deep_free). The owning block itself is
// freed separately by the caller (one heap_free(ptr) per owning block), since
// `data` here is a borrow. The single typed-free entry the boxed delete paths
// route through, replacing the scattered hand-frees over time (plan Stage 2).
priv heap_drop := func(struct_name: Str, data: Dynamic, ctx: Context) {
    if data.is_null() { return }
    if struct_name == "Str" {
        ref s : Str = to_ptr(data)
        if str_owns_c_str(s) {
            if s.c_str.is_null().not() { free(own s.c_str) }
        }
    } else {
        struct_deep_free(struct_name, data, ctx)
    }
}

// Free a container's `own data` buffer and its elements (the field loop skips
// `own` fields, so the buffer + elements would otherwise leak).
priv free_container_data := func(struct_name: Str, data: Dynamic, ctx: Context) {
    elem_type := container_elem_type(struct_name)
    if elem_type.len() == 0 { panic("free_container_data: not a container: ", struct_name) }
    data_fl := ctx_field_layout(struct_name, "data", ctx)
    ref hdr : DynPtrBox = ptr_add(data, data_fl.offset.cast(U64))
    if hdr.p.is_null() { return }
    n := container_live_count(struct_name, data, ctx)
    esz := container_elem_size(elem_type, ctx)
    for i in 0..n {
        container_elem_deep_free(elem_type, ptr_add(hdr.p, i.mul(esz).cast(U64)), ctx)
    }
    EvalHeap.heap_free(own hdr.p)
}

priv free_container_str_data_cached := func(data: Dynamic) {
    ref hdr : DynPtrBox = data
    if hdr.p.is_null() { return }
    ref n : USize = ptr_add(data, 8)
    esz := Str.size()
    for i in 0..n {
        ref s : Str = ptr_add(hdr.p, i.mul(esz).cast(U64))
        if str_owns_c_str(s) {
            if s.c_str.is_null().not() { free(own s.c_str) }
        }
    }
    EvalHeap.heap_free(own hdr.p)
}

priv clone_container_buffer := func(struct_name: Str, src_data: Dynamic, dst_data: Dynamic, ctx: Context) {
    elem_type := container_elem_type(struct_name)
    if elem_type.len() == 0 { panic("clone_container_buffer: not a container: ", struct_name) }
    data_fl := ctx_field_layout(struct_name, "data", ctx)
    ref src_hdr : DynPtrBox = ptr_add(src_data, data_fl.offset.cast(U64))
    if src_hdr.p.is_null() { return }
    cap := container_capacity(struct_name, src_data, ctx)
    esz := container_elem_size(elem_type, ctx)
    new_buf : Dynamic = EvalHeap.heap_alloc(cap.mul(esz))
    n := container_live_count(struct_name, src_data, ctx)
    for i in 0..n {
        elem_off := i.mul(esz).cast(U64)
        container_elem_clone_into(elem_type, ptr_add(new_buf, elem_off), ptr_add(src_hdr.p, elem_off), esz, ctx)
    }
    write_ptr(ptr_add(dst_data, data_fl.offset.cast(U64)), new_buf)
}

priv dyn_vec_count := func(data: Dynamic, ctx: Context) returns USize {
    fl := ctx_field_layout("DynVec", "count", ctx)
    ref n : USize = ptr_add(data, fl.offset.cast(U64))
    return n.clone()
}

priv dyn_vec_cap := func(data: Dynamic, ctx: Context) returns USize {
    fl := ctx_field_layout("DynVec", "cap", ctx)
    ref n : USize = ptr_add(data, fl.offset.cast(U64))
    return n.clone()
}

priv dyn_vec_elem_size := func(data: Dynamic, ctx: Context) returns USize {
    fl := ctx_field_layout("DynVec", "elem_size", ctx)
    ref n : USize = ptr_add(data, fl.offset.cast(U64))
    return n.clone()
}

priv dyn_vec_elem_kind := func(data: Dynamic, ctx: Context) returns USize {
    fl := ctx_field_layout("DynVec", "elem_kind", ctx)
    ref n : USize = ptr_add(data, fl.offset.cast(U64))
    return n.clone()
}

priv free_dyn_vec_buffer := func(data: Dynamic, ctx: Context) {
    data_fl := ctx_field_layout("DynVec", "data", ctx)
    ref hdr : DynPtrBox = ptr_add(data, data_fl.offset.cast(U64))
    if hdr.p.is_null() { return }
    count := dyn_vec_count(data, ctx)
    elem_size := dyn_vec_elem_size(data, ctx)
    elem_kind := dyn_vec_elem_kind(data, ctx)
    if elem_kind == ELEM_FN {
        for i in 0..count {
            ref stored : Dynamic = deref(ptr_add(hdr.p, i.mul(elem_size).cast(U64)))
            if stored.is_null().not() { callable_storage_free(stored) }
        }
    }
    EvalHeap.heap_free(own hdr.p)
}

priv clone_dyn_vec_buffer := func(src_data: Dynamic, dst_data: Dynamic, ctx: Context) {
    data_fl := ctx_field_layout("DynVec", "data", ctx)
    ref src_hdr : DynPtrBox = ptr_add(src_data, data_fl.offset.cast(U64))
    if src_hdr.p.is_null() { return }
    cap := dyn_vec_cap(src_data, ctx)
    count := dyn_vec_count(src_data, ctx)
    elem_size := dyn_vec_elem_size(src_data, ctx)
    elem_kind := dyn_vec_elem_kind(src_data, ctx)
    new_buf : Dynamic = EvalHeap.heap_alloc(cap.mul(elem_size))
    if elem_kind == ELEM_FN {
        for i in 0..count {
            elem_off := i.mul(elem_size).cast(U64)
            ref stored : Dynamic = deref(ptr_add(src_hdr.p, elem_off))
            if stored.is_null().not() { write_ptr(ptr_add(new_buf, elem_off), callable_storage_clone(stored)) }
        }
    } else {
        memcpy(new_buf, src_hdr.p, cap.mul(elem_size).cast(U64))
    }
    write_ptr(ptr_add(dst_data, data_fl.offset.cast(U64)), new_buf)
}

priv free_temp_arg_value := func(shallow v: Value) {
    switch v {
    case Value.Struct(si):
        if si.borrowed.not() {
            if si.data.is_null().not() {
                // #286 Stage 2: contents-free via the canonical heap_drop, then
                // free the owning block (a layout-less sentinel just frees it).
                if si.layout.is_null().not() {
                    heap_drop(si.struct_name(), si.data, si.ctx)
                }
                EvalHeap.heap_free(own si.data)
            }
        }
    case Value.Enum(ei):
        if ei.data.is_null().not().and(ei.borrowed.not()) {
            if ei.is_str { enum_free_str_payload(ei.data) }
            EvalHeap.heap_free(own ei.data)
        }
    case Value.Closure(cl):
        interp_closure_free(cl)
    case:
    }
}

// #286: a return value is re-cloned at each block boundary it propagates up
// through (so it survives the about-to-be-freed scope), but the value it
// replaced was overwritten WITHOUT a free -- every boundary orphaned the
// previous clone's heap (a dominant interpret leak). Clone first, free the old
// in place (free_temp_arg_value no-ops on a borrow into the freed scope and
// reclaims an owned intermediate), move the clone's bytes in, then neutralize
// the local so its own scope-end delete is a no-op (the make_struct_value
// move-out idiom).
priv reclone_return := func(mut ctx: Context) {
    if ctx.has_return.not() { return }
    // #286: an OWNED (non-borrowed) return value is heap-allocated independently
    // of the block scope torn down next, so it already survives scope_free --
    // only a BORROWED return (a view into a binding in the about-to-be-freed
    // block) must be materialised here. Re-cloning an owned return at every
    // block boundary was pure churn that also orphaned each previous clone --
    // the dominant interpret leak this guard now removes structurally, the dual
    // of the owned-return MOVE in eval_user_func_call.
    if value_is_borrowed(ctx.return_value).not() { return }
    moved := ctx.return_value.clone()
    free_temp_arg_value(ctx.return_value)
    memcpy(ctx.return_value, moved, Value.size().cast(U64))
    memcpy(moved, val_none(), Value.size().cast(U64))
}

priv free_non_own_temp_args := func(call_scope: Scope, call_expr: Expr, func_def: Expr) {    switch func_def.node_type {
    case NodeType.FuncDef(fdef):
        for pi in 0..fdef.params.len() {
            ref param : Declaration = fdef.params[pi]
            if param.own_type.is(OwnType.Own) { continue }
            if call_expr.children[pi + 1].node_type.is(NodeType.Ident) { continue }
            ref cell : Cell = scope_get(call_scope, param.name)
            if cell.is_null().not() {
                free_temp_arg_value(cell.val)
                memcpy(cell.val, val_none(), Value.size().cast(U64))
            }
        }
    case:
    }
}

priv needs_widen := func(val: Value, ptype: Str) returns Bool {
    expect(ptype.is_null().not(), "ptype is null")
    if ptype.len() == 0 { return false }
    if val.is(Value.Byte) {
        return ptype.eq("U8").not()
    }
    if val.is(Value.Short) {
        return ptype.eq("I16").not()
    }
    if val.is(Value.Ushort) {
        return ptype.eq("U16").not()
    }
    if val.is(Value.Int32) {
        return ptype.eq("I32").not()
    }
    if val.is(Value.Uint32) {
        return ptype.eq("U32").not()
    }
    return false
}

priv shallow_copy_value := func(v: Value) returns shallow Value {
    r := Value.None
    memcpy(r, v, Value.size().cast(U64))
    return r
}

// Like shallow_copy_value but marks the copy as a BORROW: the returned
// Value aliases v's heap payload (shares the same .data), so its deep
// delete must NOT free that payload -- the original owner (a scope cell, a
// namespace field, ...) still holds it and frees it later. Used at read
// sites where the value is consumed transiently; any store of it clones
// (value semantics), so the borrow never outlives the owner. Scalars carry
// no heap, so the flag is a harmless no-op for them.
priv borrow_value := func(v: Value) returns shallow Value {
    mut r := shallow_copy_value(v)
    switch r {
    case Value.Struct(si): si.borrowed = true
    case Value.Enum(ei):   ei.borrowed = true
    case Value.Closure(cl): cl.borrowed = true
    case:
    }
    return r
}

// Issue #217: in interpret mode `own 42` bound to a `: Dynamic`
// parameter must look the same as compile mode's autobox (a heap I64
// the callee sees as a Dynamic pointer). Without boxing, downstream
// ext_funcs like ptr_add try to dereference Value.Int.payload as a
// pointer and segfault one or two frames deeper, since the scalar's
// in-Value storage is a local stack location that doesn't survive
// the call chain.
//
// `track_for_free`: true for non-own param bindings. The freshly-
// allocated pointer is registered with the call scope so scope_free
// can reclaim it when the scope ends. For `own` params skip the
// registration -- the existing function-exit `free(own x)` cleanup
// already runs free_value_full on the Value.Dynamic, which frees the
// boxed pointer; tracking it again here would double-free.
//
// Tracking is per-box (a dedicated ELEM_FN Vec on Scope) rather than
// via the cell's Value.Dynamic, because plenty of other paths put
// borrowed Value.Dynamic into local cells and freeing those would
// also double-free.
priv box_scalar_to_dynamic := func(mut call_scope: Scope, v: Value, track_for_free: Bool) returns Value {
    mut dp : Dynamic = 0
    switch v {
    case Value.Int(p):     dp = malloc(8); memcpy(dp, p, 8)
    case Value.Byte(p):    dp = malloc(1); memcpy(dp, p, 1)
    case Value.Sbyte(p):   dp = malloc(1); memcpy(dp, p, 1)
    case Value.Short(p):   dp = malloc(2); memcpy(dp, p, 2)
    case Value.Ushort(p):  dp = malloc(2); memcpy(dp, p, 2)
    case Value.Int32(p):   dp = malloc(4); memcpy(dp, p, 4)
    case Value.Uint32(p):  dp = malloc(4); memcpy(dp, p, 4)
    case Value.Uint64(p):  dp = malloc(8); memcpy(dp, p, 8)
    case Value.Float(p):   dp = malloc(4); memcpy(dp, p, 4)
    case Value.Boolean(p): dp = malloc(1); memcpy(dp, p, 1)
    case Value.Func:
        dp = callable_box_new(v)
        r_callable := Value.Dynamic(dp)
        if track_for_free { call_scope.box_owned_callables.push(own DynPtrBox(p = dynamic_value_payload_copy(r_callable))) }
        return r_callable
    case Value.Closure:
        dp = callable_box_new(v)
        r_callable2 := Value.Dynamic(dp)
        if track_for_free { call_scope.box_owned_callables.push(own DynPtrBox(p = dynamic_value_payload_copy(r_callable2))) }
        return r_callable2
    // Non-scalar (struct/enum) bound to a Dynamic param: the value already
    // carries a heap .data pointer, so there is nothing to box -- the callee
    // just reads/writes through it. Return a BORROW (not a bare
    // shallow_copy_value): the caller's cell still owns the payload, so the
    // callee's cell must not free it. An unflagged copy made two non-borrowed
    // owners -> double-free once scope teardown frees both (auto.til).
    case: return borrow_value(v)
    }
    r := Value.Dynamic(dp)
    if track_for_free {
        call_scope.box_owned_dynamics.push(own DynPtrBox(p = dynamic_value_payload_copy(r)))
    }
    return r
}

priv make_struct_value := func(sname: Str, data: Dynamic, borrowed: Bool, ctx: Context) returns shallow Value {
    ref stable_sname : Str = stable_type_name(sname, ctx)
    mut r := Value.None
    tag : I32 = 10
    memcpy(r, tag, 4)
    switch r {
    case Value.Struct(payload):
        // #286: the type name is DERIVED from `layout` (struct_name()); no
        // AST-lifetime ref is stored. is_str/is_str_container still cache while
        // sname is valid so the deep delete need not consult the layout.
        payload.is_str = stable_sname == "Str"
        payload.is_str_container = container_elem_type(stable_sname) == "Str"
        payload.ctx = ctx
        // #286: borrow this struct's layout from the frozen cache as the value's
        // type-name source. NULL only when the type has no computed layout
        // (sentinels); struct_name() must not be called on such a value.
        if ctx.struct_layouts.has(stable_sname) {
            payload.layout = ctx.struct_layouts[stable_sname]
        }
        payload.data = data
        payload.borrowed = borrowed
    case:
        UNREACHABLE()
    }
    // Move r out: the returned copy becomes the sole owner of `data`, and
    // nulling r makes its scope-end (deep) delete a no-op so the payload is
    // not double-freed.
    result := shallow_copy_value(r)
    memcpy(r, val_none(), Value.size().cast(U64))
    return result
}

priv value_is_borrowed := func(v: Value) returns Bool {
    switch v {
    case Value.Struct(si): return si.borrowed
    case Value.Enum(ei):   return ei.borrowed
    case Value.Closure(cl): return cl.borrowed
    case:                  return false
    }
}

priv widen_numeric := func(v: Value, ptype: Str, ctx: Context) returns Value {
    // A borrowed view (a method's `mut self` aliasing the caller's storage,
    // or any read_field borrow) passes through UNCHANGED: it is never a
    // numeric value, so no widening is lost, and cloning it would break
    // in-place mutation (e.g. `c.items.push(...)` would push into a copy).
    // The save_old_delete around `arg = widen_numeric(arg)` skips borrowed
    // values, so the alias does not dangle.
    if value_is_borrowed(v) { return shallow_copy_value(v) }
    // Pass-through returns clone (not shallow alias): callers reassign
    // `arg = widen_numeric(arg, ...)`, whose save_old_delete frees the old
    // arg AFTER evaluating the rhs -- an alias of arg would then dangle.
    expect(ptype.is_null().not(), "ptype is null")
    if ptype.len() == 0 { return v.clone() }
    mut ival : I64 = 0
    mut uval : U64 = 0
    mut is_unsigned := false
    switch v {
    case Value.Byte(bv):
        uval = bv.cast(U64)
        is_unsigned = true
    case Value.Short(sv):
        ival = sv.cast(I64)
    case Value.Ushort(uv):
        uval = uv.cast(U64)
        is_unsigned = true
    case Value.Int32(iv):
        ival = iv.cast(I64)
    case Value.Uint32(uv):
        uval = uv.cast(U64)
        is_unsigned = true
    case:
        // Non-numeric (Str/struct/enum): pass through as an INDEPENDENT
        // clone, not a shallow alias -- callers do `arg = widen_numeric(arg)`
        // whose save_old_delete frees the old arg, which would dangle an alias.
        return v.clone()
    }
    if is_unsigned.not() { uval = ival.cast(U64) }
    else { ival = uval.cast(I64) }
    if ptype == "I64" {
        if is_unsigned { return Value.Int(uval.cast(I64)) }
        return Value.Int(ival)
    }
    if ptype == "U64" { return Value.Uint64(uval) }
    if ptype == "USize" { return Value.Uint32(uval.to_u32()) }
    if ptype == "UPtr" {
        ref uptr_name : Str = resolve_type_alias(ctx.scope, "UPtr")
        if uptr_name == "U32" { return Value.Uint32(uval.to_u32()) }
        return Value.Uint64(uval)
    }
    if ptype == "U32" {
        if v.is(Value.Byte) { return Value.Uint32(uval.to_u32()) }
    }
    if ptype == "I32" {
        if v.is(Value.Byte) { return Value.Int32(ival.to_i32()) }
        if v.is(Value.Short) { return Value.Int32(ival.to_i32()) }
    }
    if ptype == "I16" {
        if v.is(Value.Byte) { return val_i16(ival) }
    }
    if ptype == "U16" {
        if v.is(Value.Byte) { return val_u16(uval.cast(I64)) }
    }
    // Clone, not alias: see the pass-through note at the top -- callers do
    // `arg = widen_numeric(arg, ...)` and the result must be independent of v.
    return v.clone()
}

scope_get := func(mut s: Scope, name: Str) returns ref Cell {
    ref mut cur : Scope = s
    while true {
        if cur.is_null() { return NULL }
        if cur.bindings.has(name) {
            return cur.bindings[name].cell
        }
        cur = cur.parent
    }
    return NULL
}

scope_new := func(parent: Scope) returns Scope {
    return Scope(parent = parent)
}

// #286 commit 1: walk the scope chain (inner -> outer) for `name`'s heap
// pointer (rstil's lookup_var). Returns the block's real address, or NULL
// if unbound. The heap_index is empty until eval starts storing values in
// the EvalHeap (commits 2-3), so this returns NULL everywhere for now.
scope_lookup_offset := func(mut s: Scope, name: Str) returns ref Dynamic {
    ref mut cur : Scope = s
    while true {
        if cur.is_null() { return NULL }
        if cur.heap_index.has(name) {
            ref p : Dynamic = cur.heap_index[name]
            return p
        }
        cur = cur.parent
    }
    return NULL
}

// #286: lookup the type/ownership metadata that describes a heap_index
// pointer. Mirrors scope_lookup_offset's parent-chain walk so migrated values
// can be resolved without inspecting a boxed Value.
scope_lookup_heap_binding := func(mut s: Scope, name: Str) returns ref HeapBinding {
    ref mut cur : Scope = s
    while true {
        if cur.is_null() { return NULL }
        if cur.heap_bindings.has(name) {
            ref b : HeapBinding = cur.heap_bindings[name]
            return b
        }
        cur = cur.parent
    }
    return NULL
}

// #286 commit 1: bind `name` to a heap pointer in the current scope.
scope_insert_offset := func(mut s: Scope, name: Str, own ptr: Dynamic) {
    s.heap_index.set(name, own ptr)
}

// #286 Stage 1: bind a typed raw-heap slot in the current scope. Later stages
// replace scope_set_owned / scope_set_borrowed call sites with this helper as
// each value class moves off Cell/Value.
scope_set_heap_owned := func(mut s: Scope, name: Str, own ptr: Dynamic, shallow til_type: Type, own_type: OwnType, is_local: Bool, is_borrowed: Bool = false) {
    scope_insert_offset(s, name, own ptr)
    meta := HeapBinding(til_type = til_type.clone(), own_type = own_type, is_local = is_local, is_borrowed = is_borrowed, moved_out = false)
    s.heap_bindings.set(name, own meta)
}

// #286 Stage 1: mark a heap slot as moved out without deleting its metadata.
// Move sites need this separate from removing the map entry so later reads can
// fail at the source instead of silently falling back to a stale parent binding.
scope_set_heap_moved := func(mut s: Scope, name: Str, moved_out: Bool) {
    ref b : HeapBinding = scope_lookup_heap_binding(s, name)
    if b.is_null() { panic("scope_set_heap_moved: heap binding not found: ", name) }
    b.moved_out = moved_out
}

priv scope_new_boxed := func(parent: Scope) returns ref Scope {
    raw : Dynamic = malloc(Scope.size().cast(U64))
    memset(raw, 0, Scope.size().cast(U64))
    ref s : Scope = to_ptr(raw)
    s.bindings = Map(Str, Binding).new()
    s.heap_index = Map(Str, Dynamic).new()
    s.heap_bindings = Map(Str, HeapBinding).new()
    s.parent = parent
    s.payload_aliases = Map(Str, Str).new()
    s.ref_primitive_ptrs = Map(Str, Dynamic).new()
    s.box_owned_dynamics = Vec(DynPtrBox).new()
    s.box_owned_callables = Vec(DynPtrBox).new()
    return s
}

// #211 follow-up: walk the scope chain looking up a payload-alias entry
// for `name`. Returns the encoded "<enum_var>|<type>" string when found
// (registered by the Decl handler for `ref T = get_payload(<ident>)`),
// or "" otherwise. The Assign handler uses this to mirror the write.
priv scope_get_payload_alias := func(mut s: Scope, name: Str) returns Str {
    ref mut cur : Scope = s
    while true {
        if cur.is_null() { return "" }
        if cur.payload_aliases.has(name) {
            return cur.payload_aliases[name].clone()
        }
        cur = cur.parent
    }
    return ""
}

// #227: matches builder.til's is_primitive_type by name. Inlined
// here because interpreter.til doesn't import that helper.
priv interp_is_primitive_type_name := func(name: Str) returns Bool {
    if name == "I8" { return true }
    if name == "U8" { return true }
    if name == "I16" { return true }
    if name == "U16" { return true }
    if name == "I32" { return true }
    if name == "U32" { return true }
    if name == "I64" { return true }
    if name == "U64" { return true }
    if name == "USize" { return true }
    if name == "UPtr" { return true }
    if name == "F32" { return true }
    if name == "Bool" { return true }
    return false
}

// #227: returns NULL if `name` is not a ref-to-primitive binding.
// Otherwise returns the source address (the ptr_add result the ref
// was bound to) so the Assign handler can write through it.
priv scope_get_ref_primitive_ptr := func(mut s: Scope, name: Str) returns ref Dynamic {
    ref mut cur : Scope = s
    while true {
        if cur.is_null() { return NULL }
        if cur.ref_primitive_ptrs.has(name) {
            ref holder : Dynamic = cur.ref_primitive_ptrs[name]
            ref stored : Dynamic = deref(holder)
            return stored
        }
        cur = cur.parent
    }
    return NULL
}

// #286 Stage 3: peel a freshly-bound owned plain struct so scope teardown
// reclaims it via the canonical heap_drop. A heap_bindings marker records the
// peel; Cell.val keeps a borrowed view so the box's own free no-ops. Skips Str /
// containers, custom-delete/clone structs (their box teardown has user
// semantics heap_drop can't replicate), the global scope, and borrowed/layout-
// less values. valaddr is the cell ADDRESS (Cell.val is at offset 0).
priv struct_has_custom_teardown := func(struct_name: Str, ctx: Context) returns Bool {
    ref tdef : Expr = lookup_interp_type_def(struct_name, ctx)
    if tdef.is_null() { return true }
    switch tdef.node_type {
    case NodeType.StructDef(sdd):
        // Methods live in ns_decls. A user-defined delete whose body has custom
        // logic (Assign / FieldAssign / a non-field-cleanup call -- the same
        // signal master's interception uses) must keep its box teardown, so do
        // NOT peel such a struct. Auto-generated / pure-field-cleanup deletes are
        // equivalent to heap_drop, so peeling is safe there.
        for d : Declaration in sdd.ns_decls {
            if d.name == "delete" {
                if delete_body_has_custom_logic(d.default_value) { return true }
            }
        }
    case:
        return true
    }
    return false
}

priv scope_peel_owned_aggregate := func(mut s: Scope, shallow name: Str, valaddr: Dynamic) {
    if s.parent.is_null() { return }
    ref cv : Value = valaddr
    switch cv {
    case Value.Struct(si):
        if si.borrowed { return }
        if si.data.is_null() { return }
        if si.layout.is_null() { return }
        if si.is_str { return }
        if si.is_str_container { return }
        if container_elem_type(si.struct_name()).len() > 0 { return }
        if si.ctx.is_null() { return }
        if struct_has_custom_teardown(si.struct_name(), si.ctx) { return }
        marker := HeapBinding(til_type = Type.Unknown, own_type = OwnType.Own, is_local = true,
                              is_borrowed = false, moved_out = false)
        s.heap_bindings.set(name, own marker)
        si.borrowed = true
    case:
    }
}

priv scope_reclaim_peeled := func(mut s: Scope, shallow name: Str, valaddr: Dynamic) {
    if s.heap_bindings.has(name).not() { return }
    ref mut hb : HeapBinding = s.heap_bindings[name]
    if hb.moved_out { return }
    hb.moved_out = true
    ref cv : Value = valaddr
    switch cv {
    case Value.Struct(si):
        if si.data.is_null() { return }
        if si.borrowed.not() { return }
        heap_drop(si.struct_name(), si.data, si.ctx)
        EvalHeap.heap_free(own si.data)
    case:
    }
}

// #286 Stage 3: reclaim a peeled struct from the explicit-delete intercept.
// The receiver may be bound in a parent scope, so walk inner->outer for the
// nearest scope that actually holds `name`'s binding (mirroring scope_get),
// then reclaim that scope's peel marker against the cell's view.
// scope_reclaim_peeled marks the marker moved_out, so scope_free will not
// reclaim it a second time.
priv scope_reclaim_peeled_at_binding := func(mut s: Scope, shallow name: Str) {
    ref mut cur : Scope = s
    while true {
        if cur.is_null() { return }
        if cur.bindings.has(name) {
            ref b : Binding = cur.bindings[name]
            scope_reclaim_peeled(cur, name, b.cell)
            return
        }
        cur = cur.parent
    }
}

scope_set_owned := func(mut s: Scope, name: Str, mut val: Value) {
    // The cell takes ownership of val's payload (memcpy of the Value bytes,
    // including the .data pointer). val is a pointer to the caller's local,
    // so null it after the copy: this is a MOVE, and it makes the garbager's
    // deep Value.delete on the caller's local a no-op -- the cell is now the
    // sole owner and scope_free reclaims it.
    if s.bindings.has(name) {
        ref b : Binding = s.bindings[name]
        // Rebinding an existing name: the old value must be fully reclaimed,
        // not just its top box. A local cell OWNS its payload, so deep-free it
        // (a Str's c_str, a struct's nested heap) -- the shallow free_value
        // leaked that payload on every rebind, the dominant
        // bind_known_idents_in / constfolder Str_clone leak. free_temp_arg_value
        // honours the borrowed flag and the CAP_VIEW guard, so an owned view
        // Str keeps its borrowed c_str. A borrowed binding shares the source
        // cell, so never deep-free it: keep the shallow release there.
        // #286 Stage 3: reclaim a previously-peeled payload (pass b.cell, the
        // cell ADDRESS, never b.cell.val which moves the Value).
        scope_reclaim_peeled(s, name, b.cell)
        if b.cell_is_local {
            free_temp_arg_value(b.cell.val)
        } else {
            free_value(b.cell.val)
        }
        memcpy(b.cell.val, val, Value.size().cast(U64))
        memcpy(val, val_none(), Value.size().cast(U64))
        if b.cell_is_local { scope_peel_owned_aggregate(s, name, b.cell) }
        return
    }
    cell : Dynamic = malloc(Cell.size().cast(U64))
    memcpy(cell, val, Value.size().cast(U64))
    memcpy(val, val_none(), Value.size().cast(U64))
    // Build Binding: {name_ptr, cell_ptr, cell_is_local=1}
    v : Dynamic = malloc(Binding.size().cast(U64))
    memset(v, 0, Binding.size().cast(U64))
    write_ptr(v, name)
    write_ptr(ptr_add(v, 8), cell)
    local_flag := true
    memcpy(ptr_add(v, 16), local_flag, Bool.size().cast(U64))
    s.bindings.set(name, own v)
    // #286 Stage 3: move plain-struct ownership to a heap_bindings marker.
    scope_peel_owned_aggregate(s, name, cell)
}

priv scope_set_borrowed := func(mut s: Scope, name: Str, cell: Cell) {
    v : Dynamic = malloc(Binding.size().cast(U64))
    memset(v, 0, Binding.size().cast(U64))
    write_ptr(v, name)
    write_ptr(ptr_add(v, 8), cell)
    // cell_is_local = false (already zeroed by memset)
    s.bindings.set(name, own v)
}
scope_free := func(own s: Scope) {
    // #286 Stage 3: iterate by index to pass the stable bindings MAP KEY to
    // scope_reclaim_peeled, and b.cell (the cell ADDRESS, not b.cell.val).
    for i in 0..s.bindings.keys.count {
        ref kname : Str = s.bindings.keys.unsafe_get(i)
        ref b : Binding = s.bindings.values.unsafe_get(i)
        if b.cell_is_local {
            scope_reclaim_peeled(s, kname, b.cell)
            // Issue #275: deep teardown for ALL scopes -- reclaim every
            // non-borrowed Struct/Str/Enum payload. Block/if/while/catch cells
            // skipped by an early return/break (whose scope-exit AST deletes
            // never ran) were the residual interpret leak; the enum-payload
            // ownership contract (#272) makes always-deep safe, so the old
            // shallow path (which leaked Struct/Str payloads) is gone.
            free_temp_arg_value(b.cell.val)
            free(own b.cell)
        }
    }
    // Delete Map contents but not the Map struct (it's inline in Scope)
    own s.bindings.delete(false)
    // Zero out bindings so Scope destructor doesn't double-free
    memset(s.bindings, 0, Map(Str, Binding).size().cast(U64))
    // #211 follow-up: same treatment for payload_aliases. Was leaking
    // one Map(Str, Str).new() per scope per program (every scope_new()
    // defaulted the field), pushing translate ASAN from 146K to 707K
    // bytes leaked.
    own s.payload_aliases.delete(false)
    memset(s.payload_aliases, 0, Map(Str, Str).size().cast(U64))
    // #227 follow-up: same treatment for ref_primitive_ptrs (added by
    // 1e0be62). Like payload_aliases above, every scope_new() defaulted
    // this field to an empty Map(Str, Dynamic).new() -- two malloc'd Vec
    // backing buffers that scope_free never reclaimed, leaking ~2 allocs
    // per scope. That was the interpret/translate ASAN regression.
    // delete(false) frees the Str keys and both backing Vecs; the stored
    // Dynamic values are borrowed source pointers (Map.set already freed
    // the transient holder at insert time), so default_delete leaving
    // them untouched is exactly right -- do NOT free them here.
    own s.ref_primitive_ptrs.delete(false)
    memset(s.ref_primitive_ptrs, 0, Map(Str, Dynamic).size().cast(U64))
    // #286 commit 1 follow-up: same treatment for heap_index (the EvalHeap
    // name->pointer index). Every scope_new() defaults it to an empty
    // Map(Str, Dynamic).new() -- two malloc'd Vec backing buffers that
    // scope_free must reclaim, else ~2 allocs leak per scope (the 7d2a08c
    // interpret/translate ASAN regression, identical to the #211 / #227
    // misses above). Empty until eval stores values here; delete(false)
    // frees the Str keys and both backing Vecs and leaves any stored
    // Dynamic block pointers untouched (those are reclaimed by heap_free at
    // the value's own delete, exactly like ref_primitive_ptrs' borrowed
    // pointers above).
    own s.heap_index.delete(false)
    memset(s.heap_index, 0, Map(Str, Dynamic).size().cast(U64))
    // #286 Stage 1: same treatment for the heap_index metadata map. It owns
    // only type/ownership metadata; heap payload blocks are still freed by the
    // active Value path until later stages switch scope teardown to heap_drop.
    own s.heap_bindings.delete(false)
    memset(s.heap_bindings, 0, Map(Str, HeapBinding).size().cast(U64))
    // Issue #217 follow-up: free the boxes that box_scalar_to_dynamic
    // allocated for `: Dynamic` parameters bound from scalars. The Vec
    // stores owning pointer boxes so the raw heap pointer can be passed to
    // free() through an `own` field.
    for box : DynPtrBox in s.box_owned_dynamics {
        if box.p.is_null().not() { free(own box.p) }
    }
    free(own s.box_owned_dynamics.data)
    memset(s.box_owned_dynamics, 0, Vec(DynPtrBox).size().cast(U64))
    for cbox : DynPtrBox in s.box_owned_callables {
        callable_box_free(cbox.p)
    }
    free(own s.box_owned_callables.data)
    memset(s.box_owned_callables, 0, Vec(DynPtrBox).size().cast(U64))
    free(own s)
}

priv scope_root_ref := func(s: Scope) returns ref Scope {
    if s.parent.is_null() { return s }
    return scope_root_ref(s.parent)
}

priv closure_env_clone := func(env: Scope) returns ref Scope {
    ref cloned : Scope = scope_new_boxed(env.parent)
    for b : Binding in env.bindings.values {
        if b.cell_is_local {
            mut cap_val := b.cell.val.clone()
            scope_set_owned(cloned, b.name, cap_val)
        } else {
            scope_set_borrowed(cloned, b.name, b.cell)
        }
    }
    return cloned
}

priv interp_closure_clone := func(cl: InterpClosure) returns InterpClosure {
    return InterpClosure(func_def = cl.func_def, env = closure_env_clone(cl.env), borrowed = false)
}

priv interp_closure_free := func(cl: InterpClosure) {
    if cl.borrowed.not() { scope_free(own cl.env) }
}

priv make_interp_closure := func(func_def: Expr, scope: Scope) returns Value {
    ref env : Scope = scope_new_boxed(scope_root_ref(scope))
    switch func_def.node_type {
    case NodeType.FuncDef(fd):
        for cap : Declaration in fd.captures {
            ref src : Cell = scope_get(scope, cap.name)
            if cap.own_type.is(OwnType.Ref) {
                scope_set_borrowed(env, cap.name, src)
            } else if cap.own_type.is(OwnType.Shallow) {
                mut cap_val := src.val.clone()
                scope_set_owned(env, cap.name, cap_val)
            } else {
                mut cap_val2 := shallow_copy_value(src.val)
                if src.val.is(Value.Func).not() { memcpy(src.val, val_none(), Value.size().cast(U64)) }
                scope_set_owned(env, cap.name, cap_val2)
            }
        }
    case NodeType.BodyValue(bd):
        for cap2 : Declaration in bd.captures {
            ref src2 : Cell = scope_get(scope, cap2.name)
            if cap2.own_type.is(OwnType.Ref) {
                scope_set_borrowed(env, cap2.name, src2)
            } else if cap2.own_type.is(OwnType.Shallow) {
                mut cap_val3 := src2.val.clone()
                scope_set_owned(env, cap2.name, cap_val3)
            } else {
                mut cap_val4 := shallow_copy_value(src2.val)
                if src2.val.is(Value.Func).not() { memcpy(src2.val, val_none(), Value.size().cast(U64)) }
                scope_set_owned(env, cap2.name, cap_val4)
            }
        }
    case:
        UNREACHABLE()
    }
    return Value.Closure(InterpClosure(func_def = func_def, env = env, borrowed = false))
}

priv callable_box_is := func(ptr: Dynamic) returns Bool {
    if ptr.is_null() { return false }
    ref magic : U64 = ptr
    return magic == CALLABLE_BOX_MAGIC
}

priv value_is_callable := func(v: Value) returns Bool {
    return v.is(Value.Func).or(v.is(Value.Closure))
}

priv callable_box_new := func(v: Value) returns Dynamic {
    if value_is_callable(v).not() { panic("callable_box_new: non-callable Value.", value_variant_name(v)) }
    box : Dynamic = malloc(InterpCallableBox.size().cast(U64))
    memset(box, 0, InterpCallableBox.size().cast(U64))
    ref b : InterpCallableBox = to_ptr(box)
    b.magic = CALLABLE_BOX_MAGIC
    mut stored := v.clone()
    memcpy(b.val, stored, Value.size().cast(U64))
    memcpy(stored, val_none(), Value.size().cast(U64))
    return box
}

priv callable_storage_read := func(ptr: Dynamic) returns Value {
    if callable_box_is(ptr) {
        ref b : InterpCallableBox = to_ptr(ptr)
        return borrow_value(b.val)
    }
    return Value.Func(ptr)
}

priv callable_slot_read := func(ptr: Dynamic) returns Value {
    ref stored : Dynamic = deref(ptr)
    return callable_storage_read(stored)
}

priv callable_box_or_slot_read := func(ptr: Dynamic) returns Value {
    if callable_box_is(ptr) { return callable_storage_read(ptr) }
    return callable_slot_read(ptr)
}

priv callable_storage_clone := func(ptr: Dynamic) returns Dynamic {
    if callable_box_is(ptr).not() { return ptr }
    v := callable_storage_read(ptr)
    return callable_box_new(v)
}

priv callable_storage_free := func(ptr: Dynamic) {
    if callable_box_is(ptr) { callable_box_free(ptr) }
}

priv callable_box_free := func(ptr: Dynamic) {
    if callable_box_is(ptr).not() { return }
    ref b : InterpCallableBox = to_ptr(ptr)
    free_temp_arg_value(b.val)
    memset(b.val, 0, Value.size().cast(U64))
    mut owned_ptr : Dynamic = ptr
    free(own owned_ptr)
}

// Body of interp_fa_is_ns_inner pulled out so both FieldAccess and
// FieldAssign cases (which share an Str payload) can switch-destructure
// `e.node_type` without duplicating ~50 lines of logic.
priv interp_fa_is_ns_with_fname := func(obj_expr: Expr, sname: Str, sdef: Expr, fname: Str) returns Bool {
    mut has_ns := false
    mut has_inst := false
    ref ins_ns : Vec(Declaration) = def_ns_decls(sdef)
    for ins_d : Declaration in ins_ns {
        if ins_d.name == fname { has_ns = true }
    }
    switch sdef.node_type {
    case NodeType.StructDef(ins_sdd):
        for dd : Declaration in ins_sdd.fields {
            if dd.name == fname { has_inst = true }
        }
    case NodeType.EnumDef(ins_edd):
        for vn : Str in ins_edd.variants {
            if vn == fname { has_inst = true }
        }
    case:
    }
    // Issue: variant access on an enum *instance* (e.g. `v.Some` where v
    // is an Opt value, Some is a variant of Opt) is a namespace-style
    // access -- it produces the variant constructor / tag value, matching
    // what `Opt.Some` does and what the typer accepts in compile mode.
    // The existing uppercase-receiver heuristic below only catches type-
    // name receivers (`Opt.Some`); add the enum-instance case here.
    if has_inst {
        if sdef.node_type.is(NodeType.EnumDef) {
            return true
        }
    }
    if has_ns {
        if has_inst.not() { return true }
    }
    if has_ns.not() {
        if has_inst.not() {
            switch obj_expr.node_type {
            case NodeType.Ident(ident):
                if ident.ident_name() == sname { return true }
                if ident.len() > 0 {
                    if ident.unsafe_get(0) >= 65 {
                        if ident.unsafe_get(0) <= 90 { return true }
                    }
                }
            case:
            }
            return false
        }
    }
    if has_ns {
        if has_inst {
            switch obj_expr.node_type {
            case NodeType.Ident(ident):
                if ident.ident_name() == sname { return true }
                if ident.len() > 0 {
                    if ident.unsafe_get(0) >= 65 {
                        if ident.unsafe_get(0) <= 90 { return true }
                    }
                }
            case:
                return false
            }
        }
    }
    return false
}

priv interp_fa_is_ns_inner := func(scope: Scope, e: Expr, sname: Str) returns Bool {
    ref obj_expr : Expr = e.children[0]
    ref tc : Cell = scope_get(scope, sname)
    if tc.is_null() { return false }
    switch tc.val {
    case Value.Func(fptr):
        ref sdef : Expr = deref(fptr)
        if sdef.node_type.is(NodeType.StructDef).not() {
            if sdef.node_type.is(NodeType.EnumDef).not() { return false }
        }
        switch e.node_type {
        case NodeType.FieldAccess(fname):
            return interp_fa_is_ns_with_fname(obj_expr, sname, sdef, fname.field_access_name())
        case NodeType.FieldAssign(fad):
            return interp_fa_is_ns_with_fname(obj_expr, sname, sdef, fad.name)
        case:
            return false
        }
    case:
        return false
    }
}

// For FieldAssign rhs: when the value is a Dynamic Ident, return the
// source Cell so the caller can shallow-copy its value (move semantics
// for Dynamic). Returns NULL when the rhs isn't an Ident or isn't
// Dynamic, signalling "evaluate the expression normally".
priv field_assign_dyn_move_src := func(mut scope: Scope, val_expr: Expr) returns ref Cell {
    if val_expr.expr_til_type().is(Type.Dynamic).not() { return NULL }
    switch val_expr.node_type {
    case NodeType.Ident(vi): return scope_get(scope, vi.ident_name())
    case:
        return NULL
    }
}

priv interp_fa_is_ns := func(scope: Scope, e: Expr) returns Bool {
    ref obj_expr : Expr = e.children[0]
    sname := til_type_name(obj_expr.expr_til_type())
    if sname.len() > 0 { return interp_fa_is_ns_inner(scope, e, sname) }
    switch obj_expr.node_type {
    case NodeType.Ident(ident): return interp_fa_is_ns_inner(scope, e, ident.ident_name())
    case:
    }
    // Primitive receivers (`0.sub(1)`, recv = LiteralNum I64): til_type_name
    // returns "" for I64/U8/etc, fall back to til_type_name_c.
    tn := til_type_name_c(obj_expr.expr_til_type())
    if tn.eq("unknown").not().and(tn.eq("?").not()).and(tn.eq("Dynamic").not()) {
        return interp_fa_is_ns_inner(scope, e, tn)
    }
    return false
}

priv value_to_buf := func(dest: Dynamic, val: Value, type_name: Str) {
    switch val {
    case Value.Int(v):     if type_name == "I64"  { memcpy(dest, v, 8); return }
    case Value.Byte(v):    if type_name == "U8"   { memcpy(dest, v, 1); return }
    case Value.Sbyte(v):   if type_name == "I8"   { memcpy(dest, v, 1); return }
    case Value.Short(v):   if type_name == "I16"  { memcpy(dest, v, 2); return }
    case Value.Ushort(v):  if type_name == "U16"  { memcpy(dest, v, 2); return }
    case Value.Int32(v):   if type_name == "I32"  { memcpy(dest, v, 4); return }
    case Value.Uint32(v):  if type_name == "U32"  { memcpy(dest, v, 4); return }
    case Value.Boolean(v): if type_name == "Bool" { memcpy(dest, v, 1); return }
    case Value.Struct(si):
        switch lookup_interp_type_def(si.struct_name(), si.ctx).node_type {
        case NodeType.StructDef:
            sz := ctx_total_size(si.struct_name(), si.ctx)
            // Always deep-clone into the buffer: the caller deletes `val`
            // after this (e.g. build_argv_array), so the buffer must own an
            // independent copy of any nested heap (a Str payload's c_str). A
            // bare memcpy of si.data shared the c_str and dangled once `val`
            // was freed (the old non-borrowed path, fatal under deep deletes).
            mut cloned := val.clone()
            switch cloned {
            case Value.Struct(csi):
                memcpy(dest, csi.data, sz.cast(U64))
                free(own csi.data)
                csi.data = NULL
            case:
            }
        case:
        }
    case:
    }
}

priv build_argv_array := func(argv: Vec(Str), offset: U32, count: U32, elem_type: Str, ctx: Context) returns shallow Value {
    esz := elem_size_for_type(elem_type)
    mut alloc_count := count
    if alloc_count == 0 { alloc_count = 1 }
    data : Dynamic = EvalHeap.heap_alloc(alloc_count.mul(esz))
    for i in 0..count {
        v := parse_cli_arg(argv[offset + i], elem_type, ctx)
        value_to_buf(ptr_add(data, i.cast(U64) * esz.cast(U64)), v, elem_type)
    }
    array_name := format("Array__", elem_type)
    ref array_binding : TypeBinding = ctx.scope.get_binding(array_name)
    if array_binding.is_null() { panic("missing Array type '", array_name, "'") }
    ref array_canon_name : Str = array_binding.name
    ref array_def : Expr = lookup_interp_type_def(array_canon_name, ctx)
    sz := ctx_total_size(array_canon_name, ctx)
    inst_data : Dynamic = EvalHeap.heap_alloc(sz)
    ba_data_fl := ctx_field_layout(array_canon_name, "data", ctx)
    write_ptr(ptr_add(inst_data, ba_data_fl.offset.cast(U64)), data)
    ref ba_cap_d : Declaration = find_field_decl(array_def, "cap")
    ba_cap_fl := ctx_field_layout(array_canon_name, "cap", ctx)
    write_field(inst_data, ba_cap_d, ba_cap_fl.offset, ba_cap_fl.size, Value.Uint32(count), ctx)
    return make_struct_value(array_canon_name, to_ptr(inst_data), false, ctx)
}

// Cache-only pass: populate ctx.cached_str/array/vec_def/name without
// running eval_expr on namespace decl default values. Cheap walk that
// must run BEFORE constfolder_register_fold_scope so make_str_value_view /
// make_str_value calls from is_known(...) -> expr_to_value see a
// non-NULL cached_str_name -- otherwise cleanup_value_payload's
// struct_name.eq("Str") check fails for the resulting Values and the
// inner c_str buffers leak (issue #109).
populate_cached_aggregate_defs := func(mut ctx: Context, program: Expr) {
    for stmt : Expr in program.children {
        switch stmt.node_type {
        case NodeType.Decl(dd):
            if stmt.children.len() == 0 { continue }
            if stmt.children[0].node_type.is(NodeType.StructDef).not() { continue }
            if dd.name == "Str"   { ctx.cached_str_def   = stmt.children[0]; ctx.cached_str_name   = dd.name }
            if dd.name == "Array" { ctx.cached_array_def = stmt.children[0]; ctx.cached_array_name = dd.name }
            if dd.name == "Vec"   { ctx.cached_vec_def   = stmt.children[0]; ctx.cached_vec_name   = dd.name }
        case:
        }
    }
}

interpreter_init_ns := proc(mut ctx: Context, global: Scope, program: Expr) {
    if ctx.ns_inited.not() {
        ctx.ns_fields = Map(Str, Value).new()
        ctx.ns_keys = Vec(Dynamic).new()
        ctx.ns_inited = true
    }
    for stmt : Expr in program.children {
        switch stmt.node_type {
        case NodeType.Decl(dd):
            if stmt.children.len() == 0 { continue }
            ref sdef : Expr = stmt.children[0]
            if sdef.node_type.is(NodeType.StructDef).not() {
                if sdef.node_type.is(NodeType.EnumDef).not() { continue }
            }
            if sdef.node_type.is(NodeType.StructDef) {
                if dd.name == "Str"   { ctx.cached_str_def   = stmt.children[0]; ctx.cached_str_name   = dd.name }
                if dd.name == "Array" { ctx.cached_array_def = stmt.children[0]; ctx.cached_array_name = dd.name }
                if dd.name == "Vec"   { ctx.cached_vec_def   = stmt.children[0]; ctx.cached_vec_name   = dd.name }
            }
            // Register every struct/enum AST in the comprehensive type-def map
            // so readers can replace Declaration.field_struct_def with a name lookup.
            // Clone the name for owned-key safety -- a CAP_VIEW key dangles if the
            // AST gets rebuilt later in the run. The map value is a malloc'd cell
            // holding the Expr pointer (same encoding as ctx.struct_def_exprs).
            tdv : Dynamic = malloc(I64.size().cast(U64))
            write_ptr(tdv, sdef)
            ctx.interp_type_defs.set(dd.name, own tdv)
            ref ien_ns : Vec(Declaration) = def_ns_decls(sdef)
            for d_j : Declaration in ien_ns {
                ref nsd : Declaration = d_j
                if nsd.default_value.is_null() { continue }
                mut fval := eval_expr(global, nsd.default_value, ctx)
                if sdef.node_type.is(NodeType.EnumDef) {
                    if enum_has_payloads(sdef).not() {
                        // #264: narrow the cached variant value to a 4-byte
                        // Int32 box ONLY when the tag actually fits in 4 bytes.
                        // A U64-tagged no-payload enum must stay Value.Int (8
                        // bytes): the auto-generated is/eq pass enum_tag_size
                        // (=8) to is_n, which then reads 8 bytes from this cached
                        // operand. Narrowing it to a 4-byte Int32 box made is_n
                        // over-read past the allocation (heap-buffer-overflow).
                        if enum_tag_size(sdef) <= 4 {
                            switch fval {
                            case Value.Int(iv):
                                fval = val_i32(iv)
                            case:
                            }
                        }
                    }
                }
                ns_set(dd.name, nsd.name, fval, ctx)
            }
        case:
        }
    }
}

priv ns_qname := func(sname: Str, fname: Str) returns Str {
    return sname.format(".", fname)
}

ns_get := func(sname: Str, fname: Str, mut ctx: Context) returns ref Value {
    ref mut c : Context = ctx
    qn := ns_qname(sname, fname)
    if c.ns_fields.has(qn).not() { return NULL }
    return c.ns_fields[qn]
}


priv ns_set := func(sname: Str, fname: Str, shallow val: Value, mut ctx: Context) {
    ref mut c : Context = ctx
    qn := ns_qname(sname, fname)
    mut vcopy := val.clone()
    c.ns_fields.set(qn, own vcopy)
}

priv interpreter_free_ns := func(mut ctx: Context) {
    if ctx.ns_inited.not() { return }
    own ctx.ns_fields.delete(false)
    memset(ctx.ns_fields, 0, Map(Str, Value).size().cast(U64))
    own ctx.ns_keys.delete(false)
    memset(ctx.ns_keys, 0, Vec(Dynamic).size().cast(U64))
    ctx.ns_inited = false
}

make_str_value := func(data: Dynamic, len: USize, ctx: Context) returns shallow Value {
    inst_data : Dynamic = EvalHeap.heap_alloc(Str.size())
    if len == 0 {
        // Empty string: no owned buffer to allocate. Point at the shared ""
        // literal (cap=CAP_LIT) so teardown frees nothing. Avoids a 1-byte
        // malloc per empty string that the count==0 free guards skip and leak
        // (the dominant make_str_value leak, mostly from constfolder folds).
        write_ptr(inst_data, "".c_str)
        write_u32(ptr_add(inst_data, 8), 0)
        write_u32(ptr_add(inst_data, 12), CAP_LIT)
        return make_struct_value(ctx.cached_str_name, inst_data, false, ctx)
    }
    copy : Dynamic = EvalHeap.heap_alloc(len.add(1))
    memcpy(copy, data, len.cast(U64))
    memset(ptr_add(copy, len.cast(U64)), 0, 1)
    write_ptr(inst_data, copy)
    write_u32(ptr_add(inst_data, 8), len)
    // cap = count so Str.delete frees the malloc'd buffer (was CAP_LIT,
    // which left the buffer alive forever -- a per-call leak that
    // multiplied with every Str-typed constfolder fold).
    write_u32(ptr_add(inst_data, 12), len)
    return make_struct_value(ctx.cached_str_name, inst_data, false, ctx)
}

// Like make_str_value but builds a Value.Struct(Str) that VIEWS into
// the caller's buffer (cap=CAP_VIEW) rather than copying. The caller
// MUST guarantee `data` outlives every consumer of the returned Value.
// Used by constfolder to track LiteralStr Decls without copying the buffer:
// the LiteralStr's c_str is stable for the entire constfolder lifetime.
make_str_value_view := func(data: Dynamic, len: USize, ctx: Context) returns shallow Value {
    inst_data : Dynamic = EvalHeap.heap_alloc(Str.size())
    write_ptr(inst_data, data)
    write_u32(ptr_add(inst_data, 8), len)
    memcpy(ptr_add(inst_data, 12), CAP_VIEW, U32.size().cast(U64))
    return make_struct_value(ctx.cached_str_name, inst_data, false, ctx)
}

priv make_str_value_own := func(data: Dynamic, len: USize, ctx: Context) returns shallow Value {
    inst_data : Dynamic = EvalHeap.heap_alloc(Str.size())
    write_ptr(inst_data, data)
    write_u32(ptr_add(inst_data, 8), len)
    write_u32(ptr_add(inst_data, 12), len)
    return make_struct_value(ctx.cached_str_name, inst_data, false, ctx)
}
str_view := func(shallow v: Value) returns shallow Str {
    // Top-level Decl + Return so the typer's
    // skip-promote-shallow-return optimization (in
    // promote_own_transferred_locals) fires and the result stays on
    // the stack. Putting the Decl inside the switch case hid it from
    // the optimization (decl_idx fell back to the switch itself, not
    // the inner Return), so codegen malloc'd the wrapper just to
    // DEREF it on return -- 16 bytes leak per call.
    mut result := ""
    switch v {
    case Value.Struct(si):
        ref s : Str = to_ptr(si.data)
        result = Str(c_str = s.c_str, count = s.count, cap = CAP_VIEW)
    case:
        UNREACHABLE()
    }
    return result
}

priv find_field_decl := func(struct_def: Expr, fname: Str) returns ref Declaration {
    switch struct_def.node_type {
    case NodeType.StructDef(ffd_sdd):
        for dd : Declaration in ffd_sdd.fields {
            if dd.name == fname {
                return dd
            }
        }
        return NULL
    case:
        return NULL
    }
}

ENUM_PAYLOAD_OFFSET : USize = 8

read_field := func(inst_data: Dynamic, dd: Declaration, field_offset: USize, ctx: Context) returns shallow Value {
    ref ptr : Dynamic = ptr_add(inst_data, field_offset.cast(U64))
    // Resolve the field's type name. For own/ref enum fields the typer
    // sometimes leaves explicit_type empty -- recover the enum name from
    // til_type when available so the enum branch below applies regardless
    // of own_type.
    mut ftype := dd.explicit_type
    if ftype.len() == 0 {
        switch dd.til_type {
        case Type.Enum(ename):
            ftype = ename
        case:
        }
    }
    mut is_enum_field := false
    ref nd_for_enum_check : Expr = field_nested_def(dd, ctx)
    if nd_for_enum_check.is_null().not() {
        if nd_for_enum_check.node_type.is(NodeType.EnumDef) {
            is_enum_field = true
        }
    }
    if dd.til_type.is(Type.Enum) { is_enum_field = true }
    if decl_is_funcsig(dd, ctx) {
        ref stored_callable : Dynamic = deref(ptr)
        return callable_storage_read(stored_callable)
    }
    if dd.own_type.is(OwnType.Own).and(is_enum_field.not()) {
        ref nd_own : Expr = field_nested_def(dd, ctx)
        if nd_own.is_null().not() {
            ref owned : Dynamic = deref(ptr)
            return make_struct_value(ftype, owned, true, ctx)
        }
        ref owned2 : Dynamic = deref(ptr)
        // Reading an own field yields a borrowed view: the struct still
        // owns the storage. Classifying it as Value.Dynamic would let
        // free(own x) / overwrite delete the struct's field. Use Ref.
        return Value.Ref(owned2)
    }
    if dd.own_type.is(OwnType.Ref).and(is_enum_field.not()) {
        if deref(ptr).is_null() { return Value.Ref(NULL) }
        ref nd_ref : Expr = field_nested_def(dd, ctx)
        if nd_ref.is_null().not() {
            ref rp : Dynamic = deref(ptr)
            return make_struct_value(ftype, rp, true, ctx)
        }
        ref rp2 : Dynamic = deref(ptr)
        return Value.Ref(rp2)
    }
    if ftype == "I64" { ref v : I64 = ptr; return Value.Int(v) }
    if ftype == "U8" { ref v : U8 = ptr; return Value.Byte(v) }
    if ftype == "I8" { ref v : I8 = ptr; return Value.Sbyte(v) }
    if ftype == "I16" { ref v : I16 = ptr; return Value.Short(v) }
    if ftype == "U16" { ref v : U16 = ptr; return Value.Ushort(v) }
    if ftype == "I32" { ref v : I32 = ptr; return Value.Int32(v) }
    if ftype == "U32" { ref v : U32 = ptr; return Value.Uint32(v) }
    if ftype == "U64" { ref v : U64 = ptr; return Value.Uint64(v) }
    if ftype == "USize" { ref v : U32 = ptr; return Value.Uint32(v) }
    if ftype == "UPtr" {
        ref uptr_name : Str = resolve_type_alias(ctx.scope, "UPtr")
        if uptr_name == "U32" { ref v : U32 = ptr; return Value.Uint32(v) }
        ref v : U64 = ptr
        return Value.Uint64(v)
    }
    if ftype == "F32" { ref v : F32 = ptr; return Value.Float(v) }
    if ftype == "Bool" { ref v : Bool = ptr; return Value.Boolean(v) }
    // Enum field
    ref edef_lookup : Expr = lookup_interp_type_def(ftype, ctx)
    if edef_lookup.is_null().not() {
        if edef_lookup.node_type.is(NodeType.EnumDef) {
            ref edef : Expr = edef_lookup
            if enum_has_payloads(edef) {
                total_size : USize = ctx_total_size(ftype, ctx)
                if dd.own_type.is(OwnType.Own).or(dd.own_type.is(OwnType.Ref)) {
                    ref ei : EnumInstance = deref(ptr)
                    if ei.is_null() { return val_enum_simple(ftype, 0, total_size, ctx) }
                    return make_enum_value(ei.enum_name(), to_ptr(ei.data), total_size, true, ei.is_str, ctx)
                }
                ref vtag : I32 = ptr
                return make_enum_value(ftype, to_ptr(ptr), total_size, true, enum_variant_is_str(ftype, vtag, ctx), ctx)
            }
            return read_enum_tag_value(ptr, edef)
        }
    }
    // Inline struct
    ref sdef3 : Expr = lookup_interp_type_def(ftype, ctx)
    if sdef3.is_null().not() {
        if sdef3.node_type.is(NodeType.StructDef) {
            return make_struct_value(ftype, ptr, true, ctx)
        }
    }
    // FuncSig-typed field or fallback -- re-read ptr since ownership may have transferred
    ref ptr2 : Dynamic = ptr_add(inst_data, field_offset.cast(U64))
    if ftype.len() > 0 {
        ref stored : Dynamic = deref(ptr2)
        if stored.is_null().not() { return Value.Func(stored) }
    }
    // Fallback
    ref ptr3 : Dynamic = ptr_add(inst_data, field_offset.cast(U64))
    ref fi : I64 = ptr3
    return Value.Int(fi)
}

priv free_owned_struct_slot := func(ptr: Dynamic, struct_name: Str, ctx: Context) {
    ref old_owned_ref : Dynamic = deref(ptr)
    if old_owned_ref.is_null() { return }
    old_owned : Dynamic = old_owned_ref
    // #286 Stage 2: deep-free the slot's CONTENTS through the canonical
    // heap_drop (Str c_str special case / struct_deep_free), then free the
    // owning block. Was an inline duplicate of heap_drop's Str/else split.
    heap_drop(struct_name, old_owned, ctx)
    EvalHeap.heap_free(own old_owned)
}

priv write_field := func(mut inst_data: Dynamic, dd: Declaration, field_offset: USize, field_size: USize, val: Value, ctx: Context) {
    ref ptr : Dynamic = ptr_add(inst_data, field_offset.cast(U64))
    fsz := field_size
    // Enum-typed fields use the same heap-EnumInstance encoding regardless
    // of own_type; let the unified switch below allocate the heap instance.
    mut is_enum_field := false
    ref wf_nested : Expr = field_nested_def(dd, ctx)
    if wf_nested.is_null().not() {
        if wf_nested.node_type.is(NodeType.EnumDef) {
            is_enum_field = true
        }
    }
    if dd.til_type.is(Type.Enum) { is_enum_field = true }
    if val.is(Value.Enum) { is_enum_field = true }
    if decl_is_funcsig(dd, ctx) {
        ref old_callable : Dynamic = deref(ptr)
        if old_callable.is_null().not() { callable_storage_free(old_callable) }
        switch val {
        case Value.Func(fv):
            write_ptr(ptr, deref(fv))
        case Value.Closure:
            write_ptr(ptr, callable_box_new(val))
            free_temp_arg_value(val)
        case Value.Ref(pv):
            ref stored_ref : Dynamic = deref(pv)
            if dd.own_type.is(OwnType.Own) { write_ptr(ptr, callable_storage_clone(stored_ref)) }
            else { write_ptr(ptr, stored_ref) }
        case Value.Dynamic(pv):
            ref stored_dyn : Dynamic = deref(pv)
            if dd.own_type.is(OwnType.Own) { write_ptr(ptr, callable_storage_clone(stored_dyn)) }
            else { write_ptr(ptr, stored_dyn) }
        case: UNREACHABLE()
        }
        return
    }
    if dd.own_type.is(OwnType.Own).and(is_enum_field.not()) {
        ref owned_def : Expr = field_nested_def(dd, ctx)
        switch val {
        case Value.Struct:
            // OWN field stores a pointer to a struct payload the field OWNS.
            // Deep-clone val's data so the field has an independent buffer:
            // the caller deletes `val` after this call, and a bare
            // write_ptr(ptr, si.data) would leave the field pointing at the
            // freed buffer (worked only while deletes were no-ops).
            mut cloned := val.clone()
            switch cloned {
            case Value.Struct(csi):
                if owned_def.is_null().not() {
                    ref owned_struct_name : Str = stable_type_name(dd.explicit_type, ctx)
                    free_owned_struct_slot(ptr, owned_struct_name, ctx)
                }
                write_ptr(ptr, csi.data)
                csi.data = NULL
            case:
            }
        case Value.Ref(pv):
            if owned_def.is_null().not() {
                ref owned_struct_name2 : Str = stable_type_name(dd.explicit_type, ctx)
                free_owned_struct_slot(ptr, owned_struct_name2, ctx)
            }
            write_ptr(ptr, deref(pv))
        case Value.Dynamic(pv):
            if owned_def.is_null().not() {
                ref owned_struct_name3 : Str = stable_type_name(dd.explicit_type, ctx)
                free_owned_struct_slot(ptr, owned_struct_name3, ctx)
            }
            write_ptr(ptr, deref(pv))
        case Value.Func(fv):
            if owned_def.is_null().not() {
                ref owned_struct_name4 : Str = stable_type_name(dd.explicit_type, ctx)
                free_owned_struct_slot(ptr, owned_struct_name4, ctx)
            }
            write_ptr(ptr, deref(fv))
        case:
            UNREACHABLE()
        }
        return
    }
    if dd.own_type.is(OwnType.Ref).and(is_enum_field.not()) {
        switch val {
        case Value.Ref(pv):
            write_ptr(ptr, deref(pv))
        case Value.Dynamic(pv):
            write_ptr(ptr, deref(pv))
        case Value.Struct(si):
            write_ptr(ptr, si.data)
        case:
            write_ptr(ptr, NULL)
        }
        return
    }
    switch val {
    case Value.Int(v):     memcpy(ptr, v, fsz.cast(U64))
    case Value.Byte(v):    memcpy(ptr, v, fsz.cast(U64))
    case Value.Sbyte(v):   memcpy(ptr, v, fsz.cast(U64))
    case Value.Short(v):   memcpy(ptr, v, fsz.cast(U64))
    case Value.Ushort(v):  memcpy(ptr, v, fsz.cast(U64))
    case Value.Int32(v):   memcpy(ptr, v, fsz.cast(U64))
    case Value.Uint32(v):  memcpy(ptr, v, fsz.cast(U64))
    case Value.Uint64(v):  memcpy(ptr, v, fsz.cast(U64))
    case Value.Float(v):   memcpy(ptr, v, fsz.cast(U64))
    case Value.Boolean(v): memcpy(ptr, v, fsz.cast(U64))
    case Value.Struct:
        // Always deep-copy into the inline (Shallow) field: the caller owns
        // `val` and deletes it after this call, so the field must own an
        // independent copy of any nested heap (notably a Str payload's
        // c_str). Cloning then copying the clone's struct bytes + freeing the
        // clone's wrapper leaves the fresh c_str owned by the field.
        mut cloned := val.clone()
        switch cloned {
        case Value.Struct(csi):
            // Reclaim the previous inline field's nested heap before
            // overwriting. A reassignment over an inline (Shallow) struct field
            // -- e.g. DynHashMap's `m.keys = DynVec.new_type_name(...)` replacing
            // the `DynVec.new(Dynamic)` default written at construction -- would
            // otherwise orphan the old field's buffers (the `own` field case
            // above frees its old slot; this one did not). Cloned first so a
            // self-assign `s.f = s.f` reads val before the old is freed;
            // struct_deep_free reads ctx.struct_layouts (AST-independent) and
            // no-ops on the zeroed field of the first write at construction.
            ref old_field_name : Str = stable_type_name(dd.explicit_type, ctx)
            struct_deep_free(old_field_name, ptr, ctx)
            memcpy(ptr, csi.data, fsz.cast(U64))
            free(own csi.data)
            csi.data = NULL
        case:
        }
    case Value.Enum(ei):
        mut total : USize = ei.data_size
        if total < 8 { total = 8 }
        if dd.own_type.is(OwnType.Own).or(dd.own_type.is(OwnType.Ref)) {
            heap_ei : Dynamic = EvalHeap.heap_alloc(EnumInstance.size())
            memcpy(heap_ei, ei, EnumInstance.size().cast(U64))
            // Deep-copy the data buffer
            new_data : Dynamic = EvalHeap.heap_alloc(total)
            memcpy(new_data, ei.data, total.cast(U64))
            // Write data pointer into the heap EnumInstance. After dropping the
            // dead enum_def field, EnumInstance is { enum_name(0..8),
            // data(8..16), data_size(16..) } so the data slot is at offset 8.
            write_ptr(ptr_add(heap_ei, 8), new_data)
            write_ptr(ptr, heap_ei)
        } else {
            memcpy(ptr, ei.data, total.cast(U64))
        }
    case Value.Ref(pv):     write_ptr(ptr, deref(pv))
    case Value.Dynamic(pv): write_ptr(ptr, deref(pv))
    case Value.Func(fv):    write_ptr(ptr, deref(fv))
    case:
    }
}

priv interpret_register_defs := func(mut global: Scope, prog: Expr) {
    for stmt : Expr in prog.children {
        if stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0)) {
            ref decl_value : Expr = stmt.children[0]
            if decl_value.node_type.is(NodeType.FuncDef)
            .or(decl_value.node_type.is(NodeType.StructDef))
            .or(decl_value.node_type.is(NodeType.EnumDef)) {
                switch stmt.node_type {
                case NodeType.Decl(dd):
                    val := val_none()
                    memcpy(val, 9, 4)
                    write_ptr(ptr_add(val, 8), stmt.children[0])
                    scope_set_owned(global, dd.name, val)
                case:
                }
            }
        }
    }
}

priv interpret_register_aliases := func(mut global: Scope, prog: Expr) {
    for stmt : Expr in prog.children {
        if stmt.node_type.is(NodeType.Decl).not() { }
        else if stmt.expr_til_type().is(Type.None).not() { }
        else if stmt.children.len() == 0 { }
        else {
            switch stmt.children[0].node_type {
            case NodeType.Ident(rhs_ident):
                ref src : Cell = scope_get(global, rhs_ident.ident_name())
                if src.is_null().not() {
                    switch src.val {
                    case Value.Func(fptr):
                        ref sdef : Expr = deref(fptr)
                        if sdef.node_type.is(NodeType.StructDef).or(sdef.node_type.is(NodeType.EnumDef)) {
                            switch stmt.node_type {
                            case NodeType.Decl(dd):
                                val := val_none()
                                memcpy(val, 9, 4)
                                write_ptr(ptr_add(val, 8), sdef)
                                scope_set_owned(global, dd.name, val)
                            case:
                            }
                        }
                    case:
                    }
                }
            case:
            }
        }
    }
}

priv interpret_copy_alias_ns := func(prog: Expr, global: Scope, ctx: Context) {
    for stmt : Expr in prog.children {
        if stmt.node_type.is(NodeType.Decl).not() { }
        else if stmt.expr_til_type().is(Type.None).not() { }
        else if stmt.children.len() == 0 { }
        else {
            switch stmt.children[0].node_type {
            case NodeType.Ident(rhs_ident):
                switch stmt.node_type {
                case NodeType.Decl(dd):
                    ref tc : Cell = scope_get(global, rhs_ident.ident_name())
                    if tc.is_null().not() {
                        switch tc.val {
                        case Value.Func(fptr):
                            ref sdef : Expr = deref(fptr)
                            if sdef.node_type.is(NodeType.StructDef).or(sdef.node_type.is(NodeType.EnumDef)) {
                                ref ica_ns : Vec(Declaration) = def_ns_decls(sdef)
                                for d_j : Declaration in ica_ns {
                                    ref nsd : Declaration = d_j
                                    ref v : Value = ns_get(rhs_ident.ident_name(), nsd.name, ctx)
                                    if v.is_null().not() { ns_set(dd.name, nsd.name, v, ctx) }
                                }
                            }
                        case:
                        }
                    }
                case:
                }
            case:
            }
        }
    }
}

interp_session_start := func(mut session: InterpSession, user_argv: Vec(Str)) {
    session.global = scope_new_boxed(NULL)
    session.core_evaluated = false
    session.user_argc = 0
    if user_argv.is_null().not() { session.user_argc = user_argv.len() }
}

interp_session_free := func(mut session: InterpSession) {
    if session.global.is_null().not() { scope_free(own session.global) }
    session.global = NULL
    session.core_evaluated = false
    session.user_argc = 0
}

priv interp_reset_control_flow := func(mut ctx: Context) {
    if ctx.has_return {
        free_temp_arg_value(ctx.return_value)
        memcpy(ctx.return_value, val_none(), Value.size().cast(U64))
    }
    ctx.has_return = false
    ctx.has_break = false
    ctx.has_continue = false
    ctx.constfold_aborted = false
}

interp_session_prepare_context := proc(session: InterpSession, mut lp: LoadedProgram, fwd_path: Str) returns I32 {
    // Ensure builtin dispatch table is initialized deterministically.
    if lp.ctx.dispatch_inited.not() { dispatch_init(lp.ctx) }

    // FFI init: reset, load the shared lib, then scan per-file ASTs.
    ffi_reset(lp.ctx)
    empty := Expr.new(NodeType.Body, 0, 0)
    ffi_rc := ffi_init(empty, fwd_path, lp.link_c_paths, lp.ext_c_path, lp.link_flags, lp.ctx)
    if ffi_rc.eq(0).not() { return ffi_rc }
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            ffi_init_struct_defs_append(iu.ast, lp.ctx)
            ffi_init_scan_program(iu.ast, lp.ctx)
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        ffi_init_struct_defs_append(iu.ast, lp.ctx)
        ffi_init_scan_program(iu.ast, lp.ctx)
    }

    // Refresh definition pointers and namespace state against this turn's AST.
    if lp.skip_core.not() {
        for u2 : ProgramUnit in lp.core_units {
            ref iu2 : ImportUnit = lp.ctx.imported[u2.path]
            interpret_register_defs(session.global, iu2.ast)
        }
    }
    for u3 : ProgramUnit in lp.units {
        ref iu3 : ImportUnit = lp.ctx.imported[u3.path]
        interpret_register_defs(session.global, iu3.ast)
    }

    if lp.skip_core.not() {
        for u4 : ProgramUnit in lp.core_units {
            ref iu4 : ImportUnit = lp.ctx.imported[u4.path]
            interpret_register_aliases(session.global, iu4.ast)
        }
    }
    for u5 : ProgramUnit in lp.units {
        ref iu5 : ImportUnit = lp.ctx.imported[u5.path]
        interpret_register_aliases(session.global, iu5.ast)
    }

    if lp.skip_core.not() {
        for u6 : ProgramUnit in lp.core_units {
            ref iu6 : ImportUnit = lp.ctx.imported[u6.path]
            interpreter_init_ns(lp.ctx, session.global, iu6.ast)
        }
    }
    for u7 : ProgramUnit in lp.units {
        ref iu7 : ImportUnit = lp.ctx.imported[u7.path]
        interpreter_init_ns(lp.ctx, session.global, iu7.ast)
    }

    if lp.skip_core.not() {
        for u8 : ProgramUnit in lp.core_units {
            ref iu8 : ImportUnit = lp.ctx.imported[u8.path]
            interpret_copy_alias_ns(iu8.ast, session.global, lp.ctx)
        }
    }
    for u9 : ProgramUnit in lp.units {
        ref iu9 : ImportUnit = lp.ctx.imported[u9.path]
        interpret_copy_alias_ns(iu9.ast, session.global, lp.ctx)
    }
    return 0
}

interp_session_finish_context := proc(mut lp: LoadedProgram) {
    interpreter_free_ns(lp.ctx)
    ffi_cleanup(lp.ctx)
}

interp_session_eval_core_once := proc(mut session: InterpSession, mut lp: LoadedProgram) {
    if session.core_evaluated { return }
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            context_enter_file(lp.ctx, u.path)
            eval_body(session.global, iu.ast, lp.ctx)
        }
    }
    session.core_evaluated = true
    interp_reset_control_flow(lp.ctx)
}

interp_session_eval_user_units := proc(session: InterpSession, mut lp: LoadedProgram) {
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        context_enter_file(lp.ctx, u.path)
        eval_body(session.global, iu.ast, lp.ctx)
    }
    interp_reset_control_flow(lp.ctx)
}

priv interp_body_slice := func(mut program: Expr, start_idx: USize, count: USize, mut out: Expr) {
    free(own out.children.data)
    out.children.data = ptr_add(program.children.data, start_idx.mul(Expr.size()).cast(U64))
    out.children.count = count
    out.children.cap = count
}

priv interp_body_slice_clear := func(mut body: Expr) {
    body.children.data = NULL
    body.children.count = 0
    body.children.cap = 0
}

priv interp_eval_program_slice := proc(session: InterpSession, mut lp: LoadedProgram, mut program: Expr, start_idx: USize, count: USize) {
    if count == 0 { return }
    mut body := Expr.new(NodeType.Body, 0, 0)
    interp_body_slice(program, start_idx, count, body)
    eval_body(session.global, body, lp.ctx)
    interp_body_slice_clear(body)
}

priv interp_first_stmt_at_line := func(program: Expr, min_line: U32) returns USize {
    mut i : USize = 0
    while i < program.children.len() {
        if program.children[i].line >= min_line { return i }
        i++
    }
    return program.children.len()
}

priv interp_eval_exact_line := proc(session: InterpSession, mut lp: LoadedProgram, mut program: Expr, line: U32) {
    mut start : USize = program.children.len()
    mut count : USize = 0
    mut i : USize = 0
    while i < program.children.len() {
        if program.children[i].line == line {
            if count == 0 { start = i }
            count++
        } else if count > 0 {
            break
        }
        i++
    }
    if count == 0 { panic("REPL doc init line missing") }
    interp_eval_program_slice(session, lp, program, start, count)
}

interp_session_eval_current_root := proc(session: InterpSession, mut lp: LoadedProgram, block_start_line: U32, eval_doc_line: Bool) {
    ref root : ProgramUnit = lp.units[lp.units.len() - 1]
    ref iu : ImportUnit = lp.ctx.imported[root.path]
    if eval_doc_line { interp_eval_exact_line(session, lp, iu.ast, 2) }
    start_idx := interp_first_stmt_at_line(iu.ast, block_start_line)
    interp_eval_program_slice(session, lp, iu.ast, start_idx, iu.ast.children.len().sub(start_idx))
    interp_reset_control_flow(lp.ctx)
}

// Per-file interpreter entrypoint (rstil-style): uses the canonical per-file
// ASTs stored in lp.ctx.imported, but preserves the original overall
// registration/eval ordering.
priv interpret_units := proc(mut lp: LoadedProgram, user_argv: Vec(Str), fwd_path: Str) returns I32 {
    // Ensure codegen_lp() is available throughout interpretation so
    // interpreter helpers can read shared Context fields (#177/#178).
    ref mut c : Context = lp.ctx
    mut session := InterpSession()
    interp_session_start(session, user_argv)
    start_rc := interp_session_prepare_context(session, lp, fwd_path)
    if start_rc.eq(0).not() {
        interp_session_free(session)
        return start_rc
    }
    interp_session_eval_core_once(session, lp)
    interp_session_eval_user_units(session, lp)

    // Run tests (scan per-file user ASTs).  Picks up both top-level
    // test() decls and test() decls inside struct/enum namespaces so
    // tests can live next to the code they exercise.
    if lp.run_tests {
        mut test_count : I32 = 0
        mut pass_count : I32 = 0
        for u : ProgramUnit in lp.units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            for stmt : Expr in iu.ast.children {
                if is_func_decl(stmt) {
                    switch stmt.children[0].node_type {
                    case NodeType.FuncDef(fd):
                        if fd.func_type.is(FuncType.Test) {
                            switch stmt.node_type {
                            case NodeType.Decl(dd):
                                test_count++
                                test_scope := scope_new(session.global)
                                context_enter_file(lp.ctx, u.path)
                                eval_body(test_scope, stmt.children[0].children[0], lp.ctx)
                                reclone_return(c)
                                scope_free(own test_scope)
                                pass_count++
                                eprint_single("  pass: ")
                                eprint_single(dd.name)
                                eprint_single("\n")
                            case:
                            }
                        }
                    case:
                    }
                }
                if stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0)) {
                    ref rhs : Expr = stmt.children[0]
                    if rhs.node_type.is(NodeType.StructDef).or(rhs.node_type.is(NodeType.EnumDef)) {
                        switch stmt.node_type {
                        case NodeType.Decl(sdd):
                            ref ns : Vec(Declaration) = def_ns_decls(rhs)
                            for nsd : Declaration in ns {
                                ref nsfdef : Expr = nsd.default_value
                                if nsfdef.is_null() { continue }
                                switch nsfdef.node_type {
                                case NodeType.FuncDef(nsfd):
                                    if nsfd.func_type.is(FuncType.Test).not() { continue }
                                    test_count++
                                    test_scope := scope_new(session.global)
                                    context_enter_file(lp.ctx, u.path)
                                    eval_body(test_scope, nsfdef.children[0], lp.ctx)
                                    reclone_return(c)
                                    scope_free(own test_scope)
                                    pass_count++
                                    eprint_single("  pass: ")
                                    eprint_single(sdd.name)
                                    eprint_single(".")
                                    eprint_single(nsd.name)
                                    eprint_single("\n")
                                case:
                                }
                            }
                        case:
                        }
                    }
                }
            }
        }
        if test_count == 0 {
            eprint_single("no tests found\n")
        } else {
            eprint_single(pass_count.to_str())
            eprint_single("/")
            eprint_single(test_count.to_str())
            eprint_single(" tests passed\n")
        }
        if pass_count.eq(test_count).not() { exit(1) }
    }

    // In needs_main mode, call main() (same logic as interpret()).  When
    // run_tests is set, tests are the entry points -- skip main() so a
    // mode cli/gui file with inline test() decls runs only its tests.
    if lp.run_tests.not() { if lp.cur_mode.is_null().not() { if lp.cur_mode.needs_main {
        ref main_cell : Cell = scope_get(session.global, "main")
        if main_cell.is_null().or(main_cell.val.is(Value.Func).not()) {
            eprint_single(lp.path)
            eprint_single(": error: this mode requires a 'main' proc\n")
            exit(1)
        }
        switch main_cell.val {
        case Value.Func(fptr):
            ref func_def : Expr = deref(fptr)
            switch func_def.node_type {
            case NodeType.FuncDef(fd):
                nparam := fd.params.len()
                vi := fd.variadic_index
                ref body : Expr = func_def.children[0]
                main_scope := scope_new(session.global)

                if nparam > 0 {
                    mut fixed := nparam
                    if vi >= 0 {
                        fixed = nparam - 1
                        if session.user_argc < fixed {
                            eprint_single("error: main expects at least ")
                            eprint_single(fixed.to_str())
                            eprint_single(" argument(s), got ")
                            eprint_single(session.user_argc.to_str())
                            eprint_single("\n")
                            exit(1)
                        }
                    } else {
                        if session.user_argc.eq(nparam).not() {
                            eprint_single("error: main expects ")
                            eprint_single(nparam.to_str())
                            eprint_single(" argument(s), got ")
                            eprint_single(session.user_argc.to_str())
                            eprint_single("\n")
                            exit(1)
                        }
                    }
                    mut argi : I32 = 0
                    for pi in 0..nparam {
                        ref param : Declaration = fd.params[pi]
                        if pi.to_i64() == vi.cast(I64) {
                            va_count := session.user_argc - fixed
                            arr := build_argv_array(user_argv, argi.cast(U32), va_count, fd.params[vi.to_usize()].explicit_type, lp.ctx)
                            scope_set_owned(main_scope, param.name, arr)
                            argi = argi + va_count.cast(I32)
                        } else {
                            v := parse_cli_arg(user_argv[argi.to_usize()], param.explicit_type, lp.ctx)
                            scope_set_owned(main_scope, param.name, v)
                            argi++
                        }
                    }
                } else if session.user_argc > 0 {
                    eprint_single("error: main expects no arguments, got ")
                    eprint_single(session.user_argc.to_str())
                    eprint_single("\n")
                    exit(1)
                }

                eval_body(main_scope, body, lp.ctx)
                scope_free(own main_scope)
            case:
                UNREACHABLE()
            }
        case:
            UNREACHABLE()
        }
    } } }

    interp_session_finish_context(lp)
    interp_session_free(session)
    return 0
}

cmd_interpret := proc(lp: LoadedProgram, user_argv: Vec(Str)) returns I32 {
    mut interpret_fwd_path := ""
    mut result : I32 = 0
    if lp.link_c_paths.len() > 0 {
        system_cmd("mkdir -p tmp")
        interpret_fwd_path = format("tmp/ffi_", clock_ms().to_str(), "_forward.h")
        result = build_forward_header_lp(interpret_fwd_path, lp)
    }
    if result == 0 {
        result = interpret_units(lp, user_argv, interpret_fwd_path)
    }
    return result
}

// --- FFI dispatch and ext-function call handling (moved here from
// src/self/dispatch.til). Routes interpreter calls to builtins
// (the dispatch_map) and to libffi-backed ext_func/ext_proc calls. ---

priv ExtStr := struct {
    ref data : U8 = NULL
    count : USize = 0
    cap : USize = 0
}

FFIEntry := struct {
    ref fn : U8 = NULL
    ref return_type : Str = NULL
    nparam : USize = 0
    ref param_shallows : U8 = NULL
    return_is_shallow := false
    return_is_ref := false
    ref cif : ffi_cif = NULL
    ref arg_types : Dynamic = NULL
}

ExprPtrBox := struct {
    ref ptr : Expr = NULL
}

FFITypePtrBox := struct {
    ref ptr : ffi_type = NULL
}

// Reset all FFI state so a fresh scan can run.
ffi_reset := proc(ctx: Context) {
    if ctx.ffi_loaded {
        ffi_cleanup(ctx)
        ctx.ffi_map_inited = false
    } else if ctx.ffi_map_inited {
        // Reset to a fresh empty map (instead of deleting it) so the
        // Context that owns ffi_map only ever auto-deletes a live map.
        ctx.ffi_map = Map(Str, FFIEntry).new()
        ctx.ffi_map_inited = false
    }
    // Always ensure struct defs map exists.
    ctx.ffi_struct_defs = Map(Str, ExprPtrBox).new()
}

// libffi exposes its primitive ffi_type descriptors as global symbols
// (ffi_type_uint8, ffi_type_sint64, ...). Resolve one by name into a
// ref. Replaces a former family of ten near-identical
// ffi_type_<t>_ref() one-liner accessors.
priv ffi_type_ref := func(name: Str) returns ref ffi_type {
    return to_ptr(ffi_global_symbol(name))
}

priv ffi_alloc_cif := func() returns Dynamic { return malloc(ffi_cif.size().cast(U64)) }

priv ffi_cif_rtype_is_struct := func(cif: ffi_cif) returns Bool {
    expect(cif.rtype.is_null().not(), "cif.rtype is null")
    ref rt : ffi_type = cif.rtype
    return rt.type == FFI_TYPE_STRUCT.to_i16()
}

// These four are side-effecting (dlopen mutates the loader, dlerror clears
// pending state, stderr_print writes) so they MUST be ext_proc, not ext_func:
// the constfolder folds ext_funcs (issue #136) but never procs, and folding a
// side-effecting call runs the effect at COMPILE time. When ffi_init_user_so's
// `stderr_print(format("error: dlopen failed: ", ffi_last_error(), "\n"))` was
// declared with ext_funcs the constfolder evaluated it during a normal build --
// printing a bogus "error: dlopen failed:" and then baking the empty
// ffi_last_error() in, dropping the real runtime diagnostic (issue #283).
// ffi_user_symbol/ffi_global_symbol stay ext_func: their `ref U8` return is
// already never folded (try_eval_call bails on ref returns).
ffi_load_global_lib := ext_proc(soname: Str) returns shallow Bool {}
ffi_open_user_so := ext_proc(path: Str) returns shallow Bool {}
ffi_close_user_so := ext_proc() {}
ffi_user_symbol := ext_func(name: Str) returns ref U8 {}
ffi_global_symbol := ext_func(name: Str) returns ref U8 {}
ffi_last_error := ext_proc() returns Str {}
stderr_print := ext_proc(msg: Str) returns shallow I32 {}
unlink_path := ext_proc(path: Str) {}
process_id := ext_proc() returns shallow I32 {}
// ext_proc, NOT ext_func: this reads a build-time property of the RUNNING
// binary, so it must be evaluated at runtime. As an ext_func the constfolder
// folds it -- and bin/til_asan is built by the non-ASAN bin/til, so the fold
// bakes in `false` and the ASAN flag never reaches the FFI compile (#299).
til_built_with_asan := ext_proc() returns shallow Bool {}

priv ffi_dlsym := func(name: Str) returns ref U8 {
    ref fn : U8 = ffi_user_symbol(name)
    if fn.is_null().not() {
        return fn
    }
    return ffi_global_symbol(name)
}

priv ffi_init_link_libs := proc(link_flags: Str) {
    if link_flags.is_null() {
        return
    }
    mut i : USize = 0
    while i + 1 < link_flags.len() {
        if link_flags.unsafe_get(i).eq(45).and(link_flags.unsafe_get(i + 1).eq(108)) {
            i = i + 2
            start := i
            while i < link_flags.len() {
                if link_flags.unsafe_get(i) == 32 {
                    break
                }
                i++
            }
            if i > start {
                lib := link_flags.substr(start, i - start)
                soname := format("lib", lib, ".so")
                ffi_load_global_lib(soname)
            }
        } else {
            i++
        }
    }
}

priv ffi_init_user_so := proc(fwd_path: Str, user_c_path: Str, ext_c_path: Str, link_flags: Str, mut so_path_out: Str) returns I32 {
    so_path_out = Str(c_str = NULL, count = 0, cap = 0)
    expect(user_c_path.is_null().not(), "user_c_path is null")
    if user_c_path.len() == 0 { return 0 }

    dot_str := "."
    slash := ext_c_path.rfind("/")
    mut ext_dir := dot_str
    if slash >= 0 {
        ext_dir = ext_c_path.substr(0, slash.to_usize())
    }

    so_path_out = format("tmp/ffi_", process_id().to_str(), ".so")
    system_cmd("mkdir -p tmp")

    mut lf := ""
    if link_flags.is_null().not() {
        lf = link_flags
    }
    // #299: match the interpreter's own sanitizer. Under bin/til_asan the user
    // .so must be ASAN-instrumented too, so its libc allocator IS the ASAN
    // allocator -- otherwise an interpreter-side calloc that libffi routes to
    // this .so's (non-ASAN) calloc returns brk-heap memory that the
    // interpreter's ASAN free() then rejects as a bad-free.
    mut san := ""
    if til_built_with_asan() { san = " -fsanitize=address -fno-omit-frame-pointer" }
    cmd := format("cc -Wall -Wextra -shared -fPIC", san, " -I", ext_dir,
        " -include ", fwd_path,
        " -o ", so_path_out,
        " ", user_c_path, lf)
    rc := system_cmd(cmd)
    if rc != 0 {
        stderr_print(format("error: failed to compile FFI library '", user_c_path, "'\n"))
        return 1
    }
    if ffi_open_user_so(so_path_out).not() {
        stderr_print(format("error: dlopen failed for '", so_path_out, "': ", ffi_last_error(), "\n"))
        return 1
    }
    return 0
}

priv ffi_init_struct_defs := func(program: Expr, ctx: Context) {
    ctx.ffi_struct_defs = Map(Str, ExprPtrBox).new()
    ffi_init_struct_defs_append(program, ctx)
}

// Append struct defs found in program into ctx.ffi_struct_defs (does not reset).
ffi_init_struct_defs_append := func(program: Expr, ctx: Context) {
    for stmt : Expr in program.children {
        if stmt.node_type.is(NodeType.Decl).not().or(stmt.children.len().eq(0)) {
            continue
        }
        ref sdef : Expr = stmt.children[0]
        if sdef.node_type.is(NodeType.StructDef).not() {
            continue
        }
        switch stmt.node_type {
        case NodeType.Decl(dd):
            key := Str(c_str = dd.name.c_str, count = dd.name.count, cap = CAP_VIEW)
            box := ExprPtrBox(ptr = sdef)
            ctx.ffi_struct_defs.set(key, own box)
        case:
        }
    }
}

priv value_to_u64 := func(v: Value) returns U64 {
    switch v {
    case Value.Int(x):     return x.cast(U64)
    case Value.Byte(x):    return x.cast(U64)
    case Value.Sbyte(x):   return x.to_u64()
    case Value.Short(x):   return x.to_u64()
    case Value.Ushort(x):  return x.cast(U64)
    case Value.Int32(x):   return x.to_u64()
    case Value.Uint32(x):  return x.cast(U64)
    case Value.Uint64(x):  return x.clone()
    case Value.Boolean(x):
        if x { return 1 }
        return 0
    case: return 0
    }
}

priv uptr_ffi_type := func(ctx: Context) returns ref ffi_type {
    ref uptr_name : Str = resolve_type_alias(ctx.scope, "UPtr")
    if uptr_name == "U32" { return ffi_type_ref("ffi_type_uint32") }
    return ffi_type_ref("ffi_type_uint64")
}

priv usize_ffi_type := func(ctx: Context) returns ref ffi_type {
    ref usize_name : Str = resolve_type_alias(ctx.scope, "USize")
    if usize_name == "U32" { return ffi_type_ref("ffi_type_uint32") }
    return ffi_type_ref("ffi_type_uint64")
}

priv value_to_f32 := func(v: Value) returns F32 {
    switch v {
    case Value.Int(x):     return x.to_f32()
    case Value.Byte(x):    return x.to_f32()
    case Value.Sbyte(x):   return x.cast(I64).to_f32()
    case Value.Short(x):   return x.to_f32()
    case Value.Ushort(x):  return x.to_f32()
    case Value.Int32(x):   return x.to_f32()
    case Value.Uint32(x):  return x.to_f32()
    case Value.Uint64(x):  return x.to_f32()
    case Value.Float(x):   return x.clone()
    case Value.Boolean(x):
        if x { return 1 }
        return 0
    case: return 0
    }
}

// Best-effort variant name for a Value, used in diagnostics. Value.to_str
// only handles a few variants; this covers the rest. Returns "?" if the
// tag is unrecognised (shouldn't happen, but the diagnostic shouldn't
// itself crash).
priv value_variant_name := func(v: Value) returns Str {
    if v.is(Value.None)    { return "None" }
    if v.is(Value.Int)     { return "Int" }
    if v.is(Value.Byte)    { return "Byte" }
    if v.is(Value.Short)   { return "Short" }
    if v.is(Value.Int32)   { return "Int32" }
    if v.is(Value.Uint32)  { return "Uint32" }
    if v.is(Value.Uint64)  { return "Uint64" }
    if v.is(Value.Float)   { return "Float" }
    if v.is(Value.Boolean) { return "Boolean" }
    if v.is(Value.Func)    { return "Func" }
    if v.is(Value.Struct)  { return "Struct" }
    if v.is(Value.Enum)    { return "Enum" }
    if v.is(Value.Ref)     { return "Ref" }
    if v.is(Value.Dynamic) { return "Dynamic" }
    if v.is(Value.Closure) { return "Closure" }
    return "?"
}

// Narrow an FCall arg to a Value.Boolean. Used by h_Bool_and/or/not to
// pull the (possibly Value.Ref/Value.Dynamic) arg out of eval_expr and route it
// through reinterpret_ptr_value -- the same helper ref bindings, param
// binding, and ext_dispatch_ffi use. Panics if the arg doesn't end up
// as a Bool (silently defaulting to false would mask cast/typer bugs;
// the Bool handlers are reached via FFI dispatch on top-level
// and/or/not, so the typer should only let Bool-shaped values through).
priv narrow_bool_arg := proc(s: Scope, e: Expr, ctx: Context) returns Bool {
    v := reinterpret_ptr_value(eval_expr(s, e, ctx), "Bool", s, ctx, false)
    switch v {
    case Value.Boolean(bv):
        return bv.clone()
    case:
        panic("expected Bool argument to and/or/not, got Value.", value_variant_name(v))
        return false
    }
}

priv h_Bool_and := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    av := narrow_bool_arg(s, e.children[1], ctx)
    bv := narrow_bool_arg(s, e.children[2], ctx)
    r = Value.Boolean(and(av, bv))
    return true
}

priv h_Bool_or := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    av := narrow_bool_arg(s, e.children[1], ctx)
    bv := narrow_bool_arg(s, e.children[2], ctx)
    r = Value.Boolean(or(av, bv))
    return true
}

priv h_Bool_not := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    bv := narrow_bool_arg(s, e.children[1], ctx)
    r = Value.Boolean(not(bv))
    return true
}

priv h_U8_from_i64 := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    v := eval_expr(s, e.children[1], ctx)
    switch v {
    case Value.Int(i):
        r = val_u8(i)
        return true
    case:
        UNREACHABLE()
        return false
    }
}

priv h_I16_from_i64 := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    v := eval_expr(s, e.children[1], ctx)
    switch v {
    case Value.Int(i):
        r = val_i16(i)
        return true
    case:
        UNREACHABLE()
        return false
    }
}

priv h_U16_from_i64 := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    v := eval_expr(s, e.children[1], ctx)
    switch v {
    case Value.Int(i):
        r = val_u16(i)
        return true
    case:
        UNREACHABLE()
        return false
    }
}

priv h_I32_from_i64 := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    v := eval_expr(s, e.children[1], ctx)
    switch v {
    case Value.Int(i):
        r = val_i32(i)
        return true
    case:
        UNREACHABLE()
        return false
    }
}

priv h_F32_from_i64 := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    v := eval_expr(s, e.children[1], ctx)
    switch v {
    case Value.Int(i):
        r = Value.Float(i.to_f32())
        return true
    case:
        UNREACHABLE()
        return false
    }
}

priv h_U32_from_i64 := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    v := eval_expr(s, e.children[1], ctx)
    switch v {
    case Value.Int(i):
        r = val_u32(i)
        return true
    case:
        UNREACHABLE()
        return false
    }
}

// Issue #212: integer reinterpret or same-signedness widening cast. The
// typer set this FCall's til_type to the target type T; reinterpret the
// operand's bits into the matching Value variant. value_to_u64 gives
// the raw bits; the val_* constructors mask/sign-interpret to the
// target width.
priv h_cast := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    mut v := eval_expr(s, e.children[1], ctx)
    // For non-scalar operand variants (Value.Ref from `ref c : I8 =
    // ...`, Value.Struct carrying a primitive's bits via
    // StructInstance.data, etc.) the underlying primitive bits live
    // behind a pointer. Read them through the typer-known source type
    // and rebuild the matching scalar Value variant; otherwise
    // value_to_u64 hits its default `case: return 0` and the widening
    // cast silently returns zero.
    src_tn := til_type_name_c(e.children[1].expr_til_type())
    switch v {
    case Value.Ref(p):
        if src_tn == "I8" { ref tmp : I8 = p; v = Value.Sbyte(tmp) }
        else if src_tn == "U8" { ref tmp : U8 = p; v = Value.Byte(tmp) }
        else if src_tn == "I16" { ref tmp : I16 = p; v = Value.Short(tmp) }
        else if src_tn == "U16" { ref tmp : U16 = p; v = Value.Ushort(tmp) }
        else if src_tn == "I32" { ref tmp : I32 = p; v = Value.Int32(tmp) }
        else if src_tn == "U32" { ref tmp : U32 = p; v = Value.Uint32(tmp) }
        else if src_tn == "I64" { ref tmp : I64 = p; v = Value.Int(tmp) }
        else if src_tn == "U64" { ref tmp : U64 = p; v = Value.Uint64(tmp) }
    case Value.Dynamic(p):
        if src_tn == "I8" { ref tmp : I8 = p; v = Value.Sbyte(tmp) }
        else if src_tn == "U8" { ref tmp : U8 = p; v = Value.Byte(tmp) }
        else if src_tn == "I16" { ref tmp : I16 = p; v = Value.Short(tmp) }
        else if src_tn == "U16" { ref tmp : U16 = p; v = Value.Ushort(tmp) }
        else if src_tn == "I32" { ref tmp : I32 = p; v = Value.Int32(tmp) }
        else if src_tn == "U32" { ref tmp : U32 = p; v = Value.Uint32(tmp) }
        else if src_tn == "I64" { ref tmp : I64 = p; v = Value.Int(tmp) }
        else if src_tn == "U64" { ref tmp : U64 = p; v = Value.Uint64(tmp) }
    case Value.Struct(si):
        ref p : Dynamic = si.data
        if src_tn == "I8" { ref tmp : I8 = p; v = Value.Sbyte(tmp) }
        else if src_tn == "U8" { ref tmp : U8 = p; v = Value.Byte(tmp) }
        else if src_tn == "I16" { ref tmp : I16 = p; v = Value.Short(tmp) }
        else if src_tn == "U16" { ref tmp : U16 = p; v = Value.Ushort(tmp) }
        else if src_tn == "I32" { ref tmp : I32 = p; v = Value.Int32(tmp) }
        else if src_tn == "U32" { ref tmp : U32 = p; v = Value.Uint32(tmp) }
        else if src_tn == "I64" { ref tmp : I64 = p; v = Value.Int(tmp) }
        else if src_tn == "U64" { ref tmp : U64 = p; v = Value.Uint64(tmp) }
    case:
    }
    tn := til_type_name_c(e.expr_til_type())
    // Issue #58: cast(value, FuncSig) where target is a user FuncSig
    // resolves to Type.FuncPtr ("Fn"). The runtime cast is a pointer
    // re-tag: the source slot already stores the function pointer, we
    // just need a Value.Func wrapping it. For Value.Dynamic / Value.Ref
    // sources (Vec.get on an Fn-typed Vec) the payload is the slot
    // address and the function pointer is one further deref; for
    // Value.Func source it's already the fn ptr in the payload slot.
    if (tn == "Fn").or(tn == "Body") {
        switch v {
        case Value.Func(fp):
            ref real_fp : Dynamic = deref(fp)
            r = Value.Func(real_fp)
            return true
        case Value.Closure:
            r = borrow_value(v)
            return true
        case Value.Dynamic(p):
            ref slot_addr : Dynamic = deref(p)
            r = callable_box_or_slot_read(slot_addr)
            return true
        case Value.Ref(p):
            ref slot_addr : Dynamic = deref(p)
            r = callable_box_or_slot_read(slot_addr)
            return true
        case:
        }
    }
    raw := value_to_u64(v)
    if tn == "I8"  { r = val_i8(raw.cast(I64));  return true }
    if tn == "U8"  { r = val_u8(raw.cast(I64));  return true }
    if tn == "I16" { r = val_i16(raw.cast(I64)); return true }
    if tn == "U16" { r = val_u16(raw.cast(I64)); return true }
    if tn == "I32" { r = val_i32(raw.cast(I64)); return true }
    if tn == "U32" { r = val_u32(raw.cast(I64)); return true }
    if tn == "I64" { r = Value.Int(raw.cast(I64)); return true }
    if tn == "U64" { r = Value.Uint64(raw); return true }
    UNREACHABLE()
    return false
}

priv h_print_single := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    arg := eval_expr(s, e.children[1], ctx)
    // A const-fold eval is speculative and must emit no program output: if a
    // fold candidate reaches a print (e.g. through panic's message on a
    // failure branch the comptime inputs hit), swallow it. The fold itself is
    // abandoned via the abort in h_exit and the call is left for runtime.
    if ctx.constfold_active.not() { print_single(str_view(arg)) }
    r = val_none()
    return true
}

priv h_print_flush := proc(_s: Scope, _e: Expr, mut r: Value, ctx: Context) returns Bool {
    if ctx.constfold_active.not() { print_flush() }
    r = val_none()
    return true
}

priv h_exit := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    a := eval_expr(s, e.children[1], ctx)
    // exit is the single primitive that terminates the process, so it is the
    // single interception point for the const-folder. When a fold eval reaches
    // it (panic/TODO/UNREACHABLE all route here, as does a bare exit), don't
    // kill the build: set constfold_aborted and unwind like an early return
    // (propagated through eval_body/eval_while). try_eval_call then leaves the
    // call for runtime, or reports it for a macro. No name list required.
    if ctx.constfold_active {
        ctx.constfold_aborted = true
        r = val_none()
        return true
    }
    switch a {
    case Value.Int(code):
        exit(code)
    case:
        UNREACHABLE()
    }
    r = val_none()
    return true
}

priv h_readfile := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    path := eval_expr(s, e.children[1], ctx)
    content := File.readfile(str_view(path))
    r = make_str_value(content.c_str, content.count, ctx)
    return true
}

priv h_writefile := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    path := eval_expr(s, e.children[1], ctx)
    content := eval_expr(s, e.children[2], ctx)
    File.writefile(str_view(path), str_view(content))
    r = val_none()
    return true
}

priv h_spawn_cmd := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    cmd := eval_expr(s, e.children[1], ctx)
    r = Value.Int(spawn_cmd(str_view(cmd)))
    return true
}

// Borrowed pointer-view helper: returns a ref to the storage backing a
// Value, without transferring ownership. It never frees and is never an
// ownership escape hatch -- it only produces read/write views, never
// hands off an owning pointer for deletion.
priv val_to_ptr := func(v: Value) returns ref Dynamic {
    switch v {
    case Value.Ref(p):     return p
    case Value.Dynamic(p): return p
    case Value.Int(p):     return p
    case Value.Byte(p):    return p
    case Value.Sbyte(p):   return p
    case Value.Short(p):   return p
    case Value.Ushort(p):  return p
    case Value.Int32(p):   return p
    case Value.Uint32(p):  return p
    case Value.Float(p):   return p
    case Value.Boolean(p): return p
    case Value.Struct(x):  return x.data
    case: return NULL
    }
}

priv h_dyn_has_method := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    method := eval_str_owned(s, e.children[2], ctx)
    r = Value.Boolean(ns_get(type_name, method, ctx).is_null().not())
    return true
}

priv h_dyn_fn := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    type_name_val := eval_expr(s, e.children[1], ctx)
    method_val := eval_expr(s, e.children[2], ctx)
    // str_view returns a Str that BORROWS its arg Value's c_str. Inline the
    // views into their uses (rather than binding type_name/method locals)
    // so type_name_val / method_val stay live through ns_get -- their last
    // use is now the str_view inside the call, not an earlier standalone
    // str_view stmt, so the garbager does not free them out from under the
    // borrowed views.
    ref nsv : Value = ns_get(str_view(type_name_val), str_view(method_val), ctx)
    if nsv.is_null() {
        panic("dyn_fn: unknown ", str_view(type_name_val), ".", str_view(method_val))
    }
    if nsv.is(Value.Func).not() {
        panic("dyn_fn: unknown ", str_view(type_name_val), ".", str_view(method_val))
    }
    r = nsv.clone()
    return true
}

priv h_dyn_size_of := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    sz := get_elem_size(s, type_name, e, ctx)
    r = Value.Uint32(sz)
    return true
}

// Return an owned Str Value copying `src`'s bytes. Used by the
// struct_field_* handlers: a borrowed view into the AST does not survive
// being stored into a Declaration field and pushed into a Vec (the
// header is copied but the bytes must outlive the AST borrow), so the
// introspection primitives hand back owned copies. Issue #56/#58.
priv str_to_owned_value := func(src: Str, ctx: Context) returns shallow Value {
    n := src.count
    if n == 0 {
        // Empty src: malloc(1) + make_str_value_own would adopt an owned
        // 1-byte c_str with count==0, which the count==0 teardown guard never
        // frees -> leak (enum_variant_payload_type of a payloadless variant
        // like `Nothing` hits this). Return a normalized empty (CAP_LIT, no
        // owned buffer) instead, matching make_str_value's empty case.
        return make_str_value(src.c_str, 0, ctx)
    }
    buf : Dynamic = malloc(n.add(1).cast(U64))
    memcpy(buf, src.c_str, n.cast(U64))
    ref mut term : U8 = ptr_add(buf, n.cast(U64))
    term = 0
    return make_str_value_own(buf, n, ctx)
}

// Evaluate a string-typed argument and return an OWNED Str copy of its
// bytes. The eval'd Value is a local the garbager frees at this function's
// end; a str_view into it would dangle once the caller uses it past that
// point (the str_view-outlives-source UAF). Cloning the view detaches the
// result from the source so builtins can hold a Str argument safely.
// Clone the Str payload out of a Value into an OWNED Str. `v` is a borrowed
// param, so the garbager never frees it inside this call -- the str_view
// can't dangle here (unlike a view bound to a local the garbager would free
// before the .clone()). The caller keeps `v` alive across this call (it is
// the argument), then frees it afterwards.
priv value_str_clone := func(v: Value) returns Str {
    return str_view(v).clone()
}
priv eval_str_owned := proc(s: Scope, arg: Expr, ctx: Context) returns Str {
    return value_str_clone(eval_expr(s, arg, ctx))
}

// Look up a registered struct type's AST node by name, erroring out if
// the name is unknown or not a struct. Shared by the struct_field_*
// introspection handlers (issue #56/#58).
priv interp_lookup_struct := proc(s: Scope, e: Expr, type_name: Str, who: Str, ctx: Context) returns ref Expr {
    ref tc : Cell = scope_get(s, type_name)
    if tc.is_null() {
        interp_error(e, format(who, ": type '", type_name, "' not found"), ctx)
        exit(1)
    }
    switch tc.val {
    case Value.Func(fptr):
        ref node : Expr = deref(fptr)
        if node.node_type.is(NodeType.StructDef).not() {
            interp_error(e, format(who, ": '", type_name, "' is not a struct"), ctx)
            exit(1)
        }
        return node
    case:
        interp_error(e, format(who, ": '", type_name, "' is not a struct"), ctx)
        exit(1)
        return NULL
    }
}

priv h_struct_field_count := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    ref node : Expr = interp_lookup_struct(s, e, type_name, "struct_field_count", ctx)
    switch node.node_type {
    case NodeType.StructDef(sd):
        r = Value.Int(sd.fields.len().to_i64())
    case:
        UNREACHABLE()
    }
    return true
}

// Decode e.children[2] (the index argument shared by every struct_field_*
// / enum_variant_* / func_sig_* handler) as a USize. The arg is a
// til-side integer value (commonly an I64 literal); take the low 32
// bits as the slot index.
priv eval_index_arg := proc(s: Scope, e: Expr, ctx: Context) returns USize {
    return value_to_u64(eval_expr(s, e.children[2], ctx)).to_u32()
}

priv h_struct_field_name := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    idx := eval_index_arg(s, e, ctx)
    ref node : Expr = interp_lookup_struct(s, e, type_name, "struct_field_name", ctx)
    switch node.node_type {
    case NodeType.StructDef(sd):
        if idx >= sd.fields.len() {
            interp_error(e, "struct_field_name: index out of bounds", ctx)
            exit(1)
        }
        ref fd : Declaration = sd.fields[idx]
        r = str_to_owned_value(fd.name, ctx)
    case:
        UNREACHABLE()
    }
    return true
}

priv h_struct_field_is_mut := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    idx := eval_index_arg(s, e, ctx)
    ref node : Expr = interp_lookup_struct(s, e, type_name, "struct_field_is_mut", ctx)
    switch node.node_type {
    case NodeType.StructDef(sd):
        if idx >= sd.fields.len() {
            interp_error(e, "struct_field_is_mut: index out of bounds", ctx)
            exit(1)
        }
        ref fd : Declaration = sd.fields[idx]
        if fd.is_mut { r = Value.Int(1) } else { r = Value.Int(0) }
    case:
        UNREACHABLE()
    }
    return true
}

priv h_struct_field_type := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    idx := eval_index_arg(s, e, ctx)
    ref node : Expr = interp_lookup_struct(s, e, type_name, "struct_field_type", ctx)
    switch node.node_type {
    case NodeType.StructDef(sd):
        if idx >= sd.fields.len() {
            interp_error(e, "struct_field_type: index out of bounds", ctx)
            exit(1)
        }
        ref fd : Declaration = sd.fields[idx]
        r = str_to_owned_value(fd.explicit_type, ctx)
    case:
        UNREACHABLE()
    }
    return true
}

