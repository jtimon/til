priv h_dyn_type_to_str := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    type_val := eval_expr(s, e.children[1], ctx)
    switch type_val {
    case Value.Enum(ei):
        ref til_type_def : Expr = lookup_interp_type_def("Type", ctx)
        if til_type_def.is_null() {
            panic("dyn_type_to_str: Type definition not registered")
        }
        ref tag_ptr : Dynamic = ei.data
        ref tag_ref : I32 = tag_ptr
        tag := tag_ref
        if tag.eq(enum_variant_tag(til_type_def, "Unknown")).or(tag.eq(enum_variant_tag(til_type_def, "None"))) {
            r = make_str_value("".c_str, 0, ctx)
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "I64")) {
            r = make_str_value("I64".c_str, 3, ctx)
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "U8")) {
            r = make_str_value("U8".c_str, 2, ctx)
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "I8")) {
            r = make_str_value("I8".c_str, 2, ctx)
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "I16")) {
            r = make_str_value("I16".c_str, 3, ctx)
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "U16")) {
            r = make_str_value("U16".c_str, 3, ctx)
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "I32")) {
            r = make_str_value("I32".c_str, 3, ctx)
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "U32")) {
            r = make_str_value("U32".c_str, 3, ctx)
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "U64")) {
            r = make_str_value("U64".c_str, 3, ctx)
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "F32")) {
            r = make_str_value("F32".c_str, 3, ctx)
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "Bool")) {
            r = make_str_value("Bool".c_str, 4, ctx)
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "Struct")) {
            ref payload : Str = ptr_add(ei.data, ENUM_PAYLOAD_OFFSET.cast(U64))
            r = make_str_value(payload.c_str, payload.count, ctx)
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "StructDef")) {
            r = make_str_value("StructDef".c_str, 9, ctx)
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "Enum")) {
            ref payload2 : Str = ptr_add(ei.data, ENUM_PAYLOAD_OFFSET.cast(U64))
            r = make_str_value(payload2.c_str, payload2.count, ctx)
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "EnumDef")) {
            r = make_str_value("EnumDef".c_str, 7, ctx)
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "FuncDef")) {
            r = make_str_value("FunctionDef".c_str, 11, ctx)
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "FuncPtr")) {
            r = make_str_value("Fn".c_str, 2, ctx)
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "Dynamic")) {
            r = make_str_value("Dynamic".c_str, 7, ctx)
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "Custom")) {
            ref payload3 : Str = ptr_add(ei.data, ENUM_PAYLOAD_OFFSET.cast(U64))
            r = make_str_value(payload3.c_str, payload3.count, ctx)
            return true
        }
        if tag.eq(enum_variant_tag(til_type_def, "Primitive")) {
            // Type.Primitive(p) carries a Primitive enum value inline at
            // ENUM_PAYLOAD_OFFSET (its tag is the first I32). Decode it to
            // the primitive's name -- mirrors the data-driven nested switch
            // that emit_dyn_type_to_str_body generates for compiled code.
            ref prim_def : Expr = lookup_interp_type_def("Primitive", ctx)
            if prim_def.is_null() {
                panic("dyn_type_to_str: Primitive definition not registered")
            }
            ref prim_tag_ref : I32 = ptr_add(ei.data, ENUM_PAYLOAD_OFFSET.cast(U64))
            ptag := prim_tag_ref
            if ptag.eq(enum_variant_tag(prim_def, "I16")) { r = make_str_value("I16".c_str, 3, ctx); return true }
            if ptag.eq(enum_variant_tag(prim_def, "U16")) { r = make_str_value("U16".c_str, 3, ctx); return true }
            if ptag.eq(enum_variant_tag(prim_def, "I8"))  { r = make_str_value("I8".c_str, 2, ctx); return true }
            if ptag.eq(enum_variant_tag(prim_def, "U8"))  { r = make_str_value("U8".c_str, 2, ctx); return true }
            if ptag.eq(enum_variant_tag(prim_def, "U32")) { r = make_str_value("U32".c_str, 3, ctx); return true }
            if ptag.eq(enum_variant_tag(prim_def, "I32")) { r = make_str_value("I32".c_str, 3, ctx); return true }
            if ptag.eq(enum_variant_tag(prim_def, "U64")) { r = make_str_value("U64".c_str, 3, ctx); return true }
            if ptag.eq(enum_variant_tag(prim_def, "I64")) { r = make_str_value("I64".c_str, 3, ctx); return true }
            if ptag.eq(enum_variant_tag(prim_def, "F32")) { r = make_str_value("F32".c_str, 3, ctx); return true }
            if ptag.eq(enum_variant_tag(prim_def, "Bool")) { r = make_str_value("Bool".c_str, 4, ctx); return true }
            panic("dyn_type_to_str: unknown Primitive tag")
        }
        panic("dyn_type_to_str: unknown Type tag")
        r = make_str_value("".c_str, 0, ctx)
        return true
    case:
        panic("dyn_type_to_str: expected Type enum value")
        return false
    }
}

priv h_check_cmd_status := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    pidv := eval_expr(s, e.children[1], ctx)
    switch pidv {
    case Value.Int(pid):
        r = Value.Int(check_cmd_status(pid))
        return true
    case:
        UNREACHABLE()
        return false
    }
}

priv h_sleep := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    msv := eval_expr(s, e.children[1], ctx)
    switch msv {
    case Value.Int(ms):
        sleep_ms(ms)
        r = val_none()
        return true
    case:
        UNREACHABLE()
        return false
    }
}

