        if fd.return_type.len().gt(0) { r = Value.Int(1) } else { r = Value.Int(0) }
    case:
        UNREACHABLE()
    }
    return true
}

priv h_func_sig_return_type := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    idx := eval_index_arg(s, e, ctx)
    ref node : Expr = interp_lookup_funcsig(s, e, type_name, "func_sig_return_type", ctx)
    switch node.node_type {
    case NodeType.FuncDef(fd):
        if idx.neq(0).or(fd.return_type.len().eq(0)) {
            interp_error(e, "func_sig_return_type: index out of bounds", ctx)
            exit(1)
        }
        r = str_to_owned_value(fd.return_type, ctx)
    case:
