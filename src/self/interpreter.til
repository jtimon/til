            elem_off := i.mul(elem_size)
            container_elem_clone_into(elem_type, ptr_add(new_buf, elem_off), ptr_add(src_hdr.p, elem_off), elem_size, ctx)
        }
    }
    write_ptr(ptr_add(dst_data, data_fl.offset), new_buf)
}

// Resolve `name` to its raw value block, walking inner to outer.
scope_get := func(mut s: Scope, name: Str) returns ref Dynamic throws KeyNotFound {
    ref mut cur : Scope = s
    while cur.is_null().not() {
        ref hb : HeapBinding = cur.heap_bindings.get(name)?
        catch (e: KeyNotFound) { cur = cur.parent; continue }
        return to_ptr(hb.ptr)
    }
    throw KeyNotFound()
}

priv scope_return_move_is_local := func(mut s: Scope, name: Str) returns Bool {
    ref mut cur : Scope = s
    while cur.is_null().not() {
        ref hb : HeapBinding = cur.heap_bindings.get(name)?
        catch (e: KeyNotFound) {
            if cur.is_call_scope { return false }
            cur = cur.parent
            continue
        }
        return hb.is_local
    }
    return false
}

// Pool of dead Scope boxes for reuse. scope_free memsets a scope to zero
// and parks it here instead of freeing; scope_new / scope_new_boxed pop
// instead of mallocing. An all-zero Scope IS a valid empty scope now that
// Vec.new is lazy (every Map/Vec field's zero state is lazy-empty), so
// recycling needs no re-init beyond setting parent. Module-level because
// scope_new/scope_free do not see the InterpSession; every creator's
// teardown path calls scope_pool_drain (interp_session_free for the
// interpreter, the loader's fold passes after their scope_free(global)).
priv mut scope_pool := Vec(DynPtrBox).new()

priv scope_pool_put := func(own p: Dynamic) {
    scope_pool.push(own DynPtrBox(p = p))
}

// Free every parked box and release the pool's storage, leaving the pool
// a valid lazy-empty Vec for a later session/fold pass.
scope_pool_drain := func() {
    for pe : DynPtrBox in scope_pool {
        if pe.p.is_null().not() { free(own pe.p) }
    }
    free(own scope_pool.data)
    memset(scope_pool, 0, Vec(DynPtrBox).size())
}

priv scope_get_binding_scope := func(mut s: Scope, name: Str) returns ref Scope {
    ref mut cur : Scope = s
    while cur.is_null().not() {
        cur.heap_bindings.get(name)?
        catch (e: KeyNotFound) { cur = cur.parent; continue }
        return cur
    }
    return NULL
}

scope_new := func(parent: Scope) returns Scope {
    if scope_pool.len() > 0 {
        // Steal the last parked box: decrementing count makes the slot dead
        // (its own p is never elem-deleted), so ownership moves to the
        // returned scope with no double-free.
        ref e : DynPtrBox = scope_pool.unsafe_get(scope_pool.len() - 1)
        scope_pool.count = scope_pool.count - 1
        ref s : Scope = to_ptr(e.p)
        s.parent = parent
        return to_ptr(e.p)
    }
    return Scope(parent = parent)
}

// Look up the type/ownership metadata for a raw binding.
scope_lookup_heap_binding := func(mut s: Scope, name: Str) returns ref HeapBinding {
    ref mut cur : Scope = s
    while true {
        if cur.is_null() { return NULL }
        ref b : HeapBinding = cur.heap_bindings.get(name)?
        catch (e: KeyNotFound) { cur = cur.parent; continue }
        return b
    }
    return NULL
}

// Identify callable raw slots from their Type metadata.
priv heap_type_is_callable := func(shallow til_type: Type) returns Bool {
    return til_type.is_funcptr().or(til_type.is(Type.Body))
}

priv heap_slot_is_static_callable := func(shallow til_type: Type, ptr: Dynamic) returns Bool {
    if heap_type_is_callable(til_type).not() { return false }
    ref stored : Dynamic = deref(ptr)
    if stored.is_null() { panic("callable heap slot is empty") }
    return callable_box_is(stored).not()
}

priv heap_drop_by_type := func(shallow til_type: Type, ptr: Dynamic, ctx: Context) {
    if ptr.is_null() { return }
    switch til_type {
    case Type.Primitive:
    case Type.Struct(sname):
        heap_drop_struct(sname, ptr, ctx)
    case Type.Enum(ename):
        heap_drop_enum(ename, ptr, ctx)
    case Type.FuncPtr:
        ref stored_callable : Dynamic = deref(ptr)
        if stored_callable.is_null().not() { callable_storage_free(stored_callable) }
    case Type.FuncPtrSig:
        ref stored_callable2 : Dynamic = deref(ptr)
        if stored_callable2.is_null().not() { callable_storage_free(stored_callable2) }
    case Type.Body:
        ref stored_callable3 : Dynamic = deref(ptr)
        if stored_callable3.is_null().not() { callable_storage_free(stored_callable3) }
    case Type.Custom(name):
        heap_drop_by_type(type_from_name_init(name, ctx.scope), ptr, ctx)
    case:
    }
}

priv primitive_heap_clone := func(prim: Primitive, ptr: Dynamic) returns Dynamic {
    mut sz : USize = 0
    mut al : USize = 0
    builtin_primitive_size_align(prim, sz, al)
    dst : Dynamic = EvalHeap.heap_alloc(sz)
    memcpy(dst, ptr, sz.cast(U64))
    return dst
}

priv heap_clone_by_type := func(shallow til_type: Type, ptr: Dynamic, ctx: Context) returns Dynamic {
    switch til_type {
    case Type.Primitive(prim):
        return primitive_heap_clone(prim, ptr)
    case Type.Dynamic:
        dst0 : Dynamic = EvalHeap.heap_alloc(Dynamic.size())
        ref dynamic_value : Dynamic = deref(ptr)
        write_ptr(dst0, dynamic_value)
        return dst0
    case Type.Struct(sname):
        return heap_clone(sname, ptr, ctx)
    case Type.Enum(ename):
        total : USize = ctx_total_size(ename, ctx)
        return heap_clone_enum(ename, ptr, total, ctx)
    case Type.FuncPtr:
        dst : Dynamic = EvalHeap.heap_alloc(Dynamic.size())
        ref stored_callable : Dynamic = deref(ptr)
        if stored_callable.is_null().not() { write_ptr(dst, callable_storage_clone(stored_callable)) }
        return dst
    case Type.FuncPtrSig:
        dst2 : Dynamic = EvalHeap.heap_alloc(Dynamic.size())
        ref stored_callable2 : Dynamic = deref(ptr)
        if stored_callable2.is_null().not() { write_ptr(dst2, callable_storage_clone(stored_callable2)) }
        return dst2
    case Type.Body:
        dst3 : Dynamic = EvalHeap.heap_alloc(Dynamic.size())
        ref stored_callable3 : Dynamic = deref(ptr)
        if stored_callable3.is_null().not() { write_ptr(dst3, callable_storage_clone(stored_callable3)) }
        return dst3
    case Type.Custom(name):
        return heap_clone_by_type(type_from_name_init(name, ctx.scope), ptr, ctx)
    case:
        panic("cannot clone raw binding of type ", til_type_name_c(til_type))
        return NULL
    }
}

priv heap_move_ptr_into_slot := func(shallow til_type: Type, dst: Dynamic, src: Dynamic, ctx: Context) returns Bool {
    switch til_type {
    case Type.Primitive(prim):
        mut sz : USize = 0
        mut al : USize = 0
        builtin_primitive_size_align(prim, sz, al)
        memcpy(dst, src, sz.cast(U64))
        owned_src : Dynamic = src
        EvalHeap.heap_free(own owned_src)
        return true
    case Type.Struct(sname):
        heap_drop_struct(sname, dst, ctx)
        memcpy(dst, src, ctx_total_size(sname, ctx).cast(U64))
        owned_src2 : Dynamic = src
        EvalHeap.heap_free(own owned_src2)
        return true
    case Type.Enum(ename):
        heap_drop_enum(ename, dst, ctx)
        mut total : USize = ctx_total_size(ename, ctx)
        if total < 8 { total = 8 }
        memcpy(dst, src, total.cast(U64))
        owned_src3 : Dynamic = src
        EvalHeap.heap_free(own owned_src3)
        return true
    case Type.FuncPtr:
        ref old_callable : Dynamic = deref(dst)
        if old_callable.is_null().not() { callable_storage_free(old_callable) }
        ref moved_callable : Dynamic = deref(src)
        write_ptr(dst, moved_callable)
        write_ptr(src, NULL)
        owned_src4 : Dynamic = src
        EvalHeap.heap_free(own owned_src4)
        return true
    case Type.FuncPtrSig:
        ref old_callable2 : Dynamic = deref(dst)
        if old_callable2.is_null().not() { callable_storage_free(old_callable2) }
        ref moved_callable2 : Dynamic = deref(src)
        write_ptr(dst, moved_callable2)
        write_ptr(src, NULL)
        owned_src5 : Dynamic = src
        EvalHeap.heap_free(own owned_src5)
        return true
    case Type.Body:
        ref old_callable3 : Dynamic = deref(dst)
        if old_callable3.is_null().not() { callable_storage_free(old_callable3) }
        ref moved_callable3 : Dynamic = deref(src)
        write_ptr(dst, moved_callable3)
        write_ptr(src, NULL)
        owned_src6 : Dynamic = src
        EvalHeap.heap_free(own owned_src6)
        return true
    case:
        panic("heap slot move to unsupported type")
    }
    return false
}

priv scope_read_heap_binding_raw := func(hb: HeapBinding, name: Str, ctx: Context) returns Dynamic {
    if hb.moved_out { panic("read of moved binding: ", name, " type ", til_type_name_c(hb.til_type)) }
    ref heap_data : Dynamic = to_ptr(hb.ptr)
    if hb.til_type.is(Type.Unknown) { panic("binding has unknown raw type: ", name) }
    if hb.is_static_callable {
        result : Dynamic = EvalHeap.heap_alloc(Dynamic.size())
        write_ptr(result, deref(heap_data))
        return result
    }
    if heap_type_is_callable(hb.til_type) { return heap_clone_by_type(hb.til_type, heap_data, hb.ctx) }
    if heap_data.is_null() { panic("binding has null raw storage: ", name) }
    if hb.own_type.is(OwnType.Ref) {
        result : Dynamic = heap_data
        return result
    }
    // A SHALLOW primitive read loads the scalar straight into an inline
    // word -- no clone, no allocation (the old Value box's inline-scalar
    // read). Own-primitive bindings (#302 raw allocations) carry the
    // pointer as their datum and keep the block path.
    if raw_type_is_prim(hb.til_type, ctx).and(hb.own_type.is(OwnType.Shallow)) { return scalar_word_load(hb.til_type, heap_data, ctx) }
    return heap_clone_by_type(hb.til_type, heap_data, ctx)
}

scope_read_bound_raw := func(scope: Scope, name: Str, ctx: Context) returns Dynamic {
    ref hb : HeapBinding = scope_lookup_heap_binding(scope, name)
    if hb.is_null() { panic("scope read binding not found: ", name) }
    return scope_read_heap_binding_raw(hb, name, ctx)
}

priv scope_move_bound_raw := func(scope: Scope, name: Str, ctx: Context) returns Dynamic {
    ref hb : HeapBinding = scope_lookup_heap_binding(scope, name)
    if hb.is_null() { panic("scope move binding not found: ", name) }
    if hb.moved_out { panic("move of moved binding: ", name) }
    ref heap_data : Dynamic = to_ptr(hb.ptr)
    if heap_data.is_null() { panic("binding with null raw storage: ", name) }
    if hb.is_borrowed {
        if hb.own_type.is(OwnType.Ref) {
            borrowed_result : Dynamic = heap_data
            return borrowed_result
        }
        return heap_clone_by_type(hb.til_type, heap_data, ctx)
    }
    result : Dynamic = heap_data
    hb.ptr = NULL
    hb.moved_out = true
    return result
}

priv scope_drop_existing_heap_slot := func(mut s: Scope, name: Str, drop_nested: Bool = true) {
    ref hb : HeapBinding = s.heap_bindings.get(name)?
    catch (e: KeyNotFound) { return }
    if hb.is_local.not() { return }
    if hb.is_borrowed { return }
    if hb.moved_out { return }
    old_ptr : Dynamic = hb.ptr
    if old_ptr.is_null() { return }
    switch hb.til_type {
    case Type.Struct:
        if hb.ctx.is_null() { panic("heap binding without ctx: ", name) }
    case Type.Enum:
        if hb.ctx.is_null() { panic("heap binding without ctx: ", name) }
    case:
    }
    if drop_nested.and(hb.is_static_callable.not()) { heap_drop_by_type(hb.til_type, old_ptr, hb.ctx) }
    EvalHeap.heap_free(own old_ptr)
    hb.ptr = NULL
    hb.moved_out = true
}

scope_set_heap_owned := func(mut s: Scope, name: Str, ptr: Dynamic, shallow til_type: Type, own_type: OwnType, ctx: Context, is_local: Bool, is_borrowed: Bool = false, is_erased_dynamic: Bool = false) {
    if ptr.is_null() {
        if is_borrowed.not().and(til_type.is(Type.Struct).or(til_type.is(Type.Enum))) { panic("null aggregate heap binding: ", name) }
    }
    is_static_callable := heap_slot_is_static_callable(til_type, ptr)
    scope_drop_existing_heap_slot(s, name)
    meta := HeapBinding(ptr = to_ptr(ptr), til_type = til_type.clone(), own_type = own_type, ctx = ctx, is_local = is_local, is_borrowed = is_borrowed, is_erased_dynamic = is_erased_dynamic, is_static_callable = is_static_callable, moved_out = false)
    s.heap_bindings.set(name, own meta)
}

// #286 Stage 1: mark a heap slot as moved out without deleting its metadata.
// Move sites need this separate from removing the map entry so later reads can
// fail at the source instead of silently falling back to a stale parent binding.
scope_set_heap_moved := func(mut s: Scope, name: Str, moved_out: Bool) {
    ref b : HeapBinding = scope_lookup_heap_binding(s, name)
    if b.is_null() { panic("scope_set_heap_moved: heap binding not found: ", name) }
    b.moved_out = moved_out
}

scope_new_boxed := func(parent: Scope) returns ref Scope {
    if scope_pool.len() > 0 {
        // Same steal-the-dead-slot recycle as scope_new above.
        ref e : DynPtrBox = scope_pool.unsafe_get(scope_pool.len() - 1)
        scope_pool.count = scope_pool.count - 1
        ref pooled : Scope = to_ptr(e.p)
        pooled.parent = parent
        return pooled
    }
    raw : Dynamic = malloc(Scope.size())
    memset(raw, 0, Scope.size())
    ref s : Scope = to_ptr(raw)
    s.heap_bindings = Map(Str, HeapBinding).new()
    s.heap_aliases = Map(Str, Str).new()
    s.parent = parent
    return s
}

scope_drop_owned_bindings := func(s: Scope) {
    for _, hb in s.heap_bindings {
        if hb.is_local.not().or(hb.is_borrowed).or(hb.moved_out).or(hb.ptr.is_null()) { continue }
        owned_ptr : Dynamic = hb.ptr
        if hb.is_static_callable.not() { heap_drop_by_type(hb.til_type, owned_ptr, hb.ctx) }
        EvalHeap.heap_free(own owned_ptr)
        hb.ptr = NULL
        hb.moved_out = true
    }
}

priv scope_set_borrowed := func(mut s: Scope, name: Str, shallow til_type: Type, own_type: OwnType, source_name: Str, mut source_scope: Scope) {
    if source_name.len() == 0 { panic("borrowed binding without source name: ", name) }
    if source_name.len() > 0 { s.heap_aliases.set(name, own source_name.clone()) }
    if source_scope.is_null() { source_scope = s.parent }
    if source_scope.is_null() { panic("borrowed binding without source scope: ", name) }
    ref source_hb : HeapBinding = scope_lookup_heap_binding(source_scope, source_name)
    if source_hb.is_null().or(source_hb.ptr.is_null()) { panic("borrow source not found: ", source_name) }
    if source_hb.moved_out { panic("borrow of moved binding: ", source_name) }
    ref source_ptr : Dynamic = to_ptr(source_hb.ptr)
    is_erased_dynamic := source_hb.is_erased_dynamic.or(til_type.is(Type.Dynamic).and(source_hb.til_type.is(Type.Dynamic).not()))
    scope_set_heap_owned(s, name, source_ptr, til_type, own_type, source_hb.ctx, false, true, is_erased_dynamic)
}
scope_free := func(own s: Scope) {
    // Runtime slots represent compiled stack storage. Reclaim the outer slot,
    // but never drop nested payloads here; generated delete/free calls own that.
    for _, hb in s.heap_bindings {
        if hb.is_local.not().or(hb.is_borrowed).or(hb.moved_out).or(hb.ptr.is_null()) { continue }
        slot : Dynamic = hb.ptr
        EvalHeap.heap_free(own slot)
    }
    own s.heap_aliases.delete(false)
    memset(s.heap_aliases, 0, Map(Str, Str).size().cast(U64))
    // The binding map owns metadata and keys, not nested program payloads.
    own s.heap_bindings.delete(false)
    memset(s.heap_bindings, 0, Map(Str, HeapBinding).size())
    // Recycle the box through the pool instead of freeing: zero the whole
    // struct (parent, is_call_scope and the already-emptied containers) so
    // the pooled box is a valid empty scope for the next scope_new.
    memset(s, 0, Scope.size())
    scope_pool_put(own s)
}

priv scope_root_ref := func(s: Scope) returns ref Scope {
    if s.parent.is_null() { return s }
    return scope_root_ref(s.parent)
}

priv closure_env_clone := func(env: Scope) returns ref Scope {
    ref cloned : Scope = scope_new_boxed(env.parent)
    for name, hb in env.heap_bindings {
        if hb.moved_out { panic("closure clone from moved binding: ", name) }
        ref src : Dynamic = to_ptr(hb.ptr)
        if src.is_null() { panic("closure clone from null binding: ", name) }
        if hb.is_borrowed {
            scope_set_heap_owned(cloned, name, src, hb.til_type, hb.own_type, hb.ctx, false, true, hb.is_erased_dynamic)
            if env.heap_aliases.has(name) { cloned.heap_aliases.set(name, own env.heap_aliases[name].clone()) }
        } else {
            copied : Dynamic = heap_clone_by_type(hb.til_type, src, hb.ctx)
            scope_set_raw_owned(cloned, name, copied, hb.til_type, hb.own_type, hb.ctx)
        }
    }
    return cloned
}

priv capture_raw_binding := func(env: Scope, source: Scope, cap: Declaration, ctx: Context) {
    ref hb : HeapBinding = scope_lookup_heap_binding(source, cap.name)
    if hb.is_null() { panic("closure capture binding not found: ", cap.name) }
    if hb.moved_out { panic("closure capture from moved binding: ", cap.name) }
    ref source_scope : Scope = scope_get_binding_scope(source, cap.name)
    ref raw : Dynamic = to_ptr(hb.ptr)
    if raw.is_null() { panic("closure capture from null binding: ", cap.name) }
    if cap.own_type.is(OwnType.Ref) {
        scope_set_borrowed(env, cap.name, hb.til_type, cap.own_type, cap.name, source_scope)
        return
    }
    if cap.own_type.is(OwnType.Shallow).or(hb.is_borrowed).or(heap_slot_is_static_callable(hb.til_type, raw)) {
        copied : Dynamic = heap_clone_by_type(hb.til_type, raw, ctx)
        scope_set_raw_owned(env, cap.name, copied, hb.til_type, cap.own_type, ctx)
        return
    }
    scope_set_raw_owned(env, cap.name, raw, hb.til_type, cap.own_type, ctx)
    hb.ptr = NULL
    hb.moved_out = true
}

priv make_interp_closure := func(func_def: Expr, scope: Scope, ctx: Context) returns Dynamic {
    ref env : Scope = scope_new_boxed(scope_root_ref(scope))
    switch func_def.node_type {
    case NodeType.FuncDef(fd):
        for cap : Declaration in fd.captures {
            capture_raw_binding(env, scope, cap, ctx)
        }
    case NodeType.BodyValue(bd):
        for cap2 : Declaration in bd.captures {
            capture_raw_binding(env, scope, cap2, ctx)
        }
    case:
        UNREACHABLE()
    }
    box : Dynamic = EvalHeap.heap_alloc(InterpCallableBox.size())
    ref callable : InterpCallableBox = to_ptr(box)
    callable.magic = CALLABLE_BOX_MAGIC
    callable.func_def = func_def
    callable.env = env
    result : Dynamic = EvalHeap.heap_alloc(Dynamic.size())
    write_ptr(result, box)
    return result
}

priv callable_box_is := func(ptr: Dynamic) returns Bool {
    if ptr.is_null() { return false }
    ref magic : U64 = ptr
    return magic == CALLABLE_BOX_MAGIC
}

priv callable_storage_clone := func(ptr: Dynamic) returns Dynamic {
    if callable_box_is(ptr).not() { return ptr }
    ref src : InterpCallableBox = to_ptr(ptr)
    dst : Dynamic = EvalHeap.heap_alloc(InterpCallableBox.size())
    ref cloned : InterpCallableBox = to_ptr(dst)
    cloned.magic = CALLABLE_BOX_MAGIC
    cloned.func_def = src.func_def
    cloned.env = closure_env_clone(src.env)
    return dst
}

priv callable_storage_free := func(ptr: Dynamic) {
    if callable_box_is(ptr) { callable_box_free(ptr) }
}

priv callable_box_free := func(ptr: Dynamic) {
    if callable_box_is(ptr).not() { return }
    ref b : InterpCallableBox = to_ptr(ptr)
    scope_free(own b.env)
    b.env = NULL
    mut owned_ptr : Dynamic = ptr
    EvalHeap.heap_free(own owned_ptr)
}

// Body of interp_fa_is_ns_inner pulled out so both FieldAccess and
// FieldAssign cases (which share an Str payload) can switch-destructure
// `e.node_type` without duplicating ~50 lines of logic.
priv interp_fa_is_ns_with_fname := func(obj_expr: Expr, sname: Str, sdef: Expr, fname: Str) returns Bool {
    mut has_ns := false
    mut has_inst := false
    ref ins_ns : Vec(Declaration) = def_ns_decls(sdef)
    for ins_d : Declaration in ins_ns {
        if ins_d.name == fname { has_ns = true }
    }
    switch sdef.node_type {
    case NodeType.StructDef(ins_sdd):
        for dd : Declaration in ins_sdd.fields {
            if dd.name == fname { has_inst = true }
        }
    case NodeType.EnumDef(ins_edd):
        for vn : Str in ins_edd.variants {
            if vn == fname { has_inst = true }
        }
    case:
    }
    // Issue: variant access on an enum *instance* (e.g. `v.Some` where v
    // is an Opt value, Some is a variant of Opt) is a namespace-style
    // access -- it produces the variant constructor / tag value, matching
    // what `Opt.Some` does and what the typer accepts in compile mode.
    // The existing uppercase-receiver heuristic below only catches type-
    // name receivers (`Opt.Some`); add the enum-instance case here.
    if has_inst {
        if sdef.node_type.is(NodeType.EnumDef) {
            return true
        }
    }
    if has_ns {
        if has_inst.not() { return true }
    }
    if has_ns.not() {
        if has_inst.not() {
            switch obj_expr.node_type {
            case NodeType.Ident(ident):
                if ident.ident_name() == sname { return true }
                if ident.len() > 0 {
                    if ident.unsafe_get(0) >= 65 {
                        if ident.unsafe_get(0) <= 90 { return true }
                    }
                }
            case:
            }
            return false
        }
    }
    if has_ns {
        if has_inst {
            switch obj_expr.node_type {
            case NodeType.Ident(ident):
                if ident.ident_name() == sname { return true }
                if ident.len() > 0 {
                    if ident.unsafe_get(0) >= 65 {
                        if ident.unsafe_get(0) <= 90 { return true }
                    }
                }
            case:
                return false
            }
        }
    }
    return false
}

priv interp_fa_is_ns_inner := func(scope: Scope, e: Expr, sname: Str, ctx: Context) returns Bool {
    ref obj_expr : Expr = e.children[0]
    // The ctx type registry answers "is sname a struct/enum" in ONE map
    // get; the old scope_get(sname) walked the whole scope chain to
    // global (a Str-keyed map probe per level) on every field access.
    // Builtin primitive namespaces (I64.neq, ...) are not registered
    // there, so a miss still falls back to the scope walk.
    ref registry_def : Expr = lookup_interp_type_def(sname, ctx)
    if registry_def.is_null().not() {
        return interp_fa_is_ns_def(obj_expr, e, sname, registry_def)
    }
    ref tc : Dynamic = scope_get(scope, sname)?
    catch (knf: KeyNotFound) { return false }
    ref walked_def : Expr = callable_raw_func_def(tc)
    return interp_fa_is_ns_def(obj_expr, e, sname, walked_def)
}

priv interp_fa_is_ns_def := func(obj_expr: Expr, e: Expr, sname: Str, sdef: Expr) returns Bool {
    if sdef.node_type.is(NodeType.StructDef).not() {
        if sdef.node_type.is(NodeType.EnumDef).not() { return false }
    }
    switch e.node_type {
    case NodeType.FieldAccess(fname):
        return interp_fa_is_ns_with_fname(obj_expr, sname, sdef, fname.field_access_name())
    case NodeType.FieldAssign(fad):
        return interp_fa_is_ns_with_fname(obj_expr, sname, sdef, fad.name)
    case:
        return false
    }
}

priv interp_fa_is_ns := func(scope: Scope, e: Expr, ctx: Context) returns Bool {
    ref obj_expr : Expr = e.children[0]
    switch obj_expr.node_type {
    case NodeType.Ident(type_ident):
        ref type_hb : HeapBinding = scope_lookup_heap_binding(scope, type_ident.ident_name())
        if type_hb.is_null().not().and(heap_type_is_callable(type_hb.til_type)) {
            ref type_def : Expr = callable_raw_func_def(to_ptr(type_hb.ptr))
            if type_def.node_type.is(NodeType.StructDef).or(type_def.node_type.is(NodeType.EnumDef)) {
                return interp_fa_is_ns_inner(scope, e, type_ident.ident_name(), ctx)
            }
        }
    case:
    }
    sname := til_type_name(obj_expr.til_type())
    if sname.len() > 0 { return interp_fa_is_ns_inner(scope, e, sname, ctx) }
    switch obj_expr.node_type {
    case NodeType.Ident(ident): return interp_fa_is_ns_inner(scope, e, ident.ident_name(), ctx)
    case:
    }
    // Primitive receivers (`0.sub(1)`, recv = LiteralNum I64): til_type_name
    // returns "" for I64/U8/etc, fall back to til_type_name_c.
    tn := til_type_name_c(obj_expr.til_type())
    if tn.eq("unknown").not().and(tn.eq("?").not()).and(tn.eq("Dynamic").not()) {
        return interp_fa_is_ns_inner(scope, e, tn, ctx)
    }
    return false
}

priv build_argv_array := func(argv: Vec(Str), offset: USize, count: USize, elem_type: Str, ctx: Context) returns Dynamic {
    esz := elem_size_for_type(elem_type, ctx)
    mut alloc_count := count
    if alloc_count == 0 { alloc_count = 1 }
    data : Dynamic = EvalHeap.heap_alloc(alloc_count.mul(esz))
    for i in 0..count {
        raw : Dynamic = parse_cli_arg(argv[offset + i], elem_type, ctx)
        memcpy(ptr_add(data, i * esz), raw, esz)
        EvalHeap.heap_free(own raw)
    }
    array_name := format("Array__", elem_type)
    ref array_binding : TypeBinding = ctx.scope.get_binding(array_name)
    if array_binding.is_null() { panic("missing Array type '", array_name, "'") }
    ref array_canon_name : Str = array_binding.name
    sz := ctx_total_size(array_canon_name, ctx)
    inst_data : Dynamic = EvalHeap.heap_alloc(sz)
    ref ba_data_fl : FieldLayout = ctx_field_layout(array_canon_name, "data", ctx)
    write_ptr(ptr_add(inst_data, ba_data_fl.offset), data)
    ref ba_cap_fl : FieldLayout = ctx_field_layout(array_canon_name, "cap", ctx)
    memcpy(ptr_add(inst_data, ba_cap_fl.offset), count, ba_cap_fl.size)
    return inst_data
}

// Cache-only pass: populate ctx.cached_str/array/vec_def/name before raw
// allocation and layout helpers need the canonical aggregate definitions.
populate_cached_aggregate_defs := func(mut ctx: Context, program: Expr) {
    for stmt : Expr in program.children {
        switch stmt.node_type {
        case NodeType.Decl(dd):
            if stmt.children.len() == 0 { continue }
            ref sdef : Expr = stmt.children[0]
            if sdef.node_type.is(NodeType.StructDef).not() {
                if sdef.node_type.is(NodeType.EnumDef).not() { continue }
            }
            if sdef.node_type.is(NodeType.StructDef) {
                if dd.name == "Str"   { ctx.cached_str_def   = stmt.children[0]; ctx.cached_str_name   = dd.name }
                if dd.name == "Array" { ctx.cached_array_def = stmt.children[0]; ctx.cached_array_name = dd.name }
                if dd.name == "Vec"   { ctx.cached_vec_def   = stmt.children[0]; ctx.cached_vec_name   = dd.name }
            }
            tdv : Dynamic = malloc(I64.size())
            write_ptr(tdv, sdef)
            ctx.interp_type_defs.set(dd.name, own tdv)
        case:
        }
    }
}

interpreter_init_ns := proc(mut ctx: Context, global: Scope, program: Expr) {
    if ctx.ns_inited.not() {
        ctx.ns_fields = scope_new_boxed(NULL)
        ctx.ns_inited = true
    }
    for stmt : Expr in program.children {
        switch stmt.node_type {
        case NodeType.Decl(dd):
            if stmt.children.len() == 0 { continue }
            ref sdef : Expr = stmt.children[0]
            if sdef.node_type.is(NodeType.StructDef).not() {
                if sdef.node_type.is(NodeType.EnumDef).not() { continue }
            }
            if sdef.node_type.is(NodeType.StructDef) {
                if dd.name == "Str"   { ctx.cached_str_def   = stmt.children[0]; ctx.cached_str_name   = dd.name }
                if dd.name == "Array" { ctx.cached_array_def = stmt.children[0]; ctx.cached_array_name = dd.name }
                if dd.name == "Vec"   { ctx.cached_vec_def   = stmt.children[0]; ctx.cached_vec_name   = dd.name }
            }
            // Register every struct/enum AST in the comprehensive type-def map
            // so readers can replace Declaration.field_struct_def with a name lookup.
            // Clone the name for owned-key safety -- a CAP_VIEW key dangles if the
            // AST gets rebuilt later in the run. The map value is a malloc'd cell
            // holding the Expr pointer (same encoding as TypeScope.struct_defs).
            tdv : Dynamic = malloc(I64.size())
            write_ptr(tdv, sdef)
            ctx.interp_type_defs.set(dd.name, own tdv)
            ref ien_ns : Vec(Declaration) = def_ns_decls(sdef)
            // #307: two passes so registration order does not depend on
            // declaration order. A namespace CONSTANT's initializer may
            // reference a sibling method (`MAX : U64 = U64.bnot(0)`);
            // register every function member first (their eval needs no
            // siblings), then evaluate the constants.
            for d_f : Declaration in ien_ns {
                ref nsf : Declaration = d_f
                if nsf.default_value.is_null() { continue }
                if nsf.default_value.node_type.is(NodeType.FuncDef).not() { continue }
                fraw : Dynamic = eval_expr_raw(global, nsf.default_value, ctx)
                ns_set(dd.name, nsf.name, fraw, Type.Body, ctx)
            }
            for d_j : Declaration in ien_ns {
                ref nsd : Declaration = d_j
                if nsd.default_value.is_null() { continue }
                if nsd.default_value.node_type.is(NodeType.FuncDef) { continue }
                mut raw : Dynamic = eval_expr_raw(global, nsd.default_value, ctx)
                if expr_raw_is_ref(global, nsd.default_value, ctx) {
                    owned : Dynamic = heap_clone_by_type(ns_decl_raw_type(nsd), raw, ctx)
                    raw = owned
                } else if expr_word_shaped(global, nsd.default_value, ctx) {
                    // ns storage is a binding: a scalar word needs a block.
                    raw = scalar_block_from_word(ns_decl_raw_type(nsd), raw, ctx)
                }
                ns_set(dd.name, nsd.name, raw, ns_decl_raw_type(nsd), ctx)
            }
        case:
        }
    }
}

priv ns_qname := func(sname: Str, fname: Str) returns Str {
    return sname.concat3(".", fname)
}

ns_get := func(sname: Str, fname: Str, mut ctx: Context) returns ref Dynamic {
    ref mut c : Context = ctx
    qn := ns_qname(sname, fname)
    ref hb : HeapBinding = scope_lookup_heap_binding(c.ns_fields, qn)
    if hb.is_null() { return NULL }
    return to_ptr(hb.ptr)
}


priv ns_set := func(sname: Str, fname: Str, raw: Dynamic, shallow supplied_type: Type, mut ctx: Context) {
    ref mut c : Context = ctx
    qn := ns_qname(sname, fname)
    ref hb : HeapBinding = scope_lookup_heap_binding(c.ns_fields, qn)
    mut raw_type := supplied_type.clone()
    if hb.is_null().not() { raw_type = hb.til_type.clone() }
    if raw_type.is(Type.Unknown) { panic("namespace field type not found: ", qn) }
    scope_set_raw_owned(c.ns_fields, qn, raw, raw_type, OwnType.Own, ctx)
}

priv ns_decl_raw_type := func(decl: Declaration) returns Type {
    if decl.default_value.node_type.is(NodeType.FuncDef) { return Type.Body }
    return decl.default_value.til_type()
}

priv ns_field_type := func(sname: Str, fname: Str, ctx: Context) returns Type {
    ref namespace_def : Expr = lookup_interp_type_def(sname, ctx)
    if namespace_def.is_null().not().and(namespace_def.node_type.is(NodeType.EnumDef)) {
        variant_idx := enum_variant_index(namespace_def, fname)
        if variant_idx >= 0 {
            if enum_variant_type(namespace_def, variant_idx).len() == 0 { return Type.Enum(sname.clone()) }
        }
    }
    qn := ns_qname(sname, fname)
    ref hb : HeapBinding = scope_lookup_heap_binding(ctx.ns_fields, qn)
    if hb.is_null() { panic("namespace field type not found: ", qn) }
    return hb.til_type.clone()
}

interpreter_free_ns := func(mut ctx: Context) {
    if ctx.ns_inited.not() { return }
    scope_drop_owned_bindings(ctx.ns_fields)
    scope_free(own ctx.ns_fields)
    ctx.ns_fields = NULL
    ctx.ns_inited = false
}

// #192: write the count/cap USize fields of a freshly-malloc'd Str instance
// using the CTX layout (offset + size), not a hardcoded width. This keeps the
// compile-time interpreter (constfolder) correct when the compiler it runs
// inside was built at a different USize width than the source it compiles:
// the bytes are laid out the same way struct_deep_free later reads them.
priv str_write_count_cap := func(inst_data: Dynamic, count_val: USize, cap_val: USize, ctx: Context) {
    ref count_fl : FieldLayout = ctx_field_layout(ctx.cached_str_name, "count", ctx)
    ref cap_fl : FieldLayout = ctx_field_layout(ctx.cached_str_name, "cap", ctx)
    if count_fl.size == 4 { write_u32(ptr_add(inst_data, count_fl.offset), count_val.to_u32()) }
    else { write_u64(ptr_add(inst_data, count_fl.offset), count_val.to_u64()) }
    if cap_fl.size == 4 { write_u32(ptr_add(inst_data, cap_fl.offset), cap_val.to_u32()) }
    else { write_u64(ptr_add(inst_data, cap_fl.offset), cap_val.to_u64()) }
}

// #192/#309: the byte width at which a Str's USize field (count/cap) must be
// read. ctx.struct_layouts lays Str out at the HOST width (initer.til's
// compute_struct_layout: the interpreter runs host-compiled Str helpers and
// must match their ABI), so the field's slot is host-sized (8 on a 64-bit
// host). But INTERPRETED core code (substr, from_c_str, ...) writes its USize
// scalars -- including the CAP_VIEW/CAP_LIT sentinels -- at the TARGET width,
// landing the value in the field's low target-width bytes. Reading the full
// host slot then ZERO-extends a U32-target sentinel (0xFFFFFFFE) instead of
// recovering the host sentinel (0xFF..FE), so str_has_owned_storage mistakes a
// view for owned storage and frees a shared c_str (heap-use-after-free). Read
// exactly the low target-width bytes (never more than the slot) and let
// str_usize_field_at sign-extend so both host-written and target-written
// sentinels map back to the full-width host sentinel.
priv str_usize_read_width := func(field_size: USize, ctx: Context) returns USize {
    // ctx.target_usize_bytes (a SCALAR mirror of target_usize_pname) -- NOT the
    // owned target_usize_pname Str: this runs during Context teardown too, where
    // that Str is already freed (#309).
    tw := ctx.target_usize_bytes
    if tw < field_size { return tw }
    return field_size
}

// #192: read a Str instance's `cap` field at the ctx layout offset. The Str
// type the compiler is built with may put cap at a different offset than the
// source it compiles (cap@12 for U32, cap@16 for U64), so the compiled
// `str.cap` access reads the wrong bytes when folding cross-width core. Read
// it at the ctx offset instead (low bytes carry the value / the CAP_VIEW /
// CAP_LIT sentinels, which fit in 32 bits).
str_cap_at := func(str_base: Dynamic, ctx: Context) returns USize {
    ref cap_fl : FieldLayout = ctx_field_layout(ctx.cached_str_name, "cap", ctx)
    return str_usize_field_at(str_base, cap_fl.offset, str_usize_read_width(cap_fl.size, ctx))
}

// #192: read a Str's `count` field at the CTX layout, honouring the TARGET
// width -- the mirror of str_cap_at for the count offset. `ref s : Str;
// s.count` reads count at the HOST Str width (8 bytes on a U64-built
// compiler); when the target USize is narrower (U32), those 8 bytes span
// count@8 AND the neighbouring cap@12, so count comes back with cap in its
// high word -- a garbage huge value that crashes the buffer clone's memcpy.
str_count_at := func(str_base: Dynamic, ctx: Context) returns USize {
    ref count_fl : FieldLayout = ctx_field_layout(ctx.cached_str_name, "count", ctx)
    return str_usize_field_at(str_base, count_fl.offset, str_usize_read_width(count_fl.size, ctx))
}

// #192: read a USize-typed field (Str count/cap) at exactly the CTX field
// width. `ref v : USize` would read the host USize width; a U64 host
// cross-compiling a U32 target must read only the 4 target bytes (and a U32
// host building a U64 target must read all 8), else the high word picks up
// the neighbouring field / out-of-bounds bytes. Mirrors read_field's USize
// branch.
priv str_usize_field_at := func(str_base: Dynamic, offset: USize, size: USize) returns USize {
    ref p : Dynamic = ptr_add(str_base, offset)
    // #192: SIGN-extend the narrow field. cap carries the CAP_VIEW/CAP_LIT
    // sentinels (host -2/-1 = 0xFF..FE/FF); a U32 target stores only their low
    // 32 bits (0xFFFFFFFE/FF). I32.to_usize sign-extends ((USize)(int32)) so
    // those map back to the full-width host sentinels, while real small
    // counts/caps (high bit clear) are unchanged.
    if size == 4 { ref v : I32 = p; return v.to_usize() }
    ref v : U64 = p
    return v.to_usize()
}

priv find_field_decl := func(struct_def: Expr, fname: Str) returns ref Declaration {
    switch struct_def.node_type {
    case NodeType.StructDef(ffd_sdd):
        for dd : Declaration in ffd_sdd.fields {
            if dd.name == fname {
                return dd
            }
        }
        return NULL
    case:
        return NULL
    }
}

ENUM_PAYLOAD_OFFSET : USize = 8

read_field := func(inst_data: Dynamic, dd: Declaration, field_offset: USize, field_size: USize, ctx: Context) returns Dynamic {
    ref ptr : Dynamic = ptr_add(inst_data, field_offset)
    if decl_is_funcsig(dd, ctx) {
        ref stored_callable : Dynamic = deref(ptr)
        result : Dynamic = dispatch_result_alloc(dd.til_type, ctx)
        write_ptr(result, callable_storage_clone(stored_callable))
        return result
    }
    if dd.own_type.is(OwnType.Shallow).not() {
        result : Dynamic = dispatch_result_alloc(Type.Dynamic, ctx)
        ref pointed : Dynamic = deref(ptr)
        write_ptr(result, pointed)
        return result
    }
    if dd.til_type.is(Type.Struct).or(dd.til_type.is(Type.Enum)).or(field_nested_def(dd, ctx).is_null().not()) {
        result : Dynamic = dispatch_result_alloc(Type.Dynamic, ctx)
        write_ptr(result, ptr)
        return result
    }
    // A shallow primitive field reads straight into an inline word, at the
    // layout width (host struct bytes; see field_word_type).
    if raw_type_is_prim(dd.til_type, ctx) { return scalar_word_load(field_word_type(dd.til_type, field_size, ctx), ptr, ctx) }
    result : Dynamic = dispatch_result_alloc(dd.til_type, ctx)
    mut copy_size := raw_type_size(dd.til_type, ctx)
    if field_size < copy_size { copy_size = field_size }
    memcpy(result, ptr, copy_size)
    return result
}

priv free_owned_struct_slot := func(ptr: Dynamic, struct_name: Str, ctx: Context) {
    ref old_owned_ref : Dynamic = deref(ptr)
    if old_owned_ref.is_null() { return }
    old_owned : Dynamic = old_owned_ref
    heap_drop_struct(struct_name, old_owned, ctx)
    EvalHeap.heap_free(own old_owned)
}

priv free_inline_struct_slot := func(ptr: Dynamic, struct_name: Str, ctx: Context) {
    heap_drop_struct(struct_name, ptr, ctx)
}

priv free_owned_enum_slot := func(ptr: Dynamic, enum_name: Str, ctx: Context) {
    ref old_data_ref : Dynamic = deref(ptr)
    if old_data_ref.is_null() { return }
    old_data : Dynamic = old_data_ref
    heap_drop_enum(enum_name, old_data, ctx)
    EvalHeap.heap_free(own old_data)
}

priv write_field := proc(inst_data: Dynamic, dd: Declaration, field_offset: USize, field_size: USize, raw: Dynamic, shallow raw_type: Type, raw_is_ref: Bool, drop_old: Bool, ctx: Context) {
    ref dst : Dynamic = ptr_add(inst_data, field_offset)
    if decl_is_funcsig(dd, ctx) {
        ref old_callable : Dynamic = deref(dst)
        if drop_old.and(old_callable.is_null().not()) { callable_storage_free(old_callable) }
        mut source : Dynamic = raw
        ref stored : Dynamic = deref(source)
        if raw_is_ref { write_ptr(dst, callable_storage_clone(stored)) }
        else { write_ptr(dst, stored); write_ptr(raw, NULL) }
        raw_result_drop_ptr(raw_type, raw, raw_is_ref, ctx)
        return
    }
    switch dd.til_type {
    case Type.Struct(name):
        mut source : Dynamic = raw
        if dd.own_type.is(OwnType.Own) {
            if drop_old { free_owned_struct_slot(dst, name, ctx) }
            if raw_is_ref { write_ptr(dst, heap_clone(name, source, ctx)) }
            else { write_ptr(dst, source); return }
        } else if dd.own_type.is(OwnType.Ref) {
            write_ptr(dst, source)
        } else {
            if drop_old { free_inline_struct_slot(dst, name, ctx) }
            cloned : Dynamic = heap_clone(name, source, ctx)
            memcpy(dst, cloned, field_size)
            EvalHeap.heap_free(own cloned)
        }
        raw_result_drop_ptr(raw_type, raw, raw_is_ref, ctx)
        return
    case Type.Enum(name):
        mut source : Dynamic = raw
        if dd.own_type.is(OwnType.Own) {
            if drop_old { free_owned_enum_slot(dst, name, ctx) }
            if raw_is_ref { write_ptr(dst, heap_clone_enum(name, source, dispatch_enum_size(name, ctx), ctx)) }
            else { write_ptr(dst, source); return }
        } else if dd.own_type.is(OwnType.Ref) {
            write_ptr(dst, source)
        } else {
            if drop_old { heap_drop_enum(name, dst, ctx) }
            memcpy(dst, source, dispatch_enum_size(name, ctx))
            enum_payload_deep_clone(name, dst, ctx)
        }
        raw_result_drop_ptr(raw_type, raw, raw_is_ref, ctx)
        return
    case:
    }
    if dd.own_type.is(OwnType.Own).or(dd.own_type.is(OwnType.Ref)) {
        mut source : Dynamic = 0
        if raw_type.is(Type.Dynamic) { source = deref(raw) }
        if dd.own_type.is(OwnType.Own) {
            ref old : Dynamic = deref(dst)
            if drop_old.and(old.is_null().not()) { mut owned_old : Dynamic = old; free(own owned_old) }
            write_ptr(raw, NULL)
        }
        write_ptr(dst, source)
        raw_result_drop_ptr(raw_type, raw, raw_is_ref, ctx)
        return
    }
    // Shallow primitive field: the value is an inline word (a ref value
    // is the BARE source address -- load the scalar through it; the
    // source keeps its storage). The store uses the layout width (host
    // struct bytes; see field_word_type).
    if raw_type_is_prim(raw_type, ctx) {
        mut w : Dynamic = raw
        if raw_is_ref { w = scalar_word_load(raw_type, raw, ctx) }
        scalar_word_store(field_word_type(raw_type, field_size, ctx), dst, w, ctx)
        return
    }
    mut copy_size := raw_type_size(raw_type, ctx)
    if field_size < copy_size { copy_size = field_size }
    mut source : Dynamic = raw
    memcpy(dst, source, copy_size)
    raw_result_drop_ptr(raw_type, raw, raw_is_ref, ctx)
}

priv interpret_register_defs := func(global: Scope, prog: Expr) {
    for stmt : Expr in prog.children {
        if stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0)) {
            ref decl_value : Expr = stmt.children[0]
            if decl_value.node_type.is(NodeType.FuncDef)
            .or(decl_value.node_type.is(NodeType.StructDef))
            .or(decl_value.node_type.is(NodeType.EnumDef)) {
                switch stmt.node_type {
                case NodeType.Decl(dd):
                    raw : Dynamic = EvalHeap.heap_alloc(Dynamic.size())
                    write_ptr(raw, stmt.children[0])
                    scope_set_raw_owned(global, dd.name, raw, Type.Body, dd.own_type, NULL)
                case:
                }
            }
        }
    }
}

priv interpret_register_aliases := func(mut global: Scope, prog: Expr) {
    for stmt : Expr in prog.children {
        if stmt.node_type.is(NodeType.Decl).not() { }
        else if stmt.til_type().is(Type.None).not() { }
        else if stmt.children.len() == 0 { }
        else {
            switch stmt.children[0].node_type {
            case NodeType.Ident(rhs_ident):
                ref src_slot : Dynamic = scope_get(global, rhs_ident.ident_name())!
                ref src_raw : Dynamic = src_slot
                ref sdef : Expr = callable_raw_func_def(src_raw)
                        if sdef.node_type.is(NodeType.StructDef).or(sdef.node_type.is(NodeType.EnumDef)) {
                            switch stmt.node_type {
                            case NodeType.Decl(dd):
                                raw : Dynamic = EvalHeap.heap_alloc(Dynamic.size())
                                write_ptr(raw, sdef)
                                scope_set_raw_owned(global, dd.name, raw, Type.Body, dd.own_type, NULL)
                            case:
                            }
                        }
            case:
            }
        }
    }
}

priv interpret_copy_alias_ns := func(prog: Expr, global: Scope, ctx: Context) {
    for stmt : Expr in prog.children {
        if stmt.node_type.is(NodeType.Decl).not() { }
        else if stmt.til_type().is(Type.None).not() { }
        else if stmt.children.len() == 0 { }
        else {
            switch stmt.children[0].node_type {
            case NodeType.Ident(rhs_ident):
                switch stmt.node_type {
                case NodeType.Decl(dd):
                    ref tc : Dynamic = scope_get(global, rhs_ident.ident_name())!
                    ref tc_raw : Dynamic = tc
                    ref sdef : Expr = callable_raw_func_def(tc_raw)
                            if sdef.node_type.is(NodeType.StructDef).or(sdef.node_type.is(NodeType.EnumDef)) {
                                ref ica_ns : Vec(Declaration) = def_ns_decls(sdef)
                                for d_j : Declaration in ica_ns {
                                    ref nsd : Declaration = d_j
                                    ref raw : Dynamic = ns_get(rhs_ident.ident_name(), nsd.name, ctx)
                                    if raw.is_null().not() {
                                        cloned : Dynamic = heap_clone_by_type(ns_decl_raw_type(nsd), raw, ctx)
                                        ns_set(dd.name, nsd.name, cloned, ns_decl_raw_type(nsd), ctx)
                                    }
                                }
                            }
                case:
                }
            case:
            }
        }
    }
}

interp_session_start := func(mut session: InterpSession, user_argv: Vec(Str)) {
    session.global = scope_new_boxed(NULL)
    session.core_evaluated = false
    session.user_argc = 0
    session.retained_programs = Vec(DynPtrBox).new()
    session.evaluated_units = Set(Str).new()
    if user_argv.is_null().not() { session.user_argc = user_argv.len() }
}

interp_session_free := func(mut session: InterpSession) {
    if session.global.is_null().not() {
        scope_drop_owned_bindings(session.global)
        scope_free(own session.global)
    }
    session.global = NULL
    for box : DynPtrBox in session.retained_programs {
        if box.p.is_null().not() {
            LoadedProgram.delete(own to_ptr(box.p), true)
        }
    }
    free(own session.retained_programs.data)
    memset(session.retained_programs, 0, Vec(DynPtrBox).size())
    own session.evaluated_units.delete(false)
    memset(session.evaluated_units, 0, Set(Str).size())
    session.core_evaluated = false
    session.user_argc = 0
    // All scopes are dead by now (global freed above, eval scopes freed
    // during eval); release their pooled boxes.
    scope_pool_drain()
}

interp_program_to_heap := func(own lp: LoadedProgram) returns Dynamic {
    raw : Dynamic = malloc(LoadedProgram.size())
    memcpy(raw, lp, LoadedProgram.size())
    memset(lp, 0, LoadedProgram.size())
    return raw
}

interp_program_free := func(raw: Dynamic) {
    LoadedProgram.delete(own to_ptr(raw), true)
}

interp_session_retain_program := func(mut session: InterpSession, raw: Dynamic) {
    session.retained_programs.push(own DynPtrBox(p = raw))
}

priv interp_reset_control_flow := func(mut ctx: Context) {
    if ctx.has_return {
        raw : Dynamic = context_return_take(ctx)
        EvalHeap.heap_free(own raw)
    }
    ctx.has_return = false
    ctx.has_break = false
    ctx.has_continue = false
    ctx.constfold_aborted = false
}

interp_session_prepare_context := proc(session: InterpSession, mut lp: LoadedProgram, fwd_path: Str) returns I32 {
    // Ensure builtin dispatch table is initialized deterministically.
    if lp.ctx.dispatch_inited.not() { dispatch_init(lp.ctx) }

    // FFI init: reset, load the shared lib, then scan per-file ASTs.
    ffi_reset(lp.ctx)
    empty := Expr.new(NodeType.Body, 0, 0)
    ffi_rc := ffi_init(empty, fwd_path, lp.link_c_paths, lp.ext_c_path, lp.link_flags, lp.ctx)
    if ffi_rc.eq(0).not() { return ffi_rc }
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            ffi_init_struct_defs_append(iu.ast, lp.ctx)
            ffi_init_scan_program(iu.ast, lp.ctx)
        }
    }
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        ffi_init_struct_defs_append(iu.ast, lp.ctx)
        ffi_init_scan_program(iu.ast, lp.ctx)
    }

    // Refresh definition pointers and namespace state against this turn's AST.
    if lp.skip_core.not() {
        for u2 : ProgramUnit in lp.core_units {
            ref iu2 : ImportUnit = lp.ctx.imported[u2.path]
            interpret_register_defs(session.global, iu2.ast)
        }
    }
    for u3 : ProgramUnit in lp.units {
        ref iu3 : ImportUnit = lp.ctx.imported[u3.path]
        interpret_register_defs(session.global, iu3.ast)
    }

    if lp.skip_core.not() {
        for u4 : ProgramUnit in lp.core_units {
            ref iu4 : ImportUnit = lp.ctx.imported[u4.path]
            interpret_register_aliases(session.global, iu4.ast)
        }
    }
    for u5 : ProgramUnit in lp.units {
        ref iu5 : ImportUnit = lp.ctx.imported[u5.path]
        interpret_register_aliases(session.global, iu5.ast)
    }

    if lp.skip_core.not() {
        for u6 : ProgramUnit in lp.core_units {
            ref iu6 : ImportUnit = lp.ctx.imported[u6.path]
            interpreter_init_ns(lp.ctx, session.global, iu6.ast)
        }
    }
    for u7 : ProgramUnit in lp.units {
        ref iu7 : ImportUnit = lp.ctx.imported[u7.path]
        interpreter_init_ns(lp.ctx, session.global, iu7.ast)
    }

    if lp.skip_core.not() {
        for u8 : ProgramUnit in lp.core_units {
            ref iu8 : ImportUnit = lp.ctx.imported[u8.path]
            interpret_copy_alias_ns(iu8.ast, session.global, lp.ctx)
        }
    }
    for u9 : ProgramUnit in lp.units {
        ref iu9 : ImportUnit = lp.ctx.imported[u9.path]
        interpret_copy_alias_ns(iu9.ast, session.global, lp.ctx)
    }
    return 0
}

interp_session_finish_context := proc(mut lp: LoadedProgram) {
    interpreter_free_ns(lp.ctx)
    ffi_cleanup(lp.ctx)
}

interp_session_eval_core_once := proc(mut session: InterpSession, mut lp: LoadedProgram) {
    if session.core_evaluated { return }
    if lp.skip_core.not() {
        for u : ProgramUnit in lp.core_units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            context_enter_file(lp.ctx, u.path)
            eval_body(session.global, iu.ast, lp.ctx)
        }
    }
    session.core_evaluated = true
    interp_reset_control_flow(lp.ctx)
}

interp_session_eval_user_units := proc(session: InterpSession, mut lp: LoadedProgram) {
    for u : ProgramUnit in lp.units {
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        context_enter_file(lp.ctx, u.path)
        eval_body(session.global, iu.ast, lp.ctx)
    }
    interp_reset_control_flow(lp.ctx)
}

// REPL-only: run the top-level global initializers of every imported unit
// (all units except the last, which is the entry root the REPL evaluates
// incrementally) exactly once per session. Without this an imported unit's
// globals -- e.g. std/doc's __til_info_blob__/__til_docs_blob__, which the
// injected help() import brings in -- are never declared in `global`, so the
// doc-init assignment hits an undefined variable. Keyed by path so a unit
// added mid-session (a user import via the full-load path) runs on its first
// appearance and never re-runs.
interp_session_eval_imported_once := proc(mut session: InterpSession, mut lp: LoadedProgram) {
    if lp.units.len() < 2 { return }
    for i in 0..lp.units.len().sub(1) {
        ref u : ProgramUnit = lp.units[i]
        if session.evaluated_units.has(u.path) { continue }
        ref iu : ImportUnit = lp.ctx.imported[u.path]
        context_enter_file(lp.ctx, u.path)
        eval_body(session.global, iu.ast, lp.ctx)
        session.evaluated_units.add(own u.path.clone())
    }
    interp_reset_control_flow(lp.ctx)
}

priv interp_body_slice := func(mut program: Expr, start_idx: USize, count: USize, mut out: Expr) {
    free(own out.children.data)
    out.children.data = ptr_add(program.children.data, start_idx.mul(Expr.size()))
    out.children.count = count
    out.children.cap = count
}

priv interp_body_slice_clear := func(mut body: Expr) {
    body.children.data = NULL
    body.children.count = 0
    body.children.cap = 0
}

priv interp_eval_program_slice := proc(session: InterpSession, mut lp: LoadedProgram, mut program: Expr, start_idx: USize, count: USize) {
    if count == 0 { return }
    mut body := Expr.new(NodeType.Body, 0, 0)
    interp_body_slice(program, start_idx, count, body)
    eval_body(session.global, body, lp.ctx)
    interp_body_slice_clear(body)
}

priv interp_first_stmt_at_line := func(program: Expr, min_line: U32) returns USize {
    mut i : USize = 0
    while i < program.children.len() {
        if program.children[i].line >= min_line { return i }
        i++
    }
    return program.children.len()
}

priv interp_eval_exact_line := proc(session: InterpSession, mut lp: LoadedProgram, mut program: Expr, line: U32) {
    mut start : USize = program.children.len()
    mut count : USize = 0
    mut i : USize = 0
    while i < program.children.len() {
        if program.children[i].line == line {
            if count == 0 { start = i }
            count++
        } else if count > 0 {
            break
        }
        i++
    }
    if count == 0 { panic("REPL doc init line missing") }
    interp_eval_program_slice(session, lp, program, start, count)
}

// doc_init_line is the source line of the REPL's injected doc-init call
// (doc_init_cache_files, which populates the help() blobs). It sits above
// block_start_line so the normal slice skips it; when eval_doc_line is set
// it is evaluated by exact line. The caller owns the preamble layout and
// passes the line, so this stays correct if that layout changes.
interp_session_eval_current_root := proc(session: InterpSession, mut lp: LoadedProgram, block_start_line: U32, eval_doc_line: Bool, doc_init_line: U32) {
    ref root : ProgramUnit = lp.units[lp.units.len() - 1]
    ref iu : ImportUnit = lp.ctx.imported[root.path]
    if eval_doc_line { interp_eval_exact_line(session, lp, iu.ast, doc_init_line) }
    start_idx := interp_first_stmt_at_line(iu.ast, block_start_line)
    interp_eval_program_slice(session, lp, iu.ast, start_idx, iu.ast.children.len().sub(start_idx))
    interp_reset_control_flow(lp.ctx)
}

interp_session_eval_current_tail := proc(session: InterpSession, mut lp: LoadedProgram, start_idx: USize, count: USize) {
    ref root : ProgramUnit = lp.units[lp.units.len() - 1]
    ref iu : ImportUnit = lp.ctx.imported[root.path]
    interp_eval_program_slice(session, lp, iu.ast, start_idx, count)
    interp_reset_control_flow(lp.ctx)
}

// Per-file interpreter entrypoint (rstil-style): uses the canonical per-file
// ASTs stored in lp.ctx.imported, but preserves the original overall
// registration/eval ordering.
priv interpret_units := proc(mut lp: LoadedProgram, user_argv: Vec(Str), fwd_path: Str) returns I32 {
    // Ensure codegen_lp() is available throughout interpretation so
    // interpreter helpers can read shared Context fields (#177/#178).
    mut session := InterpSession()
    interp_session_start(session, user_argv)
    start_rc := interp_session_prepare_context(session, lp, fwd_path)
    if start_rc.eq(0).not() {
        interp_session_free(session)
        return start_rc
    }
    interp_session_eval_core_once(session, lp)
    interp_session_eval_user_units(session, lp)

    // Run tests (scan per-file user ASTs).  Picks up both top-level
    // test() decls and test() decls inside struct/enum namespaces so
    // tests can live next to the code they exercise.
    if lp.run_tests {
        mut test_count : I32 = 0
        mut pass_count : I32 = 0
        for u : ProgramUnit in lp.units {
            ref iu : ImportUnit = lp.ctx.imported[u.path]
            for stmt : Expr in iu.ast.children {
                if is_func_decl(stmt) {
                    switch stmt.children[0].node_type {
                    case NodeType.FuncDef(fd):
                        if fd.func_type.is(FuncType.Test) {
                            switch stmt.node_type {
                            case NodeType.Decl(dd):
                                test_count++
                                test_scope := scope_new(session.global)
                                context_enter_file(lp.ctx, u.path)
                                eval_body(test_scope, stmt.children[0].children[0], lp.ctx)
                                scope_free(own test_scope)
                                pass_count++
                                eprint_single("  pass: ")
                                eprint_single(dd.name)
                                eprint_single("\n")
                            case:
                            }
                        }
                    case:
                    }
                }
                if stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0)) {
                    ref rhs : Expr = stmt.children[0]
                    if rhs.node_type.is(NodeType.StructDef).or(rhs.node_type.is(NodeType.EnumDef)) {
                        switch stmt.node_type {
                        case NodeType.Decl(sdd):
                            ref ns : Vec(Declaration) = def_ns_decls(rhs)
                            for nsd : Declaration in ns {
                                ref nsfdef : Expr = nsd.default_value
                                if nsfdef.is_null() { continue }
                                switch nsfdef.node_type {
                                case NodeType.FuncDef(nsfd):
                                    if nsfd.func_type.is(FuncType.Test).not() { continue }
                                    test_count++
                                    test_scope := scope_new(session.global)
                                    context_enter_file(lp.ctx, u.path)
                                    eval_body(test_scope, nsfdef.children[0], lp.ctx)
                                    scope_free(own test_scope)
                                    pass_count++
                                    eprint_single("  pass: ")
                                    eprint_single(sdd.name)
                                    eprint_single(".")
                                    eprint_single(nsd.name)
                                    eprint_single("\n")
                                case:
                                }
                            }
                        case:
                        }
                    }
                }
            }
        }
        if test_count == 0 {
            eprint_single("no tests found\n")
        } else {
            eprint_single(pass_count.to_str())
            eprint_single("/")
            eprint_single(test_count.to_str())
            eprint_single(" tests passed\n")
        }
        if pass_count.eq(test_count).not() { exit(1) }
    }

    // In needs_main mode, call main() (same logic as interpret()).  When
    // run_tests is set, tests are the entry points -- skip main() so a
    // mode cli/gui file with inline test() decls runs only its tests.
    if lp.run_tests.not() { if lp.cur_mode.is_null().not() { if lp.cur_mode.needs_main {
        ref main_slot : Dynamic = scope_get(session.global, "main")!
        if main_slot.is_null() {
            eprint_single(lp.path)
            eprint_single(": error: this mode requires a 'main' proc\n")
            exit(1)
        }
        ref main_raw : Dynamic = main_slot
        ref func_def : Expr = callable_raw_func_def(main_raw)
            switch func_def.node_type {
            case NodeType.FuncDef(fd):
                nparam := fd.params.len()
                vi := fd.variadic_index
                ref body : Expr = func_def.children[0]
                main_scope := scope_new(session.global)

                if nparam > 0 {
                    mut fixed := nparam
                    if vi >= 0 {
                        fixed = nparam - 1
                        if session.user_argc < fixed {
                            eprint_single("error: main expects at least ")
                            eprint_single(fixed.to_str())
                            eprint_single(" argument(s), got ")
                            eprint_single(session.user_argc.to_str())
                            eprint_single("\n")
                            exit(1)
                        }
                    } else {
                        if session.user_argc.eq(nparam).not() {
                            eprint_single("error: main expects ")
                            eprint_single(nparam.to_str())
                            eprint_single(" argument(s), got ")
                            eprint_single(session.user_argc.to_str())
                            eprint_single("\n")
                            exit(1)
                        }
                    }
                    mut argi : I32 = 0
                    for pi in 0..nparam {
                        ref param : Declaration = fd.params[pi]
                        if pi.to_i64() == vi.cast(I64) {
                            va_count := session.user_argc - fixed
                            // Resolve width aliases (USize/UPtr) to the concrete
                            // primitive so build_argv_array's Array name, element
                            // stride, and raw storage all use the same
                            // per-build width as the rest of the compiler.
                            va_elem := resolve_type_alias(lp.ctx.scope, fd.params[vi.to_usize()].explicit_type).clone()
                            arr : Dynamic = build_argv_array(user_argv, argi.to_usize(), va_count, va_elem, lp.ctx)
                            ref va_array_binding : TypeBinding = lp.ctx.scope.get_binding(format("Array__", va_elem))
                            if va_array_binding.is_null() { panic("missing variadic Array type for ", va_elem) }
                            scope_set_raw_owned(main_scope, param.name, arr, Type.Struct(va_array_binding.name.clone()), param.own_type, lp.ctx)
                            argi = argi + va_count.to_i32()
                        } else {
                            raw : Dynamic = parse_cli_arg(user_argv[argi.to_usize()], param.explicit_type, lp.ctx)
                            scope_set_raw_owned(main_scope, param.name, raw, param.til_type, param.own_type, lp.ctx)
                            argi++
                        }
                    }
                } else if session.user_argc > 0 {
                    eprint_single("error: main expects no arguments, got ")
                    eprint_single(session.user_argc.to_str())
                    eprint_single("\n")
                    exit(1)
                }

                eval_body(main_scope, body, lp.ctx)
                scope_free(own main_scope)
            case:
                UNREACHABLE()
            }
    } } }

    interp_session_finish_context(lp)
    interp_session_free(session)
    return 0
}

cmd_interpret := proc(lp: LoadedProgram, user_argv: Vec(Str)) returns I32 {
    mut interpret_fwd_path := ""
    mut result : I32 = 0
    if lp.link_c_paths.len() > 0 {
        system_cmd("mkdir -p tmp")
        interpret_fwd_path = format("tmp/ffi_", clock_ms().to_str(), "_forward.h")
        result = build_forward_header_lp(interpret_fwd_path, lp)
    }
    if result == 0 {
        result = interpret_units(lp, user_argv, interpret_fwd_path)
    }
    return result
}

// --- FFI dispatch and ext-function call handling (moved here from
// src/self/dispatch.til). Routes interpreter calls to builtins
// (the dispatch_map) and to libffi-backed ext_func/ext_proc calls. ---

priv ExtStr := struct {
    ref data : U8 = NULL
    count : USize = 0
    cap : USize = 0
}

FFIEntry := struct {
    ref fn : U8 = NULL
    ref return_type : Str = NULL
    nparam : USize = 0
    ref param_shallows : U8 = NULL
    ref param_dynamics : U8 = NULL
    return_is_shallow := false
    return_is_ref := false
    ref cif : ffi_cif = NULL
    ref arg_types : Dynamic = NULL
}

ExprPtrBox := struct {
    ref ptr : Expr = NULL
}

FFITypePtrBox := struct {
    ref ptr : ffi_type = NULL
}

// Reset all FFI state so a fresh scan can run.
ffi_reset := proc(ctx: Context) {
    if ctx.ffi_loaded.or(ctx.ffi_map_inited).or(ctx.ffi_type_cache_inited) {
        ffi_cleanup(ctx)
    }
    // Always ensure struct defs map exists.
    ctx.ffi_struct_defs = Map(Str, ExprPtrBox).new()
}

// libffi exposes its primitive ffi_type descriptors as global symbols
// (ffi_type_uint8, ffi_type_sint64, ...). Resolve one by name into a
// ref. Replaces a former family of ten near-identical
// ffi_type_<t>_ref() one-liner accessors.
priv ffi_type_ref := func(name: Str) returns ref ffi_type {
    return to_ptr(ffi_global_symbol(name))
}

priv ffi_alloc_cif := func() returns Dynamic { return malloc(ffi_cif.size()) }

// ffi_abi is a per-architecture C enum and FFI_DEFAULT_ABI's VALUE
// differs per arch (vendor/libffi/src/*/ffitarget.h). The binding
// constant FFI_DEFAULT_ABI=2 is only correct for the x86-64 family
// (linux/mac FFI_UNIX64=2, mingw FFI_GNUW64=2). On aarch64 the enum
// is FFI_SYSV=1, FFI_WIN64=2 -- so passing 2 selected the
// Windows-on-ARM calling convention for every interpreter FFI call: a
// near-miss on linux-arm64 (til's pointer-heavy signatures happen to
// marshal identically) and memory corruption on darwin-arm64, whose
// variadic/stack rules diverge from WIN64 (issue #25). Resolve the
// abi from host_arch() -- the compile-time arch of THIS binary, which
// is what its linked libffi was built for (and, unlike uname or
// detect_current_target, free: this runs once per ext_func
// registration, and detect_current_target's two uname spawns here
// doubled the whole suite's wall time). Panic on arches whose value
// has not been audited against ffitarget.h yet, so a new native host
// cannot silently inherit a wrong ABI.
priv ffi_host_default_abi := proc() returns I32 {
    arch := host_arch()
    if arch == "x64" { return FFI_DEFAULT_ABI }
    if arch == "arm64" { return 1 }
    panic(__LOC__, "FFI_DEFAULT_ABI not audited for this arch; add its value from vendor/libffi/src/<arch>/ffitarget.h")
    return 0
}

priv ffi_cif_rtype_is_struct := func(cif: ffi_cif) returns Bool {
    ref rt : ffi_type = cif.rtype
    return rt.type == FFI_TYPE_STRUCT.to_u16()
}

// These four are side-effecting (dlopen mutates the loader, dlerror clears
// pending state, stderr_print writes) so they MUST be ext_proc, not ext_func:
// the constfolder folds ext_funcs (issue #136) but never procs, and folding a
// side-effecting call runs the effect at COMPILE time. When ffi_init_user_so's
// `stderr_print(format("error: dlopen failed: ", ffi_last_error(), "\n"))` was
// declared with ext_funcs the constfolder evaluated it during a normal build --
// printing a bogus "error: dlopen failed:" and then baking the empty
// ffi_last_error() in, dropping the real runtime diagnostic (issue #283).
// ffi_user_symbol/ffi_global_symbol stay ext_func: their `ref U8` return is
// already never folded (try_eval_call bails on ref returns).
ffi_load_global_lib := ext_proc(soname: Str) returns shallow Bool {}
ffi_open_user_so := ext_proc(path: Str) returns shallow Bool {}
ffi_close_user_so := ext_proc() {}
ffi_user_symbol := ext_func(name: Str) returns ref U8 {}
ffi_global_symbol := ext_func(name: Str) returns ref U8 {}
ffi_last_error := ext_proc() returns Str {}
stderr_print := ext_proc(msg: Str) returns shallow I32 {}
unlink_path := ext_proc(path: Str) {}
process_id := ext_proc() returns shallow I32 {}
// ext_proc, NOT ext_func: this reads a build-time property of the RUNNING
// binary, so it must be evaluated at runtime. As an ext_func the constfolder
// folds it -- and bin/til_asan is built by the non-ASAN bin/til, so the fold
// bakes in `false` and the ASAN flag never reaches the FFI compile (#299).
til_built_with_asan := ext_proc() returns shallow Bool {}

priv ffi_dlsym := func(name: Str) returns ref U8 {
    ref fn : U8 = ffi_user_symbol(name)
    if fn.is_null().not() {
        return fn
    }
    return ffi_global_symbol(name)
}

priv ffi_init_link_libs := proc(link_flags: Str) {
    if link_flags.is_null() {
        return
    }
    // dlopen resolves "-lfoo" flags by soname; the shared-lib suffix is
    // host-dependent (this runs in the compiler, on the build host).
    mut so_ext := ".so"
    if host_os() == "macos" { so_ext = ".dylib" }
    mut i : USize = 0
    while i + 1 < link_flags.len() {
        if link_flags.unsafe_get(i).eq(45).and(link_flags.unsafe_get(i + 1).eq(108)) {
            i = i + 2
            start := i
            while i < link_flags.len() {
                if link_flags.unsafe_get(i) == 32 {
                    break
                }
                i++
            }
            if i > start {
                lib := link_flags.substr(start, i - start)
                soname := format("lib", lib, so_ext)
                ffi_load_global_lib(soname)
            }
        } else {
            i++
        }
    }
}

priv ffi_init_user_so := proc(fwd_path: Str, user_c_path: Str, ext_c_path: Str, link_flags: Str, mut so_path_out: Str) returns I32 {
    so_path_out = Str(c_str = NULL, count = 0, cap = 0)
    if user_c_path.len() == 0 { return 0 }

    dot_str := "."
    slash := ext_c_path.rfind("/")
    mut ext_dir := dot_str
    if slash >= 0 {
        ext_dir = ext_c_path.substr(0, slash.to_usize())
    }

    so_path_out = format("tmp/ffi_", process_id().to_str(), ".so")
    system_cmd("mkdir -p tmp")

    mut lf := ""
    if link_flags.is_null().not() {
        lf = link_flags
    }
    // #299: match the interpreter's own sanitizer. Under bin/til_asan the user
    // .so must be ASAN-instrumented too, so its libc allocator IS the ASAN
    // allocator -- otherwise an interpreter-side calloc that libffi routes to
    // this .so's (non-ASAN) calloc returns brk-heap memory that the
    // interpreter's ASAN free() then rejects as a bad-free.
    mut san := ""
    if til_built_with_asan() { san = " -fsanitize=address -fno-omit-frame-pointer" }
    // -fsigned-char: same plain-char-is-signed contract as every other
    // til compile (see ext.h's I8 note; issue #25).
    cmd := format("cc -Wall -Wextra -fsigned-char -shared -fPIC", san, " -I", ext_dir,
        " -include ", fwd_path,
        " -o ", so_path_out,
        " ", user_c_path, lf)
    rc := system_cmd(cmd)
    if rc != 0 {
        stderr_print(format("error: failed to compile FFI library '", user_c_path, "'\n"))
        return 1
    }
    if ffi_open_user_so(so_path_out).not() {
        stderr_print(format("error: dlopen failed for '", so_path_out, "': ", ffi_last_error(), "\n"))
        return 1
    }
    return 0
}

priv ffi_init_struct_defs := func(program: Expr, ctx: Context) {
    ctx.ffi_struct_defs = Map(Str, ExprPtrBox).new()
    ffi_init_struct_defs_append(program, ctx)
}

// Append struct defs found in program into ctx.ffi_struct_defs (does not reset).
ffi_init_struct_defs_append := func(program: Expr, ctx: Context) {
    for stmt : Expr in program.children {
        if stmt.node_type.is(NodeType.Decl).not().or(stmt.children.len().eq(0)) {
            continue
        }
        ref sdef : Expr = stmt.children[0]
        if sdef.node_type.is(NodeType.StructDef).not() {
            continue
        }
        switch stmt.node_type {
        case NodeType.Decl(dd):
            key := Str(c_str = dd.name.c_str, count = dd.name.count, cap = CAP_VIEW)
            box := ExprPtrBox(ptr = sdef)
            ctx.ffi_struct_defs.set(key, own box)
        case:
        }
    }
}

priv uptr_ffi_type := func(ctx: Context) returns ref ffi_type {
    ref uptr_name : Str = resolve_type_alias(ctx.scope, "UPtr")
    if uptr_name == "U32" { return ffi_type_ref("ffi_type_uint32") }
    return ffi_type_ref("ffi_type_uint64")
}

priv usize_ffi_type := func(ctx: Context) returns ref ffi_type {
    ref usize_name : Str = resolve_type_alias(ctx.scope, "USize")
    if usize_name == "U32" { return ffi_type_ref("ffi_type_uint32") }
    return ffi_type_ref("ffi_type_uint64")
}

priv narrow_bool_arg := proc(s: Scope, e: Expr, ctx: Context) returns Bool {
    return eval_bool_arg(s, e, ctx)
}

priv eval_i64_arg := proc(s: Scope, e: Expr, ctx: Context) returns I64 {
    raw_type := scalar_raw_source_type(s, e, ctx)
    return raw_to_i64(raw_type, eval_scalar_arg_word(s, e, raw_type, ctx), ctx)
}

priv eval_u64_arg := proc(s: Scope, e: Expr, ctx: Context) returns U64 {
    raw_type := scalar_raw_source_type(s, e, ctx)
    return raw_to_u64(raw_type, eval_scalar_arg_word(s, e, raw_type, ctx), ctx)
}

// Dispatch and call results are raw value bytes.
priv dispatch_enum_size := func(name: Str, ctx: Context) returns USize {
    mut size : USize = ctx_total_size(name, ctx)
    if size < 8 { size = 8 }
    ref enum_def : Expr = lookup_interp_type_def(name, ctx)
    switch enum_def.node_type {
    case NodeType.EnumDef(ed):
        for i in 0..ed.variants.len() {
            payload_type := enum_variant_type(enum_def, i.to_i32())
            if payload_type.len() > 0 {
                payload_end : USize = ENUM_PAYLOAD_OFFSET + container_elem_size(payload_type, ctx)
                if size < payload_end { size = payload_end }
            }
        }
    case:
        panic("dispatch enum type is not registered: ", name)
    }
    return size
}

dispatch_result_alloc := func(t: Type, ctx: Context) returns Dynamic {
    mut size : USize = 0
    switch t {
    case Type.None:
        size = 1
    case Type.Primitive(prim):
        mut align : USize = 0
        builtin_primitive_size_align(prim, size, align)
    case Type.Struct(name):
        size = ctx_total_size(name, ctx)
    case Type.Enum(name):
        size = dispatch_enum_size(name, ctx)
    case Type.Dynamic:
        size = Dynamic.size()
    case Type.FuncPtr:
        size = Dynamic.size()
    case Type.FuncPtrSig:
        size = Dynamic.size()
    case Type.Body:
        size = Dynamic.size()
    case Type.Custom(name):
        return dispatch_result_alloc(type_from_name_init(name, ctx.scope), ctx)
    case:
        panic("cannot allocate dispatch result for type ", til_type_name_c(t))
    }
    raw : Dynamic = EvalHeap.heap_alloc(size)
    memset(raw, 0, size)
    return raw
}

priv dispatch_write_str := func(result: Dynamic, data: Dynamic, len: USize, ctx: Context) {
    if len == 0 {
        write_ptr(result, "".c_str)
        str_write_count_cap(result, 0, CAP_LIT, ctx)
        return
    }
    copy : Dynamic = EvalHeap.heap_alloc(len.add(1))
    memcpy(copy, data, len)
    memset(ptr_add(copy, len), 0, 1)
    write_ptr(result, copy)
    str_write_count_cap(result, len, len, ctx)
}

// and/or are core_lazy_funcs: the handler drives argument evaluation, so
// laziness is direct -- the second operand is only evaluated when the first
// does not already decide the result. (Parse-time calls were spliced to
// matches by the loader; what dispatches here are residual calls, e.g. the
// desugarer's synthesized chains under the interpreter.)
priv h_Bool_and := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    av := narrow_bool_arg(s, e.children[1], ctx)
    if av.not() {
        write_bool(r, false)
        return true
    }
    write_bool(r, narrow_bool_arg(s, e.children[2], ctx))
    return true
}

priv h_Bool_or := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    av := narrow_bool_arg(s, e.children[1], ctx)
    if av {
        write_bool(r, true)
        return true
    }
    write_bool(r, narrow_bool_arg(s, e.children[2], ctx))
    return true
}

priv h_Bool_not := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    bv := narrow_bool_arg(s, e.children[1], ctx)
    write_bool(r, not(bv))
    return true
}

// Bool.eq core_func handler (dispatch name is the flat "Bool_eq"): a
// core_func is not FFI-registered, so the interpreter evaluates it here.
// The inner .eq() is itself the core_func, lowered inline in this compiled
// handler -- no handler recursion.
priv h_Bool_eq := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    av := narrow_bool_arg(s, e.children[1], ctx)
    bv := narrow_bool_arg(s, e.children[2], ctx)
    write_bool(r, av.eq(bv))
    return true
}

priv h_U8_from_i64 := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    write_u8(r, eval_i64_arg(s, e.children[1], ctx).to_u8())
    return true
}

priv h_I16_from_i64 := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    write_i16(r, eval_i64_arg(s, e.children[1], ctx).to_i16())
    return true
}

priv h_U16_from_i64 := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    write_u16(r, eval_i64_arg(s, e.children[1], ctx).to_u16())
    return true
}

priv h_I32_from_i64 := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    write_i32(r, eval_i64_arg(s, e.children[1], ctx).to_i32())
    return true
}

priv h_F32_from_i64 := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    write_f32(r, eval_i64_arg(s, e.children[1], ctx).to_f32())
    return true
}

priv h_U32_from_i64 := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    write_u32(r, eval_i64_arg(s, e.children[1], ctx).to_u32())
    return true
}

// Issue #212: integer reinterpret or same-signedness widening cast. The
// typer set this FCall's til_type to the target type T; read the operand's
// raw bits and write them at the target width.
priv h_cast := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    ref src_expr : Expr = e.children[1]
    src : Dynamic = eval_expr_raw(s, src_expr, ctx)
    tn := til_type_name_c(e.til_type())
    if (tn == "Fn").or(tn == "Body") {
        ref stored_ref : Dynamic = deref(src)
        mut stored : Dynamic = stored_ref
        if src_expr.til_type().is(Type.Dynamic) {
            stored = callable_storage_clone(stored)
        } else {
            write_ptr(src, NULL)
        }
        write_ptr(r, stored)
        raw_result_drop(src_expr.til_type(), src, expr_raw_is_ref(s, src_expr, ctx), ctx)
        return true
    }
    src_type := scalar_raw_source_type(s, src_expr, ctx)
    // Collapse the eval to an inline word first: raw_to_u64 is word-based,
    // and the pre-word raw_arg_pointer form fed it an ADDRESS.
    raw := raw_to_u64(src_type, scalar_word_of_raw(s, src_expr, src, src_type, ctx), ctx)
    if tn == "I8"  { write_i8(r, raw.cast(I64).to_i8()); return true }
    if tn == "U8"  { write_u8(r, raw.cast(I64).to_u8()); return true }
    if tn == "I16" { write_i16(r, raw.cast(I64).to_i16()); return true }
    if tn == "U16" { write_u16(r, raw.cast(I64).to_u16()); return true }
    if tn == "I32" { write_i32(r, raw.to_i32()); return true }
    if tn == "U32" { write_u32(r, raw.to_u32()); return true }
    if tn == "I64" { write_i64(r, raw.cast(I64)); return true }
    if tn == "U64" { write_u64(r, raw); return true }
    UNREACHABLE()
    return false
}

priv h_print_single := proc(s: Scope, e: Expr, _r: Dynamic, ctx: Context) returns Bool {
    arg := eval_str_owned(s, e.children[1], ctx)
    // A const-fold eval is speculative and must emit no program output: if a
    // fold candidate reaches a print (e.g. through panic's message on a
    // failure branch the comptime inputs hit), swallow it. The fold itself is
    // abandoned via the abort in h_exit and the call is left for runtime.
    if ctx.constfold_active.not() { print_single(arg) }
    return true
}

priv h_print_flush := proc(_s: Scope, _e: Expr, _r: Dynamic, ctx: Context) returns Bool {
    if ctx.constfold_active.not() { print_flush() }
    return true
}

priv h_exit := proc(s: Scope, e: Expr, _r: Dynamic, ctx: Context) returns Bool {
    // exit is the single primitive that terminates the process, so it is the
    // single interception point for the const-folder. When a fold eval reaches
    // it (panic/TODO/UNREACHABLE all route here, as does a bare exit), don't
    // kill the build: set constfold_aborted and unwind like an early return
    // (propagated through eval_body/eval_while). try_eval_call then leaves the
    // call for runtime, or reports it for a macro. No name list required.
    if ctx.constfold_active {
        ctx.constfold_aborted = true
        return true
    }
    code := eval_i64_arg(s, e.children[1], ctx)
    exit(code)
    return true
}

priv h_readfile := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    path := eval_str_owned(s, e.children[1], ctx)
    content := File.readfile(path)
    dispatch_write_str(r, content.c_str, content.count, ctx)
    return true
}

priv h_writefile := proc(s: Scope, e: Expr, _r: Dynamic, ctx: Context) returns Bool {
    path := eval_str_owned(s, e.children[1], ctx)
    content := eval_str_owned(s, e.children[2], ctx)
    File.writefile(path, content)
    return true
}

priv h_spawn_cmd := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    cmd := eval_str_owned(s, e.children[1], ctx)
    write_i64(r, spawn_cmd(cmd))
    return true
}

priv h_dyn_has_method := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    method := eval_str_owned(s, e.children[2], ctx)
    write_bool(r, ns_get(type_name, method, ctx).is_null().not())
    return true
}

priv h_dyn_fn := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    method := eval_str_owned(s, e.children[2], ctx)
    ref stored : Dynamic = ns_get(type_name, method, ctx)
    if stored.is_null() {
        panic("dyn_fn: unknown ", type_name, ".", method)
    }
    write_ptr(r, callable_storage_clone(deref(stored)))
    return true
}

priv h_dyn_size_of := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    sz := get_elem_size(s, type_name, e, ctx)
    if ctx.target_usize_bytes == 4 { write_u32(r, sz.to_u32()) }
    else { write_u64(r, sz.to_u64()) }
    return true
}

// Write an owned raw Str copying `src`'s bytes. Used by the
// struct_field_* handlers: a borrowed view into the AST does not survive
// being stored into a Declaration field and pushed into a Vec (the
// header is copied but the bytes must outlive the AST borrow), so the
// introspection primitives hand back owned copies. Issue #56/#58.
str_copy_into := func(result: Dynamic, src: Str, ctx: Context) {
    n := src.count
    if n == 0 {
        // A normalized empty Str uses CAP_LIT and no owned buffer.
        dispatch_write_str(result, src.c_str, 0, ctx)
        return
    }
    buf : Dynamic = malloc(n.add(1))
    memcpy(buf, src.c_str, n)
    ref mut term : U8 = ptr_add(buf, n)
    term = 0
    write_ptr(result, buf)
    str_write_count_cap(result, n, n, ctx)
}

priv eval_str_owned := proc(s: Scope, arg: Expr, ctx: Context) returns Str {
    raw : Dynamic = eval_expr_raw(s, arg, ctx)
    value_raw : Dynamic = raw_arg_pointer(s, arg, raw, ctx)
    ref value : Str = to_ptr(value_raw)
    view := Str(c_str = value.c_str, count = str_count_at(value_raw, ctx), cap = CAP_VIEW)
    result := view.clone()
    raw_result_drop(arg.til_type(), raw, expr_raw_is_ref(s, arg, ctx), ctx)
    return result
}

// Look up a registered struct type's AST node by name, erroring out if
// the name is unknown or not a struct. Shared by the struct_field_*
// introspection handlers (issue #56/#58).
priv interp_lookup_struct := proc(s: Scope, e: Expr, type_name: Str, who: Str, ctx: Context) returns ref Expr {
    // A miss means `who` asked to introspect a type name with no registered
    // def -- a not-found error. On success scope_get returns a non-null cell,
    // so no guard is needed past the catch.
    ref tc : Dynamic = scope_get(s, type_name)?
    catch (knf: KeyNotFound) {
        interp_error(e, format(who, ": type '", type_name, "' not found"), ctx)
        exit(1)
    }
    ref raw : Dynamic = tc
    ref node : Expr = callable_raw_func_def(raw)
        if node.node_type.is(NodeType.StructDef).not() {
            interp_error(e, format(who, ": '", type_name, "' is not a struct"), ctx)
            exit(1)
        }
        return node
}

priv h_struct_field_count := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    ref node : Expr = interp_lookup_struct(s, e, type_name, "struct_field_count", ctx)
    switch node.node_type {
    case NodeType.StructDef(sd):
        write_i64(r, sd.fields.len().to_i64())
    case:
        UNREACHABLE()
    }
    return true
}

// Decode e.children[2] (the index argument shared by every struct_field_*
// / enum_variant_* / func_sig_* handler) as a USize. The arg is a
// til-side integer value (commonly an I64 literal); take the low 32
// bits as the slot index.
priv eval_index_arg := proc(s: Scope, e: Expr, ctx: Context) returns USize {
    return eval_u64_arg(s, e.children[2], ctx).to_u32()
}

priv h_struct_field_name := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    idx := eval_index_arg(s, e, ctx)
    ref node : Expr = interp_lookup_struct(s, e, type_name, "struct_field_name", ctx)
    switch node.node_type {
    case NodeType.StructDef(sd):
        if idx >= sd.fields.len() {
            interp_error(e, "struct_field_name: index out of bounds", ctx)
            exit(1)
        }
        ref fd : Declaration = sd.fields[idx]
        str_copy_into(r, fd.name, ctx)
    case:
        UNREACHABLE()
    }
    return true
}

priv h_struct_field_is_mut := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    idx := eval_index_arg(s, e, ctx)
    ref node : Expr = interp_lookup_struct(s, e, type_name, "struct_field_is_mut", ctx)
    switch node.node_type {
    case NodeType.StructDef(sd):
        if idx >= sd.fields.len() {
            interp_error(e, "struct_field_is_mut: index out of bounds", ctx)
            exit(1)
        }
        ref fd : Declaration = sd.fields[idx]
        if fd.is_mut { write_i64(r, 1) } else { write_i64(r, 0) }
    case:
        UNREACHABLE()
    }
    return true
}

priv h_struct_field_type := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    idx := eval_index_arg(s, e, ctx)
    ref node : Expr = interp_lookup_struct(s, e, type_name, "struct_field_type", ctx)
    switch node.node_type {
    case NodeType.StructDef(sd):
        if idx >= sd.fields.len() {
            interp_error(e, "struct_field_type: index out of bounds", ctx)
            exit(1)
        }
        ref fd : Declaration = sd.fields[idx]
        str_copy_into(r, fd.explicit_type, ctx)
    case:
        UNREACHABLE()
    }
    return true
}

// Look up a registered enum type's AST node by name, erroring out if
// the name is unknown or not an enum. Shared by the enum_variant_*
// introspection handlers (issue #57/#58).
priv interp_lookup_enum := proc(s: Scope, e: Expr, type_name: Str, who: Str, ctx: Context) returns ref Expr {
    // A miss means `who` asked to introspect a type name with no registered
    // def -- a not-found error. On success scope_get returns a non-null cell,
    // so no guard is needed past the catch.
    ref tc : Dynamic = scope_get(s, type_name)?
    catch (knf: KeyNotFound) {
        interp_error(e, format(who, ": type '", type_name, "' not found"), ctx)
        exit(1)
    }
    ref raw : Dynamic = tc
    ref node : Expr = callable_raw_func_def(raw)
        if node.node_type.is(NodeType.EnumDef).not() {
            interp_error(e, format(who, ": '", type_name, "' is not an enum"), ctx)
            exit(1)
        }
        return node
}

priv h_enum_variant_count := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    ref node : Expr = interp_lookup_enum(s, e, type_name, "enum_variant_count", ctx)
    switch node.node_type {
    case NodeType.EnumDef(ed):
        write_i64(r, ed.variants.len().to_i64())
    case:
        UNREACHABLE()
    }
    return true
}

priv h_enum_variant_name := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    idx := eval_index_arg(s, e, ctx)
    ref node : Expr = interp_lookup_enum(s, e, type_name, "enum_variant_name", ctx)
    switch node.node_type {
    case NodeType.EnumDef(ed):
        if idx >= ed.variants.len() {
            interp_error(e, "enum_variant_name: index out of bounds", ctx)
            exit(1)
        }
        ref vn : Str = ed.variants[idx]
        str_copy_into(r, vn, ctx)
    case:
        UNREACHABLE()
    }
    return true
}

priv h_enum_variant_has_payload := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    idx := eval_index_arg(s, e, ctx)
    ref node : Expr = interp_lookup_enum(s, e, type_name, "enum_variant_has_payload", ctx)
    switch node.node_type {
    case NodeType.EnumDef(ed):
        if idx >= ed.variants.len() {
            interp_error(e, "enum_variant_has_payload: index out of bounds", ctx)
            exit(1)
        }
        if ed.payload_types.has(idx.to_i64()) {
            ref pt : Str = ed.payload_types[idx.to_i64()]
            if pt.len() > 0 { write_i64(r, 1) } else { write_i64(r, 0) }
        } else {
            write_i64(r, 0)
        }
    case:
        UNREACHABLE()
    }
    return true
}

priv h_enum_variant_payload_type := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    idx := eval_index_arg(s, e, ctx)
    ref node : Expr = interp_lookup_enum(s, e, type_name, "enum_variant_payload_type", ctx)
    switch node.node_type {
    case NodeType.EnumDef(ed):
        if idx >= ed.variants.len() {
            interp_error(e, "enum_variant_payload_type: index out of bounds", ctx)
            exit(1)
        }
        if ed.payload_types.has(idx.to_i64()) {
            ref pt : Str = ed.payload_types[idx.to_i64()]
            str_copy_into(r, pt, ctx)
        } else {
            str_copy_into(r, "", ctx)
        }
    case:
        UNREACHABLE()
    }
    return true
}

// Look up a registered FuncSig type's bodyless FuncDef node by name,
// erroring out if the name is unknown or not a function signature.
// Shared by the func_sig_* introspection handlers (issue #58).
priv interp_lookup_funcsig := proc(s: Scope, e: Expr, type_name: Str, who: Str, ctx: Context) returns ref Expr {
    // A miss means `who` asked to introspect a type name with no registered
    // def -- a not-found error. On success scope_get returns a non-null cell,
    // so no guard is needed past the catch.
    ref tc : Dynamic = scope_get(s, type_name)?
    catch (knf: KeyNotFound) {
        interp_error(e, format(who, ": type '", type_name, "' not found"), ctx)
        exit(1)
    }
    ref raw : Dynamic = tc
    ref node : Expr = callable_raw_func_def(raw)
        if node.node_type.is(NodeType.FuncDef).not() {
            interp_error(e, format(who, ": '", type_name, "' is not a function signature"), ctx)
            exit(1)
        }
        return node
}

priv h_func_sig_param_count := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    ref node : Expr = interp_lookup_funcsig(s, e, type_name, "func_sig_param_count", ctx)
    switch node.node_type {
    case NodeType.FuncDef(fd):
        write_i64(r, fd.params.len().to_i64())
    case:
        UNREACHABLE()
    }
    return true
}

priv h_func_sig_param_type := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    idx := eval_index_arg(s, e, ctx)
    ref node : Expr = interp_lookup_funcsig(s, e, type_name, "func_sig_param_type", ctx)
    switch node.node_type {
    case NodeType.FuncDef(fd):
        if idx >= fd.params.len() {
            interp_error(e, "func_sig_param_type: index out of bounds", ctx)
            exit(1)
        }
        ref pd : Declaration = fd.params[idx]
        str_copy_into(r, pd.explicit_type, ctx)
    case:
        UNREACHABLE()
    }
    return true
}

priv h_func_sig_return_count := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    ref node : Expr = interp_lookup_funcsig(s, e, type_name, "func_sig_return_count", ctx)
    switch node.node_type {
    case NodeType.FuncDef(fd):
        if fd.return_type.len() > 0 { write_i64(r, 1) } else { write_i64(r, 0) }
    case:
        UNREACHABLE()
    }
    return true
}

priv h_func_sig_return_type := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    idx := eval_index_arg(s, e, ctx)
    ref node : Expr = interp_lookup_funcsig(s, e, type_name, "func_sig_return_type", ctx)
    switch node.node_type {
    case NodeType.FuncDef(fd):
        if idx.neq(0).or(fd.return_type.len().eq(0)) {
            interp_error(e, "func_sig_return_type: index out of bounds", ctx)
            exit(1)
        }
        str_copy_into(r, fd.return_type, ctx)
    case:
        UNREACHABLE()
    }
    return true
}

priv h_func_sig_throw_count := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    ref node : Expr = interp_lookup_funcsig(s, e, type_name, "func_sig_throw_count", ctx)
    switch node.node_type {
    case NodeType.FuncDef(fd):
        write_i64(r, fd.throw_types.len().to_i64())
    case:
        UNREACHABLE()
    }
    return true
}

priv h_func_sig_throw_type := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    idx := eval_index_arg(s, e, ctx)
    ref node : Expr = interp_lookup_funcsig(s, e, type_name, "func_sig_throw_type", ctx)
    switch node.node_type {
    case NodeType.FuncDef(fd):
        if idx >= fd.throw_types.len() {
            interp_error(e, "func_sig_throw_type: index out of bounds", ctx)
            exit(1)
        }
        ref tt : Str = fd.throw_types[idx]
        str_copy_into(r, tt, ctx)
    case:
        UNREACHABLE()
    }
    return true
}

priv dyn_type_to_str_raw := func(type_data: Dynamic, r: Dynamic, ctx: Context) returns Bool {
        ref til_type_def : Expr = lookup_interp_type_def("Type", ctx)
        if til_type_def.is_null() {
            panic("dyn_type_to_str: Type definition not registered")
        }
        ref tag_ptr : Dynamic = type_data
        ref tag_ref : I32 = tag_ptr
        tag := tag_ref.cast(I64)
        if tag.eq(enum_variant_tag(til_type_def, "Unknown")).or(tag.eq(enum_variant_tag(til_type_def, "None"))) {
            dispatch_write_str(r, "".c_str, 0, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "I64") {
            dispatch_write_str(r, "I64".c_str, 3, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "U8") {
            dispatch_write_str(r, "U8".c_str, 2, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "I8") {
            dispatch_write_str(r, "I8".c_str, 2, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "I16") {
            dispatch_write_str(r, "I16".c_str, 3, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "U16") {
            dispatch_write_str(r, "U16".c_str, 3, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "I32") {
            dispatch_write_str(r, "I32".c_str, 3, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "U32") {
            dispatch_write_str(r, "U32".c_str, 3, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "U64") {
            dispatch_write_str(r, "U64".c_str, 3, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "F32") {
            dispatch_write_str(r, "F32".c_str, 3, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "Bool") {
            dispatch_write_str(r, "Bool".c_str, 4, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "Struct") {
            ref payload : Str = ptr_add(type_data, ENUM_PAYLOAD_OFFSET)
            dispatch_write_str(r, payload.c_str, str_count_at(ptr_add(type_data, ENUM_PAYLOAD_OFFSET), ctx), ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "StructDef") {
            dispatch_write_str(r, "StructDef".c_str, 9, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "Enum") {
            ref payload2 : Str = ptr_add(type_data, ENUM_PAYLOAD_OFFSET)
            dispatch_write_str(r, payload2.c_str, str_count_at(ptr_add(type_data, ENUM_PAYLOAD_OFFSET), ctx), ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "EnumDef") {
            dispatch_write_str(r, "EnumDef".c_str, 7, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "FuncDef") {
            dispatch_write_str(r, "FunctionDef".c_str, 11, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "FuncPtr") {
            dispatch_write_str(r, "Fn".c_str, 2, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "Body") {
            dispatch_write_str(r, "Body".c_str, 4, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "Dynamic") {
            dispatch_write_str(r, "Dynamic".c_str, 7, ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "Custom") {
            ref payload3 : Str = ptr_add(type_data, ENUM_PAYLOAD_OFFSET)
            dispatch_write_str(r, payload3.c_str, str_count_at(ptr_add(type_data, ENUM_PAYLOAD_OFFSET), ctx), ctx)
            return true
        }
        if tag == enum_variant_tag(til_type_def, "Primitive") {
            // Type.Primitive(p) carries a Primitive enum value inline at
            // ENUM_PAYLOAD_OFFSET (its tag is the first I32). Decode it to
            // the primitive's name -- mirrors the data-driven nested switch
            // that emit_dyn_type_to_str_body generates for compiled code.
            ref prim_def : Expr = lookup_interp_type_def("Primitive", ctx)
            if prim_def.is_null() {
                panic("dyn_type_to_str: Primitive definition not registered")
            }
            ref prim_tag_ref : I32 = ptr_add(type_data, ENUM_PAYLOAD_OFFSET)
            ptag := prim_tag_ref.cast(I64)
            if ptag == enum_variant_tag(prim_def, "I16") { dispatch_write_str(r, "I16".c_str, 3, ctx); return true }
            if ptag == enum_variant_tag(prim_def, "U16") { dispatch_write_str(r, "U16".c_str, 3, ctx); return true }
            if ptag == enum_variant_tag(prim_def, "I8")  { dispatch_write_str(r, "I8".c_str, 2, ctx); return true }
            if ptag == enum_variant_tag(prim_def, "U8")  { dispatch_write_str(r, "U8".c_str, 2, ctx); return true }
            if ptag == enum_variant_tag(prim_def, "U32") { dispatch_write_str(r, "U32".c_str, 3, ctx); return true }
            if ptag == enum_variant_tag(prim_def, "I32") { dispatch_write_str(r, "I32".c_str, 3, ctx); return true }
            if ptag == enum_variant_tag(prim_def, "U64") { dispatch_write_str(r, "U64".c_str, 3, ctx); return true }
            if ptag == enum_variant_tag(prim_def, "I64") { dispatch_write_str(r, "I64".c_str, 3, ctx); return true }
            if ptag == enum_variant_tag(prim_def, "F32") { dispatch_write_str(r, "F32".c_str, 3, ctx); return true }
            if ptag == enum_variant_tag(prim_def, "Bool") { dispatch_write_str(r, "Bool".c_str, 4, ctx); return true }
            panic("dyn_type_to_str: unknown Primitive tag")
        }
        return false
}

priv h_dyn_type_to_str := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    ref arg : Expr = e.children[1]
    raw : Dynamic = eval_expr_raw(s, arg, ctx)
    type_data : Dynamic = raw_arg_pointer(s, arg, raw, ctx)
    result := dyn_type_to_str_raw(type_data, r, ctx)
    if result.not() {
        ref type_tag : I32 = to_ptr(type_data)
        switch arg.node_type {
        case NodeType.Ident(type_arg_id):
            ref type_arg_hb : HeapBinding = scope_lookup_heap_binding(s, type_arg_id.ident_name())
            panic("dyn_type_to_str: invalid Type for ", type_arg_id.ident_name(), ": tag=", type_tag.to_str(), " binding=", til_type_name_c(type_arg_hb.til_type), " ref=", type_arg_hb.own_type.is(OwnType.Ref).to_str(), " borrowed=", type_arg_hb.is_borrowed.to_str())
        case:
            panic("dyn_type_to_str: invalid Type expression tag=", type_tag.to_str())
        }
    }
    raw_result_drop(arg.til_type(), raw, expr_raw_is_ref(s, arg, ctx), ctx)
    return result
}

priv h_check_cmd_status := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    write_i64(r, check_cmd_status(eval_i64_arg(s, e.children[1], ctx)))
    return true
}

priv h_sleep := proc(s: Scope, e: Expr, _r: Dynamic, ctx: Context) returns Bool {
    sleep_ms(eval_i64_arg(s, e.children[1], ctx))
    return true
}

priv h_file_mtime := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    path := eval_str_owned(s, e.children[1], ctx)
    write_i64(r, file_mtime(path))
    return true
}

priv h_str_parse_f32 := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    arg := eval_str_owned(s, e.children[1], ctx)
    write_f32(r, str_parse_f32(arg))
    return true
}

priv h_clock_ms := proc(_s: Scope, _e: Expr, r: Dynamic, _ctx: Context) returns Bool {
    write_i64(r, clock_ms())
    return true
}

priv h_get_thread_count := proc(_s: Scope, _e: Expr, r: Dynamic, _ctx: Context) returns Bool {
    write_i64(r, get_thread_count())
    return true
}

priv h_cfile_open := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    path := eval_str_owned(s, e.children[1], ctx)
    is_write := narrow_bool_arg(s, e.children[2], ctx)
    // FILE* handle: closed via cfile_close (fclose), never free()'d,
    // so it is a borrowed view from the runtime's perspective.
    write_ptr(r, cfile_open(path, is_write))
    return true
}

// til primitive/struct type name -> ffi_type, or NULL when `type_name`
// is neither a known primitive nor a registered struct.  Shared by
// shallow_ffi_type and field_ffi_type, which differ only in the
// fallback they pick for an unknown type.
priv known_ffi_type := func(type_name: Str, ctx: Context) returns ref ffi_type {
    if type_name == "I64"   { return ffi_type_ref("ffi_type_sint64") }
    if type_name == "U8"    { return ffi_type_ref("ffi_type_uint8") }
    if type_name == "I8"    { return ffi_type_ref("ffi_type_sint8") }
    if type_name == "I16"   { return ffi_type_ref("ffi_type_sint16") }
    if type_name == "U16"   { return ffi_type_ref("ffi_type_uint16") }
    if type_name == "I32"   { return ffi_type_ref("ffi_type_sint32") }
    if type_name == "U32"   { return ffi_type_ref("ffi_type_uint32") }
    if type_name == "U64"   { return ffi_type_ref("ffi_type_uint64") }
    if type_name == "USize" { return usize_ffi_type(ctx) }
    if type_name == "UPtr"  { return uptr_ffi_type(ctx) }
    if type_name == "F32"   { return ffi_type_ref("ffi_type_float") }
    if type_name == "Bool"  { return ffi_type_ref("ffi_type_uint8") }
    if ctx.ffi_struct_defs.has(type_name) {
        ref box : ExprPtrBox = ctx.ffi_struct_defs[type_name]
        return build_struct_ffi_type(box.ptr, ctx)
    }
    return NULL
}

// type_name -> ffi_type. Inverse mapping in ffi_shallow_type_info; keep
// the two in sync if a new shallow primitive type lands.  Unknown
// types are passed as opaque pointers.
priv shallow_ffi_type := func(type_name: Str, ctx: Context) returns ref ffi_type {
    ref t : ffi_type = known_ffi_type(type_name, ctx)
    if t.is_null().not() { return t }
    return ffi_type_ref("ffi_type_pointer")
}

priv field_ffi_type := func(dd: Declaration, ctx: Context) returns ref ffi_type {
    if dd.own_type.is(OwnType.Shallow).not() { return ffi_type_ref("ffi_type_pointer") }
    if dd.explicit_type.len() == 0 { return ffi_type_ref("ffi_type_sint64") }
    ref t : ffi_type = known_ffi_type(dd.explicit_type, ctx)
    if t.is_null().not() { return t }
    return ffi_type_ref("ffi_type_sint64")
}

priv build_struct_ffi_type := func(struct_def: Expr, ctx: Context) returns ref ffi_type {
    if ctx.ffi_type_cache_inited.not() {
        ctx.ffi_type_cache = Vec(FFITypePtrBox).new()
        ctx.ffi_type_cache_inited = true
    }
    switch struct_def.node_type {
    case NodeType.StructDef(bsf_sdd):
        nfields := bsf_sdd.fields.len()
        elements : Dynamic = malloc(nfields.add(1) * Dynamic.size())
        for i in 0..nfields {
            ref fd : Declaration = bsf_sdd.fields[i]
            ref ft : ffi_type = field_ffi_type(fd, ctx)
            memcpy(ptr_add(elements, i * Dynamic.size()), ft, Dynamic.size())
        }
        memset(ptr_add(elements, nfields * Dynamic.size()), 0, Dynamic.size())
        st : Dynamic = malloc(ffi_type.size())
        ref mut stp : ffi_type = to_ptr(st)
        stp.size = 0
        stp.alignment = 0
        stp.type = FFI_TYPE_STRUCT.to_u16()
        stp.elements = elements
        box := FFITypePtrBox(ptr = stp)
        ctx.ffi_type_cache.push(own box)
        return stp
    case:
        UNREACHABLE()
        return NULL
    }
}

priv h_free := proc(s: Scope, e: Expr, _r: Dynamic, ctx: Context) returns Bool {
    switch e.children[1].node_type {
    case NodeType.Ident(ident):
        ref hb : HeapBinding = scope_lookup_heap_binding(s, ident.ident_name())
        if hb.is_null() { panic("free binding not found: ", ident.ident_name()) }
        if hb.moved_out { panic("free of moved binding: ", ident.ident_name()) }
        heap_data : Dynamic = hb.ptr
        if hb.til_type.is(Type.Dynamic).and(hb.is_erased_dynamic.not()) {
            ref pointed : Dynamic = deref(heap_data)
            if pointed.is_null().not() {
                mut owned_pointed : Dynamic = pointed
                EvalHeap.heap_free(own owned_pointed)
            }
            mut owned_slot : Dynamic = heap_data
            EvalHeap.heap_free(own owned_slot)
        } else {
            mut owned_heap_data : Dynamic = heap_data
            EvalHeap.heap_free(own owned_heap_data)
        }
    case:
        ref arg : Expr = e.children[1]
        raw : Dynamic = eval_expr_raw(s, arg, ctx)
        ptr : Dynamic = raw_arg_pointer(s, arg, raw, ctx)
        if ptr.is_null().not() {
            mut owned_ptr : Dynamic = ptr
            EvalHeap.heap_free(own owned_ptr)
        }
        raw_result_drop(arg.til_type(), raw, expr_raw_is_ref(s, arg, ctx), ctx)
    }
    return true
}

priv h_til_closure_delete := proc(s: Scope, e: Expr, _r: Dynamic, ctx: Context) returns Bool {
    switch e.children[1].node_type {
    case NodeType.Ident(id):
        ref hb : HeapBinding = scope_lookup_heap_binding(s, id.ident_name())
        if hb.is_null().or(heap_type_is_callable(hb.til_type).not()) { panic("til_closure_delete: non-callable ", id.ident_name()) }
        if hb.moved_out.not() {
            ref heap_data : Dynamic = to_ptr(hb.ptr)
            if hb.is_borrowed.not() {
                heap_drop_by_type(hb.til_type, heap_data, hb.ctx)
                mut owned_heap_data : Dynamic = heap_data
                EvalHeap.heap_free(own owned_heap_data)
            }
            hb.ptr = NULL
            hb.moved_out = true
        }
    case NodeType.FieldAccess(fa):
        if e.children[1].children.len().gt(0) {
            ref obj_expr : Expr = e.children[1].children[0]
            switch obj_expr.node_type {
            case NodeType.Ident:
                ref base : Dynamic = resolve_field_assign_base(s, obj_expr)
                if base.is_null().not() {
                    ref sdef : Expr = resolve_field_assign_sdef(s, obj_expr, ctx)
                    if sdef.is_null().not() {
                        sname := resolve_field_assign_sname(s, obj_expr)
                        ref fdecl : Declaration = find_field_decl(sdef, fa.field_access_name())
                        if fdecl.is_null().not() {
                            if decl_is_funcsig(fdecl, ctx) {
                                ref fl : FieldLayout = ctx_field_layout(sname, fa.field_access_name(), ctx)
                                ref slot : Dynamic = ptr_add(base, fl.offset.cast(U64))
                                ref stored : Dynamic = deref(slot)
                                if stored.is_null().not() { callable_storage_free(stored) }
                                write_ptr(slot, NULL)
                                return true
                            }
                        }
                    }
                }
            case:
            }
        }
        ref arg : Expr = e.children[1]
        raw : Dynamic = eval_expr_raw(s, arg, ctx)
        ref stored : Dynamic = deref(raw)
        if stored.is_null().not() { callable_storage_free(stored); write_ptr(raw, NULL) }
        raw_result_drop(arg.til_type(), raw, expr_raw_is_ref(s, arg, ctx), ctx)
    case:
        ref arg : Expr = e.children[1]
        raw : Dynamic = eval_expr_raw(s, arg, ctx)
        ref stored : Dynamic = deref(raw)
        if stored.is_null().not() { callable_storage_free(stored); write_ptr(raw, NULL) }
        raw_result_drop(arg.til_type(), raw, expr_raw_is_ref(s, arg, ctx), ctx)
    }
    return true
}

priv h_til_closure_slot_delete := proc(s: Scope, e: Expr, _r: Dynamic, ctx: Context) returns Bool {
    ref arg : Expr = e.children[1]
    raw : Dynamic = eval_expr_raw(s, arg, ctx)
    slot : Dynamic = raw_arg_pointer(s, arg, raw, ctx)
    ref stored : Dynamic = deref(slot)
    if stored.is_null().not() {
        callable_storage_free(stored)
        write_ptr(slot, NULL)
    }
    raw_result_drop(arg.til_type(), raw, expr_raw_is_ref(s, arg, ctx), ctx)
    return true
}

priv h_cfile_close := proc(s: Scope, e: Expr, _r: Dynamic, ctx: Context) returns Bool {
    ref handle_expr : Expr = e.children[1]
    handle_raw : Dynamic = eval_expr_raw(s, handle_expr, ctx)
    cfile_close(raw_arg_pointer(s, handle_expr, handle_raw, ctx))
    raw_result_drop(handle_expr.til_type(), handle_raw, expr_raw_is_ref(s, handle_expr, ctx), ctx)
    return true
}

priv h_cfile_write_str := proc(s: Scope, e: Expr, _r: Dynamic, ctx: Context) returns Bool {
    ref handle_expr : Expr = e.children[1]
    handle_raw : Dynamic = eval_expr_raw(s, handle_expr, ctx)
    sv := eval_str_owned(s, e.children[2], ctx)
    cfile_write_str(raw_arg_pointer(s, handle_expr, handle_raw, ctx), sv)
    raw_result_drop(handle_expr.til_type(), handle_raw, expr_raw_is_ref(s, handle_expr, ctx), ctx)
    return true
}

priv h_ptr_add := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    ref buf_expr : Expr = e.children[1]
    buf_raw : Dynamic = eval_expr_raw(s, buf_expr, ctx)
    write_ptr(r, ptr_add(raw_arg_pointer(s, buf_expr, buf_raw, ctx), eval_u64_arg(s, e.children[2], ctx)))
    raw_result_drop(buf_expr.til_type(), buf_raw, expr_raw_is_ref(s, buf_expr, ctx), ctx)
    return true
}

// is_null core_func handler: a core_func has no body to run and is not
// FFI-registered, so the interpreter evaluates p.is_null() here, testing the
// pointer value the raw arg represents -- exactly what the old
// `p.ptr_eq(NULL)` FFI marshalled. Testing a slot's own address instead would
// wrongly report a NULL-holding ref field as non-null (test/ref.til,
// test/aliases.til). The inner .is_null() is itself the core_func, lowered
// inline in this compiled handler -- no handler recursion.
priv h_is_null := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    ref arg : Expr = e.children[1]
    raw : Dynamic = eval_expr_raw(s, arg, ctx)
    write_bool(r, raw_arg_pointer(s, arg, raw, ctx).is_null())
    raw_result_drop(arg.til_type(), raw, expr_raw_is_ref(s, arg, ctx), ctx)
    return true
}

// is_n core_func handler: the width-aware enum-tag compare (see dyn.til).
// Comparing the first `size` raw bytes with memcmp is equivalent to ext.c's
// width-switched typed compare: both read exactly the tag (offset 0,
// `size` = tag width in bytes) of each operand for equality.
priv h_is_n := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    ref ae : Expr = e.children[1]
    ref be : Expr = e.children[2]
    a : Dynamic = eval_expr_raw(s, ae, ctx)
    switch be.node_type {
    case NodeType.FieldAccess(variant):
        enum_name := field_access_sname(be)
        ref enum_def : Expr = lookup_interp_type_def(enum_name, ctx)
        if enum_def.is_null().not().and(enum_def.node_type.is(NodeType.EnumDef)) {
            write_bool(r, enum_data_tag_key(raw_arg_pointer(s, ae, a, ctx), enum_def) == enum_variant_tag(enum_def, variant.field_access_name()))
            raw_result_drop(ae.til_type(), a, expr_raw_is_ref(s, ae, ctx), ctx)
            return true
        }
    case NodeType.Ident(other_id):
        ref other_hb : HeapBinding = scope_lookup_heap_binding(s, other_id.ident_name())
        if other_hb.is_null().not().and(other_hb.is_static_callable) {
            ref other_raw : Dynamic = to_ptr(other_hb.ptr)
            ref other_def : Expr = callable_raw_func_def(other_raw)
            for qn, candidate_hb in ctx.ns_fields.heap_bindings {
                if candidate_hb.is_static_callable.not() { continue }
                ref candidate_raw : Dynamic = to_ptr(candidate_hb.ptr)
                if callable_raw_func_def(candidate_raw).ptr_eq(other_def) {
                    dot := qn.find(".")
                    if dot > 0 {
                        zero : USize = 0
                        enum_name := qn.substr(zero, dot.to_usize())
                        variant_start := dot.to_usize().add(1)
                        variant_name := qn.substr(variant_start, qn.len().sub(variant_start))
                        ref enum_def : Expr = lookup_interp_type_def(enum_name, ctx)
                        if enum_def.is_null().not().and(enum_def.node_type.is(NodeType.EnumDef)) {
                            write_bool(r, enum_data_tag_key(raw_arg_pointer(s, ae, a, ctx), enum_def) == enum_variant_tag(enum_def, variant_name))
                            raw_result_drop(ae.til_type(), a, expr_raw_is_ref(s, ae, ctx), ctx)
                            return true
                        }
                    }
                }
            }
        }
    case:
    }
    b : Dynamic = eval_expr_raw(s, be, ctx)
    write_bool(r, memcmp(raw_arg_pointer(s, ae, a, ctx), raw_arg_pointer(s, be, b, ctx), eval_u64_arg(s, e.children[3], ctx)) == 0)
    raw_result_drop(ae.til_type(), a, expr_raw_is_ref(s, ae, ctx), ctx)
    raw_result_drop(be.til_type(), b, expr_raw_is_ref(s, be, ctx), ctx)
    return true
}

// For a FIELD-ACCESS get_payload argument (`get_payload(def.nt)`, the
// switch lowering's shape when the subject is an enum field), resolve
// the real enum storage inside the base struct: eval_expr_raw would return
// a detached COPY of the field, so a payload ref taken from it could
// not write back -- the parser mutates parsed defs exactly that way
// (`ref sdd : StructDef = structdef_of(def)` then sdd.fields.push),
// and interpreted parses read back StructDefs with 0 fields. Returns
// the enum data buffer (tag at +0), or NULL when the shape doesn't
// match (non-Ident receiver, non-enum field), letting the caller fall
// back to the copying path.
priv get_payload_field_addr := func(s: Scope, arg: Expr, ctx: Context) returns Dynamic {
    if arg.node_type.is(NodeType.FieldAccess).not() { return NULL }
    if arg.children.len() != 1 { return NULL }
    mut fname := ""
    switch arg.node_type {
    case NodeType.FieldAccess(fan):
        fname = Str.clone(fan.field_access_name())
    case:
    }
    switch arg.children[0].node_type {
    case NodeType.Ident(base_id):
        ref hb : HeapBinding = scope_lookup_heap_binding(s, base_id.ident_name())
        if hb.is_null() { return NULL }
        switch hb.til_type {
        case Type.Struct(sname):
            ref data : Dynamic = to_ptr(hb.ptr)
            ref fl : FieldLayout = ctx_field_layout(sname, fname, ctx)
            if fl.is_null() { return NULL }
            if fl.is_enum.not() { return NULL }
            if fl.own_type.is(OwnType.Own).or(fl.own_type.is(OwnType.Ref)) {
                // Own/Ref enum fields store a pointer to the raw enum bytes.
                ref heap_enum : Dynamic = deref(ptr_add(data, fl.offset))
                if heap_enum.is_null() { return NULL }
                return ptr_add(heap_enum, 0)
            }
            // Shallow enum field: the tag+payload bytes live inline.
            return ptr_add(data, fl.offset)
        case:
            return NULL
        }
    case:
        return NULL
    }
}

// get_payload core_func handler: a core_func has no body to run and is not
// FFI-registered, so the interpreter evaluates the desugarer's payload
// accessor here. Bare get_payload calls are rejected by the typer (this
// handler included), so compute the address the way the interp already does
// for payload aliasing: the payload storage sits ENUM_PAYLOAD_OFFSET bytes
// past the tag (see the #211 payload-alias machinery).
priv h_get_payload := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    fa_payload : Dynamic = get_payload_field_addr(s, e.children[1], ctx)
    if fa_payload.is_null().not() {
        write_ptr(r, ptr_add(fa_payload, ENUM_PAYLOAD_OFFSET))
        return true
    }
    ref arg : Expr = e.children[1]
    raw : Dynamic = eval_expr_raw(s, arg, ctx)
    write_ptr(r, ptr_add(raw_arg_pointer(s, arg, raw, ctx), ENUM_PAYLOAD_OFFSET))
    raw_result_drop(arg.til_type(), raw, expr_raw_is_ref(s, arg, ctx), ctx)
    return true
}

priv h_cfile_read_all := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    ref handle_expr : Expr = e.children[1]
    handle_raw : Dynamic = eval_expr_raw(s, handle_expr, ctx)
    content := cfile_read_all(raw_arg_pointer(s, handle_expr, handle_raw, ctx))
    raw_result_drop(handle_expr.til_type(), handle_raw, expr_raw_is_ref(s, handle_expr, ctx), ctx)
    dispatch_write_str(r, content.c_str, content.count, ctx)
    return true
}

priv h_cfile_open_update := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    path := eval_str_owned(s, e.children[1], ctx)
    // FILE* is closed via cfile_close (fclose), never free()'d here.
    write_ptr(r, cfile_open_update(path))
    return true
}

priv h_cfile_tell := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    ref handle_expr : Expr = e.children[1]
    handle_raw : Dynamic = eval_expr_raw(s, handle_expr, ctx)
    write_i64(r, cfile_tell(raw_arg_pointer(s, handle_expr, handle_raw, ctx)))
    raw_result_drop(handle_expr.til_type(), handle_raw, expr_raw_is_ref(s, handle_expr, ctx), ctx)
    return true
}

priv h_cfile_seek := proc(s: Scope, e: Expr, _r: Dynamic, ctx: Context) returns Bool {
    ref handle_expr : Expr = e.children[1]
    handle_raw : Dynamic = eval_expr_raw(s, handle_expr, ctx)
    cfile_seek(raw_arg_pointer(s, handle_expr, handle_raw, ctx), eval_u64_arg(s, e.children[2], ctx).cast(I64))
    raw_result_drop(handle_expr.til_type(), handle_raw, expr_raw_is_ref(s, handle_expr, ctx), ctx)
    return true
}

priv h_cfile_seek_cur := proc(s: Scope, e: Expr, _r: Dynamic, ctx: Context) returns Bool {
    ref handle_expr : Expr = e.children[1]
    handle_raw : Dynamic = eval_expr_raw(s, handle_expr, ctx)
    cfile_seek_cur(raw_arg_pointer(s, handle_expr, handle_raw, ctx), eval_u64_arg(s, e.children[2], ctx).cast(I64))
    raw_result_drop(handle_expr.til_type(), handle_raw, expr_raw_is_ref(s, handle_expr, ctx), ctx)
    return true
}

priv h_cfile_seek_end := proc(s: Scope, e: Expr, _r: Dynamic, ctx: Context) returns Bool {
    ref handle_expr : Expr = e.children[1]
    handle_raw : Dynamic = eval_expr_raw(s, handle_expr, ctx)
    cfile_seek_end(raw_arg_pointer(s, handle_expr, handle_raw, ctx), eval_u64_arg(s, e.children[2], ctx).cast(I64))
    raw_result_drop(handle_expr.til_type(), handle_raw, expr_raw_is_ref(s, handle_expr, ctx), ctx)
    return true
}

priv h_cfile_read_n := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    ref handle_expr : Expr = e.children[1]
    handle_raw : Dynamic = eval_expr_raw(s, handle_expr, ctx)
    content := cfile_read_n(raw_arg_pointer(s, handle_expr, handle_raw, ctx), eval_u64_arg(s, e.children[2], ctx).cast(I64))
    raw_result_drop(handle_expr.til_type(), handle_raw, expr_raw_is_ref(s, handle_expr, ctx), ctx)
    dispatch_write_str(r, content.c_str, content.count, ctx)
    return true
}

priv DispatchFn := proc(Scope, Expr, Dynamic, Context) returns Bool

priv reg_dispatch := func(name: Str, handler: DispatchFn, ctx: Context) {
    v : Dynamic = malloc(8)
    write_ptr(v, handler)
    ctx.dispatch_map.set(name, own v)
}

priv dispatch_init := func(ctx: Context) {
    ctx.dispatch_map = Map(Str, Dynamic).new()
    reg_dispatch("print_single", h_print_single, ctx)
    reg_dispatch("print_flush", h_print_flush, ctx)
    reg_dispatch("and", h_Bool_and, ctx)
    reg_dispatch("or", h_Bool_or, ctx)
    reg_dispatch("not", h_Bool_not, ctx)
    reg_dispatch("Bool_eq", h_Bool_eq, ctx)
    reg_dispatch("U8_from_i64", h_U8_from_i64, ctx)
    reg_dispatch("U8_from_i64_ext", h_U8_from_i64, ctx)
    reg_dispatch("I16_from_i64", h_I16_from_i64, ctx)
    reg_dispatch("I16_from_i64_ext", h_I16_from_i64, ctx)
    reg_dispatch("U16_from_i64", h_U16_from_i64, ctx)
    reg_dispatch("U16_from_i64_ext", h_U16_from_i64, ctx)
    reg_dispatch("I32_from_i64", h_I32_from_i64, ctx)
    reg_dispatch("I32_from_i64_ext", h_I32_from_i64, ctx)
    reg_dispatch("F32_from_i64", h_F32_from_i64, ctx)
    reg_dispatch("F32_from_i64_ext", h_F32_from_i64, ctx)
    reg_dispatch("U32_from_i64", h_U32_from_i64, ctx)
    reg_dispatch("U32_from_i64_ext", h_U32_from_i64, ctx)
    reg_dispatch("cast", h_cast, ctx)
    reg_dispatch("exit", h_exit, ctx)
    reg_dispatch("free", h_free, ctx)
    reg_dispatch("til_closure_delete", h_til_closure_delete, ctx)
    reg_dispatch("til_closure_slot_delete", h_til_closure_slot_delete, ctx)
    reg_dispatch("ptr_add", h_ptr_add, ctx)
    reg_dispatch("is_null", h_is_null, ctx)
    reg_dispatch("is_n", h_is_n, ctx)
    reg_dispatch("get_payload", h_get_payload, ctx)
    reg_dispatch("dyn_call", h_dyn_call, ctx)
    reg_dispatch("dyn_call_ret", h_dyn_call, ctx)
    reg_dispatch("dyn_has_method", h_dyn_has_method, ctx)
    reg_dispatch("dyn_fn", h_dyn_fn, ctx)
    reg_dispatch("dyn_size_of", h_dyn_size_of, ctx)
    reg_dispatch("struct_field_count", h_struct_field_count, ctx)
    reg_dispatch("struct_field_name", h_struct_field_name, ctx)
    reg_dispatch("struct_field_is_mut", h_struct_field_is_mut, ctx)
    reg_dispatch("struct_field_type", h_struct_field_type, ctx)
    reg_dispatch("enum_variant_count", h_enum_variant_count, ctx)
    reg_dispatch("enum_variant_name", h_enum_variant_name, ctx)
    reg_dispatch("enum_variant_has_payload", h_enum_variant_has_payload, ctx)
    reg_dispatch("enum_variant_payload_type", h_enum_variant_payload_type, ctx)
    reg_dispatch("func_sig_param_count", h_func_sig_param_count, ctx)
    reg_dispatch("func_sig_param_type", h_func_sig_param_type, ctx)
    reg_dispatch("func_sig_return_count", h_func_sig_return_count, ctx)
    reg_dispatch("func_sig_return_type", h_func_sig_return_type, ctx)
    reg_dispatch("func_sig_throw_count", h_func_sig_throw_count, ctx)
    reg_dispatch("func_sig_throw_type", h_func_sig_throw_type, ctx)
    reg_dispatch("dyn_type_to_str", h_dyn_type_to_str, ctx)
    reg_dispatch("File_readfile", h_readfile, ctx)
    reg_dispatch("File_writefile", h_writefile, ctx)
    reg_dispatch("spawn_cmd", h_spawn_cmd, ctx)
    reg_dispatch("check_cmd_status", h_check_cmd_status, ctx)
    reg_dispatch("sleep", h_sleep, ctx)
    reg_dispatch("file_mtime", h_file_mtime, ctx)
    reg_dispatch("str_parse_f32", h_str_parse_f32, ctx)
    reg_dispatch("clock_ms", h_clock_ms, ctx)
    reg_dispatch("get_thread_count", h_get_thread_count, ctx)
    reg_dispatch("cfile_open", h_cfile_open, ctx)
    reg_dispatch("cfile_open_update", h_cfile_open_update, ctx)
    reg_dispatch("cfile_close", h_cfile_close, ctx)
    reg_dispatch("cfile_write_str", h_cfile_write_str, ctx)
    reg_dispatch("cfile_read_all", h_cfile_read_all, ctx)
    reg_dispatch("cfile_tell", h_cfile_tell, ctx)
    reg_dispatch("cfile_seek", h_cfile_seek, ctx)
    reg_dispatch("cfile_seek_cur", h_cfile_seek_cur, ctx)
    reg_dispatch("cfile_seek_end", h_cfile_seek_end, ctx)
    reg_dispatch("cfile_read_n", h_cfile_read_n, ctx)
    ctx.dispatch_inited = true
}

priv ext_dispatch_builtin := func(name: Str, scope: Scope, e: Expr, result: Dynamic, ctx: Context) returns Bool {
    ref dm : Map(Str, Dynamic) = ctx.dispatch_map
    if dm.has(name) {
        ref slot : Dynamic = dm[name]
        ref fp : DispatchFn = to_ptr(slot)
        return fp(scope, e, result, ctx)
    }
    return false
}

priv h_dyn_call := proc(s: Scope, e: Expr, r: Dynamic, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    method := eval_str_owned(s, e.children[2], ctx)

    // Build fake AST: Type.method(args...)
    mut type_ident := Expr.new(ident_node(type_name), e.line, e.col)
    type_ident.set_til_type(Type.Struct(type_name.clone()))

    mut field_access := Expr.new(field_access_node(method), e.line, e.col)
    field_access.add_child(own type_ident)
    // Critical: NodeType.FCall must have an initialized FCallData payload.
    mut fake_call := Expr.new(NodeType.FCall(FCallData()), e.line, e.col)
    fake_call.set_til_type(e.til_type())
    fake_call.add_child(own field_access)

    // child 3 is arity literal, actual args start at child 4
    ref arity_expr : Expr = e.children[3]
    mut nargs : USize = 0
    switch arity_expr.node_type {
    case NodeType.Literal(Literal.Num(arity_str)): nargs = arity_str.literal_num_text().to_u32()
    case:
        UNREACHABLE()
    }
    if method == "delete" {
        if nargs == 0 { panic("dyn_call delete without receiver") }
        ref recv_expr : Expr = e.children[4]
        recv_raw : Dynamic = eval_expr_raw(s, recv_expr, ctx)
        recv_ptr : Dynamic = raw_arg_pointer(s, recv_expr, recv_raw, ctx)
        mut call_free := true
        if nargs > 1 { call_free = narrow_bool_arg(s, e.children[5], ctx) }
        heap_drop_by_type(type_from_name_init(type_name, ctx.scope), recv_ptr, ctx)
        if call_free {
            EvalHeap.heap_free(own recv_ptr)
            switch recv_expr.node_type {
            case NodeType.FieldAccess(recv_fa):
                ref recv_base : Dynamic = field_access_base(s, recv_expr.children[0], ctx)
                if recv_base.is_null().not() {
                    ref recv_fl : FieldLayout = ctx_field_layout(field_access_sname(recv_expr), recv_fa.field_access_name(), ctx)
                    write_ptr(ptr_add(recv_base, recv_fl.offset), NULL)
                }
            case:
            }
        }
        raw_result_drop(recv_expr.til_type(), recv_raw, expr_raw_is_ref(s, recv_expr, ctx), ctx)
        return true
    }
    for ai in 0..nargs {
        fake_call.push_child_clone(e.children[ai + 4])
    }

    raw : Dynamic = eval_call(s, fake_call, ctx)
    raw_result_move_into(e.til_type(), r, raw, call_raw_result_is_ref(s, e, ctx), ctx)
    return true
}

priv get_elem_size := proc(s: Scope, type_name: Str, src: Expr, ctx: Context) returns USize {
    ref size_fn : Dynamic = ns_get(type_name, "size", ctx)
    if size_fn.is_null() {
        interp_error(src, format(type_name, " has no size() method"), ctx)
        exit(1)
    }
    // Build fake call: Type.size()
    mut type_ident := Expr.new(ident_node(type_name), src.line, src.col)
    type_ident.set_til_type(Type.Struct(type_name.clone()))

    mut field_access := Expr.new(field_access_node("size"), src.line, src.col)
    field_access.add_child(own type_ident)

    // Critical: NodeType.FCall must have an initialized FCallData payload.
    mut fake_call := Expr.new(NodeType.FCall(FCallData()), src.line, src.col)
    fake_call.set_til_type(type_from_name_init("USize", ctx.scope))
    fake_call.add_child(own field_access)

    result : Dynamic = eval_call(s, fake_call, ctx)
    // A prim-stamped call result is an inline word (canonical
    // zero-extended, so one decode covers both USize widths).
    size := word_bits(result).to_usize()
    raw_result_drop(fake_call.til_type(), result, false, ctx)
    return size
}

priv enum_method_dispatch := proc(method: Str, scope: Scope, enum_def: Expr, enum_name: Str, e: Expr, result: Dynamic, ctx: Context) returns Bool {
    if method == "is" {
        switch e.children[2].node_type {
        case NodeType.FieldAccess(variant):
            ref subject : Expr = e.children[1]
            subject_raw : Dynamic = eval_expr_raw(scope, subject, ctx)
            write_bool(result, enum_data_tag_key(raw_arg_pointer(scope, subject, subject_raw, ctx), enum_def) == enum_variant_tag(enum_def, variant.field_access_name()))
            raw_result_drop(subject.til_type(), subject_raw, expr_raw_is_ref(scope, subject, ctx), ctx)
            return true
        case:
        }
    }
    if enum_has_payloads(enum_def) {
        ctor_tag := enum_variant_tag(enum_def, method)
        // Payload lookup is index-keyed; construction needs the tag VALUE --
        // keep both distinct.
        ctor_idx := enum_variant_index(enum_def, method)
        if ctor_tag >= 0 {
            vtype := enum_variant_type(enum_def, ctor_idx)
            has_payload := vtype.len() > 0
            if has_payload {
                ref payload_expr : Expr = e.children[1]
                mut pdata : Dynamic = 0
                payload_transfers := get_own_arg(e, 1)
                mut transferred_ident := false
                if payload_transfers {
                    switch payload_expr.node_type {
                    case NodeType.Ident(payload_id):
                        ref payload_hb : HeapBinding = scope_lookup_heap_binding(scope, payload_id.ident_name())
                        if payload_hb.is_null() { panic("enum payload binding not found: ", payload_id.ident_name()) }
                        if payload_hb.moved_out { panic("enum payload binding already moved: ", payload_id.ident_name()) }
                        ref payload_place : Dynamic = to_ptr(payload_hb.ptr)
                        if payload_hb.is_borrowed {
                            payload_size := raw_type_size(payload_expr.til_type(), ctx)
                            pdata = dispatch_result_alloc(payload_expr.til_type(), ctx)
                            memcpy(pdata, payload_place, payload_size)
                            memset(payload_place, 0, payload_size)
                        } else {
                            pdata = payload_place
                            payload_hb.ptr = NULL
                        }
                        payload_hb.moved_out = true
                        transferred_ident = true
                    case:
                    }
                }
                if transferred_ident.not() { pdata = eval_expr_raw(scope, payload_expr, ctx) }
                mut pdata_is_word := false
                if payload_transfers.not().and(expr_raw_is_ref(scope, payload_expr, ctx)) {
                    pdata = heap_clone_by_type(payload_expr.til_type(), pdata, ctx)
                } else if transferred_ident.not().and(expr_word_shaped(scope, payload_expr, ctx)) {
                    // A scalar payload word: park it in a ring slot so the
                    // flat-enum writer has bytes to copy from.
                    pdata = word_ring_slot(payload_expr.til_type(), pdata, ctx)
                    pdata_is_word = true
                }
                psz := raw_type_size(payload_expr.til_type(), ctx)
                write_enum_flat(result, enum_name, ctor_tag, pdata, psz, vtype == "Str", true, ctx)
                // write_enum_flat moved nested ownership into the enum bytes.
                if pdata_is_word { word_drop(own pdata) }
                else { EvalHeap.heap_free(own pdata) }
            } else {
                write_enum_flat(result, enum_name, ctor_tag, NULL, 0, false, false, ctx)
            }
            return true
        }
    }
    return false
}

priv ffi_decode_scalar := func(rtype: Str, p: Dynamic, result: Dynamic, ctx: Context) returns Bool {
    if rtype == "I64"        { memcpy(result, p, I64.size()); return true }
    else if rtype == "U8"    { memcpy(result, p, U8.size()); return true }
    else if rtype == "I16"   { memcpy(result, p, I16.size()); return true }
    else if rtype == "U16"   { memcpy(result, p, U16.size()); return true }
    else if rtype == "I32"   { memcpy(result, p, I32.size()); return true }
    else if rtype == "U32"   { memcpy(result, p, U32.size()); return true }
    else if rtype == "U64"   { memcpy(result, p, U64.size()); return true }
    else if rtype == "USize" {
        ref usize_name : Str = resolve_type_alias(ctx.scope, "USize")
        if usize_name == "U32" { memcpy(result, p, U32.size()); return true }
        memcpy(result, p, U64.size())
        return true
    }
    else if rtype == "UPtr" {
        ref uptr_name : Str = resolve_type_alias(ctx.scope, "UPtr")
        if uptr_name == "U32" { memcpy(result, p, U32.size()); return true }
        memcpy(result, p, U64.size())
        return true
    }
    else if rtype == "F32"   { memcpy(result, p, F32.size()); return true }
    else if rtype == "Bool"  { memcpy(result, p, Bool.size()); return true }
    return false
}

// Look up the StructDef Expr for fe's shallow-struct return type, or
// NULL if the return type isn't a known shallow struct.
priv ffi_call_ret_struct_def := func(fe: FFIEntry, ctx: Context) returns ref Expr {
    if fe.return_is_shallow.not() { return NULL }
    if ffi_cif_rtype_is_struct(fe.cif).not() { return NULL }
    if ctx.ffi_struct_defs.has(fe.return_type).not() { return NULL }
    ref box : ExprPtrBox = ctx.ffi_struct_defs[fe.return_type]
    return box.ptr
}

// ffi_type -> (type_name, size). Inverse mapping of shallow_ffi_type;
// keep the two in sync if a new shallow primitive type lands. Returns
// false for ffi_types that don't correspond to a primitive shallow
// value (struct/pointer/etc., caller falls back to the Ptr-default
// path). type_name identifies the primitive conversion to apply.
priv ffi_shallow_type_info := func(atype: Dynamic, mut type_name: Str, mut size: USize) returns Bool {
    if atype.ptr_eq(ffi_type_ref("ffi_type_sint64")) { type_name = "I64"; size = 8; return true }
    if atype.ptr_eq(ffi_type_ref("ffi_type_uint8"))  { type_name = "U8";  size = 1; return true }
    if atype.ptr_eq(ffi_type_ref("ffi_type_sint8"))  { type_name = "I8";  size = 1; return true }
    if atype.ptr_eq(ffi_type_ref("ffi_type_sint16")) { type_name = "I16"; size = 2; return true }
    if atype.ptr_eq(ffi_type_ref("ffi_type_uint16")) { type_name = "U16"; size = 2; return true }
    if atype.ptr_eq(ffi_type_ref("ffi_type_sint32")) { type_name = "I32"; size = 4; return true }
    if atype.ptr_eq(ffi_type_ref("ffi_type_uint32")) { type_name = "U32"; size = 4; return true }
    if atype.ptr_eq(ffi_type_ref("ffi_type_uint64")) { type_name = "U64"; size = 8; return true }
    if atype.ptr_eq(ffi_type_ref("ffi_type_float"))  { type_name = "F32"; size = 4; return true }
    return false
}

// Write a shallow primitive arg into the FFI args buffer at `dst`.
priv ffi_write_shallow_arg := func(scope: Scope, e: Expr, raw: Dynamic, atype: Dynamic, dst: Dynamic, ctx: Context) returns Bool {
    mut tn := ""
    mut sz : USize = 0
    if ffi_shallow_type_info(atype, tn, sz).not() { return false }
    mut source : Dynamic = raw_arg_pointer(scope, e, raw, ctx)
    mut source_type := scalar_raw_source_type(scope, e, ctx)
    if source_type.is(Type.Dynamic) {
        mut expr_type := e.til_type()
        switch expr_type {
        case Type.Custom(name): expr_type = type_from_name_init(name, ctx.scope)
        case:
        }
        if expr_type.is(Type.Dynamic).not().and(expr_raw_is_ref(scope, e, ctx).not()) { source = deref(source) }
        source_type = type_from_name_init(tn, ctx.scope)
    }
    // `source` is an ADDRESS (raw_arg_pointer materializes words); load
    // the scalar into a word before decoding.
    if tn == "F32" {
        tmp : F32 = raw_to_f32(source_type, scalar_word_load(source_type, source, ctx), ctx)
        memcpy(dst, tmp, 4)
    } else {
        tmp : U64 = raw_to_u64(source_type, scalar_word_load(source_type, source, ctx), ctx)
        memcpy(dst, tmp, sz)
    }
    return true
}

priv ext_dispatch_ffi := proc(name: Str, scope: Scope, e: Expr, result: Dynamic, ctx: Context) returns Bool {
    if ctx.ffi_loaded.not() { return false }
    if ctx.ffi_map.has(name).not() { return false }

    ref fe : FFIEntry = ctx.ffi_map[name]
    nargs := e.children.len() - 1
    mut alloc_n := nargs
    if alloc_n == 0 { alloc_n = 1 }
    // args[i] = void* for each arg, arg_ptrs[i] = &args[i]
    args : Dynamic = malloc(alloc_n.mul(8))
    arg_ptrs : Dynamic = malloc(alloc_n.mul(8))
    // Per-arg flag: true when args[i] holds a scalar box WE malloc'd on
    // the deep path below. No ext callee takes `own` scalars (the C side
    // only borrows these boxes), so they must be freed after ffi_call --
    // skipping that leaked one box per non-shallow scalar arg per call.
    boxed_flags : Dynamic = calloc(alloc_n, 1)
    // Keep each raw result alive until ffi_call finishes because arg_ptrs may
    // point directly into aggregate storage.
    arg_raws : Dynamic = malloc(alloc_n.mul(8))

    for i in 0..nargs {
        ref arg_expr : Expr = e.children[i + 1]
        arg_raw : Dynamic = eval_expr_raw(scope, arg_expr, ctx)
        write_ptr(ptr_add(arg_raws, i.mul(8)), arg_raw)
        mut arg_type := arg_expr.til_type()
        switch arg_type {
        case Type.Custom(type_name): arg_type = type_from_name_init(type_name, ctx.scope)
        case:
        }
        arg_is_callable := heap_type_is_callable(arg_type)
        mut is_shallow := fe.param_shallows.is_null().not()
        .and(i.lt(fe.nparam))
        if is_shallow {
            ref ps : Bool = ptr_add(fe.param_shallows, i)
            is_shallow = ps
        }
        if is_shallow {
            ref at : Dynamic = ptr_add(fe.arg_types, i.mul(8))
            ref atype : Dynamic = deref(at)
            ref ffi_arg_type : ffi_type = to_ptr(atype)
            if ffi_arg_type.type == FFI_TYPE_STRUCT.to_u16() {
                write_ptr(ptr_add(arg_ptrs, i.mul(8)), raw_arg_pointer(scope, arg_expr, arg_raw, ctx))
            } else {
                ref dst : Dynamic = ptr_add(args, i.mul(8))
                if ffi_write_shallow_arg(scope, arg_expr, arg_raw, atype, dst, ctx).not() {
                    pointer : Dynamic = raw_arg_pointer(scope, arg_expr, arg_raw, ctx)
                    if arg_is_callable.and(callable_box_is(pointer)) { panic("FFI cannot receive captured closures") }
                    write_ptr(dst, pointer)
                }
                write_ptr(ptr_add(arg_ptrs, i.mul(8)), dst)
            }
        } else {
            // Deep: pass heap-allocated pointer (FFI callee may free it)
            mut dp : Dynamic = 0
            mut pass_pointer := expr_raw_is_ref(scope, arg_expr, ctx)
            if i.lt(fe.nparam) {
                ref param_dynamic : Bool = ptr_add(fe.param_dynamics, i)
                if param_dynamic { pass_pointer = true }
            }
            switch arg_expr.node_type {
            case NodeType.Ident(arg_id):
                ref arg_hb : HeapBinding = scope_lookup_heap_binding(scope, arg_id.ident_name())
                if arg_hb.is_null() { panic("FFI argument binding not found: ", arg_id.ident_name()) }
                if arg_hb.own_type.is(OwnType.Own) { pass_pointer = true }
            case:
            }
            if pass_pointer {
                pointer : Dynamic = raw_arg_pointer(scope, arg_expr, arg_raw, ctx)
                if arg_is_callable.and(callable_box_is(pointer)) { panic("FFI cannot receive captured closures") }
                write_ptr(ptr_add(args, i.mul(8)), pointer)
            } else {
                switch arg_expr.til_type() {
                case Type.Primitive:
                    size := raw_type_size(arg_expr.til_type(), ctx)
                    dp = malloc(size)
                    memcpy(dp, raw_arg_pointer(scope, arg_expr, arg_raw, ctx), size)
                case Type.Custom(name):
                    alias_type := type_from_name_init(name, ctx.scope)
                    switch alias_type {
                    case Type.Primitive:
                        size := raw_type_size(alias_type, ctx)
                        dp = malloc(size)
                        memcpy(dp, raw_arg_pointer(scope, arg_expr, arg_raw, ctx), size)
                    case:
                        pointer : Dynamic = raw_arg_pointer(scope, arg_expr, arg_raw, ctx)
                        if arg_is_callable.and(callable_box_is(pointer)) { panic("FFI cannot receive captured closures") }
                        write_ptr(ptr_add(args, i.mul(8)), pointer)
                    }
                case:
                    pointer : Dynamic = raw_arg_pointer(scope, arg_expr, arg_raw, ctx)
                    if arg_is_callable.and(callable_box_is(pointer)) { panic("FFI cannot receive captured closures") }
                    write_ptr(ptr_add(args, i.mul(8)), pointer)
                }
            }
            if dp.is_null().not() {
                write_ptr(ptr_add(args, i.mul(8)), dp)
                ref mut bf : Bool = ptr_add(boxed_flags, i)
                bf = true
            }
            write_ptr(ptr_add(arg_ptrs, i.mul(8)), ptr_add(args, i.mul(8)))
        }
    }

    // Check if return is a shallow struct
    ref ret_sdef : Expr = ffi_call_ret_struct_def(fe, ctx)

    // raw: 16-byte buffer for return value
    raw : Dynamic = calloc(1, 16)
    if ret_sdef.is_null().not() {
        switch ret_sdef.node_type {
        case NodeType.StructDef:
            ffi_call(fe.cif, fe.fn, result, arg_ptrs)
        case:
            ffi_call(fe.cif, fe.fn, raw, arg_ptrs)
        }
    } else {
        ffi_call(fe.cif, fe.fn, raw, arg_ptrs)
    }

    // Decode return value
    if fe.return_type.is_null() {
    } else if ret_sdef.is_null().not() {
    } else if fe.return_is_shallow {
        if ffi_decode_scalar(fe.return_type, to_ptr(raw), result, ctx).not() {
            panic("unsupported shallow FFI return type: ", fe.return_type)
        }
    } else {
        ref rtype : Str = fe.return_type
        ref raw_ptr : Dynamic = deref(raw)
        if rtype == "Str" {
            ref sp : ExtStr = raw_ptr
            // A `returns ref Str` borrows the C buffer; copy it into independent
            // owned raw Str storage.
            if fe.return_is_ref { dispatch_write_str(result, sp.data, sp.count, ctx) }
            else {
                // Adopt the ext_func's Str* contents into the raw result AT
                // THE TARGET LAYOUT: the C-side Str is host-layout, so copy
                // the buffer pointer and rewrite count/cap at the ctx width.
                // Preserve CAP_VIEW/CAP_LIT (they say whether the returned
                // c_str is owned; the sentinels survive width truncation),
                // else cap=count so typed teardown reclaims the c_str. The
                // old whole-struct memcpy fused the host count+cap pair into
                // the target count under --usize=64.
                write_ptr(result, sp.data)
                mut adopted_cap : USize = sp.count
                if sp.cap >= CAP_VIEW { adopted_cap = sp.cap }
                str_write_count_cap(result, sp.count, adopted_cap, ctx)
                mut owned_str_wrapper : Dynamic = raw_ptr
                EvalHeap.heap_free(own owned_str_wrapper)
            }
        } else if rtype == "Dynamic" {
            write_ptr(result, raw_ptr)
        } else if fe.return_is_ref {
            write_ptr(result, raw_ptr)
        } else if ffi_decode_scalar(rtype, raw_ptr, result, ctx) {
            // A non-shallow `returns <scalar>` (C signature `T *f(...)`) hands
            // back an OWNED malloc'd buffer holding the value. ffi_decode_scalar
            // copied the scalar into `result`, so the buffer is ours to reclaim
            // -- leaving it leaked one alloc per such call (sum_all / Pair_sum
            // return I64*). The compiled backend frees it too. A `returns ref`
            // scalar instead borrows a foreign pointer the runtime never
            // malloc'd (e.g. into a C array), so never free that one.
            if raw_ptr.is_null().not() {
                mut owned_ret : Dynamic = raw_ptr
                free(own owned_ret)
            }
        } else if ctx.ffi_struct_defs.has(fe.return_type) {
            // `returns ref T` hands back a borrowed pointer into foreign / C
            // memory; flag the wrapper borrowed so the garbager's deep delete
            // does not free a buffer the runtime never malloc'd (ext_libc:
            // getenv returns a pointer into libc's environ).
            if fe.return_is_ref {
                write_ptr(result, raw_ptr)
            } else {
                memcpy(result, raw_ptr, ctx_total_size(fe.return_type, ctx))
                mut owned_struct_wrapper : Dynamic = raw_ptr
                EvalHeap.heap_free(own owned_struct_wrapper)
            }
        } else {
            panic("unsupported FFI return type: ", fe.return_type)
        }
    }
    for i in 0..nargs {
        ref bf : Bool = ptr_add(boxed_flags, i)
        if bf {
            mut box_ptr : Dynamic = 0
            box_ptr = deref(ptr_add(args, i.mul(8)))
            free(own box_ptr)
        }
    }
    for i in 0..nargs {
        ref arg_expr : Expr = e.children[i + 1]
        ref arg_raw : Dynamic = deref(ptr_add(arg_raws, i.mul(8)))
        owned_arg_raw : Dynamic = arg_raw
        arg_is_ref := expr_raw_is_ref(scope, arg_expr, ctx)
        raw_was_passed := raw_arg_pointer(scope, arg_expr, owned_arg_raw, ctx).ptr_eq(owned_arg_raw)
        if (name == "memcpy").and(i == 1).and(arg_is_ref.not()).and(raw_was_passed) {
            // memcpy transferred the temporary aggregate's nested ownership.
            raw_block_free(owned_arg_raw)
        } else {
            raw_result_drop(arg_expr.til_type(), owned_arg_raw, arg_is_ref, ctx)
        }
    }
    free(own arg_raws)
    free(own boxed_flags)
    free(own args)
    free(own arg_ptrs)
    free(own raw)
    return true
}

// #288 Stage 4: native interpreter evaluation of the scalar primitive ISA.
// A scalar op call like `a.mul(b)` reaches ext_function_dispatch as the flat
// name "U32_mul". Rather than dlsym'ing the ext.c symbol (a slow libffi round
// trip) we compute the result directly on the operands' raw bytes, matching the
// exact C semantics in src/c/ext.c: modular wrapping at the type width and
// signed-vs-unsigned shifts. This is the interpreter half of the core_func
// ISA -- once src/core's scalar ops migrate ext_func -> core_func and their
// ext.c symbols are deleted, this is the ONLY path. It is already live for the
// ext_func ops, so the whole suite (interpret + both-mode compare) proves it
// matches ext.c. div/mod (zero-guarded), the to_* conversions, cmp and clone
// are NOT handled here and keep dispatching to their ext.c symbols.

// Category of a scalar type name: "u" unsigned int, "i" signed int, "f" F32;
// "" for anything that is not one of the nine numeric primitives.
priv scalar_op_cat := func(t: Str) returns Str {
    switch t {
    case "U8":  return "u"
    case "U16": return "u"
    case "U32": return "u"
    case "U64": return "u"
    case "I8":  return "i"
    case "I16": return "i"
    case "I32": return "i"
    case "I64": return "i"
    case "F32": return "f"
    }
    return ""
}

priv scalar_is_binop := func(op: Str) returns Bool {
    switch op {
    case "add": return true
    case "sub": return true
    case "mul": return true
    case "band": return true
    case "bor": return true
    case "bxor": return true
    case "shl": return true
    case "shr": return true
    case "div": return true
    case "mod": return true
    }
    return false
}

// Compute the binary op at U64 width (unsigned ops: the low bits are correct
// for every narrower unsigned type after truncation in scalar_build).
priv scalar_apply_u64 := func(op: Str, a: U64, b: U64) returns U64 {
    switch op {
    case "add": return a.add(b)
    case "sub": return a.sub(b)
    case "mul": return a.mul(b)
    case "band": return a.band(b)
    case "bor": return a.bor(b)
    case "bxor": return a.bxor(b)
    case "shl": return a.shl(b)
    case "shr": return a.shr(b)
    case "div": return a.div(b)
    case "mod": return a.mod(b)
    }
    panic(__LOC__, ": scalar_apply_u64: unhandled op ", op)
    return a
}

// Compute the binary op at I64 width (signed: arithmetic shr sign-extends;
// scalar_build truncates to the narrower signed type).
priv scalar_apply_i64 := func(op: Str, a: I64, b: I64) returns I64 {
    switch op {
    case "add": return a.add(b)
    case "sub": return a.sub(b)
    case "mul": return a.mul(b)
    case "band": return a.band(b)
    case "bor": return a.bor(b)
    case "bxor": return a.bxor(b)
    case "shl": return a.shl(b)
    case "shr": return a.shr(b)
    case "div": return a.div(b)
    case "mod": return a.mod(b)
    }
    panic(__LOC__, ": scalar_apply_i64: unhandled op ", op)
    return a
}

priv scalar_apply_f32 := func(op: Str, a: F32, b: F32) returns F32 {
    switch op {
    case "add": return a.add(b)
    case "sub": return a.sub(b)
    case "mul": return a.mul(b)
    case "div": return a.div(b)
    }
    panic(__LOC__, ": scalar_apply_f32: unhandled op ", op)
    return a
}

// True for the six comparison ops that return Bool (eq/neq + the four
// ordering ops). Separate from scalar_is_binop because these write Bool.
priv scalar_is_cmp := func(op: Str) returns Bool {
    switch op {
    case "eq":  return true
    case "neq": return true
    case "lt":  return true
    case "gt":  return true
    case "lte": return true
    case "gte": return true
    }
    return false
}

// Apply a comparison at U64 width (unsigned operands: eq/neq are bit-equal,
// the ordering ops use unsigned comparison).
priv scalar_cmp_u64 := func(op: Str, a: U64, b: U64) returns Bool {
    switch op {
    case "eq":  return a.eq(b)
    case "neq": return a.neq(b)
    case "lt":  return a.lt(b)
    case "gt":  return a.gt(b)
    case "lte": return a.lte(b)
    case "gte": return a.gte(b)
    }
    panic(__LOC__, ": scalar_cmp_u64: unhandled op ", op)
    return false
}

// Apply a comparison at I64 width (signed operands).
priv scalar_cmp_i64 := func(op: Str, a: I64, b: I64) returns Bool {
    switch op {
    case "eq":  return a.eq(b)
    case "neq": return a.neq(b)
    case "lt":  return a.lt(b)
    case "gt":  return a.gt(b)
    case "lte": return a.lte(b)
    case "gte": return a.gte(b)
    }
    panic(__LOC__, ": scalar_cmp_i64: unhandled op ", op)
    return false
}

// Apply a comparison on F32 operands.
priv scalar_cmp_f32 := func(op: Str, a: F32, b: F32) returns Bool {
    switch op {
    case "eq":  return a.eq(b)
    case "neq": return a.neq(b)
    case "lt":  return a.lt(b)
    case "gt":  return a.gt(b)
    case "lte": return a.lte(b)
    case "gte": return a.gte(b)
    }
    panic(__LOC__, ": scalar_cmp_f32: unhandled op ", op)
    return false
}

priv scalar_write_raw := func(t: Str, result: Dynamic, v: I64) {
    switch t {
    case "U8":  write_u8(result, v.to_u8())
    case "I8":  write_i8(result, v.to_i8())
    case "U16": write_u16(result, v.to_u16())
    case "I16": write_i16(result, v.to_i16())
    case "U32": write_u32(result, v.to_u32())
    case "I32": write_i32(result, v.to_i32())
    case "U64": write_u64(result, v.cast(U64))
    case "I64": write_i64(result, v)
    case:
        panic("cannot write raw scalar result for ", t)
    }
}

priv scalar_read_arg := proc(scope: Scope, arg: Expr, shallow target_type: Type, ctx: Context) returns Dynamic {
    source_type := scalar_raw_source_type(scope, arg, ctx)
    raw : Dynamic = eval_scalar_arg_word(scope, arg, source_type, ctx)
    return raw_coerce_value(raw, source_type, target_type, ctx)
}

// Step a mut-local scalar in place by delta (+1 for inc, -1 for dec) -- the
// interp side of the inc/dec core_funcs. Reads the receiver's current scalar,
// adds delta, and writes the new value back into its binding. raw_to_i64 reads
// integer bytes bit-exactly; two's-complement add gives the correct wrap for
// both signednesses, and scalar_write_raw narrows to the receiver's type. The
// receiver is always a plain mut-local Ident (a range-loop counter from the
// `for x in a..b` desugaring, the only numeric inc/dec caller), so no ref-mut
// or payload-alias mirror is needed. A
// non-Ident receiver would be a compiler bug and fails loud.
priv scalar_step_cell := proc(scope: Scope, e: Expr, type_str: Str, delta: I64, ctx: Context) {
    ref arg : Expr = e.children[1]
    scalar_type := type_from_name_init(type_str, ctx.scope)
    cur : Dynamic = scalar_read_arg(scope, arg, scalar_type, ctx)
    nv := raw_to_i64(scalar_type, cur, ctx).add(delta)
    switch e.children[1].node_type {
    case NodeType.Ident(id):
        ref hb : HeapBinding = scope_lookup_heap_binding(scope, id.ident_name())
        if hb.is_null() { panic(__LOC__, ": inc/dec target undefined: ", id.ident_name()) }
        if hb.moved_out { panic(__LOC__, ": inc/dec target moved: ", id.ident_name()) }
        ref heap_data : Dynamic = to_ptr(hb.ptr)
        if hb.til_type.is(Type.Primitive).not() { panic(__LOC__, ": inc/dec target has non-primitive type: ", id.ident_name()) }
        scalar_write_raw(type_str, heap_data, nv)
    case:
        panic(__LOC__, ": inc/dec receiver is not an Ident")
    }
}

priv scalar_core_op_eval := proc(name: Str, scope: Scope, e: Expr, result: Dynamic, ctx: Context) returns Bool {
    // Cheap reject: every scalar primitive type name starts with U, I or F.
    // This skips the find/substr parse for the common non-scalar dispatch
    // names (Str_*, Vec_*, Map_*, ...) before any allocation.
    if name.len() == 0 { return false }
    ref c0 : I8 = name.unsafe_get(0)
    if (c0 == 'U').not().and((c0 == 'I').not()).and((c0 == 'F').not()) { return false }
    us := name.find("_")
    if us < 0 { return false }
    u_pos : USize = us.to_usize()
    zero : USize = 0
    type_str := name.substr(zero, u_pos)
    cat := scalar_op_cat(type_str)
    if cat == "" { return false }
    scalar_type := type_from_name_init(type_str, ctx.scope)
    op_start := u_pos.add(1)
    op_str := name.substr(op_start, name.len().sub(op_start))

    // eq/neq/lt/gt/lte/gte: binary comparison -> Bool. eq/neq are bit-equal
    // for both signednesses; the ordering ops use the category's signed,
    // unsigned, or float comparison.
    if scalar_is_cmp(op_str) {
        ref ae : Expr = e.children[1]
        ref be : Expr = e.children[2]
        av : Dynamic = scalar_read_arg(scope, ae, scalar_type, ctx)
        bv : Dynamic = scalar_read_arg(scope, be, scalar_type, ctx)
        mut cmp_result := false
        if cat == "u" { cmp_result = scalar_cmp_u64(op_str, raw_to_u64(scalar_type, av, ctx), raw_to_u64(scalar_type, bv, ctx)) }
        else if cat == "i" { cmp_result = scalar_cmp_i64(op_str, raw_to_i64(scalar_type, av, ctx), raw_to_i64(scalar_type, bv, ctx)) }
        else { cmp_result = scalar_cmp_f32(op_str, raw_to_f32(scalar_type, av, ctx), raw_to_f32(scalar_type, bv, ctx)) }
        write_bool(result, cmp_result)
        return true
    }

    // bnot: unary bitwise complement (integer only -- F32 declares no bnot,
    // so the signed path is the unconditional tail, same shape as the cmp
    // arm; no dead cat guard).
    if op_str == "bnot" {
        ref arg : Expr = e.children[1]
        av : Dynamic = scalar_read_arg(scope, arg, scalar_type, ctx)
        if cat == "u" { scalar_write_raw(type_str, result, raw_to_u64(scalar_type, av, ctx).bnot().cast(I64)) }
        else { scalar_write_raw(type_str, result, raw_to_i64(scalar_type, av, ctx).bnot()) }
        return true
    }

    // inc/dec: the sole self-mutating core ops, one arm each (delta +1/-1);
    // scalar_step_cell holds the shared read-compute-writeback.
    if op_str == "inc" { scalar_step_cell(scope, e, type_str, 1, ctx); return true }
    if op_str == "dec" { scalar_step_cell(scope, e, type_str, -1, ctx); return true }

    if scalar_is_binop(op_str) {
        ref ae : Expr = e.children[1]
        ref be : Expr = e.children[2]
        av : Dynamic = scalar_read_arg(scope, ae, scalar_type, ctx)
        bv : Dynamic = scalar_read_arg(scope, be, scalar_type, ctx)
        if cat == "u" {
            scalar_write_raw(type_str, result, scalar_apply_u64(op_str, raw_to_u64(scalar_type, av, ctx), raw_to_u64(scalar_type, bv, ctx)).cast(I64))
            return true
        }
        if cat == "i" {
            scalar_write_raw(type_str, result, scalar_apply_i64(op_str, raw_to_i64(scalar_type, av, ctx), raw_to_i64(scalar_type, bv, ctx)))
            return true
        }
        // cat == "f": only add/sub/mul/div exist on F32 (no bitwise/shift/mod).
        if (op_str == "add").or(op_str == "sub").or(op_str == "mul").or(op_str == "div") {
            write_f32(result, scalar_apply_f32(op_str, raw_to_f32(scalar_type, av, ctx), raw_to_f32(scalar_type, bv, ctx)))
            return true
        }
        return false
    }

    return false
}

// The auto-generated enum `is` core_funcs dispatch by their flat name
// ("NodeType_is", "Type_is", ...): strip the "_is" suffix, confirm the
// prefix is a registered enum, and compare the first tag-width bytes of
// each operand -- the same equality h_is_n computes (the tag sits at
// offset 0). Per-enum names cannot be reg_dispatch'd statically, hence
// the name-shape parse, mirroring scalar_core_op_eval's approach.
priv enum_core_is_eval := proc(name: Str, scope: Scope, e: Expr, result: Dynamic, ctx: Context) returns Bool {
    if name.ends_with("_is").not() { return false }
    if e.children.len() != 3 { return false }
    tlen := name.len().sub(3)
    type_str := name.substr(0, tlen)
    ref edef : Expr = lookup_interp_type_def(type_str, ctx)
    if edef.is_null() { return false }
    if edef.node_type.is(NodeType.EnumDef).not() { return false }
    ref ae : Expr = e.children[1]
    ref be : Expr = e.children[2]
    a : Dynamic = eval_expr_raw(scope, ae, ctx)
    b : Dynamic = eval_expr_raw(scope, be, ctx)
    write_bool(result, memcmp(raw_arg_pointer(scope, ae, a, ctx), raw_arg_pointer(scope, be, b, ctx), enum_tag_size(edef)) == 0)
    raw_result_drop(ae.til_type(), a, expr_raw_is_ref(scope, ae, ctx), ctx)
    raw_result_drop(be.til_type(), b, expr_raw_is_ref(scope, be, ctx), ctx)
    return true
}

priv ext_function_dispatch := proc(name: Str, scope: Scope, e: Expr, result: Dynamic, ctx: Context) returns Bool {
    if ctx.dispatch_inited.not() { dispatch_init(ctx) }
    if ext_dispatch_builtin(name, scope, e, result, ctx) { return true }
    if scalar_core_op_eval(name, scope, e, result, ctx) { return true }
    if enum_core_is_eval(name, scope, e, result, ctx) { return true }
    return ext_dispatch_ffi(name, scope, e, result, ctx)
}
priv ffi_register := proc(name: Str, fn: Dynamic, fdef: Expr, ctx: Context) {
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        np := fd.params.len()
        mut alloc_np := np
        if alloc_np == 0 { alloc_np = 1 }
        // Build ffi_type* array (each element is a pointer = 8 bytes)
        atypes : Dynamic = malloc(alloc_np.mul(8))
        pdynamics : Dynamic = calloc(alloc_np, 1)
        mut pshallows : Dynamic = 0
        mut has_shallow := false
        for k in 0..np {
            ref pk : Declaration = fd.params[k]
            ref mut dynamic_slot : Bool = ptr_add(pdynamics, k)
            dynamic_slot = type_from_name_init(pk.explicit_type, ctx.scope).is(Type.Dynamic)
            if pk.own_type.is(OwnType.Shallow) {
                write_ptr(ptr_add(atypes, k.mul(8)), shallow_ffi_type(pk.explicit_type, ctx))
                has_shallow = true
            } else {
                write_ptr(ptr_add(atypes, k.mul(8)), ffi_type_ref("ffi_type_pointer"))
            }
        }
        if has_shallow {
            pshallows = malloc(np)
            for k in 0..np {
                ref pk : Declaration = fd.params[k]
                ref mut slot : Bool = ptr_add(pshallows, k)
                slot = pk.own_type.is(OwnType.Shallow)
            }
        }
        ret_shallow := fd.return_own_type.is(OwnType.Shallow)
        cif : Dynamic = ffi_alloc_cif()

        // Build FFIEntry
        mut entry := FFIEntry()
        entry.fn = fn
        if fd.return_type.len() > 0 { entry.return_type = fd.return_type }
        entry.nparam = np
        entry.param_shallows = pshallows
        entry.param_dynamics = pdynamics
        entry.return_is_shallow = ret_shallow
        entry.return_is_ref = fd.return_own_type.is(OwnType.Ref)
        entry.cif = cif
        entry.arg_types = atypes

        // Resolve return ffi_type
        ref mut rtype : Dynamic = ffi_type_ref("ffi_type_void")
        if entry.return_type.is_null().not() {
            if ret_shallow {
                rtype = to_ptr(shallow_ffi_type(entry.return_type, ctx))
            } else {
                rtype = to_ptr(ffi_type_ref("ffi_type_pointer"))
            }
        }
        ffi_prep_cif(entry.cif, ffi_host_default_abi(), np.to_u32(), rtype, entry.arg_types)

        // Store in ctx.ffi_map. Map.set borrows the key and deep-clones it
        // internally (ELEM_BOXED), so `name` can be passed directly; the
        // old clone+box dance here leaked both the box and the cloned Str.
        // The value box is a transient that Map.set consumes.
        // Re-registering a name overwrites its FFIEntry, but the entry's cif /
        // arg_types / parameter flags are `ref` raw C pointers Map.set's delete
        // does NOT reclaim. ffi_init_scan_program scans every import unit in a
        // loop and also descends into nested function bodies, so a name seen
        // twice orphaned the previous entry's libffi cif + arg-type array --
        // a translate-time leak ffi_cleanup never saw (the stale pointers had
        // already left ffi_map). Free them first, exactly as ffi_cleanup does
        // for each live entry.
        if ctx.ffi_map.has(name) {
            ref old_fe : FFIEntry = ctx.ffi_map[name]
            free(own old_fe.param_shallows)
            free(own old_fe.param_dynamics)
            free(own old_fe.arg_types)
            free(own old_fe.cif)
        }
        val : Dynamic = malloc(FFIEntry.size())
        // Manual island byte-move (#286): erased slot, sized copy.
        memcpy(val, entry, FFIEntry.size())
        memset(entry, 0, FFIEntry.size())
        ctx.ffi_map.set(name, own val)
    case:
        UNREACHABLE()
    }
}


ffi_init_scan_program := proc(program: Expr, ctx: Context) {
    if ctx.ffi_map_inited.not() {
        ctx.ffi_map = Map(Str, FFIEntry).new()
        ctx.ffi_map_inited = true
    }
    for stmt : Expr in program.children {
        if stmt.node_type.is(NodeType.Decl).not() { }
        else if stmt.children.len() == 0 { }
        else {
            // Top-level ext_func/ext_proc
            if stmt.children[0].node_type.is(NodeType.FuncDef) {
                ref fdef : Expr = stmt.children[0]
                switch fdef.node_type {
                case NodeType.FuncDef(fd):
                    if fd.func_type.is(FuncType.ExtFunc).or(fd.func_type.is(FuncType.ExtProc)) {
                        switch stmt.node_type {
                        case NodeType.Decl(dname):
                            ref fn_ptr : U8 = ffi_dlsym(dname.name)
                            if fn_ptr.is_null().not() {
                                ffi_register(dname.name, fn_ptr, fdef, ctx)
                            }
                        case:
                        }
                    }
                case:
                }
            }
            // Struct namespace ext_func/ext_proc
            if stmt.children[0].node_type.is(NodeType.StructDef) {
                switch stmt.node_type {
                case NodeType.Decl(sdd):
                    switch stmt.children[0].node_type {
                    case NodeType.StructDef(sdd_data):
                        for d_j : Declaration in sdd_data.ns_decls {
                            ref fdd : Declaration = d_j
                            ref fdef : Expr = fdd.default_value
                            if fdef.is_null() { continue }
                            mut fd_func_type := FuncType.Func
                            switch fdef.node_type {
                            case NodeType.FuncDef(fd):
                                fd_func_type = fd.func_type
                            case:
                                continue
                            }
                            if fd_func_type.is(FuncType.ExtFunc).or(fd_func_type.is(FuncType.ExtProc)) {
                                flat_name := sdd.name.concat3("_", fdd.name)
                                ref fn_ptr : U8 = ffi_dlsym(flat_name)
                                if fn_ptr.is_null().not() {
                                    ffi_register(flat_name, fn_ptr, fdef, ctx)
                                }
                            } else if fd_func_type.is(FuncType.Func).or(fd_func_type.is(FuncType.Proc)) {
                                // Scan function body for nested ext_func/ext_proc.
                                // A bodyless namespace signature (interface
                                // method, issue #251) has no body to scan.
                                if fdef.children.len() == 0 { continue }
                                ref fbody : Expr = fdef.children[0]
                                for inner : Expr in fbody.children {
                                    if inner.node_type.is(NodeType.Decl).and(inner.children.len().gt(0)) {
                                        ref idef : Expr = inner.children[0]
                                        switch idef.node_type {
                                        case NodeType.FuncDef(ifd):
                                            if ifd.func_type.is(FuncType.ExtFunc).or(ifd.func_type.is(FuncType.ExtProc)) {
                                                switch inner.node_type {
                                                case NodeType.Decl(iname):
                                                    ref ifn : U8 = ffi_dlsym(iname.name)
                                                    if ifn.is_null().not() {
                                                        ffi_register(iname.name, ifn, idef, ctx)
                                                    }
                                                case:
                                                    UNREACHABLE()
                                                }
                                            }
                                        case:
                                        }
                                    }
                                }
                            }
                        }
                    case:
                        UNREACHABLE()
                    }
                case:
                    UNREACHABLE()
                }
            }
        }
    }
}

priv ffi_init := proc(program: Expr, fwd_path: Str, user_c_path: Str, ext_c_path: Str, link_flags: Str, ctx: Context) returns I32 {
    if ctx.ffi_loaded {
        ffi_cleanup(ctx)
        ctx.ffi_map_inited = false
    }
    mut so_path := ""
    if ffi_init_user_so(fwd_path, user_c_path, ext_c_path, link_flags, so_path).eq(0).not() {
        return 1
    }
    ffi_init_link_libs(link_flags)
    ffi_init_struct_defs(program, ctx)
    ffi_init_scan_program(program, ctx)
    ctx.ffi_loaded = true
    if so_path.len() > 0 { unlink_path(so_path) }
    return 0
}
ffi_cleanup := proc(ctx: Context) {
    if ctx.ffi_loaded { ffi_close_user_so() }
    if ctx.ffi_map_inited {
        for _, fe in ctx.ffi_map {
            free(own fe.param_shallows)
            free(own fe.param_dynamics)
            free(own fe.arg_types)
            free(own fe.cif)
        }
        // Inner C-heap pointers freed above; reset the maps to fresh
        // empties so the owning Context auto-deletes live containers
        // rather than double-freeing what we just tore down.
        ctx.ffi_map = Map(Str, FFIEntry).new()
        ctx.ffi_struct_defs = Map(Str, ExprPtrBox).new()
        ctx.ffi_map_inited = false
    }
    ctx.ffi_loaded = false
    if ctx.ffi_type_cache_inited {
        for box : FFITypePtrBox in ctx.ffi_type_cache {
            if box.ptr.is_null().not() {
                free(own box.ptr.elements)
                free(own box.ptr)
            }
        }
        ctx.ffi_type_cache = Vec(FFITypePtrBox).new()
        ctx.ffi_type_cache_inited = false
    }
}
