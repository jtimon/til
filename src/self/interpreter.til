        if node.node_type.is(NodeType.EnumDef).not() {
            interp_error(e, format(who, ": '", type_name, "' is not an enum"), ctx)
            exit(1)
        }
        return node
    case:
        interp_error(e, format(who, ": '", type_name, "' is not an enum"), ctx)
        exit(1)
        return NULL
    }
}

priv h_enum_variant_count := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    ref node : Expr = interp_lookup_enum(s, e, type_name, "enum_variant_count", ctx)
    switch node.node_type {
    case NodeType.EnumDef(ed):
        r = Value.Int(ed.variants.len().to_i64())
    case:
        UNREACHABLE()
    }
    return true
}

priv h_enum_variant_name := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    idx := eval_index_arg(s, e, ctx)
    ref node : Expr = interp_lookup_enum(s, e, type_name, "enum_variant_name", ctx)
    switch node.node_type {
    case NodeType.EnumDef(ed):
        if idx.gte(ed.variants.len()) {
            interp_error(e, "enum_variant_name: index out of bounds", ctx)
            exit(1)
        }
        ref vn : Str = ed.variants[idx]
        r = str_to_owned_value(vn, ctx)
    case:
        UNREACHABLE()
    }
    return true
}

priv h_enum_variant_has_payload := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    idx := eval_index_arg(s, e, ctx)
    ref node : Expr = interp_lookup_enum(s, e, type_name, "enum_variant_has_payload", ctx)
    switch node.node_type {
    case NodeType.EnumDef(ed):
        if idx.gte(ed.variants.len()) {
            interp_error(e, "enum_variant_has_payload: index out of bounds", ctx)
            exit(1)
        }
        if ed.payload_types.has(idx.to_i64()) {
            ref pt : Str = ed.payload_types[idx.to_i64()]
            if pt.len().gt(0) { r = Value.Int(1) } else { r = Value.Int(0) }
        } else {
            r = Value.Int(0)
        }
    case:
        UNREACHABLE()
    }
    return true
}

priv h_enum_variant_payload_type := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    idx := eval_index_arg(s, e, ctx)
    ref node : Expr = interp_lookup_enum(s, e, type_name, "enum_variant_payload_type", ctx)
    switch node.node_type {
    case NodeType.EnumDef(ed):
        if idx.gte(ed.variants.len()) {
            interp_error(e, "enum_variant_payload_type: index out of bounds", ctx)
            exit(1)
        }
        if ed.payload_types.has(idx.to_i64()) {
            ref pt : Str = ed.payload_types[idx.to_i64()]
            r = str_to_owned_value(pt, ctx)
        } else {
            r = str_to_owned_value("", ctx)
        }
    case:
        UNREACHABLE()
    }
    return true
}

// Look up a registered FuncSig type's bodyless FuncDef node by name,
// erroring out if the name is unknown or not a function signature.
// Shared by the func_sig_* introspection handlers (issue #58).
priv interp_lookup_funcsig := proc(s: Scope, e: Expr, type_name: Str, who: Str, ctx: Context) returns ref Expr {
    ref tc : Cell = scope_get(s, type_name)
    if tc.is_null() {
        interp_error(e, format(who, ": type '", type_name, "' not found"), ctx)
        exit(1)
    }
    switch tc.val {
    case Value.Func(fptr):
        ref node : Expr = deref(fptr)
        if node.node_type.is(NodeType.FuncDef).not() {
            interp_error(e, format(who, ": '", type_name, "' is not a function signature"), ctx)
            exit(1)
        }
        return node
    case:
        interp_error(e, format(who, ": '", type_name, "' is not a function signature"), ctx)
        exit(1)
        return NULL
    }
}

