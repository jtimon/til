    }
    return true
}

priv h_func_sig_return_count := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    ref node : Expr = interp_lookup_funcsig(s, e, type_name, "func_sig_return_count", ctx)
    switch node.node_type {
