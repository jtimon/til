priv h_enum_variant_name := proc(s: Scope, e: Expr, mut r: Value, ctx: Context) returns Bool {
    type_name := eval_str_owned(s, e.children[1], ctx)
    idx := eval_index_arg(s, e, ctx)
    ref node : Expr = interp_lookup_enum(s, e, type_name, "enum_variant_name", ctx)
    switch node.node_type {
    case NodeType.EnumDef(ed):
        if idx >= ed.variants.len() {
            interp_error(e, "enum_variant_name: index out of bounds", ctx)
            exit(1)
        }
        ref vn : Str = ed.variants[idx]
        r = str_to_owned_value(vn, ctx)
    case:
        UNREACHABLE()
