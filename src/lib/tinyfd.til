mode lib

// tinyfiledialogs FFI bindings (lib/tinyfiledialogs/, the external C library).

link("lib/tinyfiledialogs/libtinyfd.a")

tinyfd_saveFileDialog := ext_func(title : I8, defaultPathAndFile : I8, shallow numOfFilterPatterns : I32, filterPatterns : Dynamic, singleFilterDescription : I8) returns ref I8 {}
tinyfd_openFileDialog := ext_func(title : I8, defaultPathAndFile : I8, shallow numOfFilterPatterns : I32, filterPatterns : Dynamic, singleFilterDescription : I8, shallow allowMultipleSelects : I32) returns ref I8 {}
