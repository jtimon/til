mode cli

import("std/sys")

// test_runner.til — runs tests and reports structured results for tests.til.
//
// Usage:
//   test_runner both <file> [-no-interp] [-no-run] [-no-match] [--til-bin <path>]
//   test_runner single <label> <expected_exit> [<expected_out_file>] -- <cmd...>
//   test_runner count <label> <needle> <expected_count> -- <cmd...>

TIL := "bin/til"

// Extract basename from path: "test/types.til" -> "types"
test_basename := func(path: Str) returns Str {
    mut last_slash : USize = 0
    mut has_slash := 0
    for si in 0..path.len() {
        if path.get(si).eq('/') {
            last_slash = si
            has_slash = 1
        }
    }
    mut name := path
    if has_slash.eq(1) {
        name = path.substr(last_slash.add(1), path.len().sub(last_slash).sub(1))
    }
    if name.ends_with(".til") {
        name = name.strip_suffix(".til")
    }
    return name
}

count_matches := func(haystack: Str, needle: Str) returns I64 {
    if needle.is_empty() { return 0 }
    mut count := 0
    mut start : USize = 0
    while start.lte(haystack.len().sub(needle.len())) {
        pos := haystack.substr(start, haystack.len().sub(start)).find(needle)
        if pos.eq(-1) { return count }
        count++
        pos_u : USize = pos.to_usize()
        start = start.add(pos_u).add(needle.len())
    }
    return count
}

PhaseResult := struct {
    status := -1
    ms := 0
    mem := 0
}

run_phase := proc(cmd: Str) returns PhaseResult {
    start := clock_ms()
    pid := spawn_cmd(cmd)
    mut mem := 0
    while true {
        rss := current_rss_bytes(pid).cast(I64)
        if rss.gt(mem) { mem = rss }
        status := check_cmd_status(pid)
        if status.neq(-1) {
            return PhaseResult(status = status, ms = clock_ms().sub(start), mem = mem)
        }
        sleep_ms(10)
    }
}

main := proc(args: ..Str) {
    if args.len().lt(1) {
        println("Usage: test_runner <both|single|count> ...")
        exit(1)
    }

    ref subcmd : Str = args[0]

    // both subcommand: compare interpret output with compiled-run output.
    if subcmd.eq("both") {
        if args.len().lt(2) {
            println("Usage: test_runner both <file> [-no-interp] [-no-run] [-no-match] [--til-bin <path>] [--asan]")
            exit(1)
        }

        ref file : Str = args[1]
        mut en_interp := 1
        mut en_run := 1
        mut en_match := 1
        mut asan_flag := ""
        mut til_bin := TIL
        for i in 2..args.len() {
            ref arg : Str = args[i]
            if arg.eq("-no-interp") { en_interp = 0 }
            if arg.eq("-no-run") { en_run = 0 }
            if arg.eq("-no-match") { en_match = 0 }
            if arg.eq("--asan") { asan_flag = " --asan" }
            if arg.eq("--til-bin").and(i.add(1).lt(args.len())) {
                ref val : Str = args[i.add(1)]
                til_bin = val.clone()
            }
        }

        basename := test_basename(file)

        interp_outfile := format("gen/out/interp/", basename, ".out")
        run_outfile := format("gen/out/run/", basename, ".out")
        bin_path := format("bin/c/", basename)

        mut interp_ms := 0
        mut interp_ok := 0
        mut interp_mem := 0
        mut compile_ms := 0
        mut compile_ok := 0
        mut compile_mem := 0
        mut run_ms := 0
        mut run_ok := 0
        mut run_mem := 0
        mut fail := 0

        if en_interp.eq(1) {
            cmd := til_bin.format(" interpret '", file, "' > ", interp_outfile, " 2>/dev/null")
            phase := run_phase(cmd)
            interp_ms = phase.ms
            interp_mem = phase.mem
            if phase.status.eq(0) {
                interp_ok = 1
            } else {
                println("FAIL (interp): ", file)
                fail = 1
            }
        }

        if en_run.eq(1) {
            // Compile
            build_cmd := til_bin.format(" build", asan_flag, " -o ", bin_path, " '", file, "' 2>/dev/null")
            phase := run_phase(build_cmd)
            compile_ms = phase.ms
            compile_mem = phase.mem
            if phase.status.eq(0) {
                compile_ok = 1
                // Run the compiled binary
                run_cmd := bin_path.format(" > ", run_outfile, " 2>/dev/null")
                run_phase_result := run_phase(run_cmd)
                run_ms = run_phase_result.ms
                run_mem = run_phase_result.mem
                if run_phase_result.status.eq(0) {
                    run_ok = 1
                } else {
                    println("FAIL (run): ", file)
                    fail = 1
                }
            } else {
                println("FAIL (compile): ", file)
                fail = 1
            }
        }

        // Compare all passing both outputs
        mut out_match := 1
        mut ref_out := ""
        mut has_ref := 0

        if en_interp.eq(1).and(interp_ok.eq(1)) {
            ref_out = File.readfile(interp_outfile)
            has_ref = 1
        }
        if en_run.eq(1).and(run_ok.eq(1)) {
            run_out := File.readfile(run_outfile)
            if has_ref.eq(0) {
                ref_out = run_out
                has_ref = 1
            } else {
                if en_match.eq(1).and(run_out.neq(ref_out)) {
                    out_match = 0
                    println("MISMATCH: ", file, " (run vs interp)")
                    fail = 1
                }
            }
        }

        mut both_ok := 1
        if fail.neq(0) { both_ok = 0 }
        if out_match.eq(0) { both_ok = 0 }
        total_ms := interp_ms.add(compile_ms).add(run_ms)

        println("RESULT ok=", both_ok.to_str(), " ms=", total_ms.to_str(),
                " interp_ms=", interp_ms.to_str(), " interp_ok=", interp_ok.to_str(),
                " interp_mem=", interp_mem.to_str(),
                " compile_ms=", compile_ms.to_str(), " compile_ok=", compile_ok.to_str(),
                " compile_mem=", compile_mem.to_str(),
                " run_ms=", run_ms.to_str(), " run_ok=", run_ok.to_str(),
                " run_mem=", run_mem.to_str(),
                " match=", out_match.to_str())

        exit(fail)
    }

    // single subcommand
    if subcmd.eq("single") {
        if args.len().lt(4) {
            println("Usage: test_runner single <label> <expected_exit> [<expected_out_file>] -- <cmd...>")
            exit(1)
        }

        ref label : Str = args[1]
        ref exit_str : Str = args[2]
        expected_exit := exit_str.to_i64()

        // Find "--" starting from index 3
        mut dd : USize = 3
        while dd.lt(args.len()) {
            ref a : Str = args[dd]
            if a.eq("--") { break }
            dd++
        }

        // If there's an arg between expected_exit and "--", it's the expected output file
        mut expected_out_file := ""
        mut has_expected := 0
        if dd.gt(3) {
            ref eof : Str = args[3]
            expected_out_file = eof.clone()
            has_expected = 1
        }

        // Join args after "--" as command
        mut cmd := ""
        for ci in dd.add(1)..args.len() {
            if ci.gt(dd.add(1)) { cmd = cmd.concat(" ") }
            ref carg : Str = args[ci]
            cmd = cmd.concat(carg)
        }

        if cmd.is_empty() {
            println("FAIL: ", label, " no command after --")
            println("RESULT ms=0 ok=0")
            exit(1)
        }

        outfile := format("gen/out/single/", label, ".out")

        phase := run_phase(cmd.format(" > ", outfile, " 2>&1"))
        ms := phase.ms
        mem := phase.mem

        mut ok := 1
        if phase.status.neq(expected_exit) {
            println("FAIL: ", label, " exit=", phase.status.to_str(), " expected=", expected_exit.to_str())
            ok = 0
        }

        if ok.eq(1).and(has_expected.eq(1)) {
            actual := File.readfile(outfile)
            expected := File.readfile(expected_out_file)
            if actual.neq(expected) {
                println("FAIL: ", label, " output mismatch")
                ok = 0
            }
        }

        println("RESULT ms=", ms.to_str(), " mem=", mem.to_str(), " ok=", ok.to_str())
        if ok.eq(1) { exit(0) } else { exit(1) }
    }

    // count subcommand
    if subcmd.eq("count") {
        if args.len().lt(5) {
            println("Usage: test_runner count <label> <needle> <expected_count> -- <cmd...>")
            exit(1)
        }

        ref label : Str = args[1]
        ref needle : Str = args[2]
        ref count_str : Str = args[3]
        expected_count := count_str.to_i64()

        // Find "--" starting from index 4
        mut dd : USize = 4
        while dd.lt(args.len()) {
            ref a : Str = args[dd]
            if a.eq("--") { break }
            dd++
        }

        // Join args after "--" as command
        mut cmd := ""
        for ci in dd.add(1)..args.len() {
            if ci.gt(dd.add(1)) { cmd = cmd.concat(" ") }
            ref carg : Str = args[ci]
            cmd = cmd.concat(carg)
        }

        if cmd.is_empty() {
            println("FAIL: ", label, " no command after --")
            println("RESULT ms=0 ok=0 count=0")
            exit(1)
        }

        outfile := format("gen/out/single/", label, ".out")

        phase := run_phase(cmd.format(" > ", outfile, " 2>&1"))
        ms := phase.ms
        mem := phase.mem

        actual_out := File.readfile(outfile)
        actual_count := count_matches(actual_out, needle)

        mut ok := 1
        if actual_count.neq(expected_count) {
            println("FAIL: ", label, " count=", actual_count.to_str(), " expected=", expected_count.to_str())
            ok = 0
        }

        println("RESULT ms=", ms.to_str(), " mem=", mem.to_str(), " ok=", ok.to_str(), " count=", actual_count.to_str())
        if ok.eq(1) { exit(0) } else { exit(1) }
    }

    println("Unknown subcommand: ", subcmd)
    exit(1)
}
