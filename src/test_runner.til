mode cli

// test_runner.til — runs all enabled modes for one test file sequentially,
// compares outputs, prints structured result line for tests.til to parse.
//
// Usage: test_runner <file> [-no-ci] [-no-cr] [-no-ti] [-no-tr]

CTIL := "bin/ctil"
TIL := "bin/c/til"

// Extract basename from path: "src/test/types.til" → "types"
test_basename := func(path: Str) returns Str {
    mut last_slash : U64 = 0
    mut has_slash := 0
    mut si : U64 = 0
    while si.lt(path.len()) {
        if path.get(si).eq('/') {
            last_slash = si
            has_slash = 1
        }
        si = si.add(1)
    }
    mut name := path
    if has_slash.eq(1) {
        name = path.substr(last_slash.add(1), path.len().sub(last_slash).sub(1))
    }
    if name.ends_with(".til") {
        name = name.substr(0, name.len().sub(4))
    }
    return name
}

main := proc(args: ..Str) {
    if args.len().lt(1) {
        println("Usage: test_runner <file> [-no-ci] [-no-cr] [-no-ti] [-no-tr]")
        exit(1)
    }

    ref file : Str = args.get(0)
    mut en_ci := 1
    mut en_cr := 1
    mut en_ti := 1
    mut en_tr := 1
    mut i : U64 = 1
    while i.lt(args.len()) {
        ref arg : Str = args.get(i)
        if arg.eq("-no-ci") { en_ci = 0 }
        if arg.eq("-no-cr") { en_cr = 0 }
        if arg.eq("-no-ti") { en_ti = 0 }
        if arg.eq("-no-tr") { en_tr = 0 }
        i = i.add(1)
    }

    basename := test_basename(file)

    // Output file paths
    ci_outfile := "gen/out/ci/".concat(basename).concat(".out")
    cr_outfile := "gen/out/cr/".concat(basename).concat(".out")
    ti_outfile := "gen/out/ti/".concat(basename).concat(".out")
    tr_outfile := "gen/out/tr/".concat(basename).concat(".out")

    mut ci_ms := 0
    mut ci_ok := 0
    mut cr_ms := 0
    mut cr_ok := 0
    mut ti_ms := 0
    mut ti_ok := 0
    mut tr_ms := 0
    mut tr_ok := 0
    mut fail := 0

    // Run each enabled mode sequentially
    if en_ci.eq(1) {
        start := clock_ms()
        cmd := CTIL.concat(" interpret '").concat(file).concat("' > ").concat(ci_outfile).concat(" 2>/dev/null")
        pid := spawn_cmd(cmd)
        status := wait_cmd(pid)
        ci_ms = clock_ms().sub(start)
        if status.eq(0) {
            ci_ok = 1
        } else {
            println("FAIL (ci): ", file)
            fail = 1
        }
    }

    if en_cr.eq(1) {
        start := clock_ms()
        cmd := CTIL.concat(" run '").concat(file).concat("' > ").concat(cr_outfile).concat(" 2>/dev/null")
        pid := spawn_cmd(cmd)
        status := wait_cmd(pid)
        cr_ms = clock_ms().sub(start)
        if status.eq(0) {
            cr_ok = 1
        } else {
            println("FAIL (cr): ", file)
            fail = 1
        }
    }

    if en_ti.eq(1) {
        start := clock_ms()
        cmd := TIL.concat(" interpret '").concat(file).concat("' > ").concat(ti_outfile).concat(" 2>/dev/null")
        pid := spawn_cmd(cmd)
        status := wait_cmd(pid)
        ti_ms = clock_ms().sub(start)
        if status.eq(0) {
            ti_ok = 1
        } else {
            println("FAIL (ti): ", file)
            fail = 1
        }
    }

    if en_tr.eq(1) {
        start := clock_ms()
        cmd := TIL.concat(" run '").concat(file).concat("' > ").concat(tr_outfile).concat(" 2>/dev/null")
        pid := spawn_cmd(cmd)
        status := wait_cmd(pid)
        tr_ms = clock_ms().sub(start)
        if status.eq(0) {
            tr_ok = 1
        } else {
            println("FAIL (tr): ", file)
            fail = 1
        }
    }

    // Compare all passing mode outputs
    mut out_match := 1
    mut ref_out := ""
    mut has_ref := 0

    if en_ci.eq(1).and(ci_ok.eq(1)) {
        ref_out = readfile(ci_outfile)
        has_ref = 1
    }
    if en_cr.eq(1).and(cr_ok.eq(1)) {
        cr_out := readfile(cr_outfile)
        if has_ref.eq(0) {
            ref_out = cr_out
            has_ref = 1
        } else {
            if cr_out.neq(ref_out) {
                out_match = 0
                println("MISMATCH: ", file, " (cr vs ci)")
                fail = 1
            }
        }
    }
    if en_ti.eq(1).and(ti_ok.eq(1)) {
        ti_out := readfile(ti_outfile)
        if has_ref.eq(0) {
            ref_out = ti_out
            has_ref = 1
        } else {
            if ti_out.neq(ref_out) {
                out_match = 0
                println("MISMATCH: ", file, " (ti vs ref)")
                fail = 1
            }
        }
    }
    if en_tr.eq(1).and(tr_ok.eq(1)) {
        tr_out := readfile(tr_outfile)
        if has_ref.eq(0) {
            ref_out = tr_out
            has_ref = 1
        } else {
            if tr_out.neq(ref_out) {
                out_match = 0
                println("MISMATCH: ", file, " (tr vs ref)")
                fail = 1
            }
        }
    }

    // Print structured result line (parsed by tests.til)
    println("RESULT ci_ms=", ci_ms.to_str(), " ci_ok=", ci_ok.to_str(),
            " cr_ms=", cr_ms.to_str(), " cr_ok=", cr_ok.to_str(),
            " ti_ms=", ti_ms.to_str(), " ti_ok=", ti_ok.to_str(),
            " tr_ms=", tr_ms.to_str(), " tr_ok=", tr_ok.to_str(),
            " match=", out_match.to_str())

    exit(fail)
}
