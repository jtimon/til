mode cli

NL := Str.from_byte(U8.from_i64(10))
CTIL := "bin/ctil"
TMPF := "tmp/_test_out"

count_matches := func(haystack: Str, needle: Str) returns I64 {
    if needle.is_empty() { return 0 }
    mut count := 0
    mut start := 0
    while start.lte(haystack.len().sub(needle.len())) {
        pos := haystack.substr(start, haystack.len().sub(start)).find(needle)
        if pos.eq(0.sub(1)) { return count }
        count = count.add(1)
        start = start.add(pos).add(needle.len())
    }
    return count
}

// Run a shell command, return exit code
run := proc(cmd: Str) returns I64 {
    pid := spawn_cmd(cmd)
    return wait_cmd(pid)
}

// Run a shell command, capture output to TMPF, return exit code
run_capture := proc(cmd: Str) returns I64 {
    pid := spawn_cmd(cmd.concat(" > ").concat(TMPF).concat(" 2>&1"))
    return wait_cmd(pid)
}

// --- Job struct for parallel execution ---

Job := struct {
    mut file := ""
    mut tmode := ""
    mut pid := 0
}

// --- Section 1: Normal tests (interpret + run, exit 0) ---

run_tests_parallel := proc(files: Vec, j: I64, mut fail: I64) {
    // Build all jobs: each file gets interpret + run
    jobs := Vec.new("Job", Job.size())
    mut fi := 0
    while fi.lt(files.len()) {
        ref f : Str = files.get(fi)
        jobs.push(own Job(file = f.clone(), tmode = "interpret"))
        jobs.push(own Job(file = f.clone(), tmode = "run"))
        fi = fi.add(1)
    }

    // Add parsing.til as interpret-only
    jobs.push(own Job(file = "src/test/parsing.til", tmode = "interpret"))

    mut next := 0
    mut active := 0

    // Fixed-size slot array for running jobs
    slots := Array.new("Job", Job.size(), j)
    mut si := 0
    while si.lt(j) {
        slots.set(si, own Job())
        si = si.add(1)
    }

    // Spawn initial batch
    si = 0
    while si.lt(j).and(next.lt(jobs.len())) {
        ref job : Job = jobs.get(next)
        cmd := CTIL.concat(" ").concat(job.tmode).concat(" '").concat(job.file).concat("' > /dev/null 2>&1")
        pid := spawn_cmd(cmd)
        slots.set(si, own Job(file = job.file.clone(), tmode = job.tmode.clone(), pid = pid))
        active = active.add(1)
        next = next.add(1)
        si = si.add(1)
    }

    // Poll loop
    while active.gt(0) {
        mut i := 0
        while i.lt(j) {
            ref slot : Job = slots.get(i)
            if slot.pid.gt(0) {
                status := check_cmd_status(slot.pid)
                if status.neq(0.sub(1)) {
                    // Job finished
                    if status.neq(0) {
                        mut label := "interpret"
                        if slot.tmode.eq("run") { label = "codegen" }
                        println("FAIL (", label, "): ", slot.file)
                        fail = 1
                    }
                    active = active.sub(1)

                    // Spawn next job in this slot
                    if next.lt(jobs.len()) {
                        ref nj : Job = jobs.get(next)
                        cmd := CTIL.concat(" ").concat(nj.tmode).concat(" '").concat(nj.file).concat("' > /dev/null 2>&1")
                        pid := spawn_cmd(cmd)
                        slots.set(i, own Job(file = nj.file.clone(), tmode = nj.tmode.clone(), pid = pid))
                        active = active.add(1)
                        next = next.add(1)
                    } else {
                        slots.set(i, own Job())
                    }
                }
            }
            i = i.add(1)
        }
        if active.gt(0) {
            sleep(10)
        }
    }
}

// --- CLI test helper ---

cli_test := proc(file: Str, cmd_args: Str, expected: Str, exit_expected: I64, mut fail: I64) {
    // interpret
    mut cmd := CTIL.concat(" interpret ").concat(file)
    if cmd_args.len().gt(0) {
        cmd = cmd.concat(" ").concat(cmd_args)
    }
    rc := run_capture(cmd)
    out := readfile(TMPF)
    if rc.neq(exit_expected) {
        println("FAIL (interpret): ", file, " (exit ", rc.to_str(), ", expected ", exit_expected.to_str(), ")")
        fail = 1
    } else {
        if exit_expected.eq(0).and(out.neq(expected)) {
            println("FAIL (interpret): ", file)
            println("  expected: ", expected)
            println("  got:      ", out)
            fail = 1
        }
    }

    // codegen
    mut cmd2 := CTIL.concat(" run ").concat(file)
    if cmd_args.len().gt(0) {
        cmd2 = cmd2.concat(" ").concat(cmd_args)
    }
    rc2 := run_capture(cmd2)
    out2 := readfile(TMPF)
    if rc2.neq(exit_expected) {
        println("FAIL (codegen):   ", file, " (exit ", rc2.to_str(), ", expected ", exit_expected.to_str(), ")")
        fail = 1
    } else {
        if exit_expected.eq(0).and(out2.neq(expected)) {
            println("FAIL (codegen):   ", file)
            println("  expected: ", expected)
            println("  got:      ", out2)
            fail = 1
        }
    }
}

// --- Main ---

main := proc(args: ..Str) {
    // Parse -jN from args (default: CPU thread count)
    mut j := get_thread_count()
    mut i := 0
    while i.lt(args.len()) {
        ref arg : Str = args.get(i)
        if arg.starts_with("-j") {
            j = arg.substr(2, arg.len().sub(2)).to_i64()
            if j.lt(1) { j = 1 }
        }
        i = i.add(1)
    }

    mut fail := 0

    // --- Section 1: Normal tests (interpret + run, exit 0) ---

    files := Vec.new("Str", Str.size())
    files.push(own "src/test/types.til")
    files.push(own "src/test/operators.til")
    files.push(own "src/test/functions.til")
    files.push(own "src/test/structs.til")
    files.push(own "src/test/optional_args.til")
    files.push(own "src/test/forward_refs.til")
    files.push(own "src/test/flow.til")
    files.push(own "src/test/strings.til")
    files.push(own "src/test/ref.til")
    files.push(own "src/test/own_fields.til")
    files.push(own "src/test/macros.til")
    files.push(own "src/test/enums.til")
    files.push(own "src/test/vecs.til")
    files.push(own "src/test/arrays.til")
    files.push(own "src/test/sets.til")
    files.push(own "src/test/maps.til")
    files.push(own "src/test/globals.til")
    files.push(own "src/test/globals_cli.til")
    files.push(own "src/test/misc.til")
    files.push(own "src/test/array_lit.til")
    files.push(own "src/test/cmp.til")
    files.push(own "src/test/ufcs.til")
    files.push(own "src/test/booleans.til")
    files.push(own "src/test/imports.til")
    files.push(own "src/test/import_diamond.til")
    files.push(own "src/test/pure.til")
    files.push(own "src/test/aliases.til")
    files.push(own "src/test/lexing.til")

    run_tests_parallel(files, j, fail)

    // --- Section 2: FFI test (interpret + codegen, check output) ---

    ffi_expected := "hello world".concat(NL).concat("hello universe").concat(NL)

    ec_ffi := run_capture(CTIL.concat(" interpret src/examples/ffi/ext_module.til"))
    ffi_out := readfile(TMPF)
    if ec_ffi.neq(0).or(ffi_out.neq(ffi_expected)) {
        println("FAIL (interpret): ffi/ext_module")
        fail = 1
    }

    ec_ffi2 := run_capture(CTIL.concat(" run src/examples/ffi/ext_module.til"))
    ffi_out2 := readfile(TMPF)
    if ec_ffi2.neq(0).or(ffi_out2.neq(ffi_expected)) {
        println("FAIL (codegen):   ffi/ext_module")
        fail = 1
    }

    // --- Section 3: Typer errors (count "type error:" occurrences) ---

    run_capture(CTIL.concat(" interpret src/test/typer_errors.til"))
    typer_out := readfile(TMPF)
    errors := count_matches(typer_out, "type error:")
    if errors.neq(42) {
        println("FAIL: typer_errors expected 42 errors, got ", errors.to_str())
        fail = 1
    }

    // --- Section 4: CLI args tests ---

    cli_test("src/examples/cli_args.til", "hello world",
        "hello".concat(NL).concat("world").concat(NL), 0, fail)
    cli_test("src/examples/cli_args.til", "",
        "", 0, fail)
    cli_test("src/examples/cli_typed.til", "alice 42",
        "alice 42".concat(NL), 0, fail)
    cli_test("src/examples/hello_cli.til", "",
        "Hello World!".concat(NL), 0, fail)
    cli_test("src/examples/cli_variadic_i64.til", "add 10 20 30",
        "60".concat(NL), 0, fail)
    cli_test("src/examples/cli_variadic_i64.til", "mul 2 3 4",
        "24".concat(NL), 0, fail)
    cli_test("src/examples/cli_variadic_i64.til", "add",
        "0".concat(NL), 0, fail)
    cli_test("src/examples/cli_variadic_bool.til", "true true false",
        "false".concat(NL), 0, fail)
    cli_test("src/examples/cli_variadic_bool.til", "true true",
        "true".concat(NL), 0, fail)
    // Error cases (nonzero exit)
    cli_test("src/examples/cli_typed.til", "alice", "", 1, fail)
    cli_test("src/examples/cli_typed.til", "a b c", "", 1, fail)
    cli_test("src/examples/hello_cli.til", "extra", "", 1, fail)

    if fail.eq(0) {
        println("all tests passed")
    }
    exit(fail)
}
