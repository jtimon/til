mode cli

import("std/sys")

NL := "\n"
TIL := "bin/til"
RUNNER := "bin/test_runner"
PLOT := "bin/plot"
GUI_TIMEOUT := "1"
DOC_DOCTEST_FILE := "tmp/doc_doctests.til"

count_matches := func(haystack: Str, needle: Str) returns I64 {
    if needle.is_empty() { return 0 }
    mut count := 0
    mut start : USize = 0
    while start <= haystack.len() - needle.len() {
        pos := haystack.substr(start, haystack.len() - start).find(needle)
        if pos == -1 { return count }
        count++
        pos_u : USize = pos.to_usize()
        start = start.add(pos_u) + needle.len()
    }
    return count
}

// Run a shell command, return exit code
run := proc(cmd: Str) returns I64 {
    pid := spawn_cmd(cmd)
    return wait_cmd(pid)
}

// --- Helpers ---

ms_to_str := func(ms: I64) returns Str {
    secs := ms / 1000
    frac := ms.mod(1000) / 10
    mut frac_str := frac.to_str()
    if frac < 10 { frac_str = format("0", frac_str) }
    return format(secs.to_str(), ".", frac_str, "s")
}

pad_right := func(s: Str, width: USize) returns Str {
    mut result := s.clone()
    while result.len() < width {
        result = format(result, " ")
    }
    return result
}

test_basename := func(path: Str) returns Str {
    mut last_slash : USize = 0
    mut has_slash := 0
    for si in 0..path.len() {
        if path.get(si) == '/' {
            last_slash = si
            has_slash = 1
        }
    }
    mut name := path
    if has_slash == 1 {
        name = path.substr(last_slash + 1, path.len().sub(last_slash) - 1)
    }
    if name.ends_with(".til") {
        name = name.strip_suffix(".til")
    }
    return name
}

parse_kv := func(line: Str, key: Str) returns I64 {
    needle := format(key, "=")
    pos := line.find(needle)
    if pos < 0 { return 0 }
    pos_u : USize = pos.to_usize()
    start := pos_u + needle.len()
    mut end := start
    while end.lt(line.len()).and(line.get(end).neq(' ')).and(line.get(end).neq(10)) {
        end++
    }
    return line.substr(start, end - start).to_i64()
}

mode_flags := func(en_interp: I64, en_run: I64, asan_flag: Str) returns Str {
    mut f := ""
    if en_interp == 0 { f = format(f, " -no-interp") }
    if en_run == 0 { f = format(f, " -no-run") }
    if asan_flag.len() > 0 { f = format(f, " ", asan_flag) }
    return f
}

doc_test_line_end := func(body: Str, pos: USize) returns USize {
    rest := body.substr(pos, body.len() - pos)
    line_rel := rest.find("\n")
    if line_rel < 0 { return body.len() }
    return pos + line_rel.to_usize()
}

doc_test_next_line_pos := func(body: Str, line_end: USize) returns USize {
    if line_end >= body.len() { return body.len() }
    return line_end + 1
}

doc_test_comment_text := func(line: Str, path: Str) returns Str {
    trimmed := line.trim()
    if trimmed.starts_with("///").not() { panic("unterminated doctest block in ", path) }
    mut text := trimmed.strip_prefix("///").clone()
    if text.starts_with(" ") { text = text.strip_prefix(" ").clone() }
    return text
}

doc_test_is_doctest_begin := func(line: Str) returns Bool {
    trimmed := line.trim()
    if trimmed.starts_with("///").not() { return false }
    text := doc_test_comment_text(line, "<doc-test>")
    return text.trim().starts_with("#+begin_src").and(text.contains(":doctest"))
}

append_source_doc_doctests := func(mut out: Str, path: Str, source: Str, count: USize) returns USize {
    mut next_count := count
    mut pos : USize = 0
    while pos < source.len() {
        line_end := doc_test_line_end(source, pos)
        line := source.substr(pos, line_end - pos)
        if doc_test_is_doctest_begin(line) {
            pos = doc_test_next_line_pos(source, line_end)
            out.push_str("doctest_")
            out.push_str(next_count.to_str())
            out.push_str(" := test() {\n")
            mut found_end := false
            mut has_body := false
            while pos < source.len() {
                src_line_end := doc_test_line_end(source, pos)
                src_line := source.substr(pos, src_line_end - pos)
                body_line := doc_test_comment_text(src_line, path)
                if body_line.trim().starts_with("#+end_src") {
                    found_end = true
                    pos = doc_test_next_line_pos(source, src_line_end)
                    break
                }
                if body_line.trim().is_empty().not() { has_body = true }
                out.push_str(body_line)
                out.push_str("\n")
                pos = doc_test_next_line_pos(source, src_line_end)
            }
            if found_end.not() { panic("unterminated doctest block in ", path) }
            if has_body.not() { panic("empty doctest block in ", path) }
            out.push_str("}\n\n")
            next_count++
            continue
        }
        pos = doc_test_next_line_pos(source, line_end)
    }
    return next_count
}

write_doc_doctests := proc(out_path: Str) {
    source := File.readfile("src/core/str.til")
    mut out := Str.with_capacity(source.len().mul(2) + 1024)
    out.push_str("mode test\n\n")
    count := append_source_doc_doctests(out, "src/core/str.til", source, 0)
    if count == 0 { panic("no doc doctests found") }
    File.writefile(out_path, out)
}

// --- Data structures ---

BothData := struct {
    interp_ms := 0
    interp_ok := 0
    interp_mem := 0
    compile_ms := 0
    compile_ok := 0
    compile_mem := 0
    run_ms := 0
    run_ok := 0
    run_mem := 0
    output_match := 1
namespace:
    eq := func(a: BothData, b: BothData) returns Bool {
        return a.interp_ms.eq(b.interp_ms).and(a.interp_ok.eq(b.interp_ok))
            .and(a.interp_mem.eq(b.interp_mem))
            .and(a.compile_ms.eq(b.compile_ms)).and(a.compile_ok.eq(b.compile_ok))
            .and(a.compile_mem.eq(b.compile_mem))
            .and(a.run_ms.eq(b.run_ms)).and(a.run_ok.eq(b.run_ok))
            .and(a.run_mem.eq(b.run_mem))
            .and(a.output_match.eq(b.output_match))
    }
    to_str := func(_self: BothData) returns Str { return "BothData" }
}

TestKind := enum { Both: BothData, Single, Count }

Test := struct {
    label := ""
    cmd := ""
    outfile := ""
    category := ""
    kind := TestKind.Single
    // scheduling
    pid := 0
    start_ms := 0
    // common results
    ok := 0
    ms := 0
    mem := 0
    // both config flags
    has_interp := 0
    has_run := 0
}

Slot := struct {
    test_idx : USize = 0
    pid := 0
    start_ms := 0
}

// --- Output helpers ---

print_test_result := proc(t: Test) {
    switch t.kind {
    case TestKind.Both(md):
        mut line := pad_right(t.label, 42)
        if t.has_interp == 1 { line = format(line, "interp: ", pad_right(ms_to_str(md.interp_ms), 9)) }
        if t.has_run == 1 { line = format(line, "compile: ", pad_right(ms_to_str(md.compile_ms), 9), "run: ", pad_right(ms_to_str(md.run_ms), 9)) }
        if md.output_match == 0 { line = format(line, " MISMATCH") }
        println(line)
    case:
        if t.ok == 1 {
            println(pad_right(t.label, 42), ms_to_str(t.ms))
        }
    }
}

// --- Registration helpers ---

add_both := func(tests: Vec(Test), file: Str, flags: Str) {
    bn := test_basename(file)
    tests.push(own Test(
        label = file.clone(),
        cmd = format(RUNNER, " both '", file, "'", flags),
        outfile = format("gen/out/results/", bn, ".txt"),
        category = "both",
        kind = TestKind.Both(BothData()),
        has_interp = 1, has_run = 1
    ))
}

add_single := func(tests: Vec(Test), label: Str, category: Str,
    expected_exit: I64, expected_out: Str, cmd_suffix: Str) {
        mut runner_cmd := format(RUNNER, " single ", label, " ", expected_exit.to_str())
        if expected_out.len() > 0 {
            runner_cmd = format(runner_cmd, " ", expected_out)
        }
        runner_cmd = format(runner_cmd, " -- ", cmd_suffix)
        tests.push(own Test(
            label = label.clone(),
            cmd = runner_cmd,
            outfile = format("gen/out/results/", label, ".txt"),
            category = category.clone(),
            kind = TestKind.Single
        ))
    }

add_count := func(tests: Vec(Test), label: Str, category: Str,
    needle: Str, expected_count: I64, cmd_suffix: Str) {
        runner_cmd := format(RUNNER, " count ", label, " '", needle, "' ", expected_count.to_str(), " -- ", cmd_suffix)
        tests.push(own Test(
            label = label.clone(),
            cmd = runner_cmd,
            outfile = format("gen/out/results/", label, ".txt"),
            category = category.clone(),
            kind = TestKind.Count
        ))
    }

add_cli_pair := func(tests: Vec(Test), name: Str, file: Str,
    cli_args: Str, expected_exit: I64, expected_out: Str,
    til: Str, asan_flag: Str) {
        mut cmd_i := format(til, " interpret ", file)
        if cli_args.len() > 0 { cmd_i = format(cmd_i, " ", cli_args) }
        add_single(tests, format(name, "_i"), "cli", expected_exit, expected_out, cmd_i)
        mut cmd_r := format(til, " run", asan_flag, " -o bin/c/", name,
            " -c gen/c/", name, ".c ",
            file)
        if cli_args.len() > 0 { cmd_r = format(cmd_r, " ", cli_args) }
        add_single(tests, format(name, "_r"), "cli", expected_exit, expected_out, cmd_r)
    }

// --- Blind parallel runner ---

run_all_parallel := proc(tests: Vec(Test), j: USize, mut fail: I64, mut suite_end_ms: I64) {
    mut next : USize = 0
    mut active : USize = 0

    slots := Array(Slot).new(j)
    mut si : USize = 0
    while si < j {
        slots[si] = Slot()
        si++
    }

    // Spawn initial batch
    si = 0
    while si.lt(j).and(next.lt(tests.len())) {
        ref t : Test = tests[next]
        cmd := format(t.cmd, " > ", t.outfile, " 2>&1")
        start := clock_ms()
        pid := spawn_cmd(cmd)
        slots[si] = Slot(test_idx = next, pid = pid, start_ms = start)
        active++
        next++
        si++
    }

    // Poll loop
    while active > 0 {
        mut i : USize = 0
        while i < j {
            ref slot : Slot = slots[i]
            if slot.pid > 0 {
                status := check_cmd_status(slot.pid)
                if status != -1 {
                    ref t : Test = tests[slot.test_idx]
                    runner_out := File.readfile(t.outfile)

                    // Find RESULT line
                    mut result_line := ""
                    result_pos := runner_out.rfind("RESULT ")
                    if result_pos >= 0 {
                        result_pos_u : USize = result_pos.to_usize()
                        result_line = runner_out.substr(result_pos_u,
                            runner_out.len() - result_pos_u)
                    }

                    // Parse common fields
                    t.ok = parse_kv(result_line, "ok")
                    t.ms = parse_kv(result_line, "ms")
                    t.mem = parse_kv(result_line, "mem")
                    // Parse both-specific fields into payload
                    switch t.kind {
                    case TestKind.Both(md):
                        md.interp_ms = parse_kv(result_line, "interp_ms")
                        md.interp_ok = parse_kv(result_line, "interp_ok")
                        md.interp_mem = parse_kv(result_line, "interp_mem")
                        md.compile_ms = parse_kv(result_line, "compile_ms")
                        md.compile_ok = parse_kv(result_line, "compile_ok")
                        md.compile_mem = parse_kv(result_line, "compile_mem")
                        md.run_ms = parse_kv(result_line, "run_ms")
                        md.run_ok = parse_kv(result_line, "run_ok")
                        md.run_mem = parse_kv(result_line, "run_mem")
                        md.output_match = parse_kv(result_line, "match")
                        t.kind = TestKind.Both(md.clone())
                    case:
                    }

                    print_test_result(t)

                    // Suite wall excludes the self-translate benchmark: record
                    // when each non-"self" test finishes; the last one marks the
                    // end of the real suite (self runs in parallel past it).
                    if t.category != "self" { suite_end_ms = clock_ms() }

                    if status != 0 {
                        runner_lines := runner_out.split(NL)
                        mut li : USize = 0
                        while li < runner_lines.len() {
                            ref ln : Str = runner_lines[li]
                            if ln.starts_with("FAIL").or(ln.starts_with("MISMATCH")) {
                                println(ln)
                            }
                            li++
                        }
                        fail = 1
                    }

                    active--
                    slot.pid = 0

                    if next < tests.len() {
                        ref nt : Test = tests[next]
                        cmd := format(nt.cmd, " > ", nt.outfile, " 2>&1")
                        start := clock_ms()
                        pid := spawn_cmd(cmd)
                        slots[i] = Slot(test_idx = next, pid = pid, start_ms = start)
                        active++
                        next++
                    }
                }
            }
            i++
        }
        if active > 0 {
            sleep_ms(10)
        }
    }
}

// --- Main ---

main := proc(args: ..Str) {
    wall_start := clock_ms()

    // Parse args: -jN, -no-interp, -no-run, --no-gui, --til-bin <path>, --asan
    mut j : USize = get_thread_count().to_usize()
    mut en_interp := 1
    mut en_run := 1
    mut en_gui := 1
    mut til_bin := TIL
    mut asan := 0
    mut i : USize = 0
    while i < args.len() {
        ref arg : Str = args[i]
        if arg.starts_with("-j") {
            j = arg.substr(2, arg.len() - 2).to_usize()
            if j < 1 { j = 1 }
        }
        if arg == "-no-interp" { en_interp = 0 }
        if arg == "-no-run" { en_run = 0 }
        if arg == "--no-gui" { en_gui = 0 }
        if arg.eq("--til-bin").and(i.add(1).lt(args.len())) {
            i++
            ref val : Str = args[i]
            til_bin = val.clone()
        }
        if arg == "--asan" { asan = 1 }
        i++
    }

    // When --asan is set, asan_flag is spliced after "build"/"run"/"test"
    // so the underlying `til build` invocation produces an ASAN-instrumented
    // binary. Compiled binaries built this way run under ASAN and report
    // their own leaks when executed.
    mut asan_flag := ""
    if asan == 1 { asan_flag = " --asan" }

    mut fail := 0

    // Create output directories
    run("mkdir -p gen/out/interp gen/out/run gen/out/results gen/out/single gen/out/expected tmp")

    tests := Vec(Test).new()
    mut flags := mode_flags(en_interp, en_run, asan_flag)
    if til_bin != TIL { flags = format(" --til-bin ", til_bin, flags) }

    // Self-translate: bin/til translate src/til.til -- the compiler translating
    // its own source, the largest input it handles and the single slowest job.
    // Registered FIRST so run_all_parallel spawns it in the first batch; it then
    // holds one of the j parallel slots for the whole run (usually the long
    // pole). Its time is collected via the "self" category into self_ms and is
    // deliberately EXCLUDED from wall_ms (run_all_parallel marks the suite end
    // from the last non-"self" test), so the benchmark does not inflate wall.
    // Exit must be 0: the compiler has to be able to translate itself.
    add_single(tests, "self_translate", "self", 0, "",
        format(til_bin, " translate src/til.til"))

    // Issue #302 stage 0: the garbager decision-audit golden. Translating
    // the frozen fixture with TIL_GC_AUDIT set dumps the asap pass's
    // per-binding decisions and destructor sites; the byte-exact compare
    // against test/gc_audit.expected turns any decision change into a
    // reviewable diff. Regeneration recipe in test/gc_audit.til's header.
    add_single(tests, "gc_audit", "self", 0, "test/gc_audit.expected",
        format("TIL_GC_AUDIT=test/gc_audit.til ", til_bin, " translate test/gc_audit.til"))

    // Tests are registered slowest-first: run_all_parallel fills its parallel
    // slots in registration order and never reorders, so front-loading the
    // long-running jobs (GUI builds, then the slow both tests) keeps the
    // parallel tail short. The ordering below is based on per-test times from
    // a full `make test` run.

    // === GUI build tests (slowest: build + run with timeout) ===
    // Issue #266: GUI tests run as plain X clients of the single Xvfb that
    // the Makefile's outer `xvfb-run` starts for the whole suite (DISPLAY
    // is inherited). The old per-test `xvfb-run --auto-servernum` spawned
    // 16 nested X servers whose EXIT-trap teardowns raced on their /tmp
    // auth dirs: a failed `rm -r` there rewrote the healthy 124 exit
    // (from `timeout`) into xvfb-run's own exit 5.
    if en_gui == 1 {
        gui_files := array(Str,
            "examples/music_modes.til",
            "examples/piano.til",
            "examples/guitar.til",
            "examples/chess.til",
            "examples/checkers.til",
            "examples/go.til",
            "examples/snake.til",
            "examples/shootil.til",
            "examples/editor.til",
            "examples/minesweeper.til",
            "examples/font_test.til",
            "examples/popcorn.til",
            "examples/tilminal.til",
            "examples/game_of_life.til",
            "examples/hello_gui.til",
            "examples/raylib.til",
        )
        for gf : Str in gui_files {
            bn := test_basename(gf)
            mut run_args := ""
            if bn == "popcorn" { run_args = " --mute" }
            add_single(tests, format("build_", bn), "build", 124, "",
                format(til_bin, " build", asan_flag, " ", gf, " '&&' timeout ", GUI_TIMEOUT, " bin/", bn, run_args))
        }
    }

    // === both tests (sorted slowest-first) ===
    add_both(tests, "test/hashmaps.til", flags)
    add_both(tests, "test/dyn_hashmaps.til", flags)
    add_both(tests, "test/kwargs.til", flags)
    add_both(tests, "test/constfold.til", flags)
    add_both(tests, "test/strings.til", flags)
    add_both(tests, "test/enums.til", flags)
    add_both(tests, "test/match.til", flags)
    add_both(tests, "test/lazy.til", flags)
    add_both(tests, "test/dynamic.til", flags)
    add_both(tests, "test/maps.til", flags)
    add_both(tests, "test/dyn_maps.til", flags)
    add_both(tests, "test/hashes.til", flags)
    add_both(tests, "test/operators.til", flags)
    add_both(tests, "test/flow.til", flags)
    add_both(tests, "test/asting.til", flags)
    add_both(tests, "test/structs.til", flags)
    add_both(tests, "test/interfaces.til", flags)
    add_both(tests, "test/types.til", flags)
    add_both(tests, "test/cast.til", flags)
    add_both(tests, "test/directives.til", flags)
    add_both(tests, "test/variadic.til", flags)
    add_both(tests, "test/loops.til", flags)
    add_both(tests, "test/aliases.til", flags)
    add_both(tests, "test/fn_ptr.til", flags)
    add_both(tests, "test/comparisons.til", flags)
    add_both(tests, "test/vecs.til", flags)
    add_both(tests, "test/dyn_vecs.til", flags)
    add_both(tests, "test/eval_heap.til", flags)
    add_both(tests, "test/templ_vec.til", flags)
    add_both(tests, "test/templ_cross_unit.til", flags)
    add_both(tests, "test/templ_type_only.til", flags)
    add_both(tests, "test/priv.til", flags)
    add_both(tests, "test/trailing.til", flags)
    add_both(tests, "test/globals.til", flags)
    add_both(tests, "test/errors.til", flags)
    add_both(tests, "test/tuples.til", flags)
    add_both(tests, "test/auto.til", flags)
    add_both(tests, "test/first_class.til", flags)
    add_both(tests, "test/closures.til", flags)
    add_both(tests, "test/regression.til", flags)
    add_both(tests, "test/files.til", flags)
    add_both(tests, "test/circular_imports.til", flags)
    add_both(tests, "test/import_diamond.til", flags)
    // macros.til contains a macro that prints during constfolder; the line
    // appears in interpret output but not in compiled-run output, so
    // skip the run-vs-interp comparison.
    add_both(tests, "test/macros.til", format(flags, " -no-match"))
    add_both(tests, "test/sets.til", flags)
    add_both(tests, "test/dyn_sets.til", flags)
    add_both(tests, "test/local_defs.til", flags)
    add_both(tests, "test/shallow.til", flags)
    add_both(tests, "test/globals_cli.til", flags)
    add_both(tests, "test/own_fields.til", flags)
    add_both(tests, "test/bug256.til", flags)
    add_both(tests, "test/bug258.til", flags)
    add_both(tests, "examples/priv_demo.til", flags)
    add_both(tests, "test/imports.til", flags)
    add_both(tests, "test/arrays.til", flags)
    add_both(tests, "test/dyn_arrays.til", flags)
    add_both(tests, "test/test_in_namespace.til", flags)
    add_both(tests, "test/forward_refs.til", flags)
    add_both(tests, "test/functions.til", flags)
    // TODO: namespaces.til fails the typer: MyNamespace.set is a proc with no
    // proc/ext_proc calls and the typer now demands it be a func. Update the
    // test (or the rule) then re-enable.
    // add_both(tests, "test/namespaces.til", flags)
    // TODO: topo_sort.til segfaults in interp mode (inline nested struct
    // fields A->B->C). Fix the crash then re-enable.
    // add_both(tests, "test/topo_sort.til", flags)
    add_both(tests, "test/ref.til", flags)
    // enums_lifecycle runs compile-only (interp disabled), so it is the
    // fastest both test; keep it last.
    add_both(tests, "test/enums_lifecycle.til", mode_flags(0, en_run, asan_flag))
    // doc_block_comments imports the lexer and builds Tokens (U32 fields),
    // so it runs compile-only like the lexing tests below (issue #182).
    add_both(tests, "test/doc_block_comments.til", mode_flags(0, en_run, asan_flag))
    // TODO: lexing.til and parsing.til fail interp mode after Token line/col I64->U32
    // (interpreter doesn't handle U32 struct fields correctly)
    // add_both(tests, "test/lexing.til", flags)
    // add_both(tests, "test/parsing.til", flags)
    // TODO(#114): help()/doc comments are REPL-only for now; doc_comments.til
    // assumes docs are populated for til test / til interpret.
    // add_both(tests, "test/doc_comments.til", flags)
    write_doc_doctests(DOC_DOCTEST_FILE)
    add_both(tests, DOC_DOCTEST_FILE, flags)

    // === 2 FFI tests ===
    ffi_exp := "gen/out/expected/ffi.out"
    File.writefile(ffi_exp, format("hello world", NL, "hello universe", NL))
    add_single(tests, "ffi_interp", "ffi", 0, ffi_exp,
        format(til_bin, " interpret examples/ffi/ext_module.til"))
    add_single(tests, "ffi_run", "ffi", 0, ffi_exp,
        format(til_bin, " run", asan_flag, " examples/ffi/ext_module.til"))
    ffi_scavenge_exp := "gen/out/expected/ffi_scavenge.out"
    File.writefile(ffi_scavenge_exp, "ok")
    add_single(tests, "ffi_scavenge_link_c_run", "ffi", 0, ffi_scavenge_exp,
        format(til_bin, " run", asan_flag, " test/ffi_scavenge_link_c.til"))
    // Issue #176: binding libc functions like setenv/getenv directly via
    // ext_func must compile under -Werror and produce the expected behaviour.
    ext_libc_exp := "gen/out/expected/ext_libc.out"
    File.writefile(ext_libc_exp, format("ok", NL))
    add_single(tests, "ext_libc_run", "ffi", 0, ext_libc_exp,
        format(til_bin, " run", asan_flag, " test/ext_libc.til"))
    // Issue #283: a real dlopen failure must be reported loudly at RUNTIME.
    // The diagnostic's stderr_print/ffi_last_error are ext_proc so the
    // const-folder never executes them at build time (which printed a bogus
    // line and dropped the runtime report). Assert the message appears exactly
    // once when interpreting a file whose FFI .so fails to load.
    //
    // The failure SHAPE is platform-dependent (issue #25): ELF defers
    // undefined symbols to dlopen time, so the .so builds and dlopen
    // fails; Mach-O's linker refuses the undefined symbol while BUILDING
    // the .so, so the loud runtime report is the compile failure instead.
    // Both paths exercise the same #283 guarantee: the interpreter
    // reports the FFI load problem at runtime rather than swallowing it.
    mut dlopen_fail_pat := "dlopen failed"
    if host_os() == "macos" { dlopen_fail_pat = "failed to compile FFI library" }
    add_count(tests, "ffi_dlopen_fail_interp", "ffi", dlopen_fail_pat, 1,
        format(til_bin, " interpret test/ffi_dlopen_fail.til"))

    // === library mode checks (pure/pura build are the heaviest here) ===
    add_single(tests, "pure_build", "library", 0, "",
        format(til_bin, " build", asan_flag, " test/pure.til"))
    add_single(tests, "pura_build", "library", 0, "",
        format(til_bin, " build", asan_flag, " test/pura.til"))
    add_single(tests, "pure_interp_forbidden", "library", 1, "",
        format(til_bin, " interpret test/pure.til"))
    add_single(tests, "pure_run_forbidden", "library", 1, "",
        format(til_bin, " run", asan_flag, " test/pure.til"))
    add_single(tests, "pura_interp_forbidden", "library", 1, "",
        format(til_bin, " interpret test/pura.til"))
    add_single(tests, "pura_run_forbidden", "library", 1, "",
        format(til_bin, " run", asan_flag, " test/pura.til"))

    // === build tests: svg2ttf + issues summary ===
    // svg2ttf: transparent 2-colour logo produces img/til_logo.ttf (exit=0);
    // the full-colour logo panics with "too many colours" (exit=1).
    // Compiled-run only (no interpret variant); the interpreted run takes
    // ~90s and dominates wall time. Categorised as "build" so its time goes
    // into build_ms rather than cli_ms in totals.
    run("mkdir -p img")
    add_single(tests, "svg2ttf_ok", "build", 0, "",
        format(til_bin,
            " run", asan_flag, " -o bin/c/svg2ttf_ok -c gen/c/svg2ttf_ok.c ",
            "examples/svg2ttf.til ",
            "img/logo-transparent.svg img/til_logo.ttf"))
    add_single(tests, "svg2ttf_too_many_colors", "build", 1, "",
        format(til_bin,
            " run", asan_flag, " -o bin/c/svg2ttf_too_many_colors -c gen/c/svg2ttf_too_many_colors.c ",
            "examples/svg2ttf.til ",
            "img/logo.svg tmp/svg2ttf_fail.ttf"))
    // issues.til is fast enough to keep in the regular suite; it refreshes
    // issues/summary.org from the current issue files.
    add_single(tests, "issues_summary", "build", 0, "",
        format(til_bin,
            " run", asan_flag, " -o bin/c/issues_summary -c gen/c/issues_summary.c ",
            "examples/issues.til"))

    // === custom modes build tests ===
    add_single(tests, "build_sender", "build", 0, "",
        format(til_bin, " build", asan_flag, " -o bin/sender --extra-modes=examples/custom_modes.til examples/sender.til"))
    add_single(tests, "build_receiver", "build", 0, "",
        format(til_bin, " build", asan_flag, " -o bin/receiver --extra-modes=examples/custom_modes.til examples/receiver.til"))
    add_single(tests, "build_publisher", "build", 0, "",
        format(til_bin, " build", asan_flag, " -o bin/publisher --extra-modes=examples/custom_modes.til examples/publisher.til"))
    add_single(tests, "build_subscriber", "build", 0, "",
        format(til_bin, " build", asan_flag, " -o bin/subscriber --extra-modes=examples/custom_modes.til examples/subscriber.til"))

    // === til test command (issue #51): runs interpret + compile-and-run
    // and counts "tests passed" lines so both backends are exercised.
    add_count(tests, "til_test_cmd", "test", "tests passed", 2,
        format(til_bin, " test", asan_flag, " test/test_in_namespace.til"))

    // === parser / typer diagnostics ===
    add_count(tests, "typer_errors", "typer", "error:", 164,
        format(til_bin, " interpret test/typer_errors.til"))
    add_count(tests, "capture_block_error", "typer",
        "is not captured", 2,
        format(til_bin, " interpret test/capture_block_error.til"))
    add_count(tests, "capture_func_error", "typer",
        "cannot capture immutable", 1,
        format(til_bin, " interpret test/capture_func_error.til"))
    // #288: a core_func / core_proc is an inline-only primitive intrinsic and
    // cannot be indirected -- dyn_fn on one is a typer error (2 cases). Count
    // the enforcement substring, not "error:", since dyn_fn's Dynamic result
    // also (correctly) trips the "store Dynamic in '_'" diagnostic.
    add_count(tests, "core_func_errors", "typer",
        "cannot be indirected via dyn_fn", 2,
        format(til_bin, " interpret test/core_func_errors.til"))
    // Issue #54: function closures run under both backends.
    add_single(tests, "closures_interp", "closures", 0, "",
        format(til_bin, " interpret test/closures_interp.til"))
    add_single(tests, "closures_compile", "closures", 0, "",
        format(til_bin, " run", asan_flag, " test/closures_interp.til"))
    add_single(tests, "closures_compile_escape", "closures", 0, "",
        format(til_bin, " run", asan_flag, " test/closures_compile_escape.til"))
    add_count(tests, "capture_escape_error", "typer",
        "returned closure borrows captured local", 1,
        format(til_bin, " interpret test/capture_escape_error.til"))
    add_count(tests, "capture_own_arg_escape_error", "typer",
        "own argument closure borrows captured local", 1,
        format(til_bin, " interpret test/capture_own_arg_escape_error.til"))
    add_count(tests, "capture_mut_escape_error", "typer",
        "returned closure borrows captured local", 1,
        format(til_bin, " interpret test/capture_mut_escape_error.til"))
    add_count(tests, "qualifier_shallow_local_error", "parser",
        "locals cannot use", 1,
        format(til_bin, " interpret test/qualifier_shallow_local_error.til"))
    add_count(tests, "qualifier_ref_param_error", "parser",
        "parameters are borrowed by default", 1,
        format(til_bin, " interpret test/qualifier_ref_param_error.til"))
    add_count(tests, "qualifier_returns_own_error", "parser",
        "returns are owned by default", 1,
        format(til_bin, " interpret test/qualifier_returns_own_error.til"))
    add_count(tests, "qualifier_const_local_error", "parser",
        "on local: locals are immutable by default", 1,
        format(til_bin, " interpret test/qualifier_const_local_error.til"))
    add_count(tests, "qualifier_const_param_error", "parser",
        "on parameter: parameters are immutable by default", 1,
        format(til_bin, " interpret test/qualifier_const_param_error.til"))
    add_count(tests, "qualifier_mut_payload_error", "parser",
        "on variant payload: payloads are mutable by default", 1,
        format(til_bin, " interpret test/qualifier_mut_payload_error.til"))
    add_count(tests, "qualifier_mut_field_error", "typer",
        "on struct field", 1,
        format(til_bin, " interpret test/qualifier_mut_field_error.til"))
    add_count(tests, "qualifier_const_namespace_error", "parser",
        "on namespace declaration: namespace decls are immutable by default", 1,
        format(til_bin, " interpret test/qualifier_const_namespace_error.til"))
    add_count(tests, "const_payload_error", "typer",
        "cannot assign to immutable variable", 1,
        format(til_bin, " interpret test/const_payload_error.til"))
    add_count(tests, "priv_error_interp", "typer",
        "is private to", 4,
        format(til_bin, " interpret test/priv_error.til"))
    add_count(tests, "priv_error_build", "typer",
        "is private to", 4,
        format(til_bin, " build", asan_flag, " test/priv_error.til"))
    // #154: unused-import check, on by default. The same file with an
    // unused import passes with --check-unused-imports=false.
    add_count(tests, "unused_import_error", "typer",
        "unused import", 1,
        format(til_bin, " interpret test/unused_import_error.til"))
    add_single(tests, "unused_import_error_off", "typer", 0, "",
        format(til_bin, " interpret --check-unused-imports=false test/unused_import_error.til"))
    add_single(tests, "unused_import_ok", "typer", 0, "",
        format(til_bin, " interpret test/unused_import_ok.til"))
    add_count(tests, "priv_unused_error_interp", "typer",
        "unused priv", 7,
        format(til_bin, " interpret test/priv_unused_error.til"))
    add_count(tests, "priv_unused_error_build", "typer",
        "unused priv", 7,
        format(til_bin, " build", asan_flag, " test/priv_unused_error.til"))
    add_count(tests, "enum_switch_missing_case_interp", "typer",
        "non-exhaustive switch on enum", 4,
        format(til_bin, " interpret test/enum_switch_missing_case.til"))
    add_count(tests, "enum_switch_missing_case_build", "typer",
        "non-exhaustive switch on enum", 4,
        format(til_bin, " build", asan_flag, " test/enum_switch_missing_case.til"))
    // A main() param whose type can't be parsed from a CLI argument is
    // rejected up front (validate_cli_main) on both backends.
    add_count(tests, "cli_unsupported_main_interp", "typer",
        "cannot be parsed from a CLI argument", 1,
        format(til_bin, " interpret test/cli_unsupported_main.til"))
    add_count(tests, "cli_unsupported_main_build", "typer",
        "cannot be parsed from a CLI argument", 1,
        format(til_bin, " build", asan_flag, " test/cli_unsupported_main.til"))
    // #242: missing-required-field cases live in test/typer_errors.til.
    // A no-default field with no explicit type stays illegal (parser).
    add_count(tests, "required_field_no_type_error", "parser",
        "expected", 1,
        format(til_bin, " interpret test/required_field_no_type_error.til"))

    // === CLI tests ===
    exp := "gen/out/expected/"

    File.writefile(format(exp, "cli_args_hello.out"), format("hello", NL, "world", NL))
    add_cli_pair(tests, "cli_args_hello", "examples/cli_args.til",
        "hello world", 0, format(exp, "cli_args_hello.out"), til_bin, asan_flag)
    add_single(tests, "cli_args_default_args", "cli", 0, format(exp, "cli_args_hello.out"),
        format(til_bin, " examples/cli_args.til hello world"))
    add_single(tests, "cli_args_dd_default_args", "cli", 0, format(exp, "cli_args_hello.out"),
        format(til_bin, " -- examples/cli_args.til hello world"))

    File.writefile(format(exp, "cli_args_empty.out"), "")
    add_cli_pair(tests, "cli_args_empty", "examples/cli_args.til",
        "", 0, format(exp, "cli_args_empty.out"), til_bin, asan_flag)

    mut fb_out := ""
    mut fbi := 1
    while fbi <= 100 {
        mut fb_line := ""
        if fbi % 15 == 0 {
            fb_line = "FizzBuzz"
        } else {
            if fbi % 3 == 0 {
                fb_line = "Fizz"
            } else {
                if fbi % 5 == 0 {
                    fb_line = "Buzz"
                } else {
                    fb_line = fbi.to_str()
                }
            }
        }
        fb_out = format(fb_out, fb_line, NL)
        fbi++
    }
    File.writefile(format(exp, "fizzbuzz.out"), fb_out)
    add_cli_pair(tests, "fizzbuzz", "examples/fizzbuzz.til",
        "", 0, format(exp, "fizzbuzz.out"), til_bin, asan_flag)

    // Issue #220: script-mode map/set literals must compile under -Werror.
    File.writefile(format(exp, "script_map_lit.out"),
        format("1", NL, "true", NL, "a", NL, "b", NL, "c", NL, "true", NL,
            "1", NL, "len=3 set=3", NL, "1", NL, "1", NL, "3", NL, "1", NL))
    add_cli_pair(tests, "script_map_lit", "test/script_map_lit.til",
        "", 0, format(exp, "script_map_lit.out"), til_bin, asan_flag)

    File.writefile(format(exp, "cli_typed_alice42.out"), format("alice 42", NL))
    add_cli_pair(tests, "cli_typed_alice42", "examples/cli_typed.til",
        "alice 42", 0, format(exp, "cli_typed_alice42.out"), til_bin, asan_flag)

    File.writefile(format(exp, "hello_cli.out"), format("Hello World!", NL))
    add_cli_pair(tests, "hello_cli", "examples/hello_cli.til",
        "", 0, format(exp, "hello_cli.out"), til_bin, asan_flag)
    add_single(tests, "hello_cli_dd_default", "cli", 0, format(exp, "hello_cli.out"),
        format(til_bin, " -- examples/hello_cli.til"))
    add_single(tests, "hello_cli_dd_i", "cli", 0, format(exp, "hello_cli.out"),
        format(til_bin, " interpret -- examples/hello_cli.til"))
    add_single(tests, "hello_cli_dd_r", "cli", 0, format(exp, "hello_cli.out"),
        format(til_bin, " run", asan_flag, " -o bin/c/hello_cli_dd -c gen/c/hello_cli_dd.c -- examples/hello_cli.til"))

    File.writefile(format(exp, "variadic_add.out"), format("60", NL))
    add_cli_pair(tests, "variadic_add", "examples/cli_variadic_i64.til",
        "add 10 20 30", 0, format(exp, "variadic_add.out"), til_bin, asan_flag)

    File.writefile(format(exp, "variadic_mul.out"), format("24", NL))
    add_cli_pair(tests, "variadic_mul", "examples/cli_variadic_i64.til",
        "mul 2 3 4", 0, format(exp, "variadic_mul.out"), til_bin, asan_flag)

    File.writefile(format(exp, "variadic_add0.out"), format("0", NL))
    add_cli_pair(tests, "variadic_add0", "examples/cli_variadic_i64.til",
        "add", 0, format(exp, "variadic_add0.out"), til_bin, asan_flag)

    File.writefile(format(exp, "variadic_bool_f.out"), format("false", NL))
    add_cli_pair(tests, "variadic_bool_f", "examples/cli_variadic_bool.til",
        "true true false", 0, format(exp, "variadic_bool_f.out"), til_bin, asan_flag)

    File.writefile(format(exp, "variadic_bool_t.out"), format("true", NL))
    add_cli_pair(tests, "variadic_bool_t", "examples/cli_variadic_bool.til",
        "true true", 0, format(exp, "variadic_bool_t.out"), til_bin, asan_flag)

    // Every scalar CLI arg type (I8/U8/I16/U16/I32/U32/U64/USize/UPtr/F32),
    // both backends. Locks in the builder's cli_box_expr and the interpreter's
    // parse_cli_arg staying in lockstep.
    File.writefile(format(exp, "cli_scalars.out"),
        format("-8 200 -300 600 -70000 90000 12345678901 42 99 3.5", NL))
    add_cli_pair(tests, "cli_scalars", "examples/cli_scalars.til",
        "-8 200 -300 600 -70000 90000 12345678901 42 99 3.5", 0,
        format(exp, "cli_scalars.out"), til_bin, asan_flag)

    // Error cases (exit=1, no output check)
    add_cli_pair(tests, "cli_typed_err1", "examples/cli_typed.til", "alice", 1, "", til_bin, asan_flag)
    add_cli_pair(tests, "cli_typed_err2", "examples/cli_typed.til", "a b c", 1, "", til_bin, asan_flag)
    add_cli_pair(tests, "hello_cli_err", "examples/hello_cli.til", "extra", 1, "", til_bin, asan_flag)
    // Bad Bool value: both backends print the diagnostic and exit(1).
    add_cli_pair(tests, "cli_bool_err", "examples/cli_variadic_bool.til", "true maybe", 1, "", til_bin, asan_flag)

    // === Run all tests in parallel ===
    mut suite_end_ms := 0
    run_all_parallel(tests, j, fail, suite_end_ms)

    // --- Accumulate totals ---

    println("")
    mut total_interp_ms := 0
    mut total_compile_ms := 0
    mut total_run_ms := 0
    mut total_mem_inte := 0
    mut total_mem_comp := 0
    mut total_mem_run := 0
    mut both_passed : USize = 0
    mut both_total : USize = 0
    mut pi : USize = 0
    while pi < tests.len() {
        ref t : Test = tests[pi]
        switch t.kind {
        case TestKind.Both(md):
            both_total++
            if t.has_interp == 1 {
                total_interp_ms = total_interp_ms + md.interp_ms
                total_mem_inte = total_mem_inte + md.interp_mem
            }
            if t.has_run == 1 {
                total_compile_ms = total_compile_ms + md.compile_ms
                total_run_ms = total_run_ms + md.run_ms
                total_mem_comp = total_mem_comp + md.compile_mem
                total_mem_run = total_mem_run + md.run_mem
            }
            if t.ok == 1 { both_passed++ }
        case:
        }
        pi++
    }

    // --- Section totals from non-both tests ---

    mut ffi_ms := 0
    mut typer_ms := 0
    mut cli_ms := 0
    mut build_ms := 0
    mut build_mem := 0
    mut self_ms := 0
    mut self_mem := 0
    mut other_passed : USize = 0
    mut other_total : USize = 0
    pi = 0
    while pi < tests.len() {
        ref t : Test = tests[pi]
        if t.kind.is(TestKind.Both).not() {
            other_total++
            if t.ok == 1 { other_passed++ }
            if t.category == "ffi" { ffi_ms = ffi_ms + t.ms }
            if t.category == "typer" { typer_ms = typer_ms + t.ms }
            if t.category == "cli" { cli_ms = cli_ms + t.ms }
            if t.category == "self" {
                self_ms = self_ms + t.ms
                self_mem = self_mem + t.mem
            }
            if t.category == "build" {
                build_ms = build_ms + t.ms
                build_mem = build_mem + t.mem
            }
        }
        pi++
    }

    // --- Plot test (stays sequential) ---

    plot_start := clock_ms()
    test_csv := format("commit,interp_ms,compile_ms,run_ms,ffi_ms,typer_ms,cli_ms,wall_ms,passed,total,mem_inte,mem_comp,mem_run,mem_total,self_ms,self_mem", NL,
        "abc1234,1950,4000,1530,200,1710,1970,4640,32,32,500000,900000,300000,1700000,5200,600000", NL,
        "def5678,1890,3900,1510,190,1680,1950,4500,32,32,520000,880000,320000,1720000,5100,620000", NL)
    File.writefile("tmp/_test_plot.csv", test_csv)
    run(format(PLOT, " tmp/_test_plot.csv tmp/_test_plot.svg 0"))
    plot_svg := File.readfile("tmp/_test_plot.svg")
    mut plot_ok := 1
    if count_matches(plot_svg, "<svg") == 0 {
        println("FAIL: plot.til missing <svg tag")
        plot_ok = 0
        fail = 1
    }
    if count_matches(plot_svg, "<polyline") < 9 {
        println("FAIL: plot.til expected 9 polylines, got ", count_matches(plot_svg, "<polyline").to_str())
        plot_ok = 0
        fail = 1
    }
    if count_matches(plot_svg, "abc1234") == 0 {
        println("FAIL: plot.til missing commit label abc1234")
        plot_ok = 0
        fail = 1
    }
    if count_matches(plot_svg, "inte") == 0 {
        println("FAIL: plot.til missing legend label inte")
        plot_ok = 0
        fail = 1
    }
    if count_matches(plot_svg, "mem-total") != 0 {
        println("FAIL: plot.til should not draw mem-total legend")
        plot_ok = 0
        fail = 1
    }
    if count_matches(plot_svg, ">self<") == 0 {
        println("FAIL: plot.til missing legend label self")
        plot_ok = 0
        fail = 1
    }
    if count_matches(plot_svg, ">self-mem<") == 0 {
        println("FAIL: plot.til missing legend label self-mem")
        plot_ok = 0
        fail = 1
    }
    plot_ms := clock_ms() - plot_start

    // --- Summary ---

    total_passed := both_passed.add(other_passed) + plot_ok.to_usize()
    total_tests := both_total.add(other_total) + 1

    // Wall excludes the self-translate benchmark: suite_end_ms is when the last
    // non-"self" test finished, so self_ms stands on its own without inflating
    // wall (self runs in parallel and is usually the long pole).
    wall_ms := suite_end_ms - wall_start

    println("")
    println("=== Summary ===")
    if en_interp == 1 { println("interp:       ", ms_to_str(total_interp_ms)) }
    if en_run == 1 {
        println("compile:      ", ms_to_str(total_compile_ms))
        println("run:          ", ms_to_str(total_run_ms))
    }
    println("FFI tests:    ", ms_to_str(ffi_ms))
    println("Typer errors: ", ms_to_str(typer_ms))
    println("CLI tests:    ", ms_to_str(cli_ms))
    println("Plot test:    ", ms_to_str(plot_ms))
    println("Build tests:  ", ms_to_str(build_ms))
    println("Self-translate: ", ms_to_str(self_ms))
    println("Wall-clock:   ", ms_to_str(wall_ms))
    println("Passed:       ", total_passed.to_i64().to_str(), "/", total_tests.to_i64().to_str())
    println("")

    if fail == 0 {
        println("all tests passed")
    }

    // --- Benchmark CSV logging ---

    run("git rev-parse --short HEAD > tmp/_commit_hash")
    commit := File.readfile("tmp/_commit_hash").replace(NL, "")

    // gen/benchmark.csv -- both tests only (not tracked)
    run("mkdir -p gen")
    mut bench := Str.with_capacity(32768)
    bench.push_str("commit,file,interp_ms,compile_ms,run_ms,interp_ok,compile_ok,run_ok")
    bench.push_str(NL)
    mut bi : USize = 0
    while bi < tests.len() {
        ref bt : Test = tests[bi]
        switch bt.kind {
        case TestKind.Both(bmd):
            bench.push_str(format(commit, ",", bt.label, ",",
                bmd.interp_ms.to_str(), ",", bmd.compile_ms.to_str(), ",",
                bmd.run_ms.to_str(), ",",
                bmd.interp_ok.to_str(), ",", bmd.compile_ok.to_str(), ",",
                bmd.run_ok.to_str(), NL))
        case:
        }
        bi++
    }
    File.writefile("gen/benchmark.csv", bench)

    // doc/totals.csv -- all test totals (skip on failure)
    if fail == 0 {
        total_mem_total := total_mem_inte.add(total_mem_comp).add(total_mem_run) + build_mem
        totals_line := format(commit, ",",
            total_interp_ms.to_str(), ",",
            total_compile_ms.to_str(), ",", total_run_ms.to_str(), ",",
            ffi_ms.to_str(), ",", typer_ms.to_str(), ",",
            cli_ms.to_str(), ",", wall_ms.to_str(), ",",
            total_passed.to_i64().to_str(), ",", total_tests.to_i64().to_str(), ",",
            total_mem_inte.to_str(), ",",
            total_mem_comp.to_str(), ",",
            total_mem_run.to_str(), ",",
            total_mem_total.to_str(), ",",
            self_ms.to_str(), ",",
            self_mem.to_str())

        totals_path := "doc/totals.csv"
        // tests.til owns the header so the column set (incl self_ms / self_mem)
        // always matches the data and survives the merge's `git restore
        // doc/totals.csv`: the file is auto-generated and discarded, so the
        // header only persists if it is regenerated here.
        header := "commit,interp_ms,compile_ms,run_ms,ffi_ms,typer_ms,cli_ms,wall_ms,passed,total,mem_inte,mem_comp,mem_run,mem_total,self_ms,self_mem"
        existing := File.readfile(totals_path)
        mut totals_content := format(header, NL)
        lines := existing.split(NL)
        // Keep existing data rows (skip the old header at line 0 and blanks),
        // dropping any row for the current commit so a re-run replaces it.
        mut li : USize = 1
        while li < lines.len() {
            ref ln : Str = lines[li]
            if ln.len() > 0 {
                row_commit := ln.substr(0, ln.find(",").to_usize())
                if row_commit != commit {
                    totals_content = format(totals_content, ln, NL)
                }
            }
            li++
        }
        totals_content = format(totals_content, totals_line, NL)
        File.writefile(totals_path, totals_content)

        run(format(PLOT, " doc/totals.csv img/totals.svg 10 --no-x-labels"))
        println("Updated doc/totals.csv and img/totals.svg")
    }

    exit(fail)
}
