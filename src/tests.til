mode cli
import("examples/plot.til")

NL := Str.from_byte(10)
CTIL := "bin/ctil"
TMPF := "tmp/_test_out"

count_matches := func(haystack: Str, needle: Str) returns I64 {
    if needle.is_empty() { return 0 }
    mut count := 0
    mut start : U64 = 0
    while start.lte(haystack.len().sub(needle.len())) {
        pos := haystack.substr(start, haystack.len().sub(start)).find(needle)
        if pos.eq(0.sub(1)) { return count }
        count = count.add(1)
        start = start.add(U64.from_i64(pos)).add(needle.len())
    }
    return count
}

// Run a shell command, return exit code
run := proc(cmd: Str) returns I64 {
    pid := spawn_cmd(cmd)
    return wait_cmd(pid)
}

// Run a shell command, capture output to TMPF, return exit code
run_capture := proc(cmd: Str) returns I64 {
    pid := spawn_cmd(cmd.concat(" > ").concat(TMPF).concat(" 2>&1"))
    return wait_cmd(pid)
}

// --- Helpers ---

ms_to_str := func(ms: I64) returns Str {
    secs := ms.div(1000)
    frac := ms.mod(1000).div(10)
    mut frac_str := frac.to_str()
    if frac.lt(10) { frac_str = "0".concat(frac_str) }
    return secs.to_str().concat(".").concat(frac_str).concat("s")
}

pad_right := func(s: Str, width: U64) returns Str {
    mut result := s.clone()
    while result.len().lt(width) {
        result = result.concat(" ")
    }
    return result
}

// --- Data structures ---

Job := struct {
    mut file := ""
    mut tmode := ""
    mut pid := 0
    mut outfile := ""
    mut result_idx : U64 = 0
    mut start_ms := 0
}

TestFile := struct {
    mut file := ""
    mut interp_ms := 0
    mut run_ms := 0
    mut interp_ok := 0
    mut run_ok := 0
    mut output_match := 1
    mut has_interp := 0
    mut has_run := 0
    mut interp_outfile := ""
    mut run_outfile := ""
}

// --- Parallel test runner ---

spawn_job := proc(job: Job) returns Job {
    cmd := CTIL.concat(" ").concat(job.tmode).concat(" '").concat(job.file).concat("' > ").concat(job.outfile).concat(" 2>/dev/null")
    start := clock_ms()
    pid := spawn_cmd(cmd)
    return Job(file = job.file.clone(), tmode = job.tmode.clone(), pid = pid,
               outfile = job.outfile.clone(), result_idx = job.result_idx, start_ms = start)
}

run_tests_parallel := proc(results: Vec, jobs: Vec, j: U64, mut fail: I64) {
    mut next : U64 = 0
    mut active : U64 = 0

    slots := Array.new("Job", Job.size(), j)
    mut si : U64 = 0
    while si.lt(j) {
        slots.set(si, own Job())
        si = si.add(1)
    }

    // Spawn initial batch
    si = U64.from_i64(0)
    while si.lt(j).and(next.lt(jobs.len())) {
        ref job : Job = jobs.get(next)
        slots.set(si, own spawn_job(job))
        active = active.add(1)
        next = next.add(1)
        si = si.add(1)
    }

    // Poll loop
    while active.gt(0) {
        mut i : U64 = 0
        while i.lt(j) {
            ref slot : Job = slots.get(i)
            if slot.pid.gt(0) {
                status := check_cmd_status(slot.pid)
                if status.neq(0.sub(1)) {
                    // Record timing
                    elapsed := clock_ms().sub(slot.start_ms)
                    ref result : TestFile = results.get(slot.result_idx)
                    if slot.tmode.eq("interpret") {
                        result.interp_ms = elapsed
                        if status.eq(0) { result.interp_ok = 1 }
                        result.interp_outfile = slot.outfile.clone()
                    } else {
                        result.run_ms = elapsed
                        if status.eq(0) { result.run_ok = 1 }
                        result.run_outfile = slot.outfile.clone()
                    }

                    if status.neq(0) {
                        mut label := "interpret"
                        if slot.tmode.eq("run") { label = "codegen" }
                        println("FAIL (", label, "): ", slot.file)
                        fail = 1
                    }
                    active = active.sub(1)

                    // Spawn next job in this slot
                    if next.lt(jobs.len()) {
                        ref nj : Job = jobs.get(next)
                        slots.set(i, own spawn_job(nj))
                        active = active.add(1)
                        next = next.add(1)
                    } else {
                        slots.set(i, own Job())
                    }
                }
            }
            i = i.add(1)
        }
        if active.gt(0) {
            sleep(10)
        }
    }
}

// --- CLI test helper ---

cli_test := proc(file: Str, cmd_args: Str, expected: Str, exit_expected: I64, mut fail: I64) {
    // interpret
    mut cmd := CTIL.concat(" interpret ").concat(file)
    if cmd_args.len().gt(0) {
        cmd = cmd.concat(" ").concat(cmd_args)
    }
    rc := run_capture(cmd)
    out := readfile(TMPF)
    if rc.neq(exit_expected) {
        println("FAIL (interpret): ", file, " (exit ", rc.to_str(), ", expected ", exit_expected.to_str(), ")")
        fail = 1
    } else {
        if exit_expected.eq(0).and(out.neq(expected)) {
            println("FAIL (interpret): ", file)
            println("  expected: ", expected)
            println("  got:      ", out)
            fail = 1
        }
    }

    // codegen
    mut cmd2 := CTIL.concat(" run ").concat(file)
    if cmd_args.len().gt(0) {
        cmd2 = cmd2.concat(" ").concat(cmd_args)
    }
    rc2 := run_capture(cmd2)
    out2 := readfile(TMPF)
    if rc2.neq(exit_expected) {
        println("FAIL (codegen):   ", file, " (exit ", rc2.to_str(), ", expected ", exit_expected.to_str(), ")")
        fail = 1
    } else {
        if exit_expected.eq(0).and(out2.neq(expected)) {
            println("FAIL (codegen):   ", file)
            println("  expected: ", expected)
            println("  got:      ", out2)
            fail = 1
        }
    }
}

// --- Main ---

main := proc(args: ..Str) {
    wall_start := clock_ms()

    // Parse -jN from args (default: CPU thread count)
    mut j := U64.from_i64(get_thread_count())
    mut i : U64 = 0
    while i.lt(args.len()) {
        ref arg : Str = args.get(i)
        if arg.starts_with("-j") {
            j = U64.from_i64(arg.substr(2, arg.len().sub(2)).to_i64())
            if j.lt(1) { j = U64.from_i64(1) }
        }
        i = i.add(1)
    }

    mut fail := 0

    // --- Test categories ---

    c_common := Vec.new("Str", Str.size())
    c_common.push(own "src/test/types.til")
    c_common.push(own "src/test/operators.til")
    c_common.push(own "src/test/functions.til")
    c_common.push(own "src/test/structs.til")
    c_common.push(own "src/test/optional_args.til")
    c_common.push(own "src/test/forward_refs.til")
    c_common.push(own "src/test/flow.til")
    c_common.push(own "src/test/strings.til")
    c_common.push(own "src/test/ref.til")
    c_common.push(own "src/test/own_fields.til")
    c_common.push(own "src/test/macros.til")
    c_common.push(own "src/test/enums.til")
    c_common.push(own "src/test/vecs.til")
    c_common.push(own "src/test/arrays.til")
    c_common.push(own "src/test/sets.til")
    c_common.push(own "src/test/maps.til")
    c_common.push(own "src/test/globals.til")
    c_common.push(own "src/test/globals_cli.til")
    c_common.push(own "src/test/misc.til")
    c_common.push(own "src/test/array_lit.til")
    c_common.push(own "src/test/cmp.til")
    c_common.push(own "src/test/ufcs.til")
    c_common.push(own "src/test/booleans.til")
    c_common.push(own "src/test/imports.til")
    c_common.push(own "src/test/import_diamond.til")
    c_common.push(own "src/test/pure.til")
    c_common.push(own "src/test/aliases.til")
    c_common.push(own "src/test/loops.til")
    c_common.push(own "src/test/splat.til")
    c_common.push(own "src/test/shallow.til")
    c_common.push(own "src/test/lexing.til")
    c_common.push(own "src/test/parsing.til")

    c_codegen := Vec.new("Str", Str.size())

    c_interpreted := Vec.new("Str", Str.size())

    // Build results Vec (one TestFile per file)
    results := Vec.new("TestFile", TestFile.size())
    mut ri : U64 = 0
    while ri.lt(c_common.len()) {
        ref f : Str = c_common.get(ri)
        results.push(own TestFile(file = f.clone(), has_interp = 1, has_run = 1))
        ri = ri.add(1)
    }
    ri = U64.from_i64(0)
    while ri.lt(c_codegen.len()) {
        ref f : Str = c_codegen.get(ri)
        results.push(own TestFile(file = f.clone(), has_run = 1))
        ri = ri.add(1)
    }
    ri = U64.from_i64(0)
    while ri.lt(c_interpreted.len()) {
        ref f : Str = c_interpreted.get(ri)
        results.push(own TestFile(file = f.clone(), has_interp = 1))
        ri = ri.add(1)
    }

    // Build jobs Vec
    jobs := Vec.new("Job", Job.size())
    mut ji : U64 = 0
    mut fi : U64 = 0
    while fi.lt(c_common.len()) {
        ref f : Str = c_common.get(fi)
        jobs.push(own Job(file = f.clone(), tmode = "interpret", outfile = "tmp/_test_".concat(ji.to_i64().to_str()), result_idx = fi))
        ji = ji.add(1)
        jobs.push(own Job(file = f.clone(), tmode = "run", outfile = "tmp/_test_".concat(ji.to_i64().to_str()), result_idx = fi))
        ji = ji.add(1)
        fi = fi.add(1)
    }
    mut cgi : U64 = 0
    while cgi.lt(c_codegen.len()) {
        ref f : Str = c_codegen.get(cgi)
        ridx := c_common.len().add(cgi)
        jobs.push(own Job(file = f.clone(), tmode = "run", outfile = "tmp/_test_".concat(ji.to_i64().to_str()), result_idx = ridx))
        ji = ji.add(1)
        cgi = cgi.add(1)
    }
    mut ii : U64 = 0
    while ii.lt(c_interpreted.len()) {
        ref f : Str = c_interpreted.get(ii)
        ridx := c_common.len().add(c_codegen.len()).add(ii)
        jobs.push(own Job(file = f.clone(), tmode = "interpret", outfile = "tmp/_test_".concat(ji.to_i64().to_str()), result_idx = ridx))
        ji = ji.add(1)
        ii = ii.add(1)
    }

    // Run parallel tests
    run_tests_parallel(results, jobs, j, fail)

    // --- Output comparison for c_common tests ---

    mut ci : U64 = 0
    while ci.lt(c_common.len()) {
        ref r : TestFile = results.get(ci)
        if r.interp_ok.eq(1).and(r.run_ok.eq(1)) {
            iout := readfile(r.interp_outfile)
            rout := readfile(r.run_outfile)
            if iout.neq(rout) {
                r.output_match = 0
                println("MISMATCH: ", r.file, " (interpret vs codegen output differs)")
                fail = 1
            }
        }
        ci = ci.add(1)
    }

    // --- Print per-file timing ---

    println("")
    num_files := results.len()
    mut total_interp := 0
    mut total_run := 0
    mut passed : U64 = 0
    mut ti : U64 = 0
    while ti.lt(num_files) {
        ref r : TestFile = results.get(ti)
        mut line := pad_right(r.file, 42)
        mut ok := 1
        if r.has_interp.eq(1) {
            line = line.concat("interp: ").concat(pad_right(ms_to_str(r.interp_ms), 9))
            total_interp = total_interp.add(r.interp_ms)
            if r.interp_ok.eq(0) { ok = 0 }
        }
        if r.has_run.eq(1) {
            line = line.concat("run: ").concat(pad_right(ms_to_str(r.run_ms), 9))
            total_run = total_run.add(r.run_ms)
            if r.run_ok.eq(0) { ok = 0 }
        }
        if r.output_match.eq(0) {
            line = line.concat(" MISMATCH")
            ok = 0
        }
        if ok.eq(1) { passed = passed.add(1) }
        println(line)
        ti = ti.add(1)
    }

    // --- Section 2: FFI test ---

    ffi_start := clock_ms()
    ffi_expected := "hello world".concat(NL).concat("hello universe").concat(NL)

    ec_ffi := run_capture(CTIL.concat(" interpret src/examples/ffi/ext_module.til"))
    ffi_out := readfile(TMPF)
    if ec_ffi.neq(0).or(ffi_out.neq(ffi_expected)) {
        println("FAIL (interpret): ffi/ext_module")
        fail = 1
    }

    ec_ffi2 := run_capture(CTIL.concat(" run src/examples/ffi/ext_module.til"))
    ffi_out2 := readfile(TMPF)
    if ec_ffi2.neq(0).or(ffi_out2.neq(ffi_expected)) {
        println("FAIL (codegen):   ffi/ext_module")
        fail = 1
    }
    ffi_ms := clock_ms().sub(ffi_start)

    // --- Section 3: Typer errors ---

    typer_start := clock_ms()
    run_capture(CTIL.concat(" interpret src/test/typer_errors.til"))
    typer_out := readfile(TMPF)
    errors := count_matches(typer_out, "type error:")
    if errors.neq(51) {
        println("FAIL: typer_errors expected 51 errors, got ", errors.to_str())
        fail = 1
    }
    typer_ms := clock_ms().sub(typer_start)

    // --- Section 4: CLI args tests ---

    cli_start := clock_ms()
    cli_test("src/examples/cli_args.til", "hello world",
        "hello".concat(NL).concat("world").concat(NL), 0, fail)
    cli_test("src/examples/cli_args.til", "",
        "", 0, fail)
    cli_test("src/examples/cli_typed.til", "alice 42",
        "alice 42".concat(NL), 0, fail)
    cli_test("src/examples/hello_cli.til", "",
        "Hello World!".concat(NL), 0, fail)
    cli_test("src/examples/cli_variadic_i64.til", "add 10 20 30",
        "60".concat(NL), 0, fail)
    cli_test("src/examples/cli_variadic_i64.til", "mul 2 3 4",
        "24".concat(NL), 0, fail)
    cli_test("src/examples/cli_variadic_i64.til", "add",
        "0".concat(NL), 0, fail)
    cli_test("src/examples/cli_variadic_bool.til", "true true false",
        "false".concat(NL), 0, fail)
    cli_test("src/examples/cli_variadic_bool.til", "true true",
        "true".concat(NL), 0, fail)
    // Error cases (nonzero exit)
    cli_test("src/examples/cli_typed.til", "alice", "", 1, fail)
    cli_test("src/examples/cli_typed.til", "a b c", "", 1, fail)
    cli_test("src/examples/hello_cli.til", "extra", "", 1, fail)
    cli_ms := clock_ms().sub(cli_start)

    // --- Section 5: Plot example test ---

    plot_start := clock_ms()
    // Write test CSV
    test_csv := format("commit,interp_ms,compiled_ms,ffi_ms,typer_ms,cli_ms,wall_ms,passed,total", NL,
                       "abc1234,1940,5520,200,1710,1970,4640,32,32", NL,
                       "def5678,1880,5400,190,1680,1950,4500,32,32", NL)
    writefile("tmp/_test_plot.csv", test_csv)
    plot_csv("tmp/_test_plot.csv", "tmp/_test_plot.svg", 0)
    plot_svg := readfile("tmp/_test_plot.svg")
    if count_matches(plot_svg, "<svg").eq(0) {
        println("FAIL: plot.til missing <svg tag")
        fail = 1
    }
    if count_matches(plot_svg, "<polyline").lt(3) {
        println("FAIL: plot.til expected 3 polylines, got ", count_matches(plot_svg, "<polyline").to_str())
        fail = 1
    }
    if count_matches(plot_svg, "abc1234").eq(0) {
        println("FAIL: plot.til missing commit label abc1234")
        fail = 1
    }
    if count_matches(plot_svg, "Interpreted").eq(0) {
        println("FAIL: plot.til missing legend label Interpreted")
        fail = 1
    }
    plot_ms := clock_ms().sub(plot_start)

    // --- Section 6: Build-only tests (GUI/raylib examples) ---

    build_start := clock_ms()
    gui_examples := array("Str",
        "src/examples/gui_hello.til",
        "src/examples/snake.til",
        "src/examples/piano.til",
        "src/examples/music.til",
        "src/examples/font_test.til",
        "src/examples/minesweeper.til",
        "src/examples/popcorn.til",
        "src/examples/chess.til",
        "src/examples/go.til",
        "src/examples/raylib.til"
    )
    for gf : Str in gui_examples {
        rc := run_capture(CTIL.concat(" translate ").concat(gf))
        if rc.neq(0) {
            println("FAIL (build):     ", gf)
            fail = 1
        }
    }
    build_ms := clock_ms().sub(build_start)

    // --- Summary ---

    wall_ms := clock_ms().sub(wall_start)
    println("")
    println("=== Summary ===")
    println("Interpreted:  ", ms_to_str(total_interp))
    println("Compiled:     ", ms_to_str(total_run))
    println("FFI tests:    ", ms_to_str(ffi_ms))
    println("Typer errors: ", ms_to_str(typer_ms))
    println("CLI tests:    ", ms_to_str(cli_ms))
    println("Plot test:    ", ms_to_str(plot_ms))
    println("Build tests:  ", ms_to_str(build_ms))
    println("Wall-clock:   ", ms_to_str(wall_ms))
    println("Passed:       ", passed.to_i64().to_str(), "/", num_files.to_i64().to_str())
    println("")

    if fail.eq(0) {
        println("all tests passed")
    }

    // --- Benchmark CSV logging ---

    // Get commit hash
    run("git rev-parse --short HEAD > tmp/_commit_hash")
    commit := readfile("tmp/_commit_hash").replace(NL, "")

    // Write gen/benchmark.csv (per-test detail, not tracked in git)
    run("mkdir -p gen")
    mut bench := Str.with_capacity(32768)
    bench.push_str("commit,file,interp_ms,run_ms,interp_ok,run_ok")
    bench.push_str(NL)
    mut bi : U64 = 0
    while bi.lt(results.len()) {
        ref br : TestFile = results.get(bi)
        bench.push_str(format(commit, ",", br.file, ",",
                              br.interp_ms.to_str(), ",", br.run_ms.to_str(), ",",
                              br.interp_ok.to_str(), ",", br.run_ok.to_str(), NL))
        bi = bi.add(1)
    }
    writefile("gen/benchmark.csv", bench)

    // Build totals CSV line
    totals_line := format(commit, ",",
                          total_interp.to_str(), ",", total_run.to_str(), ",",
                          ffi_ms.to_str(), ",", typer_ms.to_str(), ",",
                          cli_ms.to_str(), ",", wall_ms.to_str(), ",",
                          passed.to_i64().to_str(), ",", num_files.to_i64().to_str())

    // Update doc/totals.csv (tracked in git)
    totals_path := "doc/totals.csv"
    // Read existing totals or start fresh
    existing := readfile(totals_path)
    mut totals_content := ""
    // Check if last line has the same commit — if so, replace it
    lines := split(existing, NL)
    mut last_data_idx := lines.len().sub(1)
    // Skip trailing empty lines
    while last_data_idx.gt(0) {
        ref last_line : Str = lines.get(last_data_idx)
        if last_line.len().gt(0) { break }
        last_data_idx = last_data_idx.sub(1)
    }
    // Only try replace if we have data rows (not just header)
    if last_data_idx.gt(0) {
        ref last_data : Str = lines.get(last_data_idx)
        last_commit := last_data.substr(0, U64.from_i64(last_data.find(",")))
        if last_commit.eq(commit) {
            // Replace last line: rebuild without it
            mut li : U64 = 0
            while li.lt(last_data_idx) {
                ref ln : Str = lines.get(li)
                totals_content = totals_content.concat(ln).concat(NL)
                li = li.add(1)
            }
        } else {
            totals_content = existing
            if existing.substr(existing.len().sub(1), 1).neq(NL) {
                totals_content = totals_content.concat(NL)
            }
        }
    } else {
        totals_content = existing
        if existing.len().gt(0).and(existing.substr(existing.len().sub(1), 1).neq(NL)) {
            totals_content = totals_content.concat(NL)
        }
    }
    totals_content = totals_content.concat(totals_line).concat(NL)
    writefile(totals_path, totals_content)

    // Generate chart
    plot_csv("doc/totals.csv", "img/totals.svg", last_n=20, show_x_labels=false)
    println("Updated doc/totals.csv and img/totals.svg")

    exit(fail)
}
