mode script

NL := Str.from_byte(U8.from_i64(10))
CTIL := "bin/ctil"
TMPF := "tmp/_test_out"
mut fail := 0

count_matches := func(haystack: Str, needle: Str) returns I64 {
    if needle.is_empty() { return 0 }
    mut count := 0
    mut start := 0
    while start.lte(haystack.len().sub(needle.len())) {
        pos := haystack.substr(start, haystack.len().sub(start)).find(needle)
        if pos.eq(0.sub(1)) { return count }
        count = count.add(1)
        start = start.add(pos).add(needle.len())
    }
    return count
}

// Run a shell command, return exit code
run := proc(cmd: Str) returns I64 {
    pid := spawn_cmd(cmd)
    return wait_cmd(pid)
}

// Run a shell command, capture output to TMPF, return exit code
run_capture := proc(cmd: Str) returns I64 {
    pid := spawn_cmd(cmd.concat(" > ").concat(TMPF).concat(" 2>&1"))
    return wait_cmd(pid)
}

// --- Section 1: Normal tests (interpret + run, exit 0) ---

run_test := proc(file: Str) {
    ec := run(CTIL.concat(" interpret '").concat(file).concat("' > /dev/null 2>&1"))
    if ec.neq(0) {
        println("FAIL (interpret): ", file)
        fail = 1
    }
    ec2 := run(CTIL.concat(" run '").concat(file).concat("' > /dev/null 2>&1"))
    if ec2.neq(0) {
        println("FAIL (codegen):   ", file)
        fail = 1
    }
}

run_test("src/test/types.til")
run_test("src/test/operators.til")
run_test("src/test/functions.til")
run_test("src/test/structs.til")
run_test("src/test/optional_args.til")
run_test("src/test/forward_refs.til")
run_test("src/test/flow.til")
run_test("src/test/strings.til")
run_test("src/test/ref.til")
run_test("src/test/own_fields.til")
run_test("src/test/macros.til")
run_test("src/test/enums.til")
run_test("src/test/vecs.til")
run_test("src/test/arrays.til")
run_test("src/test/sets.til")
run_test("src/test/maps.til")
run_test("src/test/globals.til")
run_test("src/test/globals_cli.til")
run_test("src/test/misc.til")
run_test("src/test/array_lit.til")
run_test("src/test/cmp.til")
run_test("src/test/ufcs.til")
run_test("src/test/booleans.til")

// Interpret-only (codegen has simple-enum-in-struct bug)
ec_lex := run(CTIL.concat(" interpret src/test/lexing.til > /dev/null 2>&1"))
if ec_lex.neq(0) {
    println("FAIL (interpret): src/test/lexing.til")
    fail = 1
}

// --- Section 2: FFI test (interpret + codegen, check output) ---

ffi_expected := "hello world".concat(NL).concat("hello universe").concat(NL)

ec_ffi := run_capture(CTIL.concat(" interpret src/examples/ffi/ext_module.til"))
ffi_out := readfile(TMPF)
if ec_ffi.neq(0).or(ffi_out.neq(ffi_expected)) {
    println("FAIL (interpret): ffi/ext_module")
    fail = 1
}

ec_ffi2 := run_capture(CTIL.concat(" run src/examples/ffi/ext_module.til"))
ffi_out2 := readfile(TMPF)
if ec_ffi2.neq(0).or(ffi_out2.neq(ffi_expected)) {
    println("FAIL (codegen):   ffi/ext_module")
    fail = 1
}

// --- Section 3: Typer errors (count "type error:" occurrences) ---

run_capture(CTIL.concat(" interpret src/test/typer_errors.til"))
typer_out := readfile(TMPF)
errors := count_matches(typer_out, "type error:")
if errors.neq(40) {
    println("FAIL: typer_errors expected 40 errors, got ", errors.to_str())
    fail = 1
}

// --- Section 4: CLI args tests ---

cli_test := proc(file: Str, cmd_args: Str, expected: Str, exit_expected: I64) {
    // interpret mode
    mut cmd := CTIL.concat(" interpret ").concat(file)
    if cmd_args.len().gt(0) {
        cmd = cmd.concat(" ").concat(cmd_args)
    }
    rc := run_capture(cmd)
    out := readfile(TMPF)
    if rc.neq(exit_expected) {
        println("FAIL (interpret): ", file, " (exit ", rc.to_str(), ", expected ", exit_expected.to_str(), ")")
        fail = 1
    } else {
        if exit_expected.eq(0).and(out.neq(expected)) {
            println("FAIL (interpret): ", file)
            println("  expected: ", expected)
            println("  got:      ", out)
            fail = 1
        }
    }

    // codegen mode
    mut cmd2 := CTIL.concat(" run ").concat(file)
    if cmd_args.len().gt(0) {
        cmd2 = cmd2.concat(" ").concat(cmd_args)
    }
    rc2 := run_capture(cmd2)
    out2 := readfile(TMPF)
    if rc2.neq(exit_expected) {
        println("FAIL (codegen):   ", file, " (exit ", rc2.to_str(), ", expected ", exit_expected.to_str(), ")")
        fail = 1
    } else {
        if exit_expected.eq(0).and(out2.neq(expected)) {
            println("FAIL (codegen):   ", file)
            println("  expected: ", expected)
            println("  got:      ", out2)
            fail = 1
        }
    }
}

cli_test("src/examples/cli_args.til", "hello world",
    "hello".concat(NL).concat("world").concat(NL), 0)
cli_test("src/examples/cli_args.til", "",
    "", 0)
cli_test("src/examples/cli_typed.til", "alice 42",
    "alice 42".concat(NL), 0)
cli_test("src/examples/hello_cli.til", "",
    "Hello World!".concat(NL), 0)
cli_test("src/examples/cli_variadic_i64.til", "add 10 20 30",
    "60".concat(NL), 0)
cli_test("src/examples/cli_variadic_i64.til", "mul 2 3 4",
    "24".concat(NL), 0)
cli_test("src/examples/cli_variadic_i64.til", "add",
    "0".concat(NL), 0)
cli_test("src/examples/cli_variadic_bool.til", "true true false",
    "false".concat(NL), 0)
cli_test("src/examples/cli_variadic_bool.til", "true true",
    "true".concat(NL), 0)
// Error cases (nonzero exit)
cli_test("src/examples/cli_typed.til", "alice", "", 1)
cli_test("src/examples/cli_typed.til", "a b c", "", 1)
cli_test("src/examples/hello_cli.til", "extra", "", 1)

if fail.eq(0) {
    println("all tests passed")
}
exit(fail)
