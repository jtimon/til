mode cli

NL := Str.from_byte(10)
CTIL := "bin/ctil"
TIL := "bin/c/til"
RUNNER := "bin/c/test_runner"
PLOT := "bin/c/plot"
GUI_TIMEOUT := "1"

count_matches := func(haystack: Str, needle: Str) returns I64 {
    if needle.is_empty() { return 0 }
    mut count := 0
    mut start : U64 = 0
    while start.lte(haystack.len().sub(needle.len())) {
        pos := haystack.substr(start, haystack.len().sub(start)).find(needle)
        if pos.eq(0.sub(1)) { return count }
        count = count.add(1)
        start = start.add(pos.to_u64()).add(needle.len())
    }
    return count
}

// Run a shell command, return exit code
run := proc(cmd: Str) returns I64 {
    pid := spawn_cmd(cmd)
    return wait_cmd(pid)
}

// --- Helpers ---

ms_to_str := func(ms: I64) returns Str {
    secs := ms.div(1000)
    frac := ms.mod(1000).div(10)
    mut frac_str := frac.to_str()
    if frac.lt(10) { frac_str = "0".concat(frac_str) }
    return secs.to_str().concat(".").concat(frac_str).concat("s")
}

pad_right := func(s: Str, width: U64) returns Str {
    mut result := s.clone()
    while result.len().lt(width) {
        result = result.concat(" ")
    }
    return result
}

test_basename := func(path: Str) returns Str {
    mut last_slash : U64 = 0
    mut has_slash := 0
    for si in 0..path.len() {
        if path.get(si).eq('/') {
            last_slash = si
            has_slash = 1
        }
    }
    mut name := path
    if has_slash.eq(1) {
        name = path.substr(last_slash.add(1), path.len().sub(last_slash).sub(1))
    }
    if name.ends_with(".til") {
        name = name.substr(0, name.len().sub(4))
    }
    return name
}

parse_kv := func(line: Str, key: Str) returns I64 {
    needle := key.concat("=")
    pos := line.find(needle)
    if pos.lt(0) { return 0 }
    start := pos.to_u64().add(needle.len())
    mut end := start
    while end.lt(line.len()).and(line.get(end).neq(' ')).and(line.get(end).neq(10)) {
        end = end.add(1)
    }
    return line.substr(start, end.sub(start)).to_i64()
}

mode_flags := func(en_ci: I64, en_cr: I64, en_ti: I64, en_tr: I64) returns Str {
    mut f := ""
    if en_ci.eq(0) { f = f.concat(" -no-ci") }
    if en_cr.eq(0) { f = f.concat(" -no-cr") }
    if en_ti.eq(0) { f = f.concat(" -no-ti") }
    if en_tr.eq(0) { f = f.concat(" -no-tr") }
    return f
}

// --- Data structures ---

ModeData := struct {
    mut ci_ms := 0
    mut ci_ok := 0
    mut cr_ms := 0
    mut cr_ok := 0
    mut ti_ms := 0
    mut ti_ok := 0
    mut tr_ms := 0
    mut tr_ok := 0
    mut output_match := 1
    namespace:
    eq := func(a: ModeData, b: ModeData) returns Bool {
        return a.ci_ms.eq(b.ci_ms).and(a.ci_ok.eq(b.ci_ok))
            .and(a.cr_ms.eq(b.cr_ms)).and(a.cr_ok.eq(b.cr_ok))
            .and(a.ti_ms.eq(b.ti_ms)).and(a.ti_ok.eq(b.ti_ok))
            .and(a.tr_ms.eq(b.tr_ms)).and(a.tr_ok.eq(b.tr_ok))
            .and(a.output_match.eq(b.output_match))
    }
    to_str := func(self: ModeData) returns Str { return "ModeData" }
}

TestKind := enum { Mode: ModeData, Single, Count }

Test := struct {
    mut label := ""
    mut cmd := ""
    mut outfile := ""
    mut category := ""
    mut kind := TestKind.Single
    // scheduling
    mut pid := 0
    mut start_ms := 0
    // common results
    mut ok := 0
    mut ms := 0
    // mode config flags
    mut has_ci := 0
    mut has_cr := 0
    mut has_ti := 0
    mut has_tr := 0
}

Slot := struct {
    mut test_idx : U64 = 0
    mut pid := 0
    mut start_ms := 0
}

// --- Output helpers ---

print_test_result := proc(t: Test) {
    if t.kind.is_Mode() {
        md := t.kind.get_Mode()
        mut line := pad_right(t.label, 42)
        if t.has_ci.eq(1) { line = line.concat("ci: ").concat(pad_right(ms_to_str(md.ci_ms), 9)) }
        if t.has_cr.eq(1) { line = line.concat("cr: ").concat(pad_right(ms_to_str(md.cr_ms), 9)) }
        if t.has_ti.eq(1) { line = line.concat("ti: ").concat(pad_right(ms_to_str(md.ti_ms), 9)) }
        if t.has_tr.eq(1) { line = line.concat("tr: ").concat(pad_right(ms_to_str(md.tr_ms), 9)) }
        if md.output_match.eq(0) { line = line.concat(" MISMATCH") }
        println(line)
    } else {
        if t.ok.eq(1) {
            println(pad_right(t.label, 42), ms_to_str(t.ms))
        }
    }
}

// --- Registration helpers ---

add_mode := proc(tests: Vec, file: Str, flags: Str,
                 en_ci: I64, en_cr: I64, en_ti: I64, en_tr: I64) {
    bn := test_basename(file)
    tests.push(own Test(
        label = file.clone(),
        cmd = RUNNER.concat(" mode '").concat(file).concat("'").concat(flags),
        outfile = "gen/out/results/".concat(bn).concat(".txt"),
        category = "mode",
        kind = TestKind.Mode(ModeData()),
        has_ci = en_ci, has_cr = en_cr, has_ti = en_ti, has_tr = en_tr
    ))
}

add_single := proc(tests: Vec, label: Str, category: Str,
                   expected_exit: I64, expected_out: Str, cmd_suffix: Str) {
    mut runner_cmd := RUNNER.concat(" single ").concat(label).concat(" ").concat(expected_exit.to_str())
    if expected_out.len().gt(0) {
        runner_cmd = runner_cmd.concat(" ").concat(expected_out)
    }
    runner_cmd = runner_cmd.concat(" -- ").concat(cmd_suffix)
    tests.push(own Test(
        label = label.clone(),
        cmd = runner_cmd,
        outfile = "gen/out/results/".concat(label).concat(".txt"),
        category = category.clone(),
        kind = TestKind.Single
    ))
}

add_count := proc(tests: Vec, label: Str, category: Str,
                  needle: Str, expected_count: I64, cmd_suffix: Str) {
    runner_cmd := RUNNER.concat(" count ").concat(label).concat(" '").concat(needle).concat("' ").concat(expected_count.to_str()).concat(" -- ").concat(cmd_suffix)
    tests.push(own Test(
        label = label.clone(),
        cmd = runner_cmd,
        outfile = "gen/out/results/".concat(label).concat(".txt"),
        category = category.clone(),
        kind = TestKind.Count
    ))
}

add_cli_pair := proc(tests: Vec, name: Str, file: Str,
                     cli_args: Str, expected_exit: I64, expected_out: Str) {
    mut cmd_i := CTIL.concat(" interpret ").concat(file)
    if cli_args.len().gt(0) { cmd_i = cmd_i.concat(" ").concat(cli_args) }
    add_single(tests, name.concat("_i"), "cli", expected_exit, expected_out, cmd_i)
    mut cmd_r := CTIL.concat(" run -o bin/c/").concat(name)
        .concat(" -c gen/c/").concat(name).concat(".c ")
        .concat(file)
    if cli_args.len().gt(0) { cmd_r = cmd_r.concat(" ").concat(cli_args) }
    add_single(tests, name.concat("_r"), "cli", expected_exit, expected_out, cmd_r)
}

// --- Blind parallel runner ---

run_all_parallel := proc(tests: Vec, j: U64, mut fail: I64) {
    mut next : U64 = 0
    mut active : U64 = 0

    slots := Array.new("Slot", Slot.size(), j)
    mut si : U64 = 0
    while si.lt(j) {
        slots.set(si, own Slot())
        si = si.add(1)
    }

    // Spawn initial batch
    si = 0
    while si.lt(j).and(next.lt(tests.len())) {
        ref t : Test = tests.get(next)
        cmd := t.cmd.concat(" > ").concat(t.outfile).concat(" 2>&1")
        start := clock_ms()
        pid := spawn_cmd(cmd)
        slots.set(si, own Slot(test_idx = next, pid = pid, start_ms = start))
        active = active.add(1)
        next = next.add(1)
        si = si.add(1)
    }

    // Poll loop
    while active.gt(0) {
        mut i : U64 = 0
        while i.lt(j) {
            ref slot : Slot = slots.get(i)
            if slot.pid.gt(0) {
                status := check_cmd_status(slot.pid)
                if status.neq(0.sub(1)) {
                    ref t : Test = tests.get(slot.test_idx)
                    runner_out := readfile(t.outfile)

                    // Find RESULT line
                    mut result_line := ""
                    result_pos := runner_out.rfind("RESULT ")
                    if result_pos.gte(0) {
                        result_line = runner_out.substr(result_pos.to_u64(),
                            runner_out.len().sub(result_pos.to_u64()))
                    }

                    // Parse common fields
                    t.ok = parse_kv(result_line, "ok")
                    t.ms = parse_kv(result_line, "ms")
                    // Parse mode-specific fields into payload
                    if t.kind.is_Mode() {
                        md := t.kind.get_Mode()
                        md.ci_ms = parse_kv(result_line, "ci_ms")
                        md.ci_ok = parse_kv(result_line, "ci_ok")
                        md.cr_ms = parse_kv(result_line, "cr_ms")
                        md.cr_ok = parse_kv(result_line, "cr_ok")
                        md.ti_ms = parse_kv(result_line, "ti_ms")
                        md.ti_ok = parse_kv(result_line, "ti_ok")
                        md.tr_ms = parse_kv(result_line, "tr_ms")
                        md.tr_ok = parse_kv(result_line, "tr_ok")
                        md.output_match = parse_kv(result_line, "match")
                        t.kind = TestKind.Mode(md)
                    }

                    print_test_result(t)

                    if status.neq(0) {
                        runner_lines := split(runner_out, NL)
                        mut li : U64 = 0
                        while li.lt(runner_lines.len()) {
                            ref ln : Str = runner_lines.get(li)
                            if ln.starts_with("FAIL").or(ln.starts_with("MISMATCH")) {
                                println(ln)
                            }
                            li = li.add(1)
                        }
                        fail = 1
                    }

                    active = active.sub(1)
                    slot.pid = 0

                    if next.lt(tests.len()) {
                        ref nt : Test = tests.get(next)
                        cmd := nt.cmd.concat(" > ").concat(nt.outfile).concat(" 2>&1")
                        start := clock_ms()
                        pid := spawn_cmd(cmd)
                        slots.set(i, own Slot(test_idx = next, pid = pid, start_ms = start))
                        active = active.add(1)
                        next = next.add(1)
                    }
                }
            }
            i = i.add(1)
        }
        if active.gt(0) {
            sleep(10)
        }
    }
}

// --- Main ---

main := proc(args: ..Str) {
    wall_start := clock_ms()

    // Parse args: -jN, -no-ci, -no-cr, -no-ti, -no-tr
    mut j := get_thread_count().to_u64()
    mut en_ci := 1
    mut en_cr := 1
    mut en_ti := 1
    mut en_tr := 1
    mut i : U64 = 0
    while i.lt(args.len()) {
        ref arg : Str = args.get(i)
        if arg.starts_with("-j") {
            j = arg.substr(2, arg.len().sub(2)).to_i64().to_u64()
            if j.lt(1) { j = 1 }
        }
        if arg.eq("-no-ci") { en_ci = 0 }
        if arg.eq("-no-cr") { en_cr = 0 }
        if arg.eq("-no-ti") { en_ti = 0 }
        if arg.eq("-no-tr") { en_tr = 0 }
        i = i.add(1)
    }

    mut fail := 0

    // Create output directories
    run("mkdir -p gen/out/ci gen/out/cr gen/out/ti gen/out/tr gen/out/results gen/out/single gen/out/expected")

    tests := Vec.new("Test", Test.size())
    flags := mode_flags(en_ci, en_cr, en_ti, en_tr)

    // === 35 mode tests ===
    add_mode(tests, "src/test/types.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/operators.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/functions.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/structs.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/optional_args.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/forward_refs.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/flow.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/strings.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/ref.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/own_fields.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/macros.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/enums.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/vecs.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/tuples.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/arrays.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/sets.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/maps.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/globals.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/globals_cli.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/misc.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/array_lit.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/cmp.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/ufcs.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/booleans.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/imports.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/import_diamond.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/pure.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/aliases.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/loops.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/splat.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/shallow.til", flags, en_ci, en_cr, en_ti, en_tr)
    // TODO: lexing.til and parsing.til fail ci/ti modes after Token line/col I64→U32
    // (interpreter doesn't handle U32 struct fields correctly)
    // add_mode(tests, "src/test/lexing.til", flags, en_ci, en_cr, en_ti, en_tr)
    // add_mode(tests, "src/test/parsing.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/fn_ptr.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/asting.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/trailing.til", flags, en_ci, en_cr, en_ti, en_tr)
    add_mode(tests, "src/test/kwargs.til", flags, en_ci, en_cr, en_ti, en_tr)

    // === 2 FFI tests ===
    ffi_exp := "gen/out/expected/ffi.out"
    writefile(ffi_exp, "hello world".concat(NL).concat("hello universe").concat(NL))
    add_single(tests, "ffi_interp", "ffi", 0, ffi_exp,
               CTIL.concat(" interpret src/examples/ffi/ext_module.til"))
    add_single(tests, "ffi_run", "ffi", 0, ffi_exp,
               CTIL.concat(" run src/examples/ffi/ext_module.til"))

    // === 1 typer errors test ===
    add_count(tests, "typer_errors", "typer", "type error:", 52,
              CTIL.concat(" interpret src/test/typer_errors.til"))

    // === 24 CLI tests (12 cases × interpret + run) ===
    exp := "gen/out/expected/"

    writefile(exp.concat("cli_args_hello.out"), "hello".concat(NL).concat("world").concat(NL))
    add_cli_pair(tests, "cli_args_hello", "src/examples/cli_args.til",
                 "hello world", 0, exp.concat("cli_args_hello.out"))

    writefile(exp.concat("cli_args_empty.out"), "")
    add_cli_pair(tests, "cli_args_empty", "src/examples/cli_args.til",
                 "", 0, exp.concat("cli_args_empty.out"))

    writefile(exp.concat("cli_typed_alice42.out"), "alice 42".concat(NL))
    add_cli_pair(tests, "cli_typed_alice42", "src/examples/cli_typed.til",
                 "alice 42", 0, exp.concat("cli_typed_alice42.out"))

    writefile(exp.concat("hello_cli.out"), "Hello World!".concat(NL))
    add_cli_pair(tests, "hello_cli", "src/examples/hello_cli.til",
                 "", 0, exp.concat("hello_cli.out"))

    writefile(exp.concat("variadic_add.out"), "60".concat(NL))
    add_cli_pair(tests, "variadic_add", "src/examples/cli_variadic_i64.til",
                 "add 10 20 30", 0, exp.concat("variadic_add.out"))

    writefile(exp.concat("variadic_mul.out"), "24".concat(NL))
    add_cli_pair(tests, "variadic_mul", "src/examples/cli_variadic_i64.til",
                 "mul 2 3 4", 0, exp.concat("variadic_mul.out"))

    writefile(exp.concat("variadic_add0.out"), "0".concat(NL))
    add_cli_pair(tests, "variadic_add0", "src/examples/cli_variadic_i64.til",
                 "add", 0, exp.concat("variadic_add0.out"))

    writefile(exp.concat("variadic_bool_f.out"), "false".concat(NL))
    add_cli_pair(tests, "variadic_bool_f", "src/examples/cli_variadic_bool.til",
                 "true true false", 0, exp.concat("variadic_bool_f.out"))

    writefile(exp.concat("variadic_bool_t.out"), "true".concat(NL))
    add_cli_pair(tests, "variadic_bool_t", "src/examples/cli_variadic_bool.til",
                 "true true", 0, exp.concat("variadic_bool_t.out"))

    // Error cases (exit=1, no output check)
    add_cli_pair(tests, "cli_typed_err1", "src/examples/cli_typed.til", "alice", 1, "")
    add_cli_pair(tests, "cli_typed_err2", "src/examples/cli_typed.til", "a b c", 1, "")
    add_cli_pair(tests, "hello_cli_err", "src/examples/hello_cli.til", "extra", 1, "")

    // === 20 build tests (build + run with timeout) ===
    gui_files := array("Str",
        "src/examples/gui_hello.til", "src/examples/snake.til",
        "src/examples/piano.til", "src/examples/music.til",
        "src/examples/font_test.til", "src/examples/minesweeper.til",
        "src/examples/popcorn.til", "src/examples/chess.til",
        "src/examples/go.til", "src/examples/editor.til",
        "src/examples/game_of_life.til")
    for gf : Str in gui_files {
        bn := test_basename(gf)
        mut run_args := ""
        if bn.eq("popcorn") { run_args = " --mute" }
        add_single(tests, "build_c_".concat(bn), "build", 124, "",
                   CTIL.concat(" build ").concat(gf)
                       .concat(" '&&' timeout ").concat(GUI_TIMEOUT)
                       .concat(" bin/c/").concat(bn).concat(run_args))
        if en_tr.eq(1) {
            add_single(tests, "build_t_".concat(bn), "build", 124, "",
                       TIL.concat(" build ").concat(gf)
                           .concat(" '&&' timeout ").concat(GUI_TIMEOUT)
                           .concat(" bin/til/").concat(bn).concat(run_args))
        }
    }

    // === Run all tests in parallel ===
    run_all_parallel(tests, j, fail)

    // --- Accumulate totals ---

    println("")
    mut total_ci_ms := 0
    mut total_cr_ms := 0
    mut total_ti_ms := 0
    mut total_tr_ms := 0
    mut mode_passed : U64 = 0
    mut mode_total : U64 = 0
    mut pi : U64 = 0
    while pi.lt(tests.len()) {
        ref t : Test = tests.get(pi)
        if t.kind.is_Mode() {
            mode_total = mode_total.add(1)
            md := t.kind.get_Mode()
            if t.has_ci.eq(1) { total_ci_ms = total_ci_ms.add(md.ci_ms) }
            if t.has_cr.eq(1) { total_cr_ms = total_cr_ms.add(md.cr_ms) }
            if t.has_ti.eq(1) { total_ti_ms = total_ti_ms.add(md.ti_ms) }
            if t.has_tr.eq(1) { total_tr_ms = total_tr_ms.add(md.tr_ms) }
            if t.ok.eq(1) { mode_passed = mode_passed.add(1) }
        }
        pi = pi.add(1)
    }

    // --- Section totals from non-mode tests ---

    mut ffi_ms := 0
    mut typer_ms := 0
    mut cli_ms := 0
    mut build_ms := 0
    mut other_passed : U64 = 0
    mut other_total : U64 = 0
    pi = 0
    while pi.lt(tests.len()) {
        ref t : Test = tests.get(pi)
        if t.kind.is_Mode().not() {
            other_total = other_total.add(1)
            if t.ok.eq(1) { other_passed = other_passed.add(1) }
            if t.category.eq("ffi") { ffi_ms = ffi_ms.add(t.ms) }
            if t.category.eq("typer") { typer_ms = typer_ms.add(t.ms) }
            if t.category.eq("cli") { cli_ms = cli_ms.add(t.ms) }
            if t.category.eq("build") { build_ms = build_ms.add(t.ms) }
        }
        pi = pi.add(1)
    }

    // --- Plot test (stays sequential) ---

    plot_start := clock_ms()
    test_csv := format("commit,ci_ms,cr_ms,ti_ms,tr_ms,ffi_ms,typer_ms,cli_ms,wall_ms,passed,total", NL,
                       "abc1234,1940,5520,1950,5530,200,1710,1970,4640,32,32", NL,
                       "def5678,1880,5400,1890,5410,190,1680,1950,4500,32,32", NL)
    writefile("tmp/_test_plot.csv", test_csv)
    run(PLOT.concat(" tmp/_test_plot.csv tmp/_test_plot.svg 0"))
    plot_svg := readfile("tmp/_test_plot.svg")
    mut plot_ok := 1
    if count_matches(plot_svg, "<svg").eq(0) {
        println("FAIL: plot.til missing <svg tag")
        plot_ok = 0
        fail = 1
    }
    if count_matches(plot_svg, "<polyline").lt(5) {
        println("FAIL: plot.til expected 5 polylines, got ", count_matches(plot_svg, "<polyline").to_str())
        plot_ok = 0
        fail = 1
    }
    if count_matches(plot_svg, "abc1234").eq(0) {
        println("FAIL: plot.til missing commit label abc1234")
        plot_ok = 0
        fail = 1
    }
    if count_matches(plot_svg, "ctil-i").eq(0) {
        println("FAIL: plot.til missing legend label ctil-i")
        plot_ok = 0
        fail = 1
    }
    plot_ms := clock_ms().sub(plot_start)

    // --- Summary ---

    // --- Codegen diff check (ctil vs til) ---

    mut diff_ok := 1
    c_til := readfile("gen/c/til.c")
    t_til := readfile("gen/til/til.c")
    if c_til.neq(t_til) {
        println("FAIL: gen/c/til.c differs from gen/til/til.c")
        diff_ok = 0
        fail = 1
    }

    total_passed := mode_passed.add(other_passed).add(plot_ok.to_u64()).add(diff_ok.to_u64())
    total_tests := mode_total.add(other_total).add(2)

    wall_ms := clock_ms().sub(wall_start)
    println("")
    println("=== Summary ===")
    if en_ci.eq(1) { println("ctil interp:  ", ms_to_str(total_ci_ms)) }
    if en_cr.eq(1) { println("ctil run:     ", ms_to_str(total_cr_ms)) }
    if en_ti.eq(1) { println("til interp:   ", ms_to_str(total_ti_ms)) }
    if en_tr.eq(1) { println("til run:      ", ms_to_str(total_tr_ms)) }
    println("FFI tests:    ", ms_to_str(ffi_ms))
    println("Typer errors: ", ms_to_str(typer_ms))
    println("CLI tests:    ", ms_to_str(cli_ms))
    println("Plot test:    ", ms_to_str(plot_ms))
    println("Build tests:  ", ms_to_str(build_ms))
    if diff_ok.eq(1) {
        println("Codegen diff: identical")
    } else {
        println("Codegen diff: DIFFERENT")
    }
    println("Wall-clock:   ", ms_to_str(wall_ms))
    println("Passed:       ", total_passed.to_i64().to_str(), "/", total_tests.to_i64().to_str())
    println("")

    if fail.eq(0) {
        println("all tests passed")
    }

    // --- Benchmark CSV logging ---

    run("git rev-parse --short HEAD > tmp/_commit_hash")
    commit := readfile("tmp/_commit_hash").replace(NL, "")

    // gen/benchmark.csv — mode tests only (not tracked)
    run("mkdir -p gen")
    mut bench := Str.with_capacity(32768)
    bench.push_str("commit,file,ci_ms,cr_ms,ti_ms,tr_ms,ci_ok,cr_ok,ti_ok,tr_ok")
    bench.push_str(NL)
    mut bi : U64 = 0
    while bi.lt(tests.len()) {
        ref bt : Test = tests.get(bi)
        if bt.kind.is_Mode() {
            bmd := bt.kind.get_Mode()
            bench.push_str(format(commit, ",", bt.label, ",",
                                  bmd.ci_ms.to_str(), ",", bmd.cr_ms.to_str(), ",",
                                  bmd.ti_ms.to_str(), ",", bmd.tr_ms.to_str(), ",",
                                  bmd.ci_ok.to_str(), ",", bmd.cr_ok.to_str(), ",",
                                  bmd.ti_ok.to_str(), ",", bmd.tr_ok.to_str(), NL))
        }
        bi = bi.add(1)
    }
    writefile("gen/benchmark.csv", bench)

    // doc/totals.csv — all test totals (skip on failure)
    if fail.eq(0) {
        totals_line := format(commit, ",",
                              total_ci_ms.to_str(), ",", total_cr_ms.to_str(), ",",
                              total_ti_ms.to_str(), ",", total_tr_ms.to_str(), ",",
                              ffi_ms.to_str(), ",", typer_ms.to_str(), ",",
                              cli_ms.to_str(), ",", wall_ms.to_str(), ",",
                              total_passed.to_i64().to_str(), ",", total_tests.to_i64().to_str())

        totals_path := "doc/totals.csv"
        existing := readfile(totals_path)
        mut totals_content := ""
        lines := split(existing, NL)
        mut last_data_idx := lines.len().sub(1)
        while last_data_idx.gt(0) {
            ref last_line : Str = lines.get(last_data_idx)
            if last_line.len().gt(0) { break }
            last_data_idx = last_data_idx.sub(1)
        }
        if last_data_idx.gt(0) {
            ref last_data : Str = lines.get(last_data_idx)
            last_commit := last_data.substr(0, last_data.find(",").to_u64())
            if last_commit.eq(commit) {
                mut li : U64 = 0
                while li.lt(last_data_idx) {
                    ref ln : Str = lines.get(li)
                    totals_content = totals_content.concat(ln).concat(NL)
                    li = li.add(1)
                }
            } else {
                totals_content = existing
                if existing.substr(existing.len().sub(1), 1).neq(NL) {
                    totals_content = totals_content.concat(NL)
                }
            }
        } else {
            totals_content = existing
            if existing.len().gt(0).and(existing.substr(existing.len().sub(1), 1).neq(NL)) {
                totals_content = totals_content.concat(NL)
            }
        }
        totals_content = totals_content.concat(totals_line).concat(NL)
        writefile(totals_path, totals_content)

        run(PLOT.concat(" doc/totals.csv img/totals.svg 10 --no-x-labels"))
        println("Updated doc/totals.csv and img/totals.svg")
    }

    exit(fail)
}
