    add := core_func(shallow a: U64, shallow b: U64) returns shallow U64 {}
    sub := core_func(shallow a: U64, shallow b: U64) returns shallow U64 {}
    mul := core_func(shallow a: U64, shallow b: U64) returns shallow U64 {}
    div := core_func(shallow a: U64, shallow b: U64) returns shallow U64 {}
    mod := core_func(shallow a: U64, shallow b: U64) returns shallow U64 {}
    inc := core_func(mut self: U64) {}
    dec := core_func(mut self: U64) {}
    /// Return the multiplicative identity (1) for this type.
