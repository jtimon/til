mode lib

import("array.til")
import("map.til")
import("set.til")
import("str.til")
import("vec.til")

// builtin types (empty structs for future namespace support)
StructDef : StructDef = struct {}
FunctionDef : StructDef = struct {}
Dynamic : StructDef = struct {}

U8 := ext_struct {
namespace:
    to_i64 := ext_func(shallow val: U8) returns I64 {}
    to_str := func(val: U8) returns Str {
        return val.to_i64().to_str()
    }
    from_i64 := func(val: I64) returns U8 {
        if val.lt(0).or(val.gt(255)) {
            panic("U8.from_i64", "value out of range (0-255)")
        }
        U8_from_i64_ext := ext_func(val: I64) returns U8 {}
        return U8_from_i64_ext(val)
    }
    add := ext_func(shallow a: U8, shallow b: U8) returns U8 {}
    sub := ext_func(shallow a: U8, shallow b: U8) returns U8 {}
    mul := ext_func(shallow a: U8, shallow b: U8) returns U8 {}
    div := ext_func(shallow a: U8, shallow b: U8) returns U8 {}
    mod := ext_func(shallow a: U8, shallow b: U8) returns U8 {}
    inc := ext_func(shallow a: U8) returns U8 {}
    dec := ext_func(shallow a: U8) returns U8 {}
    eq := ext_func(shallow a: U8, shallow b: U8) returns Bool {}
    cmp := ext_func(shallow a: U8, shallow b: U8) returns I64 {}
    and := ext_func(shallow a: U8, shallow b: U8) returns U8 {}
    or := ext_func(shallow a: U8, shallow b: U8) returns U8 {}
    xor := ext_func(shallow a: U8, shallow b: U8) returns U8 {}
    clone := ext_func(val: U8) returns U8 {}
    delete := ext_proc(own self: U8, call_free: Bool = true) {}
    size := func() returns I64 { return 1 }
}

I16 := ext_struct {
namespace:
    to_i64 := ext_func(shallow val: I16) returns I64 {}
    to_str := func(val: I16) returns Str {
        return val.to_i64().to_str()
    }
    from_i64 := func(val: I64) returns I16 {
        if val.lt(32768.neg()).or(val.gt(32767)) {
            panic("I16.from_i64", "value out of range (-32768 to 32767)")
        }
        I16_from_i64_ext := ext_func(val: I64) returns I16 {}
        return I16_from_i64_ext(val)
    }
    add := ext_func(shallow a: I16, shallow b: I16) returns I16 {}
    sub := ext_func(shallow a: I16, shallow b: I16) returns I16 {}
    mul := ext_func(shallow a: I16, shallow b: I16) returns I16 {}
    div := ext_func(shallow a: I16, shallow b: I16) returns I16 {}
    mod := ext_func(shallow a: I16, shallow b: I16) returns I16 {}
    inc := ext_func(shallow a: I16) returns I16 {}
    dec := ext_func(shallow a: I16) returns I16 {}
    eq := ext_func(shallow a: I16, shallow b: I16) returns Bool {}
    cmp := ext_func(shallow a: I16, shallow b: I16) returns I64 {}
    neg := func(a: I16) returns I16 { return I16.from_i64(0.sub(a.to_i64())) }
    and := ext_func(shallow a: I16, shallow b: I16) returns I16 {}
    or := ext_func(shallow a: I16, shallow b: I16) returns I16 {}
    xor := ext_func(shallow a: I16, shallow b: I16) returns I16 {}
    clone := ext_func(val: I16) returns I16 {}
    delete := ext_proc(own self: I16, call_free: Bool = true) {}
    size := func() returns I64 { return 2 }
}

