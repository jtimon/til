mode lib

import("array.til")
import("map.til")
import("set.til")
import("str.til")
import("vec.til")
import("tuple.til")
import("ast.til")

// builtin types (empty structs for future namespace support)
StructDef : StructDef = struct {}
EnumDef : StructDef = struct {}
Dynamic : StructDef = struct {}

U8 := ext_struct {
namespace:
    to_i64 := ext_func(shallow val: U8) returns shallow I64 {}
    to_str := func(val: U8) returns Str {
        return val.to_i64().to_str()
    }
    add := ext_func(shallow a: U8, shallow b: U8) returns shallow U8 {}
    sub := ext_func(shallow a: U8, shallow b: U8) returns shallow U8 {}
    mul := ext_func(shallow a: U8, shallow b: U8) returns shallow U8 {}
    div := ext_func(shallow a: U8, shallow b: U8) returns shallow U8 {}
    mod := ext_func(shallow a: U8, shallow b: U8) returns shallow U8 {}
    inc := func(mut self: U8) { self = self.add(1) }
    dec := func(mut self: U8) { self = self.sub(1) }
    unity := func(self: U8) returns U8 { return 1.to_u8() }
    eq := ext_func(shallow a: U8, shallow b: U8) returns shallow Bool {}
    cmp := ext_func(shallow a: U8, shallow b: U8) returns shallow I64 {}
    and := ext_func(shallow a: U8, shallow b: U8) returns shallow U8 {}
    or := ext_func(shallow a: U8, shallow b: U8) returns shallow U8 {}
    xor := ext_func(shallow a: U8, shallow b: U8) returns shallow U8 {}
    clone := ext_func(val: U8) returns shallow U8 {}
    delete := ext_proc(own self: U8, call_free: Bool = true) {}
    size := func() returns U64 { return 1 }
}

I16 := ext_struct {
namespace:
    to_i64 := ext_func(shallow val: I16) returns shallow I64 {}
    to_str := func(val: I16) returns Str {
        return val.to_i64().to_str()
    }
    add := ext_func(shallow a: I16, shallow b: I16) returns shallow I16 {}
    sub := ext_func(shallow a: I16, shallow b: I16) returns shallow I16 {}
    mul := ext_func(shallow a: I16, shallow b: I16) returns shallow I16 {}
    div := ext_func(shallow a: I16, shallow b: I16) returns shallow I16 {}
    mod := ext_func(shallow a: I16, shallow b: I16) returns shallow I16 {}
    inc := func(mut self: I16) { self = self.add(1) }
    dec := func(mut self: I16) { self = self.sub(1) }
    unity := func(self: I16) returns I16 { return 1.to_i16() }
    eq := ext_func(shallow a: I16, shallow b: I16) returns shallow Bool {}
    cmp := ext_func(shallow a: I16, shallow b: I16) returns shallow I64 {}
    neg := func(a: I16) returns I16 { return 0.sub(a.to_i64()).to_i16() }
    abs := func(a: I16) returns I16 { if a.to_i64().lt(0) { return 0.sub(a.to_i64()).to_i16() } return a }
    and := ext_func(shallow a: I16, shallow b: I16) returns shallow I16 {}
    or := ext_func(shallow a: I16, shallow b: I16) returns shallow I16 {}
    xor := ext_func(shallow a: I16, shallow b: I16) returns shallow I16 {}
    clone := ext_func(val: I16) returns shallow I16 {}
    delete := ext_proc(own self: I16, call_free: Bool = true) {}
    size := func() returns U64 { return 2 }
}

