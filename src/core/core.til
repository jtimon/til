mode lib

import("array.til")
import("map.til")
import("set.til")
import("str.til")
import("vec.til")
import("tuple.til")
import("ast.til")

// builtin types (empty structs for future namespace support)
StructDef : StructDef = struct {}
EnumDef : StructDef = struct {}
Dynamic : StructDef = struct {}

U8 := ext_struct {
namespace:
    to_i64 := ext_func(shallow val: U8) returns shallow I64 {}
    to_str := func(val: U8) returns Str {
        return val.to_i64().to_str()
    }
    add := ext_func(shallow a: U8, shallow b: U8) returns shallow U8 {}
    sub := ext_func(shallow a: U8, shallow b: U8) returns shallow U8 {}
    mul := ext_func(shallow a: U8, shallow b: U8) returns shallow U8 {}
    div := ext_func(shallow a: U8, shallow b: U8) returns shallow U8 {}
    mod := ext_func(shallow a: U8, shallow b: U8) returns shallow U8 {}
    inc := func(mut self: U8) { self = self.add(1) }
    dec := func(mut self: U8) { self = self.sub(1) }
    unity := func(self: U8) returns U8 { return 1.to_u8() }
    eq := ext_func(shallow a: U8, shallow b: U8) returns shallow Bool {}
    cmp := ext_func(shallow a: U8, shallow b: U8) returns shallow I64 {}
    and := ext_func(shallow a: U8, shallow b: U8) returns shallow U8 {}
    or := ext_func(shallow a: U8, shallow b: U8) returns shallow U8 {}
    xor := ext_func(shallow a: U8, shallow b: U8) returns shallow U8 {}
    clone := ext_func(val: U8) returns shallow U8 {}
    distance := func(a: Dynamic, b: Dynamic) returns shallow U64 {
        ref au : U8 = a
        ref bu : U8 = b
        if au.lte(bu) { return bu.sub(au).to_i64().to_u64() }
        return au.sub(bu).to_i64().to_u64()
    }
    delete := func(own self: U8, call_free: Bool = true) {
        if call_free { free(own self) }
    }
    size := func() returns USize { return 1 }
}

I16 := ext_struct {
namespace:
    to_i64 := ext_func(shallow val: I16) returns shallow I64 {}
    to_str := func(val: I16) returns Str {
        return val.to_i64().to_str()
    }
    add := ext_func(shallow a: I16, shallow b: I16) returns shallow I16 {}
    sub := ext_func(shallow a: I16, shallow b: I16) returns shallow I16 {}
    mul := ext_func(shallow a: I16, shallow b: I16) returns shallow I16 {}
    div := ext_func(shallow a: I16, shallow b: I16) returns shallow I16 {}
    mod := ext_func(shallow a: I16, shallow b: I16) returns shallow I16 {}
    inc := func(mut self: I16) { self = self.add(1) }
    dec := func(mut self: I16) { self = self.sub(1) }
    unity := func(self: I16) returns I16 { return 1.to_i16() }
    eq := ext_func(shallow a: I16, shallow b: I16) returns shallow Bool {}
    cmp := ext_func(shallow a: I16, shallow b: I16) returns shallow I64 {}
    neg := func(a: I16) returns I16 { return 0.sub(a.to_i64()).to_i16() }
    abs := func(a: I16) returns I16 { if a.to_i64().lt(0) { return 0.sub(a.to_i64()).to_i16() } return a }
    and := ext_func(shallow a: I16, shallow b: I16) returns shallow I16 {}
    or := ext_func(shallow a: I16, shallow b: I16) returns shallow I16 {}
    xor := ext_func(shallow a: I16, shallow b: I16) returns shallow I16 {}
    clone := ext_func(val: I16) returns shallow I16 {}
    distance := func(a: Dynamic, b: Dynamic) returns shallow U64 {
        ref au : I16 = a
        ref bu : I16 = b
        if au.lte(bu) { return bu.sub(au).to_i64().to_u64() }
        return au.sub(bu).to_i64().to_u64()
    }
    delete := func(own self: I16, call_free: Bool = true) {
        if call_free { free(own self) }
    }
    size := func() returns USize { return 2 }
}

import("i32.til")

import("f32.til")

import("u32.til")

import("u64.til")

USize := U32

import("i64.til")

Range := struct {
    start : U64 = 0
    end : U64 = 0

namespace:
    new := func(shallow start: U64, shallow end: U64) returns Range {
        return Range(start = start, end = end)
    }

    len := func(self: Range) returns U64 {
        if self.start.lte(self.end) { return self.end.sub(self.start) }
        return self.start.sub(self.end)
    }

    get := func(self: Range, shallow i: U64) returns U64 {
        if self.start.lte(self.end) {
            return self.start.add(i)
        }
        return self.start.sub(i)
    }

    clone := func(val: Range) returns Range {
        return Range(start = val.start, end = val.end)
    }

    delete := func(own self: Range, call_free: Bool = true) {
        if call_free { free(own self) }
    }
}

import("bool.til")

// builtin functions and procs
and := ext_func(shallow a: Bool, shallow b: Bool) returns shallow Bool {}
or := ext_func(shallow a: Bool, shallow b: Bool) returns shallow Bool {}
not := ext_func(shallow a: Bool) returns shallow Bool {}
print_single := ext_proc(s: Str) {}
print_flush := ext_proc() {}

println := proc(parts: ..Str) {
    for s : Str in parts {
        print_single(s)
    }
    print_flush()
}

print := proc(parts: ..Str) {
    for s : Str in parts {
        print_single(s)
    }
}

format := func(parts: ..Str) returns Str {
    mut total : USize = 0
    for s : Str in parts {
        total = total.add(s.len())
    }
    buf : Dynamic = malloc(total)
    mut offset : USize = 0
    for s : Str in parts {
        memcpy(ptr_add(buf, offset), s.c_str, s.len())
        offset = offset.add(s.len())
    }
    return Str(c_str = buf, count = total, cap = total)
}
exit := ext_func(shallow code: I64) {}
free := ext_func(own elem: Dynamic) {}
is_null := ext_func(p: Dynamic) returns shallow Bool {}
is := ext_func(self: Dynamic, other: Dynamic) returns shallow Bool {}
is_variant := ext_func(self: Dynamic, other: Dynamic) returns shallow Bool {}
get_payload := ext_func(self: Dynamic) returns ref Dynamic {}
malloc := ext_func(shallow count: U64) returns Dynamic {}
calloc := ext_func(shallow nmemb: U64, shallow size: U64) returns Dynamic {}
realloc := ext_func(own buf: Dynamic, shallow count: U64) returns Dynamic {}
ptr_add := ext_func(buf: Dynamic, shallow offset: U64) returns ref Dynamic {}
memcpy := ext_func(dest: Dynamic, src: Dynamic, shallow len: U64) {}
memmove := ext_func(dest: Dynamic, src: Dynamic, shallow len: U64) {}
memset := ext_func(dest: Dynamic, shallow val: I32, shallow len: U64) {}
dyn_call := ext_func(type_name: Str, method: Str, arity: I64, a: Dynamic, b: Dynamic = 0) {}
dyn_call_ret := ext_func(type_name: Str, method: Str, arity: I64, a: Dynamic, b: Dynamic = 0) returns Dynamic {}
dyn_fn := ext_func(type_name: Str, method: Str) returns Dynamic {}

// Default function pointer values for container struct fields
CloneFn := func(Dynamic) returns Dynamic
DeleteFn := func(Dynamic, Bool)
CmpFn := func(Dynamic, Dynamic) returns I64
IncFn := func(Dynamic)
DistanceFn := func(Dynamic, Dynamic) returns USize
default_clone : CloneFn = (v) { return v }
default_delete : DeleteFn = (v, cf) { }
default_cmp : CmpFn = (a, b) { return 0 }
default_inc : IncFn = (v) { }
default_distance : DistanceFn = (a, b) { return 0 }
dyn_has_method := ext_func(type_name: Str, method: Str) returns shallow Bool {}
array := ext_func(type_name: Str, elements: ..Dynamic) returns Array {}
vec := ext_func(type_name: Str, elements: ..Dynamic) returns Vec {}

swap := func(a: Dynamic, b: Dynamic, shallow size: U64) {
    if U8.distance(a, b).eq(0) { return }

    mut offset : U64 = 0
    while offset.add(U64.size()).lte(size) {
        ref aw : U64 = ptr_add(a, offset)
        ref bw : U64 = ptr_add(b, offset)
        tmp := aw.xor(bw)
        new_b := tmp.xor(bw)
        new_a := tmp.xor(new_b)
        memcpy(ptr_add(a, offset), new_a, U64.size())
        memcpy(ptr_add(b, offset), new_b, U64.size())
        offset = offset.add(U64.size())
    }

    while offset.lt(size) {
        ref ab : U8 = ptr_add(a, offset)
        ref bb : U8 = ptr_add(b, offset)
        tmp := ab.xor(bb)
        new_b := tmp.xor(bb)
        new_a := tmp.xor(new_b)
        memcpy(ptr_add(a, offset), new_a, 1)
        memcpy(ptr_add(b, offset), new_b, 1)
        offset = offset.add(1)
    }
}

move := func(dest: Dynamic, src: Dynamic, shallow size: U64) {
    memcpy(dest, src, size)
    memset(src, 0, size)
}

// System primitives
spawn_cmd := ext_proc(cmd: Str) returns I64 {}
check_cmd_status := ext_func(shallow pid: I64) returns shallow I64 {}
sleep := ext_proc(shallow ms: I64) {}
readfile := ext_func(path: Str) returns Str {}
writefile := ext_proc(path: Str, content: Str) {}
file_mtime := ext_func(path: Str) returns shallow I64 {}
clock_ms := ext_func() returns shallow I64 {}
get_thread_count := ext_func() returns shallow I64 {}

wait_cmd := proc(pid: I64) returns I64 {
    while true {
        status := check_cmd_status(pid)
        if status.neq(-1) { return status }
        sleep(50)
    }
}

run_cmd := proc(mut output: Str, args: ..Str) returns I64 {
    mut cmd := ""
    mut i : USize = 0
    while i.lt(args.len()) {
        ref arg: Str = args.get(i)
        if i.gt(0) {
            cmd = cmd.concat(" '").concat(arg).concat("'")
        } else {
            cmd = arg.clone()
        }
        i = i.add(1)
    }
    tmpf := "tmp/_run_cmd_out"
    pid := spawn_cmd(cmd.concat(" > ").concat(tmpf).concat(" 2>&1"))
    ec := wait_cmd(pid)
    content := readfile(tmpf)
    // Copy content data into output (transfer ownership via memcpy)
    memcpy(output, content, Str.size())
    free(own content)
    return ec
}

panic := proc(loc_str: Str, parts: ..Str) {
    println(loc_str, ": panic: ", format(..parts))
    exit(1)
}

TODO := proc(loc_str: Str, parts: ..Str) {
    panic(loc_str, "TODO: ", format(..parts))
}

UNREACHABLE := proc(loc_str: Str) {
    panic(loc_str, "unreachable")
}

assert := func(loc_str: Str, cond: Bool) returns Bool {
    if cond.not() {
        panic(loc_str, "assert failed")
    }
    return true
}

expect := proc(loc_str: Str, cond: Bool, parts: ..Str) {
    if cond.not() {
        panic(loc_str, "assert failed: ", format(..parts))
    }
}

assert_eq := proc(loc_str: Str, a: I64, b: I64) {
    if a.neq(b) {
        panic(loc_str, "assert_eq failed: expected '", a.to_str(), "', found '", b.to_str(), "'")
    }
}

assert_eq_str := proc(loc_str: Str, a: Str, b: Str) {
    if a.eq(b).not() {
        panic(loc_str, "assert_eq_str failed: expected '", a, "', found '", b, "'")
    }
}
