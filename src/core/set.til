mode lib

import("ast")
import("bool")
import("dyn")
import("i64")
import("str")
import("u8")

/// Unordered collection of unique typed elements.
Set := struct<T: Type> {
    own data : U8 = 0
    count : USize = 0
    cap : USize = 0

namespace:
    /// Create an empty Set. T must implement `cmp`.
    new := func() returns Set(T) {
        return Set(T)(data = malloc(T.size().cast(U64)), cap = 1)
    }

    len := func(self: Set(T)) returns USize { return self.count }

    /// Drop all live elements but keep the allocated storage so the Set can be reused.
    clear := func(mut self: Set(T)) {
        for i in 0..self.count {
            T.delete(own ptr_add(self.data, i.mul(T.size()).cast(U64)), false)
        }
        self.count = 0
    }

    /// True if the set contains an element equal to `val`.
    has := func(self: Set(T), val: T) returns Bool {
        mut lo : USize = 0
        mut hi := self.count
        while lo < hi {
            mid := lo.add(hi.sub(lo).div(2))
            ref cur : T = ptr_add(self.data, mid.mul(T.size()).cast(U64))
            c : I64 = T.cmp(cur, val)
            if c < 0 { lo = mid.add(1) }
            else {
                if c > 0 { hi = mid }
                else { return true }
            }
        }
        return false
    }

    /// Insert `val` into the set (sorted order). If an equal element
    /// already exists, `val` is dropped. `val` is owned.
    add := func(mut self: Set(T), own val: T) {
        mut lo : USize = 0
        mut hi := self.count
        mut found := false
        while lo < hi {
            mid := lo.add(hi.sub(lo).div(2))
            ref cur : T = ptr_add(self.data, mid.mul(T.size()).cast(U64))
            c : I64 = T.cmp(cur, val)
            if c < 0 { lo = mid.add(1) }
            else {
                if c > 0 { hi = mid }
                else { found = true; lo = mid; hi = mid }
            }
        }
        if found {
            T.delete(own val, false)
            memset(val, 0, T.size().cast(U64))
            free(own val)
        } else {
            if self.count == self.cap {
                new_cap := self.cap.mul(2)
                self.data = realloc(own self.data, new_cap.mul(T.size()).cast(U64))
                self.cap = new_cap
            }
            memmove(ptr_add(self.data, lo.add(1).mul(T.size()).cast(U64)),
                    ptr_add(self.data, lo.mul(T.size()).cast(U64)),
                    self.count.sub(lo).mul(T.size()).cast(U64))
            memcpy(ptr_add(self.data, lo.mul(T.size()).cast(U64)), val, T.size().cast(U64))
            memset(val, 0, T.size().cast(U64))
            free(own val)
            self.count = self.count.add(1)
        }
    }

    delete := func(own self: Set(T), call_free: Bool = true) {
        self.clear()
        free(own self.data)
        if call_free { free(own self) }
    }

    clone := func(self: Set(T)) returns Set(T) {
        new_data : Dynamic = malloc(self.cap.mul(T.size()).cast(U64))
        for i in 0..self.count {
            ref src : T = ptr_add(self.data, i.mul(T.size()).cast(U64))
            mut cloned : T = T.clone(src)
            memcpy(ptr_add(new_data, i.mul(T.size()).cast(U64)), cloned, T.size().cast(U64))
            memset(cloned, 0, T.size().cast(U64))
        }
        return Set(T)(data = new_data, count = self.count, cap = self.cap)
    }
}
