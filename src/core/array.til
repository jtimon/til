mode lib

import("ast")
import("bool")
import("dyn")
import("str")
import("u8")

array := ext_func(type_name: Str, elements: ..Dynamic) returns Array {}

/// Fixed-capacity array of typed elements.
Array := struct<T: Type> {
    own data : U8 = 0
    const cap : USize = 0

namespace:
    /// Create a zero-initialized Array with the given capacity.
    new := func(cap: USize) returns Array(T) {
        return Array(T)(data = calloc(cap.cast(U64), T.size().cast(U64)), cap = cap)
    }

    len := func(self: Array(T)) returns USize { return self.cap }

    /// Ref to the element at index `i`. Throws OutOfBounds if `i` is
    /// past the end; call as `arr.get(i)!` to panic on a bad index.
    get := func(self: Array(T), i: USize) returns ref T throws OutOfBounds {
        if i.gte(self.cap) {
            throw OutOfBounds(msg = format(__LOC__, ":Array.get: index ", i.to_str(),
                  " out of bounds (len ", self.cap.to_str(), ")"))
        }
        return ptr_add(self.data, i.mul(T.size()).cast(U64))
    }

    /// Overwrite the element at index `i`. Drops the old value. `val` is
    /// owned. Throws OutOfBounds if `i` is past the end; call as
    /// `arr[i] = val` (or `arr.set(i, own val)!`) to panic on a bad index.
    /// (Codegen that fills a fresh in-bounds slot uses set_init, below.)
    set := func(self: Array(T), i: USize, own val: T) throws OutOfBounds {
        if i.gte(self.cap) {
            throw OutOfBounds(msg = format(__LOC__, ":Array.set: index ", i.to_str(),
                  " out of bounds (len ", self.cap.to_str(), ")"))
        }
        T.delete(own ptr_add(self.data, i.mul(T.size()).cast(U64)), false)
        memcpy(ptr_add(self.data, i.mul(T.size()).cast(U64)), val, T.size().cast(U64))
        memset(val, 0, T.size().cast(U64))
    }

    /// Non-throwing in-place set used by the variadic-argument codegen
    /// (build_variadic_array_set fills a freshly-allocated, in-bounds slot
    /// for every variadic call). Once `set` starts throwing OutOfBounds --
    /// so `arr[i] = v` can desugar to `arr.set(i, own v)!` -- the variadic
    /// codegen must not call the throwing `set` (the typer emits these
    /// after throws-lowering, so they would never get the err-args). This
    /// variant panics on a bad index instead of throwing, keeping the
    /// codegen decoupled from `set`'s signature.
    set_init := func(self: Array(T), i: USize, own val: T) {
        if i.gte(self.cap) {
            panic("Array.set_init: index ", i.to_str(),
                  " out of bounds (len ", self.cap.to_str(), ")")
        }
        T.delete(own ptr_add(self.data, i.mul(T.size()).cast(U64)), false)
        memcpy(ptr_add(self.data, i.mul(T.size()).cast(U64)), val, T.size().cast(U64))
        memset(val, 0, T.size().cast(U64))
    }

    delete := func(own self: Array(T), call_free: Bool = true) {
        for i in 0..self.cap {
            T.delete(own ptr_add(self.data, i.mul(T.size()).cast(U64)), false)
        }
        free(own self.data)
        if call_free { free(own self) }
    }

    clone := func(self: Array(T)) returns Array(T) {
        new_data : Dynamic = malloc(self.cap.mul(T.size()).cast(U64))
        for i in 0..self.cap {
            ref src : T = ptr_add(self.data, i.mul(T.size()).cast(U64))
            mut cloned : T = T.clone(src)
            memcpy(ptr_add(new_data, i.mul(T.size()).cast(U64)), cloned, T.size().cast(U64))
            memset(cloned, 0, T.size().cast(U64))
        }
        return Array(T)(data = new_data, cap = self.cap)
    }
}
