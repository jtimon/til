mode lib

import("bool")
import("dyn")
import("i32")
import("i64")
import("map")
import("str")
import("u32")
import("u64")
import("u8")
import("vec")

// builtin types

// --- Primitive enum ---

/// Real primitive types. Issue #203 migrates them one at a time;
/// I16 first because it has the smallest call-site surface.
Primitive := enum {
    I16,
}

// --- Type enum ---

/// Type representation for the til compiler. Carries payload for named
/// types (Struct/Enum/Custom) and is tag-only for builtins.
Type := enum {
    Unknown, None,
    I64, U8, I32, U32, U64, F32, Bool,
    Struct: Str, StructDef,
    Enum: Str, EnumDef,
    FuncDef, FuncPtr, Dynamic,
    Custom: Str,
    // I8 / Primitive are appended at the end (rather than where I16
    // used to sit) so the tag values for existing variants are
    // preserved -- master's til_boot has its tag values baked into
    // its compiled C, and inserting a new variant in the middle
    // would shift everything after it and mis-decode Type values
    // created by master's compiled code while bootstrapping.
    I8,
    Primitive: Primitive,
namespace:
    /// Compare two Types. Named-payload variants (Struct/Enum/Custom)
    /// compare equal regardless of variant if their name payloads match.
    // #165 step 1: treat Custom(x) as equal to Struct(x) or Enum(x).
    // initer's registration helpers can write Custom(name) without
    // resolving against scope; typer lookups that return Struct/Enum
    // still compare equal. Uses .is() throughout (tag-only) because
    // ~switch~ on an enum desugars to recursive ~eq~ calls.
    eq := func(a: Type, b: Type) returns shallow Bool {
        // Named-payload group: Custom, Struct, Enum compare equal across
        // variants iff their name payloads match.
        a_named := a.is(Type.Custom).or(a.is(Type.Struct)).or(a.is(Type.Enum))
        b_named := b.is(Type.Custom).or(b.is(Type.Struct)).or(b.is(Type.Enum))
        if a_named.and(b_named) {
            return til_type_name(a).eq(til_type_name(b))
        }
        if a_named.or(b_named) { return false }
        // Non-payloaded variants: tag equality.
        if a.is(Type.Unknown)   { return b.is(Type.Unknown) }
        if a.is(Type.None)      { return b.is(Type.None) }
        if a.is(Type.I64)       { return b.is(Type.I64) }
        if a.is(Type.U8)        { return b.is(Type.U8) }
        if a.is(Type.I8)        { return b.is(Type.I8) }
        if a.is(Type.Primitive(Primitive.I16))       { return b.is(Type.Primitive(Primitive.I16)) }
        if a.is(Type.I32)       { return b.is(Type.I32) }
        if a.is(Type.U32)       { return b.is(Type.U32) }
        if a.is(Type.U64)       { return b.is(Type.U64) }
        if a.is(Type.F32)       { return b.is(Type.F32) }
        if a.is(Type.Bool)      { return b.is(Type.Bool) }
        if a.is(Type.StructDef) { return b.is(Type.StructDef) }
        if a.is(Type.EnumDef)   { return b.is(Type.EnumDef) }
        if a.is(Type.FuncDef)   { return b.is(Type.FuncDef) }
        if a.is(Type.FuncPtr)   { return b.is(Type.FuncPtr) }
        if a.is(Type.Dynamic)   { return b.is(Type.Dynamic) }
        return false
    }
}

til_type_name_c := func(t: Type) returns Str {
    switch t {
    case Type.Unknown:   return "unknown"
    case Type.None:      return "None"
    case Type.I64:       return "I64"
    case Type.U8:        return "U8"
    case Type.I8:        return "I8"
    case Type.Primitive(Primitive.I16):       return "I16"
    case Type.I32:       return "I32"
    case Type.U32:       return "U32"
    case Type.U64:       return "U64"
    case Type.F32:       return "F32"
    case Type.Bool:      return "Bool"
    case Type.Struct(s):
        // Issue #205: primitives modelled as Type.Struct("I32") etc.
        // round-trip to their primitive name; only "real" user
        // structs return the generic "Struct" tag.
        if s.eq("I32") { return "I32" }
        if s.eq("U8")  { return "U8" }
        if s.eq("I8")  { return "I8" }
        return "Struct"
    case Type.StructDef: return "StructDef"
    case Type.Enum:      return "Enum"
    case Type.EnumDef:   return "EnumDef"
    case Type.FuncDef:   return "FunctionDef"
    case Type.FuncPtr:   return "Fn"
    case Type.Dynamic:   return "Dynamic"
    case Type.Custom(name): return name.clone()
    }
}

// Extract the struct/enum/custom name carried in a Type's payload.
// Returns empty Str for any other variant.
til_type_name := func(t: Type) returns Str {
    switch t {
    case Type.Struct(s): return s.clone()
    case Type.Enum(s):   return s.clone()
    case Type.Custom(s): return s.clone()
    case: return ""
    }
}

// True when ~t~ is one of the scalar primitive types. Centralises the
// list so callers don't have to OR each variant by hand; the body
// changes if a primitive moves between ~Type~ and ~Type.Primitive~
// (or, later, to ~Type.Struct(name)~) but the call sites stay stable.
//
// Issue #205: the switch on Type.Struct(s) is in place so that once
// per-primitive Type variants are dropped and primitives are modelled
// as Type.Struct("I32") etc., this helper still returns true for them
// without other callers having to learn about the dual representation.
is_primitive := func(t: Type) returns shallow Bool {
    switch t {
    case Type.I64:  return true
    case Type.U8:   return true
    case Type.I8:   return true
    case Type.I32:  return true
    case Type.U32:  return true
    case Type.U64:  return true
    case Type.F32:  return true
    case Type.Bool: return true
    case Type.Primitive: return true
    case Type.Struct(s):
        if s.eq("I64")  { return true }
        if s.eq("U8")   { return true }
        if s.eq("I8")   { return true }
        if s.eq("I32")  { return true }
        if s.eq("U32")  { return true }
        if s.eq("U64")  { return true }
        if s.eq("F32")  { return true }
        if s.eq("Bool") { return true }
        if s.eq("I16")  { return true }
        return false
    case: return false
    }
}

// Compound aggregate type: user-defined struct or enum that the
// codegen represents as a multi-field record (and typically
// heap-allocates / dispatches a generated delete on). Excludes
// primitives modelled as Type.Struct("I32") so they keep value
// semantics.
is_aggregate := func(t: Type) returns shallow Bool {
    if is_primitive(t) { return false }
    return t.is(Type.Struct).or(t.is(Type.Enum))
}

dyn_type_to_str := ext_func(type: Type) returns Str {}

// --- FuncType enum ---
/// Classifies a til function declaration: func, proc, test, macro, or external.
FuncType := enum {
    None, Func, Proc, Test, Macro, ExtFunc, ExtProc,
}

/// Argument ownership mode: Own (takes ownership), Ref (borrow), Shallow (trivial copy).
OwnType := enum {
    Own, Ref, Shallow,
}

// --- Declaration struct ---

/// Variable/field/parameter declaration node.
Declaration := struct {
    mut name := ""
    mut doc := ""
    mut explicit_type := ""
    mut is_mut := false
    mut is_priv := false
    mut used := false
    mut own_type := OwnType.Shallow
    mut til_type := Type.Unknown
    mut field_offset : I32 = 0
    mut field_size : I32 = 0
    ref mut field_struct_def : Expr = NULL
    own mut default_value : Expr = Expr.new(NodeType.NoDefaultArg, 0, 0)
    // Issue #93: when init_declarations_unit hoists a nested struct/enum/
    // func from inside a function body to file scope, it stores the
    // original unmangled identifier here so unused-priv diagnostics can
    // report it (and the enclosing parent function name, derived by
    // stripping the trailing "_<orig_name>" from the mangled `name`)
    // in source terms instead of leaking the synthetic mangled name.
    mut orig_name := ""
namespace:
    eq := func(a: Declaration, b: Declaration) returns Bool { return a.name.eq(b.name) }
    to_str := func(self: Declaration) returns Str { return self.name }
}

// --- FunctionDef struct ---
/// Function signature metadata: params, return type, variadic info.
FunctionDef := struct {
    mut func_type := FuncType.Func
    mut params := Vec.new(Declaration)
    mut return_type := ""
    // Issue #198: list of error type names declared in the
    // ~throws T1, T2, ...~ clause of the signature. Empty Vec when
    // the function does not throw. Names match Type.Custom payloads
    // (e.g. ~"DivideByZero"~, ~"Str"~).
    mut throw_types := Vec.new(Str)
    mut variadic_index : I32 = -1
    mut kwargs_index : I32 = -1
    mut return_own_type := OwnType.Own
    // #187 step 2: set true on FuncDefs emitted by initer's auto-gen
    // helpers (clone/delete/size/eq/to_str/variant constructors).
    // The unused-priv-member check skips field/ns reads inside these
    // bodies so genuinely-unused priv members don't get masked by
    // boilerplate references.
    mut auto_generated := false
    mut is_enum_variant_ctor := false
namespace:
    eq := func(a: FunctionDef, b: FunctionDef) returns Bool { return a.return_type.eq(b.return_type) }
    to_str := func(self: FunctionDef) returns Str { return self.return_type }
}

// --- FCall payload struct ---
/// Per-callsite data for function calls: variadic/kwargs counts, own_args bitmap.
FCallData := struct {
    mut variadic_index : I32 = -1
    mut variadic_count : USize = 0
    mut kwargs_index : I32 = -1
    mut kwargs_count : USize = 0
    mut is_splat := false
    // Issue #198: parser sets this when the call is followed by ~?~,
    // marking it as a call to a throwing function. The typer
    // validates that does_throw matches the callee's throws set.
    mut does_throw := false
    // Issue #202: parser sets this when the call is followed by ~!~,
    // the "panic on throw" sugar. The typer desugars f(args)! into
    // f(args)? followed by an auto-injected catch (e: T) { panic } per
    // declared throw type, then clears the flag.
    mut is_bang := false
    mut own_args : U64 = 0
    // Issue #206 slice 3: payload-resident result type. The typer
    // writes the resolved callee return type here via the
    // set_fcall_til_type helper at FCall infer time, and
    // ~expr_til_type~ reads it back via the chokepoint's FCall
    // dispatch case. Callees declared without a ~returns~ clause
    // resolve to ~Type.None~ -- common for callees written as
    // ~proc~, but not a func/proc distinction (per CLAUDE.md
    // "func vs proc is not Pascal", the only rule is "func cannot
    // call proc"; both kinds may or may not return a value).
    mut til_type := Type.Unknown
namespace:
    eq := func(a: FCallData, b: FCallData) returns Bool {
        return a.variadic_index.eq(b.variadic_index)
        .and(a.variadic_count.eq(b.variadic_count))
        .and(a.kwargs_index.eq(b.kwargs_index))
        .and(a.kwargs_count.eq(b.kwargs_count))
    }
    to_str := func(_self: FCallData) returns Str { return "FCall" }
}

LiteralNumData := struct {
    mut text := ""
    mut til_type := Type.Unknown
namespace:
    eq := func(a: LiteralNumData, b: LiteralNumData) returns Bool { return a.text.eq(b.text) }
    to_str := func(self: LiteralNumData) returns Str { return self.text }
    to_i64 := func(self: LiteralNumData) returns shallow I64 { return self.text.to_i64() }
    to_u8 := func(self: LiteralNumData) returns shallow U8 { return self.text.to_u8() }
    to_i32 := func(self: LiteralNumData) returns shallow I32 { return self.text.to_i32() }
    to_u32 := func(self: LiteralNumData) returns shallow U32 { return self.text.to_u32() }
    to_u64 := func(self: LiteralNumData) returns shallow U64 { return self.text.to_u64() }
    to_usize := func(self: LiteralNumData) returns shallow USize { return self.text.to_usize() }
    to_f32 := func(self: LiteralNumData) returns shallow F32 { return self.text.to_f32() }
}

IdentData := struct {
    mut name := ""
    mut til_type := Type.Unknown
namespace:
    eq := func(a: IdentData, b: IdentData) returns Bool { return a.name.eq(b.name) }
    to_str := func(self: IdentData) returns Str { return self.name }
    len := func(self: IdentData) returns shallow U32 { return self.name.len() }
    is_empty := func(self: IdentData) returns shallow Bool { return self.name.is_empty() }
    starts_with := func(self: IdentData, prefix: Str) returns shallow Bool { return self.name.starts_with(prefix) }
    ends_with := func(self: IdentData, suffix: Str) returns shallow Bool { return self.name.ends_with(suffix) }
    concat := func(self: IdentData, tail: Str) returns Str { return self.name.concat(tail) }
    replace := func(self: IdentData, old: Str, new: Str) returns Str { return self.name.replace(old, new) }
    strip_suffix := func(self: IdentData, suffix: Str) returns Str { return self.name.strip_suffix(suffix) }
    byte_at := func(self: IdentData, i: U32) returns ref I8 { return self.name.byte_at(i) }
    get := func(self: IdentData, i: U32) returns ref I8 { return self.name.get(i) }
}

FieldAccessData := struct {
    mut name := ""
    mut til_type := Type.Unknown
namespace:
    eq := func(a: FieldAccessData, b: FieldAccessData) returns Bool { return a.name.eq(b.name) }
    to_str := func(self: FieldAccessData) returns Str { return self.name }
    len := func(self: FieldAccessData) returns shallow U32 { return self.name.len() }
    is_empty := func(self: FieldAccessData) returns shallow Bool { return self.name.is_empty() }
    starts_with := func(self: FieldAccessData, prefix: Str) returns shallow Bool { return self.name.starts_with(prefix) }
    concat := func(self: FieldAccessData, tail: Str) returns Str { return self.name.concat(tail) }
    replace := func(self: FieldAccessData, old: Str, new: Str) returns Str { return self.name.replace(old, new) }
}

literal_num_text := func(n: LiteralNumData) returns Str { return n.text.clone() }
ident_name := func(id: IdentData) returns Str { return id.name.clone() }
field_access_name := func(fa: FieldAccessData) returns Str { return fa.name.clone() }

set_own_arg := func(mut fcall: Expr, shallow arg_index: USize) {
    switch fcall.node_type {
    case NodeType.FCall(fcd):
        mut bit : U64 = 1
        for _ in 0..arg_index { bit = bit.mul(2) }
        fcd.own_args = fcd.own_args.or(bit)
    case:
        UNREACHABLE(__LOC__)
    }
}

get_own_arg := func(fcall: Expr, shallow arg_index: USize) returns shallow Bool {
    switch fcall.node_type {
    case NodeType.FCall(fcd):
        mut bit : U64 = 1
        for _ in 0..arg_index { bit = bit.mul(2) }
        return fcd.own_args.and(bit).gt(0)
    case:
        UNREACHABLE(__LOC__)
        return false
    }
}

/// Struct definition: field declarations, namespace methods, total size.
StructDef : StructDef = struct {
    mut total_struct_size : I32 = 0
    mut fields := Vec.new(Declaration)
    mut ns_decls := Vec.new(Declaration)
    mut c_tag := ""
namespace:
    eq := func(a: StructDef, b: StructDef) returns Bool {
        return a.total_struct_size.eq(b.total_struct_size)
    }
    to_str := func(_self: StructDef) returns Str { return "StructDef" }
}

/// Enum definition: variants, payload types, namespace methods.
EnumDef : StructDef = struct {
    mut ns_decls := Vec.new(Declaration)
    mut variants := Vec.new(Str)
    mut payload_types := Map.new(I64, Str)
    mut total_enum_size : I32 = 0
namespace:
    eq := func(a: EnumDef, b: EnumDef) returns Bool {
        return a.variants.len().eq(b.variants.len())
    }
    to_str := func(_self: EnumDef) returns Str { return "EnumDef" }
}

// Issue #56/#58: assemble a StructDef value for a registered struct type
// by querying the loaded program through the struct_field_* introspection
// primitives (src/core/dyn.til). Each field becomes a Declaration carrying
// its name, mutability, and declared type. Mirrors rstil's struct_def_of.
struct_def_of := func(type_name: Str) returns StructDef {
    mut def := StructDef()
    n := struct_field_count(type_name)
    for i in 0..n {
        mut decl := Declaration()
        decl.name = struct_field_name(type_name, i)
        decl.is_mut = struct_field_is_mut(type_name, i).eq(1)
        decl.explicit_type = struct_field_type(type_name, i)
        def.fields.push(own decl)
    }
    return def
}

// Issue #57/#58: assemble an EnumDef value for a registered enum type via
// the enum_variant_* primitives. Variant names go into `variants`;
// payload-bearing variants record their type in `payload_types` keyed by
// variant index. Mirrors rstil's enum_def_of.
enum_def_of := func(type_name: Str) returns EnumDef {
    mut def := EnumDef()
    n := enum_variant_count(type_name)
    for i in 0..n {
        def.variants.push(own enum_variant_name(type_name, i))
        if enum_variant_has_payload(type_name, i).eq(1) {
            pt := enum_variant_payload_type(type_name, i)
            def.payload_types.set(own i.clone(), own pt)
        }
    }
    return def
}

// Issue #58: assemble a FunctionDef (signature) value for a registered
// FuncSig type via the func_sig_* primitives. Parameter Declarations
// carry only their type (signatures have no parameter names); a single
// return type and the throw-type list are filled when present. Mirrors
// rstil's func_sig_of.
func_sig_of := func(type_name: Str) returns FunctionDef {
    mut sig := FunctionDef()
    pn := func_sig_param_count(type_name)
    for i in 0..pn {
        mut decl := Declaration()
        decl.explicit_type = func_sig_param_type(type_name, i)
        sig.params.push(own decl)
    }
    if func_sig_return_count(type_name).eq(1) {
        sig.return_type = func_sig_return_type(type_name, 0)
    }
    tn := func_sig_throw_count(type_name)
    for i in 0..tn {
        sig.throw_types.push(own func_sig_throw_type(type_name, i))
    }
    return sig
}

// --- NodeType payload enum (25 variants) ---

/// Payload for assignment nodes: which name is being assigned to.
AssignData := struct {
    mut name := ""
    mut save_old_delete := false
namespace:
    eq := func(a: AssignData, b: AssignData) returns Bool { return a.name.eq(b.name) }
    to_str := func(self: AssignData) returns Str { return self.name }
}

FieldAssignData := struct {
    mut name := ""
    mut save_old_delete := false
namespace:
    eq := func(a: FieldAssignData, b: FieldAssignData) returns Bool { return a.name.eq(b.name) }
    to_str := func(self: FieldAssignData) returns Str { return self.name }
}

/// Payload for `for name in range` loop nodes.
ForInData := struct {
    mut name := ""
    mut is_mut := false
    mut til_type := Type.Unknown
namespace:
    eq := func(a: ForInData, b: ForInData) returns Bool { return a.name.eq(b.name) }
    to_str := func(self: ForInData) returns Str { return self.name }
}

/// Literal (constant) node kinds: the leaf values written directly in
/// source. Grouped under NodeType.Literal so "is this any literal?"
/// is a single check (NodeType.Literal) instead of a four-way chain.
Literal := enum {
    Str: Str,
    Num: LiteralNumData,
    Bool: Bool,
    Null,
}

/// AST node kind. Each variant carries an optional payload (struct, string, bool).
NodeType := enum {
    Body,
    Literal: Literal,
    Ident: IdentData,
    Decl: Declaration,
    Assign: AssignData,
    FCall: FCallData,
    FuncDef: FunctionDef,
    StructDef: StructDef,
    EnumDef: EnumDef,
    FieldAccess: FieldAccessData,
    FieldAssign: FieldAssignData,
    Return,
    If,
    While,
    ForIn: ForInData,
    NamedArg: Str,
    Break,
    Continue,
    MapLit,
    SetLit,
    Switch,
    Case,
    NoDefaultArg,
    // Issue #198: error handling. Throw has 1 child (the thrown
    // expression). Catch has 3 children: Ident (var name), Ident
    // (caught type), Body. The typer validates and then lowers
    // both away to plain til (mut locals + if), so no downstream
    // stage ever evaluates them.
    Throw,
    Catch,
    // Issue #36: rest-pattern marker for struct field matching.
    // `case Point(x = 0, ..):` parses the `..` token into this node
    // and stores it as a child of the FCall pattern. The typer reads
    // its presence to allow missing-field cases and rejects patterns
    // that omit fields without the marker.
    RestPattern,
namespace:
    // is() compares only the outer enum tag, so is(NodeType.Literal(Literal.X))
    // cannot tell the literal kinds apart -- it matches any Literal. These
    // switch-based predicates discriminate the inner Literal variant. Use
    // node_type.is(NodeType.Literal) directly when "any literal" is wanted.
    is_literal_str := func(self: NodeType) returns shallow Bool {
        switch self { case NodeType.Literal(Literal.Str): return true case: return false }
    }
    is_literal_num := func(self: NodeType) returns shallow Bool {
        switch self { case NodeType.Literal(Literal.Num): return true case: return false }
    }
    is_literal_bool := func(self: NodeType) returns shallow Bool {
        switch self { case NodeType.Literal(Literal.Bool): return true case: return false }
    }
    is_literal_null := func(self: NodeType) returns shallow Bool {
        switch self { case NodeType.Literal(Literal.Null): return true case: return false }
    }
}

// --- Expr struct ---

/// AST expression node with line/col, type, children, and node-specific payload.
Expr := struct {
    mut node_type := NodeType.Body
    mut children := Vec.new(Expr)
    mut line : U32 = 0
    mut col : U32 = 0

namespace:
    /// Print a diagnostic error with file path and source location.
    error := proc(self: Expr, path: Str, msg: Str) {
        println(path, ":", self.line.to_str(), ":", self.col.to_str(), ": error: ", msg)
    }
    /// Like error() but adds "not implemented yet" note.
    todo_error := proc(self: Expr, path: Str, msg: Str) {
        self.error(path, msg)
        println("  note: this language feature is not implemented yet")
    }
    /// Like error() but adds "bug in the language" note.
    lang_error := proc(self: Expr, path: Str, msg: Str) {
        self.error(path, msg)
        println("  note: this is a bug in the language, please report it")
    }
    /// Take ownership of `child` and append it to the children list.
    add_child := func(mut self: Expr, own child: Expr) {
        self.children.push(own child)
    }
    /// Clone `child` and append the clone to the children list.
    push_child_clone := func(mut self: Expr, child: Expr) {
        self.children.push(own child.clone())
    }
    /// Append other's children into self via raw memcpy (no cloning).
    /// Zeroes other's count so it no longer owns the moved items.
    take_children := func(mut self: Expr, mut other: Expr) {
        if other.children.count.eq(0) { return }
        needed := self.children.count.add(other.children.count)
        if needed.gt(self.children.cap) {
            mut new_cap := self.children.cap
            while needed.gt(new_cap) {
                new_cap = new_cap.mul(2)
            }
            self.children.data = realloc(own self.children.data, new_cap.mul(self.children.elem_size))
            self.children.cap = new_cap
        }
        memcpy(ptr_add(self.children.data, self.children.count.mul(self.children.elem_size)),
            other.children.data, other.children.count.mul(other.children.elem_size))
        self.children.count = needed
        other.children.count = 0
        // Free other's source buffer before nulling: the bytes were
        // memcpy'd into self, but other's malloc'd buffer would leak.
        free(own other.children.data)
        other.children.data = NULL
    }
    /// Shortcut to get a ref to the i-th child of `parent`.
    child := func(parent: Expr, i: USize) returns ref Expr {
        ref c : Expr = parent.children.get(i)
        return c
    }
    /// Create a new Expr with the given node_type and source location.
    new := func(data: NodeType, shallow line: U32, shallow col: U32) returns Expr {
        mut out := Expr(node_type = data.clone(), line = line, col = col)
        switch out.node_type {
        case NodeType.FCall(fcall_data):
            fcall_data.variadic_index = -1
            fcall_data.variadic_count = 0
            fcall_data.kwargs_index = -1
            fcall_data.kwargs_count = 0
        case:
        }
        return out
    }
    eq := func(_self: Expr, _other: Expr) returns shallow Bool {
        TODO(__LOC__, "Expr.eq")
        return false
    }
    to_str := func(self: Expr) returns Str {
        return expr_to_str_indent(self, 0)
    }
}

ident_node := func(name: Str) returns NodeType {
    return NodeType.Ident(IdentData(name = name.clone()))
}

literal_num_node := func(text: Str) returns NodeType {
    return NodeType.Literal(Literal.Num(LiteralNumData(text = text.clone())))
}

field_access_node := func(name: Str) returns NodeType {
    return NodeType.FieldAccess(FieldAccessData(name = name.clone()))
}

expr_til_type := func(e: Expr) returns Type {
    switch e.node_type {
    case NodeType.Body:        return Type.None
    case NodeType.Literal(Literal.Str):  return Type.Struct("Str")
    case NodeType.Literal(Literal.Num(nd)):
        if nd.til_type.is(Type.Unknown) { return Type.I64 }
        return nd.til_type.clone()
    case NodeType.Literal(Literal.Bool): return Type.Bool
    case NodeType.Literal(Literal.Null): return Type.Dynamic
    case NodeType.Ident(id):   return id.til_type.clone()
    case NodeType.Decl(dd):    return dd.til_type.clone()
    case NodeType.Assign:
        if e.children.len().eq(0) { return Type.Unknown }
        return expr_til_type(e.child(0))
    case NodeType.MapLit:      return Type.Struct("Map")
    case NodeType.SetLit:      return Type.Struct("Set")
    case NodeType.NamedArg:
        if e.children.len().eq(0) { return Type.Unknown }
        return expr_til_type(e.child(0))
    case NodeType.FCall(fcd):  return fcd.til_type.clone()
    case NodeType.FuncDef:     return Type.FuncPtr
    case NodeType.StructDef:   return Type.Struct("StructDef")
    case NodeType.EnumDef:     return Type.Struct("EnumDef")
    case NodeType.FieldAccess(fd): return fd.til_type.clone()
    case NodeType.FieldAssign: return Type.None
    case NodeType.Return:
        if e.children.len().eq(0) { return Type.None }
        return expr_til_type(e.child(0))
    case NodeType.If:          return Type.None
    case NodeType.While:       return Type.None
    case NodeType.ForIn(fd):   return fd.til_type.clone()
    case NodeType.Break:       return Type.None
    case NodeType.Continue:    return Type.None
    case NodeType.Switch:      return Type.None
    case NodeType.Case:        return Type.None
    case NodeType.NoDefaultArg:return Type.Unknown
    case NodeType.Throw:
        if e.children.len().eq(0) { return Type.None }
        return expr_til_type(e.child(0))
    case NodeType.Catch:       return Type.None
    case NodeType.RestPattern: return Type.Unknown
    }
    return Type.Unknown
}

set_expr_til_type := func(mut e: Expr, shallow t: Type) {
    switch e.node_type {
    case NodeType.Literal(Literal.Num(nd)):
        nd.til_type = t
    case NodeType.Ident(id):
        id.til_type = t
    case NodeType.Decl(dd):
        dd.til_type = t
    case NodeType.FCall(fcd):
        fcd.til_type = t
    case NodeType.FieldAccess(fd):
        fd.til_type = t
    case NodeType.ForIn(fd):
        fd.til_type = t
    case NodeType.Throw:
        if e.children.len().gt(0) {
            set_expr_til_type(e.child(0), t)
        }
    case:
    }
}

set_fcall_til_type := func(mut fcall: Expr, shallow t: Type) {
    set_expr_til_type(fcall, t)
}

// --- func_type_variant_name ---
// Enum-variant-name form of FuncType (as written in NodeType.FuncDef
// payload), for Expr.to_str output. Distinct from func_type_name which
// returns the til keyword (lowercase/snake_case).
// (The casing is PascalCase because that's how the FuncType enum variants
// are spelled; it has nothing to do with the Pascal language. til's func
// vs proc is not Pascal's void-vs-returns split -- the only rule is that
// a func cannot call a proc.)
func_type_variant_name := func(ft: FuncType) returns Str {
    switch ft {
    case FuncType.None:    return "None"
    case FuncType.Func:    return "Func"
    case FuncType.Proc:    return "Proc"
    case FuncType.Test:    return "Test"
    case FuncType.Macro:   return "Macro"
    case FuncType.ExtFunc: return "ExtFunc"
    case FuncType.ExtProc: return "ExtProc"
    }
}

// --- node_head_str ---
// Head string used inside the parentheses by Expr.to_str: the NodeType's
// variant name plus any inline payload (identifier, literal text, decl name,
// etc.). Names are kept as written in the NodeType enum (no case conversion).
node_head_str := func(data: NodeType) returns Str {
    switch data {
    case NodeType.Body:           return "Body"
    case NodeType.Literal(Literal.Str(s)):  return format("LiteralStr \"", s, "\"")
    case NodeType.Literal(Literal.Num(s)):  return format("LiteralNum ", literal_num_text(s))
    case NodeType.Literal(Literal.Bool(b)):
        if b { return "LiteralBool true" }
        return "LiteralBool false"
    case NodeType.Literal(Literal.Null):    return "LiteralNull"
    case NodeType.Ident(s):       return format("Ident ", ident_name(s))
    case NodeType.Decl(d):
        if d.is_mut { return format("Decl mut ", d.name) }
        return format("Decl ", d.name)
    case NodeType.Assign(a):      return format("Assign ", a.name)
    case NodeType.FCall:          return "FCall"
    case NodeType.FuncDef(f):     return format("FuncDef ", func_type_variant_name(f.func_type))
    case NodeType.StructDef:      return "StructDef"
    case NodeType.EnumDef:        return "EnumDef"
    case NodeType.FieldAccess(s): return format("FieldAccess ", field_access_name(s))
    case NodeType.FieldAssign(fad): return format("FieldAssign ", fad.name)
    case NodeType.Return:         return "Return"
    case NodeType.If:             return "If"
    case NodeType.While:          return "While"
    case NodeType.ForIn(fi):
        if fi.is_mut { return format("ForIn mut ", fi.name) }
        return format("ForIn ", fi.name)
    case NodeType.NamedArg(s):    return format("NamedArg ", s)
    case NodeType.Break:          return "Break"
    case NodeType.Continue:       return "Continue"
    case NodeType.MapLit:         return "MapLit"
    case NodeType.SetLit:         return "SetLit"
    case NodeType.Switch:         return "Switch"
    case NodeType.Case:           return "Case"
    case NodeType.NoDefaultArg:   return "NoDefaultArg"
    case NodeType.Throw:          return "Throw"
    case NodeType.Catch:          return "Catch"
    case: return "?"
    }
}

// --- expr_to_str_indent ---
// Backing implementation for Expr.to_str. Produces format B-hybrid:
//   leaf (no children):        (Head)
//   with children:             ((Head)\n  c1\n  c2 ...)
// where Head = NodeType variant name + inline payload (see node_head_str).
expr_to_str_indent := func(self: Expr, shallow indent: U32) returns Str {
    mut out := ""
    for _ in 0..indent.to_u64() {
        out = out.concat("  ")
    }
    head := node_head_str(self.node_type)
    if self.children.len().eq(0) {
        return out.concat("(").concat(head).concat(")")
    }
    out = out.concat("((").concat(head).concat(")")
    for c : Expr in self.children {
        out = out.concat("\n").concat(expr_to_str_indent(c, indent.add(1)))
    }
    return out.concat(")")
}

// --- node_name ---
node_name := func(data: NodeType) returns Str {
    switch data {
    case NodeType.Body:        return "body"
    case NodeType.Literal(Literal.Str):  return "str"
    case NodeType.Literal(Literal.Num):  return "num"
    case NodeType.Literal(Literal.Bool): return "bool"
    case NodeType.Literal(Literal.Null): return "null"
    case NodeType.Ident:       return "ident"
    case NodeType.Decl:        return "decl"
    case NodeType.Assign:      return "assign"
    case NodeType.FCall:       return "fcall"
    case NodeType.FuncDef:     return "func_def"
    case NodeType.StructDef:   return "struct_def"
    case NodeType.EnumDef:     return "enum_def"
    case NodeType.FieldAccess: return "field_access"
    case NodeType.FieldAssign: return "field_assign"
    case NodeType.Return:      return "return"
    case NodeType.If:          return "if"
    case NodeType.While:       return "while"
    case NodeType.ForIn:       return "for_in"
    case NodeType.NamedArg:    return "named_arg"
    case NodeType.Break:       return "break"
    case NodeType.Continue:    return "continue"
    case NodeType.MapLit:      return "map_lit"
    case NodeType.SetLit:      return "set_lit"
    case NodeType.Switch:      return "switch"
    case NodeType.Case:        return "case"
    case NodeType.Throw:       return "throw"
    case NodeType.Catch:       return "catch"
    case: return "?"
    }
}

// --- func_type_name ---
func_type_name := func(ft: FuncType) returns Str {
    switch ft {
    case FuncType.Func:    return "func"
    case FuncType.Proc:    return "proc"
    case FuncType.Test:    return "test"
    case FuncType.Macro:   return "macro"
    case FuncType.ExtFunc: return "ext_func"
    case FuncType.ExtProc: return "ext_proc"
    case: return "?"
    }
}

// --- ast_print ---
ast_print := proc(e: Expr, shallow indent: U32) {
    for _ in 0..indent.to_u64() {
        print("  ")
    }
    print("(", node_name(e.node_type))
    et := expr_til_type(e)
    if et.is(Type.Unknown).not() {
        print(":", til_type_name_c(et))
    }
    switch e.node_type {
    case NodeType.Ident(s):      print(" \"", ident_name(s), "\"")
    case NodeType.Literal(Literal.Str(s)): print(" \"", s, "\"")
    case NodeType.Literal(Literal.Num(s)): print(" \"", literal_num_text(s), "\"")
    case NodeType.Literal(Literal.Bool(b)): if b { print(" true") } else { print(" false") }
    case NodeType.ForIn(fi):
        if fi.is_mut { print(" mut") }
        print(" \"", fi.name, "\"")
    case NodeType.Decl(decl):
        if decl.is_mut { print(" mut") }
        print(" ", decl.name)
    case NodeType.Assign(a):     print(" ", a.name)
    case NodeType.NamedArg(s):   print(" ", s)
    case NodeType.FuncDef(fdef): print(" ", func_type_name(fdef.func_type))
    case: // nothing
    }
    if e.children.len().gt(0) {
        println("")
        for e_i : Expr in e.children {
            ast_print(e_i, indent.add(1))
        }
        for _ in 0..indent.to_u64() {
            print("  ")
        }
    }
    println(")")
}

// --- Decl/type helpers ---

// Is stmt a NodeType.Decl that has an RHS child?
is_decl_with_child := func(stmt: Expr) returns shallow Bool {
    return stmt.node_type.is(NodeType.Decl).and(stmt.children.len().gt(0))
}

// Is stmt a Decl whose RHS is a StructDef or EnumDef?
is_struct_or_enum := func(stmt: Expr) returns shallow Bool {
    if is_decl_with_child(stmt).not() { return false }
    ref def : Expr = stmt.child(0)
    return def.node_type.is(NodeType.StructDef).or(def.node_type.is(NodeType.EnumDef))
}

// Is stmt a Decl whose RHS is a FuncDef?
is_func_decl := func(stmt: Expr) returns shallow Bool {
    if is_decl_with_child(stmt).not() { return false }
    return stmt.child(0).node_type.is(NodeType.FuncDef)
}

// Is stmt a Decl whose RHS is any of FuncDef/StructDef/EnumDef?
is_def := func(stmt: Expr) returns shallow Bool {
    if is_decl_with_child(stmt).not() { return false }
    ref def : Expr = stmt.child(0)
    return def.node_type.is(NodeType.FuncDef)
    .or(def.node_type.is(NodeType.StructDef))
    .or(def.node_type.is(NodeType.EnumDef))
}

def_ns_decls := func(sdef: Expr) returns ref Vec {
    switch sdef.node_type {
    case NodeType.StructDef(sd):
        return sd.ns_decls
    case NodeType.EnumDef(ed):
        return ed.ns_decls
    case:
        UNREACHABLE(__LOC__)
        return NULL
    }
}

// --- Enum helpers ---

enum_has_payloads := func(enum_def: Expr) returns shallow Bool {
    switch enum_def.node_type {
    case NodeType.EnumDef(edd):
        return edd.payload_types.len().gt(0)
    case:
        // Should be unreachable; return to satisfy C -Wreturn-type.
        UNREACHABLE(__LOC__)
        return false
    }
}

enum_variant_tag := func(enum_def: Expr, variant_name: Str) returns I32 {
    switch enum_def.node_type {
    case NodeType.EnumDef(edd):
        for i in 0..edd.variants.len() {
            ref vn : Str = edd.variants.get(i)
            if vn.eq(variant_name) { return i.to_i32() }
        }
    case:
        UNREACHABLE(__LOC__)
    }
    return -1
}

enum_variant_type := func(enum_def: Expr, shallow tag: I32) returns Str {
    switch enum_def.node_type {
    case NodeType.EnumDef(edd):
        idx := tag.to_i64()
        if edd.payload_types.has(idx) {
            ref pt : Str = edd.payload_types.get(idx)
            return pt.clone()
        }
    case:
        UNREACHABLE(__LOC__)
    }
    return ""
}
