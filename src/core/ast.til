mode lib

import("bool")
import("map")
import("numbers")
import("str")
import("vec")

// builtin types

// --- Primitive enum ---

/// Real primitive types. Issue #203 migrates them one at a time;
/// I16 first because it has the smallest call-site surface.
Primitive := enum {
    I16,
    U16,
    I8,
    U8,
    U32,
    I32,
    U64,
    I64,
    F32,
    Bool,
}

// --- Type enum ---

/// Type representation for the til compiler. Carries payload for named
/// types (Struct/Enum/Custom) and is tag-only for builtins.
Type := enum {
    Unknown, None,
    // All scalar primitives now live under Type.Primitive(Primitive). The
    // builtin metatypes below carry no payload (Struct/Enum/Custom carry a
    // name).
    Struct: Str, StructDef,
    Enum: Str, EnumDef,
    FuncDef, FuncPtr, Dynamic,
    Custom: Str,
    // Primitive is appended at the end so the tag values for existing
    // variants are preserved -- master's til_boot has its tag values baked
    // into its compiled C, and inserting a new variant in the middle would
    // shift everything after it and mis-decode Type values created by
    // master's compiled code while bootstrapping.
    Primitive: Primitive,
    // Issue #58 / #147 step 5: FuncPtr with the FuncSig alias name
    // (e.g. `Type.FuncPtrSig("BinaryOp")`). Tag-only `Type.FuncPtr` stays
    // for the wildcard "some function pointer" cases; sites that know
    // the FuncSig name (param decls with `explicit_type` matching a
    // funcsig binding, struct fields likewise) will migrate to this
    // variant in follow-up commits so Declaration.explicit_type can
    // eventually be dropped (#147 step 5). Same append-at-end rule as
    // Primitive: keeps the existing tags stable for bootstrapping.
    FuncPtrSig: Str,
    // Issue #55: first-class executable statement bodies. Backends may use
    // the same closure carrier as FuncPtr internally, but the source type is
    // distinct.
    Body,
}

// The compiler-facing Type helper funcs (til_type_name_c, is_primitive,
// is_funcptr, is_aggregate) live in src/self/context.til; dyn_type_to_str,
// til_type_name and the reflection assemblers (struct_def_of, enum_def_of,
// func_sig_of) live in src/core/dyn.til next to the introspection
// primitives they wrap.

// --- FuncType enum ---
/// Classifies a til function declaration: func, proc, test, macro, or external.
FuncType := enum {
    Func, Proc, Test, Macro, ExtFunc, ExtProc, LazyFunc, LazyProc,
    // #288: core_func/core_proc -- primitive intrinsics. Parsed and typed
    // exactly like ext_func/ext_proc, but every backend MUST lower them
    // natively (no emitted symbol, no per-backend impl) and the typer
    // FORBIDS indirecting them (dyn_fn / FuncPtr field / FFI). Appended at
    // the END so existing tag values stay stable for til_boot's committed
    // boot/ (same constraint that appended Sbyte/Ushort to Value).
    CoreFunc, CoreProc,
    // core_lazy_func: a bodyless lazy core primitive (and/or). Like a
    // core_func, every backend lowers it natively (C: the short-circuiting
    // && / || operators) and it can never be indirected; like a lazy_func,
    // its arguments are evaluated call-by-name (the loader splices the
    // compiler-known match expansion at parse-time call sites). Appended at
    // the END so existing tag values stay stable for til_boot's boot/.
    CoreLazyFunc,
namespace:
    // Enum-variant-name form (as written in the FuncType enum above), for
    // NodeType.head_str / Expr.to_str output. Distinct from func_type_name
    // (src/self/parser.til) which returns the til keyword (snake_case).
    variant_name := func(self: FuncType) returns Str {
        switch self {
        case FuncType.Func:    return "Func"
        case FuncType.Proc:    return "Proc"
        case FuncType.Test:    return "Test"
        case FuncType.Macro:   return "Macro"
        case FuncType.ExtFunc: return "ExtFunc"
        case FuncType.ExtProc: return "ExtProc"
        case FuncType.LazyFunc: return "LazyFunc"
        case FuncType.LazyProc: return "LazyProc"
        case FuncType.CoreFunc: return "CoreFunc"
        case FuncType.CoreProc: return "CoreProc"
        case FuncType.CoreLazyFunc: return "CoreLazyFunc"
        }
    }
}

/// Argument ownership mode: Own (takes ownership), Ref (borrow), Shallow (trivial copy).
OwnType := enum {
    Own, Ref, Shallow,
}

// --- Declaration struct ---

// #302 stage 1: the storage decision the garbager settles for a local
// Decl, RECORDED on the Declaration so downstream stages (builder,
// interpreter) execute it instead of re-deriving it from expression
// shapes. Unset = the pass did not classify the binding (params, ref
// locals, bodies the garbager never processed).
GcStorage := enum { Unset, Stack, HeapBox }

/// Variable/field/parameter declaration node.
Declaration := struct {
    name := ""
    doc := ""
    explicit_type := ""
    is_mut := false
    // #211: set by the parser when a struct FIELD carries an explicit
    // `mut`. Fields are mutable by default, so the keyword is redundant
    // and the typer rejects it. Meaningless for locals/params/ns-decls.
    redundant_mut := false
    is_priv := false
    used := false
    own_type := OwnType.Shallow
    til_type := Type.Unknown
    own default_value : Expr = Expr.new(NodeType.NoDefaultArg, 0, 0)
    // Issue #93: when init_declarations_unit hoists a nested struct/enum/
    // func from inside a function body to file scope, it stores the
    // original unmangled identifier here so unused-priv diagnostics can
    // report it (and the enclosing parent function name, derived by
    // stripping the trailing "_<orig_name>" from the mangled `name`)
    // in source terms instead of leaking the synthetic mangled name.
    orig_name := ""
    // #302 stage 1: settled by the garbager (record_storage_decisions)
    // after promotion; see GcStorage above. Appended at the END so the
    // committed boot's Declaration layout stays stable.
    gc_storage := GcStorage.Unset
namespace:
    eq := func(a: Declaration, b: Declaration) returns Bool { return a.name == b.name }
    to_str := func(self: Declaration) returns Str { return self.name }
}

// --- FunctionDef struct ---
/// Function signature metadata: params, return type, variadic info.
FunctionDef := struct {
    func_type := FuncType.Func
    params := Vec(Declaration).new()
    return_type := ""
    // Issue #198: list of error type names declared in the
    // ~throws T1, T2, ...~ clause of the signature. Empty Vec when
    // the function does not throw. Names match Type.Custom payloads
    // (e.g. ~"DivideByZero"~, ~"Str"~).
    throw_types := Vec(Str).new()
    variadic_index : I32 = -1
    kwargs_index : I32 = -1
    return_own_type := OwnType.Own
    // Issue #223: set by the parser ONLY when the return type carries an
    // explicit `shallow` qualifier. The redundant-shallow diagnostic must
    // test this, NOT return_own_type, because the typer's auto-shallow pass
    // overwrites return_own_type Own->Shallow for primitives -- which would
    // make the check misfire on any RE-inference of the def (e.g. a capturing
    // closure re-typed as a UFCS-receiver-call arg). This flag preserves the
    // user's original intent across re-inference so the check stays idempotent.
    return_shallow_explicit := false
    // #187 step 2: set true on FuncDefs emitted by initer's auto-gen
    // helpers (clone/delete/size/eq/to_str/variant constructors).
    // The unused-priv-member check skips field/ns reads inside these
    // bodies so genuinely-unused priv members don't get masked by
    // boilerplate references.
    auto_generated := false
    is_enum_variant_ctor := false
    // Issue #54: explicit capture list for closures, e.g.
    // `func(a: I64) returns I64 [scale] { ... }`. Each entry is a
    // Declaration carrying the captured name plus its modifier
    // (is_mut / own_type). Empty for ordinary (non-capturing) functions.
    captures := Vec(Declaration).new()
    // C backend name for the generated env-backed closure call function.
    // Empty until the typer assigns one to a capturing FuncDef.
    closure_name := ""
namespace:
    eq := func(a: FunctionDef, b: FunctionDef) returns Bool { return a.return_type == b.return_type }
    to_str := func(self: FunctionDef) returns Str { return self.return_type }
}

// --- FCall payload struct ---
/// Per-callsite data for function calls: parse-time flags (is_splat,
/// does_throw, is_bang), own_args bitmap, result type. The variadic
/// and kwargs block positions and counts are not stored -- they all
/// derive from the resolved callee's param layout plus the structural
/// markers in fcall.children:
///   - kwargs_count : trailing-NamedArg count (fcall_kwargs_count).
///   - kwargs_index : derived position via fcall_kwargs_index_via_scope.
///   - variadic_count : children layout + nparam + has-kwargs
///     (fcall_variadic_count).
///   - variadic_index : implicit at `1 + fdef_data.variadic_index`
///     post-desugar. Step 7 of #147 closes here: the trailing typer
///     resolution artifact is gone.
FCallData := struct {
    is_splat := false
    // Issue #198: parser sets this when the call is followed by ~?~,
    // marking it as a call to a throwing function. The typer
    // validates that does_throw matches the callee's throws set.
    does_throw := false
    // Issue #202: parser sets this when the call is followed by ~!~,
    // the "panic on throw" sugar. The typer desugars f(args)! into
    // f(args)? followed by an auto-injected catch (e: T) { panic } per
    // declared throw type, then clears the flag.
    is_bang := false
    own_args : U64 = 0
    swap_replace := false
    // Issue #206 slice 3: payload-resident result type. The typer
    // writes the resolved callee return type here via the
    // set_til_type method at FCall infer time, and
    // ~til_type~ reads it back via the chokepoint's FCall
    // dispatch case. Callees declared without a ~returns~ clause
    // resolve to ~Type.None~ -- common for callees written as
    // ~proc~, but not a func/proc distinction (per CLAUDE.md
    // "func vs proc is not Pascal", the only rule is "func cannot
    // call proc"; both kinds may or may not return a value).
    til_type := Type.Unknown
namespace:
    eq := func(_a: FCallData, _b: FCallData) returns Bool {
        return true
    }
    to_str := func(_self: FCallData) returns Str { return "FCall" }
}

LiteralNumData := struct {
    text := ""
    til_type := Type.Unknown
namespace:
    eq := func(a: LiteralNumData, b: LiteralNumData) returns Bool { return a.text == b.text }
    to_str := func(self: LiteralNumData) returns Str { return self.text }
    to_i64 := func(self: LiteralNumData) returns I64 { return self.text.to_i64() }
    to_u8 := func(self: LiteralNumData) returns U8 { return self.text.to_u8() }
    to_i8 := func(self: LiteralNumData) returns I8 { return self.text.to_i8() }
    to_i16 := func(self: LiteralNumData) returns I16 { return self.text.to_i16() }
    to_u16 := func(self: LiteralNumData) returns U16 { return self.text.to_u16() }
    to_i32 := func(self: LiteralNumData) returns I32 { return self.text.to_i32() }
    to_u32 := func(self: LiteralNumData) returns U32 { return self.text.to_u32() }
    to_u64 := func(self: LiteralNumData) returns U64 { return self.text.to_u64() }
    to_usize := func(self: LiteralNumData) returns USize { return self.text.to_usize() }
    to_f32 := func(self: LiteralNumData) returns F32 { return self.text.to_f32() }
    literal_num_text := func(self: LiteralNumData) returns Str { return self.text.clone() }
}

IdentData := struct {
    name := ""
    til_type := Type.Unknown
namespace:
    eq := func(a: IdentData, b: IdentData) returns Bool { return a.name == b.name }
    to_str := func(self: IdentData) returns Str { return self.name }
    len := func(self: IdentData) returns U32 { return self.name.len() }
    is_empty := func(self: IdentData) returns Bool { return self.name.is_empty() }
    starts_with := func(self: IdentData, prefix: Str) returns Bool { return self.name.starts_with(prefix) }
    ends_with := func(self: IdentData, suffix: Str) returns Bool { return self.name.ends_with(suffix) }
    replace := func(self: IdentData, old: Str, new: Str) returns Str { return self.name.replace(old, new) }
    strip_suffix := func(self: IdentData, suffix: Str) returns Str { return self.name.strip_suffix(suffix) }
    unsafe_get := func(self: IdentData, i: USize) returns ref I8 { return self.name.unsafe_get(i) }
    get := func(self: IdentData, i: USize) returns ref I8 { return self.name.get(i) }
    ident_name := func(self: IdentData) returns ref Str { return self.name }
}

FieldAccessData := struct {
    name := ""
    til_type := Type.Unknown
namespace:
    eq := func(a: FieldAccessData, b: FieldAccessData) returns Bool { return a.name == b.name }
    to_str := func(self: FieldAccessData) returns Str { return self.name }
    len := func(self: FieldAccessData) returns U32 { return self.name.len() }
    is_empty := func(self: FieldAccessData) returns Bool { return self.name.is_empty() }
    starts_with := func(self: FieldAccessData, prefix: Str) returns Bool { return self.name.starts_with(prefix) }
    replace := func(self: FieldAccessData, old: Str, new: Str) returns Str { return self.name.replace(old, new) }
    field_access_name := func(self: FieldAccessData) returns ref Str { return self.name }
}

/// Struct definition: field declarations, namespace methods, c_tag.
/// Issue #147 step 4: total_struct_size dropped from the AST in favour
/// of ctx.struct_layouts[name].total_size, populated by
/// compute_struct_layout at typer time.
StructDef : StructDef = struct {
    fields := Vec(Declaration).new()
    ns_decls := Vec(Declaration).new()
    c_tag := ""
    // Issue #251: set by parse_interface_def. The body desugars to this
    // StructDef (empty fields, ns_decls = methods); the typer uses the
    // flag to enforce the interface contract (members must be
    // ext_func/ext_proc abstract or func/proc concrete) as aggregatable
    // type errors.
    is_interface := false
    // Issue #251: set by parse_interface_def when a (redundant)
    // `namespace:` marker appears inside an interface body, so the typer
    // can reject it. An interface has no fields, so there is nothing to
    // separate methods from.
    interface_ns_marker := false
    // Issue #251: the interface name from `struct implements Iface { ... }`,
    // empty when the struct implements nothing. The typer verifies the
    // struct provides every abstract (ext_func/ext_proc) method of Iface
    // with a matching signature.
    implements_name := ""
namespace:
    eq := func(a: StructDef, b: StructDef) returns Bool {
        return a.fields.len() == b.fields.len()
    }
    to_str := func(_self: StructDef) returns Str { return "StructDef" }
}

/// Enum definition: variants, payload types, namespace methods.
/// Issue #147 step 4: total_enum_size dropped from the AST in favour
/// of ctx.struct_layouts[name].total_size, populated by
/// compute_enum_layout at typer time.
EnumDef : StructDef = struct {
    ns_decls := Vec(Declaration).new()
    variants := Vec(Str).new()
    payload_types : Map(I64, Str) = Map(I64, Str).new()
    // #211: per-variant flag (indexed by variant tag) marking variants
    // whose payload was declared `const Type`. Appended at the end of
    // the field list to minimise layout disturbance for til_boot.
    payload_consts := Vec(Bool).new()
    // Issue #251: the interface name from `enum implements Iface { ... }`,
    // empty when the enum implements nothing. Like StructDef.implements_name,
    // the typer verifies the enum provides every abstract (ext_func/ext_proc)
    // method of Iface with a matching signature. Enums carry methods in their
    // namespace just as structs do, so conformance checks identically.
    implements_name := ""
    // #264: discriminant (tag) type chosen via `enum(Type) { ... }`.
    // Empty means unspecified, which defaults to U32 (the historical
    // C-`enum`-backed width). Appended at the end to minimise layout
    // disturbance for til_boot.
    tag_type := ""
    // Explicit per-variant tag values (`enum { A = 5 }`), dense and parallel
    // to `variants`. Empty when the def came from FFI introspection
    // (enum_def_of) -- readers fall back to the variant index. Appended at
    // the end to minimise layout disturbance for til_boot.
    tag_values := Vec(I64).new()
namespace:
    eq := func(a: EnumDef, b: EnumDef) returns Bool {
        return a.variants.len() == b.variants.len()
    }
    to_str := func(_self: EnumDef) returns Str { return "EnumDef" }
}

// Issue #147 step 3: per-field and whole-type memory layout. Destined to
// live in Context.struct_layouts keyed by type name, replacing the layout
// facts currently stored on AST nodes (Declaration.field_offset /
// field_size / field_struct_def, StructDef.total_struct_size,
// EnumDef.total_enum_size). This commit populates the map alongside those
// fields; readers migrate to the map in step 4, after which the AST fields
// can be removed. struct_name is the field's struct/enum type name (""
// for primitives / Dynamic / FuncPtr) so lookups go by name rather than a
// dangling ref into the parse tree.
FieldLayout := struct {
    offset : USize = 0
    size : USize = 0
    struct_name := ""
    // #286: per-field info the cache-driven deep free / clone read instead of
    // the dangling AST struct_def. own_type distinguishes own-pointer fields
    // from inline; is_str marks a Str field (free its c_str); is_enum marks an
    // enum-typed field (struct_name names an enum, not a struct).
    own_type := OwnType.Shallow
    is_str := false
    is_enum := false
    is_funcptr := false
namespace:
    eq := func(a: FieldLayout, b: FieldLayout) returns Bool {
        return a.offset.eq(b.offset).and(a.size.eq(b.size)).and(a.struct_name.eq(b.struct_name))
    }
    to_str := func(self: FieldLayout) returns Str { return self.offset.to_str() }
}

// Whole-type layout. For enums only total_size is meaningful (fields stays
// empty); the per-variant payload sizing lives in EnumDef.payload_types.
StructLayout := struct {
    total_size : USize = 0
    align : USize = 1
    fields := Vec(FieldLayout).new()
namespace:
    eq := func(a: StructLayout, b: StructLayout) returns Bool {
        return a.total_size.eq(b.total_size).and(a.align.eq(b.align))
    }
    to_str := func(self: StructLayout) returns Str { return self.total_size.to_str() }
}

// --- NodeType payload enum (25 variants) ---

/// Payload for assignment nodes: which name is being assigned to.
AssignData := struct {
    name := ""
    save_old_delete := false
    is_payload_alias := false
    swap_replace := false
namespace:
    eq := func(a: AssignData, b: AssignData) returns Bool { return a.name == b.name }
    to_str := func(self: AssignData) returns Str { return self.name }
}

FieldAssignData := struct {
    name := ""
    save_old_delete := false
namespace:
    eq := func(a: FieldAssignData, b: FieldAssignData) returns Bool { return a.name == b.name }
    to_str := func(self: FieldAssignData) returns Str { return self.name }
}

/// Payload for `for name in range` loop nodes. The two-variable
/// key/value form `for k, v in map` fills name2/is_mut2; name2 is
/// empty for the ordinary single-variable form.
ForInData := struct {
    name := ""
    is_mut := false
    til_type := Type.Unknown
    name2 := ""
    is_mut2 := false
namespace:
    eq := func(a: ForInData, b: ForInData) returns Bool { return a.name == b.name }
    to_str := func(self: ForInData) returns Str { return self.name }
}

/// Literal (constant) node kinds: the leaf values written directly in
/// source. Grouped under NodeType.Literal so "is this any literal?"
/// is a single check (NodeType.Literal) instead of a four-way chain.
Literal := enum {
    Str: Str,
    Num: LiteralNumData,
    Bool: Bool,
    Null,
    MapLit,
    SetLit,
}

/// Payload for NodeType.Match: a `match` expression yields a value, so
/// the typer records the common arm type here (mirrors FCallData.til_type).
MatchData := struct {
    til_type := Type.Unknown
    // Name of the result temp the lowering declares; set when a match is
    // spliced as a statement so the shared switch desugar (infer_switch_stmt)
    // knows what to assign each arm's value to. Empty on a bare/user match.
    result_temp := ""
namespace:
    eq := func(a: MatchData, b: MatchData) returns Bool { return a.til_type == b.til_type }
    to_str := func(_self: MatchData) returns Str { return "" }
}

/// Payload for NodeType.CaptureBlock (issue #54): a bare `[a, mut b] { ... }`
/// block carrying an explicit capture list. The captures restrict which
/// outer-scope locals the block body may reference -- a compile-time
/// "insurance policy". Each capture is a Declaration (name + is_mut);
/// the block stays inline at runtime, so the only effect is the typer's
/// scope-restriction check. Child 0 is the Body.
CaptureBlockData := struct {
    captures := Vec(Declaration).new()
    closure_name := ""
namespace:
    eq := func(a: CaptureBlockData, b: CaptureBlockData) returns Bool {
        return a.captures.len() == b.captures.len()
    }
    to_str := func(_self: CaptureBlockData) returns Str { return "CaptureBlock" }
}

/// AST node kind. Each variant carries an optional payload (struct, string, bool).
NodeType := enum {
    Body,
    Literal: Literal,
    Ident: IdentData,
    Decl: Declaration,
    Assign: AssignData,
    FCall: FCallData,
    FuncDef: FunctionDef,
    StructDef: StructDef,
    EnumDef: EnumDef,
    FieldAccess: FieldAccessData,
    FieldAssign: FieldAssignData,
    Return,
    If,
    While,
    ForIn: ForInData,
    NamedArg: Str,
    Break,
    Continue,
    Switch,
    // Issue #244: `match` is the expression form of `switch`. Same arm
    // shape as Switch ([subject, Case...]), but each Case body is a
    // single value-expression and the whole node yields a value (the
    // common arm type, stored in MatchData). The typer lowers a Match to
    // a result temp + a synthetic Switch that assigns each arm's value.
    Match: MatchData,
    Case,
    NoDefaultArg,
    // Issue #198: error handling. Throw has 1 child (the thrown
    // expression). Catch has 3 children: Ident (var name), Ident
    // (caught type), Body. The typer validates and then lowers
    // both away to plain til (mut locals + if), so no downstream
    // stage ever evaluates them.
    Throw,
    Catch,
    // Issue #36: rest-pattern marker for struct field matching.
    // `case Point(x = 0, ..):` parses the `..` token into this node
    // and stores it as a child of the FCall pattern. The typer reads
    // its presence to allow missing-field cases and rejects patterns
    // that omit fields without the marker.
    RestPattern,
    // Issue #54: bare capture block `[a, mut b] { ... }`. Child 0 is the
    // Body; the payload holds the capture list. The typer restricts the
    // body's visible outer locals to the captured names; downstream
    // stages treat it as the inline block it wraps.
    CaptureBlock: CaptureBlockData,
    // Issue #281: post-parse sentinel for `__LOC__`. The parser emits this
    // instead of expanding __LOC__ to a Str at parse time, so resolution is
    // deferred to the typer. At a DIRECT use site infer_expr resolves it to
    // the node's own line/col + ctx.path (same as the old parse-time __LOC__).
    // As a parameter/field DEFAULT it is left for the default-fill, which
    // stamps the CALL SITE's coords (resolve_default_value) -- so a defaulted
    // `loc: Str = __LOC__` reports the caller, the C++ source_location model.
    // It never reaches the interpreter or C backend: it is always rewritten to
    // a Literal.Str first. Appended at the end of the enum so existing variant
    // tags stay stable for bootstrapping.
    Loc,
    // Issue #55: Body literal used as a value. Child 0 is the executable
    // Body; captures carry the same explicit list as closures. Appended after
    // Loc so existing NodeType tags stay stable.
    BodyValue: CaptureBlockData,
    // Issue #262: compile-time list pattern in a match case head, used by the
    // recursive form of variadic lazy callables (vand/vor):
    //   case []:        -> zero children (the empty-operands base case)
    //   case [x, ..tl]: -> two children, Ident(x) and Ident(tl) (head/tail)
    // Only legal on the variadic param of a recursive variadic lazy body; the
    // loader's recursion-unroll consumes it before typing, and the typer
    // rejects any ListPattern that survives to it. Appended after BodyValue
    // so existing NodeType tags stay stable.
    ListPattern,
namespace:
    // is() compares only the outer enum tag, so is(NodeType.Literal(Literal.X))
    // cannot tell the literal kinds apart -- it matches any Literal. These
    // switch-based predicates discriminate the inner Literal variant. Use
    // node_type.is(NodeType.Literal) directly when "any literal" is wanted.
    is_literal_str := func(self: NodeType) returns Bool {
        switch self { case NodeType.Literal(Literal.Str): return true case: return false }
    }
    is_literal_num := func(self: NodeType) returns Bool {
        switch self { case NodeType.Literal(Literal.Num): return true case: return false }
    }
    is_literal_bool := func(self: NodeType) returns Bool {
        switch self { case NodeType.Literal(Literal.Bool): return true case: return false }
    }
    is_literal_null := func(self: NodeType) returns Bool {
        switch self { case NodeType.Literal(Literal.Null): return true case: return false }
    }
    is_map_lit := func(self: NodeType) returns Bool {
        switch self { case NodeType.Literal(Literal.MapLit): return true case: return false }
    }
    is_set_lit := func(self: NodeType) returns Bool {
        switch self { case NodeType.Literal(Literal.SetLit): return true case: return false }
    }
    // Any literal except Null: the str/num/bool constants. Hoisting and
    // redundant-clone checks treat these as inlinable values while Null
    // needs separate handling.
    is_nonnull_literal := func(self: NodeType) returns Bool {
        switch self {
        case NodeType.Literal(Literal.Str):  return true
        case NodeType.Literal(Literal.Num):  return true
        case NodeType.Literal(Literal.Bool): return true
        case: return false
        }
    }
    // Head string used inside the parentheses by Expr.to_str: the NodeType's
    // variant name plus any inline payload (identifier, literal text, decl
    // name, etc.). Names are kept as written in the enum (no case conversion).
    head_str := func(self: NodeType) returns Str {
        switch self {
        case NodeType.Body:           return "Body"
        case NodeType.Literal(Literal.Str(s)):  return format("LiteralStr \"", s, "\"")
        case NodeType.Literal(Literal.Num(s)):  return format("LiteralNum ", s.literal_num_text())
        case NodeType.Literal(Literal.Bool(b)):
            if b { return "LiteralBool true" }
            return "LiteralBool false"
        case NodeType.Literal(Literal.Null):    return "LiteralNull"
        case NodeType.Ident(s):       return format("Ident ", Str.clone(s.ident_name()))
        case NodeType.Decl(d):
            if d.is_mut { return format("Decl mut ", d.name) }
            return format("Decl ", d.name)
        case NodeType.Assign(a):      return format("Assign ", a.name)
        case NodeType.FCall:          return "FCall"
        case NodeType.FuncDef(f):     return format("FuncDef ", f.func_type.variant_name())
        case NodeType.StructDef:      return "StructDef"
        case NodeType.EnumDef:        return "EnumDef"
        case NodeType.FieldAccess(s): return format("FieldAccess ", Str.clone(s.field_access_name()))
        case NodeType.FieldAssign(fad): return format("FieldAssign ", fad.name)
        case NodeType.Return:         return "Return"
        case NodeType.If:             return "If"
        case NodeType.While:          return "While"
        case NodeType.ForIn(fi):
            mut head := "ForIn "
            if fi.is_mut { head = "ForIn mut " }
            if fi.name2.len() > 0 {
                mut tail := format(", ", fi.name2)
                if fi.is_mut2 { tail = format(", mut ", fi.name2) }
                return format(head, fi.name, tail)
            }
            return format(head, fi.name)
        case NodeType.NamedArg(s):    return format("NamedArg ", s)
        case NodeType.Break:          return "Break"
        case NodeType.Continue:       return "Continue"
        case NodeType.Literal(Literal.MapLit):         return "MapLit"
        case NodeType.Literal(Literal.SetLit):         return "SetLit"
        case NodeType.Switch:         return "Switch"
        case NodeType.Match:          return "Match"
        case NodeType.Case:           return "Case"
        case NodeType.NoDefaultArg:   return "NoDefaultArg"
        case NodeType.Loc:            return "Loc"
        case NodeType.Throw:          return "Throw"
        case NodeType.Catch:          return "Catch"
        case NodeType.CaptureBlock:   return "CaptureBlock"
        case NodeType.BodyValue:      return "BodyValue"
        case: return "?"
        }
    }
}

// --- Expr struct ---

/// AST expression node with line/col, type, children, and node-specific payload.
Expr := struct {
    node_type := NodeType.Body
    children := Vec(Expr).new()
    line : U32 = 0
    col : U32 = 0

namespace:
    /// Null-safe delete. The auto-generated version dereferences `self`
    /// unconditionally, so the asap pass deleting an owned-but-null Expr
    /// (e.g. a fold helper that returns NULL on failure) SEGVs. Guarding
    /// here lets functions return owned `Expr` that may be null without
    /// the caller having to clone-and-leak to dodge the deep delete.
    delete := func(own self: Expr, call_free: Bool = true) {
        if self.is_null() { return }
        NodeType.delete(own self.node_type, false)
        self.children.clear()
        free(own self.children.data)
        if call_free { free(own self) }
    }
    /// Print a diagnostic error with file path and source location.
    error := proc(self: Expr, path: Str, msg: Str) {
        println(path, ":", self.line.to_str(), ":", self.col.to_str(), ": error: ", msg)
    }
    /// Like error() but adds "not implemented yet" note.
    todo_error := proc(self: Expr, path: Str, msg: Str) {
        self.error(path, msg)
        println("  note: this language feature is not implemented yet")
    }
    /// Like error() but adds "bug in the language" note.
    lang_error := proc(self: Expr, path: Str, msg: Str) {
        self.error(path, msg)
        println("  note: this is a bug in the language, please report it")
    }
    /// Take ownership of `child` and append it to the children list.
    add_child := func(mut self: Expr, own child: Expr) {
        self.children.push(own child)
    }
    /// Clone `child` and append the clone to the children list.
    push_child_clone := func(mut self: Expr, child: Expr) {
        self.children.push(own child.clone())
    }
    /// Append other's children into self via raw memcpy (no cloning).
    /// Zeroes other's count so it no longer owns the moved items.
    take_children := func(mut self: Expr, mut other: Expr) {
        if other.children.count == 0 { return }
        needed := self.children.count + other.children.count
        if needed > self.children.cap {
            mut new_cap := self.children.cap
            while needed > new_cap {
                new_cap = new_cap * 2
            }
            self.children.data = realloc(own self.children.data, new_cap.mul(Expr.size()))
            self.children.cap = new_cap
        }
        memcpy(ptr_add(self.children.data, self.children.count.mul(Expr.size())),
            other.children.data, other.children.count.mul(Expr.size()))
        self.children.count = needed
        other.children.count = 0
        // Free other's source buffer before nulling: the bytes were
        // memcpy'd into self, but other's malloc'd buffer would leak.
        free(own other.children.data)
        other.children.data = NULL
    }
    /// Create a new Expr with the given node_type and source location.
    new := func(data: NodeType, line: U32, col: U32) returns Expr {
        return Expr(node_type = data.clone(), line = line, col = col)
    }
    eq := func(_self: Expr, _other: Expr) returns Bool {
        TODO("Expr.eq")
        return false
    }
    til_type := func(self: Expr) returns Type {
        switch self.node_type {
        case NodeType.Body:        return Type.None
        case NodeType.Literal(Literal.Str):  return Type.Struct("Str")
        case NodeType.Literal(Literal.Num(nd)):
            if nd.til_type.is(Type.Unknown) { return Type.Primitive(Primitive.I64) }
            return nd.til_type.clone()
        case NodeType.Literal(Literal.Bool): return Type.Primitive(Primitive.Bool)
        case NodeType.Literal(Literal.Null): return Type.Dynamic
        case NodeType.Ident(id):   return id.til_type.clone()
        case NodeType.Decl(dd):    return dd.til_type.clone()
        case NodeType.Assign:
            if self.children.len() == 0 { return Type.Unknown }
            return self.children[0].til_type()
        case NodeType.Literal(Literal.MapLit):      return Type.Struct("Map")
        case NodeType.Literal(Literal.SetLit):      return Type.Struct("Set")
        case NodeType.NamedArg:
            if self.children.len() == 0 { return Type.Unknown }
            return self.children[0].til_type()
        case NodeType.FCall(fcd):  return fcd.til_type.clone()
        case NodeType.FuncDef:     return Type.FuncPtr
        case NodeType.BodyValue:   return Type.Body
        case NodeType.StructDef:   return Type.Struct("StructDef")
        case NodeType.EnumDef:     return Type.Struct("EnumDef")
        case NodeType.FieldAccess(fd): return fd.til_type.clone()
        case NodeType.FieldAssign: return Type.None
        case NodeType.Return:
            if self.children.len() == 0 { return Type.None }
            return self.children[0].til_type()
        case NodeType.If:          return Type.None
        case NodeType.While:       return Type.None
        case NodeType.ForIn(fd):   return fd.til_type.clone()
        case NodeType.Break:       return Type.None
        case NodeType.Continue:    return Type.None
        case NodeType.Switch:      return Type.None
        case NodeType.Match(md):   return md.til_type.clone()
        case NodeType.Case:        return Type.None
        case NodeType.NoDefaultArg:return Type.Unknown
        // Issue #281: the __LOC__ sentinel stands in for a Str location literal
        // until infer_expr / the default-fill resolves it, so it types as Str.
        case NodeType.Loc:         return Type.Struct("Str")
        case NodeType.Throw:
            if self.children.len() == 0 { return Type.None }
            return self.children[0].til_type()
        case NodeType.Catch:       return Type.None
        case NodeType.RestPattern: return Type.Unknown
        case NodeType.ListPattern: return Type.Unknown
        case NodeType.CaptureBlock: return Type.None
        }
        return Type.Unknown
    }
    set_til_type := func(mut self: Expr, shallow t: Type) {
        switch self.node_type {
        case NodeType.Literal(Literal.Num(nd)):
            nd.til_type = t
        case NodeType.Ident(id):
            id.til_type = t
        case NodeType.Decl(dd):
            dd.til_type = t
        case NodeType.FCall(fcd):
            fcd.til_type = t
        case NodeType.FieldAccess(fd):
            fd.til_type = t
        case NodeType.ForIn(fd):
            fd.til_type = t
        case NodeType.Match(md):
            md.til_type = t
        case NodeType.Throw:
            if self.children.len() > 0 {
                self.children[0].set_til_type(t)
            }
        case:
        }
    }
    // Backing implementation for to_str. Produces format B-hybrid:
    //   leaf (no children):        (Head)
    //   with children:             ((Head)\n  c1\n  c2 ...)
    // where Head = NodeType variant name + inline payload (see
    // NodeType.head_str).
    to_str_indent := func(self: Expr, indent: U32) returns Str {
        mut out := ""
        for _ in 0..indent {
            out = format(out, "  ")
        }
        head := self.node_type.head_str()
        if self.children.len() == 0 {
            return format(out, "(", head, ")")
        }
        out = format(out, "((", head, ")")
        for c : Expr in self.children {
            out = format(out, "\n", c.to_str_indent(indent + 1))
        }
        return format(out, ")")
    }
    to_str := func(self: Expr) returns Str {
        return self.to_str_indent(0)
    }
}

