mode lib

import("bool")
import("dyn")
import("f32")
import("i32")
import("i64")
import("i8")
import("u8")
import("vec")

CAP_LIT : USize = -1.to_usize()
CAP_VIEW : USize = -2.to_usize()

/// Concatenate multiple strings into one.
format := func(parts: ..Str) returns Str {
    mut total : USize = 0
    for s : Str in parts {
        total = total.add(s.len())
    }
    mut out := Str.with_capacity(total)
    for s : Str in parts {
        out.push_str(s)
    }
    return out
}

/// UTF-8 string with owned heap storage. The byte buffer is typed as
/// I8 (= C `char`) so direct FFI bindings against `const char *` APIs
/// can pass `s.c_str` without an intermediate pointer-cast helper.
Str := struct {
    own c_str : I8 = 0
    count : USize = 0
    cap : USize = 0

namespace:
    len := func(self: Str) returns shallow USize { return self.count }

    /// Return a ref to byte `i`. Panics if `i` is out of bounds.
    get := func(self: Str, i: USize) returns ref I8 {
        if i.gte(self.count) {
            panic(__LOC__, "Str.get: index out of bounds")
        }
        return ptr_add(self.c_str, i)
    }

    /// Unchecked byte access -- caller must ensure i < self.len().
    byte_at := func(self: Str, i: USize) returns ref I8 {
        return ptr_add(self.c_str, i)
    }

    /// Lexicographic comparison. Returns 0 if equal, negative if a < b,
    /// positive if a > b.
    cmp := func(a: Str, b: Str) returns shallow I64 {
        mut min_len := a.count
        if b.count.lt(a.count) { min_len = b.count }
        for i in 0..min_len {
            ref ab : I8 = a.get(i)
            ref bb : I8 = b.get(i)
            c := ab.cmp(bb)
            if c.neq(0) { return c }
        }
        return a.count.cmp(b.count)
    }

    /// Return a new Str with the contents of `a` followed by `b`.
    concat := func(a: Str, b: Str) returns Str {
        mut out := Str.with_capacity(a.count.add(b.count))
        out.push_str(a)
        out.push_str(b)
        return out
    }

    /// Create an empty Str pre-allocated for up to `n` bytes.
    with_capacity := func(n: USize) returns Str {
        buf : Dynamic = malloc(n.add(1))
        memset(buf, 0, 1)
        return Str(c_str = buf, count = 0, cap = n)
    }

    /// Wrap a NUL-terminated C string as a non-owning Str view (no copy).
    /// The view borrows `s`; the caller keeps ownership of the buffer.
    from_c_str := func(s: Dynamic) returns Str {
        return Str(c_str = s, count = c_str_len(s), cap = CAP_VIEW)
    }

    /// Append `s` to `self`. Panics if `self` is a view/literal or if
    /// capacity is exceeded.
    push_str := func(mut self: Str, s: Str) {
        if self.cap.gte(CAP_VIEW) {
            panic(__LOC__, "Str.push_str: cannot mutate a string view or literal")
        }
        new_len := self.count.add(s.count)
        if new_len.gt(self.cap) {
            panic(__LOC__, "Str.push_str: capacity exceeded")
        }
        memcpy(ptr_add(self.c_str, self.count), s.c_str, s.count)
        self.count = new_len
        memset(ptr_add(self.c_str, new_len), 0, 1)
    }

    /// Deep-copy the string into a new owned Str.
    clone := func(val: Str) returns Str {
        new_data : Dynamic = malloc(val.count.add(1))
        memcpy(new_data, val.c_str, val.count)
        memset(ptr_add(new_data, val.count), 0, 1)
        return Str(c_str = new_data, count = val.count, cap = val.count)
    }

    /// Free the backing buffer (unless it's a view/literal) and optionally
    /// the struct allocation.
    delete := func(own self: Str, call_free: Bool = true) {
        if self.cap.lt(CAP_VIEW) { free(own self.c_str) }
        if call_free { free(own self) }
    }

    /// Return a view into `s` from `start` for `n` bytes (no allocation).
    /// Clamps to valid bounds.
    substr := func(s: Str, start: USize, n: USize) returns Str {
        mut st := start
        mut ln := n
        if st.gt(s.count) { st = s.count }
        if st.add(ln).gt(s.count) { ln = s.count.sub(st) }
        return Str(c_str = ptr_add(s.c_str, st), count = ln, cap = CAP_VIEW)
    }

    /// Return a view of `s` with leading ASCII whitespace (space, tab,
    /// newline, carriage return) removed. View-only -- no allocation.
    trim_start := func(s: Str) returns Str {
        mut st : USize = 0
        while st.lt(s.count) {
            ref c : I8 = s.byte_at(st)
            if c.eq(' ').or(c.eq('\t')).or(c.eq('\n')).or(c.eq('\r')) {
                st = st.add(1)
            } else {
                break
            }
        }
        return s.substr(st, s.count.sub(st))
    }

    /// Return a view of `s` with leading and trailing ASCII whitespace
    /// removed. View-only -- no allocation.
    trim := func(s: Str) returns Str {
        mut st : USize = 0
        while st.lt(s.count) {
            ref c : I8 = s.byte_at(st)
            if c.eq(' ').or(c.eq('\t')).or(c.eq('\n')).or(c.eq('\r')) {
                st = st.add(1)
            } else {
                break
            }
        }
        mut en := s.count
        while en.gt(st) {
            ref c : I8 = s.byte_at(en.sub(1))
            if c.eq(' ').or(c.eq('\t')).or(c.eq('\n')).or(c.eq('\r')) {
                en = en.sub(1)
            } else {
                break
            }
        }
        return s.substr(st, en.sub(st))
    }

    /// True if `a` contains `b` as a substring.
    contains := func(a: Str, b: Str) returns shallow Bool {
        if b.count.eq(0) { return true }
        if b.count.gt(a.count) { return false }
        for i in 0..a.count.sub(b.count).add(1) {
            mut found := true
            for j in 0..b.count {
                ref ac : I8 = a.get(i.add(j))
                ref bc : I8 = b.get(j)
                if ac.neq(bc) { found = false }
            }
            if found { return true }
        }
        return false
    }

    /// True if `a` starts with prefix `b`.
    starts_with := func(a: Str, b: Str) returns shallow Bool {
        if b.count.gt(a.count) { return false }
        for i in 0..b.count {
            ref ac : I8 = a.get(i)
            ref bc : I8 = b.get(i)
            if ac.neq(bc) { return false }
        }
        return true
    }

    /// True if `a` ends with suffix `b`.
    ends_with := func(a: Str, b: Str) returns shallow Bool {
        if b.count.gt(a.count) { return false }
        offset := a.count.sub(b.count)
        for i in 0..b.count {
            ref ac : I8 = a.get(offset.add(i))
            ref bc : I8 = b.get(i)
            if ac.neq(bc) { return false }
        }
        return true
    }

    /// True if the string has zero length.
    is_empty := func(self: Str) returns shallow Bool {
        return self.count.eq(0)
    }

    /// Return the byte index of the first occurrence of `needle`, or -1.
    find := func(self: Str, needle: Str) returns shallow I64 {
        if needle.count.eq(0) { return -1 }
        if needle.count.gt(self.count) { return -1 }
        for i in 0..self.count.sub(needle.count).add(1) {
            mut found := true
            for j in 0..needle.count {
                ref ac : I8 = self.get(i.add(j))
                ref bc : I8 = needle.get(j)
                if ac.neq(bc) { found = false }
            }
            if found { return i.to_i64() }
        }
        return -1
    }

    /// Return the byte index of the last occurrence of `needle`, or -1.
    rfind := func(self: Str, needle: Str) returns shallow I64 {
        if needle.count.eq(0) { return -1 }
        if needle.count.gt(self.count) { return -1 }
        mut last := -1
        for i in 0..self.count.sub(needle.count).add(1) {
            mut found := true
            for j in 0..needle.count {
                ref ac : I8 = self.get(i.add(j))
                ref bc : I8 = needle.get(j)
                if ac.neq(bc) { found = false }
            }
            if found { last = i.to_i64() }
        }
        return last
    }

    /// Return a new Str with all occurrences of `from` replaced by `to`.
    replace := func(self: Str, from: Str, to: Str) returns Str {
        if from.count.eq(0) { return self.clone() }
        mut matches : USize = 0
        mut start : USize = 0
        while start.lte(self.count.sub(from.count)) {
            rest := self.substr(start, self.count.sub(start))
            pos := rest.find(from)
            if pos.eq(-1) {
                break
            }
            pos_u : USize = pos.to_usize()
            start = start.add(pos_u).add(from.count)
            matches = matches.add(1)
        }
        if matches.eq(0) { return self.clone() }
        removed := matches.mul(from.count)
        added := matches.mul(to.count)
        mut out := Str.with_capacity(self.count.sub(removed).add(added))
        start = 0
        while start.lte(self.count.sub(from.count)) {
            rest := self.substr(start, self.count.sub(start))
            pos := rest.find(from)
            if pos.eq(-1) {
                break
            }
            pos_u : USize = pos.to_usize()
            out.push_str(self.substr(start, pos_u))
            out.push_str(to)
            start = start.add(pos_u).add(from.count)
        }
        if start.lt(self.count) {
            out.push_str(self.substr(start, self.count.sub(start)))
        }
        return out
    }

    /// View of the single byte at index `i` as a Str.
    get_char := func(self: Str, i: USize) returns Str {
        return self.substr(i, 1)
    }

    /// Hash via the caller-supplied byte hasher, feeding it the
    /// string CONTENT bytes (c_str + count). The default bytewise
    /// fallback would hash the {c_str, count, cap} struct itself --
    /// i.e. the heap pointer's address -- which is identity, not
    /// equality. The container chooses the algorithm; this method
    /// chooses the right bytes for a Str.
    hash := func(self: Str, hasher: HashFn) returns U64 {
        return hasher(self.c_str, self.count)
    }

    /// If self starts with `prefix`, return the rest; otherwise clone.
    strip_prefix := func(self: Str, prefix: Str) returns Str {
        if self.starts_with(prefix) {
            return self.substr(prefix.count, self.count.sub(prefix.count))
        }
        return self.clone()
    }

    /// If self ends with `suffix`, return the part before it; otherwise clone.
    strip_suffix := func(self: Str, suffix: Str) returns Str {
        if self.ends_with(suffix) {
            return self.substr(0, self.count.sub(suffix.count))
        }
        return self.clone()
    }

    /// Create a 1-byte Str from a U8 value.
    from_byte := func(byte: U8) returns Str {
        buf : Dynamic = malloc(2)
        memcpy(buf, byte, 1)
        memset(ptr_add(buf, 1), 0, 1)
        return Str(c_str = buf, count = 1, cap = 1)
    }

    /// Parse the string as a base-10 signed integer. Panics on invalid input.
    to_i64 := func(self: Str) returns shallow I64 {
        if self.count.eq(0) { panic(__LOC__, "Str.to_i64: empty string") }
        mut result := 0
        mut start : USize = 0
        mut neg := false
        ref first : I8 = self.get(0)
        if first.eq(45) {
            neg = true
            start = 1
        }
        if start.eq(self.count) { panic(__LOC__, "Str.to_i64: no digits") }
        for i in start..self.count {
            ref ch : I8 = self.get(i)
            d := ch.cast(I64).sub(48)
            if d.lt(0).or(d.gt(9)) {
                panic(__LOC__, "Str.to_i64: invalid char in '", self, "'")
            }
            result = result.mul(10).add(d)
        }
        if neg { return 0.sub(result) }
        return result
    }

    /// Parse as base-10 unsigned 8-bit integer.
    to_u8 := func(self: Str) returns shallow U8 {
        return self.to_i64().to_u8()
    }

    /// Parse as base-10 signed 32-bit integer.
    to_i32 := func(self: Str) returns shallow I32 {
        return self.to_i64().to_i32()
    }

    /// Parse as base-10 unsigned 32-bit integer.
    to_u32 := func(self: Str) returns shallow U32 {
        return self.to_i64().to_u32()
    }

    /// Parse as base-10 unsigned 64-bit integer.
    to_u64 := func(self: Str) returns shallow U64 {
        return self.to_i64().cast(U64)
    }

    /// Parse as base-10 USize (collection sizes/indices).
    to_usize := func(self: Str) returns shallow USize {
        return self.to_i64().to_usize()
    }

    /// Parse as a floating-point number. Backed by C strtof: handles
    /// decimal and scientific notation at full precision, so a value
    /// printed by F32.to_repr round-trips exactly back to the same F32.
    to_f32 := func(self: Str) returns shallow F32 {
        return str_parse_f32(self)
    }

    /// Split the string on `delim`, returning a Vec of Str clones.
    split := func(self: Str, delim: Str) returns Vec {
        parts := Vec.new(Str)
        if delim.len().eq(0) {
            parts.push(own self.clone())
            return parts
        }
        mut start : USize = 0
        mut pos : USize = 0
        while pos.lte(self.len().sub(delim.len())) {
            if self.substr(pos, delim.len()).eq(delim) {
                parts.push(own self.substr(start, pos.sub(start)).clone())
                start = pos.add(delim.len())
                pos = start
            } else {
                pos = pos.add(1)
            }
        }
        parts.push(own self.substr(start, self.len().sub(start)).clone())
        return parts
    }
}

join := func(parts: Vec, sep: Str) returns Str {
    if parts.len().eq(0) { return "" }
    mut total : USize = 0
    for p : Str in parts {
        total = total.add(p.len())
    }
    total = total.add(sep.len().mul(parts.len().sub(1)))
    mut out := Str.with_capacity(total)
    for i in 0..parts.len() {
        if i.gt(0) { out.push_str(sep) }
        ref p : Str = parts[i]
        out.push_str(p)
    }
    return out
}

// c-string length (strlen).  Can't bind libc's strlen directly: til's
// generated C #includes <string.h>, so libc's `size_t strlen(const
// char *)` is in scope and an ext_func declaration clashes on the
// return type (USize is U32, size_t is unsigned long).  The byte loop
// sidesteps that and keeps the C primitive surface free of the
// typedef-bridge wrapper.
// Faithful float parse (C strtof). Top-level so the interpreter's dispatch
// handler can reach it; Str.to_f32 delegates here.
str_parse_f32 := ext_func(s: Str) returns shallow F32 {}

c_str_len := func(s: Dynamic) returns shallow USize {
    mut n : USize = 0
    while true {
        ref b : I8 = ptr_add(s, n)
        if b.eq(0) { return n }
        n = n.add(1)
    }
    return n
}

/// Error thrown by the indexed collection accessors (Array.get,
/// Vec.get, ...) when the index is past the end. The msg field
/// carries a "file:line:col:<method>: index N out of bounds (len M)"
/// description set at the throw site.
OutOfBounds := struct {
    msg: Str = ""
}
