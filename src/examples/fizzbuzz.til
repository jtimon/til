mode script

mut i := 1
while lte(i, 100) {
    if eq(mod(i, 15), 0) {
        println("FizzBuzz")
    } else {
        if eq(mod(i, 3), 0) {
            println("Fizz")
        } else {
            if eq(mod(i, 5), 0) {
                println("Buzz")
            } else {
                println(to_str(i))
            }
        }
    }
    i = add(i, 1)
}
