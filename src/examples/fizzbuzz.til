mode script

mut i := 1
while i.lte(100) {
    if i.mod(15).eq(0) {
        println("FizzBuzz")
    } else {
        if i.mod(3).eq(0) {
            println("Fizz")
        } else {
            if i.mod(5).eq(0) {
                println("Buzz")
            } else {
                println(i.to_str())
            }
        }
    }
    i = i.add(1)
}
