/* Functions defined as 'extern' by default (implicit specifiers)*/ 
ChangeDirectory := ext_proc(dirPath : I8) returns shallow Bool {}
/* Functions defined as 'extern' by default (implicit specifiers)*/ 
IsPathFile := ext_proc(path : I8) returns shallow Bool {}
/* Functions defined as 'extern' by default (implicit specifiers)*/ 
IsFileNameValid := ext_func(fileName : I8) returns shallow Bool {}
LoadDirectoryFiles := ext_proc(dirPath : I8) returns shallow FilePathList {}
LoadDirectoryFilesEx := ext_proc(basePath : I8, filter : I8, shallow scanSubdirs : Bool) returns shallow FilePathList {}
UnloadDirectoryFiles := ext_proc(shallow files : FilePathList) {}
/* Functions defined as 'extern' by default (implicit specifiers)*/ 
IsFileDropped := ext_proc() returns shallow Bool {}
