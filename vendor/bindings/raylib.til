GetFileNameWithoutExt := ext_func(filePath : I8) returns ref I8 {}
GetDirectoryPath := ext_func(filePath : I8) returns ref I8 {}
GetPrevDirectoryPath := ext_func(dirPath : I8) returns ref I8 {}
