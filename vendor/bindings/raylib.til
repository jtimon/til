SetWindowMinSize := ext_proc(shallow width : I32, shallow height : I32) {}
SetWindowMaxSize := ext_proc(shallow width : I32, shallow height : I32) {}
SetWindowSize := ext_proc(shallow width : I32, shallow height : I32) {}
SetWindowOpacity := ext_proc(shallow opacity : F32) {}
SetWindowFocused := ext_proc() {}
GetWindowHandle := ext_proc() returns Dynamic {}
// ext_proc: depends on current window dimensions.
GetScreenWidth := ext_proc() returns shallow I32 {}
GetScreenHeight := ext_proc() returns shallow I32 {}
GetRenderWidth := ext_proc() returns shallow I32 {}
GetRenderHeight := ext_proc() returns shallow I32 {}
GetMonitorCount := ext_proc() returns shallow I32 {}
GetCurrentMonitor := ext_proc() returns shallow I32 {}
GetMonitorPosition := ext_proc(shallow monitor : I32) returns shallow Vector2 {}
GetMonitorWidth := ext_proc(shallow monitor : I32) returns shallow I32 {}
GetMonitorHeight := ext_proc(shallow monitor : I32) returns shallow I32 {}
GetMonitorPhysicalWidth := ext_proc(shallow monitor : I32) returns shallow I32 {}
GetMonitorPhysicalHeight := ext_proc(shallow monitor : I32) returns shallow I32 {}
GetMonitorRefreshRate := ext_proc(shallow monitor : I32) returns shallow I32 {}
GetWindowPosition := ext_proc() returns shallow Vector2 {}
GetWindowScaleDPI := ext_proc() returns shallow Vector2 {}
GetMonitorName := ext_proc(shallow monitor : I32) returns ref I8 {}
SetClipboardText := ext_proc(text : I8) {}
GetClipboardText := ext_proc() returns ref I8 {}
GetClipboardImage := ext_proc() returns shallow Image {}
EnableEventWaiting := ext_proc() {}
DisableEventWaiting := ext_proc() {}

// Cursor-related functions
ShowCursor := ext_proc() {}
HideCursor := ext_proc() {}
/* Functions defined as 'extern' by default (implicit specifiers)*/ 
IsCursorHidden := ext_proc() returns shallow Bool {}
EnableCursor := ext_proc() {}
DisableCursor := ext_proc() {}
/* Functions defined as 'extern' by default (implicit specifiers)*/ 
IsCursorOnScreen := ext_proc() returns shallow Bool {}

// Drawing-related functions
ClearBackground := ext_proc(shallow color : Color) {}
BeginDrawing := ext_proc() {}
EndDrawing := ext_proc() {}
BeginMode2D := ext_proc(shallow camera : Camera2D) {}
EndMode2D := ext_proc() {}
BeginMode3D := ext_proc(shallow camera : Camera3D) {}
EndMode3D := ext_proc() {}
BeginTextureMode := ext_proc(shallow target : RenderTexture2D) {}
EndTextureMode := ext_proc() {}
BeginShaderMode := ext_proc(shallow shader : Shader) {}
EndShaderMode := ext_proc() {}
