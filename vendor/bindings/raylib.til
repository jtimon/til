    // Android key buttons
KEY_BACK : I32 = 4.to_i32()
KEY_MENU : I32 = 5.to_i32()
KEY_VOLUME_UP : I32 = 24.to_i32()
KEY_VOLUME_DOWN : I32 = 25.to_i32()

// Add backwards compatibility support for deprecated names

// Mouse buttons
MouseButton := I32

MOUSE_BUTTON_LEFT : I32 = 0.to_i32()
MOUSE_BUTTON_RIGHT : I32 = 1.to_i32()
MOUSE_BUTTON_MIDDLE : I32 = 2.to_i32()
MOUSE_BUTTON_SIDE : I32 = 3.to_i32()
MOUSE_BUTTON_EXTRA : I32 = 4.to_i32()
MOUSE_BUTTON_FORWARD : I32 = 5.to_i32()
MOUSE_BUTTON_BACK : I32 = 6.to_i32()

// Mouse cursor
