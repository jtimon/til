mode lib

/**********************************************************************************************
*
*   raylib v6.0 - A simple and easy-to-use library to enjoy videogames programming (www.raylib.com)
*
*   FEATURES:
*       - NO external dependencies, all required libraries included with raylib
*       - Multiplatform: Windows, Linux, macOS, FreeBSD, Web, Android, Raspberry Pi, DRM native...
*       - Written in plain C code (C99) in PascalCase/camelCase notation
*       - Hardware accelerated with OpenGL (1.1, 2.1, 3.3, 4.3, ES2, ES3 - choose at compile)
*       - Custom OpenGL abstraction layer (usable as standalone module): [rlgl]
*       - Multiple Fonts formats supported (TTF, OTF, FNT, BDF, Sprite fonts)
*       - Many texture formats supportted, including compressed formats (DXT, ETC, ASTC)
*       - Full 3d support for 3d Shapes, Models, Billboards, Heightmaps and more!
*       - Flexible Materials system, supporting classic maps and PBR maps
*       - Animated 3D models supported (skeletal bones animation) (IQM, M3D, GLTF)
*       - Shaders support, including Model shaders and Postprocessing shaders
*       - Powerful math module for Vector, Matrix and Quaternion operations: [raymath]
*       - Audio loading and playing with streaming support (WAV, OGG, MP3, FLAC, QOA, XM, MOD)
*       - VR stereo rendering with configurable HMD device parameters
*       - Bindings to multiple programming languages available!
*
*   NOTES:
*       - One default Font is loaded on InitWindow()->LoadFontDefault() [core, text]
*       - One default Texture2D is loaded on rlglInit(), 1x1 white pixel R8G8B8A8 [rlgl] (OpenGL 3.3 or ES2)
*       - One default Shader is loaded on rlglInit()->rlLoadShaderDefault() [rlgl] (OpenGL 3.3 or ES2)
*       - One default RenderBatch is loaded on rlglInit()->rlLoadRenderBatch() [rlgl] (OpenGL 3.3 or ES2)
*
*   DEPENDENCIES:
*       [rcore] Depends on the selected platform backend, check rcore.c header for details
*       [rlgl] glad/glad_gles2 (David Herberth - github.com/Dav1dde/glad) for OpenGL extensions loading
*       [raudio] miniaudio (David Reid - github.com/mackron/miniaudio) for audio device/context management
*
*   OPTIONAL DEPENDENCIES (included):
*       [rcore] sinfl (Micha Mettke) for DEFLATE decompression algorithm
*       [rcore] sdefl (Micha Mettke) for DEFLATE compression algorithm
*       [rcore] rprand (Ramon Santamaria) for pseudo-random numbers generation
*       [rtextures] qoi (Dominic Szablewski - https://phoboslab.org) for QOI image manage
*       [rtextures] stb_image (Sean Barret) for images loading (BMP, TGA, PNG, JPEG, HDR...)
*       [rtextures] stb_image_write (Sean Barret) for image writing (BMP, TGA, PNG, JPG)
*       [rtextures] stb_image_resize2 (Sean Barret) for image resizing algorithms
*       [rtextures] stb_perlin (Sean Barret) for Perlin Noise image generation
*       [rtextures] rl_gputex (Ramon Santamaria) for GPU-compressed texture formats
*       [rtext] stb_truetype (Sean Barret) for ttf fonts loading
*       [rtext] stb_rect_pack (Sean Barret) for rectangles packing
*       [rmodels] par_shapes (Philip Rideout) for parametric 3d shapes generation
*       [rmodels] tinyobj_loader_c (Syoyo Fujita) for models loading (OBJ, MTL)
*       [rmodels] cgltf (Johannes Kuhlmann) for models loading (glTF)
*       [rmodels] m3d (bzt) for models loading (M3D, https://bztsrc.gitlab.io/model3d)
*       [rmodels] vox_loader (Johann Nadalutti) for models loading (VOX)
*       [raudio] dr_wav (David Reid) for WAV audio file loading
*       [raudio] dr_flac (David Reid) for FLAC audio file loading
*       [raudio] dr_mp3 (David Reid) for MP3 audio file loading
*       [raudio] stb_vorbis (Sean Barret) for OGG audio loading
*       [raudio] jar_xm (Joshua Reisenauer) for XM audio module loading
*       [raudio] jar_mod (Joshua Reisenauer) for MOD audio module loading
*       [raudio] qoa (Dominic Szablewski - https://phoboslab.org) for QOA audio manage
*
*
*   LICENSE: zlib/libpng
*
*   raylib is licensed under an unmodified zlib/libpng license, which is an OSI-certified,
*   BSD-like license that allows static linking with closed source software:
*
*   Copyright (c) 2013-2026 Ramon Santamaria (@raysan5)
*
*   This software is provided "as-is", without any express or implied warranty. In no event
*   will the authors be held liable for any damages arising from the use of this software.
*
*   Permission is granted to anyone to use this software for any purpose, including commercial
*   applications, and to alter it and redistribute it freely, subject to the following restrictions:
*
*     1. The origin of this software must not be misrepresented; you must not claim that you
*     wrote the original software. If you use this software in a product, an acknowledgment
*     in the product documentation would be appreciated but is not required.
*
*     2. Altered source versions must be plainly marked as such, and must not be misrepresented
*     as being the original software.
*
*     3. This notice may not be removed or altered from any source distribution.
*
**********************************************************************************************/

RAYLIB_VERSION_MAJOR : I64 = 6
RAYLIB_VERSION_MINOR : I64 = 0
RAYLIB_VERSION_PATCH : I64 = 0

// Function specifiers in case library is build/used as a shared library
// NOTE: Microsoft specifiers to tell compiler that symbols are imported/exported from a .dll
// NOTE: visibility("default") attribute makes symbols "visible" when compiled with -fvisibility=hidden

//----------------------------------------------------------------------------------
// Defines and Macros
//----------------------------------------------------------------------------------

// Allow custom memory allocators
// NOTE: Require recompiling raylib sources

// NOTE: MSVC C++ compiler does not support compound literals (C99 feature)
// Plain structures in C++ (without constructors) can be initialized with { }
// This is called aggregate initialization (C++11 feature)

// Some compilers (mostly macos clang) default to C++98,
// where aggregate initialization can't be used
// So, give a more clear error stating how to fix this

// NOTE: Set some defines with some data types declared by raylib
// Other modules (raymath, rlgl) also require some of those types, so,
// to be able to use those other modules as standalone (not depending on raylib)
// this defines are useful for internal check and avoid type (re)definitions

// Some Basic Colors
// NOTE: Custom raylib color palette for amazing visuals on WHITE background

//----------------------------------------------------------------------------------
// Types and Structures Definition
//----------------------------------------------------------------------------------
// Boolean type

// Vector2, 2 components
Vector2 := struct {
    x : F32 = 0  // Vector x component
    y : F32 = 0  // Vector y component
}

// Vector3, 3 components
Vector3 := struct {
    x : F32 = 0  // Vector x component
    y : F32 = 0  // Vector y component
    z : F32 = 0  // Vector z component
}

// Vector4, 4 components
Vector4 := struct {
    x : F32 = 0  // Vector x component
    y : F32 = 0  // Vector y component
    z : F32 = 0  // Vector z component
    w : F32 = 0  // Vector w component
}

// Quaternion, 4 components (Vector4 alias)
Quaternion := Vector4

// Matrix, 4x4 components, column major, OpenGL style, right-handed
Matrix := ext_struct("Matrix") {}  // opaque: unsupported field shape

// Color, 4 components, R8G8B8A8 (32bit)
Color := struct {
    r : U8 = 0  // Color red value
    g : U8 = 0  // Color green value
    b : U8 = 0  // Color blue value
    a : U8 = 0  // Color alpha value
}

// Rectangle, 4 components
Rectangle := struct {
    x : F32 = 0  // Rectangle top-left corner position x
    y : F32 = 0  // Rectangle top-left corner position y
    width : F32 = 0  // Rectangle width
    height : F32 = 0  // Rectangle height
}

// Image, pixel data stored in CPU memory (RAM)
Image := struct {
    ref data : Dynamic = NULL  // Image raw data
    width : I32 = 0  // Image base width
    height : I32 = 0  // Image base height
    mipmaps : I32 = 0  // Mipmap levels, 1 by default
    format : I32 = 0  // Data format (PixelFormat type)
}

// Texture, tex data stored in GPU memory (VRAM)
Texture := struct {
    id : U32 = 0  // OpenGL texture id
    width : I32 = 0  // Texture base width
    height : I32 = 0  // Texture base height
    mipmaps : I32 = 0  // Mipmap levels, 1 by default
    format : I32 = 0  // Data format (PixelFormat type)
}

// Texture2D, same as Texture
Texture2D := Texture

// TextureCubemap, same as Texture
TextureCubemap := Texture

// RenderTexture, fbo for texture rendering
RenderTexture := struct {
    id : U32 = 0  // OpenGL framebuffer object id
    texture : Texture = Texture()  // Color buffer attachment texture
    depth : Texture = Texture()  // Depth buffer attachment texture
}

// RenderTexture2D, same as RenderTexture
RenderTexture2D := RenderTexture

// NPatchInfo, n-patch layout info
NPatchInfo := struct {
    source : Rectangle = Rectangle()  // Texture source rectangle
    left : I32 = 0  // Left border offset
    top : I32 = 0  // Top border offset
    right : I32 = 0  // Right border offset
    bottom : I32 = 0  // Bottom border offset
    layout : I32 = 0  // Layout of the n-patch: 3x3, 1x3 or 3x1
}

// GlyphInfo, font characters glyphs info
GlyphInfo := struct {
    value : I32 = 0  // Character value (Unicode)
    offsetX : I32 = 0  // Character offset X when drawing
    offsetY : I32 = 0  // Character offset Y when drawing
    advanceX : I32 = 0  // Character advance position X
    image : Image = Image()  // Character image data
}

// Font, font texture and GlyphInfo array data
Font := struct {
    baseSize : I32 = 0  // Base size (default chars height)
    glyphCount : I32 = 0  // Number of glyph characters
    glyphPadding : I32 = 0  // Padding around the glyph characters
    texture : Texture2D = Texture2D()  // Texture atlas containing the glyphs
    ref recs : Rectangle = NULL  // Rectangles in texture for the glyphs
    ref glyphs : GlyphInfo = NULL  // Glyphs info data
}

// Camera, defines position/orientation in 3d space
Camera3D := struct {
    position : Vector3 = Vector3()  // Camera position
    target : Vector3 = Vector3()  // Camera target it looks-at
    up : Vector3 = Vector3()  // Camera up vector (rotation over its axis)
    fovy : F32 = 0  // Camera field-of-view aperture in Y (degrees) in perspective, used as near plane height in world units in orthographic
    projection : I32 = 0  // Camera projection: CAMERA_PERSPECTIVE or CAMERA_ORTHOGRAPHIC
}

Camera := Camera3D

// Camera2D, defines position/orientation in 2d space
Camera2D := struct {
    offset : Vector2 = Vector2()  // Camera offset (screen space offset from window origin)
    target : Vector2 = Vector2()  // Camera target (world space target point that is mapped to screen space offset)
    rotation : F32 = 0  // Camera rotation in degrees (pivots around target)
    zoom : F32 = 0  // Camera zoom (scaling around target), must not be set to 0, set to 1.0f for no scale
}

// Mesh, vertex data and vao/vbo
Mesh := struct {
    vertexCount : I32 = 0  // Number of vertices stored in arrays
    triangleCount : I32 = 0  // Number of triangles stored (indexed or not)
    // Vertex attributes data
    ref vertices : F32 = NULL  // Vertex position (XYZ - 3 components per vertex) (shader-location = 0)
    ref texcoords : F32 = NULL  // Vertex texture coordinates (UV - 2 components per vertex) (shader-location = 1)
    ref texcoords2 : F32 = NULL  // Vertex texture second coordinates (UV - 2 components per vertex) (shader-location = 5)
    ref normals : F32 = NULL  // Vertex normals (XYZ - 3 components per vertex) (shader-location = 2)
    ref tangents : F32 = NULL  // Vertex tangents (XYZW - 4 components per vertex) (shader-location = 4)
    ref colors : U8 = NULL  // Vertex colors (RGBA - 4 components per vertex) (shader-location = 3)
    ref indices : I16 = NULL  // Vertex indices (in case vertex data comes indexed)
    // Skin data for animation
    boneCount : I32 = 0  // Number of bones (MAX: 256 bones)
    ref boneIndices : U8 = NULL  // Vertex bone indices, up to 4 bones influence by vertex (skinning) (shader-location = 6)
    ref boneWeights : F32 = NULL  // Vertex bone weight, up to 4 bones influence by vertex (skinning) (shader-location = 7)
    // Runtime animation vertex data (CPU skinning)
    // NOTE: In case of GPU skinning, not used, pointers are NULL
    ref animVertices : F32 = NULL  // Animated vertex positions (after bones transformations)
    ref animNormals : F32 = NULL  // Animated normals (after bones transformations)
    // OpenGL identifiers
    vaoId : U32 = 0  // OpenGL Vertex Array Object id
    ref vboId : U32 = NULL  // OpenGL Vertex Buffer Objects id (default vertex data)
}

// Shader
Shader := struct {
    id : U32 = 0  // Shader program id
    ref locs : I32 = NULL  // Shader locations array (RL_MAX_SHADER_LOCATIONS)
}

// MaterialMap
MaterialMap := struct {
    texture : Texture2D = Texture2D()  // Material map texture
    color : Color = Color()  // Material map color
    value : F32 = 0  // Material map value
}

// Material, includes shader and maps
Material := ext_struct("Material") {}  // opaque: unsupported field shape

// Transform, vertex transformation data
Transform := struct {
    translation : Vector3 = Vector3()  // Translation
    rotation : Quaternion = Quaternion()  // Rotation
    scale : Vector3 = Vector3()  // Scale
}

// Anim pose, an array of Transform[]
ModelAnimPose := Dynamic

// Bone, skeletal animation bone
BoneInfo := ext_struct("BoneInfo") {}  // opaque: unsupported field shape

// Skeleton, animation bones hierarchy
ModelSkeleton := struct {
    boneCount : I32 = 0  // Number of bones
    ref bones : BoneInfo = NULL  // Bones information (skeleton)
    ref bindPose : ModelAnimPose = NULL  // Bones base transformation (Transform[])
}

// Model, meshes, materials and animation data
Model := struct {
    transform : Matrix = Matrix()  // Local transform matrix
    meshCount : I32 = 0  // Number of meshes
    materialCount : I32 = 0  // Number of materials
    ref meshes : Mesh = NULL  // Meshes array
    ref materials : Material = NULL  // Materials array
    ref meshMaterial : I32 = NULL  // Mesh material number
    // Animation data
    skeleton : ModelSkeleton = ModelSkeleton()  // Skeleton for animation
    // Runtime animation data (CPU/GPU skinning)
    ref currentPose : ModelAnimPose = NULL  // Current animation pose (Transform[])
    ref boneMatrices : Matrix = NULL  // Bones animated transformation matrices
}

// ModelAnimation, contains a full animation sequence
ModelAnimation := ext_struct("ModelAnimation") {}  // opaque: unsupported field shape

// Ray, ray for raycasting
Ray := struct {
    position : Vector3 = Vector3()  // Ray position (origin)
    direction : Vector3 = Vector3()  // Ray direction (normalized)
}

// RayCollision, ray hit information
RayCollision := struct {
    hit : Bool = false  // Did the ray hit something?
    distance : F32 = 0  // Distance to the nearest hit
    point : Vector3 = Vector3()  // Point of the nearest hit
    normal : Vector3 = Vector3()  // Surface normal of hit
}

// BoundingBox
BoundingBox := struct {
    min : Vector3 = Vector3()  // Minimum vertex box-corner
    max : Vector3 = Vector3()  // Maximum vertex box-corner
}

// Wave, audio wave data
Wave := struct {
    frameCount : U32 = 0  // Total number of frames (considering channels)
    sampleRate : U32 = 0  // Frequency (samples per second)
    sampleSize : U32 = 0  // Bit depth (bits per sample): 8, 16, 32 (24 not supported)
    channels : U32 = 0  // Number of channels (1-mono, 2-stereo, ...)
    ref data : Dynamic = NULL  // Buffer data pointer
}

// Opaque structs declaration
// NOTE: Actual structs are defined internally in raudio module
rAudioBuffer := ext_struct("rAudioBuffer") {}

rAudioProcessor := ext_struct("rAudioProcessor") {}

// AudioStream, custom audio stream
AudioStream := struct {
    ref buffer : rAudioBuffer = NULL  // Pointer to internal data used by the audio system
    ref processor : rAudioProcessor = NULL  // Pointer to internal data processor, useful for audio effects
    sampleRate : U32 = 0  // Frequency (samples per second)
    sampleSize : U32 = 0  // Bit depth (bits per sample): 8, 16, 32 (24 not supported)
    channels : U32 = 0  // Number of channels (1-mono, 2-stereo, ...)
}

// Sound
Sound := struct {
    stream : AudioStream = AudioStream()  // Audio stream
    frameCount : U32 = 0  // Total number of frames (considering channels)
}

// Music, audio stream, anything longer than ~10 seconds should be streamed
Music := struct {
    stream : AudioStream = AudioStream()  // Audio stream
    frameCount : U32 = 0  // Total number of frames (considering channels)
    looping : Bool = false  // Music looping enable
    ctxType : I32 = 0  // Type of music context (audio filetype)
    ref ctxData : Dynamic = NULL  // Audio context data, depends on type
}

// VrDeviceInfo, Head-Mounted-Display device parameters
VrDeviceInfo := ext_struct("VrDeviceInfo") {}  // opaque: unsupported field shape

// VrStereoConfig, VR stereo rendering configuration for simulator
VrStereoConfig := ext_struct("VrStereoConfig") {}  // opaque: unsupported field shape

// File path list
FilePathList := struct {
    count : U32 = 0  // Filepaths entries count
    ref paths : Dynamic = NULL  // Filepaths entries
}

// Automation event
AutomationEvent := ext_struct("AutomationEvent") {}  // opaque: unsupported field shape

// Automation event list
AutomationEventList := struct {
    capacity : U32 = 0  // Events max entries (MAX_AUTOMATION_EVENTS)
    count : U32 = 0  // Events entries count
    ref events : AutomationEvent = NULL  // Events entries
}

//----------------------------------------------------------------------------------
// Enumerators Definition
//----------------------------------------------------------------------------------
// System/Window config flags
// NOTE: Every bit registers one state (use it with bit masks)
// By default all flags are set to 0
ConfigFlags := I32

FLAG_VSYNC_HINT : I32 = 64.to_i32()
FLAG_FULLSCREEN_MODE : I32 = 2.to_i32()
FLAG_WINDOW_RESIZABLE : I32 = 4.to_i32()
FLAG_WINDOW_UNDECORATED : I32 = 8.to_i32()
FLAG_WINDOW_HIDDEN : I32 = 128.to_i32()
FLAG_WINDOW_MINIMIZED : I32 = 512.to_i32()
FLAG_WINDOW_MAXIMIZED : I32 = 1024.to_i32()
FLAG_WINDOW_UNFOCUSED : I32 = 2048.to_i32()
FLAG_WINDOW_TOPMOST : I32 = 4096.to_i32()
FLAG_WINDOW_ALWAYS_RUN : I32 = 256.to_i32()
FLAG_WINDOW_TRANSPARENT : I32 = 16.to_i32()
FLAG_WINDOW_HIGHDPI : I32 = 8192.to_i32()
FLAG_WINDOW_MOUSE_PASSTHROUGH : I32 = 16384.to_i32()
FLAG_BORDERLESS_WINDOWED_MODE : I32 = 32768.to_i32()
FLAG_MSAA_4X_HINT : I32 = 32.to_i32()
FLAG_INTERLACED_HINT : I32 = 33.to_i32()

// Trace log level
// NOTE: Organized by priority level
TraceLogLevel := I32

LOG_ALL : I32 = 0.to_i32()
LOG_TRACE : I32 = 1.to_i32()
LOG_DEBUG : I32 = 2.to_i32()
LOG_INFO : I32 = 3.to_i32()
LOG_WARNING : I32 = 4.to_i32()
LOG_ERROR : I32 = 5.to_i32()
LOG_FATAL : I32 = 6.to_i32()
LOG_NONE : I32 = 7.to_i32()

// Keyboard keys (US keyboard layout)
// NOTE: Use GetKeyPressed() to allow redefining required keys for alternative layouts
KeyboardKey := I32

KEY_NULL : I32 = 0.to_i32()
    // Alphanumeric keys
KEY_APOSTROPHE : I32 = 39.to_i32()
KEY_COMMA : I32 = 44.to_i32()
KEY_MINUS : I32 = 45.to_i32()
KEY_PERIOD : I32 = 46.to_i32()
KEY_SLASH : I32 = 47.to_i32()
KEY_ZERO : I32 = 48.to_i32()
KEY_ONE : I32 = 49.to_i32()
KEY_TWO : I32 = 50.to_i32()
KEY_THREE : I32 = 51.to_i32()
KEY_FOUR : I32 = 52.to_i32()
KEY_FIVE : I32 = 53.to_i32()
KEY_SIX : I32 = 54.to_i32()
KEY_SEVEN : I32 = 55.to_i32()
KEY_EIGHT : I32 = 56.to_i32()
KEY_NINE : I32 = 57.to_i32()
KEY_SEMICOLON : I32 = 59.to_i32()
KEY_EQUAL : I32 = 61.to_i32()
KEY_A : I32 = 65.to_i32()
KEY_B : I32 = 66.to_i32()
KEY_C : I32 = 67.to_i32()
KEY_D : I32 = 68.to_i32()
KEY_E : I32 = 69.to_i32()
KEY_F : I32 = 70.to_i32()
KEY_G : I32 = 71.to_i32()
KEY_H : I32 = 72.to_i32()
KEY_I : I32 = 73.to_i32()
KEY_J : I32 = 74.to_i32()
KEY_K : I32 = 75.to_i32()
KEY_L : I32 = 76.to_i32()
KEY_M : I32 = 77.to_i32()
KEY_N : I32 = 78.to_i32()
KEY_O : I32 = 79.to_i32()
KEY_P : I32 = 80.to_i32()
KEY_Q : I32 = 81.to_i32()
KEY_R : I32 = 82.to_i32()
KEY_S : I32 = 83.to_i32()
KEY_T : I32 = 84.to_i32()
KEY_U : I32 = 85.to_i32()
KEY_V : I32 = 86.to_i32()
KEY_W : I32 = 87.to_i32()
KEY_X : I32 = 88.to_i32()
KEY_Y : I32 = 89.to_i32()
KEY_Z : I32 = 90.to_i32()
KEY_LEFT_BRACKET : I32 = 91.to_i32()
KEY_BACKSLASH : I32 = 92.to_i32()
KEY_RIGHT_BRACKET : I32 = 93.to_i32()
KEY_GRAVE : I32 = 96.to_i32()
    // Function keys
KEY_SPACE : I32 = 32.to_i32()
KEY_ESCAPE : I32 = 256.to_i32()
KEY_ENTER : I32 = 257.to_i32()
KEY_TAB : I32 = 258.to_i32()
KEY_BACKSPACE : I32 = 259.to_i32()
KEY_INSERT : I32 = 260.to_i32()
KEY_DELETE : I32 = 261.to_i32()
KEY_RIGHT : I32 = 262.to_i32()
KEY_LEFT : I32 = 263.to_i32()
KEY_DOWN : I32 = 264.to_i32()
KEY_UP : I32 = 265.to_i32()
KEY_PAGE_UP : I32 = 266.to_i32()
KEY_PAGE_DOWN : I32 = 267.to_i32()
KEY_HOME : I32 = 268.to_i32()
KEY_END : I32 = 269.to_i32()
KEY_CAPS_LOCK : I32 = 280.to_i32()
KEY_SCROLL_LOCK : I32 = 281.to_i32()
KEY_NUM_LOCK : I32 = 282.to_i32()
KEY_PRINT_SCREEN : I32 = 283.to_i32()
KEY_PAUSE : I32 = 284.to_i32()
KEY_F1 : I32 = 290.to_i32()
KEY_F2 : I32 = 291.to_i32()
KEY_F3 : I32 = 292.to_i32()
KEY_F4 : I32 = 293.to_i32()
KEY_F5 : I32 = 294.to_i32()
KEY_F6 : I32 = 295.to_i32()
KEY_F7 : I32 = 296.to_i32()
KEY_F8 : I32 = 297.to_i32()
KEY_F9 : I32 = 298.to_i32()
KEY_F10 : I32 = 299.to_i32()
KEY_F11 : I32 = 300.to_i32()
KEY_F12 : I32 = 301.to_i32()
KEY_LEFT_SHIFT : I32 = 340.to_i32()
KEY_LEFT_CONTROL : I32 = 341.to_i32()
KEY_LEFT_ALT : I32 = 342.to_i32()
KEY_LEFT_SUPER : I32 = 343.to_i32()
KEY_RIGHT_SHIFT : I32 = 344.to_i32()
KEY_RIGHT_CONTROL : I32 = 345.to_i32()
KEY_RIGHT_ALT : I32 = 346.to_i32()
KEY_RIGHT_SUPER : I32 = 347.to_i32()
KEY_KB_MENU : I32 = 348.to_i32()
    // Keypad keys
KEY_KP_0 : I32 = 320.to_i32()
KEY_KP_1 : I32 = 321.to_i32()
KEY_KP_2 : I32 = 322.to_i32()
KEY_KP_3 : I32 = 323.to_i32()
KEY_KP_4 : I32 = 324.to_i32()
KEY_KP_5 : I32 = 325.to_i32()
