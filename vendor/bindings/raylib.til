// Window-related functions
InitWindow := ext_proc(shallow width : I32, shallow height : I32, title : I8) {}
CloseWindow := ext_proc() {}
/* Functions defined as 'extern' by default (implicit specifiers)*/ 
// ext_proc: reads window state set by the platform layer.
WindowShouldClose := ext_proc() returns shallow Bool {}
/* Functions defined as 'extern' by default (implicit specifiers)*/ 
IsWindowReady := ext_proc() returns shallow Bool {}
/* Functions defined as 'extern' by default (implicit specifiers)*/ 
IsWindowFullscreen := ext_proc() returns shallow Bool {}
