EndVrStereoMode := ext_proc() {}

// VR stereo config functions for VR simulator
LoadVrStereoConfig := ext_func(shallow device : VrDeviceInfo) returns shallow VrStereoConfig {}
UnloadVrStereoConfig := ext_proc(shallow config : VrStereoConfig) {}

// Shader management functions
// NOTE: Shader functionality is not available on OpenGL 1.1
LoadShader := ext_proc(vsFileName : I8, fsFileName : I8) returns shallow Shader {}
LoadShaderFromMemory := ext_proc(vsCode : I8, fsCode : I8) returns shallow Shader {}
/* Functions defined as 'extern' by default (implicit specifiers)*/ 
IsShaderValid := ext_func(shallow shader : Shader) returns shallow Bool {}
GetShaderLocation := ext_func(shallow shader : Shader, uniformName : I8) returns shallow I32 {}
GetShaderLocationAttrib := ext_func(shallow shader : Shader, attribName : I8) returns shallow I32 {}
SetShaderValue := ext_proc(shallow shader : Shader, shallow locIndex : I32, value : Dynamic, shallow uniformType : I32) {}
SetShaderValueV := ext_proc(shallow shader : Shader, shallow locIndex : I32, value : Dynamic, shallow uniformType : I32, shallow count : I32) {}
SetShaderValueMatrix := ext_proc(shallow shader : Shader, shallow locIndex : I32, shallow mat : Matrix) {}
SetShaderValueTexture := ext_proc(shallow shader : Shader, shallow locIndex : I32, shallow texture : Texture2D) {}
UnloadShader := ext_proc(shallow shader : Shader) {}

// Screen-space-related functions
GetScreenToWorldRay := ext_proc(shallow position : Vector2, shallow camera : Camera) returns shallow Ray {}
GetScreenToWorldRayEx := ext_proc(shallow position : Vector2, shallow camera : Camera, shallow width : I32, shallow height : I32) returns shallow Ray {}
GetWorldToScreen := ext_proc(shallow position : Vector3, shallow camera : Camera) returns shallow Vector2 {}
GetWorldToScreenEx := ext_proc(shallow position : Vector3, shallow camera : Camera, shallow width : I32, shallow height : I32) returns shallow Vector2 {}
GetWorldToScreen2D := ext_proc(shallow position : Vector2, shallow camera : Camera2D) returns shallow Vector2 {}
GetScreenToWorld2D := ext_proc(shallow position : Vector2, shallow camera : Camera2D) returns shallow Vector2 {}
GetCameraMatrix := ext_func(shallow camera : Camera) returns shallow Matrix {}
GetCameraMatrix2D := ext_func(shallow camera : Camera2D) returns shallow Matrix {}

// Timing-related functions
SetTargetFPS := ext_proc(shallow fps : I32) {}
// ext_proc: reads the frame-clock state maintained by raylib.
GetFrameTime := ext_proc() returns shallow F32 {}
GetTime := ext_proc() returns shallow F32 {}
GetFPS := ext_proc() returns shallow I32 {}

// Custom frame control functions
// NOTE: Those functions are intended for advanced users that want full control over the frame processing
// By default EndDrawing() does this job: draws everything + SwapScreenBuffer() + manage frame timing + PollInputEvents()
// To avoid that behaviour and control frame processes manually, enable in config.h: SUPPORT_CUSTOM_FRAME_CONTROL
SwapScreenBuffer := ext_proc() {}
PollInputEvents := ext_proc() {}
WaitTime := ext_proc(shallow seconds : F32) {}

// Random values generation functions
SetRandomSeed := ext_proc(shallow seed : U32) {}
GetRandomValue := ext_proc(shallow min : I32, shallow max : I32) returns shallow I32 {}
LoadRandomSequence := ext_proc(shallow count : U32, shallow min : I32, shallow max : I32) returns ref I32 {}
UnloadRandomSequence := ext_proc(sequence : I32) {}

// Misc. functions
TakeScreenshot := ext_proc(fileName : I8) {}
SetConfigFlags := ext_proc(shallow flags : U32) {}
OpenURL := ext_proc(url : I8) {}

// Logging system
SetTraceLogLevel := ext_proc(shallow logLevel : I32) {}
SetTraceLogCallback := ext_proc(callback : TraceLogCallback) {}

// Memory management, using internal allocators
MemAlloc := ext_proc(shallow size : U32) returns Dynamic {}
MemRealloc := ext_proc(ptr : Dynamic, shallow size : U32) returns Dynamic {}
MemFree := ext_proc(ptr : Dynamic) {}

// File system management functions
LoadFileData := ext_proc(fileName : I8, dataSize : I32) returns ref I8 {}
UnloadFileData := ext_proc(data : U8) {}
/* Functions defined as 'extern' by default (implicit specifiers)*/ 
SaveFileData := ext_proc(fileName : I8, data : Dynamic, shallow dataSize : I32) returns shallow Bool {}
/* Functions defined as 'extern' by default (implicit specifiers)*/ 
ExportDataAsCode := ext_proc(data : U8, shallow dataSize : I32, fileName : I8) returns shallow Bool {}
LoadFileText := ext_proc(fileName : I8) returns ref I8 {}
UnloadFileText := ext_proc(text : I8) {}
/* Functions defined as 'extern' by default (implicit specifiers)*/ 
SaveFileText := ext_proc(fileName : I8, text : I8) returns shallow Bool {}

// File access custom callbacks
// WARNING: Callbacks setup is intended for advanced users
SetLoadFileDataCallback := ext_proc(callback : LoadFileDataCallback) {}
SetSaveFileDataCallback := ext_proc(callback : SaveFileDataCallback) {}
SetLoadFileTextCallback := ext_proc(callback : LoadFileTextCallback) {}
SetSaveFileTextCallback := ext_proc(callback : SaveFileTextCallback) {}

FileRename := ext_proc(fileName : I8, fileRename : I8) returns shallow I32 {}
FileRemove := ext_proc(fileName : I8) returns shallow I32 {}
