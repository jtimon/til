mode lib

// AUDIT: every binding here is ext_proc, not the binder's default
// ext_func. nng has no pure functions: each call either mutates or
// reads live socket/pipe/dialer/listener/ctx/aio/msg state, performs
// I/O, allocates, or returns an internal pointer. Folding any of these
// in constfolder (which ext_func permits) would run the call at compile
// time -- opening real sockets, or baking a compiler-process pointer
// into the output. So all stay ext_proc. See doc/ffi.org.

//
// Copyright 2025 Staysail Systems, Inc. <info@staysail.tech>
// Copyright 2018 Capitar IT Group BV <info@capitar.com>
//
// This software is supplied under the terms of the MIT License, a
// copy of which should be located in the distribution where this
// file was obtained (LICENSE.txt).  A copy of the license may also be
// found online at https://opensource.org/licenses/MIT.
//

// NNG (nanomsg-next-gen) is an improved implementation of the SP protocols.
// The APIs have changed, and there is no attempt to provide API compatibility
// with legacy libnanomsg. This file defines the library consumer-facing
// Public API. Use of definitions or declarations not found in this header
// file is specifically unsupported and strongly discouraged.

// NNG_DECL is used on declarations to deal with scope.
// For building Windows DLLs, it should be the appropriate __declspec().
// For shared libraries with platforms that support hidden visibility,
// it should evaluate to __attribute__((visibility("default"))).

// NNG Library & API version.
// We use SemVer, and these versions are about the API, and
// may not necessarily match the ABI versions.
NNG_MAJOR_VERSION : I64 = 1
NNG_MINOR_VERSION : I64 = 11
NNG_PATCH_VERSION : I64 = 0
// if non-empty (i.e. "pre"), this is a pre-release

// Maximum length of a socket address. This includes the terminating NUL.
// This limit is built into other implementations, so do not change it.
// Note that some transports are quite happy to let you use addresses
// in excess of this, but if you do you may not be able to communicate
// with other implementations.

// NNG_PROTOCOL_NUMBER is used by protocol headers to calculate their
// protocol number from a major and minor number.  Applications should
// probably not need to use this.

// Types common to nng.

// Identifiers are wrapped in a structure to improve compiler validation
// of incorrect passing.  This gives us strong type checking.  Modern
// compilers compile passing these by value to identical code as passing
// the integer type (at least with optimization applied).  Please do not
// access the ID member directly.

nng_ctx := ext_struct("nng_ctx_s") {
    id : U32 = 0
}

nng_dialer := ext_struct("nng_dialer_s") {
    id : U32 = 0
}

nng_listener := ext_struct("nng_listener_s") {
    id : U32 = 0
}

nng_pipe := ext_struct("nng_pipe_s") {
    id : U32 = 0
}

nng_socket := ext_struct("nng_socket_s") {
    id : U32 = 0
}

nng_duration := I32

// nng_time represents an absolute time since some arbitrary point in the
// past, measured in milliseconds.  The values are always positive.
nng_time := U64

nng_msg := ext_struct("nng_msg") {}

nng_stat := ext_struct("nng_stat") {}

nng_aio := ext_struct("nng_aio") {}

// Initializers.
// clang-format off
// clang-format on

// Some address details. This is in some ways like a traditional sockets
// sockaddr, but we have our own to cope with our unique families, etc.
// The details of this structure are directly exposed to applications.
// These structures can be obtained via property lookups, etc.

// nng_sockaddr_storage is the size required to store any nng_sockaddr.
// This size must not change, and no individual nng_sockaddr type may grow
// larger than this without breaking binary compatibility.

nng_sockaddr_inproc := ext_struct("nng_sockaddr_inproc") {}

nng_sockaddr_path := ext_struct("nng_sockaddr_path") {}

// nng.h defines nng_sockaddr_ipc as a typedef alias of struct
// nng_sockaddr_path. Two til ext_structs sharing one C tag made the
// emitter define `struct nng_sockaddr_path` twice once the #269
// scavenger wildcard kept both decls alive (a C error that broke
// `make bin/til`). Both shells are opaque and used only by pointer,
// so giving the alias its own tag is layout-neutral. The builder now
// also emits a typedef alias for repeated tags (emit_struct_typedef),
// but that fix only takes effect once it is in the boot compiler.
nng_sockaddr_ipc := ext_struct("nng_sockaddr_ipc") {}

nng_sockaddr_in := ext_struct("nng_sockaddr_in") {}

nng_sockaddr_in6 := ext_struct("nng_sockaddr_in6") {}

nng_sockaddr_zt := ext_struct("nng_sockaddr_zt") {}

nng_sockaddr_abstract := ext_struct("nng_sockaddr_abstract") {}

nng_sockaddr_storage := ext_struct("nng_sockaddr_storage") {}

nng_sockaddr := Dynamic  // typedef union from C, opaque here

// Scatter/gather I/O.
nng_iov := struct {
    ref iov_buf : Dynamic = NULL
    iov_len : USize = 0
}

// Some definitions for durations used with timeouts.

// nng_fini is used to terminate the library, freeing certain global resources.
// This should only be called during atexit() or just before dlclose().
// THIS FUNCTION MUST NOT BE CALLED CONCURRENTLY WITH ANY OTHER FUNCTION
// IN THIS LIBRARY; IT IS NOT REENTRANT OR THREADSAFE.
//
// For most cases, this call is unnecessary, but it is provided to assist
// when debugging with memory checkers (e.g. valgrind).  Calling this
// function prevents global library resources from being reported incorrectly
// as memory leaks.  In those cases, we recommend doing this with atexit().
nng_fini := ext_proc() {}

// nng_close closes the socket, terminating all activity and
// closing any underlying connections and releasing any associated
// resources.
// We're not eliding this with NNG_ELIDE_DEPRECATED for now, because
// it would break far too many applications, as nng_socket_close is brand new.
nng_close := ext_proc(shallow _arg : nng_socket) returns shallow I32 {}

// nng_socket_close is the *new* name for nng_close.  It should be used
// in new code, as nng_close will be removed in the next major release.
nng_socket_close := ext_proc(shallow _arg : nng_socket) returns shallow I32 {}

// nng_socket_id returns the positive socket id for the socket, or -1
// if the socket is not valid.
nng_socket_id := ext_proc(shallow _arg : nng_socket) returns shallow I32 {}

nng_socket_set := ext_proc(shallow _arg : nng_socket, _arg : I8, _arg : Dynamic, shallow _arg : USize) returns shallow I32 {}
nng_socket_set_bool := ext_proc(shallow _arg : nng_socket, _arg : I8, shallow _arg : Bool) returns shallow I32 {}
nng_socket_set_int := ext_proc(shallow _arg : nng_socket, _arg : I8, shallow _arg : I32) returns shallow I32 {}
nng_socket_set_size := ext_proc(shallow _arg : nng_socket, _arg : I8, shallow _arg : USize) returns shallow I32 {}
nng_socket_set_uint64 := ext_proc(shallow _arg : nng_socket, _arg : I8, shallow _arg : U64) returns shallow I32 {}
nng_socket_set_string := ext_proc(shallow _arg : nng_socket, _arg : I8, _arg : I8) returns shallow I32 {}
nng_socket_set_ptr := ext_proc(shallow _arg : nng_socket, _arg : I8, mut _arg : Dynamic) returns shallow I32 {}
nng_socket_set_ms := ext_proc(shallow _arg : nng_socket, _arg : I8, shallow _arg : nng_duration) returns shallow I32 {}
nng_socket_set_addr := ext_proc(shallow _arg : nng_socket, _arg : I8, _arg : nng_sockaddr) returns shallow I32 {}

nng_socket_get := ext_proc(shallow _arg : nng_socket, _arg : I8, mut _arg : Dynamic, mut _arg : USize) returns shallow I32 {}
nng_socket_get_bool := ext_proc(shallow _arg : nng_socket, _arg : I8, mut _arg : Bool) returns shallow I32 {}
nng_socket_get_int := ext_proc(shallow _arg : nng_socket, _arg : I8, mut _arg : I32) returns shallow I32 {}
nng_socket_get_size := ext_proc(shallow _arg : nng_socket, _arg : I8, mut _arg : USize) returns shallow I32 {}
nng_socket_get_uint64 := ext_proc(shallow _arg : nng_socket, _arg : I8, mut _arg : U64) returns shallow I32 {}
nng_socket_get_string := ext_proc(shallow _arg : nng_socket, _arg : I8, mut _arg : Dynamic) returns shallow I32 {}
nng_socket_get_ptr := ext_proc(shallow _arg : nng_socket, _arg : I8, mut _arg : Dynamic) returns shallow I32 {}
nng_socket_get_ms := ext_proc(shallow _arg : nng_socket, _arg : I8, mut _arg : nng_duration) returns shallow I32 {}
nng_socket_get_addr := ext_proc(shallow _arg : nng_socket, _arg : I8, mut _arg : nng_sockaddr) returns shallow I32 {}

// These functions are used on a socket to get information about it's
// identity, and the identity of the peer.  Few applications need these.
nng_socket_proto_id := ext_proc(shallow id : nng_socket, mut _arg : U16) returns shallow I32 {}
nng_socket_peer_id := ext_proc(shallow id : nng_socket, mut _arg : U16) returns shallow I32 {}
nng_socket_proto_name := ext_proc(shallow id : nng_socket, _arg : Dynamic) returns shallow I32 {}
nng_socket_peer_name := ext_proc(shallow id : nng_socket, _arg : Dynamic) returns shallow I32 {}
nng_socket_raw := ext_proc(shallow _arg : nng_socket, mut _arg : Bool) returns shallow I32 {}

// Utility function for getting a printable form of the socket address
// for display in logs, etc.  It is not intended to be parsed, and the
// display format may change without notice.  Generally you should alow
// at least NNG_MAXADDRSTRLEN if you want to avoid typical truncations.
// It is still possible for very long IPC paths to be truncated, but that
// is an edge case and applications that pass such long paths should
// expect some truncation (but they may pass larger values).
nng_str_sockaddr := ext_proc(sa : nng_sockaddr, mut buf : I8, shallow bufsz : USize) returns ref I8 {}

// Arguably the pipe callback functions could be handled as an option,
// but with the need to specify an argument, we find it best to unify
// this as a separate function to pass in the argument and the callback.
// Only one callback can be set on a given socket, and there is no way
// to retrieve the old value.
nng_pipe_ev := I32

NNG_PIPE_EV_ADD_PRE : I32 = 0
NNG_PIPE_EV_ADD_POST : I32 = 1
NNG_PIPE_EV_REM_POST : I32 = 2
NNG_PIPE_EV_NUM : I32 = 3

nng_pipe_cb := Dynamic

// nng_pipe_notify registers a callback to be executed when the
// given event is triggered.  To watch for different events, register
// multiple times.  Each event can have at most one callback registered.
nng_pipe_notify := ext_proc(shallow _arg : nng_socket, shallow _arg : nng_pipe_ev, _arg : nng_pipe_cb, mut _arg : Dynamic) returns shallow I32 {}

// nng_listen creates a listening endpoint with no special options,
// and starts it listening.  It is functionally equivalent to the legacy
// nn_bind(). The underlying endpoint is returned back to the caller in the
// endpoint pointer, if it is not NULL.  The flags are ignored at present.
nng_listen := ext_proc(shallow _arg : nng_socket, _arg : I8, mut _arg : nng_listener, shallow _arg : I32) returns shallow I32 {}

// nng_dial creates a dialing endpoint, with no special options, and
// starts it dialing.  Dialers have at most one active connection at a time
// This is similar to the legacy nn_connect().  The underlying endpoint
// is returned back to the caller in the endpoint pointer, if it is not NULL.
// The flags may be NNG_FLAG_NONBLOCK to indicate that the first attempt to
// dial will be made in the background, returning control to the caller
// immediately.  In this case, if the connection fails, the function will
// keep retrying in the background.  (If the connection is dropped in either
// case, it will still be reconnected in the background -- only the initial
// connection attempt is normally synchronous.)
nng_dial := ext_proc(shallow _arg : nng_socket, _arg : I8, mut _arg : nng_dialer, shallow _arg : I32) returns shallow I32 {}

// nng_dialer_create creates a new dialer, that is not yet started.
nng_dialer_create := ext_proc(mut _arg : nng_dialer, shallow _arg : nng_socket, _arg : I8) returns shallow I32 {}

// nng_listener_create creates a new listener, that is not yet started.
nng_listener_create := ext_proc(mut _arg : nng_listener, shallow _arg : nng_socket, _arg : I8) returns shallow I32 {}

// nng_dialer_start starts the endpoint dialing.  This is only possible if
// the dialer is not already dialing.
nng_dialer_start := ext_proc(shallow _arg : nng_dialer, shallow _arg : I32) returns shallow I32 {}

// nng_listener_start starts the endpoint listening.  This is only possible if
// the listener is not already listening.
nng_listener_start := ext_proc(shallow _arg : nng_listener, shallow _arg : I32) returns shallow I32 {}

// nng_dialer_close closes the dialer, shutting down all underlying
// connections and releasing all associated resources.
nng_dialer_close := ext_proc(shallow _arg : nng_dialer) returns shallow I32 {}

// nng_listener_close closes the listener, shutting down all underlying
// connections and releasing all associated resources.
nng_listener_close := ext_proc(shallow _arg : nng_listener) returns shallow I32 {}

// nng_dialer_id returns the positive dialer ID, or -1 if the dialer is
// invalid.
nng_dialer_id := ext_proc(shallow _arg : nng_dialer) returns shallow I32 {}

// nng_listener_id returns the positive listener ID, or -1 if the listener is
// invalid.
nng_listener_id := ext_proc(shallow _arg : nng_listener) returns shallow I32 {}

nng_dialer_set := ext_proc(shallow _arg : nng_dialer, _arg : I8, _arg : Dynamic, shallow _arg : USize) returns shallow I32 {}
nng_dialer_set_bool := ext_proc(shallow _arg : nng_dialer, _arg : I8, shallow _arg : Bool) returns shallow I32 {}
nng_dialer_set_int := ext_proc(shallow _arg : nng_dialer, _arg : I8, shallow _arg : I32) returns shallow I32 {}
nng_dialer_set_size := ext_proc(shallow _arg : nng_dialer, _arg : I8, shallow _arg : USize) returns shallow I32 {}
nng_dialer_set_uint64 := ext_proc(shallow _arg : nng_dialer, _arg : I8, shallow _arg : U64) returns shallow I32 {}
nng_dialer_set_string := ext_proc(shallow _arg : nng_dialer, _arg : I8, _arg : I8) returns shallow I32 {}
nng_dialer_set_ptr := ext_proc(shallow _arg : nng_dialer, _arg : I8, mut _arg : Dynamic) returns shallow I32 {}
nng_dialer_set_ms := ext_proc(shallow _arg : nng_dialer, _arg : I8, shallow _arg : nng_duration) returns shallow I32 {}
nng_dialer_set_addr := ext_proc(shallow _arg : nng_dialer, _arg : I8, _arg : nng_sockaddr) returns shallow I32 {}

nng_dialer_get := ext_proc(shallow _arg : nng_dialer, _arg : I8, mut _arg : Dynamic, mut _arg : USize) returns shallow I32 {}
nng_dialer_get_bool := ext_proc(shallow _arg : nng_dialer, _arg : I8, mut _arg : Bool) returns shallow I32 {}
nng_dialer_get_int := ext_proc(shallow _arg : nng_dialer, _arg : I8, mut _arg : I32) returns shallow I32 {}
nng_dialer_get_size := ext_proc(shallow _arg : nng_dialer, _arg : I8, mut _arg : USize) returns shallow I32 {}
nng_dialer_get_uint64 := ext_proc(shallow _arg : nng_dialer, _arg : I8, mut _arg : U64) returns shallow I32 {}
nng_dialer_get_string := ext_proc(shallow _arg : nng_dialer, _arg : I8, mut _arg : Dynamic) returns shallow I32 {}
nng_dialer_get_ptr := ext_proc(shallow _arg : nng_dialer, _arg : I8, mut _arg : Dynamic) returns shallow I32 {}
nng_dialer_get_ms := ext_proc(shallow _arg : nng_dialer, _arg : I8, mut _arg : nng_duration) returns shallow I32 {}
nng_dialer_get_addr := ext_proc(shallow _arg : nng_dialer, _arg : I8, mut _arg : nng_sockaddr) returns shallow I32 {}

nng_listener_set := ext_proc(shallow _arg : nng_listener, _arg : I8, _arg : Dynamic, shallow _arg : USize) returns shallow I32 {}
nng_listener_set_bool := ext_proc(shallow _arg : nng_listener, _arg : I8, shallow _arg : Bool) returns shallow I32 {}
nng_listener_set_int := ext_proc(shallow _arg : nng_listener, _arg : I8, shallow _arg : I32) returns shallow I32 {}
nng_listener_set_size := ext_proc(shallow _arg : nng_listener, _arg : I8, shallow _arg : USize) returns shallow I32 {}
nng_listener_set_uint64 := ext_proc(shallow _arg : nng_listener, _arg : I8, shallow _arg : U64) returns shallow I32 {}
nng_listener_set_string := ext_proc(shallow _arg : nng_listener, _arg : I8, _arg : I8) returns shallow I32 {}
nng_listener_set_ptr := ext_proc(shallow _arg : nng_listener, _arg : I8, mut _arg : Dynamic) returns shallow I32 {}
nng_listener_set_ms := ext_proc(shallow _arg : nng_listener, _arg : I8, shallow _arg : nng_duration) returns shallow I32 {}
nng_listener_set_addr := ext_proc(shallow _arg : nng_listener, _arg : I8, _arg : nng_sockaddr) returns shallow I32 {}

nng_listener_get := ext_proc(shallow _arg : nng_listener, _arg : I8, mut _arg : Dynamic, mut _arg : USize) returns shallow I32 {}
nng_listener_get_bool := ext_proc(shallow _arg : nng_listener, _arg : I8, mut _arg : Bool) returns shallow I32 {}
nng_listener_get_int := ext_proc(shallow _arg : nng_listener, _arg : I8, mut _arg : I32) returns shallow I32 {}
nng_listener_get_size := ext_proc(shallow _arg : nng_listener, _arg : I8, mut _arg : USize) returns shallow I32 {}
nng_listener_get_uint64 := ext_proc(shallow _arg : nng_listener, _arg : I8, mut _arg : U64) returns shallow I32 {}
nng_listener_get_string := ext_proc(shallow _arg : nng_listener, _arg : I8, mut _arg : Dynamic) returns shallow I32 {}
nng_listener_get_ptr := ext_proc(shallow _arg : nng_listener, _arg : I8, mut _arg : Dynamic) returns shallow I32 {}
nng_listener_get_ms := ext_proc(shallow _arg : nng_listener, _arg : I8, mut _arg : nng_duration) returns shallow I32 {}
nng_listener_get_addr := ext_proc(shallow _arg : nng_listener, _arg : I8, mut _arg : nng_sockaddr) returns shallow I32 {}

// nng_strerror returns a human-readable string associated with the error
// code supplied.
nng_strerror := ext_proc(shallow _arg : I32) returns ref I8 {}

// nng_send sends (or arranges to send) the data on the socket.  Note that
// this function may (will!) return before any receiver has actually
// received the data.  The return value will be zero to indicate that the
// socket has accepted the entire data for send, or an errno to indicate
// failure.  The flags may include NNG_FLAG_NONBLOCK or NNG_FLAG_ALLOC.
// If the flag includes NNG_FLAG_ALLOC, then the function will call
// nng_free() on the supplied pointer & size on success. (If the call
// fails then the memory is not freed.)
nng_send := ext_proc(shallow _arg : nng_socket, mut _arg : Dynamic, shallow _arg : USize, shallow _arg : I32) returns shallow I32 {}

// nng_recv receives message data into the socket, up to the supplied size.
// The actual size of the message data will be written to the value pointed
// to by size.  The flags may include NNG_FLAG_NONBLOCK and NNG_FLAG_ALLOC.
// If NNG_FLAG_ALLOC is supplied then the library will allocate memory for
// the caller.  In that case the pointer to the allocated will be stored
// instead of the data itself.  The caller is responsible for freeing the
// associated memory with nng_free().
nng_recv := ext_proc(shallow _arg : nng_socket, mut _arg : Dynamic, mut _arg : USize, shallow _arg : I32) returns shallow I32 {}

// nng_sendmsg is like nng_send, but offers up a message structure, which
// gives the ability to provide more control over the message, including
// providing backtrace information.  It also can take a message that was
// obtained via nn_recvmsg, allowing for zero copy forwarding.
nng_sendmsg := ext_proc(shallow _arg : nng_socket, mut _arg : nng_msg, shallow _arg : I32) returns shallow I32 {}

// nng_recvmsg is like nng_recv, but is used to obtain a message structure
// as well as the data buffer.  This can be used to obtain more information
// about where the message came from, access raw headers, etc.  It also
// can be passed off directly to nng_sendmsg.
nng_recvmsg := ext_proc(shallow _arg : nng_socket, mut _arg : Dynamic, shallow _arg : I32) returns shallow I32 {}

// nng_sock_send sends data on the socket asynchronously.  As with nng_send,
// the completion may be executed before the data has actually been delivered,
// but only when it is accepted for delivery.  The supplied AIO must have
// been initialized, and have an associated message.  The message will be
// "owned" by the socket if the operation completes successfully.  Otherwise,
// the caller is responsible for freeing it.
nng_sock_send := ext_proc(shallow _arg : nng_socket, mut _arg : nng_aio) {}

// Compatible alias for nng_sock_send.
nng_send_aio := ext_proc(shallow _arg : nng_socket, mut _arg : nng_aio) {}

// nng_sock_recv receives data on the socket asynchronously.  On a successful
// result, the AIO will have an associated message, that can be obtained
// with nng_aio_get_msg().  The caller takes ownership of the message at
// this point.
nng_sock_recv := ext_proc(shallow _arg : nng_socket, mut _arg : nng_aio) {}

// Compatible alias for nng_sock_recv.
nng_recv_aio := ext_proc(shallow _arg : nng_socket, mut _arg : nng_aio) {}

// Context support.  User contexts are not supported by all protocols,
// but for those that do, they give a way to create multiple contexts
// on a single socket, each of which runs the protocol's state machinery
// independently, offering a way to achieve concurrent protocol support
// without resorting to raw mode sockets.  See the protocol specific
// documentation for further details.  (Note that at this time, only
// asynchronous send/recv are supported for contexts, but its easy enough
// to make synchronous versions with nng_aio_wait().)  Note that nng_close
// of the parent socket will *block* as long as any contexts are open.

// nng_ctx_open creates a context.  This returns NNG_ENOTSUP if the
// protocol implementation does not support separate contexts.
nng_ctx_open := ext_proc(mut _arg : nng_ctx, shallow _arg : nng_socket) returns shallow I32 {}

// nng_ctx_close closes the context.
nng_ctx_close := ext_proc(shallow _arg : nng_ctx) returns shallow I32 {}

// nng_ctx_id returns the numeric id for the context; this will be
// a positive value for a valid context, or < 0 for an invalid context.
// A valid context is not necessarily an *open* context.
nng_ctx_id := ext_proc(shallow _arg : nng_ctx) returns shallow I32 {}

// nng_ctx_recv receives asynchronously.  It works like nng_sock_recv, but
// uses a local context instead of the socket global context.
nng_ctx_recv := ext_proc(shallow _arg : nng_ctx, mut _arg : nng_aio) {}

// nng_ctx_recvmsg allows for receiving a message synchronously using
// a context.  It has the same semantics as nng_recvmsg, but operates
// on a context instead of a socket.
nng_ctx_recvmsg := ext_proc(shallow _arg : nng_ctx, mut _arg : Dynamic, shallow _arg : I32) returns shallow I32 {}

// nng_ctx_send sends asynchronously. It works like nng_sock_send, but
// uses a local context instead of the socket global context.
nng_ctx_send := ext_proc(shallow _arg : nng_ctx, mut _arg : nng_aio) {}

// nng_ctx_sendmsg is allows for sending a message synchronously using
// a context.  It has the same semantics as nng_sendmsg, but operates
// on a context instead of a socket.
nng_ctx_sendmsg := ext_proc(shallow _arg : nng_ctx, mut _arg : nng_msg, shallow _arg : I32) returns shallow I32 {}

nng_ctx_get := ext_proc(shallow _arg : nng_ctx, _arg : I8, mut _arg : Dynamic, mut _arg : USize) returns shallow I32 {}
nng_ctx_get_bool := ext_proc(shallow _arg : nng_ctx, _arg : I8, mut _arg : Bool) returns shallow I32 {}
nng_ctx_get_int := ext_proc(shallow _arg : nng_ctx, _arg : I8, mut _arg : I32) returns shallow I32 {}
nng_ctx_get_size := ext_proc(shallow _arg : nng_ctx, _arg : I8, mut _arg : USize) returns shallow I32 {}
nng_ctx_get_uint64 := ext_proc(shallow _arg : nng_ctx, _arg : I8, mut _arg : U64) returns shallow I32 {}
nng_ctx_get_string := ext_proc(shallow _arg : nng_ctx, _arg : I8, mut _arg : Dynamic) returns shallow I32 {}
nng_ctx_get_ptr := ext_proc(shallow _arg : nng_ctx, _arg : I8, mut _arg : Dynamic) returns shallow I32 {}
nng_ctx_get_ms := ext_proc(shallow _arg : nng_ctx, _arg : I8, mut _arg : nng_duration) returns shallow I32 {}

nng_ctx_set := ext_proc(shallow _arg : nng_ctx, _arg : I8, _arg : Dynamic, shallow _arg : USize) returns shallow I32 {}
nng_ctx_set_bool := ext_proc(shallow _arg : nng_ctx, _arg : I8, shallow _arg : Bool) returns shallow I32 {}
nng_ctx_set_int := ext_proc(shallow _arg : nng_ctx, _arg : I8, shallow _arg : I32) returns shallow I32 {}
nng_ctx_set_size := ext_proc(shallow _arg : nng_ctx, _arg : I8, shallow _arg : USize) returns shallow I32 {}
nng_ctx_set_uint64 := ext_proc(shallow _arg : nng_ctx, _arg : I8, shallow _arg : U64) returns shallow I32 {}
nng_ctx_set_string := ext_proc(shallow _arg : nng_ctx, _arg : I8, _arg : I8) returns shallow I32 {}
nng_ctx_set_ptr := ext_proc(shallow _arg : nng_ctx, _arg : I8, mut _arg : Dynamic) returns shallow I32 {}
nng_ctx_set_ms := ext_proc(shallow _arg : nng_ctx, _arg : I8, shallow _arg : nng_duration) returns shallow I32 {}

// nng_alloc is used to allocate memory.  It's intended purpose is for
// allocating memory suitable for message buffers with nng_send().
// Applications that need memory for other purposes should use their platform
// specific API.
nng_alloc := ext_proc(shallow _arg : USize) returns Dynamic {}

// nng_free is used to free memory allocated with nng_alloc, which includes
// memory allocated by nng_recv() when the NNG_FLAG_ALLOC message is supplied.
// As the application is required to keep track of the size of memory, this
// is probably less convenient for general uses than the C library malloc and
// calloc.
nng_free := ext_proc(mut _arg : Dynamic, shallow _arg : USize) {}

// nng_strdup duplicates the source string, using nng_alloc. The result
// should be freed with nng_strfree (or nng_free(strlen(s)+1)).
nng_strdup := ext_proc(_arg : I8) returns ref I8 {}

// nng_strfree is equivalent to nng_free(strlen(s)+1).
nng_strfree := ext_proc(mut _arg : I8) {}

// Async IO API.  AIO structures can be thought of as "handles" to
// support asynchronous operations.  They contain the completion callback, and
// a pointer to consumer data.  This is similar to how overlapped I/O
// works in Windows, when used with a completion callback.
//
// AIO structures can carry up to 4 distinct input values, and up to
// 4 distinct output values, and up to 4 distinct "private state" values.
// The meaning of the inputs and the outputs are determined by the
// I/O functions being called.

// nng_aio_alloc allocates a new AIO, and associated the completion
// callback and its opaque argument.  If NULL is supplied for the
// callback, then the caller must use nng_aio_wait() to wait for the
// operation to complete.  If the completion callback is not NULL, then
// when a submitted operation completes (or is canceled or fails) the
// callback will be executed, generally in a different thread, with no
// locks held.

// nng_aio_free frees the AIO and any associated resources.
// It *must not* be in use at the time it is freed.
nng_aio_free := ext_proc(mut _arg : nng_aio) {}

// nng_aio_reap is like nng_aio_free, but calls it from a background
// reaper thread.  This can be useful to free aio objects from aio
// callbacks (e.g. when the result of the callback is to discard
// the object in question.)  The aio object must be in further use
// when this is called.
nng_aio_reap := ext_proc(mut _arg : nng_aio) {}

// nng_aio_stop stops any outstanding operation, and waits for the
// AIO to be free, including for the callback to have completed
// execution.  Therefore, the caller must NOT hold any locks that
// are acquired in the callback, or deadlock will occur.
nng_aio_stop := ext_proc(mut _arg : nng_aio) {}

// nng_aio_result returns the status/result of the operation. This
// will be zero on successful completion, or an nng error code on
// failure.
nng_aio_result := ext_proc(mut _arg : nng_aio) returns shallow I32 {}

// nng_aio_count returns the number of bytes transferred for certain
// I/O operations.  This is meaningless for other operations (e.g.
// DNS lookups or TCP connection setup).
nng_aio_count := ext_proc(mut _arg : nng_aio) returns shallow USize {}

// nng_aio_cancel attempts to cancel any in-progress I/O operation.
// The AIO callback will still be executed, but if the cancellation is
// successful then the status will be NNG_ECANCELED.
nng_aio_cancel := ext_proc(mut _arg : nng_aio) {}

// nng_aio_abort is like nng_aio_cancel, but allows for a different
// error result to be returned.
nng_aio_abort := ext_proc(mut _arg : nng_aio, shallow _arg : I32) {}

// nng_aio_wait waits synchronously for any pending operation to complete.
// It also waits for the callback to have completed execution.  Therefore,
// the caller of this function must not hold any locks acquired by the
// callback or deadlock may occur.
nng_aio_wait := ext_proc(mut _arg : nng_aio) {}

// nng_aio_busy returns true if the aio is still busy processing the
// operation, or executing associated completion functions.  Note that
// if the completion function schedules a new operation using the aio,
// then this function will continue to return true.
nng_aio_busy := ext_proc(mut _arg : nng_aio) returns shallow Bool {}

// nng_aio_set_msg sets the message structure to use for asynchronous
// message send operations.
nng_aio_set_msg := ext_proc(mut _arg : nng_aio, mut _arg : nng_msg) {}

// nng_aio_get_msg returns the message structure associated with a completed
// receive operation.
nng_aio_get_msg := ext_proc(mut _arg : nng_aio) returns ref nng_msg {}

// nng_aio_set_input sets an input parameter at the given index.
nng_aio_set_input := ext_proc(mut _arg : nng_aio, shallow _arg : U32, mut _arg : Dynamic) returns shallow I32 {}

// nng_aio_get_input retrieves the input parameter at the given index.
nng_aio_get_input := ext_proc(mut _arg : nng_aio, shallow _arg : U32) returns Dynamic {}

// nng_aio_set_output sets an output result at the given index.
nng_aio_set_output := ext_proc(mut _arg : nng_aio, shallow _arg : U32, mut _arg : Dynamic) returns shallow I32 {}

// nng_aio_get_output retrieves the output result at the given index.
nng_aio_get_output := ext_proc(mut _arg : nng_aio, shallow _arg : U32) returns Dynamic {}

// nng_aio_set_timeout sets a timeout on the AIO.  This should be called for
// operations that should time out after a period.  The timeout should be
// either a positive number of milliseconds, or NNG_DURATION_INFINITE to
// indicate that the operation has no timeout.  A poll may be done by
// specifying NNG_DURATION_ZERO.  The value NNG_DURATION_DEFAULT indicates
// that any socket specific timeout should be used.
nng_aio_set_timeout := ext_proc(mut _arg : nng_aio, shallow _arg : nng_duration) {}

// nng_aio_set_expire is like nng_aio_set_timeout, except it sets an absolute
// expiration time.  This is useful when chaining actions on a single aio
// as part of a state machine.
nng_aio_set_expire := ext_proc(mut _arg : nng_aio, shallow _arg : nng_time) {}

// nng_aio_set_iov sets a scatter/gather vector on the aio.  The iov array
// itself is copied. Data members (the memory regions referenced) *may* be
// copied as well, depending on the operation.  This operation is guaranteed
// to succeed if n <= 4, otherwise it may fail due to NNG_ENOMEM.
nng_aio_set_iov := ext_proc(mut _arg : nng_aio, shallow _arg : U32, _arg : nng_iov) returns shallow I32 {}

// nng_aio_begin is called by the provider to mark the operation as
// beginning.  If it returns false, then the provider must take no
// further action on the aio.
nng_aio_begin := ext_proc(mut _arg : nng_aio) returns shallow Bool {}

// nng_aio_finish is used to "finish" an asynchronous operation.
// It should only be called by "providers" (such as HTTP server API users).
// The argument is the value that nng_aio_result() should return.
// IMPORTANT: Callers must ensure that this is called EXACTLY ONCE on any
// given aio.
nng_aio_finish := ext_proc(mut _arg : nng_aio, shallow _arg : I32) {}

// nng_aio_defer is used to register a cancellation routine, and indicate
// that the operation will be completed asynchronously.  It must only be
// called once per operation on an aio, and must only be called by providers.
// If the operation is canceled by the consumer, the cancellation callback
// will be called.  The provider *must* still ensure that the nng_aio_finish()
// function is called EXACTLY ONCE.  If the operation cannot be canceled
// for any reason, the cancellation callback should do nothing.  The
// final argument is passed to the cancelfn.  The final argument of the
// cancellation function is the error number (will not be zero) corresponding
// to the reason for cancellation, e.g. NNG_ETIMEDOUT or NNG_ECANCELED.
nng_aio_cancelfn := Dynamic

nng_aio_defer := ext_proc(mut _arg : nng_aio, _arg : nng_aio_cancelfn, mut _arg : Dynamic) {}

// nng_aio_sleep does a "sleeping" operation, basically does nothing
// but wait for the specified number of milliseconds to expire, then
// calls the callback.  This returns 0, rather than NNG_ETIMEDOUT.
nng_sleep_aio := ext_proc(shallow _arg : nng_duration, mut _arg : nng_aio) {}

// Message API.
nng_msg_alloc := ext_proc(mut _arg : Dynamic, shallow _arg : USize) returns shallow I32 {}
nng_msg_free := ext_proc(mut _arg : nng_msg) {}
nng_msg_realloc := ext_proc(mut _arg : nng_msg, shallow _arg : USize) returns shallow I32 {}
nng_msg_reserve := ext_proc(mut _arg : nng_msg, shallow _arg : USize) returns shallow I32 {}
nng_msg_capacity := ext_proc(mut _arg : nng_msg) returns shallow USize {}
nng_msg_header := ext_proc(mut _arg : nng_msg) returns Dynamic {}
nng_msg_header_len := ext_proc(_arg : nng_msg) returns shallow USize {}
nng_msg_body := ext_proc(mut _arg : nng_msg) returns Dynamic {}
nng_msg_len := ext_proc(_arg : nng_msg) returns shallow USize {}
nng_msg_append := ext_proc(mut _arg : nng_msg, _arg : Dynamic, shallow _arg : USize) returns shallow I32 {}
nng_msg_insert := ext_proc(mut _arg : nng_msg, _arg : Dynamic, shallow _arg : USize) returns shallow I32 {}
nng_msg_trim := ext_proc(mut _arg : nng_msg, shallow _arg : USize) returns shallow I32 {}
nng_msg_chop := ext_proc(mut _arg : nng_msg, shallow _arg : USize) returns shallow I32 {}
nng_msg_header_append := ext_proc(mut _arg : nng_msg, _arg : Dynamic, shallow _arg : USize) returns shallow I32 {}
nng_msg_header_insert := ext_proc(mut _arg : nng_msg, _arg : Dynamic, shallow _arg : USize) returns shallow I32 {}
nng_msg_header_trim := ext_proc(mut _arg : nng_msg, shallow _arg : USize) returns shallow I32 {}
nng_msg_header_chop := ext_proc(mut _arg : nng_msg, shallow _arg : USize) returns shallow I32 {}
nng_msg_header_append_u16 := ext_proc(mut _arg : nng_msg, shallow _arg : U16) returns shallow I32 {}
nng_msg_header_append_u32 := ext_proc(mut _arg : nng_msg, shallow _arg : U32) returns shallow I32 {}
nng_msg_header_append_u64 := ext_proc(mut _arg : nng_msg, shallow _arg : U64) returns shallow I32 {}
nng_msg_header_insert_u16 := ext_proc(mut _arg : nng_msg, shallow _arg : U16) returns shallow I32 {}
nng_msg_header_insert_u32 := ext_proc(mut _arg : nng_msg, shallow _arg : U32) returns shallow I32 {}
nng_msg_header_insert_u64 := ext_proc(mut _arg : nng_msg, shallow _arg : U64) returns shallow I32 {}
nng_msg_header_chop_u16 := ext_proc(mut _arg : nng_msg, mut _arg : U16) returns shallow I32 {}
