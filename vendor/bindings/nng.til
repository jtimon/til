nng_listener_setopt_string := ext_proc(shallow _arg : nng_listener, _arg : I8, _arg : I8) returns shallow I32 {}

// Pipe options.  Use nng_pipe_get instead.
nng_pipe_getopt := ext_proc(shallow _arg : nng_pipe, _arg : I8, mut _arg : Dynamic, mut _arg : USize) returns shallow I32 {}
nng_pipe_getopt_bool := ext_proc(shallow _arg : nng_pipe, _arg : I8, mut _arg : Bool) returns shallow I32 {}
nng_pipe_getopt_int := ext_proc(shallow _arg : nng_pipe, _arg : I8, mut _arg : I32) returns shallow I32 {}
nng_pipe_getopt_ms := ext_proc(shallow _arg : nng_pipe, _arg : I8, mut _arg : nng_duration) returns shallow I32 {}
nng_pipe_getopt_size := ext_proc(shallow _arg : nng_pipe, _arg : I8, mut _arg : USize) returns shallow I32 {}
nng_pipe_getopt_sockaddr := ext_proc(shallow _arg : nng_pipe, _arg : I8, mut _arg : nng_sockaddr) returns shallow I32 {}
nng_pipe_getopt_uint64 := ext_proc(shallow _arg : nng_pipe, _arg : I8, mut _arg : U64) returns shallow I32 {}
nng_pipe_getopt_ptr := ext_proc(shallow _arg : nng_pipe, _arg : I8, mut _arg : Dynamic) returns shallow I32 {}
nng_pipe_getopt_string := ext_proc(shallow _arg : nng_pipe, _arg : I8, mut _arg : Dynamic) returns shallow I32 {}

// nng_closeall closes all open sockets. Do not call this from
// a library; it will affect all sockets.
nng_closeall := ext_proc() {}

// THese functions are deprecated, but they really serve no useful purpose.
nng_stream_set_addr := ext_proc(mut _arg : nng_stream, _arg : I8, _arg : nng_sockaddr) returns shallow I32 {}
nng_ctx_get_addr := ext_proc(shallow _arg : nng_ctx, _arg : I8, mut _arg : nng_sockaddr) returns shallow I32 {}
nng_ctx_set_addr := ext_proc(shallow _arg : nng_ctx, _arg : I8, _arg : nng_sockaddr) returns shallow I32 {}

// nng_init_parameter is used by applications to change a tunable setting.
// This function must be called before any other NNG function for the setting
// to have any effect.  This function is also not thread-safe!
//
// The list of parameters supported is *not* documented, and subject to change.
//
// We try to provide sane defaults, so the use here is intended to provide
// more control for applications that cannot use compile-time configuration.
//
// Applications should not depend on this API for correct operation.
//
// This API is intentionally undocumented.
//
// Parameter settings are lost after nng_fini() is called.
nng_init_parameter := I32

nng_init_set_parameter := ext_proc(shallow _arg : nng_init_parameter, shallow _arg : U64) {}

// The following list of parameters is not part of our API stability promise.
// In particular the set of parameters that are supported, the default values,
// the range of valid values, and semantics associated therein are subject to
// change at any time.  We won't go out of our way to break these, and we will
// try to prevent changes here from breaking working applications, but this is
// on a best effort basis only.
//
// NOTE: When removing a value, please leave the enumeration in place and add
// a suffix _RETIRED ... this will preserve the binary values for binary
// compatibility.

// Logging support.

// Log levels.  These correspond to RFC 5424 (syslog) levels.
// NNG never only uses priorities 3 - 7.
//
// Note that LOG_EMER is 0, but we don't let applications submit'
// such messages, so this is a useful value to prevent logging altogether.
nng_log_level := I32

NNG_LOG_NONE : I32 = 0
NNG_LOG_ERR : I32 = 3
NNG_LOG_WARN : I32 = 4
NNG_LOG_NOTICE : I32 = 5
NNG_LOG_INFO : I32 = 6
NNG_LOG_DEBUG : I32 = 7

// Facilities.  Also from RFC 5424.
// Not all values are enumerated here. Values not enumerated here
// should be assumed reserved for system use, and not available for
// NNG or general applications.
nng_log_facility := I32

NNG_LOG_USER : I32 = 1
NNG_LOG_DAEMON : I32 = 3
NNG_LOG_AUTH : I32 = 10
NNG_LOG_LOCAL0 : I32 = 16
NNG_LOG_LOCAL1 : I32 = 17
NNG_LOG_LOCAL2 : I32 = 18
NNG_LOG_LOCAL3 : I32 = 19
NNG_LOG_LOCAL4 : I32 = 20
NNG_LOG_LOCAL5 : I32 = 21
NNG_LOG_LOCAL6 : I32 = 22
NNG_LOG_LOCAL7 : I32 = 23

// Logging function, which may be supplied by application code.  Only
// one logging function may be registered.  The level and facility are
// as above.  The message ID is chosen by the submitter - internal NNG
// messages will have MSGIDs starting with "NNG-".  The MSGID should be
// not more than 8 characters, though this is not a hard requirement.
// Loggers are required ot make a copy of the msgid and message if required,
// because the values will not be valid once the logger returns.

// Function-pointer typedef from C; opaque here.
nng_logger := Dynamic

// Discard logger, simply throws logs away.
nng_null_logger := ext_proc(shallow _arg : nng_log_level, shallow _arg : nng_log_facility, _arg : I8, _arg : I8) {}

// Very simple, prints formatted messages to stderr.
nng_stderr_logger := ext_proc(shallow _arg : nng_log_level, shallow _arg : nng_log_facility, _arg : I8, _arg : I8) {}

// Performs an appropriate logging function for the system.  On
// POSIX systems it uses syslog(3).  Details vary by system, and the
// logging may be influenced by other APIs not provided by NNG, such as
// openlog() for POSIX systems.  This may be nng_stderr_logger on
// other systems.
nng_system_logger := ext_proc(shallow _arg : nng_log_level, shallow _arg : nng_log_facility, _arg : I8, _arg : I8) {}

// Set the default facility to use when logging.  NNG uses NNG_LOG_USER by
// default.
nng_log_set_facility := ext_proc(shallow facility : nng_log_facility) {}

// Set the default logging level.  Use NNG_LOG_DEBUG to get everything.
// Use NNG_LOG_NONE to prevent logging altogether.  Logs that are less
// severe (numeric level is higher) will be discarded.
nng_log_set_level := ext_proc(shallow level : nng_log_level) {}

// Get the current logging level.  The intention here os to allow
// bypassing expensive formatting operations that will be discarded
// anyway.
nng_log_get_level := ext_proc() returns shallow nng_log_level {}

// Register a logger.
nng_log_set_logger := ext_proc(logger : nng_logger) {}

// Log a message.  The msg is formatted using following arguments as per
// sprintf. The msgid may be NULL.

// Log an authentication related message.  These will use the NNG_LOG_AUTH
// facility.

// Return an absolute time from some arbitrary point.  The value is
// provided in milliseconds, and is of limited resolution based on the
// system clock.  (Do not use it for fine-grained performance measurements.)
nng_clock := ext_proc() returns shallow nng_time {}

// Sleep for specified msecs.
nng_msleep := ext_proc(shallow _arg : nng_duration) {}

// nng_random returns a "strong" (cryptographic sense) random number.
nng_random := ext_proc() returns shallow U32 {}

// nng_socket_pair is used to create a bound pair of file descriptors
// typically using the socketpair() call.  The descriptors are backed
// by reliable, bidirectional, byte streams.  This will return NNG_ENOTSUP
// if the platform lacks support for this.  The argument is a pointer
// to an array of file descriptors (or HANDLES or similar).
nng_socket_pair := ext_proc(mut _arg : I32) returns shallow I32 {}

// Multithreading and synchronization functions.

// nng_thread is a handle to a "thread", which may be a real system
// thread, or a coroutine on some platforms.
nng_thread := ext_struct("nng_thread") {}

// Create and start a thread.  Note that on some platforms, this might
// actually be a coroutine, with limitations about what system APIs
// you can call.  Therefore, these threads should only be used with the
// I/O APIs provided by nng.  The thread runs until completion.

// Set the thread name.  Support for this is platform specific and varies.
// It is intended to provide information for use when debugging applications,
// and not for programmatic use beyond that.
nng_thread_set_name := ext_proc(mut _arg : nng_thread, _arg : I8) {}

// Destroy a thread (waiting for it to complete.)  When this function
// returns all resources for the thread are cleaned up.
nng_thread_destroy := ext_proc(mut _arg : nng_thread) {}

// nng_mtx represents a mutex, which is a simple, non-reentrant, boolean lock.
nng_mtx := ext_struct("nng_mtx") {}

// nng_mtx_alloc allocates a mutex structure.
nng_mtx_alloc := ext_proc(mut _arg : Dynamic) returns shallow I32 {}

// nng_mtx_free frees the mutex.  It must not be locked.
nng_mtx_free := ext_proc(mut _arg : nng_mtx) {}

// nng_mtx_lock locks the mutex; if it is already locked it will block
// until it can be locked.  If the caller already holds the lock, the
// results are undefined (a panic may occur).
nng_mtx_lock := ext_proc(mut _arg : nng_mtx) {}

// nng_mtx_unlock unlocks a previously locked mutex.  It is an error to
// call this on a mutex which is not owned by caller.
nng_mtx_unlock := ext_proc(mut _arg : nng_mtx) {}

// nng_cv is a condition variable.  It is always allocated with an
// associated mutex, which must be held when waiting for it, or
// when signaling it.
nng_cv := ext_struct("nng_cv") {}

nng_cv_alloc := ext_proc(mut _arg : Dynamic, mut _arg : nng_mtx) returns shallow I32 {}

// nng_cv_free frees the condition variable.
nng_cv_free := ext_proc(mut _arg : nng_cv) {}

// nng_cv_wait waits until the condition variable is "signaled".
nng_cv_wait := ext_proc(mut _arg : nng_cv) {}

// nng_cv_until waits until either the condition is signaled, or
// the timeout expires.  It returns NNG_ETIMEDOUT in that case.
nng_cv_until := ext_proc(mut _arg : nng_cv, shallow _arg : nng_time) returns shallow I32 {}

// nng_cv_wake wakes all threads waiting on the condition.
nng_cv_wake := ext_proc(mut _arg : nng_cv) {}

// nng_cv_wake1 wakes only one thread waiting on the condition.  This may
// reduce the thundering herd problem, but care must be taken to ensure
// that no waiter starves forever.
nng_cv_wake1 := ext_proc(mut _arg : nng_cv) {}

// New URL accessors for endpoints - from NNG 2.0.
nng_dialer_get_url := ext_proc(shallow _arg : nng_dialer, _arg : Dynamic) returns shallow I32 {}
nng_listener_get_url := ext_proc(shallow _arg : nng_listener, _arg : Dynamic) returns shallow I32 {}

// --- Protocol constructors ---
//
// These live in nng/protocol/<proto>/<proto>.h, not in nng.h, so the
// binder (which processes a single header) does not see them. They are
// hand-added here. Each opens a socket of the given protocol, writing the
// handle into the nng_socket out-parameter (passed non-shallow, i.e. by
// address, so the C side fills in the caller's struct). ext_proc: opening
// a socket allocates kernel/library state -- never fold at compile time.
// The unsuffixed names (nng_pair_open etc.) are C macros aliasing these
// numbered symbols; bind the real symbols.

nng_bus0_open := ext_proc(mut sock : nng_socket) returns shallow I32 {}
nng_bus0_open_raw := ext_proc(mut sock : nng_socket) returns shallow I32 {}

nng_pair0_open := ext_proc(mut sock : nng_socket) returns shallow I32 {}
nng_pair0_open_raw := ext_proc(mut sock : nng_socket) returns shallow I32 {}

nng_pair1_open := ext_proc(mut sock : nng_socket) returns shallow I32 {}
nng_pair1_open_raw := ext_proc(mut sock : nng_socket) returns shallow I32 {}
nng_pair1_open_poly := ext_proc(mut sock : nng_socket) returns shallow I32 {}

nng_push0_open := ext_proc(mut sock : nng_socket) returns shallow I32 {}
nng_push0_open_raw := ext_proc(mut sock : nng_socket) returns shallow I32 {}
nng_pull0_open := ext_proc(mut sock : nng_socket) returns shallow I32 {}
nng_pull0_open_raw := ext_proc(mut sock : nng_socket) returns shallow I32 {}

nng_pub0_open := ext_proc(mut sock : nng_socket) returns shallow I32 {}
nng_pub0_open_raw := ext_proc(mut sock : nng_socket) returns shallow I32 {}
nng_sub0_open := ext_proc(mut sock : nng_socket) returns shallow I32 {}
nng_sub0_open_raw := ext_proc(mut sock : nng_socket) returns shallow I32 {}

nng_req0_open := ext_proc(mut sock : nng_socket) returns shallow I32 {}
nng_req0_open_raw := ext_proc(mut sock : nng_socket) returns shallow I32 {}
nng_rep0_open := ext_proc(mut sock : nng_socket) returns shallow I32 {}
nng_rep0_open_raw := ext_proc(mut sock : nng_socket) returns shallow I32 {}

nng_surveyor0_open := ext_proc(mut sock : nng_socket) returns shallow I32 {}
nng_surveyor0_open_raw := ext_proc(mut sock : nng_socket) returns shallow I32 {}
nng_respondent0_open := ext_proc(mut sock : nng_socket) returns shallow I32 {}
nng_respondent0_open_raw := ext_proc(mut sock : nng_socket) returns shallow I32 {}

