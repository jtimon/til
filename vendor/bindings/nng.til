nng_msg_header_trim_u64 := ext_proc(mut _arg : nng_msg, mut _arg : U64) returns shallow I32 {}
nng_msg_append_u16 := ext_proc(mut _arg : nng_msg, shallow _arg : U16) returns shallow I32 {}
nng_msg_append_u32 := ext_proc(mut _arg : nng_msg, shallow _arg : U32) returns shallow I32 {}
nng_msg_append_u64 := ext_proc(mut _arg : nng_msg, shallow _arg : U64) returns shallow I32 {}
