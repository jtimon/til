/* ---- System specific configurations ----------------------------------- */

/* For code common to all platforms on x86 and x86_64. */

/* ---- Generic type definitions ----------------------------------------- */
ffi_arg := U64

ffi_sarg := I64

ffi_abi := I32

FFI_FIRST_ABI : I32 = 1.to_i32()
FFI_UNIX64 : I32 = 2.to_i32()
FFI_WIN64 : I32 = 3.to_i32()
FFI_EFI64 : I32 = 3.to_i32()
FFI_GNUW64 : I32 = 4.to_i32()
FFI_LAST_ABI : I32 = 5.to_i32()
FFI_DEFAULT_ABI : I32 = 2.to_i32()

/* ---- Definitions for closures ----------------------------------------- */

FFI_CLOSURES : I64 = 1
FFI_GO_CLOSURES : I64 = 1

/* 4 bytes of ENDBR64 + 7 bytes of LEA + 6 bytes of JMP + 7 bytes of NOP
   + 8 bytes of pointer.  */
FFI_TRAMPOLINE_SIZE : I64 = 32
FFI_NATIVE_RAW_API : I64 = 0

/* LONG_LONG_MAX is not always defined (not if STRICT_ANSI, for example).
   But we can find it either under the correct ANSI name, or under GNU
   C's internal name.  */

FFI_64_BIT_MAX : I64 = 9223372036854775807

/* The closure code assumes that this works on pointers, i.e. a size_t
   can hold a pointer.  */

ffi_type := ext_struct("_ffi_type") {
    mut size : USize = 0
    mut alignment : I16 = 0
    mut type : I16 = 0
    ref mut elements : Dynamic = NULL
}

/* Need minimal decorations for DLLs to work on Windows.  GCC has
   autoimport and autoexport.  Always mark externally visible symbols
   as dllimport for MSVC clients, even if it means an extra indirection
   when using the static version of the library.
   Besides, as a workaround, they can define FFI_BUILDING if they
   *know* they are going to link with the static library.  */

/* The externally visible type declarations also need the MSVC DLL
   decorations, or they will not be exported from the object file.  */

/* These are defined in types.c.  */

ffi_status := I32

FFI_OK : I32 = 0.to_i32()
FFI_BAD_TYPEDEF : I32 = 1.to_i32()
FFI_BAD_ABI : I32 = 2.to_i32()
FFI_BAD_ARGTYPE : I32 = 3.to_i32()

ffi_cif := ext_struct("") {
    mut abi : ffi_abi = 0
    mut nargs : U32 = 0
    ref mut arg_types : Dynamic = NULL
    ref mut rtype : ffi_type = NULL
    mut bytes : U32 = 0
    mut flags : U32 = 0
}

/* ---- Definitions for the raw API -------------------------------------- */

FFI_SIZEOF_ARG : I64 = 8

ffi_raw := Dynamic  // typedef union from C, opaque here

ffi_java_raw := ffi_raw

ffi_raw_call := ext_proc(cif : ffi_cif, fn : Dynamic, rvalue : Dynamic, avalue : ffi_raw) {}

ffi_ptrarray_to_raw := ext_proc(cif : ffi_cif, args : Dynamic, raw : ffi_raw) {}
ffi_raw_to_ptrarray := ext_proc(cif : ffi_cif, raw : ffi_raw, args : Dynamic) {}
ffi_raw_size := ext_func(cif : ffi_cif) returns shallow USize {}

/* This is analogous to the raw API, except it uses Java parameter
   packing, even on 64-bit machines.  I.e. on 64-bit machines longs
   and doubles are followed by an empty 64-bit word.  */

ffi_java_raw_call := ext_proc(cif : ffi_cif, fn : Dynamic, rvalue : Dynamic, avalue : ffi_java_raw) {}

ffi_java_ptrarray_to_raw := ext_proc(cif : ffi_cif, args : Dynamic, raw : ffi_java_raw) {}

ffi_java_raw_to_ptrarray := ext_proc(cif : ffi_cif, raw : ffi_java_raw, args : Dynamic) {}

ffi_java_raw_size := ext_func(cif : ffi_cif) returns shallow USize {}

/* ---- Definitions for closures ----------------------------------------- */

ffi_closure := ext_struct("") {}  // opaque: unsupported field shape

ffi_closure_alloc := ext_func(shallow size : USize, code : Dynamic) returns Dynamic {}
ffi_closure_free := ext_proc(_arg : Dynamic) {}

ffi_prep_closure_loc := ext_func(_arg : ffi_closure, _arg : ffi_cif, fun : Dynamic, user_data : Dynamic, codeloc : Dynamic) returns shallow ffi_status {}

ffi_raw_closure := ext_struct("") {}  // opaque: unsupported field shape

ffi_java_raw_closure := ext_struct("") {}  // opaque: unsupported field shape

ffi_prep_raw_closure := ext_func(_arg : ffi_raw_closure, cif : ffi_cif, fun : Dynamic, user_data : Dynamic) returns shallow ffi_status {}

ffi_prep_raw_closure_loc := ext_func(_arg : ffi_raw_closure, cif : ffi_cif, fun : Dynamic, user_data : Dynamic, codeloc : Dynamic) returns shallow ffi_status {}

ffi_prep_java_raw_closure := ext_func(_arg : ffi_java_raw_closure, cif : ffi_cif, fun : Dynamic, user_data : Dynamic) returns shallow ffi_status {}

ffi_prep_java_raw_closure_loc := ext_func(_arg : ffi_java_raw_closure, cif : ffi_cif, fun : Dynamic, user_data : Dynamic, codeloc : Dynamic) returns shallow ffi_status {}

ffi_go_closure := ext_struct("") {}  // opaque: unsupported field shape

ffi_prep_go_closure := ext_func(_arg : ffi_go_closure, _arg : ffi_cif, fun : Dynamic) returns shallow ffi_status {}

ffi_call_go := ext_proc(cif : ffi_cif, fn : Dynamic, rvalue : Dynamic, avalue : Dynamic, closure : Dynamic) {}

/* ---- Public interface definition -------------------------------------- */

ffi_prep_cif := ext_func(cif : ffi_cif, shallow abi : ffi_abi, shallow nargs : U32, rtype : ffi_type, atypes : Dynamic) returns shallow ffi_status {}

ffi_prep_cif_var := ext_func(cif : ffi_cif, shallow abi : ffi_abi, shallow nfixedargs : U32, shallow ntotalargs : U32, rtype : ffi_type, atypes : Dynamic) returns shallow ffi_status {}

ffi_call := ext_proc(cif : ffi_cif, fn : Dynamic, rvalue : Dynamic, avalue : Dynamic) {}

ffi_get_struct_offsets := ext_func(shallow abi : ffi_abi, struct_type : ffi_type, offsets : USize) returns shallow ffi_status {}

/* Convert between closure and function pointers.  */

/* ---- Definitions shared with assembly code ---------------------------- */

