mode test

test_i64_map := test() {
    m := Map.new(I64, I64)
    m.set(3, own 30)
    m.set(1, own 10)
    m.set(2, own 20)
    assert_eq(__LOC__, m.len().to_i64(), 3)
    assert(__LOC__, m.has(1))
    assert(__LOC__, m.has(2))
    assert(__LOC__, m.has(3))
    assert(__LOC__, m.has(4).not())

    ref v1 : I64 = m[1]
    ref v2 : I64 = m[2]
    ref v3 : I64 = m[3]
    assert_eq(__LOC__, v1, 10)
    assert_eq(__LOC__, v2, 20)
    assert_eq(__LOC__, v3, 30)

    // overwrite existing key
    m.set(2, own 99)
    assert_eq(__LOC__, m.len().to_i64(), 3)
    ref v2b : I64 = m[2]
    assert_eq(__LOC__, v2b, 99)
}

test_str_map := test() {
    sm := Map.new(Str, I64)
    sm.set("banana", own 2)
    sm.set("apple", own 1)
    sm.set("cherry", own 3)
    assert_eq(__LOC__, sm.len().to_i64(), 3)
    assert(__LOC__, sm.has("apple"))
    assert(__LOC__, sm.has("banana"))
    assert(__LOC__, sm.has("cherry"))
    assert(__LOC__, sm.has("date").not())
    ref sa : I64 = sm["apple"]
    ref sb : I64 = sm["banana"]
    assert_eq(__LOC__, sa, 1)
    assert_eq(__LOC__, sb, 2)
}

// --- Map literal tests ---

test_map_literal_str_i64 := test() {
    m : Map = {"a": 1, "b": 2, "c": 3}
    assert_eq(__LOC__, m.len().to_i64(), 3)
    assert(__LOC__, m.has("a"))
    assert(__LOC__, m.has("b"))
    assert(__LOC__, m.has("c"))
    ref va : I64 = m["a"]
    ref vb : I64 = m["b"]
    assert_eq(__LOC__, va, 1)
    assert_eq(__LOC__, vb, 2)
}

test_map_literal_i64_i64 := test() {
    m : Map = {0: 100, 1: 200, 2: 300}
    assert_eq(__LOC__, m.len().to_i64(), 3)
    ref v0 : I64 = m[0]
    ref v2 : I64 = m[2]
    assert_eq(__LOC__, v0, 100)
    assert_eq(__LOC__, v2, 300)
}

test_map_literal_i64_str := test() {
    m : Map = {1: "one", 2: "two"}
    assert_eq(__LOC__, m.len().to_i64(), 2)
    ref v1 : Str = m[1]
    assert_eq_str(__LOC__, v1, "one")
}
