mode test

test_i64_map := test() {
    m := Map(I64, I64).new()
    m.set(3, own 30)
    m.set(1, own 10)
    m.set(2, own 20)
    assert_eq(USize, m.len(), 3)
    assert(m.has(1))
    assert(m.has(2))
    assert(m.has(3))
    assert(m.has(4).not())

    ref v1 : I64 = m[1]
    ref v2 : I64 = m[2]
    ref v3 : I64 = m[3]
    assert_eq(I64, v1, 10)
    assert_eq(I64, v2, 20)
    assert_eq(I64, v3, 30)

    // overwrite existing key
    m.set(2, own 99)
    assert_eq(USize, m.len(), 3)
    ref v2b : I64 = m[2]
    assert_eq(I64, v2b, 99)
}

test_str_map := test() {
    sm := Map(Str, I64).new()
    sm.set("banana", own 2)
    sm.set("apple", own 1)
    sm.set("cherry", own 3)
    assert_eq(USize, sm.len(), 3)
    assert(sm.has("apple"))
    assert(sm.has("banana"))
    assert(sm.has("cherry"))
    assert(sm.has("date").not())
    ref sa : I64 = sm["apple"]
    ref sb : I64 = sm["banana"]
    assert_eq(I64, sa, 1)
    assert_eq(I64, sb, 2)
}

test_map_remove := test() {
    m := Map(Str, I64).new()
    m.set("a", own 1)
    m.set("b", own 2)
    m.set("c", own 3)
    m.set("d", own 4)

    assert(m.remove("missing").not())
    assert_eq(USize, m.len(), 4)

    assert(m.remove("a"))
    assert(m.has("a").not())
    assert_eq(I64, m["b"], 2)

    assert(m.remove("c"))
    assert(m.has("c").not())
    assert_eq(I64, m["d"], 4)

    assert(m.remove("d"))
    assert(m.has("d").not())
    assert_eq(USize, m.len(), 1)
    assert_eq(I64, m["b"], 2)
}

// --- Map literal tests ---

test_map_literal_str_i64 := test() {
    m := {"a": 1, "b": 2, "c": 3}
    assert_eq(USize, m.len(), 3)
    assert(m.has("a"))
    assert(m.has("b"))
    assert(m.has("c"))
    ref va : I64 = m["a"]
    ref vb : I64 = m["b"]
    assert_eq(I64, va, 1)
    assert_eq(I64, vb, 2)
}

test_map_literal_i64_i64 := test() {
    m := {0: 100, 1: 200, 2: 300}
    assert_eq(USize, m.len(), 3)
    ref v0 : I64 = m[0]
    ref v2 : I64 = m[2]
    assert_eq(I64, v0, 100)
    assert_eq(I64, v2, 300)
}

test_map_literal_i64_str := test() {
    m := {1: "one", 2: "two"}
    assert_eq(USize, m.len(), 2)
    ref v1 : Str = m[1]
    assert_eq(Str, v1, "one")
}

// --- Issue #287: key-value for-in (`for k, v in map`) ---

// `for k, v in map` visits every entry with the right key/value pairing.
// Map iterates in sorted key order, so the concatenated keys are exact.
test_map_for_in_kv := test() {
    m := Map(Str, I64).new()
    m.set("b", own 2)
    m.set("a", own 1)
    m.set("c", own 3)
    mut order := Str.with_capacity(8)
    mut sum := 0
    mut pairs_ok := true
    for k, v in m {
        order.push_str(k)
        sum = sum.add(v)
        if k.eq("a").and(v.eq(1).not()) { pairs_ok = false }
        if k.eq("b").and(v.eq(2).not()) { pairs_ok = false }
        if k.eq("c").and(v.eq(3).not()) { pairs_ok = false }
    }
    assert_eq(Str, order, "abc")
    assert_eq(I64, sum, 6)
    assert(pairs_ok)
}

// `for k, mut v in map` mutates values in place through the value ref.
test_map_for_in_kv_mut := test() {
    mut m := Map(Str, I64).new()
    m.set("x", own 10)
    m.set("y", own 20)
    for k, mut v in m {
        assert(k.len().gt(0))
        v = v.mul(2)
    }
    ref vx : I64 = m["x"]
    ref vy : I64 = m["y"]
    assert_eq(I64, vx, 20)
    assert_eq(I64, vy, 40)
}

// `for k, mut v in <mut map>`: read the key and mutate the paired value in
// place (the key drives a different update per entry). Confirms the key/value
// pairing holds during a value-mutating walk and that `mut m` is accepted.
test_map_for_in_kv_mut_uses_key := test() {
    mut m := Map(Str, I64).new()
    m.set("a", own 1)
    m.set("b", own 2)
    for k, mut v in m {
        if k.eq("a") { v = v.mul(100) }
        else { v = v.mul(10) }
    }
    ref a : I64 = m["a"]
    ref b : I64 = m["b"]
    assert_eq(I64, a, 100)
    assert_eq(I64, b, 20)
}

// The key binding may be `_` when only values are needed.
test_map_for_in_kv_ignore_key := test() {
    m := Map(I64, I64).new()
    m.set(1, own 100)
    m.set(2, own 200)
    m.set(3, own 300)
    mut sum := 0
    for _, v in m {
        sum = sum.add(v)
    }
    assert_eq(I64, sum, 600)
}

// Both bindings may be `_` (count-only walk). Each `_` is a discard that
// emits no element decl, so the two do not collide as duplicate C locals.
test_map_for_in_kv_ignore_both := test() {
    m := Map(Str, I64).new()
    m.set("a", own 1)
    m.set("b", own 2)
    m.set("c", own 3)
    mut n := 0
    for _, _ in m {
        n++
    }
    assert_eq(I64, n, 3)
}
