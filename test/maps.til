mode test

test_i64_map := test() {
    m := Map(I64, I64).new()
    m.set(3, own 30)
    m.set(1, own 10)
    m.set(2, own 20)
    assert_eq(USize, m.len(), 3)
    assert(m.has(1))
    assert(m.has(2))
    assert(m.has(3))
    assert(m.has(4).not())

    ref v1 : I64 = m[1]
    ref v2 : I64 = m[2]
    ref v3 : I64 = m[3]
    assert_eq(I64, v1, 10)
    assert_eq(I64, v2, 20)
    assert_eq(I64, v3, 30)

    // overwrite existing key
    m.set(2, own 99)
    assert_eq(USize, m.len(), 3)
    ref v2b : I64 = m[2]
    assert_eq(I64, v2b, 99)
}

test_str_map := test() {
    sm := Map(Str, I64).new()
    sm.set("banana", own 2)
    sm.set("apple", own 1)
    sm.set("cherry", own 3)
    assert_eq(USize, sm.len(), 3)
    assert(sm.has("apple"))
    assert(sm.has("banana"))
    assert(sm.has("cherry"))
    assert(sm.has("date").not())
    ref sa : I64 = sm["apple"]
    ref sb : I64 = sm["banana"]
    assert_eq(I64, sa, 1)
    assert_eq(I64, sb, 2)
}

// --- Map literal tests ---

test_map_literal_str_i64 := test() {
    m := {"a": 1, "b": 2, "c": 3}
    assert_eq(USize, m.len(), 3)
    assert(m.has("a"))
    assert(m.has("b"))
    assert(m.has("c"))
    ref va : I64 = m["a"]
    ref vb : I64 = m["b"]
    assert_eq(I64, va, 1)
    assert_eq(I64, vb, 2)
}

test_map_literal_i64_i64 := test() {
    m := {0: 100, 1: 200, 2: 300}
    assert_eq(USize, m.len(), 3)
    ref v0 : I64 = m[0]
    ref v2 : I64 = m[2]
    assert_eq(I64, v0, 100)
    assert_eq(I64, v2, 300)
}

test_map_literal_i64_str := test() {
    m := {1: "one", 2: "two"}
    assert_eq(USize, m.len(), 2)
    ref v1 : Str = m[1]
    assert_eq(Str, v1, "one")
}
