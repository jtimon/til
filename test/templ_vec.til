mode test

// Issue #243: a TEMPLATED Vec generated per element type via a
// `macro(T: Type) returns StructDef`. Unlike core Vec (type-erased: a
// single struct that STORES elem_size + elem_clone/elem_delete function
// pointers and uses a `Dynamic` element api), `TemplVec(T)` emits
// one monomorphized struct per T that stores NOTHING about the element
// type -- no size, no name, no method pointers. The element size and the
// clone/delete operations are resolved directly at compile time per
// instantiation via `T.size()`, `T.clone(...)`, `T.delete(...)`. The api
// is fully typed: `push(own val: T)`, `get(...) returns ref T`.
//
// This exercises the initer macro-expansion substituting the type param
// `T` and the self-type placeholder `Self` into namespace-method
// signatures AND bodies -- including body-local `ref x : T` decls,
// `Self(...)` ctor calls, and `T.method(...)` static calls.

TemplVec := macro(T: Type) returns StructDef {
    return struct {
        own data : U8 = 0
        count : USize = 0
        cap : USize = 0

    namespace:
        new := func() returns Self {
            return Self(data = malloc(T.size().cast(U64)), cap = 1)
        }

        len := func(self: Self) returns USize { return self.count }

        push := func(mut self: Self, own val: T) {
            if self.count.eq(self.cap) {
                new_cap := self.cap.mul(2)
                self.data = realloc(own self.data, new_cap.mul(T.size()).cast(U64))
                self.cap = new_cap
            }
            memcpy(ptr_add(self.data, self.count.mul(T.size()).cast(U64)), val, T.size().cast(U64))
            // Ownership moved into the buffer: zero `val` so its scope-end
            // auto-delete is a no-op (same trick as Vec.push_take).
            memset(val, 0, T.size().cast(U64))
            self.count = self.count.add(1)
        }

        get := func(self: Self, i: USize) returns ref T throws OutOfBounds {
            if i.gte(self.count) {
                throw OutOfBounds(msg = format(__LOC__, ":TemplVec.get: index ", i.to_str(),
                      " out of bounds (len ", self.count.to_str(), ")"))
            }
            return ptr_add(self.data, i.mul(T.size()).cast(U64))
        }

        // Drop the existing element via T.delete, then overwrite. For POD
        // T (I64/Bool/U8) T.delete is a no-op; for Str it frees the c_str.
        set := func(mut self: Self, i: USize, own val: T) {
            if i.gte(self.count) {
                panic(__LOC__, "TemplVec.set: index ", i.to_str(), " out of bounds (len ", self.count.to_str(), ")")
            }
            T.delete(own ptr_add(self.data, i.mul(T.size()).cast(U64)), false)
            memcpy(ptr_add(self.data, i.mul(T.size()).cast(U64)), val, T.size().cast(U64))
            memset(val, 0, T.size().cast(U64))
        }

        clear := func(mut self: Self) {
            for i in 0..self.count {
                T.delete(own ptr_add(self.data, i.mul(T.size()).cast(U64)), false)
            }
            self.count = 0
        }

        delete := func(own self: Self, call_free: Bool = true) {
            Self.clear(self)
            free(own self.data)
            if call_free { free(own self) }
        }

        clone := func(self: Self) returns Self {
            new_data : Dynamic = malloc(self.cap.mul(T.size()).cast(U64))
            for i in 0..self.count {
                ref src : T = ptr_add(self.data, i.mul(T.size()).cast(U64))
                mut cloned : T = src.clone()
                memcpy(ptr_add(new_data, i.mul(T.size()).cast(U64)), cloned, T.size().cast(U64))
                // ownership of cloned's heap (if any) moves into the buffer
                memset(cloned, 0, T.size().cast(U64))
            }
            return Self(data = new_data, count = self.count, cap = self.cap)
        }
    }
}

// NOTE: each concrete type is bound to a name first, then used. The
// fully-inline form the design aims for -- `mut v := TemplVec(Bool).new()`
// and `mut v : TemplVec(Bool) = ...` -- does not compile yet: the macro
// only expands at top-level `Name := TemplVec(T)` decl scope, and the
// type-annotation position needs parser support. Inline instantiation +
// dedup is tracked as a caveat in the "templated core types" feature issue.
TemplVecI64  := TemplVec(I64)
TemplVecStr  := TemplVec(Str)
TemplVecBool := TemplVec(Bool)
TemplVecU8   := TemplVec(U8)

// --- I64: typed push/get/len, plus cross-check against a core Vec ---

test_templvec_i64_basic := test() {
    mut v := TemplVecI64.new()
    v.push(own 10)
    v.push(own 20)
    v.push(own 30)
    assert_eq(__LOC__, v.len().to_i64(), 3)
    ref a : I64 = v[0.to_usize()]
    ref b : I64 = v[1.to_usize()]
    ref c : I64 = v[2.to_usize()]
    assert_eq(__LOC__, a, 10)
    assert_eq(__LOC__, b, 20)
    assert_eq(__LOC__, c, 30)
}

test_templvec_i64_index_bang := test() {
    mut v := TemplVecI64.new()
    v.push(own 7)
    v.push(own 8)
    ref x : I64 = v[1.to_usize()]
    assert_eq(__LOC__, x, 8)
}

test_templvec_i64_set := test() {
    mut v := TemplVecI64.new()
    v.push(own 1)
    v.push(own 2)
    v.set(1, own 99)
    ref y : I64 = v[1.to_usize()]
    assert_eq(__LOC__, y, 99)
}

test_templvec_i64_grow := test() {
    mut v := TemplVecI64.new()
    for i in 0..100 {
        v.push(own i)
    }
    assert_eq(__LOC__, v.len().to_i64(), 100)
    ref last : I64 = v[99.to_usize()]
    assert_eq(__LOC__, last, 99)
}

// Functional equivalence: same push sequence into a core Vec and a
// TemplVec yields identical length and per-element values.
test_templvec_i64_equiv_vec := test() {
    mut tv := TemplVecI64.new()
    mut cv := Vec.new(I64)
    for i in 0..10 {
        tv.push(own i.mul(3))
        cv.push(own i.mul(3))
    }
    assert_eq(__LOC__, tv.len().to_i64(), cv.len().to_i64())
    for i in 0..10 {
        ref t : I64 = tv[i.to_usize()]
        ref c : I64 = cv[i.to_usize()]
        assert_eq(__LOC__, t, c)
    }
}

// --- Str: boxed elements (own heap buffers) ---

test_templvec_str_basic := test() {
    mut v := TemplVecStr.new()
    v.push(own "alpha".concat(""))
    v.push(own "beta".concat(""))
    assert_eq(__LOC__, v.len().to_i64(), 2)
    ref a : Str = v[0.to_usize()]
    ref b : Str = v[1.to_usize()]
    assert_eq_str(__LOC__, a, "alpha")
    assert_eq_str(__LOC__, b, "beta")
}

test_templvec_str_set := test() {
    mut v := TemplVecStr.new()
    v.push(own "old".concat(""))
    v.set(0, own "new".concat(""))
    ref a : Str = v[0.to_usize()]
    assert_eq_str(__LOC__, a, "new")
}

// clone must deep-copy: mutating the clone leaves the original intact.
test_templvec_str_clone_independent := test() {
    mut v := TemplVecStr.new()
    v.push(own "one".concat(""))
    v.push(own "two".concat(""))
    mut w := v.clone()
    w.set(0, own "ONE".concat(""))
    ref vo : Str = v[0.to_usize()]
    ref wo : Str = w[0.to_usize()]
    assert_eq_str(__LOC__, vo, "one")
    assert_eq_str(__LOC__, wo, "ONE")
}

// --- Bool ---

test_templvec_bool := test() {
    mut v := TemplVecBool.new()
    v.push(own true)
    v.push(own false)
    v.push(own true)
    assert_eq(__LOC__, v.len().to_i64(), 3)
    ref a : Bool = v[0.to_usize()]
    ref b : Bool = v[1.to_usize()]
    ref c : Bool = v[2.to_usize()]
    assert(__LOC__, a)
    assert(__LOC__, b.not())
    assert(__LOC__, c)
}

// --- U8 ---

test_templvec_u8 := test() {
    mut v := TemplVecU8.new()
    v.push(own 65.to_u8())
    v.push(own 66.to_u8())
    assert_eq(__LOC__, v.len().to_i64(), 2)
    ref a : U8 = v[0.to_usize()]
    assert_eq(__LOC__, a.to_i64(), 65)
}
