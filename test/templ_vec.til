mode test

// Issue #243 / #267: a TEMPLATED Vec generated per element type. It is
// declared with the `struct<T: Type> { ... }` sugar (caveat 1), which the
// parser desugars to `macro(T: Type) returns StructDef { return struct {...} }`.
// Unlike core Vec (type-erased: a single struct that STORES elem_size +
// elem_clone/elem_delete pointers and uses a `Dynamic` element api),
// `TemplVec(T)` emits
// one monomorphized struct per T that stores NOTHING about the element
// type -- no size, no name, no method pointers. The element size and the
// clone/delete operations are resolved directly at compile time per
// instantiation via `T.size()`, `T.clone(...)`, `T.delete(...)`. The api
// is fully typed: `push(own val: T)`, `get(...) returns ref T`.
//
// This exercises the initer macro-expansion substituting the type param `T`
// into namespace-method signatures AND bodies -- including body-local
// `ref x : T` decls, `TemplVec(T)(...)` ctor calls, and `T.method(...)`
// static calls.

TemplVec := struct<T: Type> {
    own data : U8 = 0
    count : USize = 0
    cap : USize = 0

namespace:
    new := func() returns TemplVec(T) {
        return TemplVec(T)(data = malloc(T.size().cast(U64)), cap = 1)
    }

    len := func(self: TemplVec(T)) returns USize { return self.count }

    push := func(mut self: TemplVec(T), own val: T) {
        if self.count.eq(self.cap) {
            new_cap := self.cap.mul(2)
            self.data = realloc(own self.data, new_cap.mul(T.size()).cast(U64))
            self.cap = new_cap
        }
        memcpy(ptr_add(self.data, self.count.mul(T.size()).cast(U64)), val, T.size().cast(U64))
        // Ownership moved into the buffer: zero `val` so its scope-end
        // auto-delete is a no-op (same trick as Vec.push_take).
        memset(val, 0, T.size().cast(U64))
        self.count = self.count.add(1)
    }

    get := func(self: TemplVec(T), i: USize) returns ref T throws OutOfBounds {
        if i.gte(self.count) {
            throw OutOfBounds(msg = format(__LOC__, ":TemplVec.get: index ", i.to_str(),
                  " out of bounds (len ", self.count.to_str(), ")"))
        }
        return ptr_add(self.data, i.mul(T.size()).cast(U64))
    }

    // Drop the existing element via T.delete, then overwrite. For POD
    // T (I64/Bool/U8) T.delete is a no-op; for Str it frees the c_str.
    set := func(mut self: TemplVec(T), i: USize, own val: T) {
        if i.gte(self.count) {
            panic("TemplVec.set: index ", i.to_str(), " out of bounds (len ", self.count.to_str(), ")")
        }
        T.delete(own ptr_add(self.data, i.mul(T.size()).cast(U64)), false)
        memcpy(ptr_add(self.data, i.mul(T.size()).cast(U64)), val, T.size().cast(U64))
        memset(val, 0, T.size().cast(U64))
    }

    clear := func(mut self: TemplVec(T)) {
        for i in 0..self.count {
            T.delete(own ptr_add(self.data, i.mul(T.size()).cast(U64)), false)
        }
        self.count = 0
    }

    delete := func(own self: TemplVec(T), call_free: Bool = true) {
        self.clear()
        free(own self.data)
        if call_free { free(own self) }
    }

    clone := func(self: TemplVec(T)) returns TemplVec(T) {
        new_data : Dynamic = malloc(self.cap.mul(T.size()).cast(U64))
        for i in 0..self.count {
            ref src : T = ptr_add(self.data, i.mul(T.size()).cast(U64))
            mut cloned : T = src.clone()
            memcpy(ptr_add(new_data, i.mul(T.size()).cast(U64)), cloned, T.size().cast(U64))
            // ownership of cloned's heap (if any) moves into the buffer
            memset(cloned, 0, T.size().cast(U64))
        }
        return TemplVec(T)(data = new_data, count = self.count, cap = self.cap)
    }
}

// Issue #267 (caveat 2): the templated type is used INLINE -- `TemplVec(T)`
// directly as a `.new()` receiver, no pre-binding to a name needed. The
// initer hoists each inline instantiation into one deduped monomorphization,
// so repeated `TemplVec(Bool)` uses across the file share a single generated
// type. `TemplVec(T)` also works in type-annotation positions now (see the
// type-annotation test near the end of this file).

// --- I64: typed push/get/len, plus cross-check against a core Vec ---

test_templvec_i64_basic := test() {
    mut v := TemplVec(I64).new()
    v.push(own 10)
    v.push(own 20)
    v.push(own 30)
    assert_eq(USize, v.len(), 3)
    ref a : I64 = v[0]
    ref b : I64 = v[1]
    ref c : I64 = v[2]
    assert_eq(I64, a, 10)
    assert_eq(I64, b, 20)
    assert_eq(I64, c, 30)
}

test_templvec_i64_index_bang := test() {
    mut v := TemplVec(I64).new()
    v.push(own 7)
    v.push(own 8)
    ref x : I64 = v[1]
    assert_eq(I64, x, 8)
}

test_templvec_i64_set := test() {
    mut v := TemplVec(I64).new()
    v.push(own 1)
    v.push(own 2)
    v.set(1, own 99)
    assert_eq(I64, v[1], 99)
}

test_templvec_i64_grow := test() {
    mut v := TemplVec(I64).new()
    for i in 0..100 {
        v.push(own i)
    }
    assert_eq(USize, v.len(), 100)
    ref last : I64 = v[99]
    assert_eq(I64, last, 99)
}

// Functional equivalence: same push sequence into a core Vec and a
// TemplVec yields identical length and per-element values.
test_templvec_i64_equiv_vec := test() {
    mut tv := TemplVec(I64).new()
    mut cv := Vec(I64).new()
    for i in 0..10 {
        tv.push(own i.mul(3))
        cv.push(own i.mul(3))
    }
    assert_eq(USize, tv.len(), cv.len())
    for i in 0..10 {
        assert_eq(I64, tv[i.to_usize()], cv[i.to_usize()])
    }
}

// --- Str: boxed elements (own heap buffers) ---

test_templvec_str_basic := test() {
    mut v := TemplVec(Str).new()
    v.push(own format("alpha", ""))
    v.push(own format("beta", ""))
    assert_eq(USize, v.len(), 2)
    ref a : Str = v[0]
    ref b : Str = v[1]
    assert_eq(Str, a, "alpha")
    assert_eq(Str, b, "beta")
}

test_templvec_str_set := test() {
    mut v := TemplVec(Str).new()
    v.push(own format("old", ""))
    v.set(0, own format("new", ""))
    ref a : Str = v[0]
    assert_eq(Str, a, "new")
}

// clone must deep-copy: mutating the clone leaves the original intact.
test_templvec_str_clone_independent := test() {
    mut v := TemplVec(Str).new()
    v.push(own format("one", ""))
    v.push(own format("two", ""))
    mut w := v.clone()
    w.set(0, own format("ONE", ""))
    assert_eq(Str, v[0], "one")
    assert_eq(Str, w[0], "ONE")
}

// --- Bool ---

test_templvec_bool := test() {
    mut v := TemplVec(Bool).new()
    v.push(own true)
    v.push(own false)
    v.push(own true)
    assert_eq(USize, v.len(), 3)
    ref a : Bool = v[0]
    ref b : Bool = v[1]
    ref c : Bool = v[2]
    assert(a)
    assert(b.not())
    assert(c)
}

// --- U8 ---

test_templvec_u8 := test() {
    mut v := TemplVec(U8).new()
    v.push(own 65)
    v.push(own 66)
    assert_eq(USize, v.len(), 2)
    ref a : U8 = v[0]
    assert_eq(U8, a, 65)
}

// --- Type-annotation positions (#267) ---
// `TemplVec(T)` used where a type is expected: a local-decl annotation and
// a function parameter type. The parser mangles `TemplVec(T)` to the same
// monomorphization name the value-position hoist generates, so the
// annotation resolves to that one generated type.

fill_i64 := func(mut v: TemplVec(I64), n: I64) {
    mut i := 0
    while i.lt(n) { v.push(own i.clone()); i++ }
}

test_templvec_type_annotation := test() {
    mut v : TemplVec(I64) = TemplVec(I64).new()
    fill_i64(v, 4)
    assert_eq(USize, v.len(), 4)
    ref last : I64 = v[3]
    assert_eq(I64, last, 3)
}

// --- Value parameters in templated type names (#270) ---
// This uses the same struct<T> sugar as TemplVec, but with an extra
// compile-time value argument. The value argument must be part of the
// deterministic monomorphization name, so InitialCap 4 and 8 do not collide.

TemplCapVec := struct<T: Type, InitialCap: I64> {
    count : USize = 0
    cap : I64 = 0

namespace:
    new := func() returns TemplCapVec(T, InitialCap) {
        return TemplCapVec(T, InitialCap)(cap = InitialCap)
    }
}

TemplCapVecI64Cap4 := TemplCapVec(I64, 4)

templ_cap_vec_i64_cap4 := func(v: TemplCapVecI64Cap4) returns I64 {
    return v.cap
}

test_templvec_value_arg_distinct_inline := test() {
    small := TemplCapVec(I64, 4).new()
    large := TemplCapVec(I64, 8).new()
    assert_eq(I64, small.cap, 4)
    assert_eq(I64, large.cap, 8)
}

test_templvec_value_arg_alias_normalizes := test() {
    v := TemplCapVec(I64, 4).new()
    assert_eq(I64, templ_cap_vec_i64_cap4(v), 4)
}
