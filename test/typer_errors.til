mode script

// undefined symbol
println(missing_x)

// undefined function
foo(1)

// undefined type in explicit declaration
y : Blah = 35

// type mismatch: declared Str but value is I64
z : Str = 35

// if condition must be Bool
if 69 {
    println("FAIL")
}

if "hello" {
    println("FAIL")
}

// while condition must be Bool
while 1 {
    println("FAIL")
}

// variable not visible outside block scope
{
    inner := "scoped"
}
println(inner)

// func cannot call proc
bad_func := func(x: I64) returns I64 {
    println("side effect!")
    return x
}


// cannot assign to immutable variable
immut := 42
immut = 43

// cannot assign to function parameter
assign_param := proc(a: I64) {
    a = 99
}

// assignment type mismatch
mut m := 42
m = "oops"

// cannot assign to const struct field (#211: fields are mut by default)
ImmutStruct := struct {
    const id := 0
    name := "x"
}
immut_struct := ImmutStruct()
immut_struct.id = 5

// struct instantiation: unknown field
bad1 := ImmutStruct(bogus=1)

// struct instantiation: positional arg not allowed
bad2 := ImmutStruct(42)

// wrong explicit type on func def
bad_fn : Str = func(n: I64) returns I64 { return n }

// wrong explicit type on struct def
bad_st : I64 = struct { x := 0 }

// cannot assign to immutable namespace field
NsStruct := struct {
    x := 0
    namespace:
    mut count := 0
    label := "fixed"
}
NsStruct.label = "oops"

// struct instantiation should not accept namespace field as named arg
bad_ns := NsStruct(count=5)

// ufcs: no such method on type
x := 42
x.nonexistent()

// ufcs: method call on type with no namespace
s := "hello"
s.nonexistent()

// ufcs: method call on literal
"hello".nonexistent()

// cannot assign to non-mut parameter (mut keyword exists)
assign_nonmut := proc(mut a: I64, b: I64) {
    a = 1
    b = 2
}

// own: missing 'own' at call site
take := proc(own x: I64) {
    println(x.to_str())
}
take(42)

// own: 'own' at call site but param is not own
regular := proc(x: I64) {
    println(x.to_str())
}
ov := 1
regular(own ov)

// own: use after ownership transfer
eat := proc(own v: I64) {
    println(v.to_str())
}
doomed := 99
eat(own doomed)
println(doomed.to_str())

// own: missing 'own' on UFCS call to own-taking method
OwnTest := struct {
    val := 0
}
ot1 := OwnTest(val=1)
ot1.delete()

// own: missing 'own' on direct namespace call to own-taking method
ot2 := OwnTest(val=2)
OwnTest.delete(ot2)

// struct literal: non-ref fields consume variables
CtorOwn := struct {
    name := "default"
}
ctor_name := "hello"
co := CtorOwn(name=ctor_name)
println(ctor_name)

// break outside loop
break

// continue outside loop
continue

// ref: declaration requires ref-returning function or ref/param variable
ref bad_ref := 42

// ref: function must return a parameter or ref variable
bad_ref_fn := func(a: I64) returns ref I64 {
    mut b := a
    return b
}

// #164 step 2: redundant 'mut' on a parameter that is never written
// through (no `p = ...`, no `p.f = ...`, never passed to a mut/own/
// Dynamic callee). The body only reads it.
terr_redundant_mut_param := func(mut redundant_p: I64) returns I64 {
    return redundant_p
}

// cannot return ref variable from non-ref function; use .clone() or 'returns ref'
TERR_ARR := array(I64, 1, 2, 3)
bad_ret_ref := func(i: I64) returns I64 {
    ref v : I64 = TERR_ARR[i]
    return v
}

// cannot own result of ref-returning function; use 'ref' or Type.clone()
good_ref_fn := func(a: I64) returns ref I64 { return a }
bad_own := good_ref_fn(42)

// cannot own result of ref-returning function (Vec.get returns ref Dynamic)
ref_vec := vec(I64, 10, 20)
bad_vec_own : I64 = ref_vec[0]

// #282 follow-up: a by-value return of a ref-returning ?-call is rejected the
// same way as the Decl form above (previously it compiled and DEREF'd a null
// ref on the throw path). Use `returns ref I64` or `.clone()` instead.
bad_ret_ref_q := func(i: USize) returns I64 throws OutOfBounds {
    return ref_vec.get(i)?
}

// no need for explicit own on typed local
own bad_own_local : U8 = malloc(2)

// no need for explicit own on typed mutable local
own mut bad_own_mut_local : U8 = malloc(2)

// no need for explicit own on Dynamic local
own bad_dyn : Dynamic = malloc(2)

// cannot store Dynamic: inferred from malloc
bad_dyn2 := malloc(32)

// dyn_call: method must be a string literal
method_var := "clone"
dyn_call_ret("I64", method_var, 1, 42)

// argument type mismatch: I64 method with Bool arg
32.add(true)

// argument type mismatch: Bool top-level func with I64 arg
and(true, 42)

// argument type mismatch: user-defined function
type_test := func(a: I64, _b: Bool) returns I64 { return a }
type_test(1, 2)

// #157 argument type mismatch: variadic ..Str called with a type that
// has no to_str method (auto-coerce only fires when to_str exists)
NoToStr := struct { x : I64 = 0 }
println(NoToStr())
str_va := proc(_parts: ..Str) { print_flush() }
str_va(NoToStr())

// cannot call method on Dynamic value (namespace UFCS ambiguous)
dyn_vec := vec(I64, 10, 20)
dyn_bad := dyn_vec.get(0).add(35)

// map literal: key type must implement cmp
NoCmp := struct { x := 0 }
bad_map := {NoCmp(x=1): "one"}

// set literal: element type must implement cmp
bad_set := {NoCmp(x=1), NoCmp(x=2)}

// for-in: Dynamic collection without explicit type
forin_vec := vec(I64, 1, 2, 3)
for x in forin_vec { }

// for-in: type has no get method
NoGet := struct {
    namespace:
    len := func(_self: NoGet) returns I64 { return 0 }
}
for x in NoGet() { }

// for-in: type has no len method
NoLen := struct {
    namespace:
    get := func(_self: NoLen, i: I64) returns ref I64 { return i }
}
for x in NoLen() { }

// NULL: cannot assign to non-ref declaration
nonnull_local : I64 = NULL

// NULL: cannot pass to 'own' parameter
take_own := proc(own _x: I64) {}
take_own(own NULL)

// NULL: cannot pass to 'shallow' parameter
take_shallow := proc(_x: I64) {}
take_shallow(NULL)

// #99: struct with new() -- literal outside namespace is an error
HasNew := struct {
    x := 0
namespace:
    new := func(x: I64) returns HasNew { return HasNew(x = x) }
}
hn := HasNew(x = 1)

// #86: unused function parameter (prefix with _ to suppress)
unused_param := func(a: I64, b: I64) returns I64 { return a }
unused_param(1, 2)

// #86: unused local variable (prefix with _ to suppress)
unused_local := func() returns I64 {
    unused := 99
    return 0
}
unused_local()

// #161: 'ref mut' cannot launder mutability from an immutable ref local
TerrLaunder := struct { field := 0 }
terr_launder_local := TerrLaunder(field=1)
ref terr_launder_r : TerrLaunder = terr_launder_local
ref mut terr_launder_rm : TerrLaunder = terr_launder_r

// #161: 'ref mut' cannot launder mutability from an immutable param
terr_launder_fn := proc(p: TerrLaunder) {
    ref mut leaked : TerrLaunder = p
    leaked.field = 99
}
terr_launder_fn(terr_launder_local)

// #113: non-exhaustive switch on enum (simple, no payload)
TerrColor := enum { Red, Green, Blue }
terr_color := TerrColor.Green
switch terr_color {
case TerrColor.Red: println("red")
case TerrColor.Green: println("green")
}

// #113: non-exhaustive switch on enum (payload variants)
TerrTok := enum { Num: I64, Name: Str, Eof }
terr_tok := TerrTok.Eof
switch terr_tok {
case TerrTok.Num: println("num")
case TerrTok.Eof: println("eof")
}

// #148: unqualified namespace member access from sibling method
NsUnqualified := namespace {
    mut urmom := 69
    get := func() returns I64 { return urmom }
}

// proc without any proc/ext_proc calls should be a func
useless_proc := proc(_x: I64) {
    return
}
useless_proc(1)

// #168 step 1: ref binding cannot be initialized from .clone()
TerrCloneRefSrc := struct { field := 0 }
terr_clone_ref_src := TerrCloneRefSrc(field=1)
ref terr_clone_ref : TerrCloneRefSrc = terr_clone_ref_src.clone()
ref mut terr_clone_ref_mut : TerrCloneRefSrc = terr_clone_ref_src.clone()

// #168 step 2: predicate generalised from literal `.clone()` to any
// FCall whose callee returns OwnType.Own. Catches struct constructors,
// factory funcs, and any user func declared `returns own ...`.
ref terr_step2_ctor : TerrCloneRefSrc = TerrCloneRefSrc(field=2)
terr_make_owned_str := func() returns Str { return "owned" }
ref terr_step2_func : Str = terr_make_owned_str()

// #168 step 5: ref-typed function cannot return an owned value.
terr_step5_bad_ret := func(f: TerrCloneRefSrc) returns ref TerrCloneRefSrc {
    return f.clone()
}

// #168 step 3: ref struct field default cannot be an owned value.
// NULL stays allowed (forced exception for ref fields).
TerrStep3 := struct {
    ref bad_field : TerrCloneRefSrc = TerrCloneRefSrc(field=3)
    ref ok_field : TerrCloneRefSrc = NULL
}

// #168 step 2 follow-up: enum variant constructors are caught too,
// because the initer registers each variant as a namespace decl with
// a FuncDef whose default return_own_type is Own.
TerrStep2Enum := enum { TerrPayload: I64, TerrEmpty }
ref terr_step2_enum : TerrStep2Enum = TerrStep2Enum.TerrPayload(5)

// #168 step 4: assignment to a ref-typed lvalue cannot accept an owned
// RHS. Catches both plain Assign and FieldAssign shapes.
TerrStep4Field := struct {
    ref data : Str = NULL
namespace:
    set_clone := func(mut self: TerrStep4Field, src: Str) returns I64 {
        self.data = src.clone()
        return 0
    }
}
terr_step4_assign := func() returns I64 {
    ref mut x : Str = "borrow"
    x = "fresh".clone()
    return 0
}
terr_step4_assign()

// #168 step 1b / #177: ref bindings cannot be initialized to NULL.
// Field defaults remain allowed (the parent type doesn't yet have an
// instance to point at). Func/proc/test/macro bodies AND module scope
// are now uniformly rejected.
terr_null_ref_local_fn := func() returns I64 {
    ref leaked_null : I64 = NULL
    ref mut leaked_null_mut : I64 = NULL
    if is_null(leaked_null) { return 0 }
    if is_null(leaked_null_mut) { return 0 }
    return 1
}
terr_null_ref_local_fn()

// #177: same rule applies at module scope (was the conservative
// carve-out before the cached_*_def migration).
ref terr_module_null : I64 = NULL
ref mut terr_module_null_mut : I64 = NULL

// #191: macro argument must be known at compile time
macro_test := macro(x: I64) returns I64 { return x }
runtime_val := func() returns I64 { return 42 }
_ = macro_test(runtime_val())

// #184: bare get_payload(...) in user code is rejected;
// switch case bindings are the only legitimate way to extract
// an enum payload.
TerrGetPayloadEnum := enum { TerrI: I64, TerrZ }
terr_get_payload_val := TerrGetPayloadEnum.TerrI(7)
get_payload(terr_get_payload_val)

// #93: a nested struct/enum/func is private to its parent function.
// init_declarations_unit (src/self/initer.til) hoists it to the top
// level under a mangled name `<parent>_<orig>` and marks it priv.
// Two checks fall out of that:
//   - if no sibling reference touches it, the existing unused-priv
//     check flags it (the lift also rewrites references to the
//     mangled name, so an originally-unused decl ends up with zero refs).
//   - the original name doesn't exist outside the parent body, so a
//     reference from another function or top-level scope errors as
//     "undefined".
unused_nested_struct_parent := func() returns I64 {
    UnusedLocalStruct := struct { mut x := 0 }
    return 0
}
unused_nested_struct_parent()

uses_nested := func() returns I64 {
    HiddenInUses := struct { mut x := 0 }
    h := HiddenInUses()
    return h.x
}
uses_nested()
// Trying to reach the nested type by its original name from outside
// the parent: the symbol doesn't exist at file scope.
reach_outside := func() returns I64 {
    h := HiddenInUses()
    return h.x
}
reach_outside()

// And trying to reach the SAME nested type by its mangled name from
// another function in the same file: function-scope priv kicks in.
reach_outside_mangled := func() returns I64 {
    h := uses_nested_HiddenInUses()
    return h.x
}
reach_outside_mangled()

// dead arm: duplicate bare variant -- second arm unreachable.
TerrDeadColor := enum { Red, Green, Blue }
terr_dead_color := TerrDeadColor.Red
switch terr_dead_color {
case TerrDeadColor.Red: println("red")
case TerrDeadColor.Red: println("red-dup")
case TerrDeadColor.Green: println("green")
case TerrDeadColor.Blue: println("blue")
}

// dead arm: a binding case fully covers the variant, so a later more
// specific arm on the same variant is unreachable.
TerrDeadTok := enum { Num: I64, Name: Str, Eof }
terr_dead_tok := TerrDeadTok.Num(1)
switch terr_dead_tok {
case TerrDeadTok.Num(n): println(n.to_str())
case TerrDeadTok.Num(_z): println("dup")
case TerrDeadTok.Name(_s): println("name")
case TerrDeadTok.Eof: println("eof")
}

// dead arm: anything after a default arm is unreachable.
switch terr_dead_color {
case TerrDeadColor.Red: println("red")
case: println("other")
case TerrDeadColor.Blue: println("blue")
}

// dead arm: two `case:` defaults in the same switch -- second is dead.
switch terr_dead_color {
case TerrDeadColor.Red: println("red")
case: println("other")
case: println("dup-default")
}

// unnecessary `case:` -- every variant of a bare enum is already listed.
switch terr_dead_color {
case TerrDeadColor.Red: println("red")
case TerrDeadColor.Green: println("green")
case TerrDeadColor.Blue: println("blue")
case: println("other")
}

// unnecessary `case:` -- every variant of a payload enum is also covered.
TerrExhaustTok := enum { Num: I64, Name: Str, Eof }
terr_exhaust_tok := TerrExhaustTok.Eof
switch terr_exhaust_tok {
case TerrExhaustTok.Num(_n): println("num")
case TerrExhaustTok.Name(_s): println("name")
case TerrExhaustTok.Eof:     println("eof")
case: println("other")
}

// struct pattern that omits a field without `..` is rejected; either
// bind all fields or use `..` to make the partial match explicit.
TerrRestPoint := struct {
    x := 0
    y := 0
    namespace:
    eq := func(a: TerrRestPoint, b: TerrRestPoint) returns Bool { return a.x.eq(b.x).and(a.y.eq(b.y)) }
    to_str := func(self: TerrRestPoint) returns Str { return format(self.x.to_str(), ",", self.y.to_str()) }
}
terr_rest_p := TerrRestPoint(x = 0, y = 0)
switch terr_rest_p {
case TerrRestPoint(x = 0): println("origin-x")
case TerrRestPoint(x = _nx, y = _ny): println("any")
}

// `.clone()` on a literal receiver is always redundant -- the literal
// is already a fresh value. Reject at the typer level so callers fix
// the source instead of paying for the copy.
terr_clone_lit_str   := "urmom".clone()
terr_clone_lit_nl    := "\n".clone()
terr_clone_lit_num   := 32.clone()
terr_clone_lit_char  := '\n'.clone()
terr_clone_lit_bool  := true.clone()

// Calling `to_<self>` on a value that is already of that type is a
// redundant self-conversion. Reported with a message that names the
// mistake directly rather than the generic "no method 'to_i64' for
// type 'I64'". Core defines no identity converters (no `to_i64` on
// I64, no `to_str` on Str), so the check fires purely on the call
// shape -- it works uniformly for primitives, Str, and user types.
// #192: to_u32/to_u64 are EXEMPT (a target-dependent USize/UPtr value
// needs `.to_u32()` on 32-bit and `.to_u64()` on 64-bit for one source
// to typecheck on both), so they are not tested here.
terr_self_conv_i64 := func() returns I64 {
    val : I64 = 7
    return val.to_i64()
}
terr_self_conv_str := func() returns Str {
    val : Str = "hello"
    return val.to_str()
}
TerrSelfAaa := struct { field := 0 }
terr_self_conv_struct := func() returns TerrSelfAaa {
    val := TerrSelfAaa(field = 1)
    return val.to_terrselfaaa()
}

// ============================================================
// Issue #198 follow-up: throw/catch validation diagnostics
// ============================================================

// Throwing function for the next batch of cases.
TerrErrA := struct {}
TerrErrB := struct {}

terr_throws_a := func() throws TerrErrA {
    throw TerrErrA()
}

terr_throws_b := func() throws TerrErrB {
    throw TerrErrB()
}

terr_no_throws := func() returns I64 { return 0 }

// missing '?' on a throwing call -- caller does not catch.
terr_missing_question := func() throws TerrErrA {
    terr_throws_a()
}

// '?' on a non-throwing call.
terr_question_on_non_throwing := func() {
    _ := terr_no_throws()?
}

// catch type that is not among the pending thrown types.
terr_catch_not_thrown := func() {
    terr_throws_a()?
    catch (err: TerrErrA) {
    }
    catch (err: TerrErrB) {  // never thrown
    }
}

// throw of type not in the function's throws clause, not caught.
terr_uncaught_undeclared_throw := func() {
    throw TerrErrA()
}

// throws clause declares TerrErrA but body never raises it.
terr_declared_never_thrown := func() throws TerrErrA {
}

// '!' on a non-throwing call -- same error category as '?' on
// non-throwing.
terr_bang_on_non_throwing := func() {
    _ := terr_no_throws()!
}

// Calling these so the unused-priv-func diagnostic doesn't mask
// the throw/catch diagnostics above.
terr_missing_question()
terr_question_on_non_throwing()
terr_catch_not_thrown()
terr_uncaught_undeclared_throw()
terr_declared_never_thrown()
terr_bang_on_non_throwing()

// Issue #223 step 2: redundant 'shallow' on a primitive parameter --
// primitives are passed by value automatically, so the qualifier is rejected.
terr_redundant_shallow_param := func(shallow x: I64) returns I64 {
    return x
}

// Issue #223 step 2: redundant 'shallow' on a primitive return type.
terr_redundant_shallow_return := func() returns shallow I64 {
    return 0
}

// is() compares only the outer enum tag, so a payload-carrying variant is
// rejected -- it would silently match any value of that variant. Use a bare
// variant or a switch to discriminate the inner variant.
TErrIsColor := enum {
    Red,
    Tagged: I64,
}
terr_is_payload := func(c: TErrIsColor) returns Bool {
    return c.is(TErrIsColor.Tagged(5))
}
terr_is_payload(TErrIsColor.Red)

// #242: a struct field with no default is required at instantiation;
// omitting it is a type error.
TErrReq := struct {
    a : U16 = 0
    b : Str
    c := -1
}
terr_req_missing := TErrReq()

// #242: defaulted fields stay optional, but a required field must be
// supplied -- omitting it errors.
TErrMixedReq := struct {
    x := 1
    label : Str
}
terr_mixed_req_missing := TErrMixedReq()

// #244: switch is statement-only; using it in value position errors and
// points at match.
TErrMatchColor := enum { Red, Green }
terr_switch_in_value := switch TErrMatchColor.Red {
case TErrMatchColor.Red:   1
case TErrMatchColor.Green: 2
}

// #244: a bare match statement discards its value; the error points at switch.
match TErrMatchColor.Red {
case TErrMatchColor.Red:   1
case TErrMatchColor.Green: 2
}

// #244: all match arms must yield the same type.
terr_match_arms := match TErrMatchColor.Red {
case TErrMatchColor.Red:   1
case TErrMatchColor.Green: "two"
}

// #289: array/vec take a bare type token (like assert_eq's `T: Type`), not a
// Str literal. The old array("I64", ...) / vec("Str", ...) string-first-arg
// form is rejected with a type error.
terr_arr_str_type := array("I64", 1, 2, 3)
terr_vec_str_type := vec("Str", "a")

// #244: a non-enum match with no `case:` default is non-exhaustive.
terr_match_nonexhaustive := match 9 {
case 1: "a"
case 2: "b"
}

// #251: an interface is fieldless -- a non-func member is rejected.
TErrInterfaceField := interface {
    x := 0
}

// #251: an interface has no `namespace:` marker (no fields to separate
// from the methods).
TErrInterfaceNamespace := interface {
    a := ext_func(self: TErrInterfaceNamespace) returns I64 {}
namespace:
    b := ext_func(self: TErrInterfaceNamespace) returns I64 {}
}

// #251: a member must be func/proc (concrete) or ext_func/ext_proc
// (abstract) -- a test()/macro member is rejected.
TErrInterfaceBadKind := interface {
    t := test() {}
}

// #251: `implements` conformance. An interface for the cases below.
TErrConfIface := interface {
    must := ext_func(self: TErrConfIface) returns I64 {}
}

// missing abstract method: TErrConfMissing implements TErrConfIface but
// does not provide `must`.
TErrConfMissing := struct implements TErrConfIface {
    x := 0
}

// wrong signature: provides `must` but returns Str, not I64.
TErrConfBadSig := struct implements TErrConfIface {
namespace:
    must := func(_self: TErrConfBadSig) returns Str { return "" }
}

// implements a non-interface (a plain struct).
TErrConfNotIface := struct { y := 0 }
TErrConfImplNonIface := struct implements TErrConfNotIface {
    z := 0
}

// #251: the same conformance rules apply to `enum implements Iface`. Enums
// carry methods in their namespace, so the three failure modes mirror the
// struct ones exactly.

// missing abstract method: the enum names the interface but omits `must`.
TErrConfEnumMissing := enum implements TErrConfIface {
    A,
    B,
}

// wrong signature: provides `must` but returns Str, not I64.
TErrConfEnumBadSig := enum implements TErrConfIface {
    A,
namespace:
    must := func(_self: TErrConfEnumBadSig) returns Str { return "" }
}

// implements a non-interface (a plain struct).
TErrConfEnumImplNonIface := enum implements TErrConfNotIface {
    A,
}

// #287: the key binding of a two-variable for-in cannot be `mut` -- mutating
// a key in place would corrupt the map's key ordering / bucket placement.
// Values may be mutated (`for k, mut v`); keys may not.
terr_kvmut_map := Map(Str, I64).new()
terr_kvmut_map.set("a", own 1)
for mut k, v in terr_kvmut_map {
    println(k)
    println(v.to_str())
}

// #262: the thunk fallback lowers non-inlinable lazy bodies (loops, early
// returns) to ordinary thunk-taking functions, so a plain loop body now
// compiles. The fallback is NOT applied when a param name is SHADOWED inside
// the body (auto-forcing a shadowed use would be wrong), so such a def stays
// lazy and still hard-errors as non-inlinable. Here the for-loop variable `b`
// shadows the param `b`, so the def is left lazy and rejected.
terr_bad_lazy := lazy_func(a: Bool, b: Bool) returns Bool {
    if b { return a }
    for b in 0..3 { if b.eq(2) { return a } }
    return a
}

// #294: a numeric conversion on a numeric literal is redundant -- the bare
// literal already narrows to the target through its declaration type, an
// argument/field type, or any numeric context. Every form below is rejected.
// Out-of-range conversions (300.to_u8() truncation, -1.to_usize() wraparound)
// stay legal and are deliberately NOT listed here.
terr_conv_decl : U32 = 5.to_u32()                    // declaration type
terr_conv_cast : U16 = 7.cast(U16)                   // cast form
terr_conv_nested : F32 = 5.to_f32() / 100.to_f32()   // nested operands, typed decl
mut terr_conv_assign : I32 = 0
terr_conv_assign = 9.to_i32()                        // assignment target type
terr_conv_infer := 5.to_u8()                         // inferred -- needs explicit type
terr_conv_arg_fn := func(terr_cv: U16) returns U16 { return terr_cv }
terr_conv_arg_fn(42.to_u16())                        // argument type
terr_conv_op_fn := func(terr_b: I16) returns Bool { return terr_b > 0.to_i16() }
terr_conv_op_fn(1)                                   // operator-operand type
terr_conv_ret_fn := func() returns F32 { return 3.to_f32() }
terr_conv_ret_fn()                                   // return type

// #302: transferring ownership inside a loop, of a binding declared
// outside the loop -- the second iteration would move an already-moved
// value (previously compiled silently into use-after-free C). Loops
// that REASSIGN the binding before transferring stay legal.
terr_loop_sink := func(own terr_ls: Str) returns I64 { return terr_ls.len().to_i64() }
terr_loop_transfer := func() returns I64 {
    terr_lt_lit := "hello"
    terr_lt_s := terr_lt_lit.clone()
    mut terr_lt_total := 0
    mut terr_lt_i := 0
    while terr_lt_i < 2 {
        terr_lt_total = terr_lt_total + terr_loop_sink(own terr_lt_s)
        terr_lt_i++
    }
    return terr_lt_total
}

// non-void function whose body can fall off the end without returning: til's
// own all-paths-return check (not left to the C backend's -Werror=return-type).
// `if` with no else -- the false path reaches the end.
terr_missing_return_if := func(terr_mr_x: I64) returns I64 {
    if terr_mr_x > 0 { return 1 }
}
// no return at all -- ends in an assignment.
terr_missing_return_none := func(terr_mr_y: I64) returns I64 {
    mut terr_mr_z := terr_mr_y
    terr_mr_z = terr_mr_z + 1
}
