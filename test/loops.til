mode test

test_for_in_str := test() {
    // Str.get returns ref I8 -- type inferred
    mut result := Str.with_capacity(10)
    for c in "hello" {
        result.push_str(Str.from_byte(c.cast(I64).band(255).to_u8()))
    }
    assert_eq(Str, result, "hello")
}

test_for_in_str_explicit := test() {
    // Explicit type annotation also works
    mut result := Str.with_capacity(10)
    for c : I8 in "world" {
        result.push_str(Str.from_byte(c.cast(I64).band(255).to_u8()))
    }
    assert_eq(Str, result, "world")
}

test_for_in_vec := test() {
    v := vec("I64", 10, 20, 30)
    mut sum := 0
    for x : I64 in v {
        sum = sum.add(x)
    }
    assert_eq(I64, sum, 60)
}

test_for_in_array := test() {
    a := array("I64", 1, 2, 3, 4, 5)
    mut sum := 0
    for x : I64 in a {
        sum = sum.add(x)
    }
    assert_eq(I64, sum, 15)
}

test_for_in_break := test() {
    mut count := 0
    for _c in "abcdef" {
        if count.eq(3) { break }
        count = count.add(1)
    }
    assert_eq(I64, count, 3)
}

test_for_in_continue := test() {
    // Skip 'b' characters
    mut result := Str.with_capacity(10)
    for c in "abcbd" {
        if c.eq('b') { continue }
        result.push_str(Str.from_byte(c.cast(I64).band(255).to_u8()))
    }
    assert_eq(Str, result, "acd")
}

test_for_in_nested := test() {
    mut count := 0
    for _c1 in "ab" {
        for _c2 in "xy" {
            count = count.add(1)
        }
    }
    assert_eq(I64, count, 4)
}

test_for_in_empty := test() {
    mut count := 0
    for _c in "" {
        count = count.add(1)
    }
    assert_eq(I64, count, 0)

    v := vec("I64")
    mut sum := 0
    for x : I64 in v {
        sum = sum.add(x)
    }
    assert_eq(I64, sum, 0)
}

test_for_in_scope := test() {
    // Loop variable should not leak to outer scope
    // (desugars to anonymous block)
    x := 42
    for _c in "abc" {
        // c is scoped inside the block
    }
    assert_eq(I64, x, 42)
}

test_range_ascending := test() {
    mut sum := 0
    for i in 0..5 {
        sum = sum.add(i)
    }
    assert_eq(I64, sum, 10)
}

test_range_descending := test() {
    mut sum := 0
    for i in 5..0 {
        sum = sum.add(i)
    }
    assert_eq(I64, sum, 15)
}

test_range_empty := test() {
    mut count := 0
    for _i in 3..3 {
        count = count.add(1)
    }
    assert_eq(I64, count, 0)
}

test_range_single := test() {
    mut sum := 0
    for i in 0..1 {
        sum = sum.add(i)
    }
    assert_eq(I64, sum, 0)
}

test_range_break := test() {
    mut last := 0
    for i in 0..100 {
        if i.eq(5) { break }
        last = i
    }
    assert_eq(I64, last, 4)
}

test_range_continue := test() {
    // Sum only even numbers 0..10
    mut sum := 0
    for i in 0..10 {
        if i.mod(2).neq(0) { continue }
        sum = sum.add(i)
    }
    assert_eq(I64, sum, 20)
}

test_range_nested := test() {
    mut sum := 0
    for _i in 0..3 {
        for _j in 0..4 {
            sum = sum.add(1)
        }
    }
    assert_eq(I64, sum, 12)
}

test_range_u32_count := test() {
    // #94: loop var is U32 (inferred from count), not U64
    count : U32 = 5
    mut sum := 0
    for i in 0..count {
        sum = sum.add(i.to_i64())
    }
    assert_eq(I64, sum, 10)
}

test_range_u32_both := test() {
    // Both start and end as U32
    start : U32 = 1
    end : U32 = 4
    mut sum := 0
    for i in start..end {
        sum = sum.add(i.to_i64())
    }
    assert_eq(I64, sum, 6)
}

// #100: negative ranges (I64)
test_range_negative := test() {
    mut sum := 0
    for i in -2..3 {
        sum = sum.add(i)
    }
    // -2 + -1 + 0 + 1 + 2 = 0
    assert_eq(I64, sum, 0)
}

test_range_negative_desc := test() {
    mut sum := 0
    for i in 2..-3 {
        sum = sum.add(i)
    }
    // 2 + 1 + 0 + -1 + -2 = 0
    assert_eq(I64, sum, 0)
}

// #100: I32 range
test_range_i32 := test() {
    start : I32 = 1
    end : I32 = 4
    mut sum := 0
    for i in start..end {
        sum = sum.add(i.cast(I64))
    }
    assert_eq(I64, sum, 6)
}

test_while_basic := test() {
    mut i := 0
    while i.lt(5) {
        i = i.add(1)
    }
    assert_eq(I64, i, 5)
}

test_while_false := test() {
    while false {
        panic("unreachable")
    }
}

test_while_break := test() {
    mut i := 0
    while true {
        if i.eq(3) { break }
        i = i.add(1)
    }
    assert_eq(I64, i, 3)
}

test_while_continue := test() {
    mut k := 0
    mut total := 0
    while k.lt(5) {
        k = k.add(1)
        if k.eq(3) { continue }
        total = total.add(k)
    }
    assert_eq(I64, total, 12)
}

// #160: 'for mut x : T in coll' makes the loop variable mutable
test_for_in_mut_collection := test() {
    v := vec("I64", 1, 2, 3)
    mut sum := 0
    for mut x : I64 in v {
        x = x.mul(10)
        sum = sum.add(x)
    }
    // 10 + 20 + 30 = 60
    assert_eq(I64, sum, 60)
}

// #160: 'for mut i in <range>' allows mutating the loop variable inside the body
test_for_in_mut_range := test() {
    mut sum := 0
    for mut i in 0..5 {
        i = i.mul(2)
        sum = sum.add(i)
    }
    // 0+2+4+6+8 = 20
    assert_eq(I64, sum, 20)
}
