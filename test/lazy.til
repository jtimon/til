mode test

# Issue #262: lazy_func / lazy_proc.
#
# A lazy callable's body is a single `return <expr>`. Arguments are spliced
# in unevaluated at the call site, so a `match` body (which only evaluates
# the taken arm) yields C-style short-circuit semantics: an unused argument
# is never evaluated, even when it has side effects.

lazy_and := lazy_func(a: Bool, b: Bool) returns Bool {
    return match a { case true: b case: false }
}

lazy_or := lazy_func(a: Bool, b: Bool) returns Bool {
    return match a { case true: true case: b }
}

# An if/else body with single returns inlines too: the inliner rewrites
# `if cond { return X } else { return Y }` to `match cond { case true: X
# case: Y }`, so it short-circuits exactly like the match form.
if_and := lazy_func(a: Bool, b: Bool) returns Bool {
    if a { return b } else { return false }
}

if_or := lazy_func(a: Bool, b: Bool) returns Bool {
    if a { return true } else { return b }
}

# A guard chain `if c1 { return X1 } ... if ck { return Xk } return Y` folds
# into nested matches, so each clause short-circuits the ones after it.
gchain := lazy_func(a: Bool, b: Bool, c: Bool) returns Bool {
    if a { return b }
    if b { return c }
    return a
}

# A body with a local binding before the inlinable tail is statement-inlined:
# the prelude (`x := costly(a)`) runs in a fresh block, the tail short-circuits.
costly := func(v: Bool) returns Bool { eval_count = eval_count.add(1); return v }
stmt_and := lazy_func(a: Bool, b: Bool) returns Bool {
    x := costly(a)
    return x.and(b)
}

# --- functional correctness ---

test_lazy_and := test() {
    expect(lazy_and(true, true), "T and T")
    expect(lazy_and(true, false).not(), "T and F")
    expect(lazy_and(false, true).not(), "F and T")
    expect(lazy_and(false, false).not(), "F and F")
}

test_lazy_or := test() {
    expect(lazy_or(true, true), "T or T")
    expect(lazy_or(true, false), "T or F")
    expect(lazy_or(false, true), "F or T")
    expect(lazy_or(false, false).not(), "F or F")
}

# --- guard-chain body: multi-clause, clause-by-clause short-circuit ---

test_guard_chain := test() {
    expect(gchain(true, true, false), "a -> b (T)")
    expect(gchain(true, false, true).not(), "a -> b (F)")
    expect(gchain(false, true, true), "b -> c (T)")
    expect(gchain(false, true, false).not(), "b -> c (F)")
    expect(gchain(false, false, true).not(), "else -> a (F)")
}

test_guard_chain_short_circuits := test() {
    eval_count = 0
    r := gchain(true, true, bump())       # a true -> b; c (bump) never reached
    expect(r, "a true skips c")
    assert_eq(I64, eval_count, 0)
    eval_count = 0
    r2 := gchain(false, false, bump())    # a,b false -> a; c (bump) never reached
    expect(r2.not(), "a,b false skips c")
    assert_eq(I64, eval_count, 0)
}

# --- statement-inlining: a local binding prelude + an inlinable tail ---

test_stmt_inline := test() {
    expect(stmt_and(true, true), "stmt T,T")
    expect(stmt_and(true, false).not(), "stmt T,F")
    expect(stmt_and(false, true).not(), "stmt F,T")
}

test_stmt_inline_short_circuits := test() {
    # a=false -> x=costly(false)=false (1 eval), so x.and(bump()) skips bump().
    eval_count = 0
    r := stmt_and(false, bump())
    expect(r.not(), "stmt false short-circuits b")
    assert_eq(I64, eval_count, 1)         # only the prelude costly(a) ran
    # a=true -> x=true (1 eval), b (bump) IS evaluated.
    eval_count = 0
    r2 := stmt_and(true, bump())
    expect(r2, "stmt true evaluates b")
    assert_eq(I64, eval_count, 2)         # costly(a) + bump()
}

# --- if/else-body lazy funcs: same results and same short-circuit as match ---

test_if_body_funcs := test() {
    expect(if_and(true, true), "if T and T")
    expect(if_and(true, false).not(), "if T and F")
    expect(if_and(false, true).not(), "if F and T")
    expect(if_or(false, true), "if F or T")
    expect(if_or(true, false), "if T or F")
    expect(if_or(false, false).not(), "if F or F")
}

test_if_body_short_circuits := test() {
    eval_count = 0
    r := if_and(false, bump())
    expect(r.not(), "if_and(false, bump()) is false")
    assert_eq(I64, eval_count, 0)
    eval_count = 0
    r2 := if_or(true, bump())
    expect(r2, "if_or(true, bump()) is true")
    assert_eq(I64, eval_count, 0)
}

# --- nested lazy calls (re-expansion of the spliced body) ---

test_lazy_nested := test() {
    expect(lazy_and(lazy_or(false, true), true), "(F or T) and T")
    expect(lazy_or(lazy_and(true, false), false).not(), "(T and F) or F")
}

test_core_bool_and_or := test() {
    expect(true.and(true), "T.and(T)")
    expect(true.and(false).not(), "T.and(F)")
    expect(false.and(true).not(), "F.and(T)")
    expect(true.or(false), "T.or(F)")
    expect(false.or(true), "F.or(T)")
    expect(false.or(false).not(), "F.or(F)")
    expect(true && true, "T && T")
    expect((true && false).not(), "T && F")
    expect(false || true, "F || T")
    expect((false || false).not(), "F || F")
}

# --- Lisp-style N-ary and/or: a binary lazy callable called with more than
#     two args right-folds into nested short-circuit matches. ---

test_nary_and_or := test() {
    expect(and(true, true, true), "and(T,T,T)")
    expect(and(true, true, false).not(), "and(T,T,F)")
    expect(and(true, false, true).not(), "and(T,F,T)")
    expect(and(false, true, true).not(), "and(F,...)")
    expect(or(false, false, true), "or(F,F,T)")
    expect(or(false, false, false).not(), "or(F,F,F)")
    expect(or(true, false, false), "or(T,...)")
    # four operands
    expect(and(true, true, true, true), "and x4 T")
    expect(and(true, true, true, false).not(), "and x4 with F")
    expect(or(false, false, false, true), "or x4 with T")
    # method-call form folds identically (receiver is the first operand)
    expect(true.and(true, true), "T.and(T,T)")
    expect(false.or(false, true), "F.or(F,T)")
}

test_nary_short_circuits := test() {
    eval_count = 0
    # first false -> every later operand (the bump()s) is skipped
    r := and(false, bump(), bump())
    expect(r.not(), "and(false, bump, bump) skips all")
    assert_eq(I64, eval_count, 0)

    eval_count = 0
    # first true -> or short-circuits, no bump() runs
    r2 := or(true, bump(), bump())
    expect(r2, "or(true, bump, bump) short-circuits")
    assert_eq(I64, eval_count, 0)

    eval_count = 0
    # and(true, true, bump()) reaches and evaluates the last operand once
    r3 := and(true, true, bump())
    expect(r3, "and(true, true, bump) evaluates last")
    assert_eq(I64, eval_count, 1)
}

# --- decisive short-circuit proof: an unused side-effecting argument must
#     NOT run. bump() increments a global counter; if it ran when it should
#     have been short-circuited, the count would be non-zero. ---

mut eval_count := 0

bump := func() returns Bool {
    eval_count++
    return true
}

test_and_short_circuits := test() {
    eval_count = 0
    r := lazy_and(false, bump())
    expect(r.not(), "false and bump() is false")
    assert_eq(I64, eval_count, 0)
}

test_or_short_circuits := test() {
    eval_count = 0
    r := lazy_or(true, bump())
    expect(r, "true or bump() is true")
    assert_eq(I64, eval_count, 0)
}

test_evaluates_taken_arm := test() {
    eval_count = 0
    r := lazy_and(true, bump())
    expect(r, "true and bump() is true")
    assert_eq(I64, eval_count, 1)
}

test_core_and_short_circuits := test() {
    eval_count = 0
    r := false.and(bump())
    expect(r.not(), "false.and(bump()) is false")
    assert_eq(I64, eval_count, 0)
}

test_core_or_short_circuits := test() {
    eval_count = 0
    r := true.or(bump())
    expect(r, "true.or(bump()) is true")
    assert_eq(I64, eval_count, 0)
}

test_ampamp_short_circuits := test() {
    eval_count = 0
    r := false && bump()
    expect(r.not(), "false && bump() is false")
    assert_eq(I64, eval_count, 0)
}

test_pipepipe_short_circuits := test() {
    eval_count = 0
    r := true || bump()
    expect(r, "true || bump() is true")
    assert_eq(I64, eval_count, 0)
}

# --- thunk fallback (#262): a non-inlinable body (loop + early return) is
#     lowered to an ordinary function whose args are passed as zero-arg thunks
#     (call-by-name). It must still short-circuit: when `a` is false the loop
#     returns false before `b` is ever forced, so a side-effecting `b` arg
#     never runs. ---

both := lazy_func(a: Bool, b: Bool) returns Bool {
    for _ in 0..3 {
        if a.not() { return false }
    }
    return b
}

test_thunk_noninlinable := test() {
    expect(both(true, true), "both(T,T)")
    expect(both(true, false).not(), "both(T,F)")
    expect(both(false, true).not(), "both(F,T)")
    expect(both(false, false).not(), "both(F,F)")
}

test_thunk_short_circuits := test() {
    # a=false -> loop returns false before b is forced: bump() must NOT run.
    eval_count = 0
    r := both(false, bump())
    expect(r.not(), "both(false, bump()) is false")
    assert_eq(I64, eval_count, 0)
    # a=true -> the trailing `return b` forces bump() exactly once.
    eval_count = 0
    r2 := both(true, bump())
    expect(r2, "both(true, bump()) is true")
    assert_eq(I64, eval_count, 1)
}

test_thunk_captures_local := test() {
    # Local args -> each thunk captures the local BY REFERENCE and is forced
    # synchronously inside `both` (exercises the capture path, not just the
    # literal/global args above where the thunk captures nothing).
    x := true
    y := false
    expect(both(x, x), "both(x, x) is true via captured locals")
    # `.not()` directly on the call: the capturing thunk arg is a UFCS-receiver
    # arg, the case that used to trip a spurious #223 redundant-shallow error.
    expect(both(x, y).not(), "both(x, y) is false via captured locals")
    expect(both(y, x).not(), "both(y, x) short-circuits on a captured local")
}

test_thunk_mixed_arg_short_circuits := test() {
    # arg 1 is a captured local, arg 2 a side-effecting global call: when the
    # captured local is false the loop short-circuits before arg 2 is forced.
    flag := false
    eval_count = 0
    r := both(flag, bump())
    expect(r.not(), "both(flag=false, bump()) is false")
    assert_eq(I64, eval_count, 0)
}

test_thunk_ufcs_method := test() {
    # UFCS method syntax on a thunk-lowered lazy func: `a.both(b)` reduces to
    # the same bare thunk call (receiver is effective arg 0) and still
    # short-circuits.
    expect(true.both(true), "true.both(true)")
    expect(true.both(false).not(), "true.both(false)")
    expect(false.both(true).not(), "false.both(true)")
    # false literal receiver -> loop returns before the arg thunk is forced.
    eval_count = 0
    r := false.both(bump())
    expect(r.not(), "false.both(bump()) short-circuits")
    assert_eq(I64, eval_count, 0)
    # captured-local receiver: the receiver thunk captures `x`, still
    # short-circuits before the arg thunk runs.
    x := false
    eval_count = 0
    r2 := x.both(bump())
    expect(r2.not(), "x.both(bump()) captures receiver and short-circuits")
    assert_eq(I64, eval_count, 0)
}

# --- lazy_proc: like lazy_func but its deferred argument may be a proc call
#     (a side-effecting expression). ---

lazy_or_p := lazy_proc(a: Bool, b: Bool) returns Bool {
    return match a { case true: true case: b }
}

mut log_count := 0

note := proc() returns Bool {
    println("note ran")
    log_count++
    return true
}

test_lazy_proc_short_circuits := test() {
    log_count = 0
    r := lazy_or_p(true, note())
    expect(r, "true or note() is true")
    assert_eq(I64, log_count, 0)
}

test_lazy_proc_runs_when_needed := test() {
    log_count = 0
    r := lazy_or_p(false, note())
    expect(r, "false or note() runs note()")
    assert_eq(I64, log_count, 1)
}

# --- A throwing call in a lazy and/or argument must compile AND short-circuit.
#     `cond.and(v[i])` desugars to `match cond { case true: v[i] ... }`, so the
#     throwing subscript `v[i]` (= `get(i)!`) lands in a match arm body. It must
#     be lowered INTO that arm so it (a) gets its hidden _err_kind/_err_<T>
#     out-args (else infer fails with "missing argument for parameter
#     '_err_kind'") and (b) only runs when the arm is taken. The empty-Vec cases
#     below guard the access, so a non-short-circuiting (eager) evaluation would
#     panic with OutOfBounds. ---

test_and_or_throwing_arg_short_circuits := test() {
    v := Vec(I64).new()
    # guard is false / true-on-the-left: v[0] must NOT be evaluated (no OOB)
    expect(v.len().gt(0).and(v[0].gt(0)).not(), "and: empty guarded")
    expect(v.len().eq(0).or(v[0].gt(0)), "or: empty guarded")
    v.push(own 42)
    expect(v.len().gt(0).and(v[0].eq(42)), "and: nonempty taken arm")
    expect(v.len().eq(0).or(v[0].eq(42)), "or: nonempty taken arm")
    # operator forms && / || lower to the same lazy and/or, so they must
    # short-circuit a guarded throwing subscript identically.
    empty := Vec(I64).new()
    expect((empty.len().gt(0) && empty[0].gt(0)).not(), "&&: empty guarded")
    expect((empty.len().eq(0) || empty[0].gt(0)), "||: empty guarded")
    expect((v.len().gt(0) && v[0].eq(42)), "&&: nonempty taken arm")
}
