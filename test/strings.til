mode test

test_eq := test() {
    assert("hello".eq("hello"))
    assert("hello".eq("world").not())
    assert("".eq(""))
    assert("a".eq("ab").not())
}

test_cmp := test() {
    // Regression: memcmp returns the raw byte difference, but cmp must
    // normalise to -1/0/1 -- the auto-derived lt/gt are cmp(a,b).eq(-1) /
    // .eq(1), so a raw diff (e.g. 'a'-'z' = -25) would break ordering for
    // strings whose first differing bytes are not adjacent.
    assert("apple".lt("zebra"))
    assert("zebra".gt("apple"))
    assert("apple".lt("apricot"))
    assert("apricot".gt("apple"))
    assert("app".lt("apple"))
    assert("apple".gt("app"))
    assert("abc".lt("abz"))
    assert("abz".gt("abc"))
    assert("abc".lte("abc"))
    assert("abc".gte("abc"))
    assert("abc".lte("abz"))
    assert("abz".gte("abc"))
}

test_concat := test() {
    assert_eq(Str, format("hello", " world"), "hello world")
    assert_eq(Str, format("", "abc"), "abc")
    assert_eq(Str, format("abc", ""), "abc")
    assert_eq(Str, format("", ""), "")
}

test_clone := test() {
    s := "hello"
    s2 := s.clone()
    assert_eq(Str, s2, "hello")
    assert_eq(Str, s, "hello")
}

test_len := test() {
    assert_eq(USize, "hello".len(), 5)
    assert_eq(USize, "".len(), 0)
    assert_eq(USize, "a".len(), 1)
    assert_eq(USize, "hello world".len(), 11)
}

test_substr := test() {
    assert_eq(Str, "hello".substr(1, 3), "ell")
    assert_eq(Str, "hello".substr(0, 5), "hello")
    assert_eq(Str, "hello".substr(0, 0), "")
    assert_eq(Str, "hello".substr(4, 1), "o")
    assert_eq(Str, "hello".substr(0, 1), "h")
}

test_contains := test() {
    assert("hello world".contains("world"))
    assert("hello".contains("hello"))
    assert("hello".contains(""))
    assert("hello".contains("ell"))
    assert("hello".contains("xyz").not())
    assert("".contains("a").not())
    assert("".contains(""))
}

test_starts_with := test() {
    assert("hello".starts_with("hel"))
    assert("hello".starts_with("hello"))
    assert("hello".starts_with(""))
    assert("hello".starts_with("world").not())
    assert("hi".starts_with("hello").not())
}

test_ends_with := test() {
    assert("hello".ends_with("llo"))
    assert("hello".ends_with("hello"))
    assert("hello".ends_with(""))
    assert("hello".ends_with("world").not())
    assert("hi".ends_with("hello").not())
}

test_neq := test() {
    assert("hello".neq("world"))
    assert("hello".neq("hello").not())
    assert("".neq("").not())
    assert("a".neq("b"))
}

test_is_empty := test() {
    assert("".is_empty())
    assert("a".is_empty().not())
    assert("hello".is_empty().not())
}

test_find := test() {
    assert_eq(I64, "hello world".find("world"), 6)
    assert_eq(I64, "hello".find("ell"), 1)
    assert_eq(I64, "hello".find("hello"), 0)
    assert_eq(I64, "hello".find("xyz"), -1)
    assert_eq(I64, "hello".find(""), -1)
    assert_eq(I64, "".find("a"), -1)
    assert_eq(I64, "aaa".find("a"), 0)
    assert_eq(I64, "abcabc".find("bc"), 1)
}

test_rfind := test() {
    assert_eq(I64, "abcabc".rfind("bc"), 4)
    assert_eq(I64, "abcabc".rfind("a"), 3)
    assert_eq(I64, "hello".rfind("ell"), 1)
    assert_eq(I64, "hello".rfind("xyz"), -1)
    assert_eq(I64, "hello".rfind(""), -1)
    assert_eq(I64, "aaa".rfind("a"), 2)
}

test_replace := test() {
    assert_eq(Str, "hello world".replace("world", "til"), "hello til")
    assert_eq(Str, "aaa".replace("a", "bb"), "bbbbbb")
    assert_eq(Str, "hello".replace("xyz", "abc"), "hello")
    assert_eq(Str, "hello".replace("", "abc"), "hello")
    assert_eq(Str, "abab".replace("ab", "c"), "cc")
    assert_eq(Str, "hello".replace("hello", ""), "")
    assert_eq(Str, "a.b.c".replace(".", "/"), "a/b/c")
}

test_get_char := test() {
    assert_eq(Str, "hello".get_char(0), "h")
    assert_eq(Str, "hello".get_char(4), "o")
    assert_eq(Str, "abc".get_char(1), "b")
}

test_strip_prefix := test() {
    assert_eq(Str, "hello world".strip_prefix("hello "), "world")
    assert_eq(Str, "hello".strip_prefix("xyz"), "hello")
    assert_eq(Str, "hello".strip_prefix(""), "hello")
    assert_eq(Str, "hello".strip_prefix("hello"), "")
}

test_strip_suffix := test() {
    assert_eq(Str, "hello world".strip_suffix(" world"), "hello")
    assert_eq(Str, "hello".strip_suffix("xyz"), "hello")
    assert_eq(Str, "hello".strip_suffix(""), "hello")
    assert_eq(Str, "hello".strip_suffix("hello"), "")
}

test_from_byte := test() {
    assert_eq(Str, Str.from_byte(65), "A")
    assert_eq(Str, Str.from_byte(48), "0")
    assert_eq(Str, Str.from_byte(97), "a")
}

test_to_i64 := test() {
    assert_eq(I64, "42".to_i64(), 42)
    assert_eq(I64, "0".to_i64(), 0)
    assert_eq(I64, "123456".to_i64(), 123456)
    assert_eq(I64, "-7".to_i64(), -7)
    assert_eq(I64, "-100".to_i64(), -100)
}

test_to_u8 := test() {
    assert_eq(I64, "42".to_u8().to_i64(), 42)
    assert_eq(I64, "0".to_u8().to_i64(), 0)
    assert_eq(I64, "255".to_u8().to_i64(), 255)
}

test_to_i32 := test() {
    assert_eq(I64, "42".to_i32().cast(I64), 42)
    assert_eq(I64, "0".to_i32().cast(I64), 0)
    assert_eq(I64, "-7".to_i32().cast(I64), -7)
    assert_eq(I64, "123456".to_i32().cast(I64), 123456)
}

test_to_f32 := test() {
    assert_eq(Str, "3.14".to_f32().to_str(), "3.14")
    assert_eq(Str, "-2.5".to_f32().to_str(), "-2.5")
    assert_eq(Str, "7".to_f32().to_str(), "7")
    assert_eq(Str, "0.25".to_f32().to_str(), "0.25")
}

test_split := test() {
    parts := "a,b,c".split(",")
    assert_eq(USize, parts.len(), 3)
    assert_eq(Str, parts[0], "a")
    assert_eq(Str, parts[1], "b")
    assert_eq(Str, parts[2], "c")

    parts2 := "hello".split(",")
    assert_eq(USize, parts2.len(), 1)
    assert_eq(Str, parts2[0], "hello")

    parts3 := "a::b".split("::")
    assert_eq(USize, parts3.len(), 2)
    assert_eq(Str, parts3[0], "a")
    assert_eq(Str, parts3[1], "b")

    parts4 := ",a,".split(",")
    assert_eq(USize, parts4.len(), 3)
    assert_eq(Str, parts4[0], "")
    assert_eq(Str, parts4[1], "a")
    assert_eq(Str, parts4[2], "")
}

test_substr_view := test() {
    // substr returns a view, not a copy
    s := "hello world"
    view := s.substr(6, 5)
    assert_eq(Str, view, "world")

    // clone materializes a view into an owned string
    owned := view.clone()
    assert_eq(Str, owned, "world")

    // views work with comparison
    assert(view.eq("world"))

    // views work with concat
    assert_eq(Str, format("say ", view), "say world")

    // get_char returns a 1-byte view
    assert_eq(Str, "abc".get_char(1), "b")

    // strip_prefix/suffix return views
    assert_eq(Str, "hello world".strip_prefix("hello "), "world")
    assert_eq(Str, "hello world".strip_suffix(" world"), "hello")

    mut v := Str.with_capacity(11)
    v.push_str("hello")
    v.push_str(" world")
    assert_eq(Str, v, "hello world")
}

test_join := test() {
    parts := "a,b,c".split(",")
    assert_eq(Str, join(parts, ","), "a,b,c")
    assert_eq(Str, join(parts, " - "), "a - b - c")

    single := Vec(Str).new()
    single.push(own "hello")
    assert_eq(Str, join(single, ","), "hello")

    empty := Vec(Str).new()
    assert_eq(Str, join(empty, ","), "")

    // Join with newline separator (escape sequence in literal)
    lines := Vec(Str).new()
    lines.push(own "aaa")
    lines.push(own "bbb")
    lines.push(own "ccc")
    result := join(lines, "\n")
    assert_eq(USize, result.len(), 11)
    assert_eq(Str, result, "aaa\nbbb\nccc")
}

// mut param concat — reproduces use-after-free bug
greet := func(mut out: Str) {
    out = format(out, " world")
}

test_mut_param_concat := test() {
    mut s := "hello"
    greet(s)
    assert_eq(Str, s, "hello world")
}

// Issue #238: reassigning a heap-backed local from a substring VIEW of itself
// (`s = s.substr(...).clone()`). The substr view aliases s's buffer; the old-
// value delete must run AFTER the clone copies from the view, and the clone
// must not be elided into a move. Use a grown with_capacity buffer (a literal
// is CAP_LIT and never freed, so it would hide the bug).
test_self_substr_reassign := test() {
    mut s := Str.with_capacity(32)
    s.push_str("int foo ( int x ) ;")
    s = s.substr(0, s.len().sub(1)).clone()
    assert_eq(Str, s, "int foo ( int x ) ")

    mut t := Str.with_capacity(16)
    t.push_str("abcdefgh")
    t = t.substr(2, 4).clone()
    assert_eq(Str, t, "cdef")

    // Repeated self-reassign from a view.
    mut u := Str.with_capacity(16)
    u.push_str("hello world")
    u = u.substr(0, 5).clone()
    u = u.substr(1, 3).clone()
    assert_eq(Str, u, "ell")
}

// Issue #250: cross-variable sibling of #238. `holder.field = src.substr(...)
// .clone()` where `src` is a grown heap buffer freed at end of scope and the
// clone result outlives src (stored in a returned struct, read after src dies).
// The substr view aliases src's buffer; src's asap-delete must run AFTER the
// clone copies from the view, not at the view-producing substr. A grown
// with_capacity buffer is required (a literal is CAP_LIT and never freed).
Holder250 := struct {
    own s : Str = ""
}

make_holder250 := func() returns Holder250 {
    mut arg := Str.with_capacity(64)
    arg.push_str("--cc=hello_world_value")
    mut h := Holder250()
    h.s = arg.substr(5, arg.len().sub(5)).clone()
    return h
}

test_self_substr_field_clone := test() {
    h := make_holder250()
    assert_eq(Str, h.s, "hello_world_value")
}

// Issue #203 point 4 / #238: Str.replace on a grown buffer, including a `from`
// longer than the whole string (the `self.count.sub(from.count)` USize
// underflow guard) and a self-reassign through replace.
test_self_replace := test() {
    mut s := Str.with_capacity(32)
    s.push_str("hello world foo")
    s = s.replace("foo", "bar")
    assert_eq(Str, s, "hello world bar")

    assert_eq(Str, "ab".replace("abcdef", "x"), "ab")
    assert_eq(Str, "".replace("abc", "x"), "")
}
