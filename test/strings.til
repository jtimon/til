mode test

test_eq := test() {
    assert(__LOC__, "hello".eq("hello"))
    assert(__LOC__, "hello".eq("world").not())
    assert(__LOC__, "".eq(""))
    assert(__LOC__, "a".eq("ab").not())
}

test_concat := test() {
    assert_eq_str(__LOC__, "hello".concat(" world"), "hello world")
    assert_eq_str(__LOC__, "".concat("abc"), "abc")
    assert_eq_str(__LOC__, "abc".concat(""), "abc")
    assert_eq_str(__LOC__, "".concat(""), "")
}

test_clone := test() {
    s := "hello"
    s2 := s.clone()
    assert_eq_str(__LOC__, s2, "hello")
    assert_eq_str(__LOC__, s, "hello")
}

test_len := test() {
    assert_eq(__LOC__, "hello".len().to_i64(), 5)
    assert_eq(__LOC__, "".len().to_i64(), 0)
    assert_eq(__LOC__, "a".len().to_i64(), 1)
    assert_eq(__LOC__, "hello world".len().to_i64(), 11)
}

test_substr := test() {
    assert_eq_str(__LOC__, "hello".substr(1, 3), "ell")
    assert_eq_str(__LOC__, "hello".substr(0, 5), "hello")
    assert_eq_str(__LOC__, "hello".substr(0, 0), "")
    assert_eq_str(__LOC__, "hello".substr(4, 1), "o")
    assert_eq_str(__LOC__, "hello".substr(0, 1), "h")
}

test_contains := test() {
    assert(__LOC__, "hello world".contains("world"))
    assert(__LOC__, "hello".contains("hello"))
    assert(__LOC__, "hello".contains(""))
    assert(__LOC__, "hello".contains("ell"))
    assert(__LOC__, "hello".contains("xyz").not())
    assert(__LOC__, "".contains("a").not())
    assert(__LOC__, "".contains(""))
}

test_starts_with := test() {
    assert(__LOC__, "hello".starts_with("hel"))
    assert(__LOC__, "hello".starts_with("hello"))
    assert(__LOC__, "hello".starts_with(""))
    assert(__LOC__, "hello".starts_with("world").not())
    assert(__LOC__, "hi".starts_with("hello").not())
}

test_ends_with := test() {
    assert(__LOC__, "hello".ends_with("llo"))
    assert(__LOC__, "hello".ends_with("hello"))
    assert(__LOC__, "hello".ends_with(""))
    assert(__LOC__, "hello".ends_with("world").not())
    assert(__LOC__, "hi".ends_with("hello").not())
}

test_neq := test() {
    assert(__LOC__, "hello".neq("world"))
    assert(__LOC__, "hello".neq("hello").not())
    assert(__LOC__, "".neq("").not())
    assert(__LOC__, "a".neq("b"))
}

test_is_empty := test() {
    assert(__LOC__, "".is_empty())
    assert(__LOC__, "a".is_empty().not())
    assert(__LOC__, "hello".is_empty().not())
}

test_find := test() {
    assert_eq(__LOC__, "hello world".find("world"), 6)
    assert_eq(__LOC__, "hello".find("ell"), 1)
    assert_eq(__LOC__, "hello".find("hello"), 0)
    assert_eq(__LOC__, "hello".find("xyz"), -1)
    assert_eq(__LOC__, "hello".find(""), -1)
    assert_eq(__LOC__, "".find("a"), -1)
    assert_eq(__LOC__, "aaa".find("a"), 0)
    assert_eq(__LOC__, "abcabc".find("bc"), 1)
}

test_rfind := test() {
    assert_eq(__LOC__, "abcabc".rfind("bc"), 4)
    assert_eq(__LOC__, "abcabc".rfind("a"), 3)
    assert_eq(__LOC__, "hello".rfind("ell"), 1)
    assert_eq(__LOC__, "hello".rfind("xyz"), -1)
    assert_eq(__LOC__, "hello".rfind(""), -1)
    assert_eq(__LOC__, "aaa".rfind("a"), 2)
}

test_replace := test() {
    assert_eq_str(__LOC__, "hello world".replace("world", "til"), "hello til")
    assert_eq_str(__LOC__, "aaa".replace("a", "bb"), "bbbbbb")
    assert_eq_str(__LOC__, "hello".replace("xyz", "abc"), "hello")
    assert_eq_str(__LOC__, "hello".replace("", "abc"), "hello")
    assert_eq_str(__LOC__, "abab".replace("ab", "c"), "cc")
    assert_eq_str(__LOC__, "hello".replace("hello", ""), "")
    assert_eq_str(__LOC__, "a.b.c".replace(".", "/"), "a/b/c")
}

test_get_char := test() {
    assert_eq_str(__LOC__, "hello".get_char(0), "h")
    assert_eq_str(__LOC__, "hello".get_char(4), "o")
    assert_eq_str(__LOC__, "abc".get_char(1), "b")
}

test_strip_prefix := test() {
    assert_eq_str(__LOC__, "hello world".strip_prefix("hello "), "world")
    assert_eq_str(__LOC__, "hello".strip_prefix("xyz"), "hello")
    assert_eq_str(__LOC__, "hello".strip_prefix(""), "hello")
    assert_eq_str(__LOC__, "hello".strip_prefix("hello"), "")
}

test_strip_suffix := test() {
    assert_eq_str(__LOC__, "hello world".strip_suffix(" world"), "hello")
    assert_eq_str(__LOC__, "hello".strip_suffix("xyz"), "hello")
    assert_eq_str(__LOC__, "hello".strip_suffix(""), "hello")
    assert_eq_str(__LOC__, "hello".strip_suffix("hello"), "")
}

test_from_byte := test() {
    assert_eq_str(__LOC__, Str.from_byte(65), "A")
    assert_eq_str(__LOC__, Str.from_byte(48), "0")
    assert_eq_str(__LOC__, Str.from_byte(97), "a")
}

test_to_i64 := test() {
    assert_eq(__LOC__, "42".to_i64(), 42)
    assert_eq(__LOC__, "0".to_i64(), 0)
    assert_eq(__LOC__, "123456".to_i64(), 123456)
    assert_eq(__LOC__, "-7".to_i64(), -7)
    assert_eq(__LOC__, "-100".to_i64(), -100)
}

test_to_u8 := test() {
    assert_eq(__LOC__, "42".to_u8().to_i64(), 42)
    assert_eq(__LOC__, "0".to_u8().to_i64(), 0)
    assert_eq(__LOC__, "255".to_u8().to_i64(), 255)
}

test_to_i32 := test() {
    assert_eq(__LOC__, "42".to_i32().cast(I64), 42)
    assert_eq(__LOC__, "0".to_i32().cast(I64), 0)
    assert_eq(__LOC__, "-7".to_i32().cast(I64), -7)
    assert_eq(__LOC__, "123456".to_i32().cast(I64), 123456)
}

test_to_f32 := test() {
    assert_eq_str(__LOC__, "3.14".to_f32().to_str(), "3.14")
    assert_eq_str(__LOC__, "-2.5".to_f32().to_str(), "-2.5")
    assert_eq_str(__LOC__, "7".to_f32().to_str(), "7")
    assert_eq_str(__LOC__, "0.25".to_f32().to_str(), "0.25")
}

test_split := test() {
    parts := "a,b,c".split(",")
    assert_eq(__LOC__, parts.len().to_i64(), 3)
    ref p0 : Str = parts[0]
    ref p1 : Str = parts[1]
    ref p2 : Str = parts[2]
    assert_eq_str(__LOC__, p0, "a")
    assert_eq_str(__LOC__, p1, "b")
    assert_eq_str(__LOC__, p2, "c")

    parts2 := "hello".split(",")
    assert_eq(__LOC__, parts2.len().to_i64(), 1)
    ref q0 : Str = parts2[0]
    assert_eq_str(__LOC__, q0, "hello")

    parts3 := "a::b".split("::")
    assert_eq(__LOC__, parts3.len().to_i64(), 2)
    ref r0 : Str = parts3[0]
    ref r1 : Str = parts3[1]
    assert_eq_str(__LOC__, r0, "a")
    assert_eq_str(__LOC__, r1, "b")

    parts4 := ",a,".split(",")
    assert_eq(__LOC__, parts4.len().to_i64(), 3)
    ref s0 : Str = parts4[0]
    ref s1 : Str = parts4[1]
    ref s2 : Str = parts4[2]
    assert_eq_str(__LOC__, s0, "")
    assert_eq_str(__LOC__, s1, "a")
    assert_eq_str(__LOC__, s2, "")
}

test_substr_view := test() {
    // substr returns a view, not a copy
    s := "hello world"
    view := s.substr(6, 5)
    assert_eq_str(__LOC__, view, "world")

    // clone materializes a view into an owned string
    owned := view.clone()
    assert_eq_str(__LOC__, owned, "world")

    // views work with comparison
    assert(__LOC__, view.eq("world"))

    // views work with concat
    assert_eq_str(__LOC__, "say ".concat(view), "say world")

    // get_char returns a 1-byte view
    assert_eq_str(__LOC__, "abc".get_char(1), "b")

    // strip_prefix/suffix return views
    assert_eq_str(__LOC__, "hello world".strip_prefix("hello "), "world")
    assert_eq_str(__LOC__, "hello world".strip_suffix(" world"), "hello")

    mut v := Str.with_capacity(11)
    v.push_str("hello")
    v.push_str(" world")
    assert_eq_str(__LOC__, v, "hello world")
}

test_join := test() {
    parts := "a,b,c".split(",")
    assert_eq_str(__LOC__, join(parts, ","), "a,b,c")
    assert_eq_str(__LOC__, join(parts, " - "), "a - b - c")

    single := Vec.new(Str)
    single.push(own "hello")
    assert_eq_str(__LOC__, join(single, ","), "hello")

    empty := Vec.new(Str)
    assert_eq_str(__LOC__, join(empty, ","), "")

    // Join with newline separator (escape sequence in literal)
    lines := Vec.new(Str)
    lines.push(own "aaa")
    lines.push(own "bbb")
    lines.push(own "ccc")
    result := join(lines, "\n")
    assert_eq(__LOC__, result.len().to_i64(), 11)
    assert_eq_str(__LOC__, result, "aaa\nbbb\nccc")
}

// mut param concat — reproduces use-after-free bug
greet := func(mut out: Str) {
    out = out.concat(" world")
}

test_mut_param_concat := test() {
    mut s := "hello"
    greet(s)
    assert_eq_str(__LOC__, s, "hello world")
}

// Issue #238: reassigning a heap-backed local from a substring VIEW of itself
// (`s = s.substr(...).clone()`). The substr view aliases s's buffer; the old-
// value delete must run AFTER the clone copies from the view, and the clone
// must not be elided into a move. Use a grown with_capacity buffer (a literal
// is CAP_LIT and never freed, so it would hide the bug).
test_self_substr_reassign := test() {
    mut s := Str.with_capacity(32)
    s.push_str("int foo ( int x ) ;")
    s = s.substr(0, s.len().sub(1)).clone()
    assert_eq_str(__LOC__, s, "int foo ( int x ) ")

    mut t := Str.with_capacity(16)
    t.push_str("abcdefgh")
    t = t.substr(2, 4).clone()
    assert_eq_str(__LOC__, t, "cdef")

    // Repeated self-reassign from a view.
    mut u := Str.with_capacity(16)
    u.push_str("hello world")
    u = u.substr(0, 5).clone()
    u = u.substr(1, 3).clone()
    assert_eq_str(__LOC__, u, "ell")
}

// Issue #250: cross-variable sibling of #238. `holder.field = src.substr(...)
// .clone()` where `src` is a grown heap buffer freed at end of scope and the
// clone result outlives src (stored in a returned struct, read after src dies).
// The substr view aliases src's buffer; src's asap-delete must run AFTER the
// clone copies from the view, not at the view-producing substr. A grown
// with_capacity buffer is required (a literal is CAP_LIT and never freed).
Holder250 := struct {
    own s : Str = ""
}

make_holder250 := func() returns Holder250 {
    mut arg := Str.with_capacity(64)
    arg.push_str("--cc=hello_world_value")
    mut h := Holder250()
    h.s = arg.substr(5, arg.len().sub(5)).clone()
    return h
}

test_self_substr_field_clone := test() {
    h := make_holder250()
    assert_eq_str(__LOC__, h.s, "hello_world_value")
}

// Issue #203 point 4 / #238: Str.replace on a grown buffer, including a `from`
// longer than the whole string (the `self.count.sub(from.count)` USize
// underflow guard) and a self-reassign through replace.
test_self_replace := test() {
    mut s := Str.with_capacity(32)
    s.push_str("hello world foo")
    s = s.replace("foo", "bar")
    assert_eq_str(__LOC__, s, "hello world bar")

    assert_eq_str(__LOC__, "ab".replace("abcdef", "x"), "ab")
    assert_eq_str(__LOC__, "".replace("abc", "x"), "")
}
