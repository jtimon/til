mode test

test_loc_directives := test() {
    // __LOC__ returns "file:line:col" string
    loc := __LOC__
    expect(__LOC__, loc.find("directives.til").neq(-1), "__LOC__ contains filename")

    // __FILE__ returns file path string
    expect(__LOC__, __FILE__.find("directives.til").neq(-1), "__FILE__ contains filename")

    // __LINE__ returns I64
    line := __LINE__
    assert_eq(__LOC__, line, 12)

    // __COL__ returns I64
    col := __COL__
    assert_eq(__LOC__, col, 12)
}

test_line_increments := test() {
    // __LINE__ on consecutive source lines differs by exactly 1
    a := __LINE__
    b := __LINE__
    assert_eq(__LOC__, b.sub(a), 1)
}

test_col_reflects_position := test() {
    // Same line, different column
    x := __COL__; y := __COL__
    assert(__LOC__, y.gt(x))
}

// Helper to verify __LINE__/__FILE__ work inside a regular func
get_line := func() returns I64 { return __LINE__ }
get_file := func() returns Str { return __FILE__ }

test_directives_in_func := test() {
    // __LINE__ inside a func resolves to the source line of the
    // directive itself, not the call site
    assert_eq(__LOC__, get_line(), 34)
    expect(__LOC__, get_file().find("directives.til").neq(-1),
           "__FILE__ in func resolves to source file")
}
