mode cli

import("../src/std/sys")

// REPL smoke test for #157: pipe several turns into bin/til, capture stdout,
// and verify help(), expression output, and persisted declarations all work.
// Invoked via
// `make test_repl_help` rather than `make test` because the REPL still
// runs the compiler pipeline for each turn, costing too much wall time
// for the regular test suite.

count_matches := func(haystack: Str, needle: Str) returns I64 {
    if needle.is_empty() { return 0 }
    mut count := 0
    mut start : USize = 0
    while start.lte(haystack.len().sub(needle.len())) {
        pos := haystack.substr(start, haystack.len().sub(start)).find(needle)
        if pos.eq(-1) { return count }
        count++
        pos_u : USize = pos.to_usize()
        start = start.add(pos_u).add(needle.len())
    }
    return count
}

main := proc() {
    File.writefile("tmp/repl_help_input", "println(\"a\")\n1 + 1\nx := 7\nprintln(x.to_str())\nhelp(\"println\")\n1 + 1\n")
    pid := spawn_cmd("bin/til < tmp/repl_help_input > tmp/repl_help_output 2>&1")
    _exit_code := wait_cmd(pid)

    output := File.readfile("tmp/repl_help_output")
    needle := "Print strings to stdout followed by a newline."
    n := count_matches(output, needle)
    bad := count_matches(output, "undefined symbol: println")
    two := count_matches(output, "til[script]> 2\n")
    a := count_matches(output, "til[script]> a\n")
    seven := count_matches(output, "til[script]> 7\n")
    if n.eq(1).and(bad.eq(0)).and(two.eq(2)).and(a.eq(1)).and(seven.eq(1)) {
        println("repl_help PASS")
        return
    }
    println("repl_help FAIL: doc matches=", n.to_str(), ", undefined matches=", bad.to_str(), ", expression matches=", two.to_str(), ", a matches=", a.to_str(), ", seven matches=", seven.to_str())
    println("--- captured output ---")
    print(output)
    exit(1)
}
