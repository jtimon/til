mode test

test_i64_set := test() {
    s := Set(I64).new()
    s.add(own 3)
    s.add(own 1)
    s.add(own 2)
    assert_eq(__LOC__, I64, s.len().to_i64(), 3)
    assert(__LOC__, s.has(1))
    assert(__LOC__, s.has(2))
    assert(__LOC__, s.has(3))
    assert(__LOC__, s.has(4).not())

    // Duplicates ignored
    s.add(own 2)
    assert_eq(__LOC__, I64, s.len().to_i64(), 3)
}

test_str_set := test() {
    ss := Set(Str).new()
    ss.add(own "banana")
    ss.add(own "apple")
    ss.add(own "cherry")
    assert_eq(__LOC__, I64, ss.len().to_i64(), 3)
    assert(__LOC__, ss.has("apple"))
    assert(__LOC__, ss.has("banana"))
    assert(__LOC__, ss.has("cherry"))
    assert(__LOC__, ss.has("date").not())
    ss.add(own "apple")
    assert_eq(__LOC__, I64, ss.len().to_i64(), 3)
}

// --- Set literal tests ---

test_set_literal_i64 := test() {
    s := {3, 1, 2}
    assert_eq(__LOC__, I64, s.len().to_i64(), 3)
    assert(__LOC__, s.has(1))
    assert(__LOC__, s.has(2))
    assert(__LOC__, s.has(3))
    assert(__LOC__, s.has(4).not())
}

test_set_literal_str := test() {
    s := {"apple", "banana", "cherry"}
    assert_eq(__LOC__, I64, s.len().to_i64(), 3)
    assert(__LOC__, s.has("apple"))
    assert(__LOC__, s.has("banana"))
    assert(__LOC__, s.has("cherry"))
    assert(__LOC__, s.has("date").not())
}
