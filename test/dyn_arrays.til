mode test

import("../src/std/dyn_array")

test_dyn_array_new_get_set := test() {
    a := DynArray.new(I64, 3)
    a.set(0, own 10)
    a.set(1, own 20)
    a.set(2, own 30)

    ref x : I64 = a.get(0)!
    ref y : I64 = a.get(1)!
    ref z : I64 = a.get(2)!

    assert_eq(__LOC__, I64, x, 10)
    assert_eq(__LOC__, I64, y, 20)
    assert_eq(__LOC__, I64, z, 30)
    assert_eq(__LOC__, USize, a.len(), 3)
}

test_dyn_array_subscript := test() {
    a := DynArray.new(I64, 3)
    a.set(0, own 10)
    a.set(1, own 20)
    a.set(2, own 30)

    ref x : I64 = a[0]
    ref y : I64 = a[1]
    ref z : I64 = a[2]

    assert_eq(__LOC__, I64, x, 10)
    assert_eq(__LOC__, I64, y, 20)
    assert_eq(__LOC__, I64, z, 30)

    mut i : USize = 1
    ref w : I64 = a[i.add(1)]
    assert_eq(__LOC__, I64, w, 30)
}

test_dyn_array_strings := test() {
    a := DynArray.new(Str, 2)
    a.set(0, own "hello")
    a.set(1, own "world")

    ref s0 : Str = a.get(0)!
    ref s1 : Str = a.get(1)!

    assert_eq(__LOC__, Str, s0, "hello")
    assert_eq(__LOC__, Str, s1, "world")
}

test_dyn_array_overwrite := test() {
    a := DynArray.new(I64, 2)
    a.set(0, own 1)
    a.set(1, own 2)
    a.set(0, own 99)

    ref v : I64 = a.get(0)!
    assert_eq(__LOC__, I64, v, 99)
}
