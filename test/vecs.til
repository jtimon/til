mode test

test_vec_push_get := test() {
    v := Vec(I64).new()
    v.push(own 42)
    v.push(own 99)
    v.push(own 7)

    ref a : I64 = v[0]
    ref b : I64 = v[1]
    ref c : I64 = v[2]

    assert_eq(I64, a, 42)
    assert_eq(I64, b, 99)
    assert_eq(I64, c, 7)
    assert_eq(USize, v.len(), 3)
}

test_vec_grow := test() {
    v := Vec(I64).new()
    // default cap is 4, push 8 to force growth
    v.push(own 1)
    v.push(own 2)
    v.push(own 3)
    v.push(own 4)
    v.push(own 5)
    v.push(own 6)
    v.push(own 7)
    v.push(own 8)

    assert_eq(USize, v.len(), 8)
    assert_eq(I64, v[0], 1)
    assert_eq(I64, v[7], 8)
}

test_vec_strings := test() {
    v := Vec(Str).new()
    v.push(own "hello")
    v.push(own "world")

    ref a : Str = v[0]
    ref b : Str = v[1]

    assert_eq(Str, a, "hello")
    assert_eq(Str, b, "world")
    assert_eq(USize, v.len(), 2)
}

test_vec_set := test() {
    v := Vec(I64).new()
    v.push(own 10)
    v.push(own 20)
    v.push(own 30)

    // set middle element
    v.set(1, own 99)!
    ref a : I64 = v[0]
    ref b : I64 = v[1]
    ref c : I64 = v[2]
    assert_eq(I64, a, 10)
    assert_eq(I64, b, 99)
    assert_eq(I64, c, 30)

    // set first element
    v.set(0, own 42)!
    assert_eq(I64, v[0], 42)
}

test_vec_set_str := test() {
    v := Vec(Str).new()
    v.push(own "aaa")
    v.push(own "bbb")

    v.set(0, own "xxx")!
    ref a : Str = v[0]
    ref b : Str = v[1]
    assert_eq(Str, a, "xxx")
    assert_eq(Str, b, "bbb")
}

// Issue #225: subscript assignment `v[i] = x` desugars to
// `v.set(i, own x)!` (mirror of the read-side `v[i] -> v.get(i)!`).
// Covers literal and computed indices, I64 and Str elements; the
// round-trip is asserted under both interp and compile.
test_vec_subscript_assign := test() {
    v := Vec(I64).new()
    v.push(own 10)
    v.push(own 20)
    v.push(own 30)

    v[0] = 100            // literal index
    i : USize = 1
    v[i.add(1)] = 300     // computed index

    ref a : I64 = v[0]
    ref b : I64 = v[1]
    ref c : I64 = v[2]
    assert_eq(I64, a, 100)
    assert_eq(I64, b, 20)
    assert_eq(I64, c, 300)
}

test_vec_subscript_assign_str := test() {
    v := Vec(Str).new()
    v.push(own "aaa")
    v.push(own "bbb")
    v[0] = "zzz"
    ref a : Str = v[0]
    ref b : Str = v[1]
    assert_eq(Str, a, "zzz")
    assert_eq(Str, b, "bbb")
}

// Out-of-bounds set throws OutOfBounds. The bang form (`v[i] = x`)
// panics; the explicit `v.set(i, own x)?` form lets a catch handle it.
// Uses a Str element so the owned value's throw-path cleanup is
// exercised under make_asan.
test_vec_subscript_assign_oob := test() {
    v := Vec(Str).new()
    v.push(own "a")
    mut caught := false
    mut emsg := ""
    v.set(5, own "unstored")?
    catch (err: OutOfBounds) {
        caught = true
        emsg = err.msg
    }
    assert(caught)
    assert(emsg.contains("Vec.set"))
}

test_vec_size := test() {
    assert_eq(USize, I64.size(), 8)
    assert_eq(USize, U8.size(), 1)
    assert_eq(USize, Str.size(), 24)
    assert_eq(USize, Bool.size(), 1)
    assert_eq(USize, Vec(Str).size(), 24)
}

test_vec_dynamic := test() {
    v := Vec(Dynamic).new()
    // Use pointer-sized allocs so FFI Vec.push reads valid memory.
    // Fill each with a distinct non-zero sentinel so the post-push
    // is(a, b) check verifies stored bytes really differ (ASAN's
    // malloc returns zeroed/uniform bytes, which would otherwise
    // make uninitialized buffers compare equal).
    p1 : Dynamic = malloc(Dynamic.size().cast(U64))
    p2 : Dynamic = malloc(Dynamic.size().cast(U64))
    memset(p1, 170, Dynamic.size().cast(U64))
    memset(p2, 187, Dynamic.size().cast(U64))
    v.push(own p1)
    v.push(own p2)

    ref a : Dynamic = v[0]
    ref b : Dynamic = v[1]

    expect(is_null(a).not(), "first dynamic pointer should not be null")
    expect(is_null(b).not(), "second dynamic pointer should not be null")
    expect(ptr_eq(a, b).not(), "distinct dynamic pointers stay distinct")
}

test_vec_pop := test() {
    v := Vec(I64).new()
    v.push(own 11)
    v.push(own 22)
    v.push(own 33)

    popped : I64 = v.pop()
    assert_eq(I64, popped, 33)
    assert_eq(USize, v.len(), 2)

    ref a : I64 = v[0]
    ref b : I64 = v[1]
    assert_eq(I64, a, 11)
    assert_eq(I64, b, 22)

    v.push(own 44)
    assert_eq(I64, popped, 33)

    ref c : I64 = v[2]
    assert_eq(I64, c, 44)
    free(own popped)
}

test_vec_take_prefix := test() {
    v := Vec(I64).new()
    v.push(own 10)
    v.push(own 20)
    v.push(own 30)
    v.push(own 40)

    prefix := v.take_prefix(2)

    assert_eq(USize, prefix.len(), 2)
    assert_eq(USize, v.len(), 2)

    ref p0 : I64 = prefix[0]
    ref p1 : I64 = prefix[1]
    ref v0 : I64 = v[0]
    ref v1 : I64 = v[1]

    assert_eq(I64, p0, 10)
    assert_eq(I64, p1, 20)
    assert_eq(I64, v0, 30)
    assert_eq(I64, v1, 40)
}

test_vec_take_prefix_str := test() {
    v := Vec(Str).new()
    v.push(own "aa")
    v.push(own "bb")
    v.push(own "cc")

    prefix := v.take_prefix(1)

    assert_eq(USize, prefix.len(), 1)
    assert_eq(USize, v.len(), 2)

    ref p0 : Str = prefix[0]
    ref v0 : Str = v[0]
    ref v1 : Str = v[1]

    assert_eq(Str, p0, "aa")
    assert_eq(Str, v0, "bb")
    assert_eq(Str, v1, "cc")
}

test_vec_append := test() {
    a := Vec(I64).new()
    b := Vec(I64).new()
    a.push(own 1)
    a.push(own 2)
    b.push(own 3)
    b.push(own 4)

    a.append(own b)

    assert_eq(USize, a.len(), 4)
    assert_eq(I64, a[0], 1)
    assert_eq(I64, a[1], 2)
    assert_eq(I64, a[2], 3)
    assert_eq(I64, a[3], 4)
}

test_vec_append_str := test() {
    a := Vec(Str).new()
    b := Vec(Str).new()
    a.push(own "aa")
    b.push(own "bb")
    b.push(own "cc")

    a.append(own b)

    assert_eq(USize, a.len(), 3)
    ref a0 : Str = a[0]
    ref a1 : Str = a[1]
    ref a2 : Str = a[2]
    assert_eq(Str, a0, "aa")
    assert_eq(Str, a1, "bb")
    assert_eq(Str, a2, "cc")
}

// Issue #284: collection for-in iterates via the unchecked unsafe_get
// accessor (the loop's `_fi < len()` test already proves the index in
// bounds). Results must be identical to the old checked-get path; this
// asserts the sum/order over a grown Vec is unchanged.
test_vec_for_in := test() {
    v := Vec(I64).new()
    v.push(own 1)
    v.push(own 2)
    v.push(own 3)
    v.push(own 4)
    v.push(own 5)
    v.push(own 6)
    v.push(own 7)
    v.push(own 8)
    v.push(own 9)
    v.push(own 10)
    mut sum : I64 = 0
    mut idx : USize = 0
    for x : I64 in v {
        assert_eq(I64, x, v[idx])
        sum = sum.add(x)
        idx++
    }
    assert_eq(USize, idx, 10)
    assert_eq(I64, sum, 55)
}

test_vec_for_in_str := test() {
    v := Vec(Str).new()
    v.push(own "a")
    v.push(own "b")
    v.push(own "c")
    mut joined := ""
    for s : Str in v {
        joined = format(joined, s)
    }
    assert_eq(Str, joined, "abc")
}

test_vec_take_prefix_append_roundtrip := test() {
    v := Vec(I64).new()
    v.push(own 5)
    v.push(own 6)
    v.push(own 7)
    v.push(own 8)

    prefix := v.take_prefix(2)
    prefix.append(own v)

    assert_eq(USize, prefix.len(), 4)
    assert_eq(I64, prefix[0], 5)
    assert_eq(I64, prefix[1], 6)
    assert_eq(I64, prefix[2], 7)
    assert_eq(I64, prefix[3], 8)
}
