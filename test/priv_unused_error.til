mode script

// Issue #187 step 1: each priv top-level decl below is unused in
// this file. The typer must flag every one with "unused priv ...;
// remove 'priv' to expose it".

priv unused_helper := func(x: I64) returns I64 { return x }

priv UnusedStruct := struct {
    value := 0
}

priv UnusedEnum := enum { A, B }

priv UNUSED_GLOBAL := 42
priv mut unused_counter := 0

// #187 step 2: priv struct field that nothing in the struct's own
// namespace ever reads. The struct itself is non-priv (so the
// top-level check stays quiet) but the field is dead.
StructWithUnusedField := struct {
    tag := 0
    priv secret := 0
namespace:
    show := func(self: StructWithUnusedField) returns I64 { return self.tag }
}

// #187 step 3: priv namespace method that no other ns member calls.
StructWithUnusedNs := struct {
    value := 0
namespace:
    public := func(self: StructWithUnusedNs) returns I64 { return self.value }
    priv unused_helper := func(self: StructWithUnusedNs) returns I64 {
        return self.value.add(1)
    }
}

// Construct + use the wrapper structs so the top-level check stays
// quiet; the new field/ns checks should still flag the priv members.
main := proc() {
    s1 := StructWithUnusedField(tag = 1)
    println(s1.show().to_str())
    s2 := StructWithUnusedNs(value = 2)
    println(s2.public().to_str())
}
