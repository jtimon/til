mode test

// Regression tests. Add new entries as bugs are fixed; one test per
// bug, named `bug<N>`. Top-level decls (structs, enums, maps) live in
// this file too -- prefix them with `Bug<N>` to avoid future
// collisions as more entries accumulate.

// --- #47: cross-namespace method calls -------------------------------
//
// Original bug: redeclaring I64 as ext_struct silently overwrote the
// core definition. Fix: struct/enum redeclaration now produces an
// error. This regression covers cross-namespace calls (calling methods
// from one type's namespace inside another type's namespace).

Bug47Helper := struct {
    const val : I64 = 0
namespace:
    make := func(n: I64) returns Bug47Helper {
        return Bug47Helper(val = n)
    }
}

Bug47Wrapper := struct {
    const data : Bug47Helper = Bug47Helper()
namespace:
    from_int := func(n: I64) returns Bug47Wrapper {
        // Cross-namespace call: Bug47Helper.make from Bug47Wrapper's namespace
        h := Bug47Helper.make(n)
        return Bug47Wrapper(data = h)
    }
}

bug47 := test() {
    // Cross-namespace call between user-defined structs
    w := Bug47Wrapper.from_int(42)
    assert_eq(I64, w.data.val, 42)
    // Cross-namespace call into a core type's namespace
    s := Str.with_capacity(10)
    assert_eq(Str, s, "")
}

// --- #125: enum payload helpers are capability-gated -----------------
//
// Payload enums remain usable when a payload type has no eq/to_str. The
// initer should omit those generated enum methods instead of emitting bodies
// that fail later while typing generated helper code.

Bug125Payload := struct {
    const value : I64 = 0
}

Bug125Enum := enum { Empty, Filled: Bug125Payload }

bug125 := test() {
    v := Bug125Enum.Filled(Bug125Payload(value = 7))
    mut got := 0
    switch v {
    case Bug125Enum.Filled(p):
        got = p.value
    case Bug125Enum.Empty:
        got = -1
    }
    assert_eq(I64, got, 7)
}

// --- #150 / #153: module-level enum-valued Map literal ---------------
//
// #150: scavenger dropped top-level init statements in test mode (so
// Map.set got pruned) and emit_as_ptr passed a stack compound literal
// to Map.set's own val param (so the internal free() hit a non-heap
// pointer and the binary aborted during teardown).
// #153: reinterpret_ptr_value hardcoded enum tag to 0, so
// `ref va : E = m.get("a")` always read back tag 0 in the interpreter.

Bug150E := enum { A, B, C }

Bug150M := {
    "a": Bug150E.A,
    "b": Bug150E.B
}

bug150 := test() {
    ref m : Map(Str, Bug150E) = Bug150M
    ref va : Bug150E = m["a"]
    assert(va.eq(Bug150E.A))
    ref vb : Bug150E = m["b"]
    assert(vb.eq(Bug150E.B))
}

// Tests for #185 (ref-Dynamic narrowed into typed-primitive call sites)
// live in test/dynamic.til as bug185_bool_dyn_arg_chain and
// bug185_u8_dyn_arg -- the test relies on dynamic.til's vec/Dynamic
// shapes. Tests for #186 (nested variadic-in-variadic) live in
// test/variadic.til as bug186_variadic_nested_in_variadic.
// Tests for #188 (nested kwargs-in-kwargs) live in
// test/kwargs.til as bug188_kwargs_nested_in_kwargs.

// --- #239: StructInstance/EnumInstance names use stable refs ---------

Bug239Leaf := struct {
    const n := 0
namespace:
    to_str := func(self: Bug239Leaf) returns Str {
        return self.n.to_str()
    }
}

Bug239Tag := enum { Leaf: Bug239Leaf, Num: I64, Empty }

Bug239Box := struct {
    const leaf := Bug239Leaf()
    const tag := Bug239Tag.Empty
}

bug239 := test() {
    box := Bug239Box(leaf = Bug239Leaf(n = 7),
                     tag = Bug239Tag.Leaf(Bug239Leaf(n = 9)))

    assert_eq(Str, box.leaf.to_str(), "7")

    switch box.tag {
    case Bug239Tag.Leaf(payload):
        assert_eq(Str, payload.to_str(), "9")
    case:
        UNREACHABLE()
    }
}

// --- #302: conditionally-transferred own params -----------------------
//
// Original bugs: the asap pass excluded ALL own params from the
// conditional-transfer sink and from pre-transfer exit-edge deletes.
// That exclusion is only correct for a param whose transfer is its own
// destructor call (a delete method's `if call_free { free(own self) }`);
// every ordinary own param transferred on one path leaked on the other
// (30 bytes per call in the repro), and an early return before the
// transfer leaked too. Procs so the constfolder cannot fold the calls
// away; the ASAN suite verifies the paths no longer leak.

bug302_sink := func(own s: Str) returns I64 {
    return s.len().to_i64()
}

bug302_cond_param := proc(own s: Str, flag: Bool) returns I64 {
    print_flush()
    if flag {
        return bug302_sink(own s)
    }
    return 0
}

bug302_early_param := proc(own s: Str, flag: Bool) returns I64 {
    print_flush()
    if flag { return 0 }
    return bug302_sink(own s)
}

test_bug302_cond_param_paths := test() {
    lit := "hello"
    a := lit.clone()
    assert(bug302_cond_param(own a, true) == 5)
    b := lit.clone()
    assert(bug302_cond_param(own b, false) == 0)
    c := lit.clone()
    assert(bug302_early_param(own c, false) == 5)
    d := lit.clone()
    assert(bug302_early_param(own d, true) == 0)
}

// #302 stage 3: sink_conditional_transfer_deletes only handled `if`,
// not a C-like `switch`. An owned local transferred in one case leaked
// on every other case (and on an unmatched scrutinee when the switch
// had no default). The sink now covers switch: each non-transferring
// case leaf gets the local's delete, and a `case:` default is
// synthesized to carry it for the unmatched path. ASAN verifies no leak
// on the non-transfer cases, no double-free on the transfer case.
// Proc + print_flush so the constfolder cannot fold the calls away.
bug302_sw_sink := func(own s: Str) returns I64 {
    return s.len().to_i64()
}

bug302_sw_transfer := proc(n: I64) returns I64 {
    print_flush()
    base := "heapstring"
    s := Str.clone(base)
    mut r : I64 = 0
    switch n {
    case 1: r = bug302_sw_sink(own s)
    case 2: r = 2
    case: r = 3
    }
    return r
}

test_bug302_switch_transfer := test() {
    assert(bug302_sw_transfer(1) == 10)
    assert(bug302_sw_transfer(2) == 2)
    assert(bug302_sw_transfer(3) == 3)
}

// --- #302: typed locals from raw allocators (raw_alloc provenance) ----
//
// Original bug: `buf : U8 = malloc(n)` MEANT different things depending
// on whether a `free(own buf)` appeared later in the body. The manual
// free's own-transfer promoted the local to Own (pointer form); without
// it the builder emitted a value local via the malloc-deref-free
// roundtrip -- reading one uninitialized byte and discarding the buffer.
// So the manual free could never be removed: its presence was what made
// the declaration a pointer. Now an allocator RHS (malloc / calloc /
// realloc) makes the local an owned heap block by provenance: pointer
// form always, and the garbager inserts the free itself (a bare free,
// never a deep delete -- the block is raw bytes).

bug302_alloc_sink := func(own p: U8) returns I64 {
    free(own p)
    return 1
}

// No manual free: the garbager owns the cleanup (ASAN verifies).
bug302_alloc_auto := proc() returns I64 {
    print_flush()
    buf : U8 = malloc(8)
    write_u8(buf, 42)
    return 0
}

// Manual free still present: the dtor transfer stands the pass down.
bug302_alloc_manual := proc() returns I64 {
    print_flush()
    buf : U8 = malloc(8)
    write_u8(buf, 43)
    free(own buf)
    return 0
}

// Transferred via own arg: the pass stands down; the callee frees.
bug302_alloc_transfer := proc() returns I64 {
    print_flush()
    buf : U8 = malloc(8)
    return bug302_alloc_sink(own buf)
}

test_bug302_raw_alloc := test() {
    assert(bug302_alloc_auto() == 0)
    assert(bug302_alloc_manual() == 0)
    assert(bug302_alloc_transfer() == 1)
}

// --- #302: move() and swap() are ownership primitives ----------------
//
// Original state: mem.til's move/swap were raw byte helpers
// (Dynamic + size args) with no ownership semantics -- a move() onto a
// live aggregate leaked its old contents (a typer guard existed just
// to forbid that). Now they work as they sound: swap(T, a, b)
// exchanges owners with the bytes; move(T, dest, own src) destroys
// dest's old value, adopts src's bytes, and consumes src -- exactly
// one owner before, exactly one after. ASAN verifies: no leak of the
// old dest, no double-free of the swapped/moved contents, src's
// wrapper reclaimed.

test_bug302_move_swap := test() {
    lit_a := "hi"
    mut a := lit_a.clone()
    lit_b := "hello"
    mut b := lit_b.clone()
    swap(Str, a, b)
    assert(a == "hello")
    assert(b == "hi")
    lit_c := "gone"
    mut c := lit_c.clone()
    move(Str, c, own a)
    assert(c == "hello")
    assert(b == "hi")
}
