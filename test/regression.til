mode test

// Regression tests. Add new entries as bugs are fixed; one test per
// bug, named `bug<N>`. Top-level decls (structs, enums, maps) live in
// this file too -- prefix them with `Bug<N>` to avoid future
// collisions as more entries accumulate.

// --- #47: cross-namespace method calls -------------------------------
//
// Original bug: redeclaring I64 as ext_struct silently overwrote the
// core definition. Fix: struct/enum redeclaration now produces an
// error. This regression covers cross-namespace calls (calling methods
// from one type's namespace inside another type's namespace).

Bug47Helper := struct {
    const val : I64 = 0
namespace:
    make := func(n: I64) returns Bug47Helper {
        return Bug47Helper(val = n)
    }
}

Bug47Wrapper := struct {
    const data : Bug47Helper = Bug47Helper()
namespace:
    from_int := func(n: I64) returns Bug47Wrapper {
        // Cross-namespace call: Bug47Helper.make from Bug47Wrapper's namespace
        h := Bug47Helper.make(n)
        return Bug47Wrapper(data = h)
    }
}

bug47 := test() {
    // Cross-namespace call between user-defined structs
    w := Bug47Wrapper.from_int(42)
    assert_eq(__LOC__, I64, w.data.val, 42)
    // Cross-namespace call into a core type's namespace
    s := Str.with_capacity(10)
    assert_eq(__LOC__, Str, s, "")
}

// --- #125: enum payload helpers are capability-gated -----------------
//
// Payload enums remain usable when a payload type has no eq/to_str. The
// initer should omit those generated enum methods instead of emitting bodies
// that fail later while typing generated helper code.

Bug125Payload := struct {
    const value : I64 = 0
}

Bug125Enum := enum { Empty, Filled: Bug125Payload }

bug125 := test() {
    v := Bug125Enum.Filled(Bug125Payload(value = 7))
    mut got := 0
    switch v {
    case Bug125Enum.Filled(p):
        got = p.value
    case Bug125Enum.Empty:
        got = -1
    }
    assert_eq(__LOC__, I64, got, 7)
}

// --- #150 / #153: module-level enum-valued Map literal ---------------
//
// #150: scavenger dropped top-level init statements in test mode (so
// Map.set got pruned) and emit_as_ptr passed a stack compound literal
// to Map.set's own val param (so the internal free() hit a non-heap
// pointer and the binary aborted during teardown).
// #153: reinterpret_ptr_value hardcoded enum tag to 0, so
// `ref va : E = m.get("a")` always read back tag 0 in the interpreter.

Bug150E := enum { A, B, C }

Bug150M := {
    "a": Bug150E.A,
    "b": Bug150E.B
}

bug150 := test() {
    ref m : Map(Str, Bug150E) = Bug150M
    ref va : Bug150E = m["a"]
    assert(__LOC__, va.eq(Bug150E.A))
    ref vb : Bug150E = m["b"]
    assert(__LOC__, vb.eq(Bug150E.B))
}

// Tests for #185 (ref-Dynamic narrowed into typed-primitive call sites)
// live in test/dynamic.til as bug185_bool_dyn_arg_chain and
// bug185_u8_dyn_arg -- the test relies on dynamic.til's vec/Dynamic
// shapes. Tests for #186 (nested variadic-in-variadic) live in
// test/variadic.til as bug186_variadic_nested_in_variadic.
// Tests for #188 (nested kwargs-in-kwargs) live in
// test/kwargs.til as bug188_kwargs_nested_in_kwargs.

// --- #239: StructInstance/EnumInstance names use stable refs ---------

Bug239Leaf := struct {
    const n := 0
namespace:
    to_str := func(self: Bug239Leaf) returns Str {
        return self.n.to_str()
    }
}

Bug239Tag := enum { Leaf: Bug239Leaf, Num: I64, Empty }

Bug239Box := struct {
    const leaf := Bug239Leaf()
    const tag := Bug239Tag.Empty
}

bug239 := test() {
    box := Bug239Box(leaf = Bug239Leaf(n = 7),
                     tag = Bug239Tag.Leaf(Bug239Leaf(n = 9)))

    ref leaf_ref : Bug239Leaf = box.leaf
    assert_eq(__LOC__, Str, leaf_ref.to_str(), "7")

    switch box.tag {
    case Bug239Tag.Leaf(payload):
        assert_eq(__LOC__, Str, payload.to_str(), "9")
    case:
        UNREACHABLE(__LOC__)
    }
}
