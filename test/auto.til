mode test

// Auto-generated inc/dec from add+sub+unity

Vec2 := struct {
    x : I64 = 0
    y : I64 = 0
namespace:
    add := func(a: Vec2, b: Vec2) returns Vec2 {
        return Vec2(x = a.x.add(b.x), y = a.y.add(b.y))
    }
    sub := func(a: Vec2, b: Vec2) returns Vec2 {
        return Vec2(x = a.x.sub(b.x), y = a.y.sub(b.y))
    }
    unity := func(_self: Vec2) returns Vec2 { return Vec2(x = 1, y = 1) }
    cmp := func(a: Vec2, b: Vec2) returns I64 {
        if a.x.lt(b.x) { return -1 }
        if a.x.gt(b.x) { return 1 }
        return a.y.cmp(b.y)
    }
    to_str := func(self: Vec2) returns Str { return self.x.to_str() }
}

test_vec2_inc_dec := test() {
    mut v := Vec2(x = 3, y = 5)
    v++
    assert_eq(__LOC__, I64, v.x, 4)
    assert_eq(__LOC__, I64, v.y, 6)
    v--
    assert_eq(__LOC__, I64, v.x, 3)
    assert_eq(__LOC__, I64, v.y, 5)
}

// Auto-generated lt/gt/lte/gte/eq/neq from a user-defined cmp.
// Vec2 above defines cmp; the comparison ops below are all derived.
test_vec2_cmp_derived := test() {
    a := Vec2(x = 1, y = 2)
    b := Vec2(x = 1, y = 5)
    c := Vec2(x = 1, y = 2)

    assert(__LOC__, a.lt(b))
    assert(__LOC__, b.gt(a))
    assert(__LOC__, a.lte(c))
    assert(__LOC__, a.gte(c))
    assert(__LOC__, a.lte(b))
    assert(__LOC__, b.gte(a))
    assert(__LOC__, a.eq(c))
    assert(__LOC__, a.neq(b))
}
