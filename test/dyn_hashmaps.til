mode test

import("../src/std/dyn_hashmap")

test_dyn_hashmap_i64_basic := test() {
    m := DynHashMap.new(I64, I64)
    m.set(own 1, own 10)
    m.set(own 2, own 20)
    m.set(own 3, own 30)
    assert_eq(__LOC__, m.len().to_i64(), 3)
    assert(__LOC__, m.has(1))
    assert(__LOC__, m.has(2))
    assert(__LOC__, m.has(3))
    assert(__LOC__, m.has(4).not())

    ref v1 : I64 = m.get(1)
    ref v2 : I64 = m.get(2)
    ref v3 : I64 = m.get(3)
    assert_eq(__LOC__, v1, 10)
    assert_eq(__LOC__, v2, 20)
    assert_eq(__LOC__, v3, 30)
}

test_dyn_hashmap_i64_overwrite := test() {
    m := DynHashMap.new(I64, I64)
    m.set(own 5, own 50)
    m.set(own 5, own 500)
    assert_eq(__LOC__, m.len().to_i64(), 1)
    ref v : I64 = m.get(5)
    assert_eq(__LOC__, v, 500)
}

test_dyn_hashmap_str_keys := test() {
    m := DynHashMap.new(Str, I64)
    m.set(own "apple", own 1)
    m.set(own "banana", own 2)
    m.set(own "cherry", own 3)
    assert_eq(__LOC__, m.len().to_i64(), 3)
    assert(__LOC__, m.has("apple"))
    assert(__LOC__, m.has("banana"))
    assert(__LOC__, m.has("cherry"))
    assert(__LOC__, m.has("date").not())

    ref va : I64 = m.get("apple")
    ref vb : I64 = m.get("banana")
    ref vc : I64 = m.get("cherry")
    assert_eq(__LOC__, va, 1)
    assert_eq(__LOC__, vb, 2)
    assert_eq(__LOC__, vc, 3)
}

test_dyn_hashmap_str_value := test() {
    m := DynHashMap.new(Str, Str)
    m.set(own "key1", own "value1")
    m.set(own "key2", own "value2")
    assert_eq(__LOC__, m.len().to_i64(), 2)
    ref v1 : Str = m.get("key1")
    ref v2 : Str = m.get("key2")
    assert_eq_str(__LOC__, v1, "value1")
    assert_eq_str(__LOC__, v2, "value2")
}

test_dyn_hashmap_grow_past_initial_buckets := test() {
    m := DynHashMap.new(I64, I64)
    for i in 0..100 {
        m.set(own i, own i.mul(10))
    }
    assert_eq(__LOC__, m.len().to_i64(), 100)
    for i in 0..100 {
        assert(__LOC__, m.has(i))
        ref v : I64 = m.get(i)
        assert_eq(__LOC__, v, i.mul(10))
    }
    assert(__LOC__, m.has(100).not())
    assert(__LOC__, m.has(-1).not())
}

test_dyn_hashmap_str_overwrite_releases_old_value := test() {
    m := DynHashMap.new(Str, Str)
    m.set(own "k", own "first")
    m.set(own "k", own "second")
    assert_eq(__LOC__, m.len().to_i64(), 1)
    ref v : Str = m.get("k")
    assert_eq_str(__LOC__, v, "second")
}

test_dyn_hashmap_remove_missing_is_noop := test() {
    m := DynHashMap.new(I64, I64)
    m.set(own 1, own 10)
    m.remove(99)
    assert_eq(__LOC__, m.len().to_i64(), 1)
    assert(__LOC__, m.has(1))
}

test_dyn_hashmap_remove_only_entry := test() {
    m := DynHashMap.new(I64, I64)
    m.set(own 5, own 50)
    m.remove(5)
    assert_eq(__LOC__, m.len().to_i64(), 0)
    assert(__LOC__, m.has(5).not())
}

test_dyn_hashmap_remove_then_reinsert := test() {
    m := DynHashMap.new(I64, I64)
    m.set(own 7, own 70)
    m.remove(7)
    m.set(own 7, own 700)
    assert_eq(__LOC__, m.len().to_i64(), 1)
    ref v : I64 = m.get(7)
    assert_eq(__LOC__, v, 700)
}

test_dyn_hashmap_remove_swap_keeps_others_findable := test() {
    m := DynHashMap.new(I64, I64)
    for i in 0..50 {
        m.set(own i.clone(), own i.mul(10))
    }
    m.remove(7)
    m.remove(23)
    m.remove(42)
    assert_eq(__LOC__, m.len().to_i64(), 47)
    for i in 0..50 {
        if i.eq(7).or(i.eq(23)).or(i.eq(42)) {
            assert(__LOC__, m.has(i).not())
        } else {
            assert(__LOC__, m.has(i))
            ref v : I64 = m.get(i)
            assert_eq(__LOC__, v, i.mul(10))
        }
    }
}

test_dyn_hashmap_remove_all := test() {
    m := DynHashMap.new(I64, I64)
    for i in 0..20 {
        m.set(own i.clone(), own i.mul(10))
    }
    for i in 0..20 {
        m.remove(i)
    }
    assert_eq(__LOC__, m.len().to_i64(), 0)
    for i in 0..20 {
        assert(__LOC__, m.has(i).not())
    }
    m.set(own 99, own 990)
    assert_eq(__LOC__, m.len().to_i64(), 1)
    ref v : I64 = m.get(99)
    assert_eq(__LOC__, v, 990)
}

test_dyn_hashmap_remove_str_key_frees_c_str := test() {
    m := DynHashMap.new(Str, I64)
    m.set(own "apple", own 1)
    m.set(own "banana", own 2)
    m.remove("apple")
    assert_eq(__LOC__, m.len().to_i64(), 1)
    assert(__LOC__, m.has("apple").not())
    assert(__LOC__, m.has("banana"))
    ref v : I64 = m.get("banana")
    assert_eq(__LOC__, v, 2)
}
