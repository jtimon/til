mode lib

// Public: visible to importers.
add_one := func(x: I64) returns I64 {
    return x.add(internal_inc(1))
}

// Private to this file: cross-file references must error.
priv internal_inc := func(x: I64) returns I64 {
    return x.add(1)
}

// #179 step 2: a priv struct -- type name hidden from other files.
priv Secret := struct {
    value := 0
namespace:
    show := func(self: Secret) returns I64 { return self.value }
}

// Public factory that returns a value derived from the priv struct.
// Same-file usage of Secret is fine; the returned I64 carries no
// reference to the hidden type.
make_secret := func(v: I64) returns I64 {
    s := Secret(value = v)
    return s.show()
}

// #179 step 4: a public struct with a priv field. The field is
// invisible outside Box's own namespace methods, even within this
// declaring file.
Box := struct {
    tag := 0
    priv hidden := 0
namespace:
    // Public method may read the priv field freely (same struct).
    hidden_plus_one := func(self: Box) returns I64 {
        return self.hidden.add(1)
    }
    // #179 step 5: priv namespace method, only callable via other
    // Box methods or `Box.bump_hidden(...)` from inside the struct.
    priv bump_hidden := func(mut self: Box) {
        self.hidden = self.hidden.add(1)
    }
    // Public wrapper that internally calls the priv namespace method.
    bump_and_show := func(mut self: Box) returns I64 {
        Box.bump_hidden(self)
        return self.hidden
    }
}

// Public factory: same-file usage of priv field is allowed inside
// the struct's namespace; this top-level helper isn't a Box method,
// so it can only set hidden by going through the struct. Keep one
// here so tests can build a Box without naming `hidden` from outside.
make_box := func(t: I64, h: I64) returns Box {
    // hidden is priv, but make_box lives in the same file as Box
    // and is NOT a Box namespace method -- this is intentionally
    // forbidden. We construct via the public tag and bump_and_show
    // to drive hidden indirectly.
    mut b := Box(tag = t)
    for _ in 0..h { b.bump_and_show() }
    return b
}

// #179 step 3: a priv enum -- type and variants hidden from other files.
priv Mood := enum { Happy, Sad, Bored }

// #179 step 6: priv top-level globals (mut + immutable). Other files
// must not name these directly. Public accessors expose the value.
priv MAGIC : I64 = 42
priv mut counter := 0

magic_value := func() returns I64 { return MAGIC }
bump_counter := proc() returns I64 {
    counter++
    println("bump")
    return counter
}
get_counter := func() returns I64 { return counter }

// Public factory that maps to an I64 -- the priv enum stays internal.
mood_score := func(m: I64) returns I64 {
    mut v := Mood.Bored
    if m.eq(0) { v = Mood.Happy }
    if m.eq(1) { v = Mood.Sad }
    switch v {
    case Mood.Happy: return 1
    case Mood.Sad:   return -1
    case Mood.Bored: return 0
    }
    return 0
}
