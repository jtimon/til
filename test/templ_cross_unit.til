mode test

import("imports/templ_cross_a")
import("imports/templ_cross_b")

test_templ_cross_unit_dedup := test() {
    a : CrossBox(I64) = cross_a_box()
    b : CrossBox(I64) = cross_b_box()
    ref av : I64 = a.get()
    ref bv : I64 = b.get()
    assert_eq(I64, av, 11)
    assert_eq(I64, bv, 21)
    assert_eq(I64, cross_a_value(), 12)
    assert_eq(I64, cross_b_value(), 22)
}
