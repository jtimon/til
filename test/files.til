mode test

test_file_write_and_read := test() {
    path := "tmp/_test_file_io.txt"
    f := File.new(path, true)
    f.write("hello ")
    f.write("world")

    f2 := File.new(path, false)
    content := f2.read_all()

    assert_eq_str(__LOC__, content, "hello world")
}

test_file_read_all := test() {
    path := "tmp/_test_file_read.txt"
    File.writefile(path, "abc123")

    f := File.new(path, false)
    content := f.read_all()

    assert_eq_str(__LOC__, content, "abc123")
}

test_file_multiple_writes := test() {
    path := "tmp/_test_file_multi.txt"
    f := File.new(path, true)
    for i in 0..5 {
        f.write(i.to_str())
        f.write(" ")
    }

    content := File.readfile(path)
    assert_eq_str(__LOC__, content, "0 1 2 3 4 ")
}

test_file_seek_tell_read := test() {
    path := "tmp/_test_file_cursor.txt"
    File.writefile(path, "hello world")

    f := File.new(path, false)
    assert_eq(__LOC__, f.tell(), 0)

    // Partial read from the start advances the cursor.
    first := f.read(5)
    assert_eq_str(__LOC__, first, "hello")
    assert_eq(__LOC__, f.tell(), 5)

    // Seek to an absolute offset, then read a region.
    f.seek(6)
    assert_eq(__LOC__, f.tell(), 6)
    rest := f.read(5)
    assert_eq_str(__LOC__, rest, "world")
}

test_file_read_past_eof := test() {
    path := "tmp/_test_file_eof.txt"
    File.writefile(path, "abc")

    f := File.new(path, false)
    // Asking for more bytes than remain returns only what is there.
    got := f.read(100)
    assert_eq_str(__LOC__, got, "abc")
    assert_eq(__LOC__, f.tell(), 3)
}

test_file_update_in_place := test() {
    path := "tmp/_test_file_update.txt"
    File.writefile(path, "hello world")

    // Patch a region without rewriting the whole file.
    f := File.update(path)
    f.seek(6)
    f.write("there")

    content := File.readfile(path)
    assert_eq_str(__LOC__, content, "hello there")
}
