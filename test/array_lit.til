mode test

test_i64_array_literal := test() {
    arr := array("I64", 1, 2, 3)
    assert_eq(__LOC__, arr.len().to_i64(), 3)
    ref a0 : I64 = arr[0]
    ref a1 : I64 = arr[1]
    ref a2 : I64 = arr[2]
    assert_eq(__LOC__, a0, 1)
    assert_eq(__LOC__, a1, 2)
    assert_eq(__LOC__, a2, 3)
}

test_i64_vec_literal := test() {
    myvec := vec("I64", 10, 20, 30)
    assert_eq(__LOC__, myvec.len().to_i64(), 3)
    ref v0 : I64 = myvec[0]
    ref v1 : I64 = myvec[1]
    ref v2 : I64 = myvec[2]
    assert_eq(__LOC__, v0, 10)
    assert_eq(__LOC__, v1, 20)
    assert_eq(__LOC__, v2, 30)
}

test_str_array_literal := test() {
    sarr := array("Str", "hello", "world")
    assert_eq(__LOC__, sarr.len().to_i64(), 2)
    ref s0 : Str = sarr[0]
    ref s1 : Str = sarr[1]
    assert_eq_str(__LOC__, s0, "hello")
    assert_eq_str(__LOC__, s1, "world")
}

test_str_vec_literal := test() {
    svec := vec("Str", "foo", "bar", "baz")
    assert_eq(__LOC__, svec.len().to_i64(), 3)
    ref sv0 : Str = svec[0]
    ref sv1 : Str = svec[1]
    ref sv2 : Str = svec[2]
    assert_eq_str(__LOC__, sv0, "foo")
    assert_eq_str(__LOC__, sv1, "bar")
    assert_eq_str(__LOC__, sv2, "baz")
}
