mode cli

// Test: global variables accessible from functions and procs (cli mode),
// including forward refs to globals declared later
// See issue #17

f := func() returns I64 {
    return x
}

g := proc() {
    println(x.to_str())
}

h := proc() {
    y := x
    println(y.to_str())
}

inc := func() {
    counter++
}

get_counter := func() returns I64 {
    return counter
}

x := 42
mut counter := 0

main := proc() {
    println(f().to_str())
    g()
    h()
    inc()
    inc()
    inc()
    assert(get_counter().eq(3))
    assert(counter.eq(3))
    counter = 100
    assert(counter.eq(100))
    println("globals cli: ok")
}
