mode test

import("../src/core/dyn")
import("../lib/hash")

// Issue #236: a file-level `mut X : HashFn = fnv1a` decl was emitted as
// a fresh function-local in main() that shadowed the global. The fix
// in src/self/builder.til detects script-global FuncPtr decls and
// emits a plain assignment instead. These tests pin the working
// behaviour: declare, observe the default, swap, observe the swap.

mut TEST_FILE_LEVEL_HASHER : HashFn = fnv1a

test_file_level_funcptr_default := test() {
    h := TEST_FILE_LEVEL_HASHER("abc", 3)
    expected := fnv1a("abc", 3)
    assert(__LOC__, h.eq(expected))
}

test_file_level_funcptr_swap := test() {
    TEST_FILE_LEVEL_HASHER = knuth_bytes
    h := TEST_FILE_LEVEL_HASHER("abc", 3)
    expected := knuth_bytes("abc", 3)
    assert(__LOC__, h.eq(expected))
    // Restore so the test pair is order-independent.
    TEST_FILE_LEVEL_HASHER = fnv1a
}
