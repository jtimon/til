mode script

import("../src/self/lexer")
import("../src/self/ast")
import("../src/self/parser")

// Helper: tokenize + parse
parse_src := proc(src: Str) returns Expr {
    tokens := tokenize(src, "test")
    mut mode_str := ""
    return parse(tokens, src, "test", mode_str)
}

test_empty := proc() {
    root := parse_src("")
    assert(__LOC__, root.node_type.is(NodeType.Body))
    assert_eq(__LOC__, root.children.len().to_i64(), 0)
}

test_declaration := proc() {
    root := parse_src("x := 42")
    assert_eq(__LOC__, root.children.len().to_i64(), 1)
    ref decl : Expr = root.children.get(0)
    assert_eq_str(__LOC__, node_name(decl.node_type), "decl")
    switch decl.node_type {
    case NodeType.Decl(dd):
        assert_eq_str(__LOC__, dd.name, "x")
        assert_eq_str(__LOC__, dd.explicit_type, "")
    case:
        UNREACHABLE(__LOC__)
    }
    assert_eq(__LOC__, decl.children.len().to_i64(), 1)
    ref val : Expr = decl.children.get(0)
    assert_eq_str(__LOC__, node_name(val.node_type), "num")
}

test_typed_decl := proc() {
    root := parse_src("x : I64 = 0")
    ref decl : Expr = root.children.get(0)
    switch decl.node_type {
    case NodeType.Decl(dd):
        assert_eq_str(__LOC__, dd.name, "x")
        assert_eq_str(__LOC__, dd.explicit_type, "I64")
    case:
        UNREACHABLE(__LOC__)
    }
}

test_assignment := proc() {
    root := parse_src("x = 1")
    ref assign : Expr = root.children.get(0)
    assert_eq_str(__LOC__, node_name(assign.node_type), "assign")
    switch assign.node_type {
    case NodeType.Assign(_as):
        assert_eq_str(__LOC__, _as, "x")
    case:
        UNREACHABLE(__LOC__)
    }
    assert_eq(__LOC__, assign.children.len().to_i64(), 1)
}

test_call := proc() {
    root := parse_src("foo(1, 2)")
    ref call : Expr = root.children.get(0)
    assert_eq_str(__LOC__, node_name(call.node_type), "fcall")
    assert_eq(__LOC__, call.children.len().to_i64(), 3)
    ref callee : Expr = call.children.get(0)
    assert_eq_str(__LOC__, node_name(callee.node_type), "ident")
    switch callee.node_type {
    case NodeType.Ident(_ci):
        assert_eq_str(__LOC__, _ci, "foo")
    case:
        UNREACHABLE(__LOC__)
    }
}

test_method_call := proc() {
    root := parse_src("x.foo(1)")
    ref call : Expr = root.children.get(0)
    assert_eq_str(__LOC__, node_name(call.node_type), "fcall")
    assert_eq(__LOC__, call.children.len().to_i64(), 2)
    ref callee : Expr = call.children.get(0)
    assert_eq_str(__LOC__, node_name(callee.node_type), "field_access")
    switch callee.node_type {
    case NodeType.FieldAccess(_cf):
        assert_eq_str(__LOC__, _cf, "foo")
    case:
        UNREACHABLE(__LOC__)
    }
}

test_method_call_on_subscript_receiver := proc() {
    root := parse_src("e.children[0].set_expr_til_type(t)")
    ref call : Expr = root.children.get(0)
    assert_eq_str(__LOC__, node_name(call.node_type), "fcall")
    ref callee : Expr = call.children.get(0)
    assert_eq_str(__LOC__, node_name(callee.node_type), "field_access")
    switch callee.node_type {
    case NodeType.FieldAccess(_cf):
        assert_eq_str(__LOC__, _cf, "set_expr_til_type")
    case:
        UNREACHABLE(__LOC__)
    }
}

test_if_else := proc() {
    root := parse_src("if true { x = 1 } else { x = 2 }")
    ref node : Expr = root.children.get(0)
    assert_eq_str(__LOC__, node_name(node.node_type), "if")
    assert_eq(__LOC__, node.children.len().to_i64(), 3)
}

test_while := proc() {
    root := parse_src("while true { x = 1 }")
    ref node : Expr = root.children.get(0)
    assert_eq_str(__LOC__, node_name(node.node_type), "while")
    assert_eq(__LOC__, node.children.len().to_i64(), 2)
}

test_func_def := proc() {
    root := parse_src("f := func(x: I64) returns I64 { return x }")
    ref decl : Expr = root.children.get(0)
    assert_eq_str(__LOC__, node_name(decl.node_type), "decl")
    assert_eq(__LOC__, decl.children.len().to_i64(), 1)
    ref fdef : Expr = decl.children.get(0)
    assert_eq_str(__LOC__, node_name(fdef.node_type), "func_def")
    switch fdef.node_type {
    case NodeType.FuncDef(fd):
        assert_eq_str(__LOC__, func_type_name(fd.func_type), "func")
        assert_eq_str(__LOC__, fd.return_type, "I64")
        assert_eq(__LOC__, fd.param_names.len().to_i64(), 1)
    case:
        UNREACHABLE(__LOC__)
    }
}

test_struct_def := proc() {
    root := parse_src("P := struct { mut x := 0 }")
    ref decl : Expr = root.children.get(0)
    assert_eq_str(__LOC__, node_name(decl.node_type), "decl")
    ref sdef : Expr = decl.children.get(0)
    assert_eq_str(__LOC__, node_name(sdef.node_type), "struct_def")
    ref body : Expr = sdef.children.get(0)
    assert_eq(__LOC__, body.children.len().to_i64(), 1)
}

test_switch := proc() {
    root := parse_src("switch x { case 1: y = 1 case 2: y = 2 case: y = 0 }")
    ref node : Expr = root.children.get(0)
    assert_eq_str(__LOC__, node_name(node.node_type), "switch")
    assert_eq(__LOC__, node.children.len().to_i64(), 4)
    ref c1 : Expr = node.children.get(1)
    assert_eq(__LOC__, c1.children.len().to_i64(), 2)
    ref cd : Expr = node.children.get(3)
    assert_eq(__LOC__, cd.children.len().to_i64(), 1)
}

test_for_in := proc() {
    root := parse_src("for i in 0..10 { x = i }")
    ref node : Expr = root.children.get(0)
    assert_eq_str(__LOC__, node_name(node.node_type), "for_in")
    switch node.node_type {
    case NodeType.ForIn(fi):
        assert_eq_str(__LOC__, fi.name, "i")
    case:
        UNREACHABLE(__LOC__)
    }
    assert_eq(__LOC__, node.children.len().to_i64(), 2)
}

test_empty()
test_declaration()
test_typed_decl()
test_assignment()
test_call()
test_method_call()
test_method_call_on_subscript_receiver()
test_if_else()
test_while()
test_func_def()
test_struct_def()
test_switch()
test_for_in()

println("parsing: ok")
