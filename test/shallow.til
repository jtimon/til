mode test

// Test shallow params on regular func
add_shallow := func(a: I64, b: I64) returns I64 {
    return a.add(b)
}

test_shallow_basic := test() {
    assert_eq(__LOC__, I64, add_shallow(3, 4), 7)
}

// Test shallow with non-shallow mix
mixed := func(a: I64, b: I64) returns I64 {
    return a.add(b)
}

test_shallow_mixed := test() {
    assert_eq(__LOC__, I64, mixed(10, 20), 30)
}

// Test shallow Bool
both_true := func(a: Bool, b: Bool) returns Bool {
    return a.and(b)
}

test_shallow_bool := test() {
    assert(__LOC__, both_true(true, true))
    assert(__LOC__, both_true(true, false).not())
}

// Test shallow param passed to another function
double_it := func(x: I64) returns I64 {
    return x.mul(2)
}

chain := func(a: I64) returns I64 {
    return double_it(a)
}

test_shallow_chain := test() {
    assert_eq(__LOC__, I64, chain(5), 10)
}

// Test shallow param used in expressions
expr_test := func(a: I64, b: I64) returns I64 {
    c := a.add(b)
    d := c.mul(2)
    return d
}

test_shallow_expr := test() {
    assert_eq(__LOC__, I64, expr_test(3, 4), 14)
}

// shallow param forwarded into another shallow func
test_shallow_forward := test() {
    assert_eq(__LOC__, I64, mixed(chain(3), 1), 7)
}

// === Issue #223 step 3: auto-shallow for small value-shaped structs ===

// SmallPair is 8 bytes (2 x I32), no own/ref fields, all-primitive fields
// -> auto-shallow: passed/returned by value WITHOUT the keyword.
SmallPair := struct {
    a : I32 = 0
    b : I32 = 0
}

add_pair := func(p: SmallPair) returns I64 {
    return p.a.cast(I64).add(p.b.cast(I64))
}

make_pair := func(x: I32, y: I32) returns SmallPair {
    return SmallPair(a = x, b = y)
}

test_auto_shallow_small_struct := test() {
    p := make_pair(10, 32)
    assert_eq(__LOC__, I64, add_pair(p), 42)
}

// === Issue #223 step 4: explicit `shallow` on a struct is force/override ===

// Explicit `shallow` on a struct that ALSO auto-qualifies: honored, NOT
// rejected as redundant (unlike a primitive, which would be).
add_pair_explicit := func(shallow p: SmallPair) returns I64 {
    return p.a.cast(I64).add(p.b.cast(I64))
}

test_explicit_shallow_small_struct := test() {
    assert_eq(__LOC__, I64, add_pair_explicit(SmallPair(a = 1, b = 4)), 5)
}

// BigQuad is 4 words (4 x I64) -> does NOT auto-qualify for step 3. An
// explicit `shallow` forces by-value passing anyway (the user opts in).
BigQuad := struct {
    a := 0
    b := 0
    c := 0
    d := 0
namespace:
    sum := func(shallow self: BigQuad) returns I64 {
        return self.a.add(self.b).add(self.c).add(self.d)
    }
}

test_shallow_forced_on_big_struct := test() {
    q := BigQuad(a = 1, b = 2, c = 3, d = 4)
    assert_eq(__LOC__, I64, BigQuad.sum(q), 10)
}
