mode test

# basic macro with I64 args
macro_add := macro(a: I64, b: I64) returns I64 {
    return a.add(b)
}

test_basic_macro := test() {
    assert_eq(I64, macro_add(3, 4), 7)
}

test_macro_const_arg := test() {
    N := 10
    assert_eq(I64, macro_add(N, 5), 15)
}

# macro returning Str
macro_greet := macro(name: Str) returns Str {
    return format("hello ", name)
}

test_macro_str := test() {
    assert_eq(Str, macro_greet("world"), "hello world")
}

# macro body can call procs (runs at compile time)
macro_double := macro(x: I64) returns I64 {
    println("constfolder: doubling ", x.to_str())
    return x.mul(2)
}

test_macro_proc_call := test() {
    assert_eq(I64, macro_double(21), 42)
}

# macro called from inside a func (with literal arg)
macro_square := macro(x: I64) returns I64 {
    return x.mul(x)
}
square_plus_one := func() returns I64 {
    s := macro_square(7)
    return s.add(1)
}

test_macro_in_func := test() {
    assert_eq(I64, square_plus_one(), 50)
}

# macro returning Bool
macro_is_big := macro(x: I64) returns Bool {
    return x.gt(100)
}

test_macro_bool := test() {
    expect(macro_is_big(200), "200 is big")
    expect(macro_is_big(50).not(), "50 is not big")
}

# --- constant folding for pure funcs ---

double := func(x: I64) returns I64 {
    return x.mul(2)
}

test_func_folding := test() {
    assert_eq(I64, double(5), 10)
    assert_eq(I64, double(double(3)), 12)
}

test_func_const_arg := test() {
    K := 7
    assert_eq(I64, double(K), 14)
}

greet := func(name: Str) returns Str {
    return format("hi ", name)
}

test_func_str := test() {
    assert_eq(Str, greet("til"), "hi til")
}

# #136: Dynamic.size() is defined as `func() returns USize { return 8 }`
# in dyn.til; before the fix, the builder's size() override emitted
# sizeof(Dynamic) = 1 (Dynamic is `struct { char _; }` in C).
test_func_ns_method_size := test() {
    assert_eq(USize, Dynamic.size(), 8)
}

# --- #285: macro args accept foldable namespace-method calls ---

# A foldable namespace-method call on a comptime constant
# (`MACRO_ONE_F.add(MACRO_ONE_F)`) resolves to the F32 namespace method
# `F32.add`, whose FuncDef lives in the F32 namespace rather than as a flat
# `F32_add` binding. expr_is_comptime used to resolve the callee only through
# scope.get_binding, so that flat-name miss wrongly rejected the arg with
# "macro argument must be known at compile time". (#294 forbids the original
# `2.to_f32()` literal-conversion form this test used; a comptime const's
# namespace-method call exercises the same callee-resolution path.)
MACRO_ONE_F : F32 = 1
macro_f32_id := macro(x: F32) returns F32 {
    return x
}

test_macro_to_f32_arg := test() {
    assert_eq(I64, macro_f32_id(MACRO_ONE_F.add(MACRO_ONE_F)).to_i64(), 2)
}

# Newton-sqrt macro reused from the lib/music.til case that surfaced #285.
calculate_sqrt := macro(x: F32) returns F32 {
    mut guess := x
    for _ in 0..12 {
        guess = guess.add(x.div(guess)).div(2)
    }
    return guess
}

# Nested macro calls whose innermost arg is a foldable namespace call
# (`MACRO_ONE_F.add(MACRO_ONE_F)` == 2.0). Folds to 2^(1/8); raising it to the
# 8th power recovers 2 exactly enough that adding 0.5 and truncating lands on 2
# regardless of F32 rounding.
nathex_step_ratio := macro() returns F32 {
    return calculate_sqrt(calculate_sqrt(calculate_sqrt(MACRO_ONE_F.add(MACRO_ONE_F))))
}

test_macro_nested_foldable_args := test() {
    step := nathex_step_ratio()
    pow2 := step.mul(step)
    pow4 := pow2.mul(pow2)
    pow8 := pow4.mul(pow4)
    assert_eq(I64, pow8.add(0.5).to_i64(), 2)
}
