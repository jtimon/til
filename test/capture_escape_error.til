mode test

UnaryOp := func(I64) returns I64

make_multiplier := func(factor: I64) returns UnaryOp {
    local_factor := factor
    return func(x: I64) returns I64 [local_factor] { return x.mul(local_factor) }
}

test_returned_borrowed_closure_error := test() {
    triple := make_multiplier(3)
    println(triple(6).to_str())
}
