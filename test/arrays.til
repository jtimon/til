mode test

test_array_new_get_set := test() {
    a := Array(I64).new(3)
    a.set(0, own 10)!
    a.set(1, own 20)!
    a.set(2, own 30)!

    ref x : I64 = a.get(0)!
    ref y : I64 = a.get(1)!
    ref z : I64 = a.get(2)!

    assert_eq(I64, x, 10)
    assert_eq(I64, y, 20)
    assert_eq(I64, z, 30)
    assert_eq(USize, a.len(), 3)
}

// Issue #284: collection for-in iterates via the unchecked unsafe_get
// accessor; results must match the old checked-get path.
test_array_for_in := test() {
    a := Array(I64).new(4)
    a.set(0, own 5)!
    a.set(1, own 6)!
    a.set(2, own 7)!
    a.set(3, own 8)!
    mut sum : I64 = 0
    mut idx : USize = 0
    for x : I64 in a {
        ref expect_x : I64 = a.get(idx)!
        assert_eq(I64, x, expect_x)
        sum = sum.add(x)
        idx = idx.add(1)
    }
    assert_eq(USize, idx, 4)
    assert_eq(I64, sum, 26)
}

// a[i] desugars to a.get(i)! in the parser (generic over any type
// whose get throws), so subscript and explicit get(i)! agree.
test_array_subscript := test() {
    a := Array(I64).new(3)
    a.set(0, own 10)!
    a.set(1, own 20)!
    a.set(2, own 30)!

    ref x : I64 = a[0]
    ref y : I64 = a[1]
    ref z : I64 = a[2]

    assert_eq(I64, x, 10)
    assert_eq(I64, y, 20)
    assert_eq(I64, z, 30)

    // Subscript with a computed index expression.
    mut i : USize = 1
    assert_eq(I64, a[i.add(1)], 30)
}

// Issue #225: subscript assignment `a[i] = x` desugars to
// `a.set(i, own x)!`, the write-side mirror of `a[i] -> a.get(i)!`.
// Literal and computed indices, round-trip asserted under interp and
// compile.
test_array_subscript_assign := test() {
    a := Array(I64).new(3)
    a[0] = 10
    a[1] = 20
    a[2] = 30

    a[0] = 100            // literal index
    idx : USize = 1
    a[idx.add(1)] = 300   // computed index

    ref x : I64 = a[0]
    ref y : I64 = a[1]
    ref z : I64 = a[2]
    assert_eq(I64, x, 100)
    assert_eq(I64, y, 20)
    assert_eq(I64, z, 300)
}

test_array_subscript_assign_str := test() {
    a := Array(Str).new(2)
    a[0] = "hello"
    a[1] = "world"
    a[0] = "zzz"
    ref s0 : Str = a[0]
    ref s1 : Str = a[1]
    assert_eq(Str, s0, "zzz")
    assert_eq(Str, s1, "world")
}

// Out-of-bounds set throws OutOfBounds. The bang form (`a[i] = x`)
// panics; the explicit `a.set(i, own x)?` form lets a catch handle it.
// Str element so the owned value's throw-path cleanup runs under ASAN.
test_array_subscript_assign_oob := test() {
    a := Array(Str).new(2)
    mut caught := false
    mut emsg := ""
    a.set(5, own "unstored")?
    catch (err: OutOfBounds) {
        caught = true
        emsg = err.msg
    }
    assert(caught)
    assert(emsg.contains("Array.set"))
}

test_array_strings := test() {
    a := Array(Str).new(2)
    a.set(0, own "hello")!
    a.set(1, own "world")!

    ref s0 : Str = a.get(0)!
    ref s1 : Str = a.get(1)!

    assert_eq(Str, s0, "hello")
    assert_eq(Str, s1, "world")
}

test_array_overwrite := test() {
    a := Array(I64).new(2)
    a.set(0, own 1)!
    a.set(1, own 2)!
    a.set(0, own 99)!

    ref v : I64 = a.get(0)!
    assert_eq(I64, v, 99)
}

// --- merged from test/array_lit.til ---

test_i64_array_literal := test() {
    arr := array(I64, 1, 2, 3)
    assert_eq(USize, arr.len(), 3)
    assert_eq(I64, arr[0], 1)
    assert_eq(I64, arr[1], 2)
    assert_eq(I64, arr[2], 3)
}

test_i64_vec_literal := test() {
    myvec := vec(I64, 10, 20, 30)
    assert_eq(USize, myvec.len(), 3)
    assert_eq(I64, myvec[0], 10)
    assert_eq(I64, myvec[1], 20)
    assert_eq(I64, myvec[2], 30)
}

test_str_array_literal := test() {
    sarr := array(Str, "hello", "world")
    assert_eq(USize, sarr.len(), 2)
    ref s0 : Str = sarr[0]
    ref s1 : Str = sarr[1]
    assert_eq(Str, s0, "hello")
    assert_eq(Str, s1, "world")
}

test_str_vec_literal := test() {
    svec := vec(Str, "foo", "bar", "baz")
    assert_eq(USize, svec.len(), 3)
    assert_eq(Str, svec[0], "foo")
    assert_eq(Str, svec[1], "bar")
    assert_eq(Str, svec[2], "baz")
}
