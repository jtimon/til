mode test

test_array_new_get_set := test() {
    a := Array(I64).new(3)
    a.set(0, own 10)
    a.set(1, own 20)
    a.set(2, own 30)

    ref x : I64 = a.get(0)!
    ref y : I64 = a.get(1)!
    ref z : I64 = a.get(2)!

    assert_eq(__LOC__, I64, x, 10)
    assert_eq(__LOC__, I64, y, 20)
    assert_eq(__LOC__, I64, z, 30)
    assert_eq(__LOC__, I64, a.len().to_i64(), 3)
}

// a[i] desugars to a.get(i)! in the parser (generic over any type
// whose get throws), so subscript and explicit get(i)! agree.
test_array_subscript := test() {
    a := Array(I64).new(3)
    a.set(0, own 10)
    a.set(1, own 20)
    a.set(2, own 30)

    ref x : I64 = a[0]
    ref y : I64 = a[1]
    ref z : I64 = a[2]

    assert_eq(__LOC__, I64, x, 10)
    assert_eq(__LOC__, I64, y, 20)
    assert_eq(__LOC__, I64, z, 30)

    // Subscript with a computed index expression.
    mut i : USize = 1
    ref w : I64 = a[i.add(1)]
    assert_eq(__LOC__, I64, w, 30)
}

test_array_strings := test() {
    a := Array(Str).new(2)
    a.set(0, own "hello")
    a.set(1, own "world")

    ref s0 : Str = a.get(0)!
    ref s1 : Str = a.get(1)!

    assert_eq(__LOC__, Str, s0, "hello")
    assert_eq(__LOC__, Str, s1, "world")
}

test_array_overwrite := test() {
    a := Array(I64).new(2)
    a.set(0, own 1)
    a.set(1, own 2)
    a.set(0, own 99)

    ref v : I64 = a.get(0)!
    assert_eq(__LOC__, I64, v, 99)
}

// --- merged from test/array_lit.til ---

test_i64_array_literal := test() {
    arr := array("I64", 1, 2, 3)
    assert_eq(__LOC__, I64, arr.len().to_i64(), 3)
    ref a0 : I64 = arr[0]
    ref a1 : I64 = arr[1]
    ref a2 : I64 = arr[2]
    assert_eq(__LOC__, I64, a0, 1)
    assert_eq(__LOC__, I64, a1, 2)
    assert_eq(__LOC__, I64, a2, 3)
}

test_i64_vec_literal := test() {
    myvec := vec("I64", 10, 20, 30)
    assert_eq(__LOC__, I64, myvec.len().to_i64(), 3)
    ref v0 : I64 = myvec[0]
    ref v1 : I64 = myvec[1]
    ref v2 : I64 = myvec[2]
    assert_eq(__LOC__, I64, v0, 10)
    assert_eq(__LOC__, I64, v1, 20)
    assert_eq(__LOC__, I64, v2, 30)
}

test_str_array_literal := test() {
    sarr := array("Str", "hello", "world")
    assert_eq(__LOC__, I64, sarr.len().to_i64(), 2)
    ref s0 : Str = sarr[0]
    ref s1 : Str = sarr[1]
    assert_eq(__LOC__, Str, s0, "hello")
    assert_eq(__LOC__, Str, s1, "world")
}

test_str_vec_literal := test() {
    svec := vec("Str", "foo", "bar", "baz")
    assert_eq(__LOC__, I64, svec.len().to_i64(), 3)
    ref sv0 : Str = svec[0]
    ref sv1 : Str = svec[1]
    ref sv2 : Str = svec[2]
    assert_eq(__LOC__, Str, sv0, "foo")
    assert_eq(__LOC__, Str, sv1, "bar")
    assert_eq(__LOC__, Str, sv2, "baz")
}
