mode test

Point := struct {
    x := 0
    y := 0
}

Line := struct {
    own start := Point(x=0, y=0)
    own end := Point(x=0, y=0)
}

# Test 1: own field access with constructor args
test_own_field_access := test() {
    line := Line(start=Point(x=1, y=2), end=Point(x=3, y=4))
    assert_eq(I64, line.start.x, 1)
    assert_eq(I64, line.start.y, 2)
    assert_eq(I64, line.end.x, 3)
    assert_eq(I64, line.end.y, 4)
}

# Test 2: default constructor
test_own_field_defaults := test() {
    line := Line()
    assert_eq(I64, line.start.x, 0)
    assert_eq(I64, line.start.y, 0)
    assert_eq(I64, line.end.x, 0)
    assert_eq(I64, line.end.y, 0)
}

# Test 3: clone struct with own fields
test_own_field_clone := test() {
    line := Line(start=Point(x=1, y=2), end=Point(x=3, y=4))
    line2 := line.clone()
    assert_eq(I64, line2.start.x, 1)
    assert_eq(I64, line2.end.y, 4)
}

# Test 4: field assignment through own field
test_own_field_nested_assign := test() {
    line := Line(start=Point(x=1, y=2), end=Point(x=3, y=4))
    line.start.x = 10
    assert_eq(I64, line.start.x, 10)
    assert_eq(I64, line.start.y, 2)
}

# Test 5: own field replacement
test_own_field_replace := test() {
    line := Line(start=Point(x=1, y=2), end=Point(x=3, y=4))
    line.start = Point(x=100, y=200)
    assert_eq(I64, line.start.x, 100)
    assert_eq(I64, line.start.y, 200)
}

# Test 6: clone independence
test_own_field_clone_independence := test() {
    line := Line(start=Point(x=1, y=2), end=Point(x=3, y=4))
    line2 := line.clone()
    line.start.x = 99
    assert_eq(I64, line2.start.x, 1)
    assert_eq(I64, line.start.x, 99)
}

# #196.A: own-mut enum field round-trip in interpret mode
EnumF := enum {
    A,
    B: I64,
}

OwnEnumW := struct {
    own e := EnumF.A
}

test_own_field_enum_default := test() {
    w := OwnEnumW()
    assert(w.e.is(EnumF.A))
}

test_own_field_enum_assign := test() {
    mut w := OwnEnumW()
    w.e = EnumF.B(42)
    assert(w.e.is(EnumF.B))
}
