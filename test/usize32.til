mode script

// Issue #309 regression. Driven by the Makefile check_usize32 target with
// --usize=32, which forces the USize container-width alias to U32 even on a
// 64-bit host (UPtr and data pointers stay 8 bytes). Two things are checked:
//
//  1. USize is really U32. Its arithmetic wraps at 2^32: 0xFFFFFFFF + 1 == 0,
//     where a U64 USize would give 4294967296. This is the direct,
//     host-independent proof that the flag took effect, both interpreted and
//     compiled. (NOTE: Str.size()/dyn_size_of still report the compile-time
//     HOST layout width, because ctx.struct_layouts is host-width for the
//     constfold interpreter -- see compute_struct_layout / issue #192. That is
//     existing cross-compile behaviour, not specific to this flag; the runtime
//     structs really are the narrow width via -DTIL_USIZE32.)
//
//  2. Real container/string work round-trips at the narrow width, catching the
//     width-mismatch heap corruption that #192 / d44f77c fixed.
//
// Deliberately NOT registered in src/tests.til: check (1) fails at the default
// U64 width, so this file only makes sense under --usize=32.

check := proc(label: Str, got: USize, want: USize) {
    if got.neq(want) {
        println(format("FAIL: ", label, " = ", got.to_str(), ", want ", want.to_str()))
        exit(1)
    }
}

// USize is U32: 0xFFFFFFFF + 1 wraps to 0 (a U64 USize would be 4294967296).
mut wrapped : USize = 4294967295
wrapped = wrapped + 1
check("USize wrap (U32)", wrapped, 0)

// Real work at the narrow width: strings and a vec must round-trip, exercising
// the ctx-driven layout (count/cap read at 4 bytes, not 8).
mut v := Vec(Str).new()
v.push(own "alpha")
v.push(own "beta")
v.push(own "gamma")
check("vec len", v.len(), 3)
ref first : Str = v.unsafe_get(0)
if first.eq("alpha").not() { println("FAIL: v[0]"); exit(1) }
ref third : Str = v.unsafe_get(2)
if third.eq("gamma").not() { println("FAIL: v[2]"); exit(1) }

s := format("til", "-", "usize", "32")
check("str len", s.len(), 11)
if s.eq("til-usize32").not() { println(format("FAIL: str = ", s)); exit(1) }

println("usize32 OK")
