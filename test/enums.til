mode test

# basic enum
Color := enum { Red, Green, Blue }

test_basic_enum := test() {
    c := Color.Red
    expect(c.eq(Color.Red), "Red eq Red")
    expect(c.eq(Color.Green).not(), "Red neq Green")
}

test_to_str := test() {
    assert_eq(Str, Color.Red.to_str(), "Red")
    assert_eq(Str, Color.Blue.to_str(), "Blue")
}

test_clone := test() {
    c2 := Color.Green
    assert_eq(Str, c2.to_str(), "Green")
}

# enum in func params
is_red := func(c: Color) returns Bool {
    return c.eq(Color.Red)
}

test_func_params := test() {
    expect(is_red(Color.Red), "func: is_red(Red)")
    expect(is_red(Color.Blue).not(), "func: is_red(Blue)")
}

# enum with namespace section
Direction := enum {
    Up, Down, Left, Right
    namespace:
    is_vertical := func(self: Direction) returns Bool {
        if self.eq(Direction.Up) { return true }
        if self.eq(Direction.Down) { return true }
        return false
    }
}

test_namespace := test() {
    expect(Direction.Up.is_vertical(), "Up is vertical")
    expect(Direction.Left.is_vertical().not(), "Left not vertical")
}

# --- type aliases ---

Color2 := Color

test_enum_type_alias := test() {
    c := Color2.Red
    expect(c.eq(Color.Red), "alias Red eq original Red")
    expect(c.eq(Color2.Green).not(), "alias Red neq alias Green")
    assert_eq(Str, Color2.Blue.to_str(), "Blue")
}

Direction2 := Direction

test_enum_alias_namespace := test() {
    expect(Direction2.Up.is_vertical(), "alias Up is vertical")
    expect(Direction2.Left.is_vertical().not(), "alias Left not vertical")
}

# --- payload enums ---

Token := enum { Num: I64, Name: Str, Eof }

test_payload_construction := test() {
    t := Token.Num(42)
    t2 := Token.Eof
    t3 := Token.Name("hello")

    expect(t.is(Token.Num), "Num is_Num")
    expect(t.is(Token.Eof).not(), "Num not is_Eof")
    expect(t2.is(Token.Eof), "Eof is_Eof")
    expect(t3.is(Token.Name), "Name is_Name")
}

test_payload_to_str := test() {
    assert_eq(Str, Token.Num(42).to_str(), "Num(42)")
    assert_eq(Str, Token.Eof.to_str(), "Eof")
    assert_eq(Str, Token.Name("hello").to_str(), "Name(hello)")
}

test_payload_eq := test() {
    t := Token.Num(42)
    expect(t.eq(Token.Num(42)), "Num(42) eq Num(42)")
    expect(t.eq(Token.Num(99)).not(), "Num(42) neq Num(99)")
    expect(t.eq(Token.Eof).not(), "Num neq Eof")
    expect(Token.Eof.eq(Token.Eof), "Eof eq Eof")
}

test_payload_clone := test() {
    t4 := Token.Num(7)
    switch t4 {
    case Token.Num(_tn4):
        assert_eq(I64, _tn4, 7)
    case:
        UNREACHABLE()
    }
}

# --- enum as struct field ---

# Simple enum field
Painted := struct {
    const color := Color.Red
    label := ""
}

test_simple_enum_field := test() {
    p := Painted(color = Color.Blue, label = "sky")
    expect(p.color.eq(Color.Blue), "simple enum field read")
    assert_eq(Str, p.label, "sky")
}

test_simple_enum_field_default := test() {
    p := Painted()
    expect(p.color.eq(Color.Red), "simple enum field default")
}

get_tag_name := func(tok: Token) returns Str {
    if tok.is(Token.Num) { return "num" }
    if tok.is(Token.Name) { return "name" }
    return "eof"
}

test_payload_func_params := test() {
    assert_eq(Str, get_tag_name(Token.Num(1)), "num")
    assert_eq(Str, get_tag_name(Token.Eof), "eof")
}

# --- struct payload in tagged enum ---

Point := struct {
    x := 0
    y := 0
    namespace:
    eq := func(a: Point, b: Point) returns Bool { return a.x.eq(b.x).and(a.y.eq(b.y)) }
    to_str := func(self: Point) returns Str { return format(self.x.to_str(), ",", self.y.to_str()) }
}

Shape := enum { Dot: Point, Line: Str, Empty }

test_struct_payload := test() {
    s := Shape.Dot(Point(x = 3, y = 4))
    switch s {
    case Shape.Dot(p):
        assert_eq(I64, p.x, 3)
        assert_eq(I64, p.y, 4)
    case:
        UNREACHABLE()
    }
}

test_struct_payload_eq := test() {
    s1 := Shape.Dot(Point(x = 1, y = 2))
    s2 := Shape.Dot(Point(x = 1, y = 2))
    s3 := Shape.Dot(Point(x = 9, y = 9))
    expect(s1.eq(s2), "same Dot eq")
    expect(s1.eq(s3).not(), "diff Dot neq")
    expect(s1.eq(Shape.Empty).not(), "Dot neq Empty")
}

test_struct_payload_clone := test() {
    s := Shape.Dot(Point(x = 5, y = 6))
    s2 := s.clone()
    switch s2 {
    case Shape.Dot(p):
        assert_eq(I64, p.x, 5)
        assert_eq(I64, p.y, 6)
    case:
        UNREACHABLE()
    }
}

test_struct_payload_to_str := test() {
    assert_eq(Str, Shape.Empty.to_str(), "Empty")
    assert_eq(Str, Shape.Line("hi").to_str(), "Line(hi)")
}

// payload enum as struct field (#53)

Data := struct {
    x := 0
    y := 0
    namespace:
    eq := func(a: Data, b: Data) returns Bool { return a.x.eq(b.x).and(a.y.eq(b.y)) }
    to_str := func(self: Data) returns Str { return format(self.x.to_str(), ",", self.y.to_str()) }
}
Kind := enum { A: Data, B: I64, C }
Container := struct { name := ""; kind := Kind.C }

test_payload_enum_field := test() {
    c := Container(name = "test", kind = Kind.A(Data(x = 3, y = 4)))
    assert_eq(Str, c.kind.to_str(), "A(3,4)")
    switch c.kind {
    case Kind.A(d):
        assert_eq(I64, d.x, 3)
        assert_eq(I64, d.y, 4)
        assert_eq(Str, d.to_str(), "3,4")
    case:
        UNREACHABLE()
    }
}

test_payload_enum_field_b := test() {
    c := Container(name = "test", kind = Kind.B(42))
    switch c.kind {
    case Kind.B(_kb):
        assert_eq(I64, _kb, 42)
    case:
        UNREACHABLE()
    }
}

test_payload_enum_field_default := test() {
    c := Container()
    expect(c.kind.is(Kind.C), "default kind.is_C()")
}

test_payload_enum_field_mut := test() {
    mut c := Container(name = "test", kind = Kind.C)
    expect(c.kind.is(Kind.C), "initially C")
    c.kind = Kind.A(Data(x = 7, y = 8))
    switch c.kind {
    case Kind.A(d):
        assert_eq(I64, d.x, 7)
        assert_eq(I64, d.y, 8)
    case:
        UNREACHABLE()
    }
}

# --- switch on enums ---

test_switch_enum := test() {
    mut result := ""
    switch Color.Green {
    case Color.Red: result = "red"
    case Color.Green: result = "green"
    case Color.Blue: result = "blue"
    }
    assert_eq(Str, result, "green")
}

test_switch_payload := test() {
    mut result := 0
    switch Token.Num(42) {
    case Token.Num(value): result = value
    case Token.Name(_s): result = -1
    case Token.Eof: result = -2
    }
    assert_eq(I64, result, 42)
}

test_switch_payload_multi := test() {
    mut num_val := 0
    mut str_val := ""
    mut is_eof := false

    switch Token.Name("hello") {
    case Token.Num(n):
        num_val = n
    case Token.Name(s):
        str_val = s
    case Token.Eof:
        is_eof = true
    }
    assert_eq(I64, num_val, 0)
    assert_eq(Str, str_val, "hello")
    assert(is_eof.not())
}

test_switch_payload_with_default := test() {
    mut result := ""
    switch Token.Eof {
    case Token.Num(_n): result = "num"
    case Token.Name(_s): result = "name"
    case: result = "other"
    }
    assert_eq(Str, result, "other")
}

# --- switch on enum without payload extraction ---

test_switch_payload_tag_only := test() {
    // switch on payload enum matching variant without extracting payload
    mut result := ""
    switch Token.Num(42) {
    case Token.Num: result = "num"
    case Token.Name: result = "name"
    case Token.Eof: result = "eof"
    }
    assert_eq(Str, result, "num")
}

# --- enum variant as function argument ---

check_variant := func(t: Token, expected_tag: Str) returns Bool {
    return t.to_str().starts_with(expected_tag)
}

test_variant_func_arg := test() {
    expect(check_variant(Token.Num(1), "Num"), "Num starts with Num")
    expect(check_variant(Token.Eof, "Eof"), "Eof starts with Eof")
}

# --- is (generic tag comparison) ---

test_is_simple := test() {
    c := Color.Green
    expect(c.is(Color.Green), "Green is Green")
    expect(c.is(Color.Red).not(), "Green not Red")
}

test_is_payload := test() {
    t := Token.Num(42)
    expect(t.is(Token.Num), "Num is Num")
    expect(t.is(Token.Eof).not(), "Num not Eof")
    expect(t.is(Token.Name).not(), "Num not Name")
}

test_is_bare_payload := test() {
    s := Shape.Dot(Point(x = 3, y = 4))
    expect(s.is(Shape.Dot), "Dot is Shape.Dot")
    expect(s.is(Shape.Empty).not(), "Dot not Shape.Empty")
    expect(s.is(Shape.Line).not(), "Dot not Shape.Line")
    // Also test with Token enum bare payload variants
    t := Token.Num(42)
    expect(t.is(Token.Num), "Num is Token.Num")
    expect(t.is(Token.Name).not(), "Num not Token.Name")
    expect(t.is(Token.Eof).not(), "Num not Token.Eof")
}

test_is_payload_eof := test() {
    t := Token.Eof
    expect(t.is(Token.Eof), "Eof is Eof")
    expect(t.is(Token.Num).not(), "Eof not Num")
}

# --- exhaustive switch (#113): default catches everything the other cases don't ---

test_switch_default_only := test() {
    mut result := ""
    switch Color.Blue {
    case: result = "other"
    }
    assert_eq(Str, result, "other")
}

test_switch_default_covers_missing := test() {
    # only Red is explicit; default absorbs Green and Blue
    mut result := ""
    switch Color.Green {
    case Color.Red: result = "red"
    case: result = "other"
    }
    assert_eq(Str, result, "other")
}

# --- nested pattern matching (#36) ---

InnerE := enum { ValueA: I64, ValueB: Str, ValueC }
OuterE := enum { WrapperA: InnerE, WrapperB: I64 }

test_nested_payload_a := test() {
    outer := OuterE.WrapperA(InnerE.ValueA(42))
    mut result := 0
    switch outer {
    case OuterE.WrapperA(InnerE.ValueA(val)): result = val
    case OuterE.WrapperA(InnerE.ValueB(_s)): result = -1
    case OuterE.WrapperA(InnerE.ValueC):     result = -2
    case OuterE.WrapperB(i):                 result = i
    }
    assert_eq(I64, result, 42)
}

test_nested_payload_b := test() {
    outer := OuterE.WrapperA(InnerE.ValueB("hello"))
    mut result := ""
    switch outer {
    case OuterE.WrapperA(InnerE.ValueA(_n)): result = "got-a"
    case OuterE.WrapperA(InnerE.ValueB(s)):  result = s
    case OuterE.WrapperA(InnerE.ValueC):     result = "got-c"
    case OuterE.WrapperB(_i):                result = "outer-b"
    }
    assert_eq(Str, result, "hello")
}

test_nested_bare_inner := test() {
    outer := OuterE.WrapperA(InnerE.ValueC)
    mut hit := false
    switch outer {
    case OuterE.WrapperA(InnerE.ValueA(_n)): hit = false
    case OuterE.WrapperA(InnerE.ValueB(_s)): hit = false
    case OuterE.WrapperA(InnerE.ValueC):     hit = true
    case OuterE.WrapperB(_i):                hit = false
    }
    assert(hit)
}

test_nested_outer_b := test() {
    outer := OuterE.WrapperB(99)
    mut result := 0
    switch outer {
    case OuterE.WrapperA(InnerE.ValueA(_n)): result = 1
    case OuterE.WrapperA(InnerE.ValueB(_s)): result = 2
    case OuterE.WrapperA(InnerE.ValueC):     result = 3
    case OuterE.WrapperB(i):                 result = i
    }
    assert_eq(I64, result, 99)
}

# Three levels of nesting.

InnerInnerE := enum { X: I64, Y }
MidE := enum { M: InnerInnerE, N: I64 }
DeepE := enum { O: MidE, P }

test_nested_triple := test() {
    v := DeepE.O(MidE.M(InnerInnerE.X(7)))
    mut result := 0
    switch v {
    case DeepE.O(MidE.M(InnerInnerE.X(n))): result = n
    case DeepE.O(MidE.M(InnerInnerE.Y)):    result = -1
    case DeepE.O(MidE.N(i)):                result = i
    case DeepE.P:                           result = -99
    }
    assert_eq(I64, result, 7)
}

test_nested_triple_fallthrough := test() {
    v := DeepE.O(MidE.N(42))
    mut result := 0
    switch v {
    case DeepE.O(MidE.M(InnerInnerE.X(n))): result = n
    case DeepE.O(MidE.M(InnerInnerE.Y)):    result = -1
    case DeepE.O(MidE.N(i)):                result = i
    case DeepE.P:                           result = -99
    }
    assert_eq(I64, result, 42)
}

# --- struct field matching in switch cases (#36) ---

PointPat := struct {
    x := 0
    y := 0
    namespace:
    eq := func(a: PointPat, b: PointPat) returns Bool { return a.x.eq(b.x).and(a.y.eq(b.y)) }
    to_str := func(self: PointPat) returns Str { return format(self.x.to_str(), ",", self.y.to_str()) }
}

test_struct_field_literal := test() {
    p := PointPat(x = 0, y = 5)
    mut r := ""
    switch p {
    case PointPat(x = 0, y = 0): r = "origin"
    case PointPat(x = 0, y = ny): r = format("y-", ny.to_str())
    case PointPat(x = nx, y = 0): r = format("x-", nx.to_str())
    case PointPat(x = _nx, y = _ny): r = "other"
    }
    assert_eq(Str, r, "y-5")
}

test_struct_field_origin := test() {
    p := PointPat(x = 0, y = 0)
    mut r := ""
    switch p {
    case PointPat(x = 0, y = 0): r = "origin"
    case PointPat(x = _nx, y = _ny): r = "other"
    }
    assert_eq(Str, r, "origin")
}

test_struct_field_bind_only := test() {
    p := PointPat(x = 7, y = 9)
    mut sum := 0
    switch p {
    case PointPat(x = nx, y = ny): sum = nx.add(ny)
    }
    assert_eq(I64, sum, 16)
}

ShapePat := enum { Dot: PointPat, Line: I64 }

test_enum_payload_then_struct_pattern := test() {
    s := ShapePat.Dot(PointPat(x = 0, y = 7))
    mut hit := ""
    switch s {
    case ShapePat.Dot(p):
        switch p {
        case PointPat(x = 0, y = ny): hit = format("y-axis-", ny.to_str())
        case PointPat(x = _nx, y = _ny): hit = "other"
        }
    case ShapePat.Line(_l): hit = "line"
    }
    assert_eq(Str, hit, "y-axis-7")
}

# Struct pattern *directly* inside an enum variant payload.
test_enum_with_struct_pattern := test() {
    s := ShapePat.Dot(PointPat(x = 0, y = 7))
    mut hit := ""
    switch s {
    case ShapePat.Dot(PointPat(x = 0, y = ny)): hit = format("y-axis-", ny.to_str())
    case ShapePat.Dot(p): hit = format("dot-", p.x.to_str(), ",", p.y.to_str())
    case ShapePat.Line(_l): hit = "line"
    }
    assert_eq(Str, hit, "y-axis-7")
}

test_enum_with_struct_pattern_fallthrough := test() {
    s := ShapePat.Dot(PointPat(x = 3, y = 4))
    mut hit := ""
    switch s {
    case ShapePat.Dot(PointPat(x = 0, y = _ny)): hit = "y-axis"
    case ShapePat.Dot(p): hit = format("dot-", p.x.to_str(), ",", p.y.to_str())
    case ShapePat.Line(_l): hit = "line"
    }
    assert_eq(Str, hit, "dot-3,4")
}

# --- `..` rest-pattern (partial struct match) ---

test_rest_partial := test() {
    p := PointPat(x = 0, y = 99)
    mut hit := false
    switch p {
    case PointPat(x = 0, ..): hit = true
    case PointPat(x = _nx, y = _ny): hit = false
    }
    assert(hit)
}

test_rest_only := test() {
    p := PointPat(x = 5, y = 6)
    mut hit := false
    switch p {
    case PointPat(..): hit = true
    }
    assert(hit)
}

# --- guard clauses (#199) ---

ColorG := enum { Unknown, Number: I64, Name: Str }

test_guard_positive := test() {
    c := ColorG.Number(42)
    mut r := ""
    switch c {
    case ColorG.Unknown: r = "unknown"
    case ColorG.Number(code) if code.gt(0): r = "positive"
    case ColorG.Number(code): r = format("non-pos-", code.to_str())
    case ColorG.Name(name): r = format("named-", name)
    }
    assert_eq(Str, r, "positive")
}

test_guard_falls_through := test() {
    c := ColorG.Number(-5)
    mut r := ""
    switch c {
    case ColorG.Unknown: r = "unknown"
    case ColorG.Number(code) if code.gt(0): r = "positive"
    case ColorG.Number(code): r = format("non-pos-", code.to_str())
    case ColorG.Name(_name): r = "named"
    }
    assert_eq(Str, r, "non-pos--5")
}

test_guard_uses_binding := test() {
    c := ColorG.Number(7)
    mut hit := 0
    switch c {
    case ColorG.Number(v) if v.eq(7): hit = v
    case ColorG.Number(_v): hit = -1
    case ColorG.Unknown: hit = -2
    case ColorG.Name(_n): hit = -3
    }
    assert_eq(I64, hit, 7)
}

test_guard_bare_variant := test() {
    flag := true
    c := ColorG.Unknown
    mut r := ""
    switch c {
    case ColorG.Unknown if flag: r = "yes"
    case ColorG.Unknown: r = "no"
    case ColorG.Number(_n): r = "num"
    case ColorG.Name(_n): r = "name"
    }
    assert_eq(Str, r, "yes")
}

test_guard_bare_variant_false := test() {
    flag := false
    c := ColorG.Unknown
    mut r := ""
    switch c {
    case ColorG.Unknown if flag: r = "yes"
    case ColorG.Unknown: r = "no"
    case ColorG.Number(_n): r = "num"
    case ColorG.Name(_n): r = "name"
    }
    assert_eq(Str, r, "no")
}

# --- #282: a throwing (bang/subscript) call in a guard runs ONLY on a
#     pattern hit. With an eager pre-switch hoist the empty-Vec subscript
#     below would OOB-panic even though the pattern never matches. ---
test_guard_throwing_call_short_circuits := test() {
    v := Vec(I64).new()       # empty
    mut r := 0
    switch v.len() {          # 0
    case 1 if v[0].gt(0): r = 1   # pattern 1 != 0; guard v[0] must NOT run
    case: r = 2
    }
    assert_eq(I64, r, 2)
}

test_guard_throwing_call_runs_on_hit := test() {
    mut v := Vec(I64).new()
    v.push(own 5)             # len 1, v[0] == 5
    mut r := 0
    switch v.len() {          # 1
    case 1 if v[0].gt(0): r = 1   # pattern hits, guard true -> r = 1
    case: r = 2
    }
    assert_eq(I64, r, 1)
}

test_guard_throwing_call_false_guard_falls_through := test() {
    mut v := Vec(I64).new()
    v.push(own -5)            # len 1, v[0] == -5 (not > 0)
    mut r := 0
    switch v.len() {          # 1
    case 1 if v[0].gt(0): r = 1   # pattern hits, guard false -> default runs
    case: r = 2
    }
    assert_eq(I64, r, 2)
}

# --- #282: a `?` throwing call in a guard short-circuits like the bang form
#     (runs only on a pattern hit), but its error is handled by the function's
#     `catch` / `throws` clause instead of panicking. ---
test_guard_question_short_circuits := test() {
    n := 0
    mut r := 0
    switch n {                              # 0; pattern 1 misses
    case 1 if 10.safe_div(0)?.gt(0): r = 1  # safe_div(0) would throw -- must NOT run
    case: r = 2
    }
    catch (e: DivideByZero) { r = 99 }
    assert_eq(I64, r, 2)
}

test_guard_question_throw_is_caught := test() {
    n := 1
    mut r := 0
    switch n {                              # 1; pattern hits, guard runs and throws
    case 1 if 10.safe_div(0)?.gt(0): r = 1
    case: r = 2
    }
    catch (e: DivideByZero) { r = 99 }      # the guard's throw lands here
    assert_eq(I64, r, 99)
}

# A guarded switch desugars to independent `if`s (not if/elif), built after the
# pre-infer throw pass. When an earlier case's `?` guard throws, the LATER cases
# must be skipped (gated on _err_kind == 0) -- otherwise their bodies would run
# on the error path before the catch. `sink` records whether a later case ran.
test_guard_question_throw_skips_later_cases := test() {
    n := 1
    mut sink := 0
    mut r := 0
    switch n {
    case 1 if 10.safe_div(0)?.gt(0): r = 1   # hit; guard throws DivideByZero
    case 1: sink = 777                        # must NOT run after the throw
    case: sink = 888                          # must NOT run after the throw
    }
    catch (e: DivideByZero) { r = 99 }
    assert_eq(I64, r, 99)
    assert_eq(I64, sink, 0)
}

# An uncaught `?` guard propagates to the caller's throws clause.
guard_classify := func(n: I64) returns I64 throws DivideByZero {
    mut r := 0
    switch n {
    case 1 if 10.safe_div(0)?.gt(0): r = 1   # throws; no local catch -> propagates
    case: r = 2
    }
    return r
}

test_guard_question_propagates := test() {
    mut got := 0
    got = guard_classify(1)?                  # n==1 hits the guard, which throws
    catch (e: DivideByZero) { got = 99 }
    assert_eq(I64, got, 99)
    # n==2 misses the guarded case entirely -> no throw, default arm
    got = guard_classify(2)?
    catch (e: DivideByZero) { got = -1 }
    assert_eq(I64, got, 2)
}

# --- #282: the throwing call's receiver may be a case PAYLOAD BINDING (`b`),
#     synthesized by the switch desugar. It still resolves to the right owning
#     type (GuardBox.checked) so the bang short-circuits / runs correctly. ---
GuardBox := struct {
    val: I64 = 0
namespace:
    checked := func(self: GuardBox, d: I64) returns I64 throws DivideByZero {
        return self.val.safe_div(d)?
    }
}

GuardWrap := enum { Empty, B: GuardBox }

test_guard_payload_binding_receiver := test() {
    miss := GuardWrap.Empty
    mut r := 0
    switch miss {
    case GuardWrap.B(b) if b.checked(0)!.gt(0): r = 1   # variant misses; b.checked must NOT run
    case: r = 2
    }
    assert_eq(I64, r, 2)

    hit := GuardWrap.B(GuardBox(val = 9))
    switch hit {
    case GuardWrap.B(b) if b.checked(3)!.gt(0): r = 3   # variant hits, 9/3 == 3 > 0
    case: r = 4
    }
    assert_eq(I64, r, 3)
}

# --- #282 + #262: a lazy `&&`/`||`/`.and()`/`.or()` in a guard expands (pre-
#     typer) to a `match`, so a throwing call on either side lands inside a
#     match *in the guard*. That match must be lowered into the pattern-gated
#     position, never hoisted out before the switch -- otherwise the guard (and
#     its throwing call) runs unconditionally. Both the scrutinee side and the
#     arm side of the lazy call must short-circuit on a pattern miss. ---
test_guard_lazy_and_arm_bang := test() {
    v := Vec(I64).new()                       # empty
    mut r := 0
    switch v.len() {                          # 0; pattern 9 misses
    case 9 if true.and(v[0].gt(0)): r = 1     # arm-side bang -- must NOT run
    case: r = 2
    }
    assert_eq(I64, r, 2)
}

test_guard_lazy_and_scrutinee_bang := test() {
    v := Vec(I64).new()                       # empty
    mut r := 0
    switch v.len() {                          # 0; pattern 9 misses
    case 9 if v[0].gt(0).and(true): r = 1     # scrutinee-side bang -- must NOT run
    case: r = 2
    }
    assert_eq(I64, r, 2)
}

test_guard_lazy_and_on_hit := test() {
    mut v := Vec(I64).new()
    v.push(own 7)                             # len 1
    mut r := 0
    switch v.len() {                          # 1; pattern hits, both operands true
    case 1 if (v.len().gt(0) && v[0].gt(0)): r = 1
    case: r = 2
    }
    assert_eq(I64, r, 1)
}

// #211: payload bindings inherit the matched value's mutability. A mut
// enum exposes a ref-mut payload binding in case patterns, so `n = 99`
// type-checks AND propagates into the enum's payload memory -- the
// second switch sees the new value. Verified in both compiled and
// interpreted modes (the interpreter mirrors the write through a
// payload-alias entry in the scope; see #211 interp follow-up).
test_mut_payload_binding := test() {
    mut c := ColorG.Number(7)
    switch c {
    case ColorG.Number(n): n = 99
    case:
    }
    switch c {
    case ColorG.Number(n2): assert_eq(I64, n2, 99)
    case: assert_eq(Str, "wrong variant", "")
    }
}

// #221: Str payloads propagate in both backends too. The compile path
// previously rebound the local Str pointer instead of writing through
// (`p = malloc(new)` vs `*p = new`); the interp path now also frees the
// old c_str before overwriting so owned sources don't leak.
test_mut_str_payload_binding := test() {
    mut c := ColorG.Name("hello")
    switch c {
    case ColorG.Name(p): p = "world"
    case:
    }
    switch c {
    case ColorG.Name(n2): assert_eq(Str, n2, "world")
    case: assert_eq(Str, "wrong variant", "")
    }
}

// #211 follow-up: struct payloads also propagate now that the typer
// accepts a constructor RHS on a payload-alias ref-mut target and the
// builder lowers it to `*p = *new` (paired with the existing
// is_payload_alias compound-payload write in builder.til).
test_mut_struct_payload_binding := test() {
    mut s := Shape.Dot(Point(x = 1, y = 2))
    switch s {
    case Shape.Dot(p): p = Point(x = 99, y = 42)
    case:
    }
    switch s {
    case Shape.Dot(q):
        assert_eq(I64, q.x, 99)
        assert_eq(I64, q.y, 42)
    case: assert_eq(Str, "wrong variant", "")
    }
}

// #211 follow-up: nested-enum payloads (Variant: SomeOtherEnum) also
// propagate now. The interp writeback handles `Value.Enum` by deep-
// copying into a fresh heap EnumInstance and storing its pointer at the
// outer payload slot, mirroring write_field's Ref-typed enum shape.
// (Compile already worked via the existing is_payload_alias compound
// branch.)
NestedInner := enum { A: I64, B }
NestedOuter := enum { Wrap: NestedInner, Bare }

test_mut_nested_enum_payload_binding := test() {
    mut o := NestedOuter.Wrap(NestedInner.A(7))
    switch o {
    case NestedOuter.Wrap(p): p = NestedInner.A(99)
    case:
    }
    switch o {
    case NestedOuter.Wrap(q):
        switch q {
        case NestedInner.A(n): assert_eq(I64, n, 99)
        case: assert_eq(Str, "wrong inner variant", "")
        }
    case: assert_eq(Str, "wrong outer variant", "")
    }
}

// #128: auto-generated enum clone deep-clones managed payloads. A
// shallow copy would alias the payload buffer: writing through the
// original's ref-mut payload binding would leak into the clone, and
// the two scope-exit deletes would double-free (ASAN suite catches
// that). Mutate the ORIGINAL after cloning and check the clone kept
// the pre-mutation payload.
test_str_payload_clone_deep := test() {
    mut t := Token.Name("orig")
    t2 := t.clone()
    switch t {
    case Token.Name(p): p = "changed"
    case: assert_eq(Str, "wrong variant", "")
    }
    assert_eq(Str, t.to_str(), "Name(changed)")
    switch t2 {
    case Token.Name(n): assert_eq(Str, n, "orig")
    case: assert_eq(Str, "wrong variant", "")
    }
}

test_struct_payload_clone_deep := test() {
    mut s := Shape.Dot(Point(x = 1, y = 2))
    s2 := s.clone()
    switch s {
    case Shape.Dot(p): p = Point(x = 99, y = 42)
    case: assert_eq(Str, "wrong variant", "")
    }
    switch s2 {
    case Shape.Dot(q):
        assert_eq(I64, q.x, 1)
        assert_eq(I64, q.y, 2)
    case: assert_eq(Str, "wrong variant", "")
    }
}

// Nested managed payload: the outer clone must recurse through the
// inner enum's payload too, not just copy the inner enum pointer.
test_nested_enum_payload_clone_deep := test() {
    mut o := NestedOuter.Wrap(NestedInner.A(7))
    o2 := o.clone()
    switch o {
    case NestedOuter.Wrap(p): p = NestedInner.A(99)
    case: assert_eq(Str, "wrong variant", "")
    }
    switch o2 {
    case NestedOuter.Wrap(q):
        switch q {
        case NestedInner.A(n): assert_eq(I64, n, 7)
        case: assert_eq(Str, "wrong inner variant", "")
        }
    case: assert_eq(Str, "wrong outer variant", "")
    }
}

// #264: `enum(Type)` pins the discriminant (tag) width. The default
// (no parens) is U8 (1 byte) for compactness; U16/U32/U64 widen the
// in-memory tag to match a chosen C backing type for FFI/compactness.
TagDefault := enum { A, B, C }
TagU8  := enum(U8)  { A, B, C }
TagU16 := enum(U16) { A, B, C }
TagU32 := enum(U32) { A, B, C }
TagU64 := enum(U64) { A, B, C }

test_enum_tag_width_sizes := test() {
    assert_eq(I64, dyn_size_of("TagDefault").to_i64(), 1)
    assert_eq(I64, dyn_size_of("TagU8").to_i64(), 1)
    assert_eq(I64, dyn_size_of("TagU16").to_i64(), 2)
    assert_eq(I64, dyn_size_of("TagU32").to_i64(), 4)
    assert_eq(I64, dyn_size_of("TagU64").to_i64(), 8)
}

test_enum_tag_width_behaviour := test() {
    c := TagU8.B
    expect(c.eq(TagU8.B), "U8 tag: B eq B")
    expect(c.eq(TagU8.A).not(), "U8 tag: B neq A")
    assert_eq(Str, TagU8.C.to_str(), "C")
    assert_eq(Str, TagU64.A.to_str(), "A")
}

// A pinned tag with payload variants: only the tag width changes, the
// payload union layout is unaffected.
TagU8Payload := enum(U8) { None, Num: I64 }

test_enum_tag_width_payload := test() {
    v := TagU8Payload.Num(42)
    switch v {
    case TagU8Payload.Num(n): assert_eq(I64, n, 42)
    case: assert_eq(Str, "wrong variant", "")
    }
}

// #264 follow-up: explicit enum tag values (`enum { A = N }`), C-like
// auto-increment after an explicit value, and a no-payload U64 tag beyond
// U32.MAX -- the case that needs the full 64-bit tag end to end (compiled
// is_n(8) + interpreter Value.Int).
TagExplicit := enum(U8) { A = 10, B = 20, C }

test_enum_explicit_value := test() {
    expect(TagExplicit.A.eq(TagExplicit.A), "explicit: A eq A")
    expect(TagExplicit.A.eq(TagExplicit.B).not(), "explicit: A neq B")
    // C auto-increments from B (20) -> 21.
    expect(TagExplicit.C.eq(TagExplicit.C), "explicit: C eq C")
    expect(TagExplicit.C.eq(TagExplicit.A).not(), "explicit: C neq A")
    mut r := 0
    switch TagExplicit.B {
    case TagExplicit.A: r = 1
    case TagExplicit.B: r = 2
    case TagExplicit.C: r = 3
    }
    assert_eq(I64, r, 2)
}

TagU64Hi := enum(U64) { A = 0, B = 4294967296 }

test_enum_u64_high_value := test() {
    expect(TagU64Hi.B.eq(TagU64Hi.B), "u64hi: B eq B")
    // If the tag were truncated to 32 bits, B (2^32) would collide with A (0).
    expect(TagU64Hi.B.eq(TagU64Hi.A).not(), "u64hi: B neq A")
    mut r := 0
    switch TagU64Hi.B {
    case TagU64Hi.A: r = 1
    case TagU64Hi.B: r = 2
    }
    assert_eq(I64, r, 2)
}

// A payload variant with an explicit tag: guards the tag-vs-index split --
// Num's tag value is 7 but its payload_types entry is at index 1.
TagPayloadExplicit := enum(U8) { None = 5, Num: I64 = 7 }

test_enum_explicit_payload := test() {
    v := TagPayloadExplicit.Num(42)
    mut got := -1
    switch v {
    case TagPayloadExplicit.None: got = 0
    case TagPayloadExplicit.Num(n): got = n
    }
    assert_eq(I64, got, 42)
}
