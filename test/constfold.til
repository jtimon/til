mode test

// Compile-time constant folding for pure func / ext_func calls with
// comptime args. Adapted from rstil's src/test/constfold.til.

double_il := func(x: I64) returns I64 { return x.mul(2) }
add := func(a: I64, b: I64) returns I64 { return a.add(b) }
sub := func(a: I64, b: I64) returns I64 { return a.sub(b) }
mul := func(a: I64, b: I64) returns I64 { return a.mul(b) }
concat := func(a: Str, b: Str) returns Str { return a.concat(b) }

// Test 1: Simple arithmetic
test_simple_add := test() {
    result := add(1, 2)
    assert_eq(I64, result, 3)
}

// Test 2: Nested arithmetic
test_nested_arithmetic := test() {
    result := mul(add(1, 2), sub(10, 5))
    assert_eq(I64, result, 15)
}

// Test 3: Deeply nested
test_deeply_nested := test() {
    result := add(mul(2, 3), mul(4, 5))
    assert_eq(I64, result, 26)
}

// Test 4: String concat -- folded at compile time.
test_string_concat := test() {
    result := concat("hello", " world")
    assert_eq(Str, result, "hello world")
}

// Test 4b: variadic (`..Str`) folding through a wrapper (issue #277). A
// pure wrapper that forwards comptime args into `format(..Str)` folds to
// the baked literal: the const-folder evals through the variadic param and
// the typer's `for s in parts` lowering (a bounds-checked `Array.get` with
// a `panic` error branch). Before #277 the `..T` param turned folding off
// and the wrapper + a runtime `format(...)` ran instead. Inspect
// test/constfold.c: `vfmt`/`vfmt2` must be gone and `r`/`r2` baked as
// "hello world" / "a-b-c".
vfmt := func(a: Str, b: Str) returns Str { return format(a, b) }
vfmt2 := func(a: Str, b: Str, c: Str) returns Str { return format(a, "-", b, "-", c) }

test_variadic_fold := test() {
    r := vfmt("hello", " world")
    assert_eq(Str, r, "hello world")
    r2 := vfmt2("a", "b", "c")
    assert_eq(Str, r2, "a-b-c")
}

// Test 4c: DIRECT variadic folding (issue #277, route B). A direct
// `format(...)` / positional+variadic call with all-comptime args folds at
// the call site WITHOUT a wrapper. The typer lowers it (before const-fold)
// to a build region -- `_va_Array_N := Array.new(..)`, throwing `Array.set`
// per element, a consumer `format(_va_Array_N)`; the const-folder
// materialises that array by interpreting the build region, bakes the
// consumer to a literal, and DCEs the now-dead build. Inspect
// test/constfold.c: no `_va_Array_` build should remain for d/d2/d3, baked
// as "x-y-z" / "abc" / 106. dsum also exercises a positional arg (whose
// hoist must be bound into the fold scope before the consumer evals).
dsum := func(prefix: I64, nums: ..I64) returns I64 {
    mut total := prefix
    for n : I64 in nums { total = total.add(n) }
    return total
}

test_variadic_direct_fold := test() {
    d := format("x", "-", "y", "-", "z")
    assert_eq(Str, d, "x-y-z")
    d2 := format("a", "b", "c")
    assert_eq(Str, d2, "abc")
    d3 := dsum(100, 1, 2, 3)
    assert_eq(I64, d3, 106)
}

// Test 5: lolalalo -- recursive vs iterative. Generates the 4-syllable
// permutation poem at compile time. Inspired by rstil/src/examples/lolalalo.til.
// Top-level `poem` so the recursion doesn't need first-class nested funcs.
// Iterative version uses simple nested range loops.

poem := func(depth: I64, current: Str, s1: Str, s2: Str) returns Str {
    if depth.eq(4) {
        return current.concat("\n")
    }
    mut result := ""
    result = result.concat(poem(depth.add(1), current.concat(s1), s1, s2))
    result = result.concat(poem(depth.add(1), current.concat(s2), s1, s2))
    if depth.eq(2) {
        result = result.concat(poem(depth.add(1), current.concat("lei"), s1, s2))
    }
    return result
}

make_poem_rec := func(s1: Str, s2: Str) returns Str {
    return poem(0, "", s1, s2)
}

make_poem_it := func(s1: Str, s2: Str) returns Str {
    mut result := ""
    for i0 in 0..2 {
        for i1 in 0..2 {
            for i2 in 0..3 {
                for i3 in 0..2 {
                    mut s0 := s1
                    if i0.neq(0) { s0 = s2 }
                    mut s1v := s1
                    if i1.neq(0) { s1v = s2 }
                    mut s2v := s1
                    if i2.eq(1) { s2v = s2 }
                    if i2.eq(2) { s2v = "lei" }
                    mut s3 := s1
                    if i3.neq(0) { s3 = s2 }
                    result = result.concat(s0.concat(s1v).concat(s2v).concat(s3).concat("\n"))
                }
            }
        }
    }
    return result
}

test_lolalalo := test() {
    lola_rec := make_poem_rec("lo", "la")
    lola_it := make_poem_it("lo", "la")
    lalo_rec := make_poem_rec("la", "lo")
    lalo_it := make_poem_it("la", "lo")
    assert_eq(Str, lola_rec, lola_it)
    assert_eq(Str, lalo_rec, lalo_it)
}

// Test 6: Const-folding through immutable variable bindings.
test_fold_variable := test() {
    x := 5
    result := add(x, 3)
    assert_eq(I64, result, 8)
}

// Test 7: __LOC__ is a comptime string containing the source location.
test_loc_folded := test() {
    assert(__LOC__.contains("constfold.til"))
    assert(__LOC__.contains(":"))
}

// Test 7b: F32-returning pure calls fold. The result bakes as a faithful
// literal (F32.to_repr 9-digit round-trip), so it survives both interp
// (re-parsed via Str.to_f32/strtof) and codegen (emitted as a C literal).
mulf := func(a: F32, b: F32) returns F32 { return a.mul(b) }
addf := func(a: F32, b: F32) returns F32 { return a.add(b) }

test_fold_f32 := test() {
    r1 := mulf(2.5, 2.5)
    assert_eq(Str, r1.to_str(), "6.25")
    r2 := addf(1.5, 2.0)
    assert_eq(Str, r2.to_str(), "3.5")
}

// --- Struct comptime folding ---

CfVec2 := struct {
    x := 0
    y := 0

    namespace:
    magic := func() returns CfVec2 {
        return CfVec2(x=42, y=99)
    }

    at := func(x: I64, y: I64) returns CfVec2 {
        return CfVec2(x=x, y=y)
    }
}

// Test 8: Simple struct with pure constructor.
test_struct_fold_simple := test() {
    v := CfVec2.magic()
    assert_eq(I64, v.x, 42)
    assert_eq(I64, v.y, 99)
}

// Test 9: Struct constructor with comptime argument values.
test_struct_fold_values := test() {
    p := CfVec2.at(10, 20)
    assert_eq(I64, p.x, 10)
    assert_eq(I64, p.y, 20)
}

// Test 10: Nested struct.
CfRect := struct {
    top_left := CfVec2()
    bottom_right := CfVec2()

    namespace:
    sample := func() returns CfRect {
        return CfRect(top_left=CfVec2(x=5, y=10), bottom_right=CfVec2(x=100, y=200))
    }
}

test_struct_fold_nested := test() {
    r := CfRect.sample()
    assert_eq(I64, r.top_left.x, 5)
    assert_eq(I64, r.top_left.y, 10)
    assert_eq(I64, r.bottom_right.x, 100)
    assert_eq(I64, r.bottom_right.y, 200)
}

// Test 10b: struct with F32 fields folds correctly. Regression: F32 was
// missing from compute_struct_layout's size/align table (initer.til), so an
// F32 field got an 8-byte slot instead of 4. The folded struct value then
// came back with zeroed F32 fields -- e.g. a v3()-built raylib Vector3 used
// to init a camera folded to (0,0,0), rendering the whole 3D scene black.
// The `at` params deliberately share the field names (x/y/z), mirroring
// examples/shootil.til's `v3` helper.
CfVec3f := struct {
    x : F32 = 0
    y : F32 = 0
    z : F32 = 0

    namespace:
    at := func(x: F32, y: F32, z: F32) returns CfVec3f {
        return CfVec3f(x=x, y=y, z=z)
    }
}

test_struct_fold_f32 := test() {
    v := CfVec3f.at(3.0, 4.0, 5.0)
    assert_eq(Str, v.x.to_str(), "3")
    assert_eq(Str, v.y.to_str(), "4")
    assert_eq(Str, v.z.to_str(), "5")
}

// --- Enum comptime folding ---

Color := enum { Red, Green, Blue }

// Test 11: Enum variant comparison folded at compile time.
test_enum_fold := test() {
    c := Color.Red
    assert(c.eq(Color.Red))
    assert(c.eq(Color.Green).not())
}

Token := enum { Num: I64, Name: Str, Eof }

// Test 12: Payload enum construction folded at compile time.
test_enum_payload_fold := test() {
    t := Token.Num(42)
    assert(t.is(Token.Num))
    assert(t.is(Token.Eof).not())
}

// Test 12b: a no-payload enum-returning pure call folds to the bare
// variant (mk_color() -> Color.Green), eliminating the runtime call.
mk_color := func() returns Color { return Color.Green }

test_enum_return_fold := test() {
    c := mk_color()
    assert(c.eq(Color.Green))
    assert(c.eq(Color.Red).not())
}

// Test 12c: payload-bearing enum-returning pure call folds to the variant
// constructor with its decoded payload (mk_tok(7) -> Token.Num(7)),
// eliminating the wrapping call. The reconstructed FCall emits the same
// way as a direct `t := Token.Num(7)` (Token_Num returns heap-allocated).
mk_tok := func(n: I64) returns Token { return Token.Num(n) }

test_enum_payload_return_fold := test() {
    t := mk_tok(7)
    assert(t.is(Token.Num))
    assert(t.is(Token.Eof).not())
}
