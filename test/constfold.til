mode test

// Compile-time constant folding for pure func / ext_func calls with
// comptime args. Adapted from rstil's src/test/constfold.til.

double_il := func(x: I64) returns I64 { return x.mul(2) }
add := func(a: I64, b: I64) returns I64 { return a.add(b) }
sub := func(a: I64, b: I64) returns I64 { return a.sub(b) }
mul := func(a: I64, b: I64) returns I64 { return a.mul(b) }
concat := func(a: Str, b: Str) returns Str { return a.concat(b) }

// Test 1: Simple arithmetic
test_simple_add := test() {
    result := add(1, 2)
    assert_eq(__LOC__, result, 3)
}

// Test 2: Nested arithmetic
test_nested_arithmetic := test() {
    result := mul(add(1, 2), sub(10, 5))
    assert_eq(__LOC__, result, 15)
}

// Test 3: Deeply nested
test_deeply_nested := test() {
    result := add(mul(2, 3), mul(4, 5))
    assert_eq(__LOC__, result, 26)
}

// Test 4: String concat -- folded at compile time.
test_string_concat := test() {
    result := concat("hello", " world")
    assert_eq_str(__LOC__, result, "hello world")
}

// Test 5: lolalalo -- both recursive and iterative `func`s with comptime
// args. Each generates the same 4-syllable permutation poem at compile
// time. Inspired by rstil/src/examples/lolalalo.til; the test asserts
// recursive == iterative so the two implementations cross-check each
// other and constfold collapses both calls (and the __LOC__ string)
// to literals in the generated C.

poem := func(depth: I64, current: Str, s1: Str, s2: Str) returns Str {
    if depth.eq(4) {
        return current.concat("\n")
    }
    mut result := ""
    result = result.concat(poem(depth.add(1), current.concat(s1), s1, s2))
    result = result.concat(poem(depth.add(1), current.concat(s2), s1, s2))
    if depth.eq(2) {
        result = result.concat(poem(depth.add(1), current.concat("lei"), s1, s2))
    }
    return result
}

make_poem_recursive := func(s1: Str, s2: Str) returns Str {
    return poem(0, "", s1, s2)
}

// Iterative version: four nested loops mirror the four syllables.
// The third position (i2) takes an extra "lei" case, matching the
// `if depth.eq(2)` branch in the recursive version. Order of emission
// (s1 before s2 before lei) matches the recursive walk.
make_poem_iterative := func(s1: Str, s2: Str) returns Str {
    mut result := ""
    for i0 in 0..2 {
        for i1 in 0..2 {
            for i2 in 0..3 {
                for i3 in 0..2 {
                    mut line := ""
                    if i0.eq(0) { line = line.concat(s1) } else { line = line.concat(s2) }
                    if i1.eq(0) { line = line.concat(s1) } else { line = line.concat(s2) }
                    if i2.eq(0) {
                        line = line.concat(s1)
                    } else if i2.eq(1) {
                        line = line.concat(s2)
                    } else {
                        line = line.concat("lei")
                    }
                    if i3.eq(0) { line = line.concat(s1) } else { line = line.concat(s2) }
                    line = line.concat("\n")
                    result = result.concat(line)
                }
            }
        }
    }
    return result
}

test_lolalalo := test() {
    lola_rec := make_poem_recursive("lo", "la")
    lola_it  := make_poem_iterative("lo", "la")
    lalo_rec := make_poem_recursive("la", "lo")
    lalo_it  := make_poem_iterative("la", "lo")
    assert_eq_str(__LOC__, lola_rec, lola_it)
    assert_eq_str(__LOC__, lalo_rec, lalo_it)
}
