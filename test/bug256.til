mode test

// Regression for issue #256: the garbager must MOVE an owned local into an
// Own struct field at the local's last use, not deep-clone it.
//
// In `build`, `val` is a named owned local whose last (and only) use is the
// FieldAssign `h.child = val` into the Own field `child`. The typer inserts a
// defensive `Node.clone(val)` for the Ident RHS; the garbager's last-use pass
// must strip it back to a bare move (`h->child = val`, no clone, no delete)
// -- exactly what a temporary RHS (`h.child = make_node()`) already does.
//
// Before the fix the clone was hoisted into a temp, hiding it from the
// garbager, so codegen emitted `Node_clone(val)` + `Node_delete(val)`: a deep
// copy whose Str_clone of the literal label leaked whenever the surrounding
// value was retained (the #252 compiler-AST regression). The compiler-level
// ASAN baseline in doc/bots/asan.org tracks the leak; this test guards the
// behavior and (under `make test`'s --asan) the move's use-after-free / double
// -free failure modes.

Node := struct {
    own label : Str = ""
}

Holder := struct {
    own child : Node = Node()
}

// Named owned local -> Own field at its last use: must move, not clone.
build := func() returns Holder {
    val := Node(label = "bug256-distinctive-literal-payload-tag!!")
    mut h := Holder()
    h.child = val
    return h
}

test_move_named_local_into_own_field := test() {
    h := build()
    assert(h.child.label.eq("bug256-distinctive-literal-payload-tag!!"))
}
