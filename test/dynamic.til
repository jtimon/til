mode test

test_dyn_map_i64 := test() {
    dm := DynMap.new()
    dm.set(own "answer", "I64", I64.size(), own 42)
    dm.set(own "count", "I64", I64.size(), own 7)

    assert_eq(__LOC__, dm.len().to_i64(), 2)
    assert(__LOC__, dm.has("answer"))
    assert(__LOC__, dm.has("count"))
    assert(__LOC__, dm.has("missing").not())

    ref v0 : I64 = dm.get("answer")
    ref v1 : I64 = dm.get("count")
    assert_eq(__LOC__, v0, 42)
    assert_eq(__LOC__, v1, 7)

    ref t0 : Str = dm.type_at("answer")
    ref s0 : USize = dm.size_at("answer")
    assert_eq_str(__LOC__, t0, "I64")
    assert_eq(__LOC__, s0.to_i64(), 8)
}

test_dyn_map_mixed := test() {
    dm := DynMap.new()
    dm.set(own "name", "Str", Str.size(), own "til")
    dm.set(own "enabled", "Bool", Bool.size(), own true)
    dm.set(own "size", "I64", I64.size(), own 64)

    ref name : Str = dm.get("name")
    ref enabled : Bool = dm.get("enabled")
    ref size : I64 = dm.get("size")

    assert_eq_str(__LOC__, name, "til")
    assert(__LOC__, enabled)
    assert_eq(__LOC__, size, 64)

    ref tn : Str = dm.type_at("name")
    ref tb : Str = dm.type_at("enabled")
    ref ts : Str = dm.type_at("size")
    assert_eq_str(__LOC__, tn, "Str")
    assert_eq_str(__LOC__, tb, "Bool")
    assert_eq_str(__LOC__, ts, "I64")
}

test_dyn_map_overwrite := test() {
    dm := DynMap.new()
    dm.set(own "v", "I64", I64.size(), own 1)
    dm.set(own "v", "Str", Str.size(), own "two")

    assert_eq(__LOC__, dm.len().to_i64(), 1)
    ref v : Str = dm.get("v")
    ref t : Str = dm.type_at("v")
    ref s : USize = dm.size_at("v")
    assert_eq_str(__LOC__, v, "two")
    assert_eq_str(__LOC__, t, "Str")
    assert_eq(__LOC__, s.to_i64(), 16)
}

Foo := struct {
    x := 0
    namespace:
    bar := func(self: Foo) returns I64 { return self.x }
}

test_dyn_has_method := test() {
    // TODO(#15): dummy references so scavenger keeps clone
    n  := 1
    hi := "hi"
    assert_eq(__LOC__, n.clone(), 1)
    assert_eq_str(__LOC__, hi.clone(), "hi")

    expect(__LOC__, dyn_has_method("I64", "delete"), "I64 has delete")
    expect(__LOC__, dyn_has_method("I64", "clone"), "I64 has clone")
    expect(__LOC__, dyn_has_method("I64", "nonexistent").not(), "I64 no nonexistent")
    expect(__LOC__, dyn_has_method("Str", "delete"), "Str has delete")
    expect(__LOC__, dyn_has_method("Str", "nonexistent").not(), "Str no nonexistent")
    expect(__LOC__, dyn_has_method("Bool", "eq"), "Bool has eq")
    expect(__LOC__, dyn_has_method("Bool", "not").not(), "Bool no not (moved to top-level)")
    f := Foo(x=0)
    assert_eq(__LOC__, f.bar(), 0)
    expect(__LOC__, dyn_has_method("Foo", "bar"), "Foo has bar")
    expect(__LOC__, dyn_has_method("Foo", "baz").not(), "Foo no baz")
}

// Dynamic arg narrowing (#20): pass Dynamic where concrete type expected
test_dynamic_narrowing := test() {
    my_vec := vec("I64", 10, 20, 30)
    ref x2 : I64 = my_vec.get(0)
    assert_eq(__LOC__, x2, 10)
    // Dynamic value as typed argument
    assert_eq(__LOC__, 34.add(my_vec.get(0)), 44)
    // Chaining with typed start: 0.add(Dynamic) returns I64, chain continues
    assert_eq(__LOC__, 0.add(my_vec.get(0)).add(my_vec.get(1)).add(my_vec.get(2)), 60)
}

// #166 regression: Bool values in Vec must round-trip correctly through
// chained UFCS calls to top-level and/or/not. Before the fix the
// interpreter's eval_arg narrowing read the low byte of the slot pointer
// instead of dereferencing it, so v.get(i) always looked like true.
//
// Contract: chained UFCS narrows Dynamic via eval_arg in dispatch.til.
// Any container whose get() returns ref Dynamic flows through the same
// path (Array.get, Map.get, Set.contains, ...) -- this Vec test is
// representative; per-container regressions belong in those containers'
// own tests, not here.
test_bool_vec_get_chain := test() {
    v := vec("Bool", true, false)
    // ref-binding path (already worked pre-fix; keep as a baseline)
    ref t0 : Bool = v.get(0)
    ref f0 : Bool = v.get(1)
    assert(__LOC__, t0)
    assert(__LOC__, f0.not())
    // Chained UFCS on Dynamic receiver: not()
    assert(__LOC__, v.get(0).not().not())
    assert(__LOC__, v.get(1).not())
    // Chained UFCS on Dynamic receiver: and()
    assert(__LOC__, v.get(0).and(v.get(0)))
    assert(__LOC__, v.get(0).and(v.get(1)).not())
    assert(__LOC__, v.get(1).and(v.get(0)).not())
    assert(__LOC__, v.get(1).and(v.get(1)).not())
    // Chained UFCS on Dynamic receiver: or()
    assert(__LOC__, v.get(0).or(v.get(0)))
    assert(__LOC__, v.get(0).or(v.get(1)))
    assert(__LOC__, v.get(1).or(v.get(0)))
    assert(__LOC__, v.get(1).or(v.get(1)).not())
}

test_dynamic_local := test() {
    buf : Dynamic = malloc(4)
    assert(__LOC__, is_null(buf).not())
    free(own buf)
}

// #180 regression: `ref x : Dynamic = some_ptr_value` must keep the
// Value.Ptr in x's cell rather than wrapping it into a Value.Struct of
// type "Dynamic" (which the generic StructDef lookup in
// reinterpret_ptr_value would do without an explicit early-return for
// "Dynamic"). Re-narrowing a Dynamic ref to Bool exercises both the
// ref-decl path and the subsequent reinterpret -- pre-fix the second
// reinterpret saw a Value.Struct and bailed via shallow_copy_value, so
// the byte at the slot was never read.
test_dynamic_ref_keeps_ptr := test() {
    v := vec("Bool", true, false)
    ref x : Dynamic = v.get(1)
    ref b : Bool = x
    assert(__LOC__, b.not())
}

// #185 regression: ref-Dynamic locals fed directly into typed-primitive
// call sites used to compile to `DEREF(x)` on a `void *`, which is
// invalid C. The typer's narrow_dynamic retypes the Ident to the param
// type (Bool/U8/etc.); emit_deref now typed-casts via the ref_dyn_locals
// set instead of falling into the generic ref-local path.
bug185_bool_dyn_arg_chain := test() {
    v := vec("Bool", true, false)
    ref x : Dynamic = v.get(1)
    ref y : Dynamic = v.get(0)
    // Top-level Bool helpers via UFCS receiver (Dynamic-typed receiver).
    assert(__LOC__, x.not())
    assert(__LOC__, y.not().not())
    // Top-level Bool helpers via positional Dynamic arg.
    assert(__LOC__, and(y, y))
    assert(__LOC__, or(x, y))
    assert(__LOC__, and(x, y).not())
}

bug185_u8_dyn_arg := test() {
    v := vec("U8", 1.to_u8(), 2.to_u8(), 3.to_u8())
    ref x : Dynamic = v.get(1)
    y : U8 = 10.to_u8()
    // Mixed typed/Dynamic args to a typed-primitive method.
    assert_eq(__LOC__, y.add(x).to_i64(), 12)
}

test_dyn_size_of := test() {
    sz_i64 : USize = dyn_size_of("I64")
    sz_u8 : USize = dyn_size_of("U8")
    sz_str : USize = dyn_size_of("Str")
    sz_dynamic : USize = dyn_size_of("Dynamic")

    assert_eq(__LOC__, sz_i64.to_i64(), 8)
    assert_eq(__LOC__, sz_u8.to_i64(), 1)
    assert_eq(__LOC__, sz_str.to_i64(), 16)
    assert_eq(__LOC__, sz_dynamic.to_i64(), Dynamic.size().to_i64())

    elem_type : Str = "I64"
    via_var : USize = dyn_size_of(elem_type)
    assert_eq(__LOC__, via_var.to_i64(), 8)

    via_size : USize = dyn_size_of("I64")
    via_method : USize = I64.size()
    assert_eq(__LOC__, via_size.to_i64(), via_method.to_i64())
}

TypeNameStruct := struct {
    x := 0
}

type_name_passthrough := func(T: Type) returns Str {
    return dyn_type_to_str(T)
}

test_dyn_type_to_str := test() {
    assert_eq_str(__LOC__, dyn_type_to_str(I64), "I64")
    assert_eq_str(__LOC__, dyn_type_to_str(Str), "Str")
    assert_eq_str(__LOC__, dyn_type_to_str(Bool), "Bool")
    assert_eq_str(__LOC__, dyn_type_to_str(TypeNameStruct), "TypeNameStruct")
    assert_eq_str(__LOC__, type_name_passthrough(Str), "Str")
    assert_eq_str(__LOC__, type_name_passthrough(TypeNameStruct), "TypeNameStruct")
}
