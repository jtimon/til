mode test

// --- Function closures (issue #54) ---
// A capturing function/lambda `func(a: I64) returns I64 [scale] { ... }`
// is a closure: it reads (and with `mut`, writes) the listed outer-scope
// locals. The capture list is explicit -- the body may only touch the
// captured names (plus its params, body-locals, globals and top-level
// funcs/types), enforced by the typer.
//
// These tests cover inferred local closure forms and direct closure
// arguments. Explicit FuncSig-local closure values are covered in
// test/first_class.til.

GLOBAL_BASE := 100

UnaryOp := func(I64) returns I64
StrSupplier := func() returns Str

WordBox := struct {
    text := ""
}

BoxSupplier := func() returns WordBox

apply_unary := func(op: UnaryOp, x: I64) returns I64 {
    return op(x)
}

// A named local closure, called within its defining scope.
test_closure_named_same_scope := test() {
    scale := 10
    scaled := func(a: I64) returns I64 [scale] { return a.mul(scale) }
    assert_eq(I64, scaled(3), 30)
    assert_eq(I64, scaled(5), 50)
}

// A lambda closure passed to a higher-order function (escapes its scope).
test_closure_lambda_escape := test() {
    factor := 7
    assert_eq(I64, apply_unary(func(x: I64) returns I64 [factor] { return x.mul(factor) }, 4), 28)
}

// A closure may freely use globals, params and body-locals alongside captures.
test_closure_with_global := test() {
    bump := 5
    f := func(a: I64) returns I64 [bump] {
        doubled := a.mul(2)
        return doubled.add(bump).add(GLOBAL_BASE)
    }
    assert_eq(I64, f(1), 107)
}

// A `mut` capture lets the closure mutate the captured outer local.
test_closure_mut_capture := test() {
    mut total := 0
    add_to_total := func(x: I64) returns I64 [mut total] {
        total = total.add(x)
        return total
    }
    assert_eq(I64, add_to_total(3), 3)
    assert_eq(I64, add_to_total(4), 7)
    assert_eq(I64, total, 7)
}

make_multiplier := func(factor: I64) returns UnaryOp {
    local_factor := factor
    return func(x: I64) returns I64 [own local_factor] { return x.mul(local_factor) }
}

test_closure_return_owns_i64 := test() {
    triple := make_multiplier(3)
    assert_eq(I64, triple(6), 18)
}

make_str_supplier := func() returns StrSupplier {
    msg := "hello"
    return func() returns Str [own msg] { return msg.clone() }
}

test_closure_return_owns_str := test() {
    get_msg := make_str_supplier()
    assert_eq(Str, get_msg(), "hello")
}

make_box_supplier := func() returns BoxSupplier {
    box := WordBox(text = "boxed")
    return func() returns WordBox [own box] { return box.clone() }
}

test_closure_return_owns_struct_with_str := test() {
    get_box := make_box_supplier()
    box := get_box()
    assert_eq(Str, box.text, "boxed")
}
