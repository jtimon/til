mode test

fn_double := func(n: I64) returns I64 {
    return n.mul(2)
}

test_func_proc := test() {
    assert_eq(__LOC__, fn_double(5), 10)
    assert_eq(__LOC__, fn_double(0), 0)
}

test_scope := test() {
    outer := 1
    {
        inner := 2
        assert_eq(__LOC__, inner, 2)
        assert_eq(__LOC__, outer, 1)
    }
    assert_eq(__LOC__, outer, 1)
}

fn_inc := func(mut x: I64) {
    x = I64.add(x, 1)
}

fn_swap := func(mut a: I64, mut b: I64) {
    tmp := a
    a = b
    b = tmp
}

test_mut_params := test() {
    mut_val := 42
    fn_inc(mut_val)
    assert_eq(__LOC__, mut_val, 43)
    mut_a := 10
    mut_b := 20
    fn_swap(mut_a, mut_b)
    assert_eq(__LOC__, mut_a, 20)
    assert_eq(__LOC__, mut_b, 10)
}

fn_identity := func(own x: I64) returns I64 {
    return x
}

test_own_params := test() {
    assert_eq(__LOC__, fn_identity(own 100), 100)
}

// --- merged from test/ufcs.til ---

// Test universal UFCS: a.f(b) resolves to top-level f(a, b)

double := func(x: I64) returns I64 { return x.mul(2) }

test_basic := test() {
    assert(__LOC__, 5.double().eq(10))
    assert(__LOC__, 0.double().eq(0))
}

test_println := test() {
    "hello from ufcs".println()
}

test_format := test() {
    s := "result: ".format(42.to_str())
    assert(__LOC__, s.eq("result: 42"))
}

greet := func(name: Str) returns Str {
    return "hello, ".format(name)
}

test_user_func := test() {
    s := "world".greet()
    assert(__LOC__, s.eq("hello, world"))
}
