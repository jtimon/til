mode test

# Issue #244: `match` is the expression form of selection. `switch` stays
# statement-only; `match` yields a value usable anywhere an expression is.

Color := enum { Red, Green, Blue }
Token := enum { Num: I64, Name: Str, Eof }

# --- match as an initializer over an enum (exhaustive, no default) ---
test_match_enum_to_str := test() {
    c := Color.Green
    name := match c {
    case Color.Red:   "red"
    case Color.Green: "green"
    case Color.Blue:  "blue"
    }
    assert_eq(__LOC__, Str, name, "green")
}

# --- every arm reached, value selected correctly ---
test_match_each_arm := test() {
    mut out := ""
    out = out.concat(match Color.Red   { case Color.Red: "r" case Color.Green: "g" case Color.Blue: "b" })
    out = out.concat(match Color.Green { case Color.Red: "r" case Color.Green: "g" case Color.Blue: "b" })
    out = out.concat(match Color.Blue  { case Color.Red: "r" case Color.Green: "g" case Color.Blue: "b" })
    assert_eq(__LOC__, Str, out, "rgb")
}

# --- payload binding; integer result ---
test_match_payload := test() {
    t := Token.Num(42)
    n := match t {
    case Token.Num(v):  v
    case Token.Name(s): s.len().to_i64()
    case Token.Eof:     -1
    }
    assert_eq(__LOC__, I64, n, 42)
}

test_match_payload_str := test() {
    t := Token.Name("hello")
    s := match t {
    case Token.Num(v):  v.to_str()
    case Token.Name(n): n
    case Token.Eof:     "eof"
    }
    assert_eq(__LOC__, Str, s, "hello")
}

# --- guard arm: a failed guard falls through to the next arm ---
test_match_guard := test() {
    n := 5
    s := match n {
    case 5 if false: "no"
    case 5:          "yes"
    case:            "other"
    }
    assert_eq(__LOC__, Str, s, "yes")
}

# --- #282: a throwing (subscript) call in a match guard runs ONLY on a
#     pattern hit. The empty-Vec subscript here must not OOB-panic when the
#     pattern misses; on a hit the guard is evaluated normally. ---
test_match_guard_throwing_call := test() {
    empty := Vec(I64).new()
    miss := match empty.len() {       # 0; pattern 1 misses, guard must not run
    case 1 if empty[0].gt(0): 1
    case: 2
    }
    assert_eq(__LOC__, I64, miss, 2)

    mut v := Vec(I64).new()
    v.push(own 9)
    hit := match v.len() {            # 1; pattern hits, guard true -> 1
    case 1 if v[0].gt(0): 1
    case: 2
    }
    assert_eq(__LOC__, I64, hit, 1)
}

# --- default `case:` on a non-enum subject ---
test_match_default := test() {
    n := 7
    s := match n {
    case 1: "one"
    case 2: "two"
    case:   "many"
    }
    assert_eq(__LOC__, Str, s, "many")
}

# --- match in return position ---
classify := func(c: Color) returns Str {
    return match c {
    case Color.Red:   "r"
    case Color.Green: "g"
    case Color.Blue:  "b"
    }
}

test_match_return := test() {
    assert_eq(__LOC__, Str, classify(Color.Blue), "b")
}

# --- match as the RHS of an assignment to an existing mut ---
test_match_assign := test() {
    mut s := "init"
    s = match Color.Red {
    case Color.Red:   "red"
    case Color.Green: "green"
    case Color.Blue:  "blue"
    }
    assert_eq(__LOC__, Str, s, "red")
}

# --- match as a function argument ---
greet := func(s: Str) returns Str {
    return "hi-".concat(s)
}

test_match_arg := test() {
    out := greet(match Color.Green {
    case Color.Red:   "r"
    case Color.Green: "g"
    case Color.Blue:  "b"
    })
    assert_eq(__LOC__, Str, out, "hi-g")
}

# --- nested match (a match in another match's arm) ---
test_match_nested := test() {
    c := Color.Green
    n := 1
    s := match c {
    case Color.Red:   "red"
    case Color.Green: match n {
        case 1: "green-one"
        case:   "green-other"
        }
    case Color.Blue:  "blue"
    }
    assert_eq(__LOC__, Str, s, "green-one")
}

# --- two matches in one statement ---
test_match_two_in_stmt := test() {
    a := match Color.Red   { case Color.Red: 1 case Color.Green: 2 case Color.Blue: 3 }
    b := match Color.Blue  { case Color.Red: 1 case Color.Green: 2 case Color.Blue: 3 }
    assert_eq(__LOC__, I64, a.add(b), 4)
}

# --- match used inside a switch arm (statement context) still works ---
test_match_in_switch := test() {
    c := Color.Green
    mut label := ""
    switch c {
    case Color.Red:
        label = "red"
    case Color.Green:
        label = match c { case Color.Green: "still-green" case: "?" }
    case Color.Blue:
        label = "blue"
    }
    assert_eq(__LOC__, Str, label, "still-green")
}

# Issue #262/#244: a throwing call in a `match` arm body must be lowered INTO
# the arm -- it gets its hidden _err_kind/_err_<T> out-args and only runs when
# that arm is taken. Covers a subscript `get!`, an explicit `f()!` (panic on
# throw), and (below) an `f()?` that propagates. Without the fix these failed
# infer with "missing argument for parameter '_err_kind'"; a guarded subscript
# would also out-of-bounds if the arm were evaluated eagerly.

MatchArmErr := struct { }

pos_or_throw := func(x: I64) returns I64 throws MatchArmErr {
    if x.lt(1) { throw MatchArmErr() }
    return x
}

test_match_arm_throwing_calls := test() {
    v := Vec(I64).new()
    # subscript get! in an arm, guarded by the (false) scrutinee -> no OOB
    a := match v.len().gt(0) { case true: v[0].gt(0) case: false }
    expect(__LOC__, a.not(), "subscript arm short-circuited")
    v.push(own 42)
    b := match v.len().gt(0) { case true: v[0].eq(42) case: false }
    expect(__LOC__, b, "subscript arm taken")
    # f()! in an arm: panics on throw; pos_or_throw(5) does not throw
    c := match true { case true: pos_or_throw(5)!.gt(0) case: false }
    expect(__LOC__, c, "bang call arm ok")
}

# f()? in a match arm propagates to the enclosing function's throws clause.
match_q := func(go: Bool, n: I64) returns Bool throws MatchArmErr {
    return match go { case true: pos_or_throw(n)?.gt(0) case: false }
}

test_match_arm_propagates := test() {
    expect(__LOC__, match_q(false, -1)!.not(), "? arm not taken: no throw")
    expect(__LOC__, match_q(true, 3)!, "? arm taken: ok")
}

# Issue #262: a throwing call in a NESTED match arm (a match inside a match
# arm) is lowered too -- process_match_arms_in re-enters via the per-statement
# throw/catch lowering it runs on each arm body, so depth is handled. The outer
# guard means the inner subscript only runs when both arms are taken.
test_nested_match_arm_throwing := test() {
    v := Vec(I64).new()
    a := match v.len().gt(0) {
        case true: match true { case true: v[0].gt(0) case: false }
        case: false
    }
    expect(__LOC__, a.not(), "nested empty: no OOB")
    v.push(own 42)
    b := match v.len().gt(0) {
        case true: match true { case true: v[0].eq(42) case: false }
        case: false
    }
    expect(__LOC__, b, "nested nonempty: taken arms")
}
