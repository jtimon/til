mode script

// #242: a struct field with no default is required at instantiation.
// Omitting it (even via a bare `Type()`) is a type error.

Abc := struct {
    a : U16 = 0
    b : Str
    c := -1
}

// 'b' has no default, so Abc() is missing a required field.
abc := Abc()

Mixed := struct {
    x := 1
    label : Str
}

// 'x' is defaulted (fine to omit) but 'label' is required.
m := Mixed()
