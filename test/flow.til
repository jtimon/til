mode test

test_if_else := test() {
    if true {
        assert(__LOC__, true)
    }
    if false {
        panic(__LOC__, "unreachable")
    } else {
        assert(__LOC__, true)
    }
    if true.and(true) {
        assert(__LOC__, true)
    }
    if true.and(false) {
        panic(__LOC__, "unreachable")
    } else {
        assert(__LOC__, true)
    }
}

test_while_loop := test() {
    while false {
        panic(__LOC__, "unreachable")
    }
    mut i := 0
    while i.lt(5) {
        i++
    }
    assert_eq(__LOC__, I64, i, 5)
}

test_break := test() {
    mut i := 0
    while true {
        if i.eq(3) { break }
        i++
    }
    assert_eq(__LOC__, I64, i, 3)
    mut sum := 0
    mut j := 0
    while true {
        if j.eq(5) { break }
        sum = sum.add(j)
        j++
    }
    assert_eq(__LOC__, I64, sum, 10)
}

test_continue := test() {
    mut k := 0
    mut total := 0
    while k.lt(5) {
        k++
        if k.eq(3) { continue }
        total = total.add(k)
    }
    assert_eq(__LOC__, I64, total, 12)
}

flow_early_ret := func(x: Bool) returns I64 {
    a := 10
    b := 20
    if x { return a }
    return b
}

test_early_return := test() {
    assert_eq(__LOC__, I64, flow_early_ret(true), 10)
    assert_eq(__LOC__, I64, flow_early_ret(false), 20)
}

flow_check := func(n: I64) returns I64 {
    if n.eq(1) { return 10 }
    else if n.eq(2) { return 20 }
    else if n.eq(3) { return 30 }
    else { return 0 }
}

test_else_if := test() {
    assert_eq(__LOC__, I64, flow_check(1), 10)
    assert_eq(__LOC__, I64, flow_check(2), 20)
    assert_eq(__LOC__, I64, flow_check(3), 30)
    assert_eq(__LOC__, I64, flow_check(99), 0)
}

# ASAP edge cases: return from inside while must free parent-scope locals

asap_return_from_while := func(n: I64) returns Str {
    s := "allocated"
    mut i := 0
    while i.lt(n) {
        if i.eq(2) { return "early" }
        i++
    }
    return s
}

test_asap_while := test() {
    # Early return path: s must be freed before returning "early"
    assert_eq(__LOC__, Str, asap_return_from_while(5), "early")
    # Normal path: s returned normally
    assert_eq(__LOC__, Str, asap_return_from_while(1), "allocated")
}

asap_return_nested := func(n: I64) returns Str {
    s1 := "first"
    s2 := "second"
    mut i := 0
    while i.lt(n) {
        if i.eq(1) {
            if true {
                return s1
            }
        }
        i++
    }
    return s2
}

test_asap_nested := test() {
    # Return from if-inside-if-inside-while: s2 must be freed, s1 returned
    assert_eq(__LOC__, Str, asap_return_nested(3), "first")
    # Normal path: s1 freed by ASAP, s2 returned
    assert_eq(__LOC__, Str, asap_return_nested(0), "second")
}

asap_break_no_leak := func() returns Str {
    s := "alive"
    mut i := 0
    while i.lt(10) {
        if i.eq(2) { break }
        i++
    }
    # s must still be alive after break (not freed by break)
    return s
}

test_asap_break := test() {
    assert_eq(__LOC__, Str, asap_break_no_leak(), "alive")
}

# ASAP edge case: variable used in both branches of if/else
asap_if_both_branches := func(x: I64) returns Str {
    s := "both"
    if x.eq(1) {
        _ := format(s)
    } else {
        _ := format(s)
    }
    # s freed after if/else, not leaked
    return "done"
}

# ASAP edge case: variable used only in one branch
asap_if_one_branch := func(x: I64) returns Str {
    s := "one"
    if x.eq(1) {
        _ := format(s)
    } else {
        _ := format("other")
    }
    # s freed after if/else even though only used in then
    return "done"
}

# ASAP edge case: return from one branch, other locals freed
asap_if_return_branch := func(x: I64) returns Str {
    s := "kept"
    t := "freed"
    if x.eq(1) {
        return s
    }
    return t
}

test_asap_if_else := test() {
    assert_eq(__LOC__, Str, asap_if_both_branches(1), "done")
    assert_eq(__LOC__, Str, asap_if_both_branches(0), "done")
    assert_eq(__LOC__, Str, asap_if_one_branch(1), "done")
    assert_eq(__LOC__, Str, asap_if_one_branch(0), "done")
    # return from if: s returned, t freed before return
    assert_eq(__LOC__, Str, asap_if_return_branch(1), "kept")
    # fall through: t returned, s freed by ASAP
    assert_eq(__LOC__, Str, asap_if_return_branch(0), "freed")
}

# ASAP edge case: mut variable reassignment must free old value
test_reassign_str := test() {
    mut s := "hello"
    s = "world"
    assert_eq(__LOC__, Str, s, "world")
}

reassign_clone_helper := func(x: Str) {
    mut s := "hello"
    s = x
    assert_eq(__LOC__, Str, s, "from_arg")
}

test_reassign_clone := test() {
    reassign_clone_helper("from_arg")
}

test_reassign_multi := test() {
    mut s := "a"
    s = "b"
    s = "c"
    s = "d"
    assert_eq(__LOC__, Str, s, "d")
}

# --- switch ---

test_switch_i64 := test() {
    mut result := 0
    switch 2 {
    case 1: result = 10
    case 2: result = 20
    case 3: result = 30
    case: result = 99
    }
    assert_eq(__LOC__, I64, result, 20)

    // Default case
    switch 99 {
    case 1: result = 10
    case: result = -1
    }
    assert_eq(__LOC__, I64, result, -1)
}

test_switch_str := test() {
    mut result := ""
    switch "bob" {
    case "alice": result = "a"
    case "bob": result = "b"
    case: result = "?"
    }
    assert_eq(__LOC__, Str, result, "b")
}

test_switch_char := test() {
    mut result := 0
    switch 'b' {
    case 'a': result = 1
    case 'b': result = 2
    case 'c': result = 3
    }
    assert_eq(__LOC__, I64, result, 2)
}

test_switch_bool := test() {
    mut result := 0
    switch true {
    case true: result = 1
    case false: result = 2
    }
    assert_eq(__LOC__, I64, result, 1)
}

test_switch_default_only := test() {
    mut result := 0
    switch 42 {
    case: result = 99
    }
    assert_eq(__LOC__, I64, result, 99)
}

test_switch_no_default := test() {
    mut result := 0
    switch 1 {
    case 1: result = 10
    case 2: result = 20
    }
    assert_eq(__LOC__, I64, result, 10)

    // No match, no default -- nothing happens
    result = 0
    switch 5 {
    case 1: result = 10
    }
    assert_eq(__LOC__, I64, result, 0)
}

test_switch_nested := test() {
    mut result := 0
    switch 1 {
    case 1:
        switch "a" {
        case "a": result = 11
        case "b": result = 12
        }
    case 2: result = 20
    }
    assert_eq(__LOC__, I64, result, 11)
}

test_switch_in_loop := test() {
    // break inside switch body should exit enclosing loop, not the switch
    mut total := 0
    for i in 0..10 {
        switch i.mod(3) {
        case 0: total = total.add(i)
        case 1: total++
        case: total = total.add(0)
        }
    }
    // i=0: +0, i=1: +1, i=2: +0, i=3: +3, i=4: +1, i=5: +0, i=6: +6, i=7: +1, i=8: +0, i=9: +9
    assert_eq(__LOC__, I64, total, 21)
}

test_switch_multi_stmt := test() {
    mut a := 0
    mut b := 0
    switch 2 {
    case 1:
        a = 1
        b = 10
    case 2:
        a = 2
        b = 20
    case:
        a = 0
        b = 0
    }
    assert_eq(__LOC__, I64, a, 2)
    assert_eq(__LOC__, I64, b, 20)
}

// Phase 2: Range cases
test_switch_range_i64 := test() {
    mut result := ""
    switch 5 {
    case 0..3: result = "low"
    case 4..7: result = "mid"
    case 8..10: result = "high"
    case: result = "other"
    }
    assert_eq(__LOC__, Str, result, "mid")
}

test_switch_range_char := test() {
    mut result := ""
    switch 'e' {
    case 'a'..'z': result = "lower"
    case 'A'..'Z': result = "upper"
    case '0'..'9': result = "digit"
    case: result = "other"
    }
    assert_eq(__LOC__, Str, result, "lower")
}

test_switch_range_mixed := test() {
    // Mix ranges, exact values, and default
    mut result := 0
    switch 5 {
    case 0: result = 1
    case 1..4: result = 2
    case 5: result = 3
    case 6..9: result = 4
    case: result = 5
    }
    assert_eq(__LOC__, I64, result, 3)
}

test_switch_range_boundary := test() {
    // Inclusive: end value should match
    mut result := false
    switch 'z' {
    case 'a'..'z': result = true
    }
    assert(__LOC__, result)

    result = false
    switch '9' {
    case '0'..'9': result = true
    }
    assert(__LOC__, result)

    // Start value should also match
    result = false
    switch 'a' {
    case 'a'..'z': result = true
    }
    assert(__LOC__, result)
}

// `break` inside a switch case should exit the enclosing loop, not the
// switch (til has no fallthrough, so cases don't need their own break)
test_switch_break_in_loop := test() {
    mut total := 0
    for i in 0..10 {
        switch i {
        case 5: break
        case: total++
        }
    }
    assert_eq(__LOC__, I64, total, 5)
}
