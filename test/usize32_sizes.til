mode script

// Issue #309 regression, COMPILE-ONLY. Built with --usize=32, the emitted
// structs use U32 container widths (via ext.h -DTIL_USIZE32), and the size
// intrinsics (X.size() / dyn_size_of) now emit C sizeof on a width-mismatched
// target, so they report that narrow width. Str = ptr(8)+count(4)+cap(4) = 16
// (24 at the default U64); Vec = ptr(8)+count(4)+cap(4) = 16.
//
// This file is driven ONLY as a compiled binary by the Makefile check_usize32
// target -- NOT interpreted: the compile-time interpreter manipulates the
// compiler's own HOST-resident structs, so X.size() is the host width (24)
// under the interpreter. Asserting 16 therefore only holds for compiled code.

check := proc(label: Str, got: USize, want: USize) {
    if got.neq(want) {
        println(format("FAIL: ", label, " = ", got.to_str(), ", want ", want.to_str()))
        exit(1)
    }
}

check("Str.size()", Str.size(), 16)
check("Vec(Str).size()", Vec(Str).size(), 16)
check("Vec(I64).size()", Vec(I64).size(), 16)
check("dyn_size_of Str", dyn_size_of("Str"), 16)

// A vec must stride at the narrow width too: 3 pushes stay addressable and
// round-trip (a host-width 24-byte stride over 16-byte structs would misplace
// elements).
mut v := Vec(Str).new()
v.push(own "a")
v.push(own "bb")
v.push(own "ccc")
check("vec len", v.len(), 3)
ref e0 : Str = v.unsafe_get(0)
ref e2 : Str = v.unsafe_get(2)
if e0.eq("a").not().or(e2.eq("ccc").not()) { println("FAIL: vec stride"); exit(1) }

println("usize32 sizes OK")
