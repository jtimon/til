mode test

// The Collection interface: the get/len contract that `for ... in` loops
// rely on (Range and Vec already implement it -- see doc/auto.org). It is
// pinned down here as a named interface so a later change can use it to
// give clearer errors when a for-in target does not provide get/len.
// Nothing wires it into the loop machinery yet -- this test just fixes the
// contract and proves it compiles end-to-end (interpret AND build) as a
// usable, fieldless type. See issue #265 for the interface keyword.

Collection := interface {
    get := func(self: Collection, i: U32) returns Dynamic
    len := func(self: Collection) returns USize
}

// Usable as a parameter type.
collection_tag := func(_c: Collection) returns I64 {
    return 7
}

// An interface-typed value can be passed on through another call.
relay := func(c: Collection) returns I64 {
    return collection_tag(c)
}

test_collection_usable_as_param_type := test() {
    assert_eq(__LOC__, collection_tag(Collection()), 7)
}

test_collection_passed_through := test() {
    assert_eq(__LOC__, relay(Collection()), 7)
}
