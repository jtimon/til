mode test

# --- ref returns with I64 ---

min := func(a: I64, b: I64) returns ref I64 {
    if a.lt(b) { return a } else { return b }
}

test_ref_i64 := test() {
    x := 3
    y := 7
    ref m := min(x, y)
    assert_eq(__LOC__, I64, m, 3)
}

# --- ref returns with Str ---

shorter := func(a: Str, b: Str) returns ref Str {
    if a.len().lt(b.len()) { return a } else { return b }
}

test_ref_str := test() {
    a := "hi"
    b := "hello"
    ref s := shorter(a, b)
    assert_eq(__LOC__, Str, s, "hi")
}

# --- ref from parameter ---

identity := func(x: I64) returns ref I64 {
    return x
}

test_ref_from_param := test() {
    v := 42
    ref r := identity(v)
    assert_eq(__LOC__, I64, r, 42)
}

# --- ref from owned compound local ---

RefPoint := struct {
    x := 0
    y := 0
}

test_ref_from_owned_compound := test() {
    p := RefPoint(x = 42, y = 99)
    ref r : RefPoint = p
    assert_eq(__LOC__, I64, r.x, 42)
    assert_eq(__LOC__, I64, r.y, 99)
}

# --- ref from field access ---

RefBox := struct {
    n := 0
    namespace:
    get_n := func(self: RefBox) returns ref I64 {
        return self.n
    }
}

test_ref_from_field_return := test() {
    b := RefBox(n = 9)
    ref n : I64 = b.get_n()
    assert_eq(__LOC__, I64, n, 9)
}

test_ref_decl_from_field := test() {
    b := RefBox(n = 11)
    ref n : I64 = b.n
    assert_eq(__LOC__, I64, n, 11)
}

# --- ref Dynamic from owned compound ---

test_ref_dynamic_from_struct := test() {
    p := RefPoint(x = 10, y = 20)
    ref d : Dynamic = p
    ref p2 : RefPoint = d
    assert_eq(__LOC__, I64, p2.x, 10)
    assert_eq(__LOC__, I64, p2.y, 20)
}

# --- NULL literal + ref struct fields ---
# (test_null_ref_local removed: #177 closed the loophole that let test()
# bodies initialize a ref binding to NULL. Same rule as #168 step 1b for
# func bodies. NULL ref-binding init now fails uniformly at module scope,
# in func/proc bodies, in test() bodies, and in macros.)

accept_null := func(x: RefPoint) {
    // A borrowed compound param can receive NULL. (Primitives are passed by
    // value now -- issue #223 auto-shallow -- so an I64 param can no longer
    // take NULL; the borrowed-pointer case lives on for compound types.)
    assert(__LOC__, is_null(x))
}

test_null_borrowed_arg := test() {
    accept_null(NULL)
}

RefNode := struct {
    const value := 0
    ref next : RefNode = NULL
}

test_ref_struct_field := test() {
    a := RefNode(value = 10)
    b := RefNode(value = 20)
    a.next = b
    assert_eq(__LOC__, I64, a.value, 10)
    assert_eq(__LOC__, I64, a.next.value, 20)

    // clone copies the pointer (not deep clone)
    c := a.clone()
    assert_eq(__LOC__, I64, c.value, 10)
    assert_eq(__LOC__, I64, c.next.value, 20)
}

# --- Issue #226 / #227: ref mut primitive must deref-write ---
#
# Both compile (#226) and interp (#227) paths now deref-write
# when assigning a value through a `ref mut x : Primitive` binding
# whose RHS was a raw pointer expression. The compile fix lives
# in builder.til (do_rebind skip for params); the interp fix lives
# in this file (ref_primitive_ptrs side table + write_* dispatch
# on Assign).

ref226_param_rhs := func(len: USize) returns U32 {
    buf : Dynamic = malloc(8)
    write_u32(buf, 0)
    ref mut slot : U32 = ptr_add(buf, 0)
    slot = len
    // Re-read via a fresh ref binding: this triggers
    // reinterpret_ptr_value which loads the U32 at `buf`, so we
    // verify the original storage actually got the write rather
    // than just trusting `slot`'s local cell.
    ref read_back : U32 = ptr_add(buf, 0)
    out : U32 = read_back
    free(own buf)
    return out
}

test_ref_mut_primitive_assign := test() {
    got := ref226_param_rhs(42)
    assert_eq(__LOC__, I64, got.to_i64(), 42)
}
