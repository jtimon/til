mode script

// Test: global variables accessible from functions and procs,
// including forward refs to globals declared later
// See issue #17

// func accessing global
f := func() returns I64 {
    return x
}

// proc accessing global
g := proc() {
    println(x.to_str())
}

// proc accessing global via declaration
h := proc() {
    y := x
    println(y.to_str())
}

x := 42

assert(f().eq(42))
g()
h()

inc := func() {
    counter++
}

get_counter := func() returns I64 {
    return counter
}

// mut global modified by proc
mut counter := 0

inc()
inc()
inc()
assert(get_counter().eq(3))
assert(counter.eq(3))
counter = 100
assert(counter.eq(100))

DeleteOnOverwrite := struct {
    id := 0
    namespace:
    mut delete_count := 0
    delete := func(own self: DeleteOnOverwrite, call_free: Bool = true) {
        DeleteOnOverwrite.delete_count = DeleteOnOverwrite.delete_count.add(1)
        if call_free { free(own self) }
    }
}

mut tracked := DeleteOnOverwrite(id=1)
assert(DeleteOnOverwrite.delete_count.eq(0))
tracked = DeleteOnOverwrite(id=2)
assert(DeleteOnOverwrite.delete_count.eq(1))
tracked = DeleteOnOverwrite(id=3)
assert(DeleteOnOverwrite.delete_count.eq(2))

// #302: a program-scope Dynamic follows the same raw-pointer contract as a
// proc local (qualifiers.org): malloc it, pass it as the pointer VALUE, and
// free(own) it. The builder used to classify it as a value global, so plain
// args took its ADDRESS (an ext write clobbered the pointer slot, not the
// buffer) and `free(own gbuf)` emitted the malloc(sizeof(void)) own-box --
// invalid C that failed the whole compile.
gbuf_read := func(p: Dynamic) returns U8 {
    ref b : U8 = p
    return b.clone()
}
gbuf : Dynamic = malloc(8)
write_u8(gbuf, 77)
assert(gbuf_read(gbuf).eq(77))
free(own gbuf)

println("globals: ok")
