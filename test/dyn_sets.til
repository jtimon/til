mode test

import("../src/std/dyn_set")

test_i64_set := test() {
    s := DynSet.new(I64)
    s.add(own 3)
    s.add(own 1)
    s.add(own 2)
    assert_eq(USize, s.len(), 3)
    assert(s.has(1))
    assert(s.has(2))
    assert(s.has(3))
    assert(s.has(4).not())

    // Duplicates ignored
    s.add(own 2)
    assert_eq(USize, s.len(), 3)
}

test_str_set := test() {
    ss := DynSet.new(Str)
    ss.add(own "banana")
    ss.add(own "apple")
    ss.add(own "cherry")
    assert_eq(USize, ss.len(), 3)
    assert(ss.has("apple"))
    assert(ss.has("banana"))
    assert(ss.has("cherry"))
    assert(ss.has("date").not())
    ss.add(own "apple")
    assert_eq(USize, ss.len(), 3)
}

// --- DynSet literal tests ---

test_dyn_set_literal_i64 := test() {
    s := {3, 1, 2}
    assert_eq(USize, s.len(), 3)
    assert(s.has(1))
    assert(s.has(2))
    assert(s.has(3))
    assert(s.has(4).not())
}

test_dyn_set_literal_str := test() {
    s := {"apple", "banana", "cherry"}
    assert_eq(USize, s.len(), 3)
    assert(s.has("apple"))
    assert(s.has("banana"))
    assert(s.has("cherry"))
    assert(s.has("date").not())
}
