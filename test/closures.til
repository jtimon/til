mode test

// --- Block captures: scope restriction (issue #54) ---
// A bare `[names] { ... }` block limits which outer-scope locals the
// block body may touch. Captures follow parameter modifier rules:
// `[x]` is a const-by-reference capture, `[mut x]` a mutable one.
// Globals, top-level functions and types need no capture. The block
// stays inline at runtime, so the only effect is the compile-time check.

GLOBAL_SCALE := 10

helper_double := func(n: I64) returns I64 { return n.mul(2) }

// Const capture: read a captured outer local, write a captured mut local.
test_block_capture_const_read := test() {
    base := 10
    mut result := 0
    [base, mut result] {
        result = base.add(5)
    }
    assert_eq(I64, result, 15)
}

// A global is always visible without being captured.
test_block_capture_global_allowed := test() {
    mut r := 0
    [mut r] {
        r = GLOBAL_SCALE.add(2)
    }
    assert_eq(I64, r, 12)
}

// A top-level function is always callable without being captured.
test_block_capture_func_allowed := test() {
    seed := 6
    mut out := 0
    [seed, mut out] {
        out = helper_double(seed)
    }
    assert_eq(I64, out, 12)
}

// Block-local declarations are free to use inside the block.
test_block_capture_block_local := test() {
    seed := 3
    mut out := 0
    [seed, mut out] {
        doubled := seed.mul(2)
        out = doubled.add(1)
    }
    assert_eq(I64, out, 7)
}

// A for-loop inside a capture block, accumulating into a captured mut.
test_block_capture_loop := test() {
    mut total := 0
    [mut total] {
        for i in 1..4 {
            total = total.add(i)
        }
    }
    assert_eq(I64, total, 6)
}

// Nested capture blocks each restrict to their own list.
test_block_capture_nested := test() {
    a := 1
    b := 2
    mut sum := 0
    [a, b, mut sum] {
        [a, mut sum] {
            sum = sum.add(a)
        }
        sum = sum.add(b)
    }
    assert_eq(I64, sum, 3)
}

// A capture block leaves untouched outer locals genuinely untouched.
test_block_capture_isolation := test() {
    mut touched := 0
    untouched := 99
    [mut touched] {
        touched++
    }
    assert_eq(I64, touched, 1)
    assert_eq(I64, untouched, 99)
}

// #295: a capturing closure is first-class -- callable by its own local name,
// not only when passed through a parameter. (Previously the by-name call
// typed as 'unknown' because the initer mis-registered it as a named func.)
// Captures a runtime value (compile-time-constant captures hit a separate
// const-folding edge tracked in #295).
Adder295 := func(x: I64) returns I64
mk_base295 := func() returns I64 { return 5 }
test_capturing_closure_by_name := test() {
    base := mk_base295()
    add1 : Adder295 = func(x: I64) returns I64 [base] { return base.add(x) }
    assert_eq(I64, add1(10), 15)
    // also still works through a parameter
    apply := func(f: Adder295) returns I64 { return f(10) }
    assert_eq(I64, apply(add1), 15)
}

// #295/#262: a struct with a funcptr field, built from a constant-arg
// constructor, must not be mishandled by the const-folder (which folds a
// struct value field by field). Guards the funcptr-field const-fold path.
Thunk295 := func() returns I64
Box295 := struct { t : Thunk295 }
forty_two295 := func() returns I64 { return 42 }
test_funcptr_field_constfold := test() {
    b := Box295(t = forty_two295)
    assert_eq(I64, b.t(), 42)
}
