mode test

test_arithmetic := test() {
    assert_eq(I64, 34.add(35), 69)
    assert_eq(I64, 10.sub(3), 7)
    assert_eq(I64, 6.mul(7), 42)
    assert_eq(I64, 10.div(3), 3)
    assert_eq(I64, 10.mod(3), 1)
    assert_eq(I64, 10.mod(5), 0)
    assert_eq(I64, 42.neg(), -42)

    // Unary minus: -N desugars to 0.sub(N), -expr to expr.neg()
    assert_eq(I64, -1, 0.sub(1))
    assert_eq(I64, -42, 0.sub(42))
    assert_eq(I64, -100, 0.sub(100))
    assert_eq(I64, 10.add(-3), 7)
    assert_eq(I64, -5.add(3), -2)
    assert_eq(I64, -1.neg(), 1)
}

// Issue #255: richer number literals (hex/binary/octal, digit
// separators, exponents).
test_number_literals := test() {
    // Hex / binary / octal integer literals
    assert_eq(I64, 0xff, 255)
    assert_eq(I64, 0xFF, 255)
    assert_eq(I64, 0x10, 16)
    assert_eq(I64, 0b1010, 10)
    assert_eq(I64, 0o17, 15)
    assert_eq(I64, 0o777, 511)

    // Digit separators
    assert_eq(I64, 1_000_000, 1000000)
    assert_eq(I64, 0xff_ff, 65535)
    assert_eq(I64, 0b1000_0001, 129)

    // Negative base-prefixed literals
    assert_eq(I64, -0x10, -16)
    assert_eq(I64, -0b100, -4)

    // Float exponents and separators
    a : F32 = 1e3
    assert_eq(I64, a.to_i64(), 1000)
    b : F32 = 1.5e3
    assert_eq(I64, b.to_i64(), 1500)
    c : F32 = 2_500.0
    assert_eq(I64, c.to_i64(), 2500)

    // Typed contexts: literal must fit / convert
    u : U8 = 0xff
    assert_eq(U8, u, 255)
    w : U32 = 0xdead_beef
    assert_eq(U32, w, 3735928559)
    s : I32 = 0b0001_0000
    assert_eq(I32, s, 16)

    // Str.to_i64 parses the same forms at runtime
    assert_eq(I64, "0x1f".to_i64()!, 31)
    assert_eq(I64, "0b101".to_i64()!, 5)
    assert_eq(I64, "0o17".to_i64()!, 15)
    assert_eq(I64, "1_234".to_i64()!, 1234)
    assert_eq(I64, "-0xff".to_i64()!, -255)
}

test_comparison := test() {
    assert(1.eq(1))
    assert(1.lt(2))
    assert(2.gt(1))
    assert(1.lte(2))
    assert(2.lte(2))
    assert(3.lte(2).not())
    assert(3.gte(2))
    assert(2.gte(2))
    assert(1.gte(2).not())
    assert(1.neq(2))
    assert(2.neq(2).not())
}

test_boolean := test() {
    assert(true.and(true))
    assert(true.and(false).not())
    assert(false.or(false).not())
    assert(false.or(true))
    assert(true.not().not())
    assert(false.not())
}

test_bitwise := test() {
    assert_eq(I64, 6.band(3), 2)
    assert_eq(I64, 6.bor(3), 7)
    assert_eq(I64, 6.bxor(3), 5)
}

test_f32_arithmetic := test() {
    a := 10.to_f32()
    b := 3.to_f32()

    assert_eq(I64, a.add(b).to_i64(), 13)
    assert_eq(I64, a.sub(b).to_i64(), 7)
    assert_eq(I64, a.mul(b).to_i64(), 30)
    assert_eq(I64, a.div(b).to_i64(), 3)

    // Float precision with literals
    x : F32 = 3.14
    assert_eq(Str, x.to_str(), "3.14")

    y : F32 = 2.5
    assert_eq(Str, y.add(y).to_str(), "5")
    assert_eq(Str, y.mul(y).to_str(), "6.25")

    // Comparisons
    assert(a.eq(10))
    assert(a.eq(b).not())
    assert_eq(I64, a.cmp(b), 1)
    assert_eq(I64, b.cmp(a), -1)
    assert_eq(I64, a.cmp(10), 0)

    // Conversions
    assert_eq(USize, F32.size(), 4)
    z : F32 = 7.9
    assert_eq(I64, z.to_i64(), 7)
}

test_mutation := test() {
    mut counter := 0
    counter = 1
    counter++
    assert_eq(I64, counter, 2)
    mut msg : Str = "hello"
    msg = "world"
    assert_eq(Str, msg, "world")
}

// --- Operator syntax tests (#22) ---

test_op_arithmetic := test() {
    assert_eq(I64, 34 + 35, 69)
    assert_eq(I64, 10 - 3, 7)
    assert_eq(I64, 6 * 7, 42)
    assert_eq(I64, 10 / 3, 3)
    assert_eq(I64, 10 % 3, 1)
    assert_eq(I64, 10 % 5, 0)
}

test_op_comparison := test() {
    assert(1 == 1)
    assert(1 < 2)
    assert(2 > 1)
    assert(1 <= 2)
    assert(2 <= 2)
    assert((3 <= 2).not())
    assert(3 >= 2)
    assert(2 >= 2)
    assert((1 >= 2).not())
    assert(1 != 2)
    assert((2 != 2).not())
}

test_op_precedence := test() {
    // * / % bind tighter than + -
    assert_eq(I64, 2 + 3 * 4, 14)
    assert_eq(I64, 10 - 2 * 3, 4)
    assert_eq(I64, 2 * 3 + 4 * 5, 26)

    // Grouping parens override precedence
    assert_eq(I64, (2 + 3) * 4, 20)
    assert_eq(I64, (10 - 2) * 3, 24)

    // Comparison is lower than arithmetic
    assert(2 + 3 == 5)
    assert(10 - 3 > 5)
    assert(2 * 3 < 10)
    assert(10 / 2 >= 5)
    assert(10 % 3 <= 1)
    assert(2 + 3 != 6)
}

test_op_with_variables := test() {
    a := 10
    b := 3
    assert_eq(I64, a + b, 13)
    assert_eq(I64, a - b, 7)
    assert_eq(I64, a * b, 30)
    assert_eq(I64, a / b, 3)
    assert_eq(I64, a % b, 1)
    assert(a > b)
    assert(b < a)
    assert(a != b)
    assert(a == 10)
}

test_op_mixed_with_methods := test() {
    // Operators mixed with method calls
    assert_eq(I64, 5.add(3) * 2, 16)
    assert_eq(I64, (2 + 3).mul(4), 20)
    assert("hello".len().to_i64() == 5)

    // Unary minus with operators
    assert_eq(I64, -1 + 2, 1)
    assert_eq(I64, 10 + -3, 7)

    // Mutation with operators
    mut counter := 0
    counter = counter + 1
    counter = counter + 1
    assert_eq(I64, counter, 2)
}

// --- Bitwise operator syntax tests ---

test_op_bitwise := test() {
    assert_eq(I64, 6 & 3, 2)
    assert_eq(I64, 6 | 3, 7)
    assert_eq(I64, 6 ^ 3, 5)
    assert_eq(I64, 0 & 0, 0)
    assert_eq(I64, 0 | 0, 0)
    assert_eq(I64, 0 ^ 0, 0)
    assert_eq(I64, 255 & 15, 15)
    assert_eq(I64, 240 | 15, 255)
    assert_eq(I64, 255 ^ 255, 0)
}

test_op_bitwise_precedence := test() {
    // & binds tighter than ^ which binds tighter than |
    assert_eq(I64, 7 & 3 ^ 1, 3 ^ 1)
    assert_eq(I64, 7 ^ 3 | 4, (7 ^ 3) | 4)
    assert_eq(I64, 6 & 3 | 4, (6 & 3) | 4)

    // Bitwise is lower than comparison (C-style)
    // 1 == 1 is true(1), then & 1 is 1
    // So (1 == 1) & 1 -- but Bool doesn't have .and(I64)
    // Instead test that arithmetic binds tighter than bitwise
    assert_eq(I64, 2 + 1 & 3, 3 & 3)
    assert_eq(I64, 2 * 3 | 1, 6 | 1)
    assert_eq(I64, 2 * 3 ^ 1, 6 ^ 1)
}

test_op_unary_minus := test() {
    // Unary minus on variables
    a := 42
    assert_eq(I64, -a, 0.sub(42))

    // Unary minus on expressions via grouping
    assert_eq(I64, -(3 + 4), -7)
    assert_eq(I64, -(2 * 5), -10)

    // Double negation
    assert_eq(I64, -(-5), 5)

    // Unary minus with method calls
    b := 10
    assert_eq(I64, -b.add(3), -13)
}

test_op_increment_decrement := test() {
    mut i := 0
    i++
    assert_eq(I64, i, 1)
    i++
    i++
    assert_eq(I64, i, 3)

    i--
    assert_eq(I64, i, 2)
    i--
    i--
    assert_eq(I64, i, 0)

    // Works on other integer types
    mut x : I32 = 10
    x++
    assert_eq(I32, x, 11)
    x--
    assert_eq(I32, x, 10)

    // Works after field access chains
    mut counter := 0
    counter++
    counter++
    counter++
    assert_eq(I64, counter, 3)
}
