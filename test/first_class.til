mode test

import("../src/std/dyn_vec")

// --- Lambda functions: anonymous inline FuncDef literals (issue #61) ---
// A lambda is the same syntax as a named function definition, just
// without a name. Param/return types are explicit (per #58 rule:
// "parameters always require explicit types"). No captures (closures
// are #54).

BinaryOp := func(I64, I64) returns I64
UnaryOp := func(I64) returns I64

apply_binop := func(op: BinaryOp, a: I64, b: I64) returns I64 {
    return op(a, b)
}

apply_unary := func(op: UnaryOp, x: I64) returns I64 {
    return op(x)
}

// --- Lambda as positional FCall argument ---

test_lambda_basic_add := test() {
    assert_eq(__LOC__, apply_binop(func(a: I64, b: I64) returns I64 { return a.add(b) }, 3, 4), 7)
}

test_lambda_basic_mul := test() {
    assert_eq(__LOC__, apply_binop(func(a: I64, b: I64) returns I64 { return a.mul(b) }, 6, 7), 42)
}

test_lambda_distinct_call_sites := test() {
    assert_eq(__LOC__, apply_binop(func(a: I64, b: I64) returns I64 { return a.sub(b) }, 10, 3), 7)
    assert_eq(__LOC__, apply_binop(func(a: I64, b: I64) returns I64 { return a.add(b.mul(2)) }, 1, 5), 11)
}

// --- Lambda as named FCall argument ---

test_lambda_named_arg := test() {
    assert_eq(__LOC__, apply_unary(op = func(x: I64) returns I64 { return x.mul(3) }, x = 4), 12)
}

// --- Lambda nested across multiple FCalls ---

test_lambda_nested_calls := test() {
    inner := apply_unary(func(x: I64) returns I64 { return x.add(1) }, 5)
    assert_eq(__LOC__, inner, 6)
    outer := apply_binop(func(a: I64, b: I64) returns I64 { return a.mul(b) }, inner, 7)
    assert_eq(__LOC__, outer, 42)
}

// --- Lambda as UFCS method-call argument ---

Wrapper := struct {
    val : I64 = 0

namespace:
    apply := func(self: Wrapper, op: UnaryOp) returns I64 {
        return op(self.val)
    }
}

test_lambda_ufcs_method_arg := test() {
    w := Wrapper(val = 6)
    assert_eq(__LOC__, w.apply(func(x: I64) returns I64 { return x.mul(7) }), 42)
}

// --- Lambda as RHS of FuncSig-typed declaration ---

test_lambda_as_value_unary := test() {
    f : UnaryOp = func(x: I64) returns I64 { return x.mul(2) }
    assert_eq(__LOC__, f(7), 14)
    assert_eq(__LOC__, apply_unary(f, 5), 10)
}

test_capturing_lambda_as_value_unary := test() {
    scale := 10
    f : UnaryOp = func(x: I64) returns I64 [scale] { return x.mul(scale) }
    assert_eq(__LOC__, f(7), 70)
    assert_eq(__LOC__, apply_unary(f, 5), 50)
}

test_inferred_capturing_lambda_value_unary := test() {
    scale := 10
    f := func(x: I64) returns I64 [scale] { return x.mul(scale) }
    assert_eq(__LOC__, f(3), 30)
}

test_lambda_as_value_binary := test() {
    g : BinaryOp = func(a: I64, b: I64) returns I64 { return a.add(b) }
    assert_eq(__LOC__, g(3, 4), 7)
    assert_eq(__LOC__, apply_binop(g, 10, 20), 30)
}

// --- Lambda as struct-field default value ---

Handler := struct {
    on_click : BinaryOp = func(a: I64, b: I64) returns I64 { return a.add(b) }
}

test_struct_field_lambda_default := test() {
    h := Handler()
    assert_eq(__LOC__, h.on_click(3, 5), 8)
}

test_struct_field_lambda_ctor := test() {
    h := Handler(on_click = func(a: I64, b: I64) returns I64 { return a.mul(b) })
    assert_eq(__LOC__, h.on_click(4, 6), 24)
}

// --- FuncSig-form lambda (type separated from param names) ---

test_funcsig_form_lambda_unary := test() {
    assert_eq(__LOC__, apply_unary(func(I64) returns I64 = (a) { return a.mul(2) }, 7), 14)
}

test_funcsig_form_lambda_binary := test() {
    assert_eq(__LOC__, apply_binop(func(I64, I64) returns I64 = (a, b) { return a.add(b) }, 3, 4), 7)
}

test_funcsig_form_lambda_as_value := test() {
    f : BinaryOp = func(I64, I64) returns I64 = (a, b) { return a.sub(b) }
    assert_eq(__LOC__, f(10, 3), 7)
}

test_named_funcsig_form_capturing_lambda := test() {
    scale := 10
    f : UnaryOp = (x) [scale] { return x.mul(scale) }
    assert_eq(__LOC__, f(3), 30)
}

// --- FuncSig as first-class Type value (issue #58) ---
// A bodyless `func(...) returns ...` (FuncSig) is a Type alias for
// Type.FuncPtr. Using its name where a Type is expected must round-trip
// to "Fn", not to the function's return type.

fn_add := func(a: I64, b: I64) returns I64 { return a.add(b) }
fn_mul := func(a: I64, b: I64) returns I64 { return a.mul(b) }

test_dyn_type_to_str_funcsig := test() {
    assert_eq_str(__LOC__, "Fn", dyn_type_to_str(BinaryOp))
    assert_eq_str(__LOC__, "Fn", dyn_type_to_str(Type.FuncPtr))
}

test_vec_funcsig_create := test() {
    ops := DynVec.new(BinaryOp)
    assert_eq(__LOC__, ops.len().to_i64(), 0)
}

test_vec_funcsig_push_len := test() {
    mut ops := DynVec.new(BinaryOp)
    ops.push(own fn_add)
    ops.push(own fn_mul)
    assert_eq(__LOC__, ops.len().to_i64(), 2)
}

// Round-trip: push fn_add / fn_mul into a DynVec.new(BinaryOp), pull each
// slot out via a FuncSig-typed ref binding (`ref g : BinaryOp = ops[i]`)
// and call it. The ref-binding reads the slot through
// reinterpret_ptr_value's FuncSig branch -- which only works once the
// FFI bridge round-trips Value.Func through Vec.push without losing the
// pointer (Value.Func cases in ext_dispatch_ffi, issue #58).
test_vec_funcsig_call_through_ref := test() {
    mut ops := DynVec.new(BinaryOp)
    ops.push(own fn_add)
    ops.push(own fn_mul)
    ref g : BinaryOp = ops[0.to_usize()]
    assert_eq(__LOC__, g(3, 4), 7)
    ref h : BinaryOp = ops[1.to_usize()]
    assert_eq(__LOC__, h(3, 4), 12)
}

// Inline `cast(<dyn>, BinaryOp)(args)` -- a fn ptr pulled directly out
// of a typed Vec, cast to the matching FuncSig, and invoked, all in one
// expression (issue #58). Three pieces had to line up: the parser
// accepts a postfix `(args)` on any expression; the typer's cast accepts
// Dynamic -> FuncPtr against the user FuncSig and the outer FCall
// resolves the sig through cast's preserved Ident child; codegen emits
// `(*(void **)slot)` for the dynamic-to-fn-ptr read, then the standard
// indirect-call cast on top.
test_vec_funcsig_cast_call_inline := test() {
    mut ops := DynVec.new(BinaryOp)
    ops.push(own fn_add)
    ops.push(own fn_mul)
    ref raw0 : Dynamic = ops[0.to_usize()]
    ref raw1 : Dynamic = ops[1.to_usize()]
    assert_eq(__LOC__, cast(raw0, BinaryOp)(3, 4), 7)
    assert_eq(__LOC__, cast(raw1, BinaryOp)(3, 4), 12)
}

// --- Explicit FuncDef / FunctionDef metatype annotation (issue #58) ---
// rstil's first_class.org uses `FuncDef` as the metatype name for
// concrete function definitions; til's internal struct is named
// `FunctionDef`. Both names should be accepted for the annotation.

triple_funcdef : FuncDef = func(x: I64) returns I64 { return x.mul(3) }
double_funcdef : FunctionDef = func(x: I64) returns I64 { return x.mul(2) }

test_explicit_funcdef_annotation := test() {
    assert_eq(__LOC__, triple_funcdef(5), 15)
    assert_eq(__LOC__, double_funcdef(7), 14)
}

// --- First-class structs (issue #56), verified-working foundation ---
// StructDef-as-value (Vec(StructDef).new() by value, struct_def_of,
// anonymous struct construction, `func(T) returns T`) is covered below
// alongside the named foundation; `func(T) returns T` (full generics)
// still depends on #58's metatype-reflection foundation.

Point56 := struct {
    x: I64 = 0
    y: I64 = 0
}

// A struct type can be passed where a `Type` parameter is expected and
// round-trips through dyn_type_to_str back to its own name.
type_name_of := func(T: Type) returns Str {
    return dyn_type_to_str(T)
}

test_struct_type_as_type_arg := test() {
    assert_eq_str(__LOC__, "Point56", type_name_of(Point56))
}

// The StructDef metatype round-trips to "StructDef" both as the bare
// type name and via the Type enum variant.
test_structdef_metatype_str := test() {
    assert_eq_str(__LOC__, "StructDef", dyn_type_to_str(StructDef))
    assert_eq_str(__LOC__, "StructDef", dyn_type_to_str(Type.StructDef))
}

// Struct instances (not definitions) are first-class values: storable in
// a Vec keyed on the concrete struct type.
test_vec_of_struct_instances := test() {
    mut points := Vec(Point56).new()
    points.push(own Point56(x=10, y=20))
    points.push(own Point56(x=30, y=40))
    assert_eq(__LOC__, points.len().to_i64(), 2)
}

// --- Anonymous struct instantiation (issue #56) ---
// `struct { ... }(args)` constructs an instance of an inline anonymous
// struct. init lifts the literal to a top-level AnonStructN type, so it
// works in both interpret and compile mode and at function-body scope.

test_anon_struct_ctor := test() {
    p := struct {
        x: I64 = 0
        y: I64 = 0
    }(x=10, y=20)
    assert_eq(__LOC__, p.x, 10)
    assert_eq(__LOC__, p.y, 20)
}

test_anon_struct_defaults := test() {
    q := struct {
        a: I64 = 7
    }()
    assert_eq(__LOC__, q.a, 7)
}

// --- Anonymous enum literals (issue #57) ---
// `enum { ... }.Variant` (and `.Variant(payload)`) reference a variant of
// an inline anonymous enum. init lifts the literal to a top-level
// AnonEnumN type, so it works in both interpret and compile mode.

test_anon_enum_variant := test() {
    c := enum {
        Red, Green, Blue
    }.Green
    assert_eq_str(__LOC__, c.to_str(), "Green")
}

test_anon_enum_payload := test() {
    v := enum {
        Num: I64
        Nothing
    }.Num(42)
    assert_eq_str(__LOC__, v.to_str(), "Num(42)")
}

// Structurally-identical anon literals unify to one generated type, so a
// value built from one literal matches a `switch` case built from another
// -- including payload extraction.
test_anon_enum_switch := test() {
    c := enum { Red, Green, Blue }.Green
    switch c {
    case enum { Red, Green, Blue }.Red:
        assert_eq(__LOC__, 0, 1)
    case enum { Red, Green, Blue }.Green:
        assert(__LOC__, true)
    case enum { Red, Green, Blue }.Blue:
        assert_eq(__LOC__, 0, 1)
    }
}

test_anon_enum_payload_switch := test() {
    v := enum { Num: I64, Nothing }.Num(7)
    mut got := 0
    switch v {
    case enum { Num: I64, Nothing }.Num(x):
        got = x
    case enum { Num: I64, Nothing }.Nothing:
        got = -1
    }
    assert_eq(__LOC__, got, 7)
}

// Conversely, literals that differ observably (here, a field default) stay
// distinct types and keep their own defaults.
test_anon_struct_distinct_defaults := test() {
    a := struct { x: I64 = 1 }()
    b := struct { x: I64 = 2 }()
    assert_eq(__LOC__, a.x, 1)
    assert_eq(__LOC__, b.x, 2)
}

// --- Anonymous defs in type positions (issue #56/#57) ---
// `struct { ... }` / `enum { ... }` may also appear where a type is
// expected (param, return, field, local-decl annotation). The same
// generated type backs a type-position literal and a structurally
// identical value-position one, so a value flows into the annotated slot.

anon_sum_xy := func(p: struct {
    x: I64 = 0
    y: I64 = 0
}) returns I64 {
    return p.x.add(p.y)
}

test_anon_param_type := test() {
    arg := struct {
        x: I64 = 0
        y: I64 = 0
    }(x=3, y=4)
    assert_eq(__LOC__, anon_sum_xy(arg), 7)
}

anon_make_pt := func() returns struct {
    x: I64 = 0
    y: I64 = 0
} {
    return struct {
        x: I64 = 0
        y: I64 = 0
    }(x=5, y=6)
}

test_anon_return_type := test() {
    p := anon_make_pt()
    assert_eq(__LOC__, p.x.add(p.y), 11)
}

// Anon enum as return type. Returning a bare tag-only enum variant used to
// hit a pre-existing compile-mode codegen bug; issue #70's bootstrapping
// fix (0678984) cleared it for both named and anonymous enums.
anon_make_color := func() returns enum { Red, Green, Blue } {
    return enum { Red, Green, Blue }.Green
}

test_anon_enum_return_type := test() {
    assert_eq_str(__LOC__, anon_make_color().to_str(), "Green")
}

anon_name_of := func(c: enum { Red, Green, Blue }) returns Str {
    return c.to_str()
}

test_anon_enum_param_type := test() {
    assert_eq_str(__LOC__, anon_name_of(enum { Red, Green, Blue }.Blue), "Blue")
}

test_anon_local_decl_type := test() {
    p: struct { x: I64 = 0 } = struct { x: I64 = 0 }(x=9)
    assert_eq(__LOC__, p.x, 9)
}

AnonFieldHolder := struct {
    inner: struct { v: I64 = 0 } = struct { v: I64 = 0 }()
}

test_anon_field_type := test() {
    h := AnonFieldHolder(inner = struct { v: I64 = 0 }(v=42))
    assert_eq(__LOC__, h.inner.v, 42)
}

// --- Bare anonymous defs as values (issue #56) ---
// `own struct { ... }` as a call argument resolves to a runtime
// StructDef value (the definition itself, distinct from instantiation
// or type-position usage), built via struct_def_of against the
// underlying generated AnonStructN name. Symmetric for enums via
// enum_def_of. The `own` prefix is the signal that the caller wants
// the definition AS A VALUE; bare `struct { ... }` without `own`
// elsewhere in an arg position remains a type reference for
// introspection-style `func(T: Type)` callees.

test_anon_struct_as_value := test() {
    mut defs := Vec(StructDef).new()
    defs.push(own struct {
        x: I64 = 0
        y: I64 = 0
    })
    defs.push(own struct {
        a: I64 = 0
    })
    assert_eq(__LOC__, defs.len().to_i64(), 2)
}

test_anon_enum_as_value := test() {
    mut enums := Vec(EnumDef).new()
    enums.push(own enum { Red, Green, Blue })
    enums.push(own enum { On, Off })
    assert_eq(__LOC__, enums.len().to_i64(), 2)
}

// --- Anonymous defs as introspection-func args (issue #57/#58) ---
// A bare `struct { ... }` / `enum { ... }` passed as a call argument
// resolves to the underlying generated type name -- so the same
// `func(T: Type)` signature that introspects a named type also accepts
// an inline anonymous one. This also covers the named-type case
// without the previous "keep_alive" workaround: the scavenger now
// follows the `Type.Enum(...)` / `Type.Struct(...)` form that the
// typer rewrites a Type-typed ident into, so the type stays live.

count_variants_of := func(T: Type) returns I64 {
    return enum_variant_count(til_type_name(T))
}

count_fields_of := func(T: Type) returns I64 {
    return struct_field_count(til_type_name(T))
}

NamedColor3 := enum { Red, Green, Blue }

test_named_enum_as_type_arg := test() {
    assert_eq(__LOC__, count_variants_of(NamedColor3), 3)
}

test_anon_enum_as_type_arg := test() {
    assert_eq(__LOC__, count_variants_of(enum { Red, Green, Blue }), 3)
    assert_eq(__LOC__, count_variants_of(enum { A, B, C, D }), 4)
    assert_eq(__LOC__, count_variants_of(enum { X: I64, Y, Z: Str }), 3)
}

test_anon_struct_as_type_arg := test() {
    assert_eq(__LOC__, count_fields_of(struct {
        x: I64 = 0
        y: I64 = 0
    }), 2)
}

// --- Anonymous defs as macro Type-arg (issue #57) ---
// Same shape as the func(T: Type) introspection pattern, but the callee
// is a macro -- it evaluates at compile time. Both named and anonymous
// types resolve through the Type metatype param.

count_variants_macro := macro(T: Type) returns I64 {
    return enum_variant_count(til_type_name(T))
}

NamedColor3M := enum { Red, Green, Blue }

test_named_enum_as_macro_arg := test() {
    assert_eq(__LOC__, count_variants_macro(NamedColor3M), 3)
}

test_anon_enum_as_macro_arg := test() {
    assert_eq(__LOC__, count_variants_macro(enum { Red, Green, Blue }), 3)
    assert_eq(__LOC__, count_variants_macro(enum { A, B, C, D }), 4)
}

// --- Macros as type generators (issue #57) ---
// A macro returning StructDef/EnumDef acts as a generic type generator
// at decl scope: `Pair := make_pair(I64)` desugars to
// `Pair := struct { first: I64 = 0, second: I64 = 0 }`. init expands the
// macro body's return literal with the type-parameters substituted out
// for the call-site args, so the rest of the pipeline treats the Decl
// like any other named struct/enum (constructor, field access, methods).
// Mirrors rstil's macro-returns-StructDef path (precomp.rs ~309).

make_pair := macro(T: Type) returns StructDef {
    return struct {
        first: T = 0
        second: T = 0
    }
}
PairI64 := make_pair(I64)

test_macro_struct_gen := test() {
    p := PairI64(first=3, second=4)
    assert_eq(__LOC__, p.first.add(p.second), 7)
}

make_kv := macro(K: Type, V: Type) returns StructDef {
    return struct {
        key: K = 0
        value: V = 0
    }
}
KVI64Str := make_kv(I64, Str)

test_macro_struct_gen_multi_param := test() {
    kv := KVI64Str(key=42, value="answer")
    assert_eq(__LOC__, kv.key, 42)
    assert_eq_str(__LOC__, kv.value, "answer")
}

make_opt := macro(T: Type) returns EnumDef {
    return enum {
        None
        Some: T
    }
}
OptI64 := make_opt(I64)

test_macro_enum_gen := test() {
    o := OptI64.Some(99)
    assert_eq_str(__LOC__, o.to_str(), "Some(99)")
}

// Issue #243 follow-up: enum-generator macros get the same template type
// substitution into namespace methods as struct-generators. Without
// the FuncDef dispatch in init_subst_enum_params, the method's `val: T`
// and `self: make_pair_enum(T)` stayed as-is and the typer rejected them.
make_pair_enum := macro(T: Type) returns EnumDef {
    return enum {
        Empty
        One: T
    namespace:
        unwrap_or := func(self: make_pair_enum(T), default_v: T) returns T {
            switch self {
            case make_pair_enum(T).One(v): return v
            case: return default_v
            }
        }
    }
}
PairEnumI64 := make_pair_enum(I64)

test_macro_enum_ns_t_and_self := test() {
    assert_eq(__LOC__, PairEnumI64.One(7).unwrap_or(0), 7)
    assert_eq(__LOC__, PairEnumI64.Empty.unwrap_or(42), 42)
}

// --- Issue #56 close-out: macro StructDef + user namespace method.
// The merge with the auto-generated clone/delete is automatic; the
// auto-gen runs on the substituted struct literal and the user
// namespace methods are kept as-is. Symmetric with
// test_macro_enum_ns_t_and_self on the enum side (#57).
make_box56 := macro(T: Type) returns StructDef {
    return struct {
        v: T = 0
    namespace:
        twice := func(self: make_box56(T)) returns T { return self.v.add(self.v) }
    }
}
BoxI64 := make_box56(I64)

test_macro_struct_ns_method := test() {
    b := BoxI64(v = 5)
    assert_eq(__LOC__, b.twice(), 10)
}

// Issue #56 close-out: INFER_TYPE -- a field declared without an
// explicit `: Type` annotation but with a default value pulled from a
// macro arg infers its type from the substituted default.
make_holder56 := macro(N: I64) returns StructDef {
    return struct {
        val := N
    }
}
Holder56 := make_holder56(42)

test_macro_struct_infer_type := test() {
    h := Holder56()
    assert_eq(__LOC__, h.val, 42)
}

// Issue #56 close-out: constfolder of a default-value EXPRESSION inside an
// expanded struct. The default is `N.add(1)` -- after N is substituted,
// the expression evaluates at compile time.
make_sized56 := macro(N: I64) returns StructDef {
    return struct {
        size: I64 = N.add(1)
    }
}
Sized5 := make_sized56(4)

test_macro_struct_constfolder_default := test() {
    s := Sized5()
    assert_eq(__LOC__, s.size, 5)
}

// Issue #57 close-out: reflection helper to count an arbitrary enum's
// variants. `enum_def_of` + `variants.len()` round-trips through the
// registered enum metadata.
Dir57 := enum { N57; S57; E57; W57 }

count_variants57 := func(E: Type) returns I64 {
    name := dyn_type_to_str(E)
    def := enum_def_of(name)
    return def.variants.len().to_i64()
}

test_macro_enum_count_variants := test() {
    assert_eq(__LOC__, count_variants57(Dir57), 4)
}

// --- Function generators (issue #57) ---
// A macro returning FuncDef is the symmetric analog of macros returning
// StructDef / EnumDef: `id_i64 := make_id(I64)` expands to
// `id_i64 := func(x: I64) returns I64 { return x }`. init's pre-pass
// substitutes type-params in the function literal's signature and body,
// then the rest of the pipeline registers the decl as a normal func.

make_id := macro(T: Type) returns FuncDef {
    return func(x: T) returns T { return x }
}

id_i64 := make_id(I64)
id_str := make_id(Str)

test_macro_func_gen_i64 := test() {
    assert_eq(__LOC__, id_i64(42), 42)
}

test_macro_func_gen_str := test() {
    assert_eq_str(__LOC__, id_str("hi"), "hi")
}

// --- Function generators with value-typed params (issue #57) ---
// A macro param like `N: I64` is a regular value, not a type; the
// inliner substitutes Ident(N) inside the function body's expressions
// with a clone of the call-site arg, so `make_adder(5)` bakes the
// literal 5 into the generated function. Type-name explicit_type
// strings (`x: T`) still substitute the receiver's ident name; value
// args leave those strings unchanged.

make_adder := macro(N: I64) returns FuncDef {
    return func(x: I64) returns I64 { return x.add(N) }
}
add5 := make_adder(5)
add100 := make_adder(100)

test_macro_func_gen_value_param := test() {
    assert_eq(__LOC__, add5(3), 8)
    assert_eq(__LOC__, add100(1), 101)
}

make_typed_adder := macro(T: Type, N: I64) returns FuncDef {
    return func(x: T) returns T { return x.add(N) }
}
add_i64_5 := make_typed_adder(I64, 5)

test_macro_func_gen_mixed_params := test() {
    assert_eq(__LOC__, add_i64_5(7), 12)
}

// --- Conditional macro bodies (issue #58) ---
// init's pre-pass evaluates `T.is(Type.<Variant>)` at expand time and
// picks the matching branch's return literal. Else-if chains and bare
// else both work; StructDef / EnumDef / FuncDef returns are all
// supported in every branch.

make_tagged := macro(T: Type) returns StructDef {
    if T.is(Type.Primitive(Primitive.I64)) {
        return struct {
            value: I64 = 0
            tag:   I32 = 1
        }
    } else if T.is(Type.Primitive(Primitive.I32)) {
        return struct {
            value: I64 = 0
            tag:   I32 = 2
        }
    } else {
        return struct {
            value: I64 = 0
            tag:   I32 = 3
        }
    }
}
TaggedI64 := make_tagged(I64)
TaggedI32 := make_tagged(I32)
TaggedF32 := make_tagged(F32)

test_cond_macro_struct_else_if := test() {
    a := TaggedI64(value = 1)
    b := TaggedI32(value = 2)
    c := TaggedF32(value = 3)
    assert_eq(__LOC__, a.tag.cast(I64), 1)
    assert_eq(__LOC__, b.tag.cast(I64), 2)
    assert_eq(__LOC__, c.tag.cast(I64), 3)
}

make_default_fn := macro(T: Type) returns FuncDef {
    if T.is(Type.Primitive(Primitive.I64)) {
        return func() returns I64 { return 42 }
    } else {
        return func() returns I64 { return 0 }
    }
}
answer_fn := make_default_fn(I64)
zero_fn   := make_default_fn(F32)

test_cond_macro_funcdef := test() {
    assert_eq(__LOC__, answer_fn(), 42)
    assert_eq(__LOC__, zero_fn(), 0)
}

make_greeter := macro(name: Str) returns FuncDef {
    return func() returns Str { return name }
}
greeter_hi := make_greeter("hello")

test_macro_func_gen_str_param := test() {
    assert_eq_str(__LOC__, greeter_hi(), "hello")
}

// --- Variant access on enum instance ---
// `v.SomeVariant` where v is an enum instance produces the variant
// constructor / tag value, same as `Opt.Some`. Previously errored in
// interpret mode with "field access on non-struct"; the typer accepted
// it for compile mode via the ns_decls lookup.

OptVAI := enum { None, Some: I64 }

test_enum_instance_variant_access := test() {
    v := OptVAI.Some(42)
    assert(__LOC__, v.is(v.Some))
}

// --- Struct introspection primitives (issue #56/#58) ---
// struct_field_* query a registered struct type's fields by name. The
// queried type must be live in the program (an unused type is DCE'd
// away), so the constructor call in the previous test keeps Point56 alive.

test_struct_field_primitives := test() {
    assert_eq(__LOC__, struct_field_count("Point56"), 2)
    assert_eq_str(__LOC__, "x", struct_field_name("Point56", 0))
    assert_eq_str(__LOC__, "y", struct_field_name("Point56", 1))
    assert_eq(__LOC__, struct_field_is_mut("Point56", 0), 1)
    assert_eq(__LOC__, struct_field_is_mut("Point56", 1), 1)
    assert_eq_str(__LOC__, "I64", struct_field_type("Point56", 0))
}

// --- struct_def_of assembler (issue #56/#58) ---
// Builds a StructDef value from the struct_field_* primitives (in
// src/core/ast.til). Also exercises the #213 fix: returning an owned
// aggregate holding a Vec of structs-with-owned-fields.

test_struct_def_of := test() {
    def := struct_def_of("Point56")
    assert_eq(__LOC__, def.fields.len().to_i64(), 2)
    ref f0 : Declaration = def.fields[0.to_usize()]
    assert_eq_str(__LOC__, "x", f0.name)
    assert_eq_str(__LOC__, "I64", f0.explicit_type)
    expect(__LOC__, f0.is_mut, "f0 is_mut")
    ref f1 : Declaration = def.fields[1.to_usize()]
    assert_eq_str(__LOC__, "y", f1.name)
    assert_eq_str(__LOC__, "I64", f1.explicit_type)
}

// --- Enum introspection primitives (issue #57/#58) ---
// enum_variant_* query a registered enum type's variants by name. Like
// the struct primitives, the type must be live (the switch below keeps
// Shape56 alive). Mixes payload and payload-less variants.

Shape56 := enum {
    Circle: I64,
    Square,
    Label: Str,
}

test_enum_variant_primitives := test() {
    s := Shape56.Square
    expect(__LOC__, s.is(Shape56.Square), "Shape56 stays live")
    assert_eq(__LOC__, enum_variant_count("Shape56"), 3)
    assert_eq_str(__LOC__, "Circle", enum_variant_name("Shape56", 0))
    assert_eq_str(__LOC__, "Square", enum_variant_name("Shape56", 1))
    assert_eq_str(__LOC__, "Label", enum_variant_name("Shape56", 2))
    assert_eq(__LOC__, enum_variant_has_payload("Shape56", 0), 1)
    assert_eq(__LOC__, enum_variant_has_payload("Shape56", 1), 0)
    assert_eq(__LOC__, enum_variant_has_payload("Shape56", 2), 1)
    assert_eq_str(__LOC__, "I64", enum_variant_payload_type("Shape56", 0))
    assert_eq_str(__LOC__, "", enum_variant_payload_type("Shape56", 1))
    assert_eq_str(__LOC__, "Str", enum_variant_payload_type("Shape56", 2))
}

// --- enum_def_of assembler (issue #57/#58) ---
// Builds an EnumDef value from the enum_variant_* primitives.

test_enum_def_of := test() {
    def := enum_def_of("Shape56")
    assert_eq(__LOC__, def.variants.len().to_i64(), 3)
    ref v0 : Str = def.variants[0.to_usize()]
    assert_eq_str(__LOC__, "Circle", v0)
    ref v1 : Str = def.variants[1.to_usize()]
    assert_eq_str(__LOC__, "Square", v1)
    ref v2 : Str = def.variants[2.to_usize()]
    assert_eq_str(__LOC__, "Label", v2)
    ref def_pts : Map(I64, Str) = def.payload_types
    expect(__LOC__, def_pts.has(0), "Circle has payload")
    expect(__LOC__, def_pts.has(1).not(), "Square no payload")
    ref p0 : Str = def_pts[0]
    assert_eq_str(__LOC__, "I64", p0)
    ref p2 : Str = def_pts[2]
    assert_eq_str(__LOC__, "Str", p2)
}

// --- FuncSig introspection primitives (issue #58) ---
// func_sig_* query a registered FuncSig (a bodyless func/proc) for its
// parameter types, return type, and throw types by name. The FuncSig
// must be live (kept so by the real calls below). til funcs have at most
// one return type, so func_sig_return_count is 0 or 1; parameter names
// are not part of a signature, only types.

apply_bin58 := func(op: BinaryOp, a: I64, b: I64) returns I64 { return op(a, b) }
add58 := func(a: I64, b: I64) returns I64 { return a.add(b) }

test_func_sig_primitives := test() {
    assert_eq(__LOC__, apply_bin58(add58, 3, 4), 7)  // keep BinaryOp live
    assert_eq(__LOC__, func_sig_param_count("BinaryOp"), 2)
    assert_eq_str(__LOC__, "I64", func_sig_param_type("BinaryOp", 0))
    assert_eq_str(__LOC__, "I64", func_sig_param_type("BinaryOp", 1))
    assert_eq(__LOC__, func_sig_return_count("BinaryOp"), 1)
    assert_eq_str(__LOC__, "I64", func_sig_return_type("BinaryOp", 0))
    assert_eq(__LOC__, func_sig_throw_count("BinaryOp"), 0)
}

// --- func_sig_of assembler (issue #58) ---
// Builds a FunctionDef (signature) value from the func_sig_* primitives.

test_func_sig_of := test() {
    assert_eq(__LOC__, apply_bin58(add58, 1, 1), 2)  // keep BinaryOp live
    sig := func_sig_of("BinaryOp")
    assert_eq(__LOC__, sig.params.len().to_i64(), 2)
    ref p0 : Declaration = sig.params[0.to_usize()]
    assert_eq_str(__LOC__, "I64", p0.explicit_type)
    ref p1 : Declaration = sig.params[1.to_usize()]
    assert_eq_str(__LOC__, "I64", p1.explicit_type)
    assert_eq_str(__LOC__, "I64", sig.return_type)
    assert_eq(__LOC__, sig.throw_types.len().to_i64(), 0)
}

// --- Direct generic functions: func(T: Type, ...) (issue #58 "Phase now") ---
// A top-level func/proc whose param list uses a `Type`-named param as the
// type of another param (or the return type) is a GENERIC function. It is
// called directly with the type-arg inline -- `gid(I64, 42)` -- and init
// monomorphizes it per distinct type-arg tuple, dropping the type-args at
// the call site and synthesizing one concrete copy per tuple (deduped).
// Distinct from a plain `func(t: Type)` runtime-Type-value param, which is
// left untouched. Distinct from the macro path (`macro(T: Type) returns
// FuncDef`), which requires a separate naming step.

Point58g := struct { x: I64 = 0; y: I64 = 0 }

gid := func(T: Type, v: T) returns T { return v }
gdefault := func(T: Type) returns T { return T() }
gcombine := func(A: Type, B: Type, a: A, b: B) returns A { return a.add(b) }

uses_gid := func(n: I64) returns I64 { return gid(I64, n) }

test_generic_func_identity := test() {
    assert_eq(__LOC__, gid(I64, 42), 42)
}
test_generic_func_constructor := test() {
    p := gdefault(Point58g)
    assert_eq(__LOC__, p.x, 0)
}
test_generic_func_multi_param := test() {
    assert_eq(__LOC__, gcombine(I64, I64, 7, 8), 15)
}
test_generic_func_dedup := test() {
    // Two uses of gid(I64, ..) share one monomorphization.
    assert_eq(__LOC__, gid(I64, 1).add(gid(I64, 2)), 3)
}
test_generic_func_nested_call := test() {
    assert_eq(__LOC__, uses_gid(99), 99)
}

// Composition: a generic func calling another generic func with the
// type-param threaded through. The synthesized body of gid2__I64
// contains `gid(I64, v)` after substitution; the post-substitute walk
// expands that to `gid__I64(v)`, otherwise the typer sees an
// unresolved generic-shaped call.
gid58g := func(T: Type, v: T) returns T { return v }
gid58g_compose := func(T: Type, v: T) returns T { return gid58g(T, v) }

test_generic_func_compose := test() {
    assert_eq(__LOC__, gid58g_compose(I64, 99), 99)
}

// own value-args flow through the generic-call rewrite. The source
// `own a` marker is carried onto the rewritten `store__Item(vec, own a)`
// so the monomorphized callee receives ownership and consumes it
// (pushes into the Vec). ASAN-clean when the callee actually consumes
// the value (a callee that takes `own` and drops it on the floor leaks,
// exactly as a non-generic `own` func would -- that is user error, not
// a monomorphizer bug).
GItem58 := struct { n : USize = 0 }

gstore58 := func(mut into: Vec(GItem58), own v: GItem58) { into.push(own v) }

test_generic_func_own_arg := test() {
    mut vec := Vec(GItem58).new()
    a := GItem58(n = 5)
    gstore58(vec, own a)
    assert_eq(__LOC__, vec.len().to_i64(), 1)
    ref got : GItem58 = vec[0.to_usize()]
    assert_eq(__LOC__, got.n.to_i64(), 5)
}

// Canonical swap (issue #58 example): mut value-args through a generic.
gswap58 := func(T: Type, mut a: T, mut b: T) {
    t := a
    a = b
    b = t
}

test_generic_func_swap := test() {
    mut x := 3
    mut y := 7
    gswap58(I64, x, y)
    assert_eq(__LOC__, x, 7)
    assert_eq(__LOC__, y, 3)
}

// `func<T: Type>(...)` angle-bracket sugar (parser-level): desugars to
// `macro(T: Type) returns FuncDef { return func(...) { ... } }`, mirroring
// how `struct<T: Type> { ... }` desugars to a StructDef-returning macro
// (TemplVec, #267). Reuses parse_generic_params and the existing
// init_hoist_inline_macros / init_expand_type_gen_macros pipeline: the
// inner `gid_angle(I64)` gets lifted to a synthesized monomorphization, so
// the curried call `gid_angle(I64)(7)` resolves to a concrete function
// call -- exactly analogous to `TemplVec(I64).new()`.
gid_angle := func<T: Type>(v: T) returns T { return v }
gswap_angle := func<T: Type>(mut a: T, mut b: T) {
    t := a
    a = b
    b = t
}

test_generic_func_angle_identity := test() {
    assert_eq(__LOC__, gid_angle(I64)(7), 7)
}
test_generic_func_angle_swap := test() {
    mut x := 1
    mut y := 2
    gswap_angle(I64)(x, y)
    assert_eq(__LOC__, x, 2)
    assert_eq(__LOC__, y, 1)
}
