mode test

// --- Lambda functions: anonymous inline FuncDef literals (issue #61) ---
// A lambda is the same syntax as a named function definition, just
// without a name. Param/return types are explicit (per #58 rule:
// "parameters always require explicit types"). No captures (closures
// are #54).

BinaryOp := func(I64, I64) returns I64
UnaryOp := func(I64) returns I64

apply_binop := func(op: BinaryOp, a: I64, b: I64) returns I64 {
    return op(a, b)
}

apply_unary := func(op: UnaryOp, x: I64) returns I64 {
    return op(x)
}

// --- Lambda as positional FCall argument ---

test_lambda_basic_add := test() {
    assert_eq(__LOC__, apply_binop(func(a: I64, b: I64) returns I64 { return a.add(b) }, 3, 4), 7)
}

test_lambda_basic_mul := test() {
    assert_eq(__LOC__, apply_binop(func(a: I64, b: I64) returns I64 { return a.mul(b) }, 6, 7), 42)
}

test_lambda_distinct_call_sites := test() {
    assert_eq(__LOC__, apply_binop(func(a: I64, b: I64) returns I64 { return a.sub(b) }, 10, 3), 7)
    assert_eq(__LOC__, apply_binop(func(a: I64, b: I64) returns I64 { return a.add(b.mul(2)) }, 1, 5), 11)
}

// --- Lambda as named FCall argument ---

test_lambda_named_arg := test() {
    assert_eq(__LOC__, apply_unary(op = func(x: I64) returns I64 { return x.mul(3) }, x = 4), 12)
}

// --- Lambda nested across multiple FCalls ---

test_lambda_nested_calls := test() {
    inner := apply_unary(func(x: I64) returns I64 { return x.add(1) }, 5)
    assert_eq(__LOC__, inner, 6)
    outer := apply_binop(func(a: I64, b: I64) returns I64 { return a.mul(b) }, inner, 7)
    assert_eq(__LOC__, outer, 42)
}

// --- Lambda as UFCS method-call argument ---

Wrapper := struct {
    val : I64 = 0

namespace:
    apply := func(self: Wrapper, op: UnaryOp) returns I64 {
        return op(self.val)
    }
}

test_lambda_ufcs_method_arg := test() {
    w := Wrapper(val = 6)
    assert_eq(__LOC__, w.apply(func(x: I64) returns I64 { return x.mul(7) }), 42)
}

// --- Lambda as RHS of FuncSig-typed declaration ---

test_lambda_as_value_unary := test() {
    f : UnaryOp = func(x: I64) returns I64 { return x.mul(2) }
    assert_eq(__LOC__, f(7), 14)
    assert_eq(__LOC__, apply_unary(f, 5), 10)
}

test_lambda_as_value_binary := test() {
    g : BinaryOp = func(a: I64, b: I64) returns I64 { return a.add(b) }
    assert_eq(__LOC__, g(3, 4), 7)
    assert_eq(__LOC__, apply_binop(g, 10, 20), 30)
}

// --- Lambda as struct-field default value ---

Handler := struct {
    on_click : BinaryOp = func(a: I64, b: I64) returns I64 { return a.add(b) }
}

test_struct_field_lambda_default := test() {
    h := Handler()
    assert_eq(__LOC__, h.on_click(3, 5), 8)
}

test_struct_field_lambda_ctor := test() {
    h := Handler(on_click = func(a: I64, b: I64) returns I64 { return a.mul(b) })
    assert_eq(__LOC__, h.on_click(4, 6), 24)
}

// --- FuncSig-form lambda (type separated from param names) ---

test_funcsig_form_lambda_unary := test() {
    assert_eq(__LOC__, apply_unary(func(I64) returns I64 = (a) { return a.mul(2) }, 7), 14)
}

test_funcsig_form_lambda_binary := test() {
    assert_eq(__LOC__, apply_binop(func(I64, I64) returns I64 = (a, b) { return a.add(b) }, 3, 4), 7)
}

test_funcsig_form_lambda_as_value := test() {
    f : BinaryOp = func(I64, I64) returns I64 = (a, b) { return a.sub(b) }
    assert_eq(__LOC__, f(10, 3), 7)
}

// --- FuncSig as first-class Type value (issue #58) ---
// A bodyless `func(...) returns ...` (FuncSig) is a Type alias for
// Type.FuncPtr. Using its name where a Type is expected must round-trip
// to "Fn", not to the function's return type.

fn_add := func(a: I64, b: I64) returns I64 { return a.add(b) }
fn_mul := func(a: I64, b: I64) returns I64 { return a.mul(b) }

test_dyn_type_to_str_funcsig := test() {
    assert_eq_str(__LOC__, "Fn", dyn_type_to_str(BinaryOp))
    assert_eq_str(__LOC__, "Fn", dyn_type_to_str(Type.FuncPtr))
}

test_vec_funcsig_create := test() {
    ops := Vec.new(BinaryOp)
    assert_eq(__LOC__, ops.len().to_i64(), 0)
}

test_vec_funcsig_push_len := test() {
    mut ops := Vec.new(BinaryOp)
    ops.push(own fn_add)
    ops.push(own fn_mul)
    assert_eq(__LOC__, ops.len().to_i64(), 2)
}

// --- Explicit FuncDef / FunctionDef metatype annotation (issue #58) ---
// rstil's first_class.org uses `FuncDef` as the metatype name for
// concrete function definitions; til's internal struct is named
// `FunctionDef`. Both names should be accepted for the annotation.

triple_funcdef : FuncDef = func(x: I64) returns I64 { return x.mul(3) }
double_funcdef : FunctionDef = func(x: I64) returns I64 { return x.mul(2) }

test_explicit_funcdef_annotation := test() {
    assert_eq(__LOC__, triple_funcdef(5), 15)
    assert_eq(__LOC__, double_funcdef(7), 14)
}

// --- First-class structs (issue #56), verified-working foundation ---
// StructDef-as-value (Vec.new(StructDef) by value, struct_def_of,
// anonymous struct construction, `func(T) returns T`) still depend on
// #58's metatype-reflection foundation and are not yet supported.
// What works today is covered below.

Point56 := struct {
    x: I64 = 0
    y: I64 = 0
}

// A struct type can be passed where a `Type` parameter is expected and
// round-trips through dyn_type_to_str back to its own name.
type_name_of := func(T: Type) returns Str {
    return dyn_type_to_str(T)
}

test_struct_type_as_type_arg := test() {
    assert_eq_str(__LOC__, "Point56", type_name_of(Point56))
}

// The StructDef metatype round-trips to "StructDef" both as the bare
// type name and via the Type enum variant.
test_structdef_metatype_str := test() {
    assert_eq_str(__LOC__, "StructDef", dyn_type_to_str(StructDef))
    assert_eq_str(__LOC__, "StructDef", dyn_type_to_str(Type.StructDef))
}

// Struct instances (not definitions) are first-class values: storable in
// a Vec keyed on the concrete struct type.
test_vec_of_struct_instances := test() {
    mut points := Vec.new(Point56)
    points.push(own Point56(x=10, y=20))
    points.push(own Point56(x=30, y=40))
    assert_eq(__LOC__, points.len().to_i64(), 2)
}

// --- Anonymous struct instantiation (issue #56) ---
// `struct { ... }(args)` constructs an instance of an inline anonymous
// struct. init lifts the literal to a top-level AnonStructN type, so it
// works in both interpret and compile mode and at function-body scope.

test_anon_struct_ctor := test() {
    p := struct {
        x: I64 = 0
        y: I64 = 0
    }(x=10, y=20)
    assert_eq(__LOC__, p.x, 10)
    assert_eq(__LOC__, p.y, 20)
}

test_anon_struct_defaults := test() {
    q := struct {
        a: I64 = 7
    }()
    assert_eq(__LOC__, q.a, 7)
}

// --- Anonymous enum literals (issue #57) ---
// `enum { ... }.Variant` (and `.Variant(payload)`) reference a variant of
// an inline anonymous enum. init lifts the literal to a top-level
// AnonEnumN type, so it works in both interpret and compile mode.

test_anon_enum_variant := test() {
    c := enum {
        Red, Green, Blue
    }.Green
    assert_eq_str(__LOC__, c.to_str(), "Green")
}

test_anon_enum_payload := test() {
    v := enum {
        Num: I64
        Nothing
    }.Num(42)
    assert_eq_str(__LOC__, v.to_str(), "Num(42)")
}

// Structurally-identical anon literals unify to one generated type, so a
// value built from one literal matches a `switch` case built from another
// -- including payload extraction.
test_anon_enum_switch := test() {
    mut c := enum { Red, Green, Blue }.Green
    switch c {
    case enum { Red, Green, Blue }.Red:
        assert_eq(__LOC__, 0, 1)
    case enum { Red, Green, Blue }.Green:
        assert(__LOC__, true)
    case enum { Red, Green, Blue }.Blue:
        assert_eq(__LOC__, 0, 1)
    }
}

test_anon_enum_payload_switch := test() {
    v := enum { Num: I64, Nothing }.Num(7)
    mut got := 0
    switch v {
    case enum { Num: I64, Nothing }.Num(x):
        got = x
    case enum { Num: I64, Nothing }.Nothing:
        got = -1
    }
    assert_eq(__LOC__, got, 7)
}

// Conversely, literals that differ observably (here, a field default) stay
// distinct types and keep their own defaults.
test_anon_struct_distinct_defaults := test() {
    a := struct { x: I64 = 1 }()
    b := struct { x: I64 = 2 }()
    assert_eq(__LOC__, a.x, 1)
    assert_eq(__LOC__, b.x, 2)
}

// --- Anonymous defs in type positions (issue #56/#57) ---
// `struct { ... }` / `enum { ... }` may also appear where a type is
// expected (param, return, field, local-decl annotation). The same
// generated type backs a type-position literal and a structurally
// identical value-position one, so a value flows into the annotated slot.

anon_sum_xy := func(p: struct {
    x: I64 = 0
    y: I64 = 0
}) returns I64 {
    return p.x.add(p.y)
}

test_anon_param_type := test() {
    arg := struct {
        x: I64 = 0
        y: I64 = 0
    }(x=3, y=4)
    assert_eq(__LOC__, anon_sum_xy(arg), 7)
}

anon_make_pt := func() returns struct {
    x: I64 = 0
    y: I64 = 0
} {
    return struct {
        x: I64 = 0
        y: I64 = 0
    }(x=5, y=6)
}

test_anon_return_type := test() {
    p := anon_make_pt()
    assert_eq(__LOC__, p.x.add(p.y), 11)
}

anon_name_of := func(c: enum { Red, Green, Blue }) returns Str {
    return c.to_str()
}

test_anon_enum_param_type := test() {
    assert_eq_str(__LOC__, anon_name_of(enum { Red, Green, Blue }.Blue), "Blue")
}

test_anon_local_decl_type := test() {
    mut p: struct { x: I64 = 0 } = struct { x: I64 = 0 }(x=9)
    assert_eq(__LOC__, p.x, 9)
}

AnonFieldHolder := struct {
    inner: struct { v: I64 = 0 } = struct { v: I64 = 0 }()
}

test_anon_field_type := test() {
    h := AnonFieldHolder(inner = struct { v: I64 = 0 }(v=42))
    assert_eq(__LOC__, h.inner.v, 42)
}

// --- Anonymous defs as introspection-func args (issue #57/#58) ---
// A bare `struct { ... }` / `enum { ... }` passed as a call argument
// resolves to the underlying generated type name -- so the same
// `func(T: Type)` signature that introspects a named type also accepts
// an inline anonymous one. This also covers the named-type case
// without the previous "keep_alive" workaround: the scavenger now
// follows the `Type.Enum(...)` / `Type.Struct(...)` form that the
// typer rewrites a Type-typed ident into, so the type stays live.

count_variants_of := func(T: Type) returns I64 {
    return enum_variant_count(til_type_name(T))
}

count_fields_of := func(T: Type) returns I64 {
    return struct_field_count(til_type_name(T))
}

NamedColor3 := enum { Red, Green, Blue }

test_named_enum_as_type_arg := test() {
    assert_eq(__LOC__, count_variants_of(NamedColor3), 3)
}

test_anon_enum_as_type_arg := test() {
    assert_eq(__LOC__, count_variants_of(enum { Red, Green, Blue }), 3)
    assert_eq(__LOC__, count_variants_of(enum { A, B, C, D }), 4)
    assert_eq(__LOC__, count_variants_of(enum { X: I64, Y, Z: Str }), 3)
}

test_anon_struct_as_type_arg := test() {
    assert_eq(__LOC__, count_fields_of(struct {
        x: I64 = 0
        y: I64 = 0
    }), 2)
}

// --- Struct introspection primitives (issue #56/#58) ---
// struct_field_* query a registered struct type's fields by name. The
// queried type must be live in the program (an unused type is DCE'd
// away), so the constructor call in the previous test keeps Point56 alive.

test_struct_field_primitives := test() {
    assert_eq(__LOC__, struct_field_count("Point56"), 2)
    assert_eq_str(__LOC__, "x", struct_field_name("Point56", 0))
    assert_eq_str(__LOC__, "y", struct_field_name("Point56", 1))
    assert_eq(__LOC__, struct_field_is_mut("Point56", 0), 1)
    assert_eq(__LOC__, struct_field_is_mut("Point56", 1), 1)
    assert_eq_str(__LOC__, "I64", struct_field_type("Point56", 0))
}

// --- struct_def_of assembler (issue #56/#58) ---
// Builds a StructDef value from the struct_field_* primitives (in
// src/core/ast.til). Also exercises the #213 fix: returning an owned
// aggregate holding a Vec of structs-with-owned-fields.

test_struct_def_of := test() {
    def := struct_def_of("Point56")
    assert_eq(__LOC__, def.fields.len().to_i64(), 2)
    ref f0 : Declaration = def.fields.get(0.to_usize())
    assert_eq_str(__LOC__, "x", f0.name)
    assert_eq_str(__LOC__, "I64", f0.explicit_type)
    expect(__LOC__, f0.is_mut, "f0 is_mut")
    ref f1 : Declaration = def.fields.get(1.to_usize())
    assert_eq_str(__LOC__, "y", f1.name)
    assert_eq_str(__LOC__, "I64", f1.explicit_type)
}

// --- Enum introspection primitives (issue #57/#58) ---
// enum_variant_* query a registered enum type's variants by name. Like
// the struct primitives, the type must be live (the switch below keeps
// Shape56 alive). Mixes payload and payload-less variants.

Shape56 := enum {
    Circle: I64,
    Square,
    Label: Str,
}

test_enum_variant_primitives := test() {
    s := Shape56.Square
    expect(__LOC__, s.is(Shape56.Square), "Shape56 stays live")
    assert_eq(__LOC__, enum_variant_count("Shape56"), 3)
    assert_eq_str(__LOC__, "Circle", enum_variant_name("Shape56", 0))
    assert_eq_str(__LOC__, "Square", enum_variant_name("Shape56", 1))
    assert_eq_str(__LOC__, "Label", enum_variant_name("Shape56", 2))
    assert_eq(__LOC__, enum_variant_has_payload("Shape56", 0), 1)
    assert_eq(__LOC__, enum_variant_has_payload("Shape56", 1), 0)
    assert_eq(__LOC__, enum_variant_has_payload("Shape56", 2), 1)
    assert_eq_str(__LOC__, "I64", enum_variant_payload_type("Shape56", 0))
    assert_eq_str(__LOC__, "", enum_variant_payload_type("Shape56", 1))
    assert_eq_str(__LOC__, "Str", enum_variant_payload_type("Shape56", 2))
}

// --- enum_def_of assembler (issue #57/#58) ---
// Builds an EnumDef value from the enum_variant_* primitives.

test_enum_def_of := test() {
    def := enum_def_of("Shape56")
    assert_eq(__LOC__, def.variants.len().to_i64(), 3)
    ref v0 : Str = def.variants.get(0.to_usize())
    assert_eq_str(__LOC__, "Circle", v0)
    ref v1 : Str = def.variants.get(1.to_usize())
    assert_eq_str(__LOC__, "Square", v1)
    ref v2 : Str = def.variants.get(2.to_usize())
    assert_eq_str(__LOC__, "Label", v2)
    expect(__LOC__, def.payload_types.has(0), "Circle has payload")
    expect(__LOC__, def.payload_types.has(1).not(), "Square no payload")
    ref p0 : Str = def.payload_types.get(0)
    assert_eq_str(__LOC__, "I64", p0)
    ref p2 : Str = def.payload_types.get(2)
    assert_eq_str(__LOC__, "Str", p2)
}

// --- FuncSig introspection primitives (issue #58) ---
// func_sig_* query a registered FuncSig (a bodyless func/proc) for its
// parameter types, return type, and throw types by name. The FuncSig
// must be live (kept so by the real calls below). til funcs have at most
// one return type, so func_sig_return_count is 0 or 1; parameter names
// are not part of a signature, only types.

apply_bin58 := func(op: BinaryOp, a: I64, b: I64) returns I64 { return op(a, b) }
add58 := func(a: I64, b: I64) returns I64 { return a.add(b) }

test_func_sig_primitives := test() {
    assert_eq(__LOC__, apply_bin58(add58, 3, 4), 7)  // keep BinaryOp live
    assert_eq(__LOC__, func_sig_param_count("BinaryOp"), 2)
    assert_eq_str(__LOC__, "I64", func_sig_param_type("BinaryOp", 0))
    assert_eq_str(__LOC__, "I64", func_sig_param_type("BinaryOp", 1))
    assert_eq(__LOC__, func_sig_return_count("BinaryOp"), 1)
    assert_eq_str(__LOC__, "I64", func_sig_return_type("BinaryOp", 0))
    assert_eq(__LOC__, func_sig_throw_count("BinaryOp"), 0)
}

// --- func_sig_of assembler (issue #58) ---
// Builds a FunctionDef (signature) value from the func_sig_* primitives.

test_func_sig_of := test() {
    assert_eq(__LOC__, apply_bin58(add58, 1, 1), 2)  // keep BinaryOp live
    sig := func_sig_of("BinaryOp")
    assert_eq(__LOC__, sig.params.len().to_i64(), 2)
    ref p0 : Declaration = sig.params.get(0.to_usize())
    assert_eq_str(__LOC__, "I64", p0.explicit_type)
    ref p1 : Declaration = sig.params.get(1.to_usize())
    assert_eq_str(__LOC__, "I64", p1.explicit_type)
    assert_eq_str(__LOC__, "I64", sig.return_type)
    assert_eq(__LOC__, sig.throw_types.len().to_i64(), 0)
}
