mode test

Token := enum { Num: I64, Name: Str, Eof }

WordBag := struct {
    items := Vec(Str).new()
    namespace:
    eq := func(a: WordBag, b: WordBag) returns Bool {
        if a.items.len().neq(b.items.len()) { return false }
        for i in 0..a.items.len() {
            if a.items[i].eq(b.items[i]).not() { return false }
        }
        return true
    }
    to_str := func(self: WordBag) returns Str {
        return self.items.len().to_str()
    }
}

PayloadBox := enum { Bag: WordBag, Tok: Token, Empty }

test_nested_enum_payload_clone := test() {
    mut b := PayloadBox.Tok(Token.Name("hello"))
    b2 := b.clone()

    b = PayloadBox.Tok(Token.Name("bye"))

    assert_eq(Str, b.to_str(), "Tok(Name(bye))")
    assert_eq(Str, b2.to_str(), "Tok(Name(hello))")
}

test_vec_payload_clone := test() {
    bag := WordBag()
    bag.items.push(own "a")
    bag.items.push(own "b")

    b := PayloadBox.Bag(bag)
    b2 := b.clone()

    switch b {
    case PayloadBox.Bag(bag1):
        bag1.items.set(0, own "x")!
        switch b2 {
        case PayloadBox.Bag(bag2):
            assert_eq(Str, bag1.items[0], "x")
            assert_eq(Str, bag2.items[0], "a")
            assert_eq(USize, bag2.items.len(), 2)
        case:
            UNREACHABLE()
        }
    case:
        UNREACHABLE()
    }
}

// A struct with an INLINE enum field whose payload owns heap (Token.Name's
// Str). The ctor temp used to alias its payload storage into the struct;
// the temp's delete then freed the shared c_str, and the return-in-if
// reclone read freed memory (the interpreter use-after-free that kept
// this file and test/parsing.til compile-only).
TokenHolder := struct {
    t := Token.Eof
}

priv make_holder := func(flag: Bool) returns TokenHolder {
    h := TokenHolder(t = Token.Name("hello world longer string to heap"))
    if flag {
        return h
    }
    return TokenHolder(t = Token.Eof)
}

test_inline_enum_payload_return_in_if := test() {
    x := make_holder(true)
    switch x.t {
    case Token.Name(s):
        assert_eq(Str, s, "hello world longer string to heap")
    case:
        UNREACHABLE()
    }
}

// Field overwrite must free the previous inline payload's nested heap
// (this leaked before write_field released the old payload).
test_inline_enum_payload_overwrite := test() {
    mut h := TokenHolder(t = Token.Name("first heap string payload"))
    h.t = Token.Name("second heap string payload")
    switch h.t {
    case Token.Name(s):
        assert_eq(Str, s, "second heap string payload")
    case:
        UNREACHABLE()
    }
}

// `returns ref` payload alias across a call boundary: mutations through
// the returned ref must land in the STORED payload. The interpreter used
// to deep-clone borrowed return values at every block/call boundary, so
// the parser's `ref sdd = structdef_of(def)` + sdd.push_field writes
// were silently lost (parsed StructDefs read back with 0 fields).
BagHolder := struct {
    pb := PayloadBox.Empty
}

priv bag_of := func(bh: BagHolder) returns ref WordBag {
    switch bh.pb {
    case PayloadBox.Bag(bag):
        return bag
    case:
        UNREACHABLE()
        return NULL
    }
}

test_ref_return_payload_alias := test() {
    bh := BagHolder(pb = PayloadBox.Bag(WordBag()))
    ref wb : WordBag = bag_of(bh)
    wb.items.push(own "added")
    switch bh.pb {
    case PayloadBox.Bag(bag2):
        assert_eq(USize, bag2.items.len(), 1)
        assert_eq(Str, bag2.items[0], "added")
    case:
        UNREACHABLE()
    }
}
