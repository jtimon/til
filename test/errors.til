// ==========================================================
// Array.get throws OutOfBounds (catch-friendly indexed access;
// callers use arr.get(i)! to keep the panic-on-OOB behavior).
// ==========================================================

test_array_get_ok := test() {
    arr := array(I64, 10, 20, 30)
    ref v : I64 = arr.get(1)?
    catch (err: OutOfBounds) {
        assert(false)
    }
    assert(v.eq(20))
}

test_array_get_oob := test() {
    arr := array(I64, 10, 20, 30)
    mut caught := false
    ref _v : I64 = arr.get(99)?
    catch (err: OutOfBounds) {
        caught = true
    }
    assert(caught)
}

// The bang form panics on OOB (same as the old behavior). The
// success path returns the element normally.
test_array_get_bang_ok := test() {
    arr := array(I64, 5, 6, 7)
    ref v : I64 = arr.get(2)!
    assert(v.eq(7))
}

test_vec_get_oob := test() {
    mut v := vec(I64)
    v.push(own 10)
    v.push(own 20)
    mut caught := false
    ref _x : I64 = v.get(99)?
    catch (e: OutOfBounds) {
        caught = e.eq(OutOfBounds())
    }
    assert(caught)
}

// ==========================================================
// Issue #225 prep: statement-level `?`/`!` on method calls.
//
// A free-function call already parsed a trailing `?`/`!` at statement
// position (`f(x)?` works), but a method call did not -- a bare
// `obj.m(args)!` only parsed in expression position. Subscript
// assignment `a[b] = c` lowers to `a.set(b, own c)!`, a throwing
// method call in statement position, so the statement parser must
// accept the suffix. These exercise that shape directly with a
// throwing void method (no subscript involved).
// ==========================================================

StmtThrowError := struct { msg: Str = "" }

StmtThrower := struct {
    n: I64 = 0
namespace:
    bump := func(mut self: StmtThrower, by: I64) throws StmtThrowError {
        if by.lt(0) {
            throw StmtThrowError(msg = "negative bump")
        }
        self.n = self.n.add(by)
    }
}

// `!` on a statement-level method call: no throw on this path, so no
// panic; the call runs to completion.
test_stmt_method_bang_ok := test() {
    mut t := StmtThrower()
    t.bump(5)!
    assert_eq(I64, t.n, 5)
    t.bump(3)!
    assert_eq(I64, t.n, 8)
}

// `?` on a statement-level method call, throw path: the catch runs and
// the statements after the throwing call (inside bump) do not.
test_stmt_method_question_throws := test() {
    mut t := StmtThrower()
    mut caught := false
    mut emsg := ""
    t.bump(-1)?
    catch (err: StmtThrowError) {
        caught = true
        emsg = err.msg
    }
    assert(caught)
    assert(emsg.eq("negative bump"))
    assert_eq(I64, t.n, 0)
}

// `?` on a statement-level method call, success path: the catch is
// skipped and the call's effect is visible.
test_stmt_method_question_ok := test() {
    mut t := StmtThrower()
    mut caught := false
    t.bump(2)?
    catch (err: StmtThrowError) {
        caught = true
    }
    assert(caught.not())
    assert_eq(I64, t.n, 2)
}

// Issue #281: a THROWING helper with a defaulted `loc: Str = __LOC__` reports
// the CALLER's location in its thrown error, not the helper's own definition
// line. This is the issue's primary payoff (cf. Vec.get's OutOfBounds), proven
// on a user helper: a defaulted param now works on a throwing function -- its
// synthetic _err_* out-params are injected before the trailing default so they
// still line up positionally (append_err_out_params).
LocCheckErr := struct { msg := "" }

guard_nonneg := func(x: I64, loc: Str = __LOC__) returns I64 throws LocCheckErr {
    if x.lt(0) {
        throw LocCheckErr(msg = format(loc, ": negative input"))
    }
    return x
}

test_throwing_helper_reports_caller := test() {
    mut caught := ""
    cl := __LINE__
    guard_nonneg(-5)?
    catch (e: LocCheckErr) {
        caught = e.msg.clone()
    }
    // The throwing call is the line right after cl's capture.
    call_line := cl.add(1)
    expect(caught.find("errors.til").neq(-1),
           "throwing helper error names the CALLER file, not its own")
    expect(caught.find(format(":", call_line.to_str(), ":")).neq(-1),
           "throwing helper error points at the CALL line, not guard_nonneg's def")
    expect(caught.find("negative input").neq(-1), "carries the formatted message")

    // Success path returns normally (no throw); '!' handles the throws clause.
    ok := guard_nonneg(7)!
    assert_eq(I64, ok, 7)
}

// Issue #201 (throw-lowering): a throwing function may declare locals AFTER a
// guarded throw and use them across later statements. The lowering guards the
// whole post-throw remainder with ONE `if _err_kind == 0` block; the old bug
// wrapped each statement in its own guard, scoping every post-throw local to
// its own block, so `acc` / `doubled` below were "undefined" on the next line.
post_guard_locals := func(x: I64) returns I64 throws OutOfBounds {
    if x.lt(0) {
        throw OutOfBounds()
    }
    mut acc : I64 = x
    acc = acc.add(10)
    doubled := acc.mul(2)
    return doubled
}

test_throw_post_guard_locals := test() {
    // Success path: locals declared after the guarded throw compute, flow
    // into one another, then into the return.
    ok := post_guard_locals(4)!
    assert_eq(I64, ok, 28)

    // Error path: the guarded throw still fires and is catchable.
    mut caught := false
    post_guard_locals(-1)?
    catch (e: OutOfBounds) { caught = true }
    assert(caught)
}
