mode test

// Issue #198: throw/catch error handling, rstil-style.
// Lowering lives in the typer so the interpreter and builder both
// run these without any new error-handling code paths.

AAAError := struct {}

test_simplest_catch := test() {
    mut catched := false
    if I64.eq(1, 1) {
        throw AAAError()
    }
    assert(false)  // unreachable on the error path
    catch (err: AAAError) {
        catched = true
    }
    assert(catched)
}

// A fieldless catch binding is constructed only in the taken arm. This keeps
// ordinary catches tag-only while preserving source-level values when used.
test_fieldless_catch_binding := test() {
    mut catched := false
    throw AAAError()
    catch (err: AAAError) {
        assert(err.eq(AAAError()))
        catched = true
    }
    assert(catched)
}

make_fieldless_error := func(mut calls: I64) returns AAAError {
    calls++
    return AAAError()
}

// A non-constructor fieldless throw expression must still run exactly once;
// its owned empty result is discarded on the throw path rather than leaked.
test_fieldless_throw_expression := test() {
    mut calls := 0
    mut catched := false
    throw make_fieldless_error(calls)
    catch (err: AAAError) {
        catched = true
    }
    assert(catched)
    assert_eq(I64, calls, 1)
}

ErrorWithMessage := struct {
    msg: Str = "default error message"
}

mixed_throw := func(empty: Bool) throws AAAError, ErrorWithMessage {
    if empty { throw AAAError() }
    throw ErrorWithMessage(msg = "rich error")
}

test_mixed_fieldless_and_payload_errors := test() {
    mut caught_empty := false
    mut caught_rich := ""
    mixed_throw(true)?
    catch (empty: AAAError) {
        caught_empty = empty.eq(AAAError())
    }
    catch (rich: ErrorWithMessage) {
        caught_rich = rich.msg
    }
    assert(caught_empty)
    assert(caught_rich.eq(""))

    mixed_throw(false)?
    catch (empty: AAAError) {
        caught_empty = empty.eq(AAAError())
    }
    catch (rich: ErrorWithMessage) {
        caught_rich = rich.msg
    }
    assert(caught_rich.eq("rich error"))
}

test_catch_with_fields := test() {
    mut caught_msg := ""
    mut catched := false
    if I64.eq(1, 1) {
        my_error := ErrorWithMessage()
        throw my_error
    }
    catch (err: ErrorWithMessage) {
        caught_msg = err.msg
        catched = true
    }
    assert(catched)
    assert(caught_msg.eq("default error message"))
}

// DivideByZero is defined in src/core/i64.til alongside I64.safe_div.

unsafe_div := func(a: I64, b: I64) returns I64 {
    result := a.safe_div(b)?
    catch (err: DivideByZero) {
        return 0
    }
    return result
}

test_unsafe_div := test() {
    assert(unsafe_div(42, 0).eq(0))
    assert(unsafe_div(42, 2).eq(21))
}

// Issue #281 follow-up: safe_div now reports the caller. DivideByZero gained a
// msg field and safe_div a defaulted loc, so a divide-by-zero names the CALL
// site, not i64.til's throw line -- consistent with safe_add/sub/mul.
test_safe_div_reports_caller := test() {
    mut caught := ""
    cl := __LINE__
    _ := I64.safe_div(1, 0)?
    catch (e: DivideByZero) {
        caught = e.msg.clone()
    }
    call_line := cl.add(1)
    expect(caught.find("errors.til").neq(-1),
           "safe_div DivideByZero names the CALLER file, not i64.til")
    expect(caught.find(format(":", call_line.to_str(), ":")).neq(-1),
           "safe_div DivideByZero points at the CALL line, not i64.til's throw")
    expect(caught.find("safe_div").neq(-1), "carries the safe_div message")
}

test_catch_str_error := test() {
    mut caught := false
    mut error_msg := ""
    if I64.eq(1, 1) {
        throw "This is a test error message"
    }
    catch (err: Str) {
        caught = true
        error_msg = err
    }
    assert(caught)
    assert(error_msg.eq("This is a test error message"))
}

test_catch_error_with_str_field := test() {
    mut caught := false
    mut caught_msg := ""
    if I64.eq(1, 1) {
        mut my_error := ErrorWithMessage()
        my_error.msg = "Custom error message"
        throw my_error
    }
    catch (err: ErrorWithMessage) {
        caught = true
        caught_msg = err.msg
    }
    assert(caught)
    assert(caught_msg.eq("Custom error message"))
}

// ==========================================================
// Bug #34 regression: code AFTER catch runs in both paths;
// code BETWEEN throwing call and catch is skipped on error.
// ==========================================================

Bug34Error := struct {
    msg: Str = ""
}

bug34_maybe_throw := func(should_throw: Bool) throws Bug34Error {
    if should_throw {
        throw Bug34Error()
    }
}

test_bug34_after_catch_success := test() {
    mut after_catch_ran := false
    bug34_maybe_throw(false)?
    catch (err: Bug34Error) {
    }
    after_catch_ran = true
    assert(after_catch_ran)
}

test_bug34_after_catch_error := test() {
    mut after_catch_ran := false
    bug34_maybe_throw(true)?
    catch (err: Bug34Error) {
    }
    after_catch_ran = true
    assert(after_catch_ran)
}

test_bug34_between_throw_and_catch := test() {
    mut caught := false
    bug34_maybe_throw(true)?
    caught = false  // should NOT run on error path
    catch (err: Bug34Error) {
        caught = true
    }
    assert(caught)
}

test_bug34_between_success := test() {
    mut between_ran := false
    mut caught := false
    bug34_maybe_throw(false)?
    between_ran = true
    catch (err: Bug34Error) {
        caught = true
    }
    assert(caught.not())
    assert(between_ran)
}

// ==========================================================
// Multi-catch tests
// ==========================================================

TestErrorA := struct {}
TestErrorB := struct {}

throw_a_maybe := func(should_throw: Bool) throws TestErrorA {
    if should_throw {
        throw TestErrorA()
    }
}

throw_b_maybe := func(should_throw: Bool) throws TestErrorB {
    if should_throw {
        throw TestErrorB()
    }
}

test_non_consecutive_catches := test() {
    mut after_a_ran := false
    mut after_b_ran := false
    mut caught_a := false
    mut caught_b := false

    throw_a_maybe(true)?
    after_a_ran = true
    catch (err: TestErrorA) {
        caught_a = true
    }

    throw_b_maybe(true)?
    after_b_ran = true
    catch (err: TestErrorB) {
        caught_b = true
    }

    assert(after_a_ran.not())
    assert(after_b_ran.not())
    assert(caught_a)
    assert(caught_b)
}

MultiThrowError := struct {}

multi_throw_maybe := func(should_throw: Bool) throws MultiThrowError {
    if should_throw {
        throw MultiThrowError()
    }
}

test_multi_throw_single_catch := test() {
    mut after_first_ran := false
    mut after_second_ran := false
    mut caught := false

    multi_throw_maybe(true)?
    after_first_ran = true
    multi_throw_maybe(false)?
    after_second_ran = true
    catch (err: MultiThrowError) {
        caught = true
    }

    assert(after_first_ran.not())
    assert(after_second_ran.not())
    assert(caught)
}

test_multi_throw_success := test() {
    mut after_first_ran := false
    mut after_second_ran := false
    mut caught := false

    multi_throw_maybe(false)?
    after_first_ran = true
    multi_throw_maybe(false)?
    after_second_ran = true
    catch (err: MultiThrowError) {
        caught = true
    }

    assert(after_first_ran)
    assert(after_second_ran)
    assert(caught.not())
}

// ==========================================================
// Caller/callee with different throws sets
// ==========================================================

CallerCalleeErrorA := struct {}
CallerCalleeErrorB := struct {}

callee2_throws_both := func(throw_a: Bool, throw_b: Bool) throws CallerCalleeErrorA, CallerCalleeErrorB {
    if throw_b {
        throw CallerCalleeErrorB()
    }
    if throw_a {
        throw CallerCalleeErrorA()
    }
}

callee1_throws_a_only := func(throw_a: Bool, throw_b: Bool) returns Bool throws CallerCalleeErrorA {
    mut caught_b := false
    callee2_throws_both(throw_a, throw_b)?
    catch (err: CallerCalleeErrorB) {
        caught_b = true
    }
    return caught_b
}

test_caller_callee_different_throws := test() {
    caught_b_internally := callee1_throws_a_only(false, true)?
    catch (err: CallerCalleeErrorA) {
    }
    assert(caught_b_internally)

    mut after_callee1_ran := false
    mut caught_a := false
    _ := callee1_throws_a_only(true, false)?
    after_callee1_ran = true
    catch (err: CallerCalleeErrorA) {
        caught_a = true
    }
    assert(after_callee1_ran.not())
    assert(caught_a)
}

// ==========================================================
// Issue #202: bang operator -- panic-on-throw shorthand
// ==========================================================

bang_throws := func(should_throw: Bool) returns I64 throws CallerCalleeErrorA {
    if should_throw {
        throw CallerCalleeErrorA()
    }
    return 42
}

// Success path: bang on a call that doesn't throw returns normally.
test_bang_success := test() {
    result := bang_throws(false)!
    assert(result.eq(42))
}

// Bang inside a Return: hoisted to a temp so the catch+panic
// executes BEFORE the return statement, otherwise unreachable.
bang_return_wrapper := func(x: Bool) returns I64 throws CallerCalleeErrorA {
    return bang_throws(x)!
}

test_bang_in_return := test() {
    result := bang_return_wrapper(false)!
    assert(result.eq(42))
}

// Nested-bang positions: bang inside an arg or method-chain receiver
// gets hoisted into a temp before the enclosing statement. Without
// hoisting these would slip past the stmt-level handler and trip the
// typer's arity check on the lowered throwing-call signature.
test_bang_nested_in_arg := test() {
    // bang inside an FCall arg
    assert(bang_throws(false)!.eq(42))
}

test_bang_nested_in_chain := test() {
    // bang on the receiver of a method chain
    s := bang_throws(false)!.to_str()
    assert(s.eq("42"))
}

test_bang_inside_bang := test() {
    // outer bang on a call whose arg is itself a bang
    inner := bang_throws(false)!
    outer := bang_return_wrapper(false)!
    assert(inner.eq(42))
    assert(outer.eq(42))
}

// ==========================================================
// Issue #201: built-in safe_* methods on numeric types
// ==========================================================

// F32.safe_div (reuses DivideByZero from src/core/i64.til)
test_f32_safe_div_ok := test() {
    result := F32.safe_div(F32.from_i64(10), F32.from_i64(2))?
    catch (err: DivideByZero) {
        assert(false)
    }
    assert(result.eq(F32.from_i64(5)))
}

test_f32_safe_div_zero := test() {
    mut caught := false
    _ := F32.safe_div(F32.from_i64(10), F32.from_i64(0))?
    catch (err: DivideByZero) {
        caught = true
    }
    assert(caught)
}

test_f32_safe_div_ufcs := test() {
    mut caught := false
    _ := F32.from_i64(10).safe_div(F32.from_i64(0))?
    catch (err: DivideByZero) {
        caught = true
    }
    assert(caught)
}

// ==========================================================
// Issue #201: I64.safe_add / safe_sub / safe_mul
// ==========================================================

MAX_I64_LIT : I64 = 9223372036854775807
// MIN_I64 is derived inside the underflow tests from a `mut`
// local, not from MAX_I64_LIT directly: folding a const
// `MAX_I64_LIT.neg().sub(1)` to INT64_MIN trips an interpreter
// constant-folding quirk (stringifying INT64_MIN). A mut local
// is not const-folded, so the value is computed at runtime.

test_i64_safe_add_ok := test() {
    result := 2.safe_add(3)?
    catch (err: IntegerOverflow) {
        assert(false)
    }
    assert(result.eq(5))
}

test_i64_safe_add_overflow := test() {
    mut caught := false
    mut emsg := ""
    _ := MAX_I64_LIT.safe_add(1)?
    catch (err: IntegerOverflow) {
        caught = true
        emsg = err.msg
    }
    assert(caught)
    assert(emsg.contains("I64.safe_add"))
}

test_i64_safe_add_underflow := test() {
    mut caught := false
    mut mx : I64 = 9223372036854775807
    min_i64 := mx.neg().sub(1)
    _ := min_i64.safe_add(-1)?
    catch (err: IntegerOverflow) {
        caught = true
    }
    assert(caught)
}

test_i64_safe_sub_ok := test() {
    result := 10.safe_sub(3)?
    catch (err: IntegerOverflow) {
        assert(false)
    }
    assert(result.eq(7))
}

test_i64_safe_sub_underflow := test() {
    mut caught := false
    mut emsg := ""
    mut mx : I64 = 9223372036854775807
    min_i64 := mx.neg().sub(1)
    _ := min_i64.safe_sub(1)?
    catch (err: IntegerOverflow) {
        caught = true
        emsg = err.msg
    }
    assert(caught)
    assert(emsg.contains("I64.safe_sub"))
}

test_i64_safe_sub_overflow := test() {
    mut caught := false
    _ := MAX_I64_LIT.safe_sub(-1)?
    catch (err: IntegerOverflow) {
        caught = true
    }
    assert(caught)
}

test_i64_safe_mul_ok := test() {
    result := 7.safe_mul(6)?
    catch (err: IntegerOverflow) {
        assert(false)
    }
    assert(result.eq(42))
}

test_i64_safe_mul_overflow := test() {
    mut caught := false
    mut emsg := ""
    _ := MAX_I64_LIT.safe_mul(2)?
    catch (err: IntegerOverflow) {
        caught = true
        emsg = err.msg
    }
    assert(caught)
    assert(emsg.contains("I64.safe_mul"))
}

