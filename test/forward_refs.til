mode test

// forward reference: call a function defined later
test_forward_func := test() {
    assert_eq(__LOC__, I64, fwd_double(5), 10)
}

fwd_double := func(n: I64) returns I64 {
    return n.mul(2)
}

fwd_factorial := func(n: I64) returns I64 {
    if n.lte(1) { return 1 }
    return n.mul(fwd_factorial(n.sub(1)))
}

test_recursion := test() {
    assert_eq(__LOC__, I64, fwd_factorial(5), 120)
    assert_eq(__LOC__, I64, fwd_factorial(1), 1)
    assert_eq(__LOC__, I64, fwd_factorial(0), 1)
}

fwd_is_even := func(n: I64) returns Bool {
    if n.eq(0) { return true }
    return fwd_is_odd(n.sub(1))
}

fwd_is_odd := func(n: I64) returns Bool {
    if n.eq(0) { return false }
    return fwd_is_even(n.sub(1))
}

test_mutual_recursion := test() {
    assert(__LOC__, fwd_is_even(0))
    assert(__LOC__, fwd_is_odd(0).not())
    assert(__LOC__, fwd_is_odd(1))
    assert(__LOC__, fwd_is_even(4))
    assert(__LOC__, fwd_is_odd(7))
}

fwd_make_point := func(x: I64, y: I64) returns FwdPoint {
    return FwdPoint(x=x, y=y)
}

FwdPoint := struct {
    x := 0
    y := 0
}

test_forward_struct := test() {
    p := fwd_make_point(3, 7)
    assert_eq(__LOC__, I64, p.x, 3)
    assert_eq(__LOC__, I64, p.y, 7)
}

// #165: type alias to a builtin primitive declared at the very top of the
// file -- before any usage. Pinned by c4b8064 (alias NotFound case
// registers when target is a builtin primitive). Mirrors the USize := U32
// pattern in src/core/usize.til.
FwdAliasTop := U32

FwdAliasTopHolder := struct {
    count : FwdAliasTop = 0
namespace:
    inc := func(mut self: FwdAliasTopHolder) {
        self.count = self.count.add(1)
    }
}

test_alias_top_of_file := test() {
    mut h := FwdAliasTopHolder()
    h.inc()
    h.inc()
    h.inc()
    assert_eq(__LOC__, USize, h.count, 3)
}

// #165: type alias declared *after* a struct that uses it as a field type.
// In-file source order should not matter for type aliases to builtin
// primitives.
FwdAliasBottomHolder := struct {
    value : FwdAliasBottom = 0
namespace:
    set := func(mut self: FwdAliasBottomHolder, v: FwdAliasBottom) {
        self.value = v
    }
}

FwdAliasBottom := U32

test_alias_bottom_of_file := test() {
    mut h := FwdAliasBottomHolder()
    h.set(42)
    assert_eq(__LOC__, I64, h.value.to_i64(), 42)
}
