mode script

// Negative test (issue #54): the typer validates function captures the
// same way as block captures. Capturing an immutable local with `mut` is
// an error, and a closure body may only reference its captured outer
// locals.
main := proc() {
    total := 0
    other := 9
    // `total` is immutable: capturing it as `mut` is rejected.
    g := func(x: I64) returns I64 [mut total] { return x.add(total) }
    // `other` is not captured: the body may not reference it.
    h := func(x: I64) returns I64 [total] { return x.add(other) }
    println(g(2).to_str())
    println(h(2).to_str())
}
