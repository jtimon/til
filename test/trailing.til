mode test

// #60: Trailing commas anywhere they make sense

// Trailing comma in enum variants
Color := enum {
    Red,
    Green,
    Blue,
}

// Trailing comma in struct fields + constructor
Point := struct {
    mut x := 0
    mut y := 0
}

// Trailing comma in func params
add := func(a: I64, b: I64,) returns I64 {
    return a.add(b)
}

test_trailing_call := test() {
    // Trailing comma in function call args
    assert_eq(__LOC__, add(1, 2,), 3)
}

test_trailing_method := test() {
    // Trailing comma in method call args
    x := 10
    assert_eq(__LOC__, x.add(5,), 15)
}

test_trailing_enum := test() {
    assert_eq_str(__LOC__, Color.Red.to_str(), "Red")
    assert_eq_str(__LOC__, Color.Blue.to_str(), "Blue")
}

test_trailing_struct := test() {
    // Trailing comma in struct constructor
    p := Point(x = 3, y = 4,)
    assert_eq(__LOC__, p.x, 3)
    assert_eq(__LOC__, p.y, 4)
}
