mode test

// Issue #251: interfaces are named bags of method signatures that desugar
// to a fieldless struct. A method signature is written
// `func(...) returns T {}` -- a func/proc with an empty body, consistent
// with ext_func/ext_proc declarations. Phase 1: an interface is a usable,
// empty type; it does not yet check conformance or dispatch dynamically.
// These tests pin down that interfaces compile end-to-end (interpret AND
// build) and are usable as types. The rejection cases (illegal
// implementation / non-func member) live in test/typer_errors.til.

// Collection: the get/len contract that `for ... in` relies on (Range and
// Vec already satisfy it). A `namespace:` marker inside an interface is a
// redundant no-op -- exercised here to confirm it is accepted, not an error.
Collection := interface {
    get := func(self: Collection, i: U32) returns Dynamic {}
namespace:
    len := func(self: Collection) returns USize {}
}

// A second interface with unrelated methods, to confirm more than one
// interface type compiles.
Drawable := interface {
    draw := func(self: Drawable) returns Str {}
}

// Usable as a parameter type ...
collection_tag := func(_c: Collection) returns I64 {
    return 7
}

// ... and the value can be passed on through another call.
relay := func(c: Collection) returns I64 {
    return collection_tag(c)
}

drawable_tag := func(_d: Drawable) returns I64 {
    return 9
}

test_interface_usable_as_param_type := test() {
    assert_eq(__LOC__, collection_tag(Collection()), 7)
}

test_interface_value_passed_through := test() {
    assert_eq(__LOC__, relay(Collection()), 7)
}

test_second_interface_type := test() {
    assert_eq(__LOC__, drawable_tag(Drawable()), 9)
}
