mode test

// Issue #251: an interface is an abstract-class-like contract that desugars
// to a fieldless struct. A member is either ABSTRACT -- declared with
// `ext_func`/`ext_proc` and an empty `{}` body, to be provided by
// conforming types -- or a CONCRETE default -- an ordinary `func`/`proc`
// with a real body, supplied by the interface itself. No fields, no
// `namespace:` marker. The rejection cases live in test/typer_errors.til.
// These tests pin down that interfaces compile end-to-end (interpret AND
// build) and that concrete defaults are callable.

// Collection: the get/len contract that `for ... in` relies on -- both
// abstract.
Collection := interface {
    get := ext_func(self: Collection, i: U32) returns Dynamic {}
    len := ext_func(self: Collection) returns USize {}
}

// Drawable: an abstract method plus two concrete defaults. `label` ignores
// self; `describe` calls the abstract `self.draw()`, so once copied into an
// implementer (#268) it dispatches to that implementer's own draw.
Drawable := interface {
    draw := ext_func(self: Drawable) returns Str {}
    label := func(_self: Drawable) returns Str { return "shape" }
    describe := func(self: Drawable) returns Str { return self.draw() }
}

// Circle conforms to Drawable: it provides the abstract `draw`. The typer
// verifies this at the struct definition; the interface's `self: Drawable`
// matches `self: Circle` by Self-substitution.
Circle := struct implements Drawable {
    r := 1
namespace:
    draw := func(_self: Circle) returns Str { return "circle" }
}

// An enum conforms to an interface exactly as a struct does: it carries
// methods in its namespace, so it provides the abstract `draw` there and the
// typer verifies it (Self-substitution maps `self: Drawable` to `self:
// Polygon`).
Polygon := enum implements Drawable {
    Tri,
    Quad,
namespace:
    draw := func(_self: Polygon) returns Str { return "polygon" }
}

// Labeled provides the abstract `draw` AND defines its own `label`, which
// overrides the interface default -- the copy must keep Labeled's version.
// It does not define `describe`, so it still inherits that default.
Labeled := struct implements Drawable {
    n := 0
namespace:
    draw := func(_self: Labeled) returns Str { return "labeled" }
    label := func(_self: Labeled) returns Str { return "custom" }
}

// Usable as a parameter type ...
collection_tag := func(_c: Collection) returns I64 {
    return 7
}

// ... and the value can be passed on through another call.
relay := func(c: Collection) returns I64 {
    return collection_tag(c)
}

drawable_tag := func(_d: Drawable) returns I64 {
    return 9
}

test_interface_usable_as_param_type := test() {
    assert_eq(__LOC__, collection_tag(Collection()), 7)
}

test_interface_value_passed_through := test() {
    assert_eq(__LOC__, relay(Collection()), 7)
}

test_second_interface_type := test() {
    assert_eq(__LOC__, drawable_tag(Drawable()), 9)
}

// A concrete default method is a real, callable implementation.
test_interface_concrete_default_method := test() {
    d := Drawable()
    assert_eq_str(__LOC__, d.label(), "shape")
}

// A conforming struct compiles and its provided method is callable.
test_implements_conformance := test() {
    c := Circle(r = 2)
    assert_eq_str(__LOC__, c.draw(), "circle")
}

// A conforming enum compiles and its provided method is callable.
test_enum_implements_conformance := test() {
    p := Polygon.Tri
    assert_eq_str(__LOC__, p.draw(), "polygon")
}

// #268: the interface's concrete default is copied into the implementer's
// namespace, so it is callable directly on the concrete value -- for both a
// struct and an enum.
test_struct_inherits_default := test() {
    c := Circle(r = 1)
    assert_eq_str(__LOC__, c.label(), "shape")
}

test_enum_inherits_default := test() {
    p := Polygon.Quad
    assert_eq_str(__LOC__, p.label(), "shape")
}

// #268: a default that calls an abstract method (`self.draw()`) dispatches to
// the implementer's own method, because Self was substituted on copy.
test_default_calls_self_method := test() {
    c := Circle(r = 1)
    assert_eq_str(__LOC__, c.describe(), "circle")
    p := Polygon.Tri
    assert_eq_str(__LOC__, p.describe(), "polygon")
}

// #268: a type that defines its own copy of a default method overrides it;
// methods it does not define are still inherited.
test_default_override := test() {
    l := Labeled(n = 1)
    assert_eq_str(__LOC__, l.label(), "custom")
    assert_eq_str(__LOC__, l.describe(), "labeled")
}

// #269: dynamic dispatch. An interface-typed parameter accepts any
// conforming value -- the typer boxes it with the concrete type's name --
// and an abstract-method call on it dispatches to the RUNTIME type's
// implementation via the dyn_call machinery, in both backends.
render := func(d: Drawable) returns Str {
    return d.draw()
}

test_dispatch_struct := test() {
    c := Circle(r = 1)
    assert_eq_str(__LOC__, render(c), "circle")
    l := Labeled(n = 1)
    assert_eq_str(__LOC__, render(l), "labeled")
}

test_dispatch_enum := test() {
    p := Polygon.Tri
    assert_eq_str(__LOC__, render(p), "polygon")
}

// #269: a concrete default called through the interface value stays a
// static call to the interface's implementation, but an abstract call
// INSIDE it (describe's body calls self.draw()) dispatches to the boxed
// concrete type.
describe_of := func(d: Drawable) returns Str {
    return d.describe()
}

test_default_through_iface_dispatches := test() {
    c := Circle(r = 1)
    assert_eq_str(__LOC__, describe_of(c), "circle")
}

// #251 follow-up: a conforming concrete bound to an interface-typed LOCAL
// (`d : Drawable = c`) boxes exactly like an interface-typed argument, and an
// abstract-method call on that local dispatches to the runtime type -- a
// struct (Circle) and an enum (Polygon). The borrow is sound: the source
// local is declared first, so it outlives the interface-typed binding.
test_local_binding_dispatch := test() {
    c := Circle(r = 1)
    d : Drawable = c
    assert_eq_str(__LOC__, d.draw(), "circle")
    p := Polygon.Tri
    pd : Drawable = p
    assert_eq_str(__LOC__, pd.draw(), "polygon")
}
