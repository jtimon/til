mode test

// variadic args
variadic_sum := func(nums: ..I64) returns I64 {
    mut total := 0
    for n : I64 in nums {
        total = total.add(n)
    }
    return total
}

test_variadic := test() {
    assert_eq(__LOC__, variadic_sum(1, 2, 3), 6)
    assert_eq(__LOC__, variadic_sum(10), 10)
    assert_eq(__LOC__, variadic_sum(), 0)
}

// proc-based variadic test (not constant-foldable)
variadic_print := proc(nums: ..I64) {
    for i in 0..nums.len() {
        ref n: I64 = nums.get(i)!
        print(n.to_str())
        if i.lt(nums.len().sub(1)) { print(",") }
    }
    println("")
}

test_variadic_proc := test() {
    variadic_print(10, 20, 30)
}

// Variadic Str
variadic_concat := func(parts: ..Str) returns Str {
    mut result := ""
    for p : Str in parts {
        result = result.concat(p)
    }
    return result
}

test_variadic_str := test() {
    assert_eq_str(__LOC__, variadic_concat("a", "b", "c"), "abc")
    assert_eq_str(__LOC__, variadic_concat("hi"), "hi")
    assert_eq_str(__LOC__, variadic_concat(), "")
}

// #157: ..Str varargs auto-wrap non-Str args via T.to_str(). Allows
// `print(1+1)` etc. to work like Python while keeping types honest --
// types without a to_str method still error at the typer.
test_variadic_str_auto_to_str := test() {
    assert_eq_str(__LOC__, variadic_concat("x=", 42), "x=42")
    assert_eq_str(__LOC__, variadic_concat(1, "+", 2, "=", 3), "1+2=3")
    assert_eq_str(__LOC__, variadic_concat(true, " ", false), "true false")
    assert_eq_str(__LOC__, variadic_concat("ok=", true), "ok=true")
}

// Variadic Bool
variadic_all := func(flags: ..Bool) returns Bool {
    for f : Bool in flags {
        if f.not() { return false }
    }
    return true
}

test_variadic_bool := test() {
    assert(__LOC__, variadic_all(true, true, true))
    assert(__LOC__, variadic_all(true, false, true).not())
    // Empty variadic: vacuously true
    assert(__LOC__, variadic_all())
}

// Positional param + variadic tail
prefix_sum := func(prefix: I64, nums: ..I64) returns I64 {
    mut total := prefix
    for n : I64 in nums {
        total = total.add(n)
    }
    return total
}

test_variadic_with_positional := test() {
    assert_eq(__LOC__, prefix_sum(100, 1, 2, 3), 106)
    assert_eq(__LOC__, prefix_sum(100), 100)
    assert_eq(__LOC__, prefix_sum(0, 5), 5)
}

// Issue #186: a user-defined variadic call nested inside another
// variadic call (println). Before the fix the outer desugar wrapped
// only println's args into an Array, leaving the inner say(...) with
// raw args -- gcc rejected the call as "too many arguments".
say_flags := func(bools: ..Bool) returns Str {
    mut out := ""
    for b : Bool in bools { if b { out = out.concat("T") } else { out = out.concat("F") } }
    return out
}

bug186_variadic_nested_in_variadic := test() {
    assert_eq_str(__LOC__, say_flags(true, false, true), "TFT")
    // Nested user-defined variadic inside a variadic Str.concat-style
    // call: pass the result of one variadic into another variadic.
    assert_eq_str(__LOC__, variadic_concat(say_flags(true, false), say_flags(true)), "TFT")
}

// Sibling-position variant of #186 / #188: when a stmt contains
// multiple SIBLING variadic fcalls (i.e. peers in the same arg list,
// not nested inside one another), find_variadic_fcall returned only
// the first one in DFS order. The first got desugared into _va_Array_0
// + Array.set..., the rest stayed raw and gcc rejected them. The
// containing call doesn't have to be variadic itself for this to bite.
// Fix: after rewriting a variadic fcall, recurse process_call_desugars
// on stmt to catch any remaining sibling variadic fcalls.
add2_i64 := func(a: I64, b: I64) returns I64 { return a.add(b) }

bug189_sibling_variadic := test() {
    // add2_i64 is regular but takes two variadic-call results -- two
    // SIBLINGS in the same arg list.
    assert_eq(__LOC__, add2_i64(variadic_sum(1, 2), variadic_sum(3, 4)), 10)
    // Mixed: a sibling variadic alongside a raw arg.
    assert_eq(__LOC__, add2_i64(variadic_sum(1, 2, 3), 100), 106)
}

// --- merged from test/splat.til ---

sum := func(nums: ..I64) returns I64 {
    mut total := 0
    for n : I64 in nums {
        total = total.add(n)
    }
    return total
}

// Forward variadic to another variadic function
double_sum := func(nums: ..I64) returns I64 {
    return sum(..nums)
}

test_splat_forward := test() {
    assert_eq(__LOC__, double_sum(1, 2, 3), 6)
    assert_eq(__LOC__, double_sum(10), 10)
    assert_eq(__LOC__, double_sum(), 0)
}

// Splat an array into a variadic call
test_splat_array := test() {
    a := array("I64", 1, 2, 3)
    assert_eq(__LOC__, sum(..a), 6)
}

// Forward Str variadic to format
my_format := func(parts: ..Str) returns Str {
    return format(..parts)
}

test_splat_format := test() {
    assert_eq_str(__LOC__, my_format("hello", " ", "world"), "hello world")
}

test_splat_empty := test() {
    assert_eq(__LOC__, sum(), 0)
    assert_eq(__LOC__, double_sum(), 0)
    assert_eq_str(__LOC__, my_format(), "")
}
