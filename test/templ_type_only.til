mode test

import("imports/templ_type_only_a")
// b must be LOADED (it holds the second type-only CrossBox(I64)
// instantiation this dedup test needs) but nothing here reads its
// decls; the _-prefix opts out of the unused-import check.
_b := import("imports/templ_type_only_b")

RootTypeOnlyHolder := struct {
    box : CrossBox(I64)
}

test_templ_type_only_instantiation := test() {
    assert(RootTypeOnlyHolder.size().gt(0))
}
