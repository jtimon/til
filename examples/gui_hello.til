mode gui

main := proc() {
    init_window(800, 450, "hello from til!")
    set_target_fps(60)
    mut x := 0
    mut y := 0
    while window_should_close().not() {
        x = x.add(2)
        y = y.add(1)
        begin_drawing()
        clear_background(0, 0, 0, 255)
        draw_rectangle(x, y, 50, 50, 230, 41, 55, 255)
        end_drawing()
    }
    close_window()
}
