mode gui

main := proc() {
    TITLE := "hello from til!"
    InitWindow(800, 450, TITLE.c_str)
    SetTargetFPS(60)

    BLACK := Color(r = 0, g = 0, b = 0, a = 255)
    RED := Color(r = 230, g = 41, b = 55, a = 255)

    mut x : I32 = 0
    mut y : I32 = 0
    while !WindowShouldClose() {
        BeginDrawing()
        ClearBackground(BLACK)
        DrawRectangle(x, y, 50, 50, RED)
        EndDrawing()
        x++
        y--
    }
    CloseWindow()
}
