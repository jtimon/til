mode gui

push_line := func(lines: Vec, text: Str) {
    lines.push(own text.clone())
}

push_output := func(lines: Vec, output: Str) {
    if output.len() == 0 {
        push_line(lines, "")
        return
    }
    parts := output.split("\n")
    for p : Str in parts {
        push_line(lines, p)
    }
}

run_shell_command := proc(lines: Vec, cmd: Str) {
    push_line(lines, "$ ".concat(cmd))

    if cmd == "help" {
        push_line(lines, "help: run any shell command")
        push_line(lines, "clear: clear the terminal")
        return
    }

    mut out := ""
    ec := run_cmd(out, "sh", "-lc", cmd)

    push_output(lines, out)
    push_line(lines, format("[exit ", ec.to_str(), "]"))
}

main := proc(args: ..Str) {
    line_h : I32 = 18
    pad_x : I32 = 10
    pad_y : I32 = 10
    input_h : I32 = 36

    mut lines := Vec.new(Str)
    push_line(lines, "tilminal")
    push_line(lines, "type a shell command and press Enter")
    push_line(lines, "builtins: clear, help")
    push_line(lines, "")

    // Optional startup command: tilminal.til "<command>"
    if args.len() > 0 {
        ref startup_cmd : Str = args.get(0)
        if startup_cmd.len() > 0 {
            run_shell_command(lines, startup_cmd)
        }
    }

    mut input := ""

    SetConfigFlags(FLAG_WINDOW_RESIZABLE.to_u32())
    InitWindow(960, 640, "tilminal".c_str)
    SetWindowMinSize(320, 200)
    SetTargetFPS(60)

    while !WindowShouldClose() {
        // Enter: run command
        if IsKeyPressed(257) {
            if input.len() > 0 {
                cmd := input.clone()
                if cmd == "clear" {
                    mut fresh := Vec.new(Str)
                    lines = fresh
                } else {
                    run_shell_command(lines, cmd)
                }
                input = ""
            }
        }

        // Backspace
        if IsKeyPressed(259) {
            if input.len() > 0 {
                input = input.substr(0, input.len() - 1)
            }
        }

        // Character input (printable ASCII)
        mut ch := GetCharPressed()
        while ch > 0 {
            if ch >= 32 & ch < 127 {
                input = input.concat(Str.from_byte(ch.to_i64().to_u8()))
            }
            ch = GetCharPressed()
        }

        BeginDrawing()
        ClearBackground(Color(r = 10, g = 12, b = 16, a = 255))

        // Dynamic window dimensions
        w := GetScreenWidth()
        h := GetScreenHeight()

        // Output region
        out_h := h - input_h - pad_y * 2
        max_lines := out_h / line_h
        mut start : USize = 0
        if lines.len() > max_lines.to_usize() {
            start = lines.len() - max_lines.to_usize()
        }

        DrawRectangle(0, h - input_h, w, input_h, Color(r = 25, g = 28, b = 36, a = 255))

        mut row : I32 = 0
        mut i := start
        while i.lt(lines.len()) {
            if row >= max_lines { break }
            ref line : Str = lines.get(i)
            DrawText(line.c_str, pad_x, pad_y + row * line_h, 16, Color(r = 220, g = 220, b = 220, a = 255))
            row++
            i++
        }

        prompt := "$ ".concat(input)
        DrawText(prompt.c_str, pad_x, h - input_h + 10, 18, Color(r = 120, g = 255, b = 120, a = 255))
        DrawText("Enter=run  Esc=quit".c_str, w - 190, h - input_h + 12, 14, Color(r = 130, g = 130, b = 150, a = 255))

        EndDrawing()
    }

    CloseWindow()
}
